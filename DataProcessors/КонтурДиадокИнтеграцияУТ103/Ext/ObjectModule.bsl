// Получает структурированное представление адреса склада (места осуществления деятельности).
// У складов нет предопределенного вида адреса, поэтому выбираются сведения о первой записи
// в регистре "Контактная информация" с типом "Адрес", где владелец - указанный склад.
//
// Параметры:
//  Склад - СправочникСсылка.Склады - МОД (место осуществления деятельности)
// 
// Возвращаемое значение:
//  Структура, Неопределено - см. УПД970_НовыйСведенияОбАдресе
//
Функция УПД970_АдресСклада(Склад)
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", Склад);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	*
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация КАК Т
	|ГДЕ
	|	Т.Объект = &Объект
	|	И Т.Тип = &Тип
	|	И НЕ Т.Вид.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ПоляАдреса = НоваяЗаписьКонтактнойИнформации();
		ЗаполнитьЗначенияСвойств(ПоляАдреса, Выборка);
		
		ЗаполнитьТипыАдресныхОбъектов(ПоляАдреса);
		
		Если ЗначениеЗаполнено(ПоляАдреса.Значение) Тогда
			ДополнитьКонтактнуюИнформациюДаннымиJson(ПоляАдреса, Выборка.Значение, Выборка.Тип);
		КонецЕсли;
		
		УПД970_АдаптироватьПоляСтруктурыАдресов(ПоляАдреса);
		
		Результат = УПД970_НовыйСведенияОбАдресе();
		
		УПД970_ЗаполнитьСведенияОбАдресеПоДаннымРегистра(Результат, ПоляАдреса);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УПД970_АдаптироватьПоляСтруктурыАдресов(СведенияОбАдресе)
	
	ТипСтрока = Тип("Строка");
	
	Если ТипЗнч(СведенияОбАдресе.Страна) <> ТипСтрока Тогда
		СведенияОбАдресе.Страна = НРег(XMLСтрока(СведенияОбАдресе.Страна));
	КонецЕсли;
	
	Если ТипЗнч(СведенияОбАдресе.ТипДома) <> ТипСтрока Тогда
		СведенияОбАдресе.ТипДома = НРег(XMLСтрока(СведенияОбАдресе.ТипДома));
	КонецЕсли;
	
	Если ТипЗнч(СведенияОбАдресе.ТипКвартиры) <> ТипСтрока Тогда
		СведенияОбАдресе.ТипКвартиры = НРег(XMLСтрока(СведенияОбАдресе.ТипКвартиры));
	КонецЕсли;
	
	Если ТипЗнч(СведенияОбАдресе.ТипКорпуса) <> ТипСтрока Тогда
		СведенияОбАдресе.ТипКорпуса = НРег(XMLСтрока(СведенияОбАдресе.ТипКорпуса));
	КонецЕсли;
	
КонецПроцедуры

