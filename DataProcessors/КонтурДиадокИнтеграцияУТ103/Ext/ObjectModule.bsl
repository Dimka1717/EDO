Функция УПД970_ИсходныеДанныеДокументаСчетФактураВыданный(ДокСсылка)
	
	ТекстЗапросаРеквизиты = УПД970_ТекстЗапросаДанныхШапкиСчетФактураВыданный();
	ТекстЗапросаДанныхОДокументахОплаты = УПД970_ТекстЗапросаДанныхОДокументахОплатыСчетФактурыВыданный();
	ТекстЗапросаДокументыОснования = УПД970_ТекстЗапросаДокументовОснованияСчетФактураВыданный();
	
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(ТекстЗапросаРеквизиты);
	ТекстыЗапросов.Добавить(ТекстЗапросаДанныхОДокументахОплаты);
	ТекстыЗапросов.Добавить(ТекстЗапросаДокументыОснования);
	
	ТекстЗапроса = Ядро.СоединитьСтроку(ТекстыЗапросов, ТекстЗапроса_РазделительЗапросов());

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);

	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	Результат = УПД970_Контракт_ДанныеСчетФактураВыданный();
	
	ТабДанныеШапки = РезультатыЗапроса[0].Выгрузить();
	ДанныеШапки = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТабДанныеШапки[0]);
	
	СведенияОДокументахОплаты = РезультатыЗапроса[1].Выгрузить();
	ДокументыОснования = РезультатыЗапроса[2].Выгрузить().ВыгрузитьКолонку(0);
	
	ЭтоДоговорСКомитентом = (ДанныеШапки.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомитентом);
	ЭтоДоговорСКомиссионером = (ДанныеШапки.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером);
	
	Результат.ДанныеШапки = ДанныеШапки;
	Результат.СведенияОДокументахОплаты = СведенияОДокументахОплаты;
	Результат.ДокументыОснования = ДокументыОснования;
	Результат.ЭтоДоговорСКомитентом = ЭтоДоговорСКомитентом;
	Результат.ЭтоДоговорСКомиссионером = ЭтоДоговорСКомиссионером;
	Результат.ЭтоСчетФактураНаАванс = Ложь;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ИсходныеДанныеДокументаОснованияСчетаФактуры(ДокументСсылка, СчетФактура)

	Перем Результат;
	
	ТипДокумента = ТипЗнч(ДокументСсылка);

	Если ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаРеализацияТоваровУслуг(ДокументСсылка, СчетФактура);
		
	ИначеЕсли ЭтоИсправлениеРеализации(ДокументСсылка) Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаКорректировкаРеализации(ДокументСсылка, СчетФактура);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ОтчетКомитентуОПродажах") Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаОтчетКомитентуОПродажах(ДокументСсылка, СчетФактура);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаВозвратТоваровПоставщику(ДокументСсылка, СчетФактура);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщикуИзНТТ") Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаВозвратТоваровПоставщикуИзНТТ(ДокументСсылка, СчетФактура);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах") Тогда
		
		Результат = УПД970_ИсходныеДанныеДокументаОтчетКомиссионераОПродажах(ДокументСсылка, СчетФактура);
		
	Иначе
		
		ШаблонТекстаОшибки = НСтр("ru='Неподдерживаемый тип документа-основания счета-фактура выданный: %1'");
		
		ТекстОшибки = СтрШаблонЛок(ШаблонТекстаОшибки, ТипЗнч(ДокументСсылка));
		
		ВызватьИсключение ТекстОшибки;
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

