// Возвращает заполненную протоструктуру титула продавца в формате 970 по данным документа 1С
//
// Параметры:
//  ДокСсылка		 - ДокументСсылка - ссылка на учетный документ 1С,
//										по которому заполняется протоконтент титула продавца 970@
//  ФункцияДокумента - Строка - функция УПД (возможные значения: СЧФ, СЧФДОП, ДОП)
//  ДополнительныеПараметры	 - Структура - Модуль_Ядро.ДополнительныеПараметрыПолученияКонтента
// 
// Возвращаемое значение:
//  Структура - заполненный протоконтент УПД (см. Контракт_ПротоСтруктураУПД970)
//
Функция УПД970_КонтентТитулаПродавца(ДокСсылка, ФункцияДокумента, ДополнительныеПараметры) Экспорт
	
	Перем Результат;
	
	ТипДокумента = ТипЗнч(ДокСсылка);
	
	Если ТипДокумента = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
		
		Если ЭтоСчетФактураНаАванс(ДокСсылка) Тогда
			Результат = УПД970_КонтентТитулаПродавцаПоДокументуСчетФактураВыданныйНаАванс(
				ДокСсылка,
				ФункцияДокумента,
				ДополнительныеПараметры);
		Иначе
			Результат = УПД970_КонтентТитулаПродавцаПоДокументуСчетФактураВыданный(
				ДокСсылка,
				ФункцияДокумента,
				ДополнительныеПараметры);
		КонецЕсли;
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаПоДокументуРеализацияТоваровУслуг(
			ДокСсылка,
			ФункцияДокумента,
			ДополнительныеПараметры);
		
	ИначеЕсли ЭтоИсправлениеРеализации(ДокСсылка) Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаПоДокументуКорректировкаРеализации(
			ДокСсылка,
			ФункцияДокумента,
			ДополнительныеПараметры);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ОтчетКомитентуОПродажах") Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаПоДокументуОтчетКомитентуОПродажах(
			ДокСсылка,
			ФункцияДокумента,
			ДополнительныеПараметры);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаПоДокументуВозвратТоваровПоставщику(
			ДокСсылка,
			ФункцияДокумента,
			ДополнительныеПараметры);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщикуИзНТТ") Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаПоДокументуВозвратТоваровПоставщикуИзНТТ(
			ДокСсылка,
			ФункцияДокумента,
			ДополнительныеПараметры);
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		
		Результат = УПД970_КонтентТитулаПродавцаНаПеремещениеТоваров(
			ДокСсылка,
			ДополнительныеПараметры);
		
	Иначе
		
		ШаблонТекстаОшибки = НСтр("ru='Неподдерживаемый тип документа: %1'");
		
		ТекстОшибки = СтрШаблонЛок(ШаблонТекстаОшибки, ТипЗнч(ДокСсылка));
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

//} УПД970. Программный интерфейс

//{ УПД970. Заполнение протоструктуры по документам

Функция УПД970_КонтентТитулаПродавцаПоДокументуСчетФактураВыданный(
	СчетФактура,
	ФункцияДокумента,
	ДополнительныеПараметры)
	
	Перем Контент;
	
	ДанныеПоДокументу = УПД970_ИсходныеДанныеДокументаСчетФактураВыданный(СчетФактура);
	
	ДанныеШапки = ДанныеПоДокументу.ДанныеШапки;
	ДокументыОснования = ДанныеПоДокументу.ДокументыОснования;
	СведенияОДокументахОплаты = ДанныеПоДокументу.СведенияОДокументахОплаты;
	
	ДокументОснование = ДокументыОснования[0];
	
	ДанныеПоДокументуОснования = УПД970_ИсходныеДанныеДокументаОснованияСчетаФактуры(
		ДокументОснование,
		СчетФактура);
	
	ДанныеШапкиОснования = ДанныеПоДокументуОснования.ДанныеШапки;
	
	Контент = Контракт_ПротоструктураУПД970();
	
	Контент.Function = ФункцияДокумента;
	Контент.CircumFormatInvoice = УПД970_ОбстоятельстваФормированияДокумента(ДанныеПоДокументу, ФункцияДокумента);
	Контент.GovernmentContractInfo = ДанныеШапки.ИдентификаторГосКонтракта;

	Если ДанныеШапки.Исправление Тогда
		УПД970_ЗаполнитьДатуНомерДляИсправительногоДокумента(Контент, ДанныеШапки);
	Иначе
		УПД970_ЗаполнитьДатуНомер(Контент, ДанныеШапки);
	КонецЕсли;
		
	УПД970_ЗаполнитьСведенияОДокументахОплатыСчетаФактуры(
		Контент,
		СведенияОДокументахОплаты);
	
	ОснованияПередачиТоваров = УПД970_РеквизитыОснованияПередачиТоваровПоОснованиюСчетФактураВыданный(ДокументыОснования);
		
	УПД970_ЗаполнитьРеквизитыОснованияПередачиТоваров(Контент, ОснованияПередачиТоваров, ДополнительныеПараметры);
	
	УПД970_ЗаполнитьВалюту(Контент, ДанныеШапкиОснования);
	
	УПД970_ЗаполнитьСведенияОбУчастникахЭДО(Контент, ДанныеШапкиОснования);
	Если ЗначениеЗаполнено(ДанныеШапки.КППКонтрагента) Тогда
		Контент.Buyers[0].Kpp = ДанныеШапки.КППКонтрагента;
	КонецЕсли;
	
	УПД970_ЗаполнитьСоставителяДокументаПоДаннымПродавца(Контент);

	УПД970_ЗаполнитьТаблицуТоваровКонтентаПоДаннымДокумента(
		Контент,
		ДанныеПоДокументуОснования,
		ДополнительныеПараметры);
		
	Для Индекс = 1 По ДокументыОснования.ВГраница() Цикл
		
		ДокументОснование = ДокументыОснования[Индекс];
		
		ДанныеПоДокументуОснования = УПД970_ИсходныеДанныеДокументаОснованияСчетаФактуры(
			ДокументОснование,
			СчетФактура);
	
		УПД970_ЗаполнитьТаблицуТоваровКонтентаПоДаннымДокумента(
			Контент,
			ДанныеПоДокументуОснования,
			ДополнительныеПараметры);
		
	КонецЦикла;
	
	УПД970_ЗаполнитьСведенияДокументовОбОтгрузке(Контент, ДокументыОснования, ФункцияДокумента);

	УПД970_ЗаполнитьНаименованиеДокумента(Контент, ФункцияДокумента);
	
	УПД970_ЗаполнитьСведенияОСотруднике(Контент, ДополнительныеПараметры);
	
	УПД970_ЗаполнитьПризнакНаличияПрослеживаемыхТоваров(Контент);
	
	УПД970_ЗаполнитьСведенияОМаркировке(Контент, СчетФактура);

	Возврат Контент;
	
КонецФункции

Функция УПД970_КонтентТитулаПродавцаПоДокументуСчетФактураВыданныйНаАванс(
		ДокСсылка,
		ФункцияДокумента,
		ДополнительныеПараметры)
	
	Перем Контент;
	
	ДанныеПоДокументу = УПД970_ИсходныеДанныеДокументаСчетФактураВыданныйНаАванс(ДокСсылка);
	
	ДанныеШапки = ДанныеПоДокументу.ДанныеШапки;
	
	Контент = Контракт_ПротоструктураУПД970();
	
	Контент.Function = ФункцияДокумента;
	Контент.CircumFormatInvoice = УПД970_ОбстоятельстваФормированияДокумента(ДанныеПоДокументу, ФункцияДокумента);
	Контент.GovernmentContractInfo = ДанныеШапки.ИдентификаторГосКонтракта;
	
	УПД970_ЗаполнитьДатуНомер(Контент, ДанныеШапки);
	
	УПД970_ЗаполнитьСведенияОДокументахОплатыСчетаФактуры(
		Контент,
		ДанныеПоДокументу.СведенияОДокументахОплаты);
		
	УПД970_ЗаполнитьВалюту(Контент, ДанныеШапки);
		
	УПД970_ЗаполнитьСведенияОбУчастникахЭДО(Контент, ДанныеШапки);
	УПД970_ЗаполнитьСоставителяДокументаПоДаннымПродавца(Контент);
	
	УПД970_ЗаполнитьТаблицуКонтентаПоДаннымСчетФактураНаАванс(
		Контент,
		ДанныеПоДокументу.ТабличныеДанные,
		ДополнительныеПараметры);
	
	УПД970_ЗаполнитьПризнакНаличияПрослеживаемыхТоваров(Контент);
	
	Возврат Контент;
	
КонецФункции

Функция УПД970_КонтентТитулаПродавцаПоДокументуРеализацияТоваровУслуг(
	ДокСсылка,
	ФункцияДокумента,
	ДополнительныеПараметры)
	
	ДанныеПоДокументу = УПД970_ИсходныеДанныеДокументаРеализацияТоваровУслуг(ДокСсылка);
	
	ДанныеШапки = ДанныеПоДокументу.ДанныеШапки;
	
