Функция УПД970_ТекстЗапросаТабличныхДанныхДокументаКорректировкаРеализации()
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК Порядок,
	|	ТабТовары.Ссылка КАК Ссылка,
	|	ТабТовары.НомерСтроки КАК НомерСтроки,
	|	&ТипНоменклатурыТовар КАК ТипНоменклатуры,
	|	&ТоварыИдентификаторСтроки КАК ИдентификаторСтроки,
	|	""Товары"" КАК ИмяТабличнойЧасти,
	|	ТабТовары.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(СпрНоменклатура.НаименованиеПолное КАК СТРОКА(1000)) КАК НоменклатураПолноеНаименование,
	|	ВЫРАЗИТЬ(СпрНоменклатура.Наименование КАК СТРОКА(1000)) КАК НоменклатураНаименование,
	|	&КодИлиАртикулНоменклатуры КАК КодИлиАртикулНоменклатуры,
	|	ТабТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ТабТовары.СерияНоменклатуры КАК СерияНоменклатуры,
	|	&СтранаПроисхожденияСсылка КАК СтранаПроисхождения,
	|	&СтранаПроисхожденияКод КАК СтранаПроисхожденияКод,
	|	&СтранаПроисхожденияУчастникЕАЭС КАК СтранаПроисхожденияУчастникЕАЭС,
	|	ТабТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЕдиницыИзмерения.ЕдиницаПоКлассификатору.НаименованиеПолное КАК ЕдиницаИзмеренияНаименование,
	|	ЕдиницыИзмерения.ЕдиницаПоКлассификатору.Код КАК ЕдиницаИзмеренияКод,
	|	СерииНоменклатуры.НомерГТД.Код КАК НомерГТД,
	|	ТабТовары.Количество КАК Количество,
	|	ТабТовары.Цена КАК Цена,
	|	ТабТовары.СтавкаНДС КАК СтавкаНДС,
	|	ТабТовары.СуммаНДС КАК СуммаНДС,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.УчитыватьНДС
	|				И ДанныеШапки.СуммаВключаетНДС
	|			ТОГДА ТабТовары.Сумма - ТабТовары.СуммаНДС
	|		ИНАЧЕ ТабТовары.Сумма
	|	КОНЕЦ КАК СуммаБезНДС,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.УчитыватьНДС
	|				И НЕ ДанныеШапки.СуммаВключаетНДС
	|			ТОГДА ТабТовары.Сумма + ТабТовары.СуммаНДС
	|		ИНАЧЕ ТабТовары.Сумма
	|	КОНЕЦ КАК СуммаВсего,
	|	&ПрослеживаемыйТовар КАК ПрослеживаемыйТовар
	|ИЗ
	|	Документ.КорректировкаРеализации.Товары КАК ТабТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО ТабТовары.Номенклатура = СпрНоменклатура.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	|		ПО ТабТовары.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ПО ТабТовары.СерияНоменклатуры = СерииНоменклатуры.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации КАК ДанныеШапки
	|		ПО ТабТовары.Ссылка = ДанныеШапки.Ссылка
	|ГДЕ
	|	ТабТовары.Ссылка = &Ссылка
	|	И ТабТовары.Количество > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2 КАК Порядок,
	|	ТабУслуги.Ссылка КАК Ссылка,
	|	ТабУслуги.НомерСтроки КАК НомерСтроки,
	|	&ТипНоменклатурыУслуга КАК ТипНоменклатуры,
	|	&ПустаяСтрока КАК ИдентификаторСтроки,
	|	""Услуги"" КАК ИмяТабличнойЧасти,
	|	ТабУслуги.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТабУслуги.Содержание КАК СТРОКА(1000)) КАК НоменклатураПолноеНаименование,
	|	ВЫРАЗИТЬ(СпрНоменклатура.Наименование КАК СТРОКА(1000)) КАК НоменклатураНаименование,
	|	&КодИлиАртикулНоменклатуры КАК КодИлиАртикулНоменклатуры,
	|	&ПустаяХарактеристика КАК ХарактеристикаНоменклатуры,
	|	&ПустаяСерия КАК СерияНоменклатуры,
	|	&ПустаяСтрана КАК СтранаПроисхождения,
	|	&ПустаяСтрока КАК СтранаПроисхожденияКод,
	|	ЛОЖЬ КАК СтранаПроисхожденияУчастникЕАЭС,
	|	СпрНоменклатура.БазоваяЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СпрНоменклатура.БазоваяЕдиницаИзмерения.Представление КАК ЕдиницаИзмеренияНаименование,
	|	СпрНоменклатура.БазоваяЕдиницаИзмерения.Код КАК ЕдиницаИзмеренияКод,
	|	&ПустаяСтрока КАК НомерГТД,
	|	ТабУслуги.Количество КАК Количество,
	|	ТабУслуги.Цена КАК Цена,
	|	ТабУслуги.СтавкаНДС КАК СтавкаНДС,
	|	ТабУслуги.СуммаНДС КАК СуммаНДС,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.УчитыватьНДС
	|				И ДанныеШапки.СуммаВключаетНДС
	|			ТОГДА ТабУслуги.Сумма - ТабУслуги.СуммаНДС
	|		ИНАЧЕ ТабУслуги.Сумма
	|	КОНЕЦ КАК СуммаБезНДС,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.УчитыватьНДС
	|				И НЕ ДанныеШапки.СуммаВключаетНДС
	|			ТОГДА ТабУслуги.Сумма + ТабУслуги.СуммаНДС
	|		ИНАЧЕ ТабУслуги.Сумма
	|	КОНЕЦ КАК СуммаВсего,
	|	ЛОЖЬ КАК ПрослеживаемыйТовар
	|ИЗ
	|	Документ.КорректировкаРеализации.Услуги КАК ТабУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО ТабУслуги.Номенклатура = СпрНоменклатура.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации КАК ДанныеШапки
	|		ПО ТабУслуги.Ссылка = ДанныеШапки.Ссылка
	|ГДЕ
	|	ТабУслуги.Ссылка = &Ссылка
	|	И ТабУслуги.Количество > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	НомерСтроки";
	
	МетаданныеТЧ = Метаданные.Документы.КорректировкаРеализации.ТабличныеЧасти.Товары;
	
	ВыражениеТоварыИдентификаторСтроки = "ТабТовары.ИдентификаторСтроки";
	Если Не ЕстьРеквизитОбъектаЛок("ИдентификаторСтроки", МетаданныеТЧ) Тогда
		ВыражениеТоварыИдентификаторСтроки = """""";
	КонецЕсли;
	
	ВыражениеПрослеживаемыйТовар = "ТабТовары.ПрослеживаемыйТовар";
	Если Не ЕстьРеквизитОбъектаЛок("ПрослеживаемыйТовар", МетаданныеТЧ) Тогда
		ВыражениеПрослеживаемыйТовар = "ЛОЖЬ";
	КонецЕсли;
	
	ВыражениеСтранаСсылка = "ТабТовары.СтранаПроисхождения";
	ВыражениеСтранаКод = "ЕСТЬNULL(ТабТовары.СтранаПроисхождения.Код, """")";
	ВыражениеСтранаУчастникЕАЭС = "ЕСТЬNULL(ТабТовары.СтранаПроисхождения.УчастникЕАЭС, ЛОЖЬ)";
	
	Если Не ЕстьРеквизитОбъектаЛок("СтранаПроисхождения", МетаданныеТЧ) Тогда // 10.3.69 и ниже
		ВыражениеСтранаСсылка = "ЕСТЬNULL(ТабТовары.СерияНоменклатуры.СтранаПроисхождения, ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка))";
		ВыражениеСтранаКод = "ЕСТЬNULL(ТабТовары.СерияНоменклатуры.СтранаПроисхождения.Код, """")";
		ВыражениеСтранаУчастникЕАЭС = "ЛОЖЬ";
	КонецЕсли;
	
	ВыражениеКодИлиАртикул =
	"ВЫБОР
	|		КОГДА &ДопКолонкаПечатныхФорм = ЗНАЧЕНИЕ(Перечисление.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул)
	|			ТОГДА СпрНоменклатура.Артикул
	|		ИНАЧЕ СпрНоменклатура.Код
	|	КОНЕЦ";
	
	Замены = Новый СписокЗначений;
	Замены.Добавить("&ТоварыИдентификаторСтроки", ВыражениеТоварыИдентификаторСтроки);
	Замены.Добавить("&КодИлиАртикулНоменклатуры", ВыражениеКодИлиАртикул);
	Замены.Добавить("&СтранаПроисхожденияСсылка", ВыражениеСтранаСсылка);
	Замены.Добавить("&СтранаПроисхожденияКод", ВыражениеСтранаКод);
	Замены.Добавить("&СтранаПроисхожденияУчастникЕАЭС", ВыражениеСтранаУчастникЕАЭС);
	Замены.Добавить("&ПрослеживаемыйТовар", ВыражениеПрослеживаемыйТовар);
	Замены.Добавить("&СтавкаБезНДС", "ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНДС)");
	Замены.Добавить("&ПустаяХарактеристика", "ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)");
	Замены.Добавить("&ПустаяСерия", "ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)");
	Замены.Добавить("&ПустаяСтрана", "ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)");
	Замены.Добавить("&ПустойНомерГТД", "ЗНАЧЕНИЕ(Справочник.НомераГТД.ПустаяСсылка)");
	Замены.Добавить("&ПустаяСтрока", """""");
	
	Для Каждого Элемент Из Замены Цикл
		Результат = СтрЗаменить(Результат, Элемент.Значение, Элемент.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

