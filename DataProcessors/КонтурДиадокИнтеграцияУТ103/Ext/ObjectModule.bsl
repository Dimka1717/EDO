	|	ВложенныйЗапрос.СуммаНДС КАК СуммаНДС,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.Метка КАК Метка
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТабличнаяЧасть.Номенклатура КАК Номенклатура,
	|		ТабличнаяЧасть.Коэффициент КАК Коэффициент,
	|		ТабличнаяЧасть.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|		ТабличнаяЧасть.ЕдиницаИзмеренияМест КАК ЕдиницаИзмеренияМест,
	|		ТабличнаяЧасть.ЕдиницаИзмеренияМест.Коэффициент КАК КоэффициентМест,
	|		ТабличнаяЧасть.ХарактеристикаНоменклатуры КАК Характеристика,
	|		ТабличнаяЧасть.СерияНоменклатуры КАК Серия,
	|		ТабличнаяЧасть.СтавкаНДС КАК СтавкаНДС,
	|		ТабличнаяЧасть.Цена КАК Цена,
	|		ТабличнаяЧасть.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|		ТабличнаяЧасть.ПроцентАвтоматическихСкидок КАК ПроцентАвтоматическихСкидок,
	|		СУММА(ТабличнаяЧасть.Количество) КАК Количество,
	|		СУММА(ТабличнаяЧасть.КоличествоМест) КАК КоличествоМест,
	|		СУММА(ТабличнаяЧасть.Сумма) КАК Сумма,
	|		СУММА(ТабличнаяЧасть.СуммаНДС) КАК СуммаНДС,
	|		МИНИМУМ(ТабличнаяЧасть.НомерСтроки) КАК НомерСтроки,
	|		0 КАК Метка
	|	ИЗ
	|		Документ.КорректировкаРеализации.Товары КАК ТабличнаяЧасть
	|	ГДЕ
	|		ТабличнаяЧасть.Ссылка = &ТекущийДокумент
	|		И ТабличнаяЧасть.Количество > 0
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТабличнаяЧасть.Номенклатура,
	|		ТабличнаяЧасть.Коэффициент,
	|		ТабличнаяЧасть.ЕдиницаИзмерения,
	|		ТабличнаяЧасть.ЕдиницаИзмеренияМест,
	|		ТабличнаяЧасть.ХарактеристикаНоменклатуры,
	|		ТабличнаяЧасть.СерияНоменклатуры,
	|		ТабличнаяЧасть.СтавкаНДС,
	|		ТабличнаяЧасть.Цена,
	|		ТабличнаяЧасть.ПроцентСкидкиНаценки,
	|		ТабличнаяЧасть.ПроцентАвтоматическихСкидок,
	|		ТабличнаяЧасть.ЕдиницаИзмеренияМест.Коэффициент) КАК ВложенныйЗапрос
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТабличнаяЧасть.Номенклатура,
	|	NULL,
	|	&ПолеСодержание,
	|	ТабличнаяЧасть.Номенклатура.Код,
	|	ТабличнаяЧасть.Номенклатура.Артикул,
	|	ТабличнаяЧасть.Номенклатура.ЕдиницаХраненияОстатков.Представление,
	|	ТабличнаяЧасть.Номенклатура.ЕдиницаХраненияОстатков.ЕдиницаПоКлассификатору.Код,
	|	ТабличнаяЧасть.Номенклатура.ЕдиницаХраненияОстатков,
	|	NULL,
	|	NULL,
	|	0,
	|	NULL,
	|	NULL,
	|	ТабличнаяЧасть.СтавкаНДС,
	|	ТабличнаяЧасть.Цена,
	|	ВЫБОР
	|		КОГДА ТабличнаяЧасть.ПроцентСкидкиНаценки = 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ТабличнаяЧасть.Количество,
	|	NULL,
	|	ТабличнаяЧасть.ПроцентСкидкиНаценки + ТабличнаяЧасть.ПроцентАвтоматическихСкидок,
	|	ТабличнаяЧасть.Сумма,
	|	ТабличнаяЧасть.СуммаНДС,
	|	ТабличнаяЧасть.НомерСтроки,
	|	1
	|ИЗ
	|	Документ.КорректировкаРеализации.Услуги КАК ТабличнаяЧасть
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &ТекущийДокумент
	|	И ТабличнаяЧасть.Количество > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Метка,
	|	НомерСтроки";
	
	ПолеНоменклатураНаименование = ВыражениеНоменклатураНаименование("ВложенныйЗапрос");
	ПолеСодержание = ОбработкаТабличныхЧастей.ПолучитьЧастьЗапросаДляВыбораСодержания("ТабличнаяЧасть");
	
	Результат = СтрЗаменить(
		Результат,
		"&ПолеНоменклатураНаименование",
		ПолеНоменклатураНаименование
	);
	
	Результат = СтрЗаменить(
		Результат,
		"&ПолеСодержание",
		ПолеСодержание
	);
	
	Возврат Результат;
	
КонецФункции

Функция ВыражениеНоменклатураНаименование(ИмяТаблицыВыбора)
	
	СтрокаИмениТаблицыВыборки = "";
	Если Не ПустаяСтрока(ИмяТаблицыВыбора) Тогда
		
		СтрокаИмениТаблицыВыборки = ИмяТаблицыВыбора + ".";
		
	КонецЕсли;
	
	Результат =
	"ВЫБОР
	|		КОГДА НЕ (" + СтрокаИмениТаблицыВыборки + "Номенклатура.НаименованиеПолное Подобно """") ТОГДА
	|			ВЫРАЗИТЬ(" + СтрокаИмениТаблицыВыборки + "Номенклатура.НаименованиеПолное КАК Строка (1000))
	|		ИНАЧЕ
	|			" + СтрокаИмениТаблицыВыборки + "Номенклатура.Наименование
	|	КОНЕЦ";
	
	Возврат Результат;
	
КонецФункции

Функция ТипКонтентаUtd970()

	Возврат "utd970";
	
КонецФункции

Функция ЭтоСчетФактураВыданный(ДокументСсылка)

	Результат = (ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.СчетФактураВыданный"));
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоСчетФактураНаАванс(ДокументСсылка)

	Результат = Ложь;
	
	Если ЭтоСчетФактураВыданный(ДокументСсылка) Тогда
		
		ВидСчетаФактуры = ЗначениеРеквизитаОбъектаЛок(ДокументСсылка, "ВидСчетаФактуры");
		
		Результат = (ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.НаАванс
					Или ВидСчетаФактуры = Перечисления.ВидСчетаФактурыВыставленного.НаАвансКомитента);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоОтчетКомитентуОПродажах(ДокументСсылка)

	Результат = (ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетКомитентуОПродажах"));
	
	Возврат Результат;
	
КонецФункции

Функция СоединитьЭлементыАдресногоОбъекта(Элемент1, Элемент2)

	ЭлементыАдресногоОбъекта = Новый Массив;
	ЭлементыАдресногоОбъекта.Добавить(Элемент1);
	ЭлементыАдресногоОбъекта.Добавить(Элемент2);
	
	Результат = СокрЛП(СоединитьСтроку(ЭлементыАдресногоОбъекта, " "));
	
	Возврат Результат;
	
КонецФункции

Функция Общее_ВСтрокеТолькоЦифры(Строка)
	
	Результат = Истина;
	
	КодСимвола0 = КодСимвола("0");
	КодСимвола9 = КодСимвола("9");
	
	ДлинаСтроки = СтрДлина(Строка);
	
	Для Сч = 1 По ДлинаСтроки Цикл
		
		КодСимвола = КодСимвола(Строка, Сч);
		
		Если КодСимвола < КодСимвола0
			Или КодСимвола > КодСимвола9 Тогда
			Результат = Ложь;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

