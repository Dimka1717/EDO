Функция УПД970_ИсправляемыйДокументОтгрузки(ИсходныйДокумент)
	
	Если ЗначениеЗаполнено(ИсходныйДокумент)
		И ТипЗнч(ИсходныйДокумент) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		
		ДокументРеализации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсходныйДокумент, "ДокументРеализации");
		Результат = УПД970_ИсправляемыйДокументОтгрузки(ДокументРеализации);
		
	Иначе
		
		Результат = ИсходныйДокумент;
		
	КонецЕсли;
	
	Возврат Результат;

