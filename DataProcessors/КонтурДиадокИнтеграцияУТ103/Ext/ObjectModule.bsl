// Вызывается из МодульМенеджер.ЗначенияПолейМаршрутизацииПоПодразделениям.
// Переопределяет получение значений полей маршрутизации по документу 1С
//
// Параметры:
//	ПоляОтправителя		- Массив 			- значения полей маршрутизации в подразделение отправителя
//	ПоляПолучателя		- Массив 			- значения полей маршрутизации в подразделение получателя
//	Документ1С			- ДокументСсылка 	- документ пакета, для которого определяются значения полей
Процедура ЗаполнитьЗначенияПолейМаршрутизацииПоПодразделениям(ПоляОтправителя, ПоляПолучателя, Документ1С) Экспорт
	
	ТипСсылки = ТипЗнч(Документ1С);
	
	ЭтоСчетФактураВыданный = (ТипСсылки = Тип("ДокументСсылка.СчетФактураВыданный"));
	
	Если ЭтоСчетФактураВыданный Тогда
		
		ОснованияСФ = ДокументыОснованияСчетаФактуры(Документ1С);
		
		Если ОснованияСФ.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ИсточникДанных = ОснованияСФ[0];
		
	Иначе
		ИсточникДанных = Документ1С;
	КонецЕсли;
	
	МетаданныеИсточникаДанных = ИсточникДанных.Метаданные();
	
	ЕстьРеквизитПодразделение = Ядро.Общее_ЕстьРеквизитМетаданных(МетаданныеИсточникаДанных, "Подразделение");
	ЕстьРеквизитОрганизация = Ядро.Общее_ЕстьРеквизитМетаданных(МетаданныеИсточникаДанных, "Организация");
	ЕстьРеквизитКонтрагент = Ядро.Общее_ЕстьРеквизитМетаданных(МетаданныеИсточникаДанных, "Контрагент");
	ЕстьРеквизитСкладОтправитель = Ядро.Общее_ЕстьРеквизитМетаданных(МетаданныеИсточникаДанных, "СкладОтправитель");
	ЕстьРеквизитСкладПолучатель = Ядро.Общее_ЕстьРеквизитМетаданных(МетаданныеИсточникаДанных, "СкладПолучатель");
	
	ИменаРеквизитов = Новый Массив;
	
	Если ЕстьРеквизитСкладОтправитель Тогда
		ИменаРеквизитов.Добавить("СкладОтправитель");
	КонецЕсли;
	
	Если ЕстьРеквизитСкладПолучатель Тогда
		ИменаРеквизитов.Добавить("СкладПолучатель");
	КонецЕсли;
	
	Если ЕстьРеквизитПодразделение Тогда
		ИменаРеквизитов.Добавить("Подразделение");
	КонецЕсли;
	
	Если ЕстьРеквизитОрганизация Тогда
		ИменаРеквизитов.Добавить("Организация");
	КонецЕсли;
	
	Если ЕстьРеквизитКонтрагент Тогда
		ИменаРеквизитов.Добавить("Контрагент");
	КонецЕсли;
	
	Разделитель = ",";
	ТребуемыеРеквизиты = Ядро.СоединитьСтроку(ИменаРеквизитов, Разделитель);
	
	Если ЗначениеЗаполнено(ТребуемыеРеквизиты) Тогда
		Реквизиты = Ядро.Общее_ЗначенияРеквизитовОбъекта(ИсточникДанных, ТребуемыеРеквизиты);
	КонецЕсли;
	
	// В коллекции ПоляОтправителя и ПоляПолучателя индекс элементов соответствует приоритету этих элементов.
	// Чем меньше индекс, тем выше приоритет.
	
	Если ЕстьРеквизитСкладОтправитель И ЗначениеЗаполнено(Реквизиты.СкладОтправитель) Тогда
		ПоляОтправителя.Добавить(Реквизиты.СкладОтправитель);
	КонецЕсли;
	
	Если ЕстьРеквизитПодразделение И ЗначениеЗаполнено(Реквизиты.Подразделение) Тогда
		ПоляОтправителя.Добавить(Реквизиты.Подразделение);
	КонецЕсли;
	
	Если ЕстьРеквизитОрганизация И ЗначениеЗаполнено(Реквизиты.Организация) Тогда
		ПоляОтправителя.Добавить(Реквизиты.Организация);
	КонецЕсли;
	
	Если ЕстьРеквизитСкладПолучатель И ЗначениеЗаполнено(Реквизиты.СкладПолучатель) Тогда
		ПоляПолучателя.Добавить(Реквизиты.СкладПолучатель);
	КонецЕсли;
	
	Если ЕстьРеквизитКонтрагент И ЗначениеЗаполнено(Реквизиты.Контрагент) Тогда
		ПоляПолучателя.Добавить(Реквизиты.Контрагент);
	КонецЕсли;
	
КонецПроцедуры

// Функция находит документы-основания заданного счета-фактуры.
//
// Параметры:
//  СчетФактура - ДокументСсылка - счет-фактура, основание которой нужно найти;
// 
// Возвращаемое значение:
//  Массив - содержит ссылки на основания счета-фактуры.
//
Функция ДокументыОснованияСчетаФактуры(СчетФактура)
	
	Результат = Новый Массив;
	
	Если Не ЗначениеЗаполнено(СчетФактура) Тогда 
		Возврат Результат;
	КонецЕсли;
	
	Выборка = Ядро.Общее_ВыборкаДанныхОбъекта(СчетФактура, "ДокументыОснования", "ДокументОснование");
			
	Пока Выборка.Следующий() Цикл 
		
		ДокументОснование = Выборка.ДокументОснование;
		
		Если Результат.Найти(ДокументОснование) = Неопределено Тогда
			Результат.Добавить(ДокументОснование);
		КонецЕсли;
		
	КонецЦикла;
			
	Возврат Результат;
	
КонецФункции

