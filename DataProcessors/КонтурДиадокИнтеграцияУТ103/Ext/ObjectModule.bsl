Функция УПД970_КонтентТитулаПродавцаНаПеремещениеТоваров(СсылкаНаОбъект, ДополнительныеПараметры)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Шапка.Ссылка КАК Ссылка,
	|	Шапка.Номер КАК Номер,
	|	Шапка.Дата КАК Дата,
	|	Шапка.Организация КАК Организация,
	|	Шапка.Организация.НаименованиеПолное КАК ОрганизацияПредставление,
	|	Шапка.Организация.ИНН КАК ОрганизацияИНН,
	|	Шапка.Организация.КПП КАК ОрганизацияКПП,
	|	Шапка.СкладОтправитель КАК СкладОтправитель,
	|	Шапка.СкладОтправитель.Наименование КАК СкладОтправительПредставление,
	|	Шапка.СкладПолучатель КАК СкладПолучатель,
	|	Шапка.СкладПолучатель.Наименование КАК СкладПолучательПредставление,
	|	Шапка.Подразделение КАК Подразделение,
	|	Шапка.Подразделение.Наименование КАК ПодразделениеПредставление
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК Шапка
	|ГДЕ
	|	Шапка.Ссылка = &СсылкаНаОбъект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТЧ.Ссылка КАК Ссылка,
	|	ТЧ.НомерСтроки КАК НомерСтроки,
	|	ТЧ.Номенклатура КАК Номенклатура,
	|	ТЧ.Номенклатура.Код КАК НоменклатураКод,
	|	ТЧ.Номенклатура.Артикул КАК НоменклатураАртикул,
	|	ТЧ.Номенклатура.НаименованиеПолное КАК НоменклатураПредставление,
	|	&СтавкаБезНДС КАК СтавкаНДС,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.НомерГТД, &ПустойНомерГТД) КАК НомерГТД,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.НомерГТД.Код, """") КАК ПолныйНомерГТД,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.НомерГТД.РегистрационныйНомер, """") КАК РегистрационныйНомерГТД,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.СтранаПроисхождения, &ПустаяСтранаПроисхождения) КАК СтранаПроисхождения,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.СтранаПроисхождения.Код, """") КАК СтранаПроисхожденияКод,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.СтранаПроисхождения.Наименование, """") КАК СтранаПроисхожденияНаименование,
	|	&СтранаПроисхожденияУчастникЕАЭС КАК СтранаПроисхожденияУчастникЕАЭС,
	|	ТЧ.ХарактеристикаНоменклатуры КАК Характеристика,
	|	ЕСТЬNULL(ТЧ.ХарактеристикаНоменклатуры.Наименование, """") КАК ХарактеристикаПредставление,
	|	ТЧ.СерияНоменклатуры КАК Серия,
	|	ЕСТЬNULL(ТЧ.СерияНоменклатуры.Наименование, """") КАК СерияПредставление,
	|	ТЧ.ЕдиницаИзмерения КАК Упаковка,
	|	ЕСТЬNULL(ТЧ.ЕдиницаИзмерения.ЕдиницаПоКлассификатору, &ПустаяЕдиница) КАК ЕдиницаИзмерения,
	|	ЕСТЬNULL(ТЧ.ЕдиницаИзмерения.ЕдиницаПоКлассификатору.Код, """") КАК ЕдиницаИзмеренияКод,
	|	ЕСТЬNULL(ТЧ.ЕдиницаИзмерения.ЕдиницаПоКлассификатору.Наименование, """") КАК ЕдиницаИзмеренияНаименование,
	|	ТЧ.Цена КАК Цена,
	|	ТЧ.Количество КАК Количество,
	|	ТЧ.Цена * ТЧ.Количество КАК Сумма,
	|	1 КАК Порядок
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ТЧ
	|ГДЕ
	|	ТЧ.Ссылка = &СсылкаНаОбъект
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТЧ.Ссылка,
	|	ТЧ.НомерСтроки,
	|	ТЧ.Номенклатура,
	|	ТЧ.Номенклатура.Код,
	|	ТЧ.Номенклатура.Артикул,
	|	ТЧ.Номенклатура.НаименованиеПолное,
	|	&СтавкаБезНДС,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	ТЧ.Номенклатура.БазоваяЕдиницаИзмерения,
	|	ЕСТЬNULL(ТЧ.Номенклатура.БазоваяЕдиницаИзмерения, &ПустаяЕдиница),
	|	ЕСТЬNULL(ТЧ.Номенклатура.БазоваяЕдиницаИзмерения.Код, """"""""),
	|	ЕСТЬNULL(ТЧ.Номенклатура.БазоваяЕдиницаИзмерения.Наименование, """"""""),
	|	0,
	|	ТЧ.Количество,
	|	0,
	|	2
	|ИЗ
	|	Документ.ПеремещениеТоваров.ВозвратнаяТара КАК ТЧ
	|ГДЕ
	|	ТЧ.Ссылка = &СсылкаНаОбъект
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	Ссылка,
	|	НомерСтроки";
	
	СтранаПроисхожденияУчастникЕАЭС = "ЕСТЬNULL(ТЧ.СерияНоменклатуры.СтранаПроисхождения.УчастникЕАЭС, ЛОЖЬ)";
	
	Если Не ЕстьРеквизитОбъектаЛок("УчастникЕАЭС", Метаданные.Справочники.КлассификаторСтранМира) Тогда // 10.3.69 и ниже
		СтранаПроисхожденияУчастникЕАЭС = "ЛОЖЬ";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&СтранаПроисхожденияУчастникЕАЭС", СтранаПроисхожденияУчастникЕАЭС);
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("СсылкаНаОбъект", СсылкаНаОбъект);
	Запрос.УстановитьПараметр("ПустаяЕдиница", Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустойНомерГТД", Справочники.НомераГТД.ПустаяСсылка());
	Запрос.УстановитьПараметр("ПустаяСтранаПроисхождения", Справочники.КлассификаторСтранМира.ПустаяСсылка());
	Запрос.УстановитьПараметр("СтавкаБезНДС", Перечисления.СтавкиНДС.БезНДС);
	
	Данные = Запрос.ВыполнитьПакет();
	
	Шапка = Данные[0].Выбрать();
	Шапка.Следующий();
	
	Валюта = ВалютаРегламентированногоУчета();
	ФункцияДокумента = ФункцияДокументаУПД_ДОП();
	ДокументыОтгрузки = ЗначениеВМассив(СсылкаНаОбъект);
	НаименованияДокументов = НаименованияДокументовОтгрузки();
	
	Контент = Контракт_ПротоструктураУПД970();
	Контент.Function = ФункцияДокумента;
	Контент.CircumFormatInvoice = "00051";
	Контент.DocumentNumber = ПредставлениеНомера(СсылкаНаОбъект);
	Контент.DocumentDate = Шапка.Дата;
	Контент.DocumentName = НаименованияДокументов.УПД;
	Контент.Currency = Валюта.Код;
	
	DocumentShipment = УПД970_НовыйDocumentShipments970(
		Контент.DocumentName,
		Контент.DocumentNumber,
		Контент.DocumentDate
	);
	
	Контент.DocumentShipments.Добавить(DocumentShipment);
	
	ПродавецИнфо = УПД970_ДанныеУчастникаЭДО(Шапка.Организация, Шапка.Дата);
	Seller = Контракт_ExtendedOrganizationInfo970();
	УПД970_ЗаполнитьExtendedOrganizationInfo(Seller, ПродавецИнфо);
	Контент.Sellers.Добавить(Seller);
	
	ПокупательИнфо = ОбщегоНазначения.СкопироватьРекурсивно(ПродавецИнфо);
	Buyer = Контракт_ExtendedOrganizationInfo970();
	УПД970_ЗаполнитьExtendedOrganizationInfo(Buyer, ПокупательИнфо);
	Контент.Buyers.Добавить(Buyer);
	
	ГрузоотправительИнфо = ОбщегоНазначения.СкопироватьРекурсивно(ПродавецИнфо);
	ГрузоотправительИнфо.Адрес = УПД970_АдресСклада(Шапка.СкладОтправитель);
	Shipper = Контракт_Shipper970();
	Shipper.SameAsSeller = Ложь;
	Shipper.OrganizationInfo = Контракт_ExtendedOrganizationInfo970();
	УПД970_ЗаполнитьExtendedOrganizationInfo(Shipper.OrganizationInfo, ГрузоотправительИнфо);
	Shipper.OrganizationInfo.Department = Шапка.СкладОтправительПредставление;
	Контент.Shippers.Добавить(Shipper);
	
	ГрузополучательИнфо = ОбщегоНазначения.СкопироватьРекурсивно(ПродавецИнфо);
	ГрузополучательИнфо.Адрес = УПД970_АдресСклада(Шапка.СкладПолучатель);
	Consignee = Контракт_ExtendedOrganizationInfo970();
	УПД970_ЗаполнитьExtendedOrganizationInfo(Consignee, ГрузополучательИнфо);
	Consignee.Department = Шапка.СкладПолучательПредставление;
	Контент.Consignees.Добавить(Consignee);
	
	Table = Контракт_InvoiceTable970();
	Контент.Table = Table;
	РезультатТовары = Данные[1].Выгрузить();
	
	ТочностьКоличества = 3;
	ТипыНоменклатуры = ГенерацияXML.Перечисление_ItemMarks();
	ДопКолонка = Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить();
	
	ВсеСтрокиБезНДС = Истина;
	
	Для Каждого ДанныеТЧ Из РезультатТовары Цикл
		
		Item = Контракт_Item970();
		
		Item.Product = ПредставлениеНоменклатурыЛок(ДанныеТЧ.НоменклатураПредставление, ДанныеТЧ.ХарактеристикаПредставление, "");
		Item.ItemMark = ТипыНоменклатуры.Имущество;
		
		Если ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул Тогда
			Item.ItemVendorCode = ДанныеТЧ.НоменклатураАртикул;
		ИначеЕсли ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
			Item.ItemVendorCode = ДанныеТЧ.НоменклатураКод;
		Иначе
			Item.ItemVendorCode = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТЧ.ЕдиницаИзмеренияНаименование) Тогда
			Item.UnitName = СокрЛП(ДанныеТЧ.ЕдиницаИзмеренияНаименование);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТЧ.ЕдиницаИзмеренияКод) Тогда
			Item.Unit = СокрЛП(ДанныеТЧ.ЕдиницаИзмеренияКод);
		КонецЕсли;
		
		Item.Quantity = 0;
		Если ЗначениеЗаполнено(ДанныеТЧ.Количество) Тогда
			Item.Quantity = Окр(ДанныеТЧ.Количество, ТочностьКоличества);
		КонецЕсли;
		
		Item.TaxRate = ПредставлениеСтавкиНДС(ДанныеТЧ.СтавкаНДС);
		Item.WithoutVat = XMLСтрока(ДанныеТЧ.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС);
		Если ДанныеТЧ.СтавкаНДС <> Перечисления.СтавкиНДС.БезНДС Тогда
			ВсеСтрокиБезНДС = Ложь;
		КонецЕсли;
		
		УПД970_ЗаполнитьСведенияОТаможеннойДекларации(Item, ДанныеТЧ);
		
		Item.Price = ДанныеТЧ.Цена;
		Item.Vat = 0;
		Item.Subtotal = ДанныеТЧ.Сумма;
		Item.SubtotalWithVatExcluded = Item.Subtotal - Item.Vat;
		
		СлужебнаяИнфо = Контракт_СлужебнаяИнформацияСтроки();
		СлужебнаяИнфо.ЕдиницаИзмерения = ДанныеТЧ.ЕдиницаИзмерения;
		СлужебнаяИнфо.Номенклатура = ДанныеТЧ.Номенклатура;
		СлужебнаяИнфо.СтранаПроисхождения = ДанныеТЧ.СтранаПроисхождения;
		СлужебнаяИнфо.СтавкаНДС = ДанныеТЧ.СтавкаНДС;
		СлужебнаяИнфо.НомерГТД = ДанныеТЧ.НомерГТД;
		СлужебнаяИнфо.ПрослеживаемыйТовар = Ложь;
		СлужебнаяИнфо.Серия = ДанныеТЧ.Серия;
		СлужебнаяИнфо.Характеристика = ДанныеТЧ.Характеристика;
		СлужебнаяИнфо.ДокументОтгрузки = СсылкаНаОбъект;
		
		Item.СлужебнаяИнформация = СлужебнаяИнфо;
		
		Table.Items.Добавить(Item);
		
	КонецЦикла;
	
	Table.TotalNet = РезультатТовары.Итог("Количество");
	Table.WithoutVat = XMLСтрока(ВсеСтрокиБезНДС);
	Table.Vat = 0;
	Table.Total = РезультатТовары.Итог("Сумма");
	Table.TotalWithVatExcluded = Table.Total - Table.Vat;
	
	TransferInfo = Контракт_TransferInfo970();
	TransferInfo.WithoutTransferBase = Истина;
	TransferInfo.OperationInfo = "Товары переданы, работы сданы, услуги оказаны";
	Контент.TransferInfo = TransferInfo;
	
	УПД970_ЗаполнитьСведенияОСотруднике(Контент, ДополнительныеПараметры);
	УПД970_ЗаполнитьДатуОтгрузки(Контент);
	УПД970_ЗаполнитьПризнакНаличияПрослеживаемыхТоваров(Контент);
	УПД970_ЗаполнитьСведенияОМаркировке(Контент, СсылкаНаОбъект);
	УПД970_ЗаполнитьСоставителяДокументаПоДаннымПродавца(Контент);
	
	Возврат Контент;
	
КонецФункции

//{ УПД970. Заполнение протоструктуры по документам. Общее

Процедура УПД970_ЗаполнитьДатуНомер(Контент, ДанныеШапки)

	Контент.DocumentNumber = ПредставлениеНомера(ДанныеШапки.Ссылка);
	Контент.DocumentDate = ДанныеШапки.Дата;

КонецПроцедуры

Процедура УПД970_ЗаполнитьДатуНомерДляИсправительногоДокумента(Контент, ДанныеШапки)

	Контент.RevisionNumber = ДанныеШапки.НомерИсправления;
	Контент.RevisionDate = ДанныеШапки.Дата;
	
	Контент.DocumentNumber = УПД970_НомерИсходногоДокументаИсправительногоСчетФактураВыданный(ДанныеШапки);
	Контент.DocumentDate = УПД970_ДатаИсходногоДокументаИсправительногоСчетФактураВыданный(ДанныеШапки);

КонецПроцедуры

Процедура УПД970_ЗаполнитьВалюту(Контент, ДанныеШапки)
	
	Валюта = ДанныеШапки.ВалютаДокумента;
	
	Контент.Currency = Валюта.Код;

КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияДокументовОбОтгрузке(Контент, КоллекцияДокументов, ФункцияДокумента)
	
	ДокументыОтгрузки = УПД970_ДокументыОтгрузки(КоллекцияДокументов);
	
	СтрокиТаблицы = Контент.Table.Items;
	
	НаименованиеДокумента = УПД790_НаименованиеДокументаОтгрузки(СтрокиТаблицы, ДокументыОтгрузки, ФункцияДокумента);
	
	Если ФункцияДокумента = ФункцияДокументаУПД_СЧФ() Тогда
		
		РеквизитыДокументовОтгрузки = Общее_ЗначенияРеквизитовОбъектов(ДокументыОтгрузки, "Дата");
		
		Для Каждого КлючЗначение Из РеквизитыДокументовОтгрузки Цикл
			
			ДокументОтгрузки = КлючЗначение.Ключ;
			РеквизитыДокумента = КлючЗначение.Значение;
			
			НомерДокумента = ПредставлениеНомера(ДокументОтгрузки);
			ДатаДокумента = РеквизитыДокумента.Дата;
			
			DocumentShipment = УПД970_НовыйDocumentShipments970(НаименованиеДокумента, НомерДокумента, ДатаДокумента);
			Контент.DocumentShipments.Добавить(DocumentShipment);
		
		КонецЦикла;
		
	Иначе
		
		НомерДокумента = Контент.DocumentNumber;
		ДатаДокумента = Контент.DocumentDate;
		
		DocumentShipment = УПД970_НовыйDocumentShipments970(НаименованиеДокумента, НомерДокумента, ДатаДокумента);
		Контент.DocumentShipments.Добавить(DocumentShipment);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОДокументахОплатыСчетаФактуры(Контент, СведенияОДокументахОплаты)
	
	Для Каждого СтрокаТаблицы Из СведенияОДокументахОплаты Цикл
		
		PaymentDocument = Контракт_PaymentDocumentInfo();
		
		PaymentDocument.Number = СтрокаТаблицы.НомерДокумента;
		PaymentDocument.Date = СтрокаТаблицы.ДатаДокумента;
		
		Контент.PaymentDocuments.Добавить(PaymentDocument);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьРеквизитыОснованияПередачиТоваров(
	Контент,
	ОснованияПередачиТоваров,
	ДополнительныеПараметры)
	
	Перем УказыватьОтсутствиеОснованияУПД;
	
	TransferInfo = Контракт_TransferInfo970();
	Контент.TransferInfo = TransferInfo;
	
	TransferInfo.OperationInfo = "Товары переданы, работы сданы, услуги оказаны";
	
	ДополнительныеПараметры.Свойство("УказыватьОтсутствиеОснованияУПД", УказыватьОтсутствиеОснованияУПД);
	
	Для Каждого РеквизитыОснования Из ОснованияПередачиТоваров Цикл
		
		РеквизитыЗаполнены = УПД970_РеквизитыОснованияЗаполнены(РеквизитыОснования);
		
		Если Не РеквизитыЗаполнены
			И УказыватьОтсутствиеОснованияУПД = Истина Тогда
			
			TransferInfo.TransferBases.Очистить();
			Прервать;
			
		Иначе
			
			TransferBase = УПД970_НовыйTransferBase(РеквизитыОснования);
			TransferInfo.TransferBases.Добавить(TransferBase);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если TransferInfo.TransferBases.Количество() = 0 Тогда
		TransferInfo.WithoutTransferBase = Истина;
	КонецЕсли;

	УПД970_ЗаполнитьДатуОтгрузки(Контент);
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьДатуОтгрузки(Контент)

	Если Контент.Function <> ФункцияДокументаУПД_СЧФ() Тогда
		
		ДатаОтгрузки = Контент.DocumentDate;
		
		Для Каждого DocumentShipment Из Контент.DocumentShipments Цикл
			ДатаОтгрузки = DocumentShipment.Date;
			Прервать;
		КонецЦикла;
		
		Контент.TransferInfo.TransferDate = ДатаОтгрузки;
		
	КонецЕсли;

КонецПроцедуры

Процедура УПД970_ЗаполнитьНаименованиеДокумента(Контент, ФункцияДокумента)
	
	Если ФункцияДокумента <> ФункцияДокументаУПД_СЧФ()
		И Контент.DocumentShipments.Количество() > 0 Тогда
		Контент.DocumentName = Контент.DocumentShipments[0].Name;
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОбУчастникахЭДО(Контент, ДанныеШапки)
	
	СведенияОбУчастникахЭДО = УПД970_СведенияОбУчастникахЭДО(ДанныеШапки);
	
	Seller = Контракт_ExtendedOrganizationInfo970();
	Контент.Sellers.Добавить(Seller);
	УПД970_ЗаполнитьExtendedOrganizationInfo(Seller, СведенияОбУчастникахЭДО.Организация);
	Seller.СлужебнаяИнформация.Ссылка = СведенияОбУчастникахЭДО.Организация.Ссылка;
	
	Buyer = Контракт_ExtendedOrganizationInfo970();
	Контент.Buyers.Добавить(Buyer);
	УПД970_ЗаполнитьExtendedOrganizationInfo(Buyer, СведенияОбУчастникахЭДО.Контрагент);
	Buyer.СлужебнаяИнформация.Ссылка = СведенияОбУчастникахЭДО.Контрагент.Ссылка;
	
	Грузоотправитель = СведенияОбУчастникахЭДО.Грузоотправитель;
	Если Грузоотправитель <> Неопределено Тогда
		
		Shipper = Контракт_Shipper970();
		Shipper.SameAsSeller = Ложь;
		
		Контент.Shippers.Добавить(Shipper);
		
		Если Грузоотправитель.Ссылка = СведенияОбУчастникахЭДО.Организация.Ссылка Тогда
			
			Shipper.SameAsSeller = Истина;
			
		Иначе
			
			ShipperInfo = Контракт_ExtendedOrganizationInfo970();
			Shipper.OrganizationInfo = ShipperInfo;
			
			УПД970_ЗаполнитьExtendedOrganizationInfo(ShipperInfo, Грузоотправитель);
			
			ShipperInfo.СлужебнаяИнформация.Ссылка = Грузоотправитель.Ссылка;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если СведенияОбУчастникахЭДО.Грузополучатель <> Неопределено Тогда
		
		Consignee = Контракт_ExtendedOrganizationInfo970();
		Контент.Consignees.Добавить(Consignee);

		УПД970_ЗаполнитьExtendedOrganizationInfo(Consignee, СведенияОбУчастникахЭДО.Грузополучатель);
		
		Consignee.СлужебнаяИнформация.Ссылка = СведенияОбУчастникахЭДО.Грузополучатель.Ссылка;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьExtendedOrganizationInfo(Content, ДанныеУчастникаЭДО)
	
	Content.Type = УПД970_ExtendedOrganizationInfoType(ДанныеУчастникаЭДО);
	
	Content.Name = ДанныеУчастникаЭДО.Наименование;
	
	Content.Inn = ДанныеУчастникаЭДО.ИНН;
	Content.Kpp = ДанныеУчастникаЭДО.КПП;
	Content.Okpo = ДанныеУчастникаЭДО.КодПоОКПО;
	
	Content.IndividualEntityRegistrationCertificate = ДанныеУчастникаЭДО.Свидетельство;
	
	Content.IndividualEntityRegistrationNumber = ДанныеУчастникаЭДО.ОГРНИП;
	Content.IndividualEntityRegistrationDate = ДанныеУчастникаЭДО.ДатаОГРНИП;
	
	Content.LegalEntityId = ДанныеУчастникаЭДО.НалоговыйНомерВСтранеРегистрации;
	
	Content.Country = ДанныеУчастникаЭДО.СтранаНаименование;
	Content.CountryCode = ДанныеУчастникаЭДО.СтранаКод;
	
	Если ЗначениеЗаполнено(ДанныеУчастникаЭДО.Телефоны) Тогда
		Content.Phone.Добавить(ДанныеУчастникаЭДО.Телефоны);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеУчастникаЭДО.ЭлектроннаяПочта) Тогда
		Content.Email.Добавить(ДанныеУчастникаЭДО.ЭлектроннаяПочта);
	КонецЕсли;
	
	Content.BankName = ДанныеУчастникаЭДО.НаименованиеБанка;
	Content.BankAccountNumber = ДанныеУчастникаЭДО.НомерСчета;
	Content.CorrespondentAccount = ДанныеУчастникаЭДО.КоррСчет;
	Content.BankId = ДанныеУчастникаЭДО.БИК;
	
	УПД970_ЗаполнитьAddressInfo(Content, ДанныеУчастникаЭДО.Адрес);
	
	Content.СлужебнаяИнформация.Ссылка = ДанныеУчастникаЭДО.Ссылка;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьAddressInfo(OrganizationInfo, СведенияОбАдресе)
	
	Если Не ЗначениеЗаполнено(СведенияОбАдресе) Тогда
		Возврат;
	КонецЕсли;
	
	AddressInfo = Контракт_AddressInfo970();
	OrganizationInfo.Address = AddressInfo;
	
	ВидыАдресов = ГенерацияXML.Перечисление_ВидыАдресов();
	
	ЭтоАдресВФорматеРФ = ЭтоАдресВФорматеАдрРФ(СведенияОбАдресе);
	
	Если ЭтоАдресВФорматеРФ Тогда
		
		AddressRF = УПД970_ЗаполненныйAddressRF(СведенияОбАдресе);
		
		AddressInfo.AddressRF = AddressRF;
		AddressInfo.Type = ВидыАдресов.АдресРФ;
		
	Иначе
		
		AddressText = УПД970_ЗаполненныйAddressText(СведенияОбАдресе);
		
		AddressInfo.AddressText = AddressText;
		AddressInfo.Type = ВидыАдресов.АдресСтрокой;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоАдресВФорматеАдрРФ(СведенияОбАдресе)
	
	Результат = Ложь;
	
	Если НЕ ЭтоАдминистративноТерриториальныйАдресЛок(СведенияОбАдресе.ТипАдреса)
		ИЛИ НЕ ЗначениеЗаполнено(СведенияОбАдресе.КодРегиона) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Если СведенияОбАдресе.Корпуса.Количество() > 1
		ИЛИ СведенияОбАдресе.Помещения.Количество() > 1 Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.Корпуса)
		И ВРЕГ(СведенияОбАдресе.Корпуса[0].ТипКорпуса) <> ВРЕГ(ТипКорпусаАдрРФ()) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.Помещения)
		И ВРЕГ(СведенияОбАдресе.Помещения[0].ТипПомещения) <> ВРЕГ(ТипПомещенияАдрРФ()) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ТипКорпусаАдрРФ()
	
	Возврат "Корпус";
	
КонецФункции

Функция ТипПомещенияАдрРФ()
	
	Возврат "Квартира";
	
КонецФункции

Процедура УПД970_ЗаполнитьТаблицуТоваровКонтентаПоДаннымДокумента(Контент, ДанныеПоДокументу, ДополнительныеПараметры)
	
	Перем СведенияПрослеживаемости;
	
	ТабличныеДанные = ДанныеПоДокументу.ТабличныеДанные;
	ДанныеПоДокументу.Свойство("СведенияПрослеживаемости", СведенияПрослеживаемости);
	
	ТочностьЦены = ДополнительныеПараметры.ТочностьЦены;
	ТочностьКоличества = ДополнительныеПараметры.ТочностьКоличества;
	
	ВсеСтрокиБезНДС = Истина;
	
	Если Контент.Table = Неопределено Тогда
		Table = Контракт_InvoiceTable970();
		Контент.Table = Table;
	Иначе
		Table = Контент.Table;
	КонецЕсли;

	Для Каждого СтрокаТаблицы Из ТабличныеДанные Цикл
		
		Если Контент.Function <> ФункцияДокументаУПД_ДОП()
			И СтрокаТаблицы.ТипНоменклатуры = УПД970_ТипНоменклатурыВозвратнаяТара() Тогда
			Продолжить;
		КонецЕсли;
			
		Item = Контракт_Item970();
		
		УПД970_ЗаполнитьОсновныеСведенияОНоменклатуре(Item, СтрокаТаблицы);
		
		Item.Quantity = 0;
		Если ЗначениеЗаполнено(СтрокаТаблицы.Количество) Тогда
			Item.Quantity = Окр(СтрокаТаблицы.Количество, ТочностьКоличества);
		КонецЕсли;
		
		ПредставлениеСтавки = ПредставлениеСтавкиНДС(СтрокаТаблицы.СтавкаНДС);
			
		Item.TaxRate = ПредставлениеСтавки;
		
		ЭтоСтавкаБезНДС = (Item.TaxRate = ПредставлениеСтавкиБезНДС());
		Item.WithoutVat = XMLСтрока(ЭтоСтавкаБезНДС);
		
		Item.Price = УПД970_ЦенаБезНДС(СтрокаТаблицы, ТочностьЦены);
		
		Item.Vat = СтрокаТаблицы.СуммаНДС;
		Item.Subtotal = СтрокаТаблицы.СуммаВсего;
		
		Item.SubtotalWithVatExcluded = СтрокаТаблицы.СуммаБезНДС;
		
		УПД970_ЗаполнитьДополнительныеСведенияОНоменклатуре(
			Item,
			СтрокаТаблицы,
			СведенияПрослеживаемости);
			
		Item.СлужебнаяИнформация = УПД970_ЗаполненныйСлужебнаяИнформацияItem(СтрокаТаблицы);
		
		Table.Items.Добавить(Item);
		
		Если НЕ ЭтоСтавкаБезНДС Тогда
			ВсеСтрокиБезНДС = Ложь;
		КонецЕсли;
		
		УПД970_ПерерассчитатьИтоговыеЗначенияТаблицы(Table, Item);

	КонецЦикла;
	
	Table.WithoutVat = XMLСтрока(ВсеСтрокиБезНДС);	
	
КонецПроцедуры

Процедура УПД970_ПерерассчитатьИтоговыеЗначенияТаблицы(Table, Item)

	Если Table.TotalNet = Неопределено Тогда
		Table.TotalNet = 0;
	КонецЕсли;
	
	Если Table.TotalWithVatExcluded = Неопределено Тогда
		Table.TotalWithVatExcluded = 0;
	КонецЕсли;
	
	Если Table.Vat = Неопределено Тогда
		Table.Vat = 0;
	КонецЕсли;
	
	Если Table.Total = Неопределено Тогда
		Table.Total = 0;
	КонецЕсли;
	
	Если Item.Quantity <> Неопределено Тогда
		Table.TotalNet = Table.TotalNet + Item.Quantity;
	КонецЕсли;
	
	Table.Vat = Table.Vat + Item.Vat;
	Table.TotalWithVatExcluded = Table.TotalWithVatExcluded + Item.SubtotalWithVatExcluded;
	Table.Total = Table.Total + Item.Subtotal;

КонецПроцедуры

Процедура УПД970_ЗаполнитьОсновныеСведенияОНоменклатуре(Item, СтрокаТаблицы)
	
	Item.Product = УПД970_ПредставлениеНоменклатуры(СтрокаТаблицы);
	Item.ItemMark = УПД970_ТипНоменклатурыВТерминахПрото(СтрокаТаблицы.ТипНоменклатуры);
	
	Item.ItemVendorCode = СтрокаТаблицы.КодИлиАртикулНоменклатуры;
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.ЕдиницаИзмерения) Тогда
		
		КодЕИ = СокрЛП(СтрокаТаблицы.ЕдиницаИзмеренияКод);
		ИмяЕИ = СокрЛП(СтрокаТаблицы.ЕдиницаИзмерения);
		
		Item.Unit = ГенерацияXML.XML_КодЕдиницыИзмерения(КодЕИ);
		Item.UnitName = ИмяЕИ;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьДополнительныеСведенияОНоменклатуре(Item, СтрокаТаблицы, СведенияПрослеживаемости)

	УПД970_ЗаполнитьСведенияОТаможеннойДекларации(
		Item,
		СтрокаТаблицы);
	
	Если СтрокаТаблицы.ПрослеживаемыйТовар Тогда
		
		УПД970_ЗаполнитьСведенияПрослеживаемости(
			Item,
			СведенияПрослеживаемости,
			СтрокаТаблицы.ИдентификаторСтроки);
		
	КонецЕсли;
	
	Если Item.ItemTracingInfos.Количество() > 0 Тогда
		УПД970_ЗаполнитьПризнакПрослеживаемогоТовараВСведенияхОТаможеннойДекларации(Item.CustomDeclarations);
	КонецЕсли;

КонецПроцедуры

Процедура УПД970_ЗаполнитьТаблицуКонтентаПоДаннымСчетФактураНаАванс(Контент, ТабличныеДанные, ДополнительныеПараметры)
	
	Table = Контракт_InvoiceTable970();
	Контент.Table = Table;

	Для Каждого СтрокаТаблицы Из ТабличныеДанные Цикл
			
		Item = Контракт_Item970();
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.Содержание) Тогда
			НаименованиеНоменклатуры = СтрокаТаблицы.НоменклатураПолноеНаименование;
		ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.НоменклатураНаименование) Тогда
			НаименованиеНоменклатуры = СтрокаТаблицы.НоменклатураНаименование;
		Иначе
			НаименованиеНоменклатуры = "Предварительная оплата";
		КонецЕсли;
		
		Item.Product = НаименованиеНоменклатуры;
		Item.ItemMark = УПД970_ТипНоменклатурыВТерминахПрото(СтрокаТаблицы.ТипНоменклатуры);
		
		Item.ItemVendorCode = СтрокаТаблицы.КодИлиАртикулНоменклатуры;
		
		ПредставлениеСтавки = ПредставлениеСтавкиНДС(СтрокаТаблицы.СтавкаНДС);
		Item.TaxRate = ПредставлениеСтавки;
		
		Item.Vat = СтрокаТаблицы.СуммаНДС;
		Item.Subtotal = СтрокаТаблицы.СуммаВсего;
		
		Item.СлужебнаяИнформация = Контракт_СлужебнаяИнформацияСтроки();
		Item.СлужебнаяИнформация.Номенклатура = СтрокаТаблицы.Номенклатура;
		Item.СлужебнаяИнформация.СтавкаНДС = СтрокаТаблицы.СтавкаНДС;
		
		Table.Items.Добавить(Item);
		
	КонецЦикла;
	
	Table.Vat = ТабличныеДанные.Итог("СуммаНДС");
	Table.Total = ТабличныеДанные.Итог("СуммаВсего");
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОТаможеннойДекларации(Item, СтрокаТаблицы)
	
	ЭтоСтранаПроисхожденияРоссия = СтрокаТаблицы.СтранаПроисхожденияКод = ОсновнаяСтрана().Код;
	Если ЭтоСтранаПроисхожденияРоссия Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаТаблицы.НомерГТД)
		И (Не ЗначениеЗаполнено(СтрокаТаблицы.СтранаПроисхожденияКод)
			Или СтрокаТаблицы.СтранаПроисхожденияУчастникЕАЭС) Тогда
		Возврат;
	КонецЕсли;
		
	CustomDeclaration = Контракт_CustomDeclarations();
	CustomDeclaration.CountryCode = СтрокаТаблицы.СтранаПроисхожденияКод;
	CustomDeclaration.DeclarationNumber = СокрЛП(СтрокаТаблицы.НомерГТД);
	
	Item.CustomDeclarations.Добавить(CustomDeclaration);
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьПризнакПрослеживаемогоТовараВСведенияхОТаможеннойДекларации(CustomDeclarations)
	
	Для каждого CustomDeclaration Из CustomDeclarations Цикл
		CustomDeclaration.DeclarationNumber = УПД970_РегистрационныйНомерПрослеживаемогоТовара();
	КонецЦикла;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияПрослеживаемости(Item, СведенияПрослеживаемостиДокумента, ИдентификаторСтроки)
	
	Если СведенияПрослеживаемостиДокумента = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("ИдентификаторСтроки", ИдентификаторСтроки);
	СтрокиПрослеживаемости = СведенияПрослеживаемостиДокумента.НайтиСтроки(Отбор);
	
	Для Каждого СтрокаПрослеживаемости Из СтрокиПрослеживаемости Цикл
		
		ItemTracingInfo = Контракт_ItemTracingInfo970();
		
		ItemTracingInfo.RegNumberUnit = СокрЛП(СтрокаПрослеживаемости.НомерРНПТ);
		ItemTracingInfo.Quantity = СтрокаПрослеживаемости.КоличествоПрослеживаемости;
		
		Если СтрокаПрослеживаемости.Сумма = Неопределено Тогда
			ItemTracingInfo.SumWithoutVat = Item.SubtotalWithVatExcluded;
		Иначе
			ItemTracingInfo.SumWithoutVat = СтрокаПрослеживаемости.Сумма;
		КонецЕсли;
		
		ItemTracingInfo.Unit = Item.Unit;
		ItemTracingInfo.UnitName = Item.UnitName;
		
		Item.ItemTracingInfos.Добавить(ItemTracingInfo);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСоставителяДокументаПоДаннымПродавца(Контент)
	
	Контент.DocumentCreator = "";
	Контент.DocumentCreatorBase = "";
	
	Если Контент.Sellers.Количество() > 0 Тогда
		
		ПродавецИнфо = Контент.Sellers[0];
		Контент.DocumentCreator = НаименованиеИННКПП(ПродавецИнфо.Name, ПродавецИнфо.Inn, ПродавецИнфо.Kpp);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОСотруднике(Контент, ДополнительныеПараметры)
	
	Перем ДанныеСотрудника;
	
	ДополнительныеПараметры.Свойство("ДанныеСотрудника", ДанныеСотрудника);
		
	ЕстьТовары = УПД970_ВДокументеЕстьТовары(Контент.Table.Items);
	
	НеобходимоЗаполнитьСведения = (ЗначениеЗаполнено(ДанныеСотрудника)
		И ЗначениеЗаполнено(ДанныеСотрудника.Должность)
		И Контент.Function <> ФункцияДокументаУПД_СЧФ()
		И ЕстьТовары);
	
	Если НеобходимоЗаполнитьСведения Тогда
		
		Employee = Контракт_Employee970();
		
		Employee.Surname = ДанныеСотрудника.Фамилия;
		Employee.FirstName = ДанныеСотрудника.Имя;
		Employee.Patronymic = ДанныеСотрудника.Отчество;
		Employee.EmployeePosition = ДанныеСотрудника.Должность;
		
		Контент.TransferInfo.Employee = Employee;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьПризнакНаличияПрослеживаемыхТоваров(Контент)
	
	ЕстьПрослеживаемыеТовары = Ложь;
	
	Для Каждого Item Из Контент.Table.Items Цикл
		Если Item.ItemTracingInfos.Количество() > 0 Тогда
			ЕстьПрослеживаемыеТовары = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ПризнакиТоваров = ГенерацияXML.Новый_ПризнакиПрослеживаемыхИМаркируемыхТоваровУПД970(ЕстьПрослеживаемыеТовары);
	
	ГенерацияXML.Заполнить_ПризнакиПрослеживаемыхИМаркируемыхТоваровДокументаУПД970(Контент, ПризнакиТоваров);

КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОМаркировке(Контент, СсылкаНаОбъект)
	
	Попытка
		
		РаботаСМаркировкойЛок.ЗаполнитьСведенияОМаркировке970(Контент);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(Ошибка);
		
		ПодробнаяОшибка = Ядро.Общее_ПодставитьПараметрыВСтроку(
			"Не удалось заполнить сведения о маркировке по причине:
			|%1",
			ПодробноеПредставлениеОшибки);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.РаботаСМаркировкой",
			УровеньЖурналаРегистрации.Ошибка,
			СсылкаНаОбъект.Метаданные(),
			СсылкаНаОбъект,
			ПодробнаяОшибка);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОПомещении(AddressSAR, СведенияОбАдресе)

	Если ЗначениеЗаполнено(СведенияОбАдресе.Помещения) Тогда
		
		Помещение = СведенияОбАдресе.Помещения[0];
		
		Если ЗначениеЗаполнено(Помещение.Номер) Тогда
			AddressSAR.Apartment = Помещение.Номер;
			AddressSAR.ApartmentType = Помещение.ТипПомещения;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура УПД970_ЗаполнитьСведенияОКорпусахСтроениях(AddressSAR, СведенияОбАдресе)

	Для Каждого Корпус Из СведенияОбАдресе.Корпуса Цикл
		
		Если ЗначениеЗаполнено(Корпус.Номер) Тогда
			
			AddressObject = Контракт_AddressObjectNumberInfo();
			AddressSAR.Buildings.Добавить(AddressObject);
			
			AddressObject.Number = Корпус.Номер;
			AddressObject.Type = Корпус.ТипКорпуса;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Функция УПД970_КодМуниципальногоРайона(ТипМуниципальногоРайона)
	
	Результат = "";
	
	Если ВРег(ТипМуниципальногоРайона) = ВРег("м.р-н") Тогда
		
		Результат = "1";
		
	ИначеЕсли ВРег(ТипМуниципальногоРайона) = ВРег("г.о.")
		Или ВРег(ТипМуниципальногоРайона) = ВРег("ф.т.") Тогда
		
		Результат = "2";
		
	ИначеЕсли ВРег(ТипМуниципальногоРайона) = ВРег("вн.тер.")
		Или ВРег(ТипМуниципальногоРайона) = ВРег("вн.тер. г.")
		Или ВРег(ТипМуниципальногоРайона) = ВРег("вн.тер.г.") Тогда
		
		Результат = "3";
		
	ИначеЕсли ВРег(ТипМуниципальногоРайона) = ВРег("мун. окр.")
		Или ВРег(ТипМуниципальногоРайона) = ВРег("м.о.")
		Или ВРег(ТипМуниципальногоРайона) = ВРег("мун.окр.") Тогда
		
		Результат = "4";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ЗаполненныйAddressRF(СведенияОбАдресе)
	
	Результат = Контракт_AddressRFInfo();
	
	Результат.ZipCode = СведенияОбАдресе.Индекс;
	Результат.RegionCode = СведенияОбАдресе.КодРегиона;
	Результат.Region = СведенияОбАдресе.Регион;
	Результат.Territory = СведенияОбАдресе.Район;
	
	Результат.City = СоединитьЭлементыАдресногоОбъекта(
		СведенияОбАдресе.Город,
		СведенияОбАдресе.ГородСокращение);
	
	Результат.Locality = СоединитьЭлементыАдресногоОбъекта(
		СведенияОбАдресе.НаселенныйПункт,
		СведенияОбАдресе.НаселенныйПунктСокращение);
		
	Результат.Street = СоединитьЭлементыАдресногоОбъекта(
		СведенияОбАдресе.Улица,
		СведенияОбАдресе.УлицаСокращение);
	
	ИмяПоляНомер = "Номер";
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.Здание) Тогда 
		СведенияОбАдресе.Здание.Свойство(ИмяПоляНомер, Результат.Building);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.Корпуса) Тогда 
		СведенияОбАдресе.Корпуса[0].Свойство(ИмяПоляНомер, Результат.Block);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.Помещения) Тогда 
		СведенияОбАдресе.Помещения[0].Свойство(ИмяПоляНомер, Результат.Apartment);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ЗаполненныйAddressText(СведенияОбАдресе)
	
	Результат = Контракт_AddressTextInfo();
	
	ПредставлениеАдреса = СведенияОбАдресе.Представление;
	Если ЭтоМуниципальныйАдресЛок(СведенияОбАдресе.ТипАдреса)
		И ЗначениеЗаполнено(СведенияОбАдресе.МуниципальноеПредставление) Тогда
		
		ПредставлениеАдреса = СведенияОбАдресе.МуниципальноеПредставление;
		
	КонецЕсли;
	
	Результат.AddressText = ПредставлениеАдреса;
	Результат.CountryCode = СведенияОбАдресе.КодСтраны;
	Результат.Country = СведенияОбАдресе.Страна;

	Возврат Результат;
	
КонецФункции

Функция УПД970_ПредставлениеРегиона(СведенияОбАдресе)
	
	КодыРегионов = ГенерацияXML_КодыРегионов();
	
	Результат = "";
	
	Если ЗначениеЗаполнено(СведенияОбАдресе.КодРегиона) Тогда
		Результат = КодыРегионов.Получить(XMLЗначение(Тип("Число"), СведенияОбАдресе.КодРегиона));
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		
		ЧастиРегиона = Новый Массив;
		ЧастиРегиона.Добавить(СокрЛП(СведенияОбАдресе.Регион));
		ЧастиРегиона.Добавить(НРег(СведенияОбАдресе.РегионТипПолный));
		
		Результат = СоединитьСтроку(ЧастиРегиона, " ");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ExtendedOrganizationInfoType(ДанныеУчастникаЭДО)
	
	ВидыЮрФизЛиц = ГенерацияXML_Перечисление_ВидыЮрФизЛиц();
	
	ЭтоФизЛицо = НЕ ДанныеУчастникаЭДО.ЭтоЮрЛицо;
	ЭтоРезидент = НЕ ДанныеУчастникаЭДО.Нерезидент;
	
	Если ЭтоФизЛицо И ЭтоРезидент Тогда
		
		Результат = ВидыЮрФизЛиц.ИндивидуальныйПредприниматель;
		
	ИначеЕсли ДанныеУчастникаЭДО.ЭтоЮрЛицо И ЭтоРезидент Тогда
		
		Результат = ВидыЮрФизЛиц.ЮридическоеЛицо;
		
	ИначеЕсли ЭтоФизЛицо И ДанныеУчастникаЭДО.Нерезидент Тогда
		
		Результат = ВидыЮрФизЛиц.ИностранныйГражданин;
		
	ИначеЕсли ДанныеУчастникаЭДО.ЭтоЮрЛицо
		И ДанныеУчастникаЭДО.Нерезидент Тогда
		
		Результат = ВидыЮрФизЛиц.ИностраннаяОрганизация;
		
	Иначе
		
		ТекстОшибки = НСтр("ru='Не удалось определить тип участника ЭДО.
				|Заполните корректные реквизиты участников ЭДО в базе 1С 
				|(организация, грузоотправитель, контрагент, грузополучатель)'");
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
