Функция ТекстЗапроса_ДанныеТабличнойЧастиСчетНаОплатуПокупателю()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТабличнаяЧасть.Номенклатура КАК Номенклатура,
	|	&ПолеНоменклатураНаименование КАК НаименованиеПолное,
	|	NULL КАК Содержание,
	|	ТабличнаяЧасть.Номенклатура.Код КАК Код,
	|	ТабличнаяЧасть.Номенклатура.Артикул КАК Артикул,
	|	ТабличнаяЧасть.Количество,
	|	ТабличнаяЧасть.ЕдиницаИзмерения.Представление КАК ЕдиницаИзмерения,
	|	ТабличнаяЧасть.ПроцентСкидкиНаценки 
	|	+ ТабличнаяЧасть.ПроцентАвтоматическихСкидок КАК Скидка,
	|	ТабличнаяЧасть.Цена КАК Цена,
	|	ТабличнаяЧасть.Сумма КАК Сумма,
	|	ТабличнаяЧасть.СуммаНДС КАК СуммаНДС,
	|	ТабличнаяЧасть.ХарактеристикаНоменклатуры КАК Характеристика,
	|	NULL КАК Серия,
	|	ТабличнаяЧасть.НомерСтроки КАК НомерСтроки,
	|	0 КАК Метка
	|ИЗ
	|	Документ.СчетНаОплатуПокупателю.Товары КАК ТабличнаяЧасть
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &ТекущийДокумент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТабличнаяЧасть.Номенклатура,
	|	NULL КАК НаименованиеПолное,
	|	&ПолеСодержание КАК Содержание,
	|	ТабличнаяЧасть.Номенклатура.Код КАК Код,
	|	ТабличнаяЧасть.Номенклатура.Артикул КАК Артикул,
	|	ТабличнаяЧасть.Количество,
	|	ТабличнаяЧасть.Номенклатура.ЕдиницаХраненияОстатков,
	|	ТабличнаяЧасть.ПроцентСкидкиНаценки + ТабличнаяЧасть.ПроцентАвтоматическихСкидок,
	|	ТабличнаяЧасть.Цена,
	|	ТабличнаяЧасть.Сумма,
	|	ТабличнаяЧасть.СуммаНДС,
	|	NULL,
	|	NULL,
	|	ТабличнаяЧасть.НомерСтроки,
	|	1
	|ИЗ
	|	Документ.СчетНаОплатуПокупателю.Услуги КАК ТабличнаяЧасть
	|ГДЕ
	|	ТабличнаяЧасть.Ссылка = &ТекущийДокумент
	|УПОРЯДОЧИТЬ ПО
	|	Метка,
	|	НомерСтроки";
	
	ПолеНоменклатураНаименование = ВыражениеНоменклатураНаименование("ТабличнаяЧасть");
	ПолеСодержание = ОбработкаТабличныхЧастей.ПолучитьЧастьЗапросаДляВыбораСодержания("ТабличнаяЧасть");
	
	Результат = СтрЗаменить(
		Результат,
		"&ПолеНоменклатураНаименование",
		ПолеНоменклатураНаименование
	);
	
	Результат = СтрЗаменить(
		Результат,
		"&ПолеСодержание",
		ПолеСодержание
	);
	
	Возврат Результат;
	
