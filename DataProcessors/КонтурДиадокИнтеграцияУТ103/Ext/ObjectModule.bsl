// Значения реквизитов документов учета организация контрагент
//
// Параметры:
//  КоллекцияДокументов - Массив - коллекция документов учета
// 
// Возвращаемое значение:
//  Соотвествие - Соответствие в котором ключом является сам документ а в значении структура ревизитов (Организация, Контрагент) 
//
Функция ЗначенияРеквизитовДокументовУчета_ОрганизацияКонтрагент(КоллекцияДокументов) Экспорт
	
	ПервыйЭлемент = КоллекцияДокументов[0];
	МетаданныеЭлемента = ПервыйЭлемент.Метаданные();
	
	Реквизиты = Новый Массив;
	Если НЕ МетаданныеЭлемента.Реквизиты.Найти("Организация") = Неопределено Тогда
		Реквизиты.Добавить("Организация");	
	КонецЕсли;
	
	Если НЕ МетаданныеЭлемента.Реквизиты.Найти("Контрагент") = Неопределено Тогда
		Реквизиты.Добавить("Контрагент");	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Реквизиты) Тогда
		Возврат Новый Соответствие;
	КонецЕсли;
	
	ИменаРеквизитов = СоединитьСтроку(Реквизиты, ","); 
	
	Результат = Общее_ЗначенияРеквизитовОбъектов(КоллекцияДокументов, ИменаРеквизитов);
	
	Возврат Результат;
	
КонецФункции

