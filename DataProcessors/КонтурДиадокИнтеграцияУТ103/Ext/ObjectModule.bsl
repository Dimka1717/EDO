	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ДанныеШапки.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПлатежноеПоручениеВходящее КАК ПлатежноеПоручениеВходящее
	|		ПО ДанныеШапки.ДокументОснование = ПлатежноеПоручениеВходящее.Ссылка
	|ГДЕ
	|	ДанныеШапки.Ссылка = &Ссылка";
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ТекстЗапросаТабличныхДанныхДокументаСчетФактураВыданныйНаАванс()
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	""Услуга"" КАК ТипНоменклатуры,
	|	ТабАвансы.Ссылка КАК Ссылка,
	|	ТабАвансы.НомерСтроки КАК НомерСтроки,
	|	""Авансы"" КАК ИмяТабличнойЧасти,
	|	ТабАвансы.Сумма КАК СуммаВсего,
	|	ТабАвансы.СуммаНДС КАК СуммаНДС,
	|	ТабАвансы.СтавкаНДС КАК СтавкаНДС,
	|	ВЫРАЗИТЬ(ТабАвансы.Содержание КАК СТРОКА(1000)) КАК Содержание,
	|	ТабАвансы.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(СпрНоменклатура.НаименованиеПолное КАК СТРОКА(1000)) КАК НоменклатураПолноеНаименование,
	|	ВЫРАЗИТЬ(СпрНоменклатура.Наименование КАК СТРОКА(1000)) КАК НоменклатураНаименование,
	|	&КодИлиАртикулНоменклатуры КАК КодИлиАртикулНоменклатуры
	|ИЗ
	|	Документ.СчетФактураВыданный.Авансы КАК ТабАвансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО ТабАвансы.Номенклатура = СпрНоменклатура.Ссылка
	|ГДЕ
	|	ТабАвансы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	ВыражениеКодИлиАртикул =
	"ВЫБОР
	|		КОГДА &ДопКолонкаПечатныхФорм = ЗНАЧЕНИЕ(Перечисление.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул)
	|			ТОГДА СпрНоменклатура.Артикул
	|		ИНАЧЕ СпрНоменклатура.Код
	|	КОНЕЦ";
	
	Замены = Новый СписокЗначений;
	Замены.Добавить("&КодИлиАртикулНоменклатуры", ВыражениеКодИлиАртикул);
	
	Для Каждого Элемент Из Замены Цикл
		Результат = СтрЗаменить(Результат, Элемент.Значение, Элемент.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ТекстЗапросаДанныхОДокументахОплатыСчетФактурыВыданныйНаАванс()
	
	Результат = УПД970_ТекстЗапросаДанныхОДокументахОплатыСчетФактурыВыданный();
	
	Возврат Результат;
	
