Функция УПД970_ТекстЗапросаДанныхШапкиДокументаОтчетКомитентуОПродажах()
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	ДанныеШапки.Дата КАК Дата,
	|	ДанныеШапки.ВалютаДокумента КАК ВалютаДокумента,
	|	ДанныеШапки.Организация КАК Организация,
	|	ДанныеШапки.Контрагент КАК Контрагент,
	|	ДанныеШапки.Контрагент.ГоловнойКонтрагент КАК ГоловнойКонтрагент,
	|	ДанныеШапки.Контрагент.ОбособленноеПодразделение КАК ОбособленноеПодразделение,
	|	НЕОПРЕДЕЛЕНО КАК Грузоотправитель,
	|	НЕОПРЕДЕЛЕНО КАК Грузополучатель,
	|	НЕОПРЕДЕЛЕНО КАК АдресДоставки,
	|	ИСТИНА КАК СуммаВключаетНДС,
	|	ДанныеШапки.Организация.ОсновнойБанковскийСчет КАК БанковскийСчетОрганизации,
	|	ДанныеШапки.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ДанныеШапки.КурсВзаиморасчетов КАК КурсВзаиморасчетов,
	|	ДанныеШапки.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,

	|	ДоговорыКонтрагентов.Дата КАК ДоговорДата,
	|	ДоговорыКонтрагентов.Номер КАК ДоговорНомер,
	|	ДоговорыКонтрагентов.ВидДоговора КАК ВидДоговора,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.РасчетыВУсловныхЕдиницах, ЛОЖЬ) КАК РасчетыВУсловныхЕдиницах,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.ВалютаВзаиморасчетов, """") КАК ВалютаВзаиморасчетов
	|ИЗ
	|	Документ.ОтчетКомитентуОПродажах КАК ДанныеШапки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО ДанныеШапки.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	ДанныеШапки.Ссылка = &Ссылка";
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ТекстЗапросаТабличныхДанныхДокументаОтчетКомитентуОПродажах()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ОтчетКомитентуОПродажахТовары.СуммаВознаграждения) КАК СуммаВознаграждения,
	|	СУММА(ОтчетКомитентуОПродажахТовары.СуммаНДСВознаграждения) КАК СуммаНДСВознаграждения,
	|	ОтчетКомитентуОПродажахТовары.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВремСуммыВознаграждения
	|ИЗ
	|	Документ.ОтчетКомитентуОПродажах.Товары КАК ОтчетКомитентуОПродажахТовары
	|ГДЕ
	|	ОтчетКомитентуОПродажахТовары.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтчетКомитентуОПродажахТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК Порядок,
	|	ОтчетКомитентуОПродажах.Ссылка КАК Ссылка,
	|	1 КАК НомерСтроки,
	|	&ТипНоменклатурыУслуга КАК ТипНоменклатуры,
	|	"""" КАК ИдентификаторСтроки,
	|	"""" КАК ИмяТабличнойЧасти,
	|	&ПустаяНоменклатура КАК Номенклатура,
	|	""Комиссионное вознаграждение"" КАК НоменклатураПолноеНаименование,
	|	""Комиссионное вознаграждение"" КАК НоменклатураНаименование,
	|	&ПустаяСтрока КАК КодИлиАртикулНоменклатуры,
	|	&ПустаяХарактеристика КАК ХарактеристикаНоменклатуры,
	|	&ПустаяСерия КАК СерияНоменклатуры,
	|	&ПустаяСтрана КАК СтранаПроисхождения,
	|	&ПустаяСтрока КАК ПредставлениеСтраны,
	|	&ПустаяСтрока КАК СтранаПроисхожденияКод,
	|	ЛОЖЬ КАК СтранаПроисхожденияУчастникЕАЭС,
	|	&ПустаяЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	"""" КАК ЕдиницаИзмеренияНаименование,
	|	"""" КАК ЕдиницаИзмеренияКод,
	|	&ПустаяСтрока КАК НомерГТД,
	|	0 КАК Количество,
	|	0 КАК Цена,
	|	ОтчетКомитентуОПродажах.СтавкаНДСВознаграждения КАК СтавкаНДС,
	|	СуммыВознаграждения.СуммаНДСВознаграждения КАК СуммаНДС,
	|	СуммыВознаграждения.СуммаВознаграждения - СуммыВознаграждения.СуммаНДСВознаграждения КАК СуммаБезНДС,
	|	СуммыВознаграждения.СуммаВознаграждения КАК СуммаВсего,
	|	ЛОЖЬ КАК ПрослеживаемыйТовар
	|ИЗ
	|	Документ.ОтчетКомитентуОПродажах КАК ОтчетКомитентуОПродажах
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВремСуммыВознаграждения КАК СуммыВознаграждения
	|		ПО ОтчетКомитентуОПродажах.Ссылка = СуммыВознаграждения.Ссылка
	|ГДЕ
	|	ОтчетКомитентуОПродажах.Ссылка = &Ссылка";
	
	Замены = Новый СписокЗначений;
	Замены.Добавить("&ПустаяСтрока", """""");
	Замены.Добавить("&ПустаяНоменклатура", "ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)");
	Замены.Добавить("&ПустаяХарактеристика", "ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)");
	Замены.Добавить("&ПустаяСерия", "ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)");
	Замены.Добавить("&ПустаяЕдиницаИзмерения", "ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)");
	Замены.Добавить("&ПустаяСтрана", "ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)");
	Замены.Добавить("&ПустойНомерГТД", "ЗНАЧЕНИЕ(Справочник.НомераГТД.ПустаяСсылка)");
	
	Для Каждого Элемент Из Замены Цикл
		Результат = СтрЗаменить(Результат, Элемент.Значение, Элемент.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

