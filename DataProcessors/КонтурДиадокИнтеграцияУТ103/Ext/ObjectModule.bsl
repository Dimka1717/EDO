Функция УПД970_НовыеДанныеПервичногоДокумента(
	РезультатЗапросаПоШапке,
	РезультатЗапросаПоТаблицам,
	РезультатЗапросаПоПрослеживаемости,
	СчетФактура)
	
	Результат = УПД970_Контракт_ДанныеПервичногоДокумента();
	
	ТабДанныеШапки = РезультатЗапросаПоШапке.Выгрузить();
	Если ТабДанныеШапки.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеШапки = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТабДанныеШапки[0]);
	
	ТабличныеДанные = РезультатЗапросаПоТаблицам.Выгрузить();
	
	Если РезультатЗапросаПоПрослеживаемости = Неопределено Тогда
		СведенияПрослеживаемости = Неопределено;
	Иначе
		СведенияПрослеживаемости = РезультатЗапросаПоПрослеживаемости.Выгрузить();
	КонецЕсли;
	
	ЭтоДоговорСКомитентом = (ДанныеШапки.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомитентом);
	ЭтоДоговорСКомиссионером = (ДанныеШапки.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером);

	Результат.ДанныеШапки = ДанныеШапки;
	Результат.ТабличныеДанные = ТабличныеДанные;
	Результат.СведенияПрослеживаемости = СведенияПрослеживаемости;
	Результат.ЭтоДоговорСКомитентом = ЭтоДоговорСКомитентом;
	Результат.ЭтоДоговорСКомиссионером = ЭтоДоговорСКомиссионером;
	Результат.СчетФактура = СчетФактура;
	
	Если УПД970_НеобходимоВыполнитьПересчетСуммВВалютеРегУчета(ДанныеШапки, СчетФактура) Тогда
		УПД970_ПерезаполнитьСуммыДокументаВВалютеРегУчета(ДанныеШапки, ТабличныеДанные);
		ДанныеШапки.ВалютаДокумента = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	КонецЕсли;
	
	Если УПД970_ВТабличныхДанныхДокументаТолькоУслуги(ТабличныеДанные) Тогда
		ДанныеШапки.Грузоотправитель = Неопределено;
		ДанныеШапки.Грузополучатель = Неопределено;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

