Функция УПД970_ДанныеГрузополучателя(Ссылка, ДатаСведений, Знач АдресДоставки)
	
	Результат = УПД970_ДанныеУчастникаЭДО(Ссылка, ДатаСведений);
	
	АдресДоставки = СокрЛП(АдресДоставки);
	
	Если ЗначениеЗаполнено(АдресДоставки) Тогда
		СведенияОбАдресе = УПД970_СведенияОбАдресеДоставки(Ссылка, АдресДоставки);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СведенияОбАдресе) Тогда
		СведенияОбАдресе = УПД970_СведенияОФактическомАдресе(Ссылка);
	КонецЕсли;
	
	Результат.Адрес = СведенияОбАдресе;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОбЮридическомАдресе(Ссылка)
	
	Перем Результат;
	
	ВидыКИ = Перечисление_ВидыКонтактнойИнформации();
	
	ЗаписьКИ = УПД970_АдресИзКонтактнойИнформации(Ссылка, ВидыКИ.ЮридическийАдрес);
	
	Если ЗаписьКИ <> Неопределено Тогда
		
		Результат = УПД970_СведенияОбАдресе(ЗаписьКИ);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОФактическомАдресе(Ссылка)
	
	Перем Результат;
	
	ВидыКИ = Перечисление_ВидыКонтактнойИнформации();
	
	ЗаписьКИ = УПД970_АдресИзКонтактнойИнформации(Ссылка, ВидыКИ.ФактическийАдрес);
	
	Если ЗаписьКИ <> Неопределено Тогда
		
		Результат = УПД970_СведенияОбАдресе(ЗаписьКИ);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОбАдресеДоставки(Ссылка, АдресДоставки)
	
	Перем Результат;
	
	ПоляАдреса = УПД970_АдресИзПредставленияАдреса(Ссылка, АдресДоставки);
	
	Если ПоляАдреса <> Неопределено Тогда
		
		Результат = УПД970_НовыйСведенияОбАдресе();
		
		УПД970_ЗаполнитьСведенияОбАдресеПоДаннымРегистра(Результат, ПоляАдреса);
		
		Результат.ТипАдреса = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОбАдресе(ЗаписьКИ)
	
	Результат = УПД970_НовыйСведенияОбАдресе();
	УПД970_ЗаполнитьСведенияОбАдресеПоДаннымРегистра(Результат, ЗаписьКИ);
	
	УПД970_ДополнитьСведенияОбАдресеОсновнойСтраной(Результат);
	
	ЭтоАдминистративноТерриториальныйАдрес = УПД970_АдресСоответствуетСтруктуреAddressRF(Результат);
	
	ЭтоМуниципальныйАдрес = Ложь;
	Если Не ЭтоАдминистративноТерриториальныйАдрес Тогда
		ЭтоМуниципальныйАдрес = УПД970_АдресСоответствуетСтруктуреAddressSAR(Результат);
	КонецЕсли;
	
	Если Не ЭтоМуниципальныйАдрес
		И Не ЭтоАдминистративноТерриториальныйАдрес Тогда
		
		Результат.ТипАдреса = ТипАдресаВСвободнойФорме();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УПД970_ЗаполнитьСведенияОбАдресеПоДаннымРегистра(СведенияОбАдресе, ЗаписьКИ)
	
	СведенияОбАдресе.Представление = ЗаписьКИ.Представление;
	
	Индекс = Неопределено;
	КодСтраны = Неопределено;
	НаименованиеСтраны = Неопределено;
	
	Если Не Общее_ВСтрокеТолькоЦифры(ЗаписьКИ.Поле1) Тогда 
		НаименованиеСтраны = СокрП(ЗаписьКИ.Поле1);
		КодСтраны = ГенерацияXML.КодСтраны(НаименованиеСтраны);
	Иначе
		Индекс = СокрП(ЗаписьКИ.Поле1);
	КонецЕсли;
	
	СведенияОбАдресе.Регион = СокрЛП(ЗаписьКИ.Поле2);
	КодРегиона = УПД970_КодРегиона(СведенияОбАдресе.Регион);
	
	Если ЗначениеЗаполнено(КодРегиона) Тогда // Это структурированный адрес РФ
		
		СведенияОбАдресе.ТипАдреса = АдминистративноТерриториальныйАдрес();
		
		СведенияОбАдресе.Страна = ОсновнаяСтрана().Наименование;
		СведенияОбАдресе.Индекс = Индекс;
		СведенияОбАдресе.КодСтраны = ОсновнаяСтрана().Код;
		СведенияОбАдресе.КодРегиона = КодРегиона;
		СведенияОбАдресе.Район = ЗаписьКИ.Поле3;
		СведенияОбАдресе.Город = ЗаписьКИ.Поле4;
		СведенияОбАдресе.НаселенныйПункт = ЗаписьКИ.Поле5;
		СведенияОбАдресе.Улица = ЗаписьКИ.Поле6;
		
		СведенияОбАдресе.Здание.ТипЗдания = ЗаписьКИ.ТипДома;
		СведенияОбАдресе.Здание.Номер = ЗаписьКИ.Поле7;
		
		Если ЗначениеЗаполнено(ЗаписьКИ.Поле8) Тогда
			
			Корпус = Новый Структура;
			Корпус.Вставить("ТипКорпуса", ЗаписьКИ.ТипКорпуса);
			Корпус.Вставить("Номер", ЗаписьКИ.Поле8);
			
			СведенияОбАдресе.Корпуса.Добавить(Корпус);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЗаписьКИ.Поле9) Тогда
			
			Помещение = Новый Структура;
			Помещение.Вставить("ТипПомещения", ЗаписьКИ.ТипКвартиры);
			Помещение.Вставить("Номер", ЗаписьКИ.Поле9); 
			СведенияОбАдресе.Помещения.Добавить(Помещение);
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(КодСтраны) Тогда // Это иностранный или российский адрес в свободной форме
		
		СведенияОбАдресе.КодСтраны = КодСтраны;
		СведенияОбАдресе.Страна = НаименованиеСтраны;
		
	Иначе // Это российский адрес, который не удалось разложить в структуру
		
		СведенияОбАдресе.Страна = ОсновнаяСтрана().Наименование;
		СведенияОбАдресе.КодСтраны = ОсновнаяСтрана().Код;
		
	КонецЕсли;
	
КонецПроцедуры

Функция УПД970_АдресСоответствуетСтруктуреAddressSAR(СведенияОбАдресе)
	
	Результат = ЭтоМуниципальныйАдресЛок(СведенияОбАдресе.ТипАдреса);
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_АдресСоответствуетСтруктуреAddressRF(СведенияОбАдресе)
	
	Результат = ЭтоАдминистративноТерриториальныйАдресЛок(СведенияОбАдресе.ТипАдреса);
	
	Возврат Результат;
	
КонецФункции

Процедура УПД970_ДополнитьСведенияОбАдресеОсновнойСтраной(Результат)
	
	Если НЕ ЗначениеЗаполнено(Результат.КодСтраны)
		И НЕ ЗначениеЗаполнено(Результат.Страна) Тогда
		
		Результат.КодСтраны = ОсновнаяСтрана().Код;
		Результат.Страна = ОсновнаяСтрана().Наименование;
		
