// Возвращает массив ссылок на связанные документы учета 1С.
// Для получения подчиненных документов используется критерии отбора СвязанныеДокументы.
//
// Параметры:
//  ДокументУчета	 - Любая ссылка	 - ссылка на документ учета 1С, для которого необходимо получить коллекую связанных с ним
// 
// Возвращаемое значение:
//  Массив - массив ссылок на документы 1С
//
Функция СчетаНаОплату_СвязанныеДокументыПоКритериюОтбора(Документ) Экспорт
	
	Результат = Новый Массив;
		
	СвязанныеДокументы_ЗаполнитьКоллекциюПоДокументу(Результат, Документ);
	
	Если ЭтоСчетНаОплату(Документ) Тогда
		
		ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ, "ЗаказПокупателя");
		
		Если ЗначениеЗаполнено(ДокументОснование) Тогда
			Результат.Добавить(ДокументОснование);
			СвязанныеДокументы_ЗаполнитьКоллекциюПоДокументу(Результат, ДокументОснование);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат.Найти(Документ) = Неопределено Тогда
		
		Результат.Добавить(Документ);
		
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции	

// Находит связи с учетным документом, на основании которого формируется электронный счет на оплату.
// Если в аргументе передается счет на оплату, то в результат функции добавляются связи
// второго порядка. Например, документ реализации - это связь первого порядка.
// А счет-фактура на реализацию - это связь второго порядка.
//
// Параметры:
//  ОснованиеЭлектронногоСчета - ЛюбаяСсылка - учетный документ (счет, заказ, документ продажи),
//                               на основании которого формируется электронный счет на оплату.
// 
// Возвращаемое значение:
//  Массив из ЛюбаяСсылка.
//
Функция СчетаНаОплату_СвязанныеДокументы(ОснованиеЭлектронногоСчета) Экспорт
	
	Если ЭтоСчетНаОплату(ОснованиеЭлектронногоСчета) Тогда
		
		Результат = СчетаНаОплату_СвязиПоСчетуНаОплату(ОснованиеЭлектронногоСчета);
		Результат.Добавить(ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ЭтоЗаказПокупателя(ОснованиеЭлектронногоСчета) Тогда
		
		Результат = СчетаНаОплату_СвязиПоЗаказуПокупателя(ОснованиеЭлектронногоСчета);
		Результат.Добавить(ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ЭтоДокументПродажи(ОснованиеЭлектронногоСчета) Тогда
		
		Результат = СчетаНаОплату_СвязиПоДокументуПродажи(ОснованиеЭлектронногоСчета);
		Результат.Добавить(ОснованиеЭлектронногоСчета);
		
	Иначе
		
		Результат = Новый Массив;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_СвязиПоСчетуНаОплату(СчетНаОплату)
		
	ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетНаОплату, "ЗаказПокупателя");
	
	Если ЗначениеЗаполнено(ДокументОснование) Тогда
		
		Результат = СчетаНаОплату_СвязиПоЗаказуПокупателя(ДокументОснование);
		Результат.Добавить(ДокументОснование);
		
	Иначе
		
		Результат = СчетаНаОплату_СвязиПоСчетуНаОплатуБезОснования(СчетНаОплату);
		
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_СвязиПоСчетуНаОплатуБезОснования(СчетНаОплату)
	
	Результат = Новый Массив;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказПокупателя.Ссылка
	|ПОМЕСТИТЬ ВТ_СвязанныеПервичныеДокументы
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	НЕ ЗаказПокупателя.ПометкаУдаления
	|	И ЗаказПокупателя.ДокументОснование = &СчетПокупателя
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияТоваровУслуг.Ссылка
	|ПОМЕСТИТЬ ВТ_СвязанныеВторичныеДокументы
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_СвязанныеПервичныеДокументы.Ссылка = РеализацияТоваровУслуг.Сделка
	|ГДЕ
	|	НЕ РеализацияТоваровУслуг.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Ссылка
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|		ПО ВТ_СвязанныеПервичныеДокументы.Ссылка = РеализацияТоваровУслугТовары.ЗаказПокупателя
	|ГДЕ
	|	НЕ РеализацияТоваровУслугТовары.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугВозвратнаяТара.Ссылка
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.ВозвратнаяТара КАК РеализацияТоваровУслугВозвратнаяТара
	|		ПО ВТ_СвязанныеПервичныеДокументы.Ссылка = РеализацияТоваровУслугВозвратнаяТара.ЗаказПокупателя
	|ГДЕ
	|	НЕ РеализацияТоваровУслугВозвратнаяТара.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугУслуги.Ссылка
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
	|		ПО ВТ_СвязанныеПервичныеДокументы.Ссылка = РеализацияТоваровУслугУслуги.ЗаказПокупателя
	|ГДЕ
	|	НЕ РеализацияТоваровУслугУслуги.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	НЕ РеализацияТоваровУслуг.ПометкаУдаления
	|	И РеализацияТоваровУслуг.Сделка = &СчетПокупателя
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетФактураВыданныйДокументыОснования.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_СвязанныеВторичныеДокументы КАК ВТ_СвязанныеВторичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|		ПО ВТ_СвязанныеВторичныеДокументы.Ссылка = СчетФактураВыданныйДокументыОснования.ДокументОснование
	|ГДЕ
	|	НЕ СчетФактураВыданныйДокументыОснования.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СчетФактураВыданный.Ссылка
	|ИЗ
	|	ВТ_СвязанныеВторичныеДокументы КАК ВТ_СвязанныеВторичныеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|		ПО ВТ_СвязанныеВторичныеДокументы.Ссылка = СчетФактураВыданный.ДокументОснование
	|ГДЕ
	|	НЕ СчетФактураВыданный.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВТ_СвязанныеВторичныеДокументы.Ссылка
	|ИЗ
	|	ВТ_СвязанныеВторичныеДокументы КАК ВТ_СвязанныеВторичныеДокументы
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВТ_СвязанныеПервичныеДокументы.Ссылка
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("СчетПокупателя", СчетНаОплату);
	
	ТаблицаРезультата = Запрос.Выполнить().Выгрузить();
	Результат = ТаблицаРезультата.ВыгрузитьКолонку(0);
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_СвязиПоЗаказуПокупателя(ЗаказПокупателя)
	
	Результат = Новый Массив;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РТУТовары.Ссылка КАК Документ
	|ПОМЕСТИТЬ ВТ_СвязанныеПервичныеДокументы
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РТУТовары
	|ГДЕ
	|	РТУТовары.ЗаказПокупателя = &ЗаказПокупателя
	|	И НЕ РТУТовары.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РТУВозвратнаяТара.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.ВозвратнаяТара КАК РТУВозвратнаяТара
	|ГДЕ
	|	РТУВозвратнаяТара.ЗаказПокупателя = &ЗаказПокупателя
	|	И НЕ РТУВозвратнаяТара.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РТУУслуги.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Услуги КАК РТУУслуги
	|ГДЕ
	|	РТУУслуги.ЗаказПокупателя = &ЗаказПокупателя
	|	И НЕ РТУУслуги.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РТУ.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РТУ
	|ГДЕ
	|	РТУ.Сделка = &ЗаказПокупателя
	|	И НЕ РТУ.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СчетФактураВыданныйДокументыОснования.Ссылка КАК Документ
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|		ПО ВТ_СвязанныеПервичныеДокументы.Документ = СчетФактураВыданныйДокументыОснования.ДокументОснование
	|ГДЕ
	|	НЕ СчетФактураВыданныйДокументыОснования.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_СвязанныеПервичныеДокументы.Документ
	|ИЗ
	|	ВТ_СвязанныеПервичныеДокументы КАК ВТ_СвязанныеПервичныеДокументы";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ЗаказПокупателя", ЗаказПокупателя);
	
	ТаблицаРезультата = Запрос.Выполнить().Выгрузить();
	Результат = ТаблицаРезультата.ВыгрузитьКолонку(0);
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_СвязиПоДокументуПродажи(ДокументПродажи)
	
	Результат = Новый Массив;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СчетФактураВыданныйДокументыОснования.Ссылка КАК Документ
	|ИЗ
	|	Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|ГДЕ
	|	СчетФактураВыданныйДокументыОснования.ДокументОснование = &ДокументПродажи
	|	И НЕ СчетФактураВыданныйДокументыОснования.Ссылка.ПометкаУдаления";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДокументПродажи", ДокументПродажи);
	
	ТаблицаРезультата = Запрос.Выполнить().Выгрузить();
	Результат = ТаблицаРезультата.ВыгрузитьКолонку(0);
	
	Возврат Результат;
	
КонецФункции

Процедура СвязанныеДокументы_ЗаполнитьКоллекциюПоДокументу(КоллекцияПриемник, Документ)
	
	СвязанныеДокументы = СвязанныеДокументы_ПолучитьПоКритериюОтбора(Документ);
	
	Для Каждого СсылкаНаОбъект Из СвязанныеДокументы Цикл
		Если КоллекцияПриемник.Найти(СсылкаНаОбъект) = Неопределено Тогда
			КоллекцияПриемник.Добавить(СсылкаНаОбъект); 
			СвязанныеДокументы_ЗаполнитьКоллекциюПоДокументу(КоллекцияПриемник, СсылкаНаОбъект)
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Возвращает массив ссылок на связанные документы учета 1С
//
// Параметры:
//  Документ - Любая ссылка	 - ссылка на документ учета 1С, для которого необходимо получить коллекую связанных с ним
// 
// Возвращаемое значение:
//  Массив - массив ссылок на документы 1С
//
Функция СвязанныеДокументы_ПолучитьПоКритериюОтбора(Документ)
	
	ТекстЗапроса = 	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СвязанныеДокументы.Ссылка КАК Ссылка
	|ИЗ
	|	КритерийОтбора.СвязанныеДокументы(&Ссылка) КАК СвязанныеДокументы";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Результат = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0);
	
	Возврат Результат;	
	
КонецФункции

// Процедура - При получении оснований документа учета
//
// Параметры:
//  КоллекцияОснований	 - Массив - Коллекция для заполнения документами основания
//  ДокументУчета		 - ДокументСсылка - Ссылка на документ учета по которому выбираются документы основания
//
Процедура ПриПолученииОснованийДокументаУчета(КоллекцияОснований, ДокументУчета) Экспорт
	
	Если НЕ ТипЗнч(ДокументУчета) = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	КоллекцияОснований = ДокументыОснованияСчетаФактуры(ДокументУчета);
	
КонецПроцедуры

Функция ЭтоСчетНаОплату(Документ)
	
	Результат = (ТипЗнч(Документ) = Тип("ДокументСсылка.СчетНаОплатуПокупателю"));
	Возврат Результат;
	
КонецФункции

Функция ЭтоЗаказПокупателя(Документ)
	
	Результат = (ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказПокупателя"));
	Возврат Результат;
	
КонецФункции

Функция ЭтоДокументПродажи(Документ)
	
	МассивТипов = Новый Массив;
	
	МассивТипов.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетКомиссионераОПродажах"));
	МассивТипов.Добавить(Тип("ДокументСсылка.КорректировкаРеализации"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетКомитентуОПродажах"));
	
	Результат = МассивТипов.Найти(ТипЗнч(Документ)) <> Неопределено;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что документ является корректировочным документом.
// Корректировочный документ - это КРТУ с видом "Корректировка по согласованию сторон"
// или исправительный КРТУ на основании корректировочного документа.
//
// Параметры:
//  КРТУ - ДокументСсылка.КорректировкаРеализации - ссылка на проверяемый документ
// 
// Возвращаемое значение:
//  Булево - Истина, если это КРТУ на корректировку или исправление корректировки.
//
Функция ЭтоКорректировкаРеализации(КРТУ)
	
	Результат = Ложь;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Т.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА Т.ВидОперации = &ВидОперацииКорректировка
	|				ИЛИ Т.ИсправляемыйДокументРеализации ССЫЛКА Документ.КорректировкаРеализации
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоКорректировка
	|ИЗ
	|	Документ.КорректировкаРеализации КАК Т
	|ГДЕ
	|	Т.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", КРТУ);
	Запрос.УстановитьПараметр("ВидОперацииКорректировка", Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.ЭтоКорректировка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет модель данных электронного счета на оплату.
//
// Параметры:
//	Шапка - Контракт шапки неформализованного счета на оплату по форме ДД (см. МенеджерИнтеграции.Новый_ШапкаСчетаНаОплату())
//  ТабличнаяЧасть - Контракт табличной части неформализованного счета на оплату по форме ДД (см. МенеджерИнтеграции.Новый_ТабличнаяЧастьСчетаНаОплату() 
//  ОснованиеЭлектронногоСчета - ЛюбаяСсылка - Основание электронного счета
//
Процедура СчетаНаОплату_ЗаполнитьДанные(МодельШапка, МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета) Экспорт
	
	Если ЭтоСчетНаОплату(ОснованиеЭлектронногоСчета) Тогда
		
		СчетаНаОплату_ШапкаСчетНаОплатуПокупателю(МодельШапка, ОснованиеЭлектронногоСчета);
		СчетаНаОплату_ТабличнаяЧастьСчетНаОплатуПокупателю(МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ЭтоЗаказПокупателя(ОснованиеЭлектронногоСчета) Тогда
		
		СчетаНаОплату_ШапкаЗаказПокупателя(МодельШапка, ОснованиеЭлектронногоСчета);
		СчетаНаОплату_ТабличнаяЧастьЗаказПокупателя(МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ЭтоДокументПродажи(ОснованиеЭлектронногоСчета) Тогда
		
		СчетаНаОплату_ШапкаДокументПродажи(МодельШапка, ОснованиеЭлектронногоСчета);
		СчетаНаОплату_ТабличнаяЧастьДокументПродажи(МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета);
		
	Иначе
		
		ШаблонТекстаОшибки = НСтр("ru='Неожиданный тип документа: %1'");
		
		ТекстОшибки = СтрШаблонЛок(ШаблонТекстаОшибки, ТипЗнч(ОснованиеЭлектронногоСчета));
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СчетаНаОплату_ШапкаСчетНаОплатуПокупателю(МодельШапка, ОснованиеЭлектронногоСчета)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", ОснованиеЭлектронногоСчета);
	Запрос.Текст = ТекстЗапроса_ДанныеДокументаСчетНаОплатуПокупателю();
	
	ДанныеШапки = Запрос.Выполнить().Выбрать();
	ДанныеШапки.Следующий();
	
	СчетаНаОплату_ЗаполнитьШапкуЭлектронногоСчетаПоУмолчанию(МодельШапка, ДанныеШапки);
	
КонецПроцедуры

Процедура СчетаНаОплату_ТабличнаяЧастьСчетНаОплатуПокупателю(МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета)
	
