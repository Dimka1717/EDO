Функция ЗаполнитьТаблицуСопоставленияНоменклатуры(Параметры)
	
	ВладелецНоменклатуры		= Параметры.Контрагент;
	НоменклатураКонтрагента		= Параметры.МассивНоменклатуры;
	РезультатСозданияДокумента	= Параметры.РезультатСозданияДокумента;
	
	Для Каждого Элемент Из НоменклатураКонтрагента Цикл
		
		НоменклатураКод = Элемент.Код;
		НоменклатураАртикул = Элемент.Артикул;
		НоменклатураНаименование = Элемент.Наименование;
		
		ДобавитьНоменклатуруДляСопоставления(
			РезультатСозданияДокумента,
			ВладелецНоменклатуры,
			НоменклатураНаименование,
			НоменклатураКод,
			НоменклатураАртикул
		);
		
	КонецЦикла;
	
	Возврат Истина;
	
