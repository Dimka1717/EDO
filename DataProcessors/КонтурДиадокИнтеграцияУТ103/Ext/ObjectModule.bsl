Функция ТекстЗапроса_СчетаФактуры(ОписаниеВидаПакета, ВидСчетаФактуры, Исправление)
	
	ВидПакетаID = ОписаниеВидаПакета.ID;
	
	Результат =
		"ВЫБРАТЬ
		|	СчетФактура.Ссылка КАК Документ,
		|	СчетФактура.Номер КАК НомерДокумента,
		|	СчетФактура.Дата КАК ДатаДокумента,
		|	СчетФактура.Контрагент КАК Контрагент,
		|	СчетФактура.Организация КАК Организация,
		|	СчетФактура.СуммаДокумента КАК СуммаДокумента,
		|	&ВидПакетаID КАК ВидПакетаID
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО СчетФактура.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И СчетФактура.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО СчетФактура.Ссылка = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL
		|	И НЕ ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные
		|	И СчетФактура.Проведен
		|	И СчетФактура.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И СчетФактура.ВидСчетаФактуры = ЗНАЧЕНИЕ(Перечисление.ВидСчетаФактурыВыставленного.НаРеализацию)
		|	И НЕ СчетФактура.Исправление
		|	И &ДополнительныеОтборы
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СчетФактура.Ссылка,
		|	СчетФактура.Номер,
		|	СчетФактура.Дата,
		|	СчетФактура.Контрагент,
		|	СчетФактура.Организация,
		|	СчетФактура.СуммаДокумента,
		|	&ВидПакетаID
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО СчетФактура.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И СчетФактура.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО СчетФактура.Ссылка = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL
		|	И ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные
		|	И НЕ СчетФактура.ПометкаУдаления
		|	И СчетФактура.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И СчетФактура.ВидСчетаФактуры = ЗНАЧЕНИЕ(Перечисление.ВидСчетаФактурыВыставленного.НаРеализацию)
		|	И НЕ СчетФактура.Исправление
		|	И &ДополнительныеОтборы";
	
	Если Исправление Тогда
		
		Если ВидПакетаID = "ID_ИСФ" Тогда
			ВидИсправляемогоПакета = "ID_ОсновнойПакет";
		Иначе
			ВидИсправляемогоПакета = СтрЗаменить(ВидПакетаID, "ID_И", "ID_");
		КонецЕсли;
		
		Результат = СтрЗаменить(Результат, "ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID",
				"ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = """ + ВидИсправляемогоПакета + """");
		
		Результат = СтрЗаменить(Результат, "НЕ СчетФактура.Исправление", "СчетФактура.Исправление");
		
	КонецЕсли;
	
	ТекстЗапросаДополнительныеОтборы = ТекстЗапроса_ДополнительныеОтборыСчетаФактуры();
	
	Результат = СтрЗаменить(Результат, "&ДополнительныеОтборы", ТекстЗапросаДополнительныеОтборы);
	Результат = СтрЗаменить(Результат, "&ВидПакетаID", """" + ВидПакетаID + """");
	Результат = СтрЗаменить(Результат, "НаРеализацию", ВидСчетаФактуры);
	
	
	Результат = ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(Результат, ОписаниеВидаПакета);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ДополнительныеОтборыСчетаФактуры()
	
	Результат = "НЕ СчетФактура.ДокументОснование Ссылка Документ.ОтчетКомиссионераОПродажах";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_СчетФактурыПоОтчетуКомиссионера(ОписаниеВидаПакета)
	
	ВидПакетаID = ОписаниеВидаПакета.ID;
	
	Результат =
		"ВЫБРАТЬ
		|	СчетФактурыПоОтчетуКомиссионера.Документ КАК Документ,
		|	СчетФактурыПоОтчетуКомиссионера.НомерДокумента КАК НомерДокумента,
		|	СчетФактурыПоОтчетуКомиссионера.ДатаДокумента КАК ДатаДокумента,
		|	СчетФактурыПоОтчетуКомиссионера.Контрагент КАК Контрагент,
		|	СчетФактурыПоОтчетуКомиссионера.Организация КАК Организация,
		|	0 КАК СуммаДокумента,
		|	&ВидПакетаID КАК ВидПакетаID
		|ИЗ
		|	ВТ_СчетФактурыПоОтчетуКомиссионера КАК СчетФактурыПоОтчетуКомиссионера
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО СчетФактурыПоОтчетуКомиссионера.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И СчетФактурыПоОтчетуКомиссионера.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО СчетФактурыПоОтчетуКомиссионера.Документ = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL
		|	И ВЫБОР
		|			КОГДА ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ СчетФактурыПоОтчетуКомиссионера.Проведен
		|		КОНЕЦ";
	
	Результат = СтрЗаменить(Результат, "&ВидПакетаID", """" + ВидПакетаID + """");
	
	Результат = ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(Результат, ОписаниеВидаПакета);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ПервичныеДокументыБезНДС(ОписаниеВидаПакета)
	
	ВидПакетаID = ОписаниеВидаПакета.ID;
	
	Результат =
		"ВЫБРАТЬ
		|	ВТ_ДокументыБезНДС.Документ,
		|	ВТ_ДокументыБезНДС.НомерДокумента,
		|	ВТ_ДокументыБезНДС.ДатаДокумента,
		|	ВТ_ДокументыБезНДС.Контрагент,
		|	ВТ_ДокументыБезНДС.Организация,
		|	ВТ_ДокументыБезНДС.СуммаДокумента,
		|	&ВидПакетаID КАК ВидПакетаID
		|ИЗ
		|	ВТ_ДокументыБезНДС КАК ВТ_ДокументыБезНДС
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО ВТ_ДокументыБезНДС.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И ВТ_ДокументыБезНДС.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|			И (ВТ_ДокументыБезНДС.ЭтоИсправление)
		|			И (НЕ ВТ_ДокументыБезНДС.ЭтоКорректировка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО ВТ_ДокументыБезНДС.Документ = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL 
		|	И НЕ ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные
		|	И ВТ_ДокументыБезНДС.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_ДокументыБезНДС.Документ,
		|	ВТ_ДокументыБезНДС.НомерДокумента,
		|	ВТ_ДокументыБезНДС.ДатаДокумента,
		|	ВТ_ДокументыБезНДС.Контрагент,
		|	ВТ_ДокументыБезНДС.Организация,
		|	ВТ_ДокументыБезНДС.СуммаДокумента,
		|	&ВидПакетаID
		|ИЗ
		|	ВТ_ДокументыБезНДС КАК ВТ_ДокументыБезНДС
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО ВТ_ДокументыБезНДС.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И ВТ_ДокументыБезНДС.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|			И (ВТ_ДокументыБезНДС.ЭтоИсправление)
		|			И (НЕ ВТ_ДокументыБезНДС.ЭтоКорректировка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО ВТ_ДокументыБезНДС.Документ = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL 
		|	И ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные";
	
	Если Найти(ВидПакетаID, "ID_И") = 0 Тогда
		Результат = СтрЗаменить(
				Результат,
				"И (ВТ_ДокументыБезНДС.ЭтоИсправление)",
				"И (НЕ ВТ_ДокументыБезНДС.ЭтоИсправление)");
	КонецЕсли;
	
	Если ЭтоКорректировкаРеализацииБезНДС(ВидПакетаID) Тогда
		Результат = СтрЗаменить(
				Результат,
				"И (НЕ ВТ_ДокументыБезНДС.ЭтоКорректировка)",
				"И (ВТ_ДокументыБезНДС.ЭтоКорректировка)");
	КонецЕсли;
	
	Если ВидПакетаID = "ID_ТОРГ12_Акт_БезНДС" Тогда
		ВидПервичногоПакета = "= ""ID_ОсновнойПакет""";
	Иначе
		
		ВидПервичногоПакетаПолный = СтрЗаменить(ВидПакетаID, "ID_И", "ID_");
		ВидПервичногоПакетаПолный = СтрЗаменить(ВидПервичногоПакетаПолный, "_БезНДС", "");
		ВидПервичногоПакетаРаздельно = ВидПервичногоПакетаПолный + "_Раздельно";
		
		ВидПервичногоПакета = "В (""" + ВидПервичногоПакетаПолный + """,""" + ВидПервичногоПакетаРаздельно + """)";
		
	КонецЕсли;
	
	Результат = СтрЗаменить(
			Результат,
			"ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID",
			"ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID " + ВидПервичногоПакета);
	
	Результат = СтрЗаменить(Результат, "&ВидПакетаID", """" + ВидПакетаID + """");
	
	Результат = ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(Результат, ОписаниеВидаПакета);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_СчетаНаОплату(ОписаниеВидаПакета)
	
	КатегорияПакета = ОписаниеВидаПакета.КатегорияПакета;
	ВидПакетаID = ОписаниеВидаПакета.ID;
	
	Результат =
		"ВЫБРАТЬ
		|	СчетНаОплатуПокупателю.Ссылка КАК Документ,
		|	СчетНаОплатуПокупателю.Номер КАК НомерДокумента,
		|	СчетНаОплатуПокупателю.Дата КАК ДатаДокумента,
		|	СчетНаОплатуПокупателю.Контрагент КАК Контрагент,
		|	СчетНаОплатуПокупателю.Организация КАК Организация,
		|	СчетНаОплатуПокупателю.СуммаДокумента КАК СуммаДокумента,
		|	&ВидПакетаID КАК ВидПакетаID
		|ИЗ
		|	Документ.СчетНаОплатуПокупателю КАК СчетНаОплатуПокупателю
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО СчетНаОплатуПокупателю.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И СчетНаОплатуПокупателю.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО СчетНаОплатуПокупателю.Ссылка = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL
		|	И СчетНаОплатуПокупателю.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И НЕ СчетНаОплатуПокупателю.ПометкаУдаления";
	
	Результат = СтрЗаменить(Результат, "&ВидПакетаID", """" + ВидПакетаID + """");
	
	Результат = ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(Результат, ОписаниеВидаПакета);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_АктыСверок(ОписаниеВидаПакета)
	
	ВидПакетаID = ОписаниеВидаПакета.ID;
	
	Результат =
		"ВЫБРАТЬ
		|	АктСверкиВзаиморасчетов.Ссылка КАК Документ,
		|	АктСверкиВзаиморасчетов.Номер КАК НомерДокумента,
		|	АктСверкиВзаиморасчетов.Дата КАК ДатаДокумента,
		|	АктСверкиВзаиморасчетов.Контрагент КАК Контрагент,
		|	АктСверкиВзаиморасчетов.Организация КАК Организация,
		|	0 КАК СуммаДокумента,
		|	&ВидПакетаID КАК ВидПакетаID
		|ИЗ
		|	Документ.АктСверкиВзаиморасчетов КАК АктСверкиВзаиморасчетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов
		|		ПО АктСверкиВзаиморасчетов.Организация = ВТ_КэшКонтрагентовПоВидамПакетов.Организация1С
		|			И АктСверкиВзаиморасчетов.Контрагент = ВТ_КэшКонтрагентовПоВидамПакетов.Контрагент1С
		|			И (ВТ_КэшКонтрагентовПоВидамПакетов.ВидПакетаID = &ВидПакетаID)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
		|		ПО АктСверкиВзаиморасчетов.Ссылка = ОтправленныеДокументы.Документ
		|			И (&УсловиеСвязиПоКатегорииПакета)
		|ГДЕ
		|	ОтправленныеДокументы.Документ ЕСТЬ NULL
		|	И АктСверкиВзаиморасчетов.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И НЕ АктСверкиВзаиморасчетов.ПометкаУдаления";
	
	Результат = СтрЗаменить(Результат, "&ВидПакетаID", """" + ВидПакетаID + """");
	
	Результат = ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(Результат, ОписаниеВидаПакета);
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьТаблицу_ПеремещениеТоваров(Запрос)
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТаблицаДокументов.Организация КАК Организация,
	|	ВТ_Отправители.Подразделение1С КАК ПодразделениеОтправитель,
	|	ВТ_Получатели.Подразделение1С КАК ПодразделениеПолучатель,
	|	ТаблицаДокументов.Номер КАК НомерДокумента,
	|	ТаблицаДокументов.Дата КАК ДатаДокумента,
	|	0 КАК СуммаДокумента,
	|	ТаблицаДокументов.Ссылка КАК Документ
	|ПОМЕСТИТЬ Диадок_ПеремещениеТоваров
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ТаблицаДокументов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_НастройкиВнутреннегоДокументооборота КАК ВТ_Настройки
	|		ПО ТаблицаДокументов.Организация = ВТ_Настройки.Организация1С
	|			И (ВТ_Настройки.ВидПакета = &ВидПакетаID)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_УчастникиВнутреннегоДокументооборота КАК ВТ_Отправители
	|		ПО ТаблицаДокументов.Организация = ВТ_Отправители.Организация1С
	|			И ТаблицаДокументов.СкладОтправитель = ВТ_Отправители.Подразделение1С
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_УчастникиВнутреннегоДокументооборота КАК ВТ_Получатели
	|		ПО ТаблицаДокументов.Организация = ВТ_Получатели.Организация1С
	|			И ТаблицаДокументов.СкладПолучатель = ВТ_Получатели.Подразделение1С
	|ГДЕ
	|	ТаблицаДокументов.Проведен
	|	И ТаблицаДокументов.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И НЕ ВТ_Отправители.Подразделение1С ЕСТЬ NULL
	|	И НЕ ВТ_Получатели.Подразделение1С ЕСТЬ NULL";
	
	Запрос.Выполнить();
	
	Возврат "Диадок_ПеремещениеТоваров";
	
КонецФункции

Функция ТекстЗапроса_СкорректированныеСвязиДляОтправленныхДокументов(ТекстЗапроса, ОписаниеВидаПакета)
	
	ВидПакетаID = ОписаниеВидаПакета.ID;
	КатегорияПакета = ОписаниеВидаПакета.КатегорияПакета;
	
	ОсновнойПакет = КатегорииПакетов_Основная();
	
	ПодстрокаПоиска = "&УсловиеСвязиПоКатегорииПакета";
	
	Если ЗначениеЗаполнено(КатегорияПакета) Тогда
		ПодстрокаЗамены = "ОтправленныеДокументы.КатегорияПакета = """ + КатегорияПакета + """"
			+ " ИЛИ ОтправленныеДокументы.КатегорияПакета ЕСТЬ NULL";
	Иначе
		ПодстрокаЗамены = "ОтправленныеДокументы.ВидПакета = &ВидПакетаID_" + ВидПакетаID
			+ " ИЛИ ОтправленныеДокументы.ВидПакета ЕСТЬ NULL";
	КонецЕсли;
	
	Если КатегорияПакета = КатегорииПакетов_СчетаНаОплату() Тогда
		
		ПодстрокаЗамены = ПодстрокаЗамены
			+ " ИЛИ ОтправленныеДокументы.КатегорияПакета = """ + ОсновнойПакет + """";
		
		ИспользоватьСХ2 = НЕ ОсновнойМодуль.ИспользоватьПодсистемуДиадока();
		ОснованияПоУмолчанию = Ядро_ОснованияВидовДокументов_ИспользуютсяТолькоНастройкиПоУмолчанию();
		
		Если ИспользоватьСХ2 И ОснованияПоУмолчанию Тогда
			ПодстрокаЗамены = "ИСТИНА";
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = СтрЗаменить(ТекстЗапроса, ПодстрокаПоиска, ПодстрокаЗамены);
	
	Возврат Результат;
	
КонецФункции

