Функция УПД970_АдресИзПредставленияАдреса(Ссылка, ПредставлениеАдреса)
	
	Результат = Неопределено;
	
	РезультатЗапроса = УПД970_СведенияОбАдресеПоПредставлениюИзИБ(Ссылка, ПредставлениеАдреса);
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда 
		
		Результат = НоваяЗаписьКонтактнойИнформации();
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		
		ЗаполнитьТипыАдресныхОбъектов(Результат);
		
		Если ЗначениеЗаполнено(Результат.Значение) Тогда
			ДополнитьКонтактнуюИнформациюДаннымиJson(Результат, Выборка.Значение, Выборка.Тип);
		КонецЕсли;
		
		УПД970_АдаптироватьПоляСтруктурыАдресов(Результат);
		
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		Результат = НоваяЗаписьКонтактнойИнформации();
		Результат.Представление = ПредставлениеАдреса;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОбАдресеПоПредставлениюИзИБ(Ссылка, Знач ПредставлениеАдреса)
	
	Результат = Неопределено;
	
	МаксимальнаяДлинаСтроки = 1000;
	ПредставлениеАдреса = Сред(ПредставлениеАдреса, 1, МаксимальнаяДлинаСтроки);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", Ссылка);
	Запрос.УстановитьПараметр("Представление", ПредставлениеАдреса);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	*
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация КАК Т
	|ГДЕ
	|	Т.Объект = &Объект
	|	И ВЫРАЗИТЬ(Т.Представление КАК СТРОКА(1000)) = &Представление";
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции

