КонецПроцедуры

Процедура СчетаНаОплату_ШапкаОтчетКомитентуОПродажах(МодельШапка, ОснованиеЭлектронногоСчет)
	
	Результат = Новый ТабличныйДокумент;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", ОснованиеЭлектронногоСчет);
	Запрос.Текст = ТекстЗапроса_ДанныеДокументаОтчетКомитентуОПродажах();
	
	ДанныеШапки = Запрос.Выполнить().Выбрать();
	ДанныеШапки.Следующий();
	
	НомерДокумента = ПредставлениеНомера(ДанныеШапки);
	ДатаДокумента = ДанныеШапки.Дата;
	
	СведенияОбОрганизации = СчетаНаОплату_ДанныеЮрФизЛица(ДанныеШапки.Организация, ДатаДокумента);
	СведенияОКонтрагенте = СчетаНаОплату_ДанныеЮрФизЛица(ДанныеШапки.Контрагент, ДатаДокумента);
	
	МодельШапка.Заголовок = СчетаНаОплату_ЗаголовокПечатнойФормы(НомерДокумента, ДатаДокумента);
	МодельШапка.Продавец = ДанныеШапки.Организация;
	МодельШапка.ПродавецПредставление = СчетаНаОплату_ПредставлениеЮрФизЛица(СведенияОбОрганизации);
	МодельШапка.ПродавецОписание = СчетаНаОплату_СтрокаРеквизитыЮрФизЛица(СведенияОбОрганизации);
	МодельШапка.ПродавецИНН = СведенияОбОрганизации.ИНН;
	МодельШапка.ПродавецКПП = СведенияОбОрганизации.КПП;
	МодельШапка.Покупатель = ДанныеШапки.Контрагент;
	МодельШапка.ПокупательПредставление = СчетаНаОплату_ПредставлениеЮрФизЛица(СведенияОКонтрагенте);
	МодельШапка.ПокупательОписание = СчетаНаОплату_СтрокаРеквизитыЮрФизЛица(СведенияОКонтрагенте);
	МодельШапка.Номер = НомерДокумента;
	МодельШапка.Дата = ДатаДокумента;
	МодельШапка.ЦенаВключаетНДС = Истина;
	МодельШапка.ОблагаетсяНДСУПокупателя = Ложь;
	МодельШапка.Валюта = ДанныеШапки.Валюта;
	МодельШапка.ВалютаКод = КодВалюты(ДанныеШапки.Валюта);
	МодельШапка.УчитыватьНДС = ДанныеШапки.УчитыватьНДС;
	
	БанковскийСчет = ДанныеШапки.БанковскийСчетОрганизацииПоУмолчанию;
	
	Если ЗначениеЗаполнено(БанковскийСчет) Тогда
		
		РеквизитыСчета = РеквизитыБанковскогоСчета(БанковскийСчет);
		
		МодельШапка.ПродавецБанк = РеквизитыСчета.Банк;
		МодельШапка.ПродавецБанкБИК = РеквизитыСчета.БИК;
		МодельШапка.ПродавецБанкПредставление = РеквизитыСчета.БанкНаименование;
		МодельШапка.ПродавецБанковскийСчет = БанковскийСчет;
		МодельШапка.ПродавецБанковскийСчетНомер = РеквизитыСчета.НомерСчета;
		МодельШапка.ПродавецБанковскийСчетКорСчет = РеквизитыСчета.КоррСчет;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СчетаНаОплату_ТабличнаяЧастьОтчетКомитентуОПродажах(МодельТабличнаяЧасть, ОснованиеЭлектронногоСчета)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", ОснованиеЭлектронногоСчета);
	Запрос.Текст = ТекстЗапроса_ДанныеТабличнойЧастиОтчетКомитентуОПродажах();
	
	ДанныеТабличнойЧасти = Запрос.Выполнить().Выбрать();
	ДанныеТабличнойЧасти.Следующий();
	
	НоваяСтрока = МодельТабличнаяЧасть.Добавить();
	
	НоваяСтрока.НоменклатураПредставление = НСтр("ru='Комиссионное вознаграждение'");
	НоваяСтрока.Сумма = ДанныеТабличнойЧасти.Сумма;
	НоваяСтрока.СуммаНДС = ДанныеТабличнойЧасти.СуммаНДС;
	
КонецПроцедуры

Процедура СчетаНаОплату_ЗаполнитьШапкуЭлектронногоСчетаПоУмолчанию(Модель, ДанныеШапки)
	
	НомерДокумента = ПредставлениеНомера(ДанныеШапки);
	ДатаДокумента = ДанныеШапки.Дата;
	
	СведенияОбОрганизации = СчетаНаОплату_ДанныеЮрФизЛица(ДанныеШапки.Организация, ДатаДокумента);
	СведенияОКонтрагенте = СчетаНаОплату_ДанныеЮрФизЛица(ДанныеШапки.Контрагент, ДатаДокумента);
	
	Модель.Заголовок = СчетаНаОплату_ЗаголовокПечатнойФормы(НомерДокумента, ДатаДокумента);
	Модель.Продавец = ДанныеШапки.Организация;
	Модель.ПродавецПредставление = СчетаНаОплату_ПредставлениеЮрФизЛица(СведенияОбОрганизации);
	Модель.ПродавецОписание = СчетаНаОплату_СтрокаРеквизитыЮрФизЛица(СведенияОбОрганизации);
	Модель.ПродавецИНН = СведенияОбОрганизации.ИНН;
	Модель.ПродавецКПП = СведенияОбОрганизации.КПП;
	Модель.Покупатель = ДанныеШапки.Контрагент;
	Модель.ПокупательПредставление = СчетаНаОплату_ПредставлениеЮрФизЛица(СведенияОКонтрагенте);
	Модель.ПокупательОписание = СчетаНаОплату_СтрокаРеквизитыЮрФизЛица(СведенияОКонтрагенте);
	Модель.Номер = НомерДокумента;
	Модель.Дата = ДатаДокумента;
	Модель.ЦенаВключаетНДС = ДанныеШапки.СуммаВключаетНДС;
	Модель.ОблагаетсяНДСУПокупателя = Ложь;
	Модель.Валюта = ДанныеШапки.Валюта;
	Модель.ВалютаКод = КодВалюты(ДанныеШапки.Валюта);
	Модель.УчитыватьНДС = ДанныеШапки.УчитыватьНДС;
	
	БанковскийСчет = ДанныеШапки.БанковскийСчетОрганизации;
	Если НЕ ЗначениеЗаполнено(БанковскийСчет)
		ИЛИ ТипЗнч(БанковскийСчет) <> Тип("СправочникСсылка.БанковскиеСчета") Тогда
		БанковскийСчет = ДанныеШапки.БанковскийСчетОрганизацииПоУмолчанию;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(БанковскийСчет) Тогда
		
		РеквизитыСчета = РеквизитыБанковскогоСчета(БанковскийСчет);
		
		Модель.ПродавецБанк = РеквизитыСчета.Банк;
		Модель.ПродавецБанкБИК = РеквизитыСчета.БИК;
		Модель.ПродавецБанкПредставление = РеквизитыСчета.БанкНаименование;
		Модель.ПродавецБанковскийСчет = БанковскийСчет;
		Модель.ПродавецБанковскийСчетНомер = РеквизитыСчета.НомерСчета;
		Модель.ПродавецБанковскийСчетКорСчет = РеквизитыСчета.КоррСчет;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СчетаНаОплату_ЗаполнитьТабличнуюЧастьЭлектронногоСчетаПоУмолчанию(Модель, ДанныеТабличнойЧасти)
	
	МодульЦенообразование = ОбщийМодульПоИмениЛок("Ценообразование");
	
	Пока ДанныеТабличнойЧасти.Следующий() Цикл
		
		НоваяСтрока = Модель.Добавить();
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеТабличнойЧасти);
		
		НоваяСтрока.СуммаСкидки = МодульЦенообразование.ПолучитьСуммуСкидки(ДанныеТабличнойЧасти.Сумма, ДанныеТабличнойЧасти.Скидка);
		
		НоваяСтрока.НоменклатураПредставление = ПредставлениеНоменклатурыЛок(
			ДанныеТабличнойЧасти.НаименованиеПолное,
			ДанныеТабличнойЧасти.Характеристика,
			ДанныеТабличнойЧасти.Содержание
		);
		
		НоваяСтрока.НоменклатураАртикул = АртикулНоменклатуры(ДанныеТабличнойЧасти.Номенклатура);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СчетаНаОплату_ПредставлениеЮрФизЛица(РеквизитыЮрФизЛица)
	
	Результат = РеквизитыЮрФизЛица.ПолноеНаименование;
	
	Если РеквизитыЮрФизЛица.Свойство("Представление") Тогда
		Результат = РеквизитыЮрФизЛица.Представление;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_СтрокаРеквизитыЮрФизЛица(Реквизиты)
	
	ШаблонПредставления = "ПолноеНаименование,ИНН,КПП,ЮридическийАдрес,Телефоны";
	Результат = ПредставлениеЮрФизЛицаСлужебный(Реквизиты, ШаблонПредставления);
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_ДанныеЮрФизЛица(Участник, ДатаСведений)
	
	Модель = Новый Структура;
	Модель.Вставить("ПолноеНаименование", "");
	Модель.Вставить("СокращенноеНаименование", "");
	Модель.Вставить("ИНН", "");
	Модель.Вставить("КПП", "");
	Модель.Вставить("Телефоны", "");
	Модель.Вставить("ЮридическийАдрес", "");
	
	МодульУправлениеКонтактнойИнформацией = ОбщийМодульПоИмениЛок("УправлениеКонтактнойИнформацией");
	
	Данные = МодульУправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Участник, ДатаСведений);
	
	Модель.ПолноеНаименование = Данные.ПолноеНаименование;
	Модель.ИНН = Данные.ИНН;
	Модель.КПП = Данные.КПП;
	Модель.Телефоны = Данные.Телефоны;
	Модель.ЮридическийАдрес = Данные.ЮридическийАдрес;
	
	Если Данные.Свойство("НаименованиеСокращенное") Тогда
		Модель.СокращенноеНаименование = Данные.НаименованиеСокращенное;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Модель.СокращенноеНаименование) Тогда
		Модель.СокращенноеНаименование = Данные.Представление;
	КонецЕсли;
	
	Результат = Новый ФиксированнаяСтруктура(Модель);
	
	Возврат Результат;
	
КонецФункции

Функция СчетаНаОплату_ЗаголовокПечатнойФормы(НомерДокумента, ДатаДокумента)
	
	Результат = СтрШаблонЛок(
		"Счет на оплату № %1 от %2",
		НомерДокумента,
		Формат(ДатаДокумента, "ДФ=dd.MM.yyyy")
	);
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеЮрФизЛицаСлужебный(Реквизиты, ШаблонПредставления = "")
	
	Перем Префикс, СтрокаДополнения;
	
	СоответствиеПараметров = Новый Структура;
	СоответствиеПараметров.Вставить("ПолноеНаименование", " ");
	СоответствиеПараметров.Вставить("НаименованиеСокращенное", " ");
	СоответствиеПараметров.Вставить("Представление", " ");
	СоответствиеПараметров.Вставить("ИНН", " ИНН ");
	СоответствиеПараметров.Вставить("КПП", " КПП ");
	СоответствиеПараметров.Вставить("Свидетельство", " ");
	СоответствиеПараметров.Вставить("СвидетельствоДатаВыдачи", " от ");
	СоответствиеПараметров.Вставить("ЮридическийАдрес", " ");
	СоответствиеПараметров.Вставить("ФактическийАдрес", " ");
	СоответствиеПараметров.Вставить("Телефоны", " тел.: ");
	СоответствиеПараметров.Вставить("Факс", " факс: ");
	СоответствиеПараметров.Вставить("НомерСчета", " р/с ");
	СоответствиеПараметров.Вставить("Банк", " в банке ");
	СоответствиеПараметров.Вставить("БИК", " БИК ");
	СоответствиеПараметров.Вставить("КоррСчет", " к/с ");
	СоответствиеПараметров.Вставить("КодПоОКПО", " Код по ОКПО ");
	
	Если ПустаяСтрока(ШаблонПредставления) Тогда
		
		Если НЕ Реквизиты.Свойство("Представление")
			ИЛИ НЕ ЗначениеЗаполнено(Реквизиты.Представление) Тогда
			
			ШаблонПредставления = "ПолноеНаименование," + ШаблонПредставления;
			
		Иначе
			
			ШаблонПредставления = "Представление," + ШаблонПредставления;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПропускатьПустыеСтроки = Истина;
	Разделитель = ",";
	ИнтерфейсБСП = ОбщийМодульПоИмениЛок("СтроковыеФункцииКлиентСервер");
	СписокПараметров = ИнтерфейсБСП.РазложитьСтрокуВМассивПодстрок(
		ШаблонПредставления,
		Разделитель,
		ПропускатьПустыеСтроки
	);
	
	Результат = Новый Массив;
	
	Для Каждого ИмяПараметра Из СписокПараметров Цикл
		
		Если Реквизиты.Свойство(ИмяПараметра, СтрокаДополнения) Тогда
			
			Реквизиты.Свойство(ИмяПараметра, СтрокаДополнения);
			Если ПустаяСтрока(СтрокаДополнения) Тогда
				Продолжить;
			КонецЕсли;
			
			Если СоответствиеПараметров.Свойство(ИмяПараметра, Префикс) Тогда
				Результат.Добавить(Префикс + СтрокаДополнения);
			Иначе
				Результат.Добавить(СтрокаДополнения);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтрокаРезультата = СоединитьСтроку(Результат, ",");
	СтрокаРезультата = СтрЗаменить(СтрокаРезультата, "  ", " ");
	
	Возврат СокрЛП(СтрокаРезультата);
	
КонецФункции

Функция КодВалюты(ВалютаСсылка)
	
	ЗначениеРеквизита = ЗначенияРеквизитовОбъектаЛок(
		ВалютаСсылка,
		"Код"
	);
	
	Результат = ЗначениеРеквизита.Код;
	
	Если Результат = Неопределено Тогда
		Результат = "643";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеНоменклатурыЛок(Номенклатура, Характеристика, Содержание)
	
	НоменклатураНаименование = СокрЛП(Номенклатура);
	ХарактеристикаНаименование = СокрЛП(Характеристика);
	Упаковка = Неопределено;
	Серия = Неопределено;
	
	МодульНоменклатураКлиентСервер = ОбщийМодульПоИмениЛок("НоменклатураКлиентСервер");
	
	ДополнительныеПараметры = МодульНоменклатураКлиентСервер.ДополнительныеПараметрыПредставлениеНоменклатурыДляПечати();
	ДополнительныеПараметры.Содержание = Содержание;
	
	Результат = МодульНоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
		НоменклатураНаименование,
		ХарактеристикаНаименование,
		Упаковка,
		Серия,
		ДополнительныеПараметры
	);
	
	Возврат Результат;
	
КонецФункции

Функция АртикулНоменклатуры(Номенклатура)
	
	ДополнительнаяКолонкаНоменклатуры = Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить();
	
	Если ДополнительнаяКолонкаНоменклатуры = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул Тогда
		
		Результат = Номенклатура.Артикул;
		
	ИначеЕсли ДополнительнаяКолонкаНоменклатуры = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
		
		Результат = Номенклатура.Код;
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РеквизитыБанковскогоСчета(БанковскийСчет)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БанковскиеСчета.НомерСчета КАК НомерСчета,
	|	БанковскиеСчета.Банк.Код КАК БИК,
	|	БанковскиеСчета.Банк КАК Банк,
	|	БанковскиеСчета.Банк.Наименование КАК БанкНаименование,
	|	БанковскиеСчета.Банк.КоррСчет КАК КоррСчет
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	БанковскиеСчета.Ссылка = &БанковскийСчет";
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() > 0 Тогда
		Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура АктыСверок_ЗаполнитьДанные(Модель, СсылкаНаОбъект) Экспорт
	
	ТипОбъекта = ТипЗнч(СсылкаНаОбъект);
	Если ТипОбъекта <> Тип("ДокументСсылка.АктСверкиВзаиморасчетов") Тогда
		
		Ошибка = СтрШаблонЛок(
			"Неожиданный тип параметра 'СсылкаНаОбъект' (%1)",
			Строка(ТипОбъекта)
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Дата КАК Дата,
	|	ДанныеДокумента.ДатаНачала КАК НачалоПериода,
	|	ДанныеДокумента.ДатаОкончания КАК КонецПериода,
	|	ДанныеДокумента.ДоговорКонтрагента КАК Договор,
	|	ПРЕДСТАВЛЕНИЕ(ДанныеДокумента.ДоговорКонтрагента) КАК ДоговорПредставление,
	|	ДанныеДокумента.ВалютаДокумента.Код КАК ВалютаКод,
	|	ДанныеДокумента.ВалютаДокумента.Наименование КАК ВалютаПредставление,
	|	ДанныеДокумента.ОстатокНаНачало КАК ОстатокНаНачало,
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.Организация.Наименование КАК ОрганизацияНаименование,
	|	ДанныеДокумента.Организация.НаименованиеПолное КАК ОрганизацияНаименованиеПолное,
	|	ДанныеДокумента.ПредставительОрганизации КАК ПредставительОрганизации,
	|	ЕСТЬNULL(ДанныеДокумента.ПредставительОрганизации.Наименование, """") КАК ПредставительОрганизацииФИО,
	|	ДанныеДокумента.Контрагент.Наименование КАК КонтрагентНаименование,
	|	ДанныеДокумента.Контрагент.НаименованиеПолное КАК КонтрагентНаименованиеПолное,
	|	ЕСТЬNULL(ДанныеДокумента.ПредставительКонтрагента.Наименование, """") КАК ПредставительКонтрагентаФИО,
	|	ЕСТЬNULL(ДанныеДокумента.ПредставительКонтрагента.Должность, """") КАК ПредставительКонтрагентаДолжность,
	|	ДанныеДокумента.СверкаСогласована КАК СверкаСогласована
	|ИЗ
	|	Документ.АктСверкиВзаиморасчетов КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОрганизации.НомерСтроки КАК НомерСтроки,
	|	ДанныеОрганизации.ДоговорКонтрагента КАК Аналитика,
	|	ДанныеОрганизации.Представление КАК ДокументПредставление,
	|	ДанныеОрганизации.Дата КАК Дата,
	|	ДанныеОрганизации.Дебет КАК Дебет,
	|	ДанныеОрганизации.Кредит КАК Кредит,
	|	ИСТИНА КАК ЭтоДанныеОрганизации
	|ИЗ
	|	Документ.АктСверкиВзаиморасчетов.ПоДаннымОрганизации КАК ДанныеОрганизации
	|ГДЕ
	|	ДанныеОрганизации.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеКонтрагента.НомерСтроки,
	|	ДанныеКонтрагента.ДоговорКонтрагента,
	|	ДанныеКонтрагента.Представление,
	|	ДанныеКонтрагента.Дата,
	|	ДанныеКонтрагента.Дебет,
	|	ДанныеКонтрагента.Кредит,
	|	ЛОЖЬ
	|ИЗ
	|	Документ.АктСверкиВзаиморасчетов.ПоДаннымКонтрагента КАК ДанныеКонтрагента
	|ГДЕ
	|	ДанныеКонтрагента.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтоДанныеОрганизации,
	|	НомерСтроки";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", СсылкаНаОбъект);
	Запрос.УстановитьПараметр("ДатаСверки", СсылкаНаОбъект.Дата);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаШапка = РезультатЗапроса[0].Выбрать();
	Если ВыборкаШапка.Следующий() Тогда
		
		Модель.Шапка.Дата = ВыборкаШапка.Дата;
		Модель.Шапка.НачалоПериода = ВыборкаШапка.НачалоПериода;
		Модель.Шапка.КонецПериода = ВыборкаШапка.КонецПериода;
		Модель.Шапка.ГруппироватьПоАналитике = Ложь;
		Модель.Шапка.СверкаСогласована = ВыборкаШапка.СверкаСогласована;
		
		Модель.Шапка.СверкаПоДоговору = ЗначениеЗаполнено(ВыборкаШапка.Договор);
		Модель.Шапка.ДоговорПредставление = СокрЛП(ВыборкаШапка.ДоговорПредставление);
		
		Модель.Шапка.ВалютаКод = СокрЛП(ВыборкаШапка.ВалютаКод);
		Модель.Шапка.ВалютаПредставление = СокрЛП(ВыборкаШапка.ВалютаПредставление);
		Модель.Шапка.ОстатокНаНачало = ВыборкаШапка.ОстатокНаНачало;
		
		Модель.Шапка.ОрганизацияПредставление = СокрЛП(ВыборкаШапка.ОрганизацияНаименованиеПолное);
		Если ПустаяСтрока(ВыборкаШапка.ОрганизацияНаименованиеПолное) Тогда
			Модель.Шапка.ОрганизацияПредставление = СокрЛП(ВыборкаШапка.ОрганизацияНаименование);
		КонецЕсли;
		
		Модель.Шапка.ПредставительОрганизацииФИО = СокрЛП(ВыборкаШапка.ПредставительОрганизацииФИО);
		Модель.Шапка.ПредставительОрганизацииДолжность = ДолжностьОтветственногоЛицаОрганизации(
			ВыборкаШапка.ПредставительОрганизации,
			ВыборкаШапка.Организация,
			ВыборкаШапка.Дата
		);
		
		Модель.Шапка.КонтрагентПредставление = СокрЛП(ВыборкаШапка.КонтрагентНаименованиеПолное);
		Если ПустаяСтрока(ВыборкаШапка.КонтрагентНаименованиеПолное) Тогда
			Модель.Шапка.КонтрагентПредставление = СокрЛП(ВыборкаШапка.КонтрагентНаименование);
		КонецЕсли;
		
		Модель.Шапка.ПредставительКонтрагентаФИО = СокрЛП(ВыборкаШапка.ПредставительКонтрагентаФИО);
		Модель.Шапка.ПредставительКонтрагентаДолжность = СокрЛП(ВыборкаШапка.ПредставительКонтрагентаДолжность);
		
	КонецЕсли;
	
	ВыборкаТЧ = РезультатЗапроса[1].Выбрать();
	
	Пока ВыборкаТЧ.Следующий() Цикл
		
		Если ВыборкаТЧ.ЭтоДанныеОрганизации Тогда
			Запись = Модель.ДанныеОрганизации.Добавить();
		Иначе
			Запись = Модель.ДанныеКонтрагента.Добавить();
		КонецЕсли;
		
		Запись.Аналитика = ВыборкаТЧ.Аналитика;
		Запись.ДокументПредставление = СокрЛП(ВыборкаТЧ.ДокументПредставление);
		Запись.Дата = ВыборкаТЧ.Дата;
		Запись.Дебет = ВыборкаТЧ.Дебет;
		Запись.Кредит = ВыборкаТЧ.Кредит;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДолжностьОтветственногоЛицаОрганизации(ФизическоеЛицо, Организация, НаДату = '00010101')
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ОтветственныеЛица.Период КАК Период,
	|	ОтветственныеЛица.Должность КАК Должность,
	|	ПРЕДСТАВЛЕНИЕ(ОтветственныеЛица.Должность) КАК ДолжностьПредставление
	|ИЗ
	|	РегистрСведений.ОтветственныеЛицаОрганизации.СрезПоследних(
	|			&Дата,
	|			СтруктурнаяЕдиница = &Организация
	|				И ФизическоеЛицо = &ФизическоеЛицо) КАК ОтветственныеЛица
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Дата", НаДату);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = "";
	Если Выборка.Следующий() Тогда
		Результат = СокрЛП(Выборка.ДолжностьПредставление);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает прикладное значение ставки НДС по его строковому представлению
//
// Параметры:
//  ПредставлениеСтавки - Строка - Строковое представление ставки НДС
// 
// Возвращаемое значение:
//  ПеречислениеСсылка - Прикладное значение ставки НДС
//
Функция ЗначениеСтавкиНДС(ПредставлениеСтавки) Экспорт
	
	СтавкиНДСДиадок = Новый Соответствие;
	СтавкиНДСДиадок.Вставить("0", Перечисления.СтавкиНДС.НДС0);
	СтавкиНДСДиадок.Вставить("10", Перечисления.СтавкиНДС.НДС10);
	СтавкиНДСДиадок.Вставить("18", Перечисления.СтавкиНДС.НДС18);
	СтавкиНДСДиадок.Вставить("20", Перечисления.СтавкиНДС.НДС20);
	СтавкиНДСДиадок.Вставить("10/110", Перечисления.СтавкиНДС.НДС10_110);
	СтавкиНДСДиадок.Вставить("18/118", Перечисления.СтавкиНДС.НДС18_118);
	СтавкиНДСДиадок.Вставить("20/120", Перечисления.СтавкиНДС.НДС20_120);
	СтавкиНДСДиадок.Вставить(ПредставлениеСтавкиБезНДС(), Перечисления.СтавкиНДС.БезНДС);
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС5") Тогда
		СтавкиНДСДиадок.Вставить("5", Перечисления.СтавкиНДС.НДС5);
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС7") Тогда
		СтавкиНДСДиадок.Вставить("7", Перечисления.СтавкиНДС.НДС7);
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС22") Тогда
		СтавкиНДСДиадок.Вставить("22", Перечисления.СтавкиНДС.НДС22);
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС5_105") Тогда
		СтавкиНДСДиадок.Вставить("5/105", Перечисления.СтавкиНДС.НДС5_105);
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС7_107") Тогда
		СтавкиНДСДиадок.Вставить("7/107", Перечисления.СтавкиНДС.НДС7_107);
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС22_122") Тогда
		СтавкиНДСДиадок.Вставить("22/122", Перечисления.СтавкиНДС.НДС22_122);
	КонецЕсли;
	
	Результат = СтавкиНДСДиадок.Получить(ПредставлениеСтавки);
	
	Возврат Результат;
	
КонецФункции

// Возвращает строковое представление ставки НДС по прикладному значению
//
// Параметры:
//  ЗначениеСтавки - ПеречислениеСсылка - Прикладное значение ставки НДС
// 
// Возвращаемое значение:
//  Строка - Строковое представление ставки НДС для электронного документа
//
Функция ПредставлениеСтавкиНДС(ЗначениеСтавки) Экспорт
	
	Результат = "";
	
	Если ЗначениеЗаполнено(ЗначениеСтавки) Тогда
		
		Если НЕ ЗначениеЗаполнено(_СоответствиеСтавокНДС) Тогда
			_СоответствиеСтавокНДС = _ПеречислениеСтавокНДС();
		КонецЕсли;
		
		Результат = _СоответствиеСтавокНДС.Получить(ЗначениеСтавки);
		
		Если Не ЗначениеЗаполнено(Результат) Тогда
			Результат = "##";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция _ПеречислениеСтавокНДС()
	
	Результат = Новый Соответствие;
	Результат.Вставить(Перечисления.СтавкиНДС.НДС0, "0");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС10, "10");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС18, "18");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС20, "20");
	Результат.Вставить(Перечисления.СтавкиНДС.БезНДС, "без НДС");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС10_110, "10/110");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС18_118, "18/118");
	Результат.Вставить(Перечисления.СтавкиНДС.НДС20_120, "20/120");
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС5") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС5, "5");
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС7") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС7, "7");
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС22") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС22, "22");
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС5_105") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС5_105, "5/105");
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС7_107") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС7_107, "7/107");
	КонецЕсли;
	
	Если СуществуетЗначениеПеречисленияСтавкиНДС("НДС22_122") Тогда
		Результат.Вставить(Перечисления.СтавкиНДС.НДС22_122, "22/122");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СуществуетЗначениеПеречисленияСтавкиНДС(ИмяЗначенияСтавкаНДС)
	
	ЗначенияПеречисления = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления;
	Результат = (ЗначенияПеречисления.Найти(ИмяЗначенияСтавкаНДС) <> Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды документов из текущей конфигурации для поиска в модуле
// 
// Возвращаемое значение:
//  Массив - Предопределенные виды документов конфигурации для поиска в модуле
//
Функция ВидыПредопределенныхДокументовДляПоискаВМодуле() Экспорт
	
	ДокументыКонфигурации = Метаданные.Документы;
	
	Результат = Новый Массив;
	Результат.Добавить(ДокументыКонфигурации.КорректировкаРеализации);
	Результат.Добавить(ДокументыКонфигурации.ОтчетКомитентуОПродажах);
	Результат.Добавить(ДокументыКонфигурации.ВозвратТоваровПоставщику);
	Результат.Добавить(ДокументыКонфигурации.ОтчетКомиссионераОПродажах);
	Результат.Добавить(ДокументыКонфигурации.РеализацияТоваровУслуг);
	Результат.Добавить(ДокументыКонфигурации.СчетФактураВыданный);
	Результат.Добавить(ДокументыКонфигурации.СчетНаОплатуПокупателю);
	Результат.Добавить(ДокументыКонфигурации.АктСверкиВзаиморасчетов);

	Возврат Результат;
	
КонецФункции

