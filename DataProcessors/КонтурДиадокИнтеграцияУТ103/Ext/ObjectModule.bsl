Функция УПД970_НеобходимоВыполнитьПересчетСуммВВалютеРегУчета(ДанныеШапки, СчетФактура)
	
	Перем Результат;
	
	ВалютаРеглУчета = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	
	Если ЭтоСчетФактураНаАванс(СчетФактура) Тогда
		
		Результат = Истина;
		
	ИначеЕсли ДанныеШапки.РасчетыВУсловныхЕдиницах
		И ДанныеШапки.ВалютаДокумента <> ВалютаРеглУчета Тогда
		
		Результат = УчетнаяПолитикаОрганизацииНастроена(ДанныеШапки.Организация, ДанныеШапки.Дата);
		
	Иначе
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УПД970_ПерезаполнитьСуммыДокументаВВалютеРегУчета(ДанныеШапки, ТабличныеДанные)
	
	СуммаДокументаВВалютеРегУчета = УПД970_СуммаДокументаВВалютеРегУчетаСУчетомКурсовыхРазниц(
		ДанныеШапки,
		ТабличныеДанные);
	
	Коэффициент = ДанныеШапки.КурсВзаиморасчетов / ДанныеШапки.КратностьВзаиморасчетов;
	РазрядностьСуммы = 2;

	МассивРаспределения = Новый Массив;
	
	Для Каждого СтрокаТаблицы Из ТабличныеДанные Цикл
		
		СтрокаТаблицы.СуммаБезНДС = Окр(СтрокаТаблицы.СуммаБезНДС * Коэффициент, РазрядностьСуммы);
		СтрокаТаблицы.СуммаНДС = Окр(СтрокаТаблицы.СуммаНДС * Коэффициент, РазрядностьСуммы);
		
		СтрокаТаблицы.СуммаВсего = СтрокаТаблицы.СуммаБезНДС + СтрокаТаблицы.СуммаНДС;
		
		МассивРаспределения.Добавить(СтрокаТаблицы.СуммаВсего);
		
	КонецЦикла;
	
	МодульУчетНДС = ОбщийМодульПоИмениЛок("УчетНДС");
	
	МодульУчетНДС.РаспределитьСуммуПоСтолбцу(
		МассивРаспределения,
		СуммаДокументаВВалютеРегУчета,
		ТабличныеДанные,
		"СуммаВсего");
	
	РасчетСуммыНДСПоСтавке = МодульУчетНДС.РасчетНДСвРубляхПоСтавкеДокумента(ДанныеШапки.Дата);
	
	Для Каждого СтрокаТаблицы Из ТабличныеДанные Цикл
		
		Если РасчетСуммыНДСПоСтавке Тогда
			
			СтавкаНДСЧислом = МодульУчетНДС.ПолучитьСтавкуНДС(СтрокаТаблицы.СтавкаНДС);
			
			СуммаНДС = Окр(СтрокаТаблицы.СуммаВсего * СтавкаНДСЧислом / (100 + СтавкаНДСЧислом), РазрядностьСуммы);
			
			СтрокаТаблицы.СуммаНДС = СуммаНДС;
			СтрокаТаблицы.СуммаБезНДС = СтрокаТаблицы.СуммаВсего - СтрокаТаблицы.СуммаНДС;
			
		Иначе
			
			МассивРаспределения.Очистить();
			МассивРаспределения.Добавить(СтрокаТаблицы.СуммаБезНДС);
			МассивРаспределения.Добавить(СтрокаТаблицы.СуммаНДС);
			
			РезультатРаспределения = ОбщегоНазначения.РаспределитьПропорционально(
				СтрокаТаблицы.СуммаВсего,
				МассивРаспределения);
			
			Если РезультатРаспределения <> Неопределено Тогда
				СтрокаТаблицы.СуммаБезНДС = РезультатРаспределения[0];
				СтрокаТаблицы.СуммаНДС = РезультатРаспределения[1];
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаТаблицы.СуммаВсего = СтрокаТаблицы.СуммаБезНДС + СтрокаТаблицы.СуммаНДС;
		
	КонецЦикла;

КонецПроцедуры

Функция УПД970_СуммаДокументаВВалютеРегУчетаСУчетомКурсовыхРазниц(ДанныеШапки, ТабличныеДанные)
	
	Результат = 0;
	
	Если Не УПД970_ЕстьТабличнаяЧастьДокументыРасчетовСКонтрагентом(ДанныеШапки.Ссылка) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяДокумента = ДанныеШапки.Ссылка.Метаданные().Имя;
	
	ШаблонТекстаЗапроса = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ДокументыРасчетов.СуммаВзаиморасчетов), 0) КАК СуммаВзаиморасчетов,
	|	ЕСТЬNULL(СУММА(ДокументыРасчетов.СуммаРегл), 0) КАК СуммаРегл
	|ИЗ
	|	Документ.%1.ДокументыРасчетовСКонтрагентом КАК ДокументыРасчетов
	|ГДЕ
	|	ДокументыРасчетов.Ссылка = &Ссылка";
	
	ТекстЗапроса = СтрШаблонЛок(ШаблонТекстаЗапроса, ИмяДокумента);
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДанныеШапки.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СуммаВзаиморасчетовДокумента = 0;
	СуммаРегл = 0;
	
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Если Выборка.Следующий() Тогда
		СуммаВзаиморасчетовДокумента = Выборка.СуммаВзаиморасчетов;
		СуммаРегл  = Выборка.СуммаРегл;
	КонецЕсли;
	
	ВалютаРегУчета = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	СуммаДокумента = УПД970_СуммаДокументаСНДСБезУчетаВозвратнойТары(ТабличныеДанные);
	
	Если ДанныеШапки.ВалютаДокумента = ВалютаРегУчета Тогда
		КурсДокумента = 1;
		КратностьДокумента = 1;
	Иначе
		КурсДокумента = ДанныеШапки.КурсВзаиморасчетов;
		КратностьДокумента = ДанныеШапки.КратностьВзаиморасчетов;
	КонецЕсли;
	
	ИнтерфейсКонфигурации = ОбщийМодульПоИмениЛок("МодульВалютногоУчета");
	СуммаВзаиморасчетовВУЕ = ИнтерфейсКонфигурации.ПересчитатьИзВалютыВВалюту(
		СуммаДокумента,
		ДанныеШапки.ВалютаДокумента,
		ДанныеШапки.ВалютаВзаиморасчетов,
		КурсДокумента,
		ДанныеШапки.КурсВзаиморасчетов,
		КратностьДокумента,
		ДанныеШапки.КратностьВзаиморасчетов);
	
	НеоплаченнаяСуммаВзаиморасчетов = СуммаВзаиморасчетовВУЕ - СуммаВзаиморасчетовДокумента;
	
	НеоплаченнаяСуммаРегл = ИнтерфейсКонфигурации.ПересчитатьИзВалютыВВалюту(
		НеоплаченнаяСуммаВзаиморасчетов,
		ДанныеШапки.ВалютаВзаиморасчетов,
		ВалютаРегУчета,
		ДанныеШапки.КурсВзаиморасчетов,
		1,
		ДанныеШапки.КратностьВзаиморасчетов,
		1);
	
	Результат = СуммаРегл + НеоплаченнаяСуммаРегл;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ЕстьТабличнаяЧастьДокументыРасчетовСКонтрагентом(Документ)
	
	ТипДокумента = ТипЗнч(Документ);
	
	Результат = (ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг")
		Или ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщику")
		Или ТипДокумента = Тип("ДокументСсылка.ОтчетКомиссионераОПродажах")
		Или ТипДокумента = Тип("ДокументСсылка.ОтчетКомитентуОПродажах")
		Или ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровПоставщикуИзНТТ"));
		
	Возврат Результат;
	
КонецФункции

Функция УПД970_СуммаДокументаСНДСБезУчетаВозвратнойТары(ТабличныеДанные)
	
	Результат = 0;
	
	Для Каждого СтрокаТаблицы Из ТабличныеДанные Цикл
		
		Если СтрокаТаблицы.ТипНоменклатуры <> УПД970_ТипНоменклатурыВозвратнаяТара() Тогда
			Результат = Результат + СтрокаТаблицы.СуммаВсего;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ОбстоятельстваФормированияДокумента(ДанныеДокумента, ФункцияДокумента)
	
	Если ФункцияДокумента = ФункцияДокументаУПД_СЧФ() Тогда
		Результат = УПД970_ОбстоятельстваФормированияСчетФактуры(ДанныеДокумента);
	Иначе
		Результат = УПД970_ОбстоятельстваФормированияУПД(ДанныеДокумента);
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ОбстоятельстваФормированияУПД(ДанныеДокумента)
	
	Результат = Неопределено;
	
	Если ДанныеДокумента.ЭтоДоговорСКомиссионером Тогда
		Результат = "00005";
	КонецЕсли;
	
	Если ДанныеДокумента.ЭтоДоговорСКомитентом Тогда
		Результат = "00007";
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Функция УПД970_ОбстоятельстваФормированияСчетФактуры(ДанныеПоДокументу)
	
	Перем Результат;
	
	ЭтоКомиссионнаяТорговля = (ДанныеПоДокументу.ЭтоДоговорСКомитентом Или ДанныеПоДокументу.ЭтоДоговорСКомиссионером);
	
	ДанныеШапки = ДанныеПоДокументу.ДанныеШапки;

	Если ДанныеШапки.КодВидаОперации = "01" И ЭтоКомиссионнаяТорговля Тогда
		Результат = "1";	
	ИначеЕсли ДанныеШапки.КодВидаОперации = "02" Тогда
		Результат = "2";
	ИначеЕсли ДанныеШапки.КодВидаОперации = "27" Тогда
		Результат = "3";
	ИначеЕсли ДанныеШапки.КодВидаОперации = "06" Тогда
		Результат = "4";
	ИначеЕсли ДанныеШапки.КодВидаОперации = "34"
		Или (ДанныеШапки.КодВидаОперации = "33" И ДанныеПоДокументу.ЭтоСчетФактураНаАванс) Тогда
		Результат = "5";
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_РеквизитыОснованияПередачиТоваровПоОснованиюСчетФактураВыданный(ДокументыОснования)
	
	Результат = Новый Массив;

	ОснованияОтгрузки = Новый Массив;
	Для Каждого СсылкаНаДокумент Из ДокументыОснования Цикл
		
		ОснованиеОтгрузки = УПД970_ОснованиеОтгрузкиТоваровПоДокументу(СсылкаНаДокумент);
		Если ЗначениеЗаполнено(ОснованиеОтгрузки)
			И ОснованияОтгрузки.Найти(ОснованиеОтгрузки) = Неопределено Тогда
			ОснованияОтгрузки.Добавить(ОснованиеОтгрузки);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ОснованиеОтгрузки Из ОснованияОтгрузки Цикл
		
		РеквизитыОснования = УПД970_РеквизитыОснованияОтгрузкиТоваров(ОснованиеОтгрузки);
		Результат.Добавить(РеквизитыОснования);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ОснованиеОтгрузкиТоваровПоДокументу(ДокументСсылка)
	
	РеквизитыДокумента = ЗначенияРеквизитовОбъектаЛок(ДокументСсылка, "ДоговорКонтрагента, Сделка");
	
	Договор = РеквизитыДокумента.ДоговорКонтрагента;
	Сделка = РеквизитыДокумента.Сделка;
	
	Если ВедениеВзаиморасчетовПоЗаказам(Договор)
		И ЗначениеЗаполнено(Сделка)
		И ЭтоЗаказПокупателя(Сделка) Тогда
		
		Результат = Сделка;
		
	ИначеЕсли ЗначениеЗаполнено(Договор) Тогда
		
		Результат = Договор;
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_РеквизитыОснованияОтгрузкиТоваров(ОснованиеОтгрузки)
	
	Если ЗначениеЗаполнено(ОснованиеОтгрузки) Тогда
		
		Если ЭтоЗаказПокупателя(ОснованиеОтгрузки) Тогда
			Результат = УПД970_РеквизитыОснованияОтгрузкиТоваровПоЗаказу(ОснованиеОтгрузки);
		Иначе
			Результат = УПД970_РеквизитыОснованияОтгрузкиТоваровПоДоговору(ОснованиеОтгрузки);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_РеквизитыОснованияОтгрузкиТоваровПоЗаказу(ДокументСсылка)
	
	ИмяДокумента = "Заказ покупателя";
	ДатаДокумента = ЗначениеРеквизитаОбъектаЛок(ДокументСсылка, "Дата");
	НомерДокумента = ПредставлениеНомера(ДокументСсылка);
	
	Результат = УПД970_НовыеРеквизитыОснованияОтгрузки(
		ИмяДокумента,
		НомерДокумента,
		ДатаДокумента);
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_РеквизитыОснованияОтгрузкиТоваровПоДоговору(Договор)

	РеквизитыДоговора = ЗначенияРеквизитовОбъектаЛок(
		Договор,
		"Номер, Дата");
			
	Результат = УПД970_НовыеРеквизитыОснованияОтгрузки(
		"Договор",
		РеквизитыДоговора.Номер,
		РеквизитыДоговора.Дата);
		
	Возврат Результат;

КонецФункции

Функция УПД970_РеквизитыОснованияЗаполнены(РеквизитыОснования)
	
	ОбязательныеРеквизитыЗаполнены = (РеквизитыОснования <> Неопределено
		И ЗначениеЗаполнено(РеквизитыОснования.Наименование)
		И ЗначениеЗаполнено(РеквизитыОснования.Номер)
		И ЗначениеЗаполнено(РеквизитыОснования.Дата));
	
	Возврат ОбязательныеРеквизитыЗаполнены;
	
КонецФункции

Функция УПД970_НовыеРеквизитыОснованияОтгрузки(Наименование = "", Номер = "", Дата = '00010101')

	Результат = Новый Структура;
	Результат.Вставить("Наименование", Наименование);
	Результат.Вставить("Номер", Номер);
	Результат.Вставить("Дата", Дата);
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_СведенияОбУчастникахЭДО(ДанныеШапки)
	
	// Продавец
	СведенияОбОрганизации = УПД970_ДанныеУчастникаЭДОсЮрАдресом(
		ДанныеШапки.Организация,
		ДанныеШапки.Дата,
		ДанныеШапки.БанковскийСчетОрганизации);
	
	// Покупатель
	Если ДанныеШапки.ОбособленноеПодразделение Тогда
		
		СведенияОКонтрагенте = УПД970_ДанныеУчастникаЭДОсЮрАдресом(
			ДанныеШапки.ГоловнойКонтрагент,
			ДанныеШапки.Дата);
			
		СведенияОКонтрагенте.КПП = ЗначениеРеквизитаОбъектаЛок(ДанныеШапки.Контрагент, "КПП");
		
	Иначе
		
		СведенияОКонтрагенте = УПД970_ДанныеУчастникаЭДОсЮрАдресом(
			ДанныеШапки.Контрагент,
			ДанныеШапки.Дата);
			
	КонецЕсли;
	
	// Грузоотправитель
	Если ЗначениеЗаполнено(ДанныеШапки.Грузоотправитель) Тогда
		
		СведенияОГрузоотправителе = УПД970_ДанныеУчастникаЭДОсФактАдресом(
			ДанныеШапки.Грузоотправитель,
			ДанныеШапки.Дата);
		
	КонецЕсли;
	
	// Грузополучатель
	СведенияОГрузополучателе = Неопределено;
	
	Если ЗначениеЗаполнено(ДанныеШапки.Грузополучатель) Тогда
		
		СведенияОГрузополучателе = УПД970_ДанныеГрузополучателя(
			ДанныеШапки.Грузополучатель,
			ДанныеШапки.Дата,
			ДанныеШапки.АдресДоставки);
		
	КонецЕсли;

	Результат = УПД970_Контракт_УчастникиЭДО();
	Результат.Организация = СведенияОбОрганизации;
	Результат.Контрагент = СведенияОКонтрагенте;
	Результат.Грузоотправитель = СведенияОГрузоотправителе;
	Результат.Грузополучатель = СведенияОГрузополучателе;

	Возврат Результат;
	
КонецФункции

Функция УПД970_ДанныеУчастникаЭДОсЮрАдресом(Ссылка, ДатаСведений, БанковскийСчет = Неопределено)
	
	Результат = УПД970_ДанныеУчастникаЭДО(Ссылка, ДатаСведений, БанковскийСчет);
	
	СведенияОбАдресе = УПД970_СведенияОбЮридическомАдресе(Ссылка);
	
	Результат.Адрес = СведенияОбАдресе;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ДанныеУчастникаЭДОсФактАдресом(Ссылка, ДатаСведений, БанковскийСчет = Неопределено)
	
	Результат = УПД970_ДанныеУчастникаЭДО(Ссылка, ДатаСведений, БанковскийСчет);
	
	СведенияОбАдресе = УПД970_СведенияОФактическомАдресе(Ссылка);
	
	Результат.Адрес = СведенияОбАдресе;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ДанныеУчастникаЭДО(Ссылка, ДатаСведений, БанковскийСчет = Неопределено)
	
	Результат = УПД970_Контракт_ДанныеУчастникаЭДО();
	
	МодульУправлениеКонтактнойИнформацией = ОбщийМодульПоИмениЛок("УправлениеКонтактнойИнформацией");
	
	СведенияОЮрФизЛице = МодульУправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Ссылка, ДатаСведений, , БанковскийСчет);
	
	Результат.Ссылка = Ссылка;
	
	Результат.Наименование = СведенияОЮрФизЛице.ПолноеНаименование;
	Результат.ИНН = СведенияОЮрФизЛице.ИНН;
	Результат.КПП = СведенияОЮрФизЛице.КПП;
	Результат.КодПоОКПО = СведенияОЮрФизЛице.КодПоОКПО;
	
	Если ЗначениеЗаполнено(СведенияОЮрФизЛице.Банк) Тогда
		Результат.НаименованиеБанка = СведенияОЮрФизЛице.Банк.Наименование;
	Иначе
		Результат.НаименованиеБанка = "";
	КонецЕсли;
	
	Результат.НомерСчета = СведенияОЮрФизЛице.НомерСчета;
	Результат.КоррСчет = СведенияОЮрФизЛице.КоррСчет;
	Результат.БИК = СведенияОЮрФизЛице.БИК;
	
	Результат.Телефоны = СведенияОЮрФизЛице.Телефоны;
	
	Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Организации") Тогда
		УПД970_ДополнитьСведенияОбУчастникеЭДОДаннымиОрганизации(Результат, Ссылка);
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		УПД970_ДополнитьСведенияОбУчастникеЭДОДаннымиКонтрагента(Результат, Ссылка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УПД970_ДополнитьСведенияОбУчастникеЭДОДаннымиОрганизации(ДанныеУчастникаЭДО, Ссылка)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Т.Наименование КАК Наименование,
	|	Т.ЮрФизЛицо КАК ЮрФизЛицо,
	|	&СтранаРегистрацииСсылка КАК Страна,
	|	&СтранаРегистрацииКод КАК СтранаКод,
	|	&СтранаРегистрацииНаименование КАК СтранаНаименование,
	|	Т.ОГРН КАК ОГРН,
	|	Т.НаименованиеПолное КАК НаименованиеИнострОрганизации,
	|	&ИностраннаяОрганизация КАК ИностраннаяОрганизация,
	|	&КодВСтранеРегистрации КАК КодВСтранеРегистрации,
	|	Т.СвидетельствоСерияНомер КАК СвидетельствоСерияНомер,
	|	Т.СвидетельствоДатаВыдачи КАК СвидетельствоДатаВыдачи
	|ИЗ
	|	Справочник.Организации КАК Т
	|ГДЕ
	|	Т.Ссылка = &Ссылка";
	
	СтранаРегистрацииСсылка = "Т.СтранаРегистрации";
	СтранаРегистрацииКод = "ЕСТЬNULL(Т.СтранаРегистрации.Код, """")";
	СтранаРегистрацииНаименование = "ЕСТЬNULL(Т.СтранаРегистрации.Наименование, """")";
	ИностраннаяОрганизация = "Т.ИностраннаяОрганизация";
	КодВСтранеРегистрации = "Т.КодВСтранеРегистрации";
	НаименованиеИнострОрганизации = "Т.НаименованиеИнострОрганизации";
	
	ОбъектМД = Метаданные.Справочники.Организации;
	Если Не ЕстьРеквизитОбъектаЛок("СтранаРегистрации", ОбъектМД) Тогда
		СтранаРегистрацииСсылка = "ЗНАЧЕНИЕ(Справочник.КлассификаторСтранМира.ПустаяСсылка)";
		СтранаРегистрацииКод = """""";
		СтранаРегистрацииНаименование = """""";
		ИностраннаяОрганизация = "ЛОЖЬ";
		КодВСтранеРегистрации = """""";
		НаименованиеИнострОрганизации = """""";
	КонецЕсли;
	
	Замены = Новый СписокЗначений;
	Замены.Добавить("&СтранаРегистрацииСсылка", СтранаРегистрацииСсылка);
	Замены.Добавить("&СтранаРегистрацииКод", СтранаРегистрацииКод);
	Замены.Добавить("&СтранаРегистрацииНаименование", СтранаРегистрацииНаименование);
	Замены.Добавить("&ИностраннаяОрганизация", ИностраннаяОрганизация);
	Замены.Добавить("&КодВСтранеРегистрации", КодВСтранеРегистрации);
	Замены.Добавить("&НаименованиеИнострОрганизации", НаименованиеИнострОрганизации);
	
	Для Каждого Элемент Из Замены Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Элемент.Значение, Элемент.Представление);
	КонецЦикла;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	СведенияОбОрганизации = Запрос.Выполнить().Выбрать();
	Если Не СведенияОбОрганизации.Следующий() Тогда
		Ошибка = СтрШаблонЛок("Не удалось прочитать данные организации (Ссылка = %1)", Ссылка);
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ЭтоИндивидуальныйПредприниматель = (СведенияОбОрганизации.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо);
	ЭтоИностраннаяОрганизация = СведенияОбОрганизации.ИностраннаяОрганизация;
	
	ДанныеУчастникаЭДО.ЭтоЮрЛицо = (СведенияОбОрганизации.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо);
	
	СтранаКод = СведенияОбОрганизации.СтранаКод;
	СтранаНаименование = СведенияОбОрганизации.СтранаНаименование;
	Если Не ЗначениеЗаполнено(СведенияОбОрганизации.Страна)
		И Не ЭтоИностраннаяОрганизация Тогда
		
		СтранаКод = ОсновнаяСтрана().Код;
		СтранаНаименование = ОсновнаяСтрана().Наименование;
		
	КонецЕсли;
	
	Если ЭтоИндивидуальныйПредприниматель Тогда
		ДанныеУчастникаЭДО.ОГРНИП = СведенияОбОрганизации.ОГРН;
	КонецЕсли;
	
	Если ЭтоИностраннаяОрганизация Тогда
		ДанныеУчастникаЭДО.Наименование = СведенияОбОрганизации.НаименованиеИнострОрганизации;
		ДанныеУчастникаЭДО.НалоговыйНомерВСтранеРегистрации = СведенияОбОрганизации.КодВСтранеРегистрации;
	КонецЕсли;
	
	ДанныеУчастникаЭДО.СтранаКод = СтранаКод;
	ДанныеУчастникаЭДО.СтранаНаименование = СтранаНаименование;
	
	ДанныеУчастникаЭДО.Нерезидент = ЭтоИностраннаяОрганизация;
	
	Свидетельство = "";
	Если ЗначениеЗаполнено(СведенияОбОрганизации.СвидетельствоСерияНомер) Тогда
		Свидетельство = "свидетельство " + СведенияОбОрганизации.СвидетельствоСерияНомер;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОбОрганизации.СвидетельствоДатаВыдачи) Тогда
		Свидетельство = Свидетельство + " от " + Формат(СведенияОбОрганизации.СвидетельствоДатаВыдачи, "ДФ=dd.MM.yyyy");
	КонецЕсли;
	
	ДанныеУчастникаЭДО.Свидетельство = Свидетельство;
	
	ДанныеУчастникаЭДО.ЭлектроннаяПочта = УправлениеЭлектроннойПочтой.ОпределитьАдресПолучателя(Ссылка);
	
КонецПроцедуры

