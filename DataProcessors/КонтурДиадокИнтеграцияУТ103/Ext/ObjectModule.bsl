Функция УПД970_ИсходныеДанныеДокументаРеализацияТоваровУслуг(ДокСсылка, СчетФактура = Неопределено)
	
	ТекстыЗапросов = Новый Массив;
	
	ТекстыЗапросов.Добавить(УПД970_ТекстЗапросаДанныхШапкиДокументаРеализацияТоваровУслуг());
	ТекстыЗапросов.Добавить(УПД970_ТекстЗапросаТабличныхДанныхДокументаРеализацияТоваровУслуг());
	ТекстыЗапросов.Добавить(УПД970_ТекстЗапросаСведенийОПрослеживаемостиДокументаРеализацияТоваровУслуг());
	
	СтрОбъединениеЗапросов = ТекстЗапроса_РазделительЗапросов();
	
	ТекстЗапроса = СоединитьСтроку(ТекстыЗапросов, СтрОбъединениеЗапросов);
	
