Функция ФункцияДокументаДляXML(TypeNamedId, FunctionName)

	Если TypeNamedId = "Invoice" ИЛИ TypeNamedId = "InvoiceRevision" Тогда
		Результат = "СЧФ";
	ИначеЕсли TypeNamedId = "XmlTorg12" ИЛИ TypeNamedId = "XmlAcceptanceCertificate" Тогда
		Результат = "ДОП";
	ИначеЕсли TypeNamedId = "InvoiceCorrection" ИЛИ TypeNamedId = "InvoiceCorrectionRevision" Тогда
		Результат = "КСЧФ";
	Иначе
		Результат = ОсновнойМодуль.ФункцияДокументаДляXML(TypeNamedId, FunctionName);
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции

Функция СформироватьВнешнююПечатнуюФорму(Документ, ВнешняяПечатнаяФорма, ИдентификаторКомандыПечатнойФормы = Неопределено, ДопПараметры = Неопределено)
	
	Попытка
		
		ТабличныйДокумент = НапечататьВнешнююФормуЛок(Документ, ВнешняяПечатнаяФорма);
		
	Исключение
		
		ОшибкаИнфо = ИнформацияОбОшибке();
		// BSLLS:NestedFunctionInParameters-off
		КомментарийЖР = СтрШаблонЛок(
			"Не удалось сформировать внешнюю печатную форму (%1) по причине:
			|%2",
			ВнешняяПечатнаяФорма,
			ПодробноеПредставлениеОшибки(ОшибкаИнфо)
		);
		// BSLLS:NestedFunctionInParameters-on
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ПодготовитьЭлектронныйДокумент",
			УровеньЖурналаРегистрации.Ошибка,
			Документ.Метаданные(),
			Документ,
			КомментарийЖР
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	// BSLLS:NestedFunctionInParameters-off
	ИмяФайла = СтрШаблонЛок(
		"%1 № %2 от %3.pdf",
		ВнешняяПечатнаяФорма.Наименование,
		Документ.Номер,
		Формат(Документ.Дата, "ДФ=dd.MM.yyyy")
	);
	// BSLLS:NestedFunctionInParameters-on
	
	ИмяФайла = ЗаменитьНедопустимыеСимволы(ИмяФайла);
	
	// BSLLS:MissingTemporaryFileDeletion-off
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("pdf");
	// BSLLS:MissingTemporaryFileDeletion-on
	ТабличныйДокумент.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
	
	Возврат Новый Структура("ИмяВременногоФайла, ИмяФайла", ИмяВременногоФайла, ИмяФайла);
	
КонецФункции

// Аналог функции УниверсальныеМеханизмы.НапечататьВнешнююФорму
//
// Параметры:
//  Ссылка - ЛюбаяСсылка - ссылка на объект, по которому нужно сформировать печатную форму
//  ВнешняяПФ - СправочникСсылка.ВнешниеОбработки - внешняя печатная форма
// 
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма
//
Функция НапечататьВнешнююФормуЛок(Ссылка, ВнешняяПФ)
	
	ИндексПринадлежности = 0;
	ДвоичныеДанные = ВнешняяПФ.Принадлежность[ИндексПринадлежности].ХранилищеВнешнейОбработки.Получить();
	Если ДвоичныеДанные = Неопределено Тогда
		ДвоичныеДанные = ВнешняяПФ.ХранилищеВнешнейОбработки.Получить();
	КонецЕсли;
	ДополнительныеПараметры = ВнешняяПФ.Принадлежность[ИндексПринадлежности].ДополнительныеПараметрыОбработки.Получить();
	
	Если ДвоичныеДанные = Неопределено Тогда
		Ошибка = СтрШаблонЛок("Не удалось получить файл внешней печатной формы (%1)", ВнешняяПФ);
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ТабДокумент = Неопределено;
	
	ИмяФайла = ПолучитьИмяВременногоФайла("epf");
	ДвоичныеДанные.Записать(ИмяФайла);
	// BSLLS:UsingExternalCodeTools-off
	Обработка = ВнешниеОбработки.Создать(ИмяФайла);
	// BSLLS:UsingExternalCodeTools-on
	Обработка.СсылкаНаОбъект = Ссылка;
	
	// Передать внешней обработке дополнительные параметры
	Если ДополнительныеПараметры <> Неопределено Тогда
		// Если у внешней обработки есть реквизит для дополнительных параметров, присвоить ему значение
		Если НЕ Обработка.Метаданные().Реквизиты.Найти("ДополнительныеПараметры") = Неопределено Тогда
			Обработка.ДополнительныеПараметры = ДополнительныеПараметры;
		КонецЕсли;
	КонецЕсли;
	
	ТабДокумент = Обработка.Печать();
	
	// BSLLS:UsingSynchronousCalls-off
	УдалитьФайлы(ИмяФайла);
	// BSLLS:UsingSynchronousCalls-on
	
	Если ТипЗнч(ТабДокумент) = Тип("ТабличныйДокумент") И (ПустаяСтрока(ТабДокумент.ИмяПараметровПечати)) Тогда
		Попытка
			
			ИдентификаторОбработки = Строка(ВнешняяПФ.УникальныйИдентификатор());
			ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_" + СтрЗаменить(ИдентификаторОбработки, "-", "_");
			ТабДокумент.ИмяПараметровПечати = ТабДокумент.ИмяПараметровПечати + "_" + Ссылка.Метаданные().Имя;
			
		Исключение
			
			ОшибкаИнфо = ИнформацияОбОшибке();
			// BSLLS:NestedFunctionInParameters-off
			КомментарийЖР = СтрШаблонЛок(
				"Не удалось установить имя параметров печати (%1) по причине:
				|%2",
				ВнешняяПФ,
				ПодробноеПредставлениеОшибки(ОшибкаИнфо)
			);
			// BSLLS:NestedFunctionInParameters-on
			
			// BSLLS:UsageWriteLogEvent-off
			ЗаписьЖурналаРегистрации(
				"Диадок.ПодготовитьЭлектронныйДокумент",
				УровеньЖурналаРегистрации.Предупреждение,
				Ссылка.Метаданные(),
				Ссылка,
				КомментарийЖР
			);
			// BSLLS:UsageWriteLogEvent-on
			
		КонецПопытки;
	КонецЕсли;
	
	Возврат ТабДокумент;
	
КонецФункции

Функция ЗаменитьНедопустимыеСимволы(СтрокаОбработки)
	
	НедопустимыеЗнаки = "\/:*?""<>|";
	
	Пока СтрДлина(НедопустимыеЗнаки) > 0 Цикл
		
		ТекСимвол = Лев(НедопустимыеЗнаки, 1);
		Если Найти(СтрокаОбработки, ТекСимвол) <> 0 Тогда
			СтрокаОбработки = СтрЗаменить(СтрокаОбработки, ТекСимвол, "_");
		КонецЕсли;
		НедопустимыеЗнаки = Сред(НедопустимыеЗнаки, 2);
		
	КонецЦикла;
	
	Возврат СтрокаОбработки;
	
КонецФункции

