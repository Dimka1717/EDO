Процедура СчетаНаОплату_ШапкаДокументПродажи(МодельШапка, ОснованиеЭлектронногоСчета)
	
	Если ТипЗнч(ОснованиеЭлектронногоСчета) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		СчетаНаОплату_ШапкаРеализацияТоваровУслуг(МодельШапка, ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ТипЗнч(ОснованиеЭлектронногоСчета) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		
		СчетаНаОплату_ШапкаКорректировкаРеализации(МодельШапка, ОснованиеЭлектронногоСчета);
		
	ИначеЕсли ТипЗнч(ОснованиеЭлектронногоСчета) = Тип("ДокументСсылка.ОтчетКомитентуОПродажах") Тогда
		
		СчетаНаОплату_ШапкаОтчетКомитентуОПродажах(МодельШапка, ОснованиеЭлектронногоСчета);
		
	Иначе
		
		ШаблонТекстаОшибки = НСтр("ru='Неожиданный тип документа продажи: %1'");
		
		ТекстОшибки = СтрШаблонЛок(ШаблонТекстаОшибки, ТипЗнч(ОснованиеЭлектронногоСчета));
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

