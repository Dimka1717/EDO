Функция УПД970_ВДокументеЕстьТовары(СтрокиТаблицы)

	Результат = Ложь;
	
	ТипыНоменклатуры = ГенерацияXML.Перечисление_ItemMarks();
	
	Для Каждого СтрокаТаблицы Из СтрокиТаблицы Цикл
		Если СтрокаТаблицы.ItemMark = ТипыНоменклатуры.Имущество Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ВДокументеЕстьУслуги(СтрокиТаблицы)

	Результат = Ложь;
	
	ТипыНоменклатуры = ГенерацияXML.Перечисление_ItemMarks();
	
	МаксИндекс = СтрокиТаблицы.Количество() - 1;
	
	Для ТекИндекс = - МаксИндекс По 0 Цикл
		
		ItemMark = СтрокиТаблицы[ - ТекИндекс].ItemMark;
		
		Если ItemMark = ТипыНоменклатуры.Услуга
			ИЛИ ItemMark = ТипыНоменклатуры.Работа
			ИЛИ ItemMark = ТипыНоменклатуры.ИмущественныеПрава Тогда
			
			Результат = Истина;
			Прервать;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ЦенаБезНДС(СтрокаТаблицы, Разрядность)
	
	Перем Результат;
	
	ДопустимоеОтклонение = 0.03;
	
	Если СтрокаТаблицы.Количество = 0 Тогда
		
		Результат = 0;
		
	Иначе
		
		Результат = Окр(СтрокаТаблицы.СуммаБезНДС / СтрокаТаблицы.Количество, Разрядность);
		ОтклонениеВЦене = (Результат - СтрокаТаблицы.Цена) * СтрокаТаблицы.Количество;
		
		ОтклонениеВЦенеПоМодулю = Макс(ОтклонениеВЦене, -ОтклонениеВЦене);
		
		Если ОтклонениеВЦенеПоМодулю <= ДопустимоеОтклонение Тогда
			Результат = Окр(СтрокаТаблицы.Цена, Разрядность);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УПД970_ПредставлениеНоменклатуры(СтрокаТаблицы)
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.НоменклатураПолноеНаименование) Тогда
		НаименованиеНоменклатуры = СтрокаТаблицы.НоменклатураПолноеНаименование;
	Иначе
		НаименованиеНоменклатуры = СтрокаТаблицы.НоменклатураНаименование;
	КонецЕсли;
	
	ХарактеристикаНоменклатуры = "";
	Если ЗначениеЗаполнено(СтрокаТаблицы.ХарактеристикаНоменклатуры) Тогда
		ХарактеристикаНоменклатуры = ЗначениеРеквизитаОбъектаЛок(СтрокаТаблицы.ХарактеристикаНоменклатуры, "Наименование");
	КонецЕсли;
	
	СерияНоменклатуры = "";
	Если ЗначениеЗаполнено(СтрокаТаблицы.СерияНоменклатуры) Тогда
		СерияНоменклатуры = ЗначениеРеквизитаОбъектаЛок(СтрокаТаблицы.СерияНоменклатуры, "Наименование");
	КонецЕсли;
	
	ДопСведенияОНоменклатуре = Новый Массив;
	ДопСведенияОНоменклатуре.Добавить(СтрокаТаблицы.ХарактеристикаНоменклатуры);
	ДопСведенияОНоменклатуре.Добавить(СтрокаТаблицы.СерияНоменклатуры);
	
	РазделительСведений = "; ";
	ПредставлениеДопСведенийОНоменклатуре = СоединитьСтроку(ДопСведенияОНоменклатуре, РазделительСведений);
	
	Если ЗначениеЗаполнено(ПредставлениеДопСведенийОНоменклатуре) Тогда
		ПредставлениеДопСведенийОНоменклатуре = СтрШаблонЛок(" (%1)", ПредставлениеДопСведенийОНоменклатуре);
	КонецЕсли;
	
	Результат = НаименованиеНоменклатуры + ПредставлениеДопСведенийОНоменклатуре;
	
	Возврат Результат;
	
КонецФункции

