Функция УПД970_ТекстЗапросаДанныхШапкиДокументаВозвратТоваровПоставщику()
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	ДанныеШапки.Дата КАК Дата,
	|	ДанныеШапки.ВалютаДокумента КАК ВалютаДокумента,
	|	ДанныеШапки.Организация КАК Организация,
	|	ДанныеШапки.Контрагент КАК Контрагент,
	|	ДанныеШапки.Контрагент.ГоловнойКонтрагент КАК ГоловнойКонтрагент,
	|	ДанныеШапки.Контрагент.ОбособленноеПодразделение КАК ОбособленноеПодразделение,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА ДанныеШапки.Организация
	|		ИНАЧЕ ДанныеШапки.Грузоотправитель
	|	КОНЕЦ КАК Грузоотправитель,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Грузополучатель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА ДанныеШапки.Контрагент
	|		ИНАЧЕ ДанныеШапки.Грузополучатель
	|	КОНЕЦ КАК Грузополучатель,
	|	НЕОПРЕДЕЛЕНО КАК АдресДоставки,
	|	ДанныеШапки.СуммаВключаетНДС КАК СуммаВключаетНДС,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.БанковскийСчетОрганизации = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
	|			ТОГДА ДанныеШапки.Организация.ОсновнойБанковскийСчет
	|		ИНАЧЕ ДанныеШапки.БанковскийСчетОрганизации
	|	КОНЕЦ КАК БанковскийСчетОрганизации,
	|	ДанныеШапки.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ДанныеШапки.КурсВзаиморасчетов КАК КурсВзаиморасчетов,
	|	ДанныеШапки.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,

	|	ДоговорыКонтрагентов.Дата КАК ДоговорДата,
	|	ДоговорыКонтрагентов.Номер КАК ДоговорНомер,
	|	ДоговорыКонтрагентов.ВидДоговора КАК ВидДоговора,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.РасчетыВУсловныхЕдиницах, ЛОЖЬ) КАК РасчетыВУсловныхЕдиницах,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.ВалютаВзаиморасчетов, """") КАК ВалютаВзаиморасчетов
	|ИЗ
	|	Документ.ВозвратТоваровПоставщику КАК ДанныеШапки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО ДанныеШапки.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	ДанныеШапки.Ссылка = &Ссылка";
	
	Возврат Результат;
	
