// Определяет операцию по умолчанию при создании учетного документа.
//
// Параметры:
//  ТипЭД - Структура - Тип электронного документа (см. Документ.Тип)
// 
// Возвращаемое значение:
//  Строка - Идентификатор операции по умолчанию (см. СписокТиповДокументовДляСоздания).
//  Неопределено - Если не удалось определить тип операциии.
//
Функция ИдентификаторОперацииПоУмолчанию(ТипЭД)
	
	Если ОсновнойМодуль.ЭтоУниверсальныйПередаточныйДокумент(ТипЭД)
		Или ОсновнойМодуль.ЭтоПередаточныйДокумент(ТипЭД) Тогда
		
		Результат = ОперацияПоступлениеТоваровУслуг();
		
	ИначеЕсли ОсновнойМодуль.ЭтоУниверсальныйКорректировочныйДокумент(ТипЭД)
		Или ОсновнойМодуль.ЭтоСоглашениеОбИзмененииСтоимости(ТипЭД) Тогда
		
		Результат = ОперацияКорректировкаПоступления();
		
	ИначеЕсли ОсновнойМодуль.ЭтоСчетФактура(ТипЭД)
		Или ОсновнойМодуль.ЭтоКорректировочныйСчетФактура(ТипЭД) Тогда
		
		Результат = ОперацияСчетФактураПолученный();
		
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПроверитьЗаполнитьДокументОснование(ПараметрыСобытия, Ошибки)
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		Возврат;
	КонецЕсли;
	
	ДокументОснование = Неопределено;
	Если ПараметрыСобытия.ДополнительныеПараметры.Свойство("ДокументОснование", ДокументОснование)
		И ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	Документ = ПараметрыСобытия.Документ;
	ИдентификаторОперации = ПараметрыСобытия.ИдентификаторОперации;
	
	Если ИдентификаторОперации = ОперацияКорректировкаПоступления() Тогда
		
		ДокументОснование = НайтиОснованиеДляСозданияКорректировкиПоступления(Документ, Ошибки);
		
	КонецЕсли;
	
	ПараметрыСобытия.ДополнительныеПараметры.Вставить("ДокументОснование", ДокументОснование);
	
КонецПроцедуры

Процедура ПроверитьЗаполнитьИдентификаторОперации(ПараметрыСобытия, Ошибки)
	
	Если ЗначениеЗаполнено(Ошибки)
		Или ЗначениеЗаполнено(ПараметрыСобытия.ИдентификаторОперации) Тогда
		Возврат;
	КонецЕсли;
	
	Документ = ПараметрыСобытия.Документ;
	ТипЭД = Документ.Тип;
	ПараметрыСобытия.ИдентификаторОперации = ИдентификаторОперацииПоУмолчанию(ТипЭД);
	
	Если Не ЗначениеЗаполнено(ПараметрыСобытия.ИдентификаторОперации) Тогда
		
		Если Не Документ.Тип.Формализованный Тогда
			Ошибки.Добавить("Документ неформализованный.");
		КонецЕсли;
		
		Ошибки.Добавить("Для этого формата или типа документа нельзя создать документ.");
		Ошибки.Добавить("Сопоставьте документ вручную из карточки документа.");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьФункциюДокумента(ПараметрыСобытия, Ошибки)
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		Возврат;
	КонецЕсли;
	
	Документ = ПараметрыСобытия.Документ;
	ТипЭД = Документ.Тип;
	
	Если ОсновнойМодуль.ЭтоАгентскиеФункцииУПДУКД(ТипЭД.ФункцияДокумента) Тогда
		ТекстОшибки = "Не задана операция для создания учетного документа!";
		Ошибки.Добавить(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

Функция ТребуетсяСоздатьСчетФактуру(ДокументОбъект)
	
	МетаданныеОснованийСФ = Новый Массив;
	МетаданныеОснованийСФ.Добавить(Метаданные.Документы.ПоступлениеТоваровУслуг);
	МетаданныеОснованийСФ.Добавить(Метаданные.Документы.ПоступлениеДопРасходов);
	МетаданныеОснованийСФ.Добавить(Метаданные.Документы.КорректировкаПоступления);
	
	ОбъектМетаданных = ДокументОбъект.Метаданные();
	
	Результат = (МетаданныеОснованийСФ.Найти(ОбъектМетаданных) <> Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Ищем в пакете документ счета-фактуры: если есть, то сразу создаем его в 1С.
//
// Параметры:
//  ДокументОбъект - ДокументОбъект - Основание для создания счета-фактуры полученного.
//  Документ - Структура - электронный документ (см. Контракт_Документ).
//  ИспользоватьДатуЭД - Булево - Истина, заполнять дату документа из документа ЭДО
//
Процедура СоздатьСчетФактуру(ДокументОбъект, Документ, ИспользоватьДатуЭД)
	
	Если ДокументОбъект = Неопределено
		ИЛИ НЕ ТребуетсяСоздатьСчетФактуру(ДокументОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ЭлектронныйСФ = ЭлектронныйСчетФактураПакета(Документ);
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйСФ)
		ИЛИ ЗначениеЗаполнено(ЭлектронныйСФ.ДокументУчета) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокументОбъект.Номер) Тогда
		ДокументОбъект.УстановитьНовыйНомер();
	КонецЕсли;
	
	ДокументОбъект.ОбменДанными.Загрузка = Истина;
	ДокументОбъект.Записать();
	
	ДатаДокумента = ТекущаяДатаСеанса();
	Если ИспользоватьДатуЭД Тогда
		ДатаДокумента = ЭлектронныйСФ.Реквизиты.Дата;
	КонецЕсли;
	
	ДокументСФ = Документы.СчетФактураПолученный.СоздатьДокумент();
	ДокументСФ.Заполнить(ДокументОбъект.Ссылка);
	ДокументСФ.ДатаВходящегоДокумента = ЭлектронныйСФ.Реквизиты.Дата;
	ДокументСФ.НомерВходящегоДокумента = ЭлектронныйСФ.Реквизиты.Номер;
	ДокументСФ.Дата = ДатаДокумента;
	ДокументСФ.КодСпособаПолучения = 2;
	ДокументСФ.ОбменДанными.Загрузка = Истина;
	ДокументСФ.Записать();
	
	Если НЕ ЭлектронныеДокументыРавны(Документ, ЭлектронныйСФ) Тогда
		ОсновнойМодуль.ОбновлениеРеквизитовДокумента(ЭлектронныйСФ.Идентификаторы, ДокументСФ.Ссылка);
		ОсновнойМодуль.ЭДО_ОбновитьКомментарийДокументаУчета(Документ, ДокументСФ);
	КонецЕсли;
	
КонецПроцедуры

// Выполняет поиск счета-фактуры, полученного в одном пакете с указанным электронным документом.
//
// Параметры:
//  Документ - Структура - электронный документ (см. Контракт_Документ).
// 
// Возвращаемое значение:
//  Структура - электронный счет-фактура (см. Контракт_Документ).
//  Неопределено - если в пакете с указанным документом не найден счет-фактура.
//
Функция ЭлектронныйСчетФактураПакета(Документ)
	
	Результат = Неопределено;
	
	ТипДокумента = Документ.Тип;
	
	Если ОсновнойМодуль.ЭтоУниверсальныйПередаточныйДокумент(ТипДокумента)
		Или ОсновнойМодуль.ЭтоСчетФактура(ТипДокумента)
		Или ОсновнойМодуль.ЭтоКорректировочныйСчетФактура(ТипДокумента)
		Или ОсновнойМодуль.ЭтоУниверсальныйКорректировочныйДокумент(ТипДокумента) Тогда
		
		Результат = Документ;
		
	Иначе
		
		ТаблицаДокументовПакета = ОсновнойМодуль.Пакеты_ДокументыПакетов(Документ.Идентификаторы);
		
		Для Каждого ДокументПакета Из ТаблицаДокументовПакета Цикл
			
			Если ЭлектронныеДокументыРавны(Документ, ДокументПакета) Тогда
				Продолжить;
			КонецЕсли;
			
			ТипДокументаПакета = ДокументПакета.Тип;
			
			Если ОсновнойМодуль.ЭтоСчетФактура(ТипДокументаПакета) 
				Или ОсновнойМодуль.ЭтоКорректировочныйСчетФактура(ТипДокументаПакета) Тогда
				Результат = ДокументПакета;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Находит учетный документ, на основании которого нужно создать корректировку поступления.
//
// Параметры:
//  Документ - Структура - электронный УКД или КСФ (см. Контракт_Документ).
//  Ошибки - Массив из Строка- (возвращаемый параметр) Описания ошибок подбора документа-основания.
// 
// Возвращаемое значение:
//  ЛюабяСсылка - ссылка на документ-основание корректировки поступления.
//
Функция НайтиОснованиеДляСозданияКорректировкиПоступления(Документ, Ошибки)
	
	ДвоичныеДанные = Документ.Документооборот.ХранилищеКонтента.Данные;
	ДеревоКонтента = ОсновнойМодуль.XML_В_XDTO(ДвоичныеДанные);
	НомерДатаСФ = ДеревоКонтента.Документ.СвКСчФ.СчФ;
	
	ДокументОснование = Неопределено;
	
	Если ЭтоКорректировкаПоНесколькимОснованиям(НомерДатаСФ) Тогда
		
		Ошибки.Добавить("Создание корректировки по нескольким документам-оснований недоступно.");
		Ошибки.Добавить("Вы можете вручную создать документ в 1С и сопоставить его с текущим документом.");
		
	Иначе
		
		ДокументОснование = НайтиОснованиеКорректировки(Документ, НомерДатаСФ, Ошибки);
		ПроверитьОснованиеКорректировки(ДокументОснование, Ошибки);
		
	КонецЕсли;
	
	Возврат ДокументОснование;
	
КонецФункции

Функция ЭтоКорректировкаПоНесколькимОснованиям(НомерДатаСФ)
	
	Результат = (ТипЗнч(НомерДатаСФ) = Тип("СписокXDTO"));
	Возврат Результат;
	
КонецФункции

Функция НайтиОснованиеКорректировки(Документ, НомерДатаСФ, Ошибки)
	
	ДокументОснование = Неопределено;
	
	НомерОснования = НомерДатаСФ.НомерСчФ;
	ДатаОснования  = ОсновнойМодуль.ДатаXML_в_Дата1С(НомерДатаСФ.ДатаСчФ);
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Организация",		Документ.Получатель.Организация);
	ПараметрыОтбора.Вставить("Контрагент",		Документ.Отправитель.Организация);
	ПараметрыОтбора.Вставить("ДатаДокумента",	ДатаОснования);
	ПараметрыОтбора.Вставить("НомерДокумента",	НомерОснования);
	
	Если Документ.Тип.ФункцияДокумента = "InvoiceAndBasic" Тогда
		
		ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "СчетФактураПолученный");
		
		Если ДокументыОснования1С <> Неопределено И ДокументыОснования1С.Количество() = 1 
			И ДокументыОснования1С[0].ДокументыОснования.Количество() = 1 Тогда
			ДокументОснование = ДокументыОснования1С[0].ДокументыОснования[0].ДокументОснование;
		КонецЕсли;
		
	ИначеЕсли Документ.Тип.ФункцияДокумента = "Basic" Тогда

		ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "ПоступлениеТоваровУслуг");
		
		Если ДокументыОснования1С = Неопределено Тогда
			ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "ПоступлениеДопРасходов");
		КонецЕсли;
		
		Если ДокументыОснования1С <> Неопределено И ДокументыОснования1С.Количество() = 1 Тогда
			ДокументОснование = ДокументыОснования1С[0];
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		
		ТекстОшибки = "Для корректировки не найден документ-основание №%НомерДокумента% от %ДатаДокумента%.";
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%НомерДокумента%", НомерОснования);
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ДатаДокумента%", ДатаОснования);
		
		СоздаватьСчетаФактуры = ОсновнойМодуль.ЭДО_Модуль_ОбщиеНастройки().СоздаватьСчетаФактуры;
		
		Если СоздаватьСчетаФактуры = Истина Тогда
			ТекстРешения = "Создайте счет-фактуру для документа-основания и повторите создание документа.";
		Иначе
			ТекстРешения = "Сопоставьте документ вручную из карточки документа.";
		КонецЕсли;
		
		Ошибки.Добавить(ТекстОшибки);
		Ошибки.Добавить(ТекстРешения);
		
	КонецЕсли;
	
	Возврат ДокументОснование;
	
КонецФункции

Процедура ПроверитьОснованиеКорректировки(ДокументОснование, Ошибки)
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	ТребуемыеРеквизиты = Новый Структура;
	ТребуемыеРеквизиты.Вставить("Договор", "ДоговорКонтрагента");
	
	ЗначенияРеквизитов = ЗначенияРеквизитовОбъектаЛок(ДокументОснование, ТребуемыеРеквизиты);
	
	ПредставлениеДокумента = Строка(ДокументОснование);
	
	Если Не ЗначениеЗаполнено(ЗначенияРеквизитов.Договор) Тогда
		
		ТекстОшибки = "На основании документа %Документ% нельзя создать корректировку поступления, т.к. не указан договор.";
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Документ%", ПредставлениеДокумента);
		
		Ошибки.Добавить(ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьДокументы1С(ПараметрыОтбора, ВидДокумента1С)

	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	
	Для Каждого Элемент Из ПараметрыОтбора Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Если ВидДокумента1С = "ПоступлениеТоваровУслуг" Тогда				
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПоступлениеТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.ПоступлениеТоваровУслуг КАК ПоступлениеТоваровУслуг
		|ГДЕ
		|	НЕ ПоступлениеТоваровУслуг.ПометкаУдаления
		|	И ПоступлениеТоваровУслуг.Организация = &Организация
		|	И ПоступлениеТоваровУслуг.Контрагент = &Контрагент
		|	И ПоступлениеТоваровУслуг.ДатаВходящегоДокумента = &ДатаДокумента
		|	И ПоступлениеТоваровУслуг.НомерВходящегоДокумента = &НомерДокумента";
	
	ИначеЕсли ВидДокумента1С = "ПоступлениеДопРасходов" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПоступлениеДопРасходов.Ссылка
		|ИЗ
		|	Документ.ПоступлениеДопРасходов КАК ПоступлениеДопРасходов
		|ГДЕ
		|	НЕ ПоступлениеДопРасходов.ПометкаУдаления
		|	И ПоступлениеДопРасходов.Организация = &Организация
		|	И ПоступлениеДопРасходов.Контрагент = &Контрагент
		|	И ПоступлениеДопРасходов.ДатаВходящегоДокумента = &ДатаДокумента
		|	И ПоступлениеДопРасходов.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "КорректировкаПоступления" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КорректировкаПоступления.Ссылка
		|ИЗ
		|	Документ.КорректировкаПоступления КАК КорректировкаПоступления
		|ГДЕ
		|	НЕ КорректировкаПоступления.ПометкаУдаления
		|	И КорректировкаПоступления.Организация = &Организация
		|	И КорректировкаПоступления.Контрагент = &Контрагент
		|	И КорректировкаПоступления.ДатаВходящегоДокумента = &ДатаДокумента
		|	И КорректировкаПоступления.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "СчетФактураПолученный" Тогда
	
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетФактураПолученный.Ссылка
		|ИЗ
		|	Документ.СчетФактураПолученный КАК СчетФактураПолученный
		|ГДЕ
		|	НЕ СчетФактураПолученный.ПометкаУдаления
		|	И СчетФактураПолученный.Организация = &Организация
		|	И СчетФактураПолученный.Контрагент = &Контрагент
		|	И СчетФактураПолученный.ДатаВходящегоДокумента = &ДатаДокумента
		|	И СчетФактураПолученный.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "СчетНаОплатуПоставщика" Тогда
	
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетНаОплатуПоставщика.Ссылка
		|ИЗ
		|	Документ.СчетНаОплатуПоставщика КАК СчетНаОплатуПоставщика
		|ГДЕ
		|	НЕ СчетНаОплатуПоставщика.ПометкаУдаления
		|	И СчетНаОплатуПоставщика.Организация = &Организация
		|	И СчетНаОплатуПоставщика.Контрагент = &Контрагент
		|	И СчетНаОплатуПоставщика.ДатаВходящегоДокумента = &ДатаДокумента
		|	И СчетНаОплатуПоставщика.НомерВходящегоДокумента = &НомерДокумента";		
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Запрос.Текст) Тогда
		
		РезультатЗапроса = Запрос.Выполнить();

		Если НЕ РезультатЗапроса.Пустой() Тогда
			Результат = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновитьКомментарийДокументаУчета(Параметры)
	
	Документ = Параметры.Документ;
	
	ДокументУчета		= Документ.ДокументУчета;
	ФункцияДокумента	= Документ.Тип.ФункцияДокумента;
	    	
	ДобавляемыйКомментарий = Параметры.Комментарий;
	
	Если Параметры.ДокументОбъект = Неопределено Тогда
		Документ1С = ДокументУчета;
	Иначе
		Документ1С = Параметры.ДокументОбъект;
	КонецЕсли;

	// меняем комментарий в самом документе
	ОсновнойМодуль.ЭДО_ОбновитьКомментарийДокумента1С(Документ1С, ДобавляемыйКомментарий);

	// далее при необходимости поменяем комментарий в документах-основаниях
	ЭтоПолныйУПД_УКД = ФункцияДокумента = "СЧФДОП" ИЛИ ФункцияДокумента = "КСЧФДИС"; 
	
	ЭтоСФ = ТипЗнч(ДокументУчета) = Тип("ДокументСсылка.СчетФактураВыданный")
			ИЛИ ТипЗнч(ДокументУчета) = Тип("ДокументСсылка.СчетФактураПолученный");
	
	Если ЭтоПолныйУПД_УКД И ЭтоСФ Тогда
		
		Для Каждого СтрокаОснование Из ДокументУчета.ДокументыОснования Цикл
			ОсновнойМодуль.ЭДО_ОбновитьКомментарийДокумента1С(СтрокаОснование.ДокументОснование, ДобавляемыйКомментарий);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ПроверитьЗаполнениеДокумента(ДокументОбъект, Ошибки, ОтключитьПроверкуСопоставленияНоменклатуры)
	
	Если ДокументОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьСтрокуДокументовОснованияСЧФ(ДокументОбъект);
	
	Если НЕ ОтключитьПроверкуСопоставленияНоменклатуры Тогда
		
		ПроверитьЧтоНоменклатураЗаполнена(ДокументОбъект, Ошибки);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЧтоНоменклатураЗаполнена(ДокументОбъект, Ошибки)
	
	ПроверяемыеТаблицы = Новый Структура;
	ПроверяемыеТаблицы.Вставить("Товары", Неопределено);
	ПроверяемыеТаблицы.Вставить("Услуги", Неопределено);
	
	ЗаполнитьЗначенияСвойств(ПроверяемыеТаблицы, ДокументОбъект);
	
	Для Каждого ЭлементСтруктуры Из ПроверяемыеТаблицы Цикл
		
		ПроверяемаяТаблица = ЭлементСтруктуры.Значение;
		
		Если ПроверяемаяТаблица = Неопределено
			Или ЗначениеЗаполнено(Ошибки) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СтрокаТовар Из ПроверяемаяТаблица Цикл
			
			Номенклатура = СтрокаТовар.Номенклатура;
			
			Если Не ЗначениеЗаполнено(Номенклатура) Тогда
				
				ТекстОшибки = НСтр(
						"ru = 'Не сопоставлена номенклатура. Проверьте сопоставление номенклатуры.';
						|en = 'Не сопоставлена номенклатура. Проверьте сопоставление номенклатуры.'"
					);
				
				Ошибки.Добавить(ТекстОшибки);
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьСтрокуДокументовОснованияСЧФ(ДокументОбъект)
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.СчетФактураПолученный")
		И Не ЗначениеЗаполнено(ДокументОбъект.ДокументОснование) 
		И ДокументОбъект.ДокументыОснования.Количество() = 0 Тогда
		
		ДокументОбъект.ДокументыОснования.Добавить(); 
		
	КонецЕсли;
	
КонецПроцедуры

Функция Общее_СтрокаВДату(Значение)
	
	ИнтерфейсБСП = ОбщийМодульПоИмениЛок("СтроковыеФункцииКлиентСервер");
	Результат = ИнтерфейсБСП.СтрокаВДату(Значение);
	
	Возврат Результат;
	
КонецФункции

Функция СтрШаблонЛок(ШаблонСтроки, Параметр1
	, Параметр2 = Неопределено
	, Параметр3 = Неопределено
	, Параметр4 = Неопределено
	, Параметр5 = Неопределено
	, Параметр6 = Неопределено)
	
	Результат = СтрЗаменить(ШаблонСтроки, "%1", Параметр1);
	Результат = СтрЗаменить(Результат	, "%2", Параметр2);
	Результат = СтрЗаменить(Результат	, "%3", Параметр3);
	Результат = СтрЗаменить(Результат	, "%4", Параметр4);
	Результат = СтрЗаменить(Результат	, "%5", Параметр5);
	Результат = СтрЗаменить(Результат	, "%6", Параметр6);
	
	Возврат Результат;
	
