		Возврат;
	КонецЕсли;
	
	Метрика_ПриЗакрытии();
	
	Если Режим = "ОбновлениеРазделаСКонтрагентами_ВашиКонтрагенты" 
		Или Режим = "ОбновлениеРазделаСКонтрагентами_ПоискИПриглашение" Тогда
		
		Метрики_НовоеВВерсииРаботаСКонтрагентами_ЗакрытиеФормы(); 
		
	ИначеЕсли Режим = "СопоставлениеСКонтрагентами1С_ВашиКонтрагенты" 
		Или Режим = "СопоставлениеСКонтрагентами1С_ПоискИПриглашение" Тогда
		
		Метрики_СопоставлениеСКонтрагентами1С_ЗакрытиеФормы();
		
	КонецЕсли;
	
