// Обработчик нажатия на гиперссылку "Сопоставить"
// Параметры:
//  Результат - Строка - Индекс значения списка ДанныхКонтрагентов
//  ДополнительныеПараметры - Неопределено - не испльзуется
//
&НаКлиенте
Процедура ОбработатьНажатие_ОткрытьСсылкуСопоставитьКонтрагента(Результат = Неопределено,
	ДополнительныеПараметры = Неопределено) Экспорт
	
	ДанныеКонтрагента = ДанныеКонтрагентов.Получить(Число(Результат)).Значение;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ID", ДанныеКонтрагента.ID);
	ПараметрыФормы.Вставить("ДанныеКонтрагента", ДанныеКонтрагента);
	ПараметрыФормы.Вставить("ДанныеОрганизации", ОтборПоОрганизации);
	ПараметрыФормы.Вставить("ИмяСправочника", "Контрагенты");
	
	Модуль_Платформа = Модуль_Платформа();
	ОповещениеОЗакрытииФормы = Модуль_Платформа.НовыйОписаниеОповещения("ПослеЗакрытияФормыКонтрагента", ЭтаФорма);
	
	Модуль_Платформа.ОткрытьФормуДиадокМодальноЛок(
		"ФормаЭлементаСправочникаУправляемая",
		ЭтаФорма,
		ПараметрыФормы,
		ОповещениеОЗакрытииФормы);
	
	Если ДанныеКонтрагента.СвязанныйСправочник1 = Неопределено Тогда
		ДействиеМетрики = "Сопоставить";
	Иначе 
		ДействиеМетрики = "СопоставлениеВыполнено";
	КонецЕсли;
	
	Метрика_ДобавитьСтатистику_ПринятиеНесколькихПриглашений(ДействиеМетрики);
	Метрика_ДобавитьПоведение_ПринятиеНесколькихПриглашений(ДействиеМетрики);
	
КонецПроцедуры

