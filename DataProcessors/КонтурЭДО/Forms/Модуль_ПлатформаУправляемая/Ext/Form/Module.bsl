// Открывает форму ожидания подписания Госключ
//  ОповещениеОЗавершении содержит описание процедуры, которая будет вызвана после закрытия окна ожидания
//  со следующими параметрами:
//  РезультатПодписанияГосключ - Неопределено, Структура - см. РезультатПодписанияГосключ результат подписания Госключ
//  ДополнительныеПараметры - Произвольный - значение, которое было указано при создании объекта ОписаниеОповещения.
//
// Параметры:
//  ОповещениеОЗавершении	 - ОписаниеОповещения	 - Оповещение, вызываемое при окончании подписания
//  ПараметрыОткрытияФормы	 - Структура			 - см. ПараметрыФормыПодписанияГосключ()
//
&НаКлиенте
Процедура ОткрытьФормуОжиданияПодписанияГосключ(ОповещениеОЗавершении, ПараметрыОткрытияФормы) Экспорт
	
	ОткрытьФормуДиадокМодальноЛок("Госключ_ФормаОжиданияПодписанияУправляемая", ЭтаФорма,
		ПараметрыОткрытияФормы, ОповещениеОЗавершении);
	
КонецПроцедуры

// Возвращает праметры для метода проверки СНИЛС
//
// Параметры:
//  ВведенныйСНИЛС		 - Строка	 - Веденный СНИЛС
//  ВведенныйOID		 - Строка	 - Веденный OID
// 
// Возвращаемое значение:
//  Структура - Параметры для проверки СНИЛС/OID
//
&НаКлиенте
Функция ПараметрыДляПроверкиСНИЛС_OID(ВведенныйСНИЛС, ВведенныйOID) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ВведенныйСНИЛС", ВведенныйСНИЛС);
	Результат.Вставить("ВведенныйOID", ВведенныйOID);
	
	Результат.Вставить("СНИЛСВалиден", Ложь);
	Результат.Вставить("OIDВалиден", Ложь);
	
	Возврат Результат;
	
КонецФункции

