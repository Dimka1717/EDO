&НаСервере
Функция ИдентификаторыОрганизацииДокументаНаСервере(ДокументУчета)
	
	Результат = Новый Структура("АдресЯщика, BoxId");
	
	Ядро = Модуль_Ядро();
	
	Организация = Ядро.ДокументыУчета_Организация(ДокументУчета);
	
	Если ЗначениеЗаполнено(Организация) Тогда
		
		ИдентификаторПоСсылке = Ядро.Организации_ИдентификаторПоСсылке(Организация);
		
		Если ЗначениеЗаполнено(ИдентификаторПоСсылке) Тогда
			
			Результат.АдресЯщика = Ядро.ИдентификаторВАдресЯщика(ИдентификаторПоСсылке);
			Результат.BoxId = Ядро.АдресЯщикаВИдентификатор(ИдентификаторПоСсылке);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

