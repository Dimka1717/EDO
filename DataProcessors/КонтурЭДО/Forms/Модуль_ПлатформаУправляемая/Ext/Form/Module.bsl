// Открывает форму списка уведомлений пользователей
//
// Параметры:
//  Фильтр - Структура - Параметры фильтра для запроса ЭУ
//  ИдентификаторСпискаУведомлений - Строка - Ключ таблицы уведомлений для формы-владельца уведомлений
//  ПараметрВладелец - ФормаКлиентскогоПриложения - (Необязательный) форма-владелец
//  ОбработчикЗакрытия - Структура, ОписаниеОповещения - (Необязательный) оповещение о закрытии формы ЭУ
//
&НаКлиенте
Процедура ОткрытьФормуУведомлений(Фильтр, ИдентификаторСпискаУведомлений, ПараметрВладелец = Неопределено,
	ОбработчикЗакрытия = Неопределено)
	
	ИмяФормыСпискаУведомлений = ПутьКФормам + "ФормаСпискаУведомленийУправляемая";
	КлючУникальностиФормы = "СписокУведомлений";
	ОкноПриложения = Неопределено;
	НавигационнаяСсылка = Неопределено;
	
	Если ПараметрВладелец = Неопределено Тогда
		ПараметрВладелец = ОсновнаяФорма();
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Объект", Объект);
	ПараметрыФормы.Вставить("Фильтр", Фильтр);
	ПараметрыФормы.Вставить("КлючТаблицыУведомлений", ИдентификаторСпискаУведомлений);
	
	ОткрытьФормуЛок(
		ИмяФормыСпискаУведомлений,
		ПараметрыФормы,
		ПараметрВладелец,
		КлючУникальностиФормы,
		ОкноПриложения,
		НавигационнаяСсылка,
		ОбработчикЗакрытия,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца
	);
	
КонецПроцедуры

