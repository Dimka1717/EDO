Функция ПараметрыФормыВвода() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Заголовок", "");
	Результат.Вставить("ТекстСообщения", "");
	Результат.Вставить("ТекстКнопкиВыполнить", "");
