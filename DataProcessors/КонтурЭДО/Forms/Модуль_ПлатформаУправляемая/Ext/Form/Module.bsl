&НаСервере
Функция ОбработкаОбъект()
	
	Если _ОбработкаОбъект = Неопределено Тогда
		_ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	КонецЕсли;
	
	Возврат _ОбработкаОбъект;
	
КонецФункции

&НаСервере
Функция Модуль_Ядро()
	
	Если _МодульЯдроНаСервере = Неопределено Тогда
		Модуль = ОбработкаОбъект();
		_МодульЯдроНаСервере = Модуль.Модуль_Ядро();
	КонецЕсли;
	
	Возврат _МодульЯдроНаСервере;
	
КонецФункции

&НаКлиенте
Функция Модуль_ЯдроНаКлиенте() Экспорт
	
	Если _МодульЯдроНаКлиенте <> Неопределено Тогда
		УстановитьКонтекстВызываемойФормы(_МодульЯдроНаКлиенте);
		Возврат _МодульЯдроНаКлиенте;
	КонецЕсли;
	
	ИмяФормыЯдро = "Обработка.КонтурДиадокЯдро.Форма.КлиентскиеВызовы";
	Если ПодключатьМодулиИзМакетов Тогда
		ИмяФормыЯдро = "Внешняя" + ИмяФормыЯдро;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ОбщийКонтекстКлиентСервер", Объект.ОбщийКонтекстКлиентСервер);
	
	// BSLLS:GetFormMethod-off
	_МодульЯдроНаКлиенте = ПолучитьФорму(ИмяФормыЯдро, ПараметрыФормы, ЭтаФорма);
	// BSLLS:GetFormMethod-on
	
	Возврат _МодульЯдроНаКлиенте;
	
КонецФункции

