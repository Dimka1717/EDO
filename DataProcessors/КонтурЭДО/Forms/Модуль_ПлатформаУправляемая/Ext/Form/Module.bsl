// Открывает форму настройки конфигурации клиента OAuth (имя и ключ приложения).
//
// Параметры:
//  ПриИзменении - ОписаниеОповещения - обработчик, который будет вызван при успешном сохранении настроек.
//
&НаКлиенте
Процедура Аутх_РедактироватьКонфигурациюПриложения(ПриИзменении) Экспорт
	
	Если Не Пользователи_ЕстьАдминистративныеПраваВызовСервера() Тогда
		
		ТекстЛок = "Для редактирования конфигурации OAuth требуются права администратора.";
		ТаймаутЛок = 60;
		ЗаголовокЛок = "Контур.Диадок: Доступ запрещён";
		ПоказатьПредупреждениеЛок(Неопределено, ТекстЛок, ТаймаутЛок, ЗаголовокЛок);
		
		Возврат;
		
	КонецЕсли;
	
	ПараметрыРедактированияКонфигурации = Новый Структура;
	ПараметрыРедактированияКонфигурации.Вставить("ПриИзмененииКонфигурации", ПриИзменении);
	
	ПриИзмененииКонфигурацииПриложения = НовыйОписаниеОповещения(
		"АутхСлужебныйОбработчик_ПриИзмененииКонфигурацииПриложения",
		ЭтаФорма,
		ПараметрыРедактированияКонфигурации
	);
	
	ПараметрыФормы = Новый Структура;
	
	ОткрытьФормуДиадокМодальноЛок(
		"АутхКонфигурацияПриложенияУправляемая",
		ПриИзменении.Модуль,
		ПараметрыФормы,
		ПриИзмененииКонфигурацииПриложения,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс
	);
	
КонецПроцедуры

&НаКлиенте
Процедура АутхСлужебныйОбработчик_ПриИзмененииКонфигурацииПриложения(Знач НастройкиИзменены, Знач ПараметрыРедактированияКонфигурации = Неопределено) Экспорт
	
	Если НастройкиИзменены <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещенияЛок(
		ПараметрыРедактированияКонфигурации.ПриИзмененииКонфигурации,
		НастройкиИзменены
	);
	
КонецПроцедуры

&НаКлиенте
Процедура АвторизацияСлужебныйОбработчик_ПриПолученииСессииЧерезБраузер(ПортальнаяСессия, ПараметрыПолученияСессии) Экспорт
	
	Если ТипЗнч(ПортальнаяСессия) <> Тип("ФиксированнаяСтруктура")
		И ТипЗнч(ПортальнаяСессия) <> Тип("Структура") Тогда
		// Пользователь не подтвердил доступы приложения в браузере
		Возврат;
	КонецЕсли;
	
	Сессия = АвторизацияСлужебный_СессияПорталБраузерВызовСервера(АутхКлючНастройки(), ПортальнаяСессия);
	
	ВыполнитьОбработкуОповещенияЛок(
		ПараметрыПолученияСессии.ПриПолученииСессии,
		Сессия
	);
	
