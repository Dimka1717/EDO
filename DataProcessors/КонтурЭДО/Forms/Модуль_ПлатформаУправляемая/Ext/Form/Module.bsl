// Асинхронный метод получения авторизационного токена Диадока по протоколу Open ID Connect.
// Передает структуру Ядро.МодельСессияПользователя как результат в обработчик ПриПолученииСессии.
//
// Параметры:
//  ПриПолученииСессии - ОписаниеОповещения - обработчик, который будет вызван при получении токена
//
&НаКлиенте
Процедура Авторизация_НачатьПолучениеСессииЧерезБраузер(ПриПолученииСессии) Экспорт
	
	ПараметрыПолученияСессии = Новый Структура;
	ПараметрыПолученияСессии.Вставить("ПриПолученииСессии", ПриПолученииСессии);
	
	ПриПолученииСессииЧерезБраузер = НовыйОписаниеОповещения(
		"АвторизацияСлужебныйОбработчик_ПриПолученииСессииЧерезБраузер",
		ЭтаФорма,
		ПараметрыПолученияСессии
	);
	
	// BSLLS:UnusedLocalVariable-off
	КлючСессии = АутхКлючНастройки();
	// BSLLS:UnusedLocalVariable-on
	
	МодульАутх = МодульАутхСлужебныйНаКлиенте();
	МодульАутх.НачатьПолучениеСессии(ПриПолученииСессииЧерезБраузер);
	
КонецПроцедуры

