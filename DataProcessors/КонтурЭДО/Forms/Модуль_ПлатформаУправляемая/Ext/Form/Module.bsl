// Выполняет проверку введенного СНИЛС/OID, по результатам выводит сообщения пользователю
//
// Параметры:
//  ПараметрыДляПроверкиСНИЛС_OID	 - Структура - см. ПараметрыДляПроверкиСНИЛС_OID().
// 
// Возвращаемое значение:
//  Структура - см. РезультатВводаСНИЛС_OID()
//
&НаКлиенте
Функция ПроверитьСНИЛС_OID(ПараметрыДляПроверкиСНИЛС_OID) Экспорт
	
	ВведенныйСНИЛС = ПараметрыДляПроверкиСНИЛС_OID.ВведенныйСНИЛС;
	ВведенныйOID = ПараметрыДляПроверкиСНИЛС_OID.ВведенныйOID;
	
	РезультатВводаСНИЛС_OID = РезультатВводаСНИЛС_OID();
	
	Если Не ЗначениеЗаполнено(ВведенныйСНИЛС)
		И Не ЗначениеЗаполнено(ВведенныйOID) Тогда
		
		РезультатВводаСНИЛС_OID.ПодробноеОписаниеСтатуса = НСтр("ru = 'СНИЛС/OID не введен'");
		
	Иначе
		ПараметрыДляПроверкиСНИЛС_OID.СНИЛСВалиден = ЭтоВалидныйСНИЛС(ВведенныйСНИЛС);
		ПараметрыДляПроверкиСНИЛС_OID.OIDВалиден = ЭтоВалидныйOID(ВведенныйOID);
		
		Если ПараметрыДляПроверкиСНИЛС_OID.СНИЛСВалиден Тогда
		
			РезультатВводаСНИЛС_OID.РазрешитьДействие = Истина;
			РезультатВводаСНИЛС_OID.ВведенныйСНИЛС = ВведенныйСНИЛС;
			РезультатВводаСНИЛС_OID.ВыбранноеДействие = Перечисление_ВыбранныйСпособПодписанияГосключ().СНИЛС;
			
		ИначеЕсли ПараметрыДляПроверкиСНИЛС_OID.OIDВалиден Тогда
			
			РезультатВводаСНИЛС_OID.РазрешитьДействие = Истина;
			РезультатВводаСНИЛС_OID.ВведенныйOID = ВведенныйOID;
			РезультатВводаСНИЛС_OID.ВыбранноеДействие = Перечисление_ВыбранныйСпособПодписанияГосключ().OID;
			
		Иначе
			
			РезультатВводаСНИЛС_OID.ПодробноеОписаниеСтатуса = НСтр("ru = 'Введен ошибочный СНИЛС/OID'");
			
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатВводаСНИЛС_OID;
	
КонецФункции

&НаКлиенте
