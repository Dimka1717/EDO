&НаКлиенте
Процедура СформироватьМетрикуДействияИзДокумента1С(ДействиеМетрики, ИсточникОткрытия)
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	КатегорияМетрики = Ядро.Метрика_НазваниеКатегории().ДействияИзДокумента1С;
	МеткаМетрики = "Нажать кнопку";
	ПредставлениеМетрики = "Документ1С";
	TraceId = "РаботаИзИнтерфейса1С" + ИсточникОткрытия.УникальныйИдентификатор();
	
	ДопПеременные = Новый Соответствие;
	ДопПеременные.Вставить("Источник", СокрЛП(ТипЗнч(ИсточникОткрытия)));
	
	ИдентификаторЯщика = ИдентификаторЯщикаОрганизацииДокумента(ИсточникОткрытия);
	
	Ядро.Метрика_ДобавитьСтатистику_ДляОрганизации(
		ИдентификаторЯщика,
		КатегорияМетрики,
		ДействиеМетрики,
		Неопределено,
		ДопПеременные,
		ПредставлениеМетрики,
		TraceId
	);
	Ядро.Метрика_ДобавитьПоведение(
		КатегорияМетрики,
		ДействиеМетрики,
		МеткаМетрики,
		Неопределено,
		ПредставлениеМетрики,
		TraceId
	);
	
