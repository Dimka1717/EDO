&НаКлиенте
Процедура ВыполнитьОбменССерверомСФормойПрогресса(
	ИдентификаторОсновнойФормы = Неопределено,
	ОбработчикНастройкиСервисныхФункций = Неопределено
	) Экспорт
	
	СформироватьИзвещенияОПолучении();
	
	СформироватьОтменуФиксацииГИСМТ();
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	Ядро.ВнешнееХранение_ВыполнитьОчисткуУстаревшихДокументов();
	
	Если Объект.ОбщийКонтекстКлиентСервер.ИспользоватьСлужебнуюУчетнуюЗапись
		 И Не ПроверитьАвторизациюСлужебногоПользователяНаСервере() Тогда
		
		ТекстОшибкиАвторизации	= "В настройках введен неверный логин или пароль.
			|Не удалось выполнить обмен с сервером.";
		
		ПоказатьПредупреждениеОбОшибкеАвторизацииСлужебногоПользователя(
			ТекстОшибкиАвторизации,
			ОбработчикНастройкиСервисныхФункций
		);
		
		Возврат;
		
	КонецЕсли;
	
	СтрокиКонтекста = Ядро.КонтекстСеанса_СтрокиКонтекста();
	
	КоличествоОрганизаций = СтрокиКонтекста.Количество();
	
	ОрганизацииСОшибкамиАвторизации = Новый Массив;
	СчетчикОрганизаций = 0;
	
	Для Каждого СтрокаКонтекста Из СтрокиКонтекста Цикл
		
		Если НЕ СтрокаКонтекста.Значение.Свойство("ОрганизацияДиадок") Тогда
			Продолжить;
		КонецЕсли;
		
		BoxId = СтрокаКонтекста.Ключ;
		
		КатегорияМетрики = Ядро.Метрика_НазваниеКатегории().ОбменССервером;
		ДействиеМетрики = "Обмен с сервером";
		
		Ядро.Метрика_ДобавитьСтатистику_ДляОрганизации(BoxId, КатегорияМетрики, ДействиеМетрики);
		
		СчетчикОрганизаций = СчетчикОрганизаций + 1;
		ОрганизацияДиадок = СтрокаКонтекста.Значение.ОрганизацияДиадок;
		
		ШаблонЗаголовкаФормыПрогресса = "Синхронизация (%1 из %2): %3";
		
		ЗаголовокФормыПрогресса = Ядро.Общее_ПодставитьПараметрыВСтроку(
			ШаблонЗаголовкаФормыПрогресса,
			СчетчикОрганизаций,
			КоличествоОрганизаций,
			ОрганизацияДиадок
		);
		
		ФормаПрогресса = Форма_ПрогрессВыполнения();
		ФормаПрогресса.МассоваяОбработка = Истина;
		ФормаПрогресса.УстановитьЗаголовок(ЗаголовокФормыПрогресса);
		ФормаПрогресса.УстановитьЗначениеПрогресса(0);
		ФормаПрогресса.СброситьНадписи();
		
		Если СтрокаКонтекста.Значение.ПраваПользователя.DocumentAccessLevel <> "AllDocuments"
			И Не Объект.ОбщийКонтекстКлиентСервер.ИспользоватьСлужебнуюУчетнуюЗапись Тогда
			
			ОрганизацииСОшибкамиАвторизации.Добавить(ОрганизацияДиадок);
			
			Продолжить;
			
		КонецЕсли;
		
		СчетчикЦикла = 0;
		
		Пока Истина Цикл
			
			ОбработкаПрерыванияПользователя();
			
			СчетчикЦикла = СчетчикЦикла + 1;
			
			ОсталосьСобытийВЯщике = ОсталосьСобытийВЯщикеВызовСервера(ОрганизацияДиадок);
			ВсегоИтерацийКОбработке = СчетчикЦикла + Цел(ОсталосьСобытийВЯщике / 100);
			
			ФормаПрогресса.УстановитьМаксимальноеЗначение(ВсегоИтерацийКОбработке);
			ФормаПрогресса.УвеличитьЗначениеПрогресса();
			
			Если ОсталосьСобытийВЯщике = 0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		ФормаПрогресса.Закрыть();
		
	КонецЦикла;
	
	ИмяСобытия = "Диадок_ОбновитьГлавныйСписок";
	ПараметрыОповещения = Неопределено;
	
	Оповестить(
		ИмяСобытия,
		ПараметрыОповещения,
		ИдентификаторОсновнойФормы
	);
	
	Если ОрганизацииСОшибкамиАвторизации.Количество() > 0 Тогда
		
		ТекстОшибкиАвторизации	= "Не удалось выполнить обмен с сервером.
			|Укажите служебную учетную запись с полным доступом ко всем подразделениям организаций: ";
		
		ОрганизацииСтрокой = Ядро.СоединитьСтроку(ОрганизацииСОшибкамиАвторизации, ", ");
		ТекстОшибкиАвторизации = ТекстОшибкиАвторизации + ОрганизацииСтрокой;
		
		ПоказатьПредупреждениеОбОшибкеАвторизацииСлужебногоПользователя(
			ТекстОшибкиАвторизации,
			ОбработчикНастройкиСервисныхФункций
		);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьИзвещенияОПолучении() Экспорт
	
	Перем ФормироватьУС;
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	СтрокиКонтекста = Ядро.КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого СтрокаКонтекста Из СтрокиКонтекста Цикл
		
		BoxId = СтрокаКонтекста.Значение.Ящик.Идентификатор;
		
		Если ФормироватьУС = Истина Тогда
			Прервать;
		Иначе
			ФормироватьУС = Ядро.УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ФормироватьУС = Неопределено Тогда
		СформироватьИзвещенияОПолученииУстаревшегоФормата();
	Иначе
		
		Если ФормироватьУС Тогда
			СформироватьУниверсальныеСообщенияДляИзвещенийОПолучении();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьУниверсальныеСообщенияДляИзвещенийОПолучении()
	
	Состояние("Формирование и отправка извещений о получении СФ...");
	СформироватьИзвещенияОПолученииВызовСервера();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьИзвещенияОПолученииВызовСервера()
	
	Ядро = Модуль_Ядро();
	
	ПодготовленныеИзвещенияВсехОрганизаций = Ядро.ИоП_ПодготовитьИзвещенияОПолучении();
	Ядро.ИоП_ОтправитьИзвещенияОПолучении(ПодготовленныеИзвещенияВсехОрганизаций);
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьИзвещенияОПолученииУстаревшегоФормата()
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	ЕстьОтпечатокСертификата = Ложь;
	
	СтрокиКонтекста = Ядро.КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого СтрокаКонтекста Из СтрокиКонтекста Цикл
		Если СтрокаКонтекста.Значение.Свойство("ОтпечатокСертификата")
			И ЗначениеЗаполнено(СтрокаКонтекста.Значение.ОтпечатокСертификата) Тогда
			ЕстьОтпечатокСертификата = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьОтпечатокСертификата Тогда
		
		Состояние("Формирование и отправка извещений о получении СФ...");
		
		ПодготовленныеИзвещенияВсехОрганизаций = Ядро.ИоП_ПодготовитьИзвещенияОПолучении();
		
		Попытка
			Ядро.ИоП_ПодписатьИзвещенияОПолучении(ПодготовленныеИзвещенияВсехОрганизаций);
		Исключение
			
			ВидОперации = НСтр("ru = 'Формирование извещений о получении'");
			ТекстСообщения = НСтр("ru = 'Не удалось подписать извещения'");
			Ошибка = ИнформацияОбОшибке();
			
			Ядро.Ошибка_Обработать(
				ВидОперации,
				Ошибка,
				ТекстСообщения
			);
			
			Возврат;
			
		КонецПопытки;
		
		Ядро.ИоП_ОтправитьИзвещенияОПолучении(ПодготовленныеИзвещенияВсехОрганизаций);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьОтменуФиксацииГИСМТ() Экспорт
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	ФормироватьКвитанцииОбОтменеФиксации =
		Ядро.ФормироватьКвитанцииОбОтменеФиксации();
	
	Если НЕ ФормироватьКвитанцииОбОтменеФиксации Тогда
		Возврат;
	КонецЕсли;
	
	Состояние("Формирование и отправка отмены фиксации ГИСМТ...");
	
	СтрокиКонтекста = Ядро.КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого СтрокаКонтекста Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = СтрокаКонтекста.Значение;
		BoxId = СтрокаКонтекста.BoxId;
		ИНН = СтрокаКонтекста.Ящик.Организация.ИНН;
		ОтпечатокСертификата = Неопределено;
		СтрокаКонтекста.Свойство(
			"ОтпечатокСертификата",
			ОтпечатокСертификата);
		
		Если НЕ ЗначениеЗаполнено(BoxId)
			ИЛИ НЕ ЗначениеЗаполнено(ОтпечатокСертификата) Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			ДанныеОтменыФиксации = Ядро.ОтменаФиксации_ПолучитьДанные(BoxId, ИНН);
			
			Если НЕ ЗначениеЗаполнено(ДанныеОтменыФиксации) Тогда
				Продолжить;
			КонецЕсли;
			
			Ядро.ОтменаФиксации_Подписать(ОтпечатокСертификата, ДанныеОтменыФиксации);
			Ядро.ОтменаФиксации_Отправить(BoxId, ДанныеОтменыФиксации);
			
		Исключение
			
			ВидОперации = НСтр("ru = 'Подписание и отправка документов отмена фиксации'");
			ТекстСообщения = НСтр("ru = 'Не удалось подписать и отправить отмену фиксации'");
			Ошибка = ИнформацияОбОшибке();
			
			Ядро.Ошибка_Обработать(
				ВидОперации,
				Ошибка,
				ТекстСообщения);
			
			Возврат;
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьАвторизациюСлужебногоПользователяНаСервере()
	
	Ядро = Модуль_Ядро();
	
	ЛогинДляОбмена = Ядро.ОбщиеНастройки_Прочитать("СлужебнаяУчетнаяЗаписьЛогин");
	ПарольДляОбмена = Ядро.ОбщиеНастройки_Прочитать("СлужебнаяУчетнаяЗаписьПароль");
	
	Результат = Ядро.Авторизация_ПроверкаАвторизации(Неопределено, ЛогинДляОбмена, ПарольДляОбмена);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьПредупреждениеОбОшибкеАвторизацииСлужебногоПользователя(
	ТекстОшибкиАвторизации,
	ОбработчикНастройкиСервисныхФункций)
	
	ДопПараметры = Новый Структура;
	Доппараметры.Вставить("ОповещениеОЗакрытииНастроек", ОбработчикНастройкиСервисныхФункций);
	
	Оповещение = НовыйОписаниеОповещения("ОбработчикОткрытьНастройкуСервисныеФункции", ЭтаФорма, ДопПараметры);
	
	КнопкаПерейтиКНастройке = "Перейти к настройке";
	
	КнопкиВопроса = Новый СписокЗначений;
	КнопкиВопроса.Добавить(КнопкаПерейтиКНастройке);
	КнопкиВопроса.Добавить("Закрыть");
	
	ПоказатьВопросЛок(Оповещение, ТекстОшибкиАвторизации, КнопкиВопроса, , КнопкаПерейтиКНастройке);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОткрытьНастройкуСервисныеФункции(
	ПараметрОповещения = Неопределено,
	ПараметрыОбработки = Неопределено) Экспорт
	
	Если ПараметрОповещения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ПараметрОповещения <> "Перейти к настройке" Тогда
		Возврат;
	КонецЕсли;
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	НазваниеФормы = НазваниеОсновнойФормы();
	КатегорияМетрики = Ядро.Метрика_НазваниеКатегории().ОбменССервером;
	ДействиеМетрики = "Перейти к настройке";
	
	Ядро.Метрика_ДобавитьПоведение_НажатиеКнопки(
		НазваниеФормы,
		КатегорияМетрики,
		ДействиеМетрики
	);
	Ядро.Метрика_ДобавитьСтатистику_ПоКонтексту(КатегорияМетрики, ДействиеМетрики);
	
	ОткрытьНастройкиНезависимо("СервисныеФункции", ПараметрыОбработки.ОповещениеОЗакрытииНастроек);
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройкиНезависимо(РазделНастроек, ОповещениеОЗакрытииНастроек) Экспорт
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("РазделНастроек", РазделНастроек);
	ДопПараметры.Вставить("Объект", Объект);
	
	ИмяФормыСпискаНастроек = ПутьКФормам + "НастройкиУправляемая";
	КлючУникальностиФормы = Неопределено;
	ОкноПриложения = Неопределено;
	НавигационнаяСсылка = Неопределено;
	РежимБлокирования = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
	
	ОткрытьФормуЛок(
		ИмяФормыСпискаНастроек,
		ДопПараметры,
		ЭтаФорма,
		КлючУникальностиФормы,
		ОкноПриложения,
		НавигационнаяСсылка,
		ОповещениеОЗакрытииНастроек,
		РежимБлокирования
	);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройки(РазделНастроек, ОповещениеОЗакрытииНастроек) Экспорт
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("РазделНастроек", РазделНастроек);
	
	ОткрытьФормуДиадокМодальноЛок("НастройкиУправляемая", ЭтаФорма, ДопПараметры, ОповещениеОЗакрытииНастроек);
	
КонецПроцедуры

&НаСервере
Функция ОсталосьСобытийВЯщикеВызовСервера(ОрганизацияДиадок)
	
	Ядро = Модуль_Ядро();
	
	ОписаниеОрганизации = Ядро.Организации_ЗаполненныеРеквизиты(ОрганизацияДиадок);
	
	Результат = Ядро.Лента_ОбработатьНовыеСобытияДокументов(ОписаниеОрганизации, 1);
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НазваниеОсновнойФормы()
	
	Возврат "Основная форма";
	
КонецФункции

&НаКлиенте
Процедура ПроверитьДокументУчета(Знач ДокументУчета, Знач ПослеЗавершенияПроверки) Экспорт
	
	ЕстьОграниченияПоТарифу = ЕстьОграниченияПоТарифуНаСервере();
	
	Если ЕстьОграниченияПоТарифу Тогда
		НаименованиеФормы = "Команда расширения";
		ПоказатьПредупреждениеОТарифе(НаименованиеФормы);
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ДокументУчета", ДокументУчета);
	ПараметрыФормы.Вставить("Объект", Объект);
	ПараметрыФормы.Вставить("ФормироватьМетрикуСоСпискомОшибокИсточникаОткрытия", Истина);
	
	ПараметрыЗакрытияФормы = Новый Структура;
	ПараметрыЗакрытияФормы.Вставить("ПослеЗавершенияПроверки", ПослеЗавершенияПроверки);
	ПараметрыЗакрытияФормы = Новый ФиксированнаяСтруктура(ПараметрыЗакрытияФормы);
	
	ПриЗакрытииФормыПоискаДокументаСлужебный = НовыйОписаниеОповещения(
		"СлужебныйОбработчик_ПриЗакрытииФормыПоискаДокумента",
		ЭтаФорма,
		ПараметрыЗакрытияФормы
	);
	
	ИмяФормыПомощникаПроверкиДокумента = "ПомощникПоискаДокументаУправляемая";
	ФормаПроверкиДокумента = ПолучитьФорму(ПутьКФормам + ИмяФормыПомощникаПроверкиДокумента, ПараметрыФормы, ЭтаФорма);
	
	ДокументПрошелПроверку = ФормаПроверкиДокумента.ДокументПрошелПроверку();
	
	Если ДокументПрошелПроверку Тогда
		ВыполнитьОбработкуОповещенияЛок(ПриЗакрытииФормыПоискаДокументаСлужебный, ДокументПрошелПроверку);
	Иначе
		
		ПараметрыФормы.Вставить("ФормироватьМетрикуСоСпискомОшибокИсточникаОткрытия", Ложь);
		
		ОткрытьФормуДиадокМодальноЛок(
			ИмяФормыПомощникаПроверкиДокумента,
			ЭтаФорма,
			ПараметрыФормы,
			ПриЗакрытииФормыПоискаДокументаСлужебный
		);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СлужебныйОбработчик_ПриЗакрытииФормыПоискаДокумента(
	Знач ПроверкаПройдена,
	Знач ПараметрыЗакрытияФормы = Неопределено) Экспорт
	
	ВыполнитьОбработкуОповещенияЛок(ПараметрыЗакрытияФормы.ПослеЗавершенияПроверки, ПроверкаПройдена);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДокументУчета(Знач ДокументУчета, Знач ПослеЗакрытияДокумента) Экспорт
	
	ЕстьОграниченияПоТарифу = ЕстьОграниченияПоТарифуНаСервере();
	
	Если ЕстьОграниченияПоТарифу Тогда
		НаименованиеФормы = "Команда расширения";
		ПоказатьПредупреждениеОТарифе(НаименованиеФормы);
		Возврат;
	КонецЕсли;
	
	СтрокаСписка = СтрокаСпискаПоДокументуУчета(ДокументУчета);
	
	Если ЗначениеЗаполнено(СтрокаСписка.LetterId) Тогда
		РежимОтображенияДокументов = "ОтправленныеДокументы";
	Иначе
		РежимОтображенияДокументов = "ОтправкаПакетов";
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимОтображенияДокументов", РежимОтображенияДокументов);
	ПараметрыФормы.Вставить("РежимФормы", "ОтображениеПакета");
	ПараметрыФормы.Вставить("СтрокаСписка", СтрокаСписка);
	ПараметрыФормы.Вставить("ВыбранныеФайлы", Неопределено);
	ПараметрыФормы.Вставить("ИсточникОткрытия", ДокументУчета);
	
	ПараметрыЗакрытияФормы = Новый Структура;
	ПараметрыЗакрытияФормы.Вставить("ПослеЗакрытияДокумента", ПослеЗакрытияДокумента);
	ПараметрыЗакрытияФормы = Новый ФиксированнаяСтруктура(ПараметрыЗакрытияФормы);
	
	ПриЗакрытииФормыПакета = НовыйОписаниеОповещения(
		"СлужебныйОбработчик_ПриЗакрытииФормыПакета",
		ЭтаФорма,
		ПараметрыЗакрытияФормы
	);
	
	ОткрытьФормуДиадокМодальноЛок(
		"ФормаПакетаУправляемая",
		ЭтаФорма,
		ПараметрыФормы,
		ПриЗакрытииФормыПакета
	);
	
КонецПроцедуры

&НаКлиенте
Процедура СлужебныйОбработчик_ПриЗакрытииФормыПакета(
	Знач ПроверкаПройдена,
	Знач ПараметрыЗакрытияФормы = Неопределено) Экспорт
	
	ВыполнитьОбработкуОповещенияЛок(ПараметрыЗакрытияФормы.ПослеЗакрытияДокумента, ПроверкаПройдена);
	
