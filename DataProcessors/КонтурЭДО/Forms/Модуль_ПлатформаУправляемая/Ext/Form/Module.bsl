&НаКлиенте
Функция МодульАутхСлужебныйНаКлиенте()
	
	ИмяФормыАутх = "Обработка.КонтурДиадокАутентификатор.Форма.Клиент";
	Если ЭтоВнешняяОбработка Тогда
		ИмяФормыАутх = "ВнешняяОбработка.КонтурДиадокАутентификатор.Форма.Клиент";
	КонецЕсли;
	
	// BSLLS:GetFormMethod-off
	Результат = ПолучитьФорму(ИмяФормыАутх);
	// BSLLS:GetFormMethod-on
	
	Результат.УстановитьКонфигурациюПровайдера(АутхПровайдер);
	Результат.УстановитьКонфигурациюПриложения(АутхПриложение);
	Если АутхПрокси <> Неопределено Тогда
		Результат.УстановитьНастройкиПрокси(АутхПрокси);
	КонецЕсли;
	Результат.УстановитьОтборСессий(АутхОтборСессий(Результат.СобратьКлючОбъекта()));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция МодульАутхСлужебныйНаСервере()
	
	ИмяМодуляАутх = "ОбработкаОбъект.КонтурДиадокАутентификатор";
	Если ЭтоВнешняяОбработка Тогда
		ИмяМодуляАутх = "ВнешняяОбработкаОбъект.КонтурДиадокАутентификатор";
	КонецЕсли;
	
	Результат = Новый(ИмяМодуляАутх);
	Результат.УстановитьКонфигурациюПровайдера(АутхПровайдер);
	Результат.УстановитьКонфигурациюПриложения(АутхПриложение);
	Если АутхПрокси <> Неопределено Тогда
		Результат.УстановитьНастройкиПрокси(АутхПрокси);
	КонецЕсли;
	Результат.УстановитьХранилищеСессий(Неопределено);
	Результат.УстановитьОтборСессий(АутхОтборСессий(Результат.СобратьКлючОбъекта()));
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция АутхОтборСессий(Знач КлючОбъекта)
	
	Результат = Новый Структура("КлючОбъекта, КлючНастроек, Пользователь");
	Результат.КлючОбъекта = КлючОбъекта;
	Результат.КлючНастроек = АутхКлючНастройки();
	Результат.Пользователь = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	
	Возврат Новый ФиксированнаяСтруктура(Результат);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция АутхКлючНастройки()
	Возврат "e2714b37-0f4e-492e-dd1c-d01ab55ac000"; // Константа
КонецФункции

// #КонецОбласти Авторизация

// #Область СеансРаботыПользователя

// Запускает инициализацию сеанса пользователя. Если не удалось восстановить
// контекст предыдущего сеанса (его не было, истекло действие авторизационного
// токена и т.п.), открывается форма авторизации.
//
// Параметры:
//  ПриНачалеСеанса - ОписаниеОповещения - обработчик, который будет вызван
//                                         после иницилизации контекста сеанса
//
&НаКлиенте
Процедура Сеанс_Начать(Знач ПриНачалеСеанса) Экспорт
	
	СохраненныеНастройки = СеансСлужебный_НастройкиЯщиков();
	
	Если Не ЗначениеЗаполнено(СохраненныеНастройки) Тогда
		СеансСлужебный_ПоказатьФормуАвторизации("Авторизация", ПриНачалеСеанса);
		Возврат;
	КонецЕсли;
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	Попытка
		ЛокальныеСертификаты = СеансСлужебный_ОписанияСертификатов(СохраненныеНастройки);
	Исключение
		ОшибкаИнфо = ИнформацияОбОшибке();
		Ядро.Ошибка_Обработать("Получить описания сертификатов", ОшибкаИнфо);
		СеансСлужебный_ПоказатьФормуАвторизации("Авторизация", ПриНачалеСеанса);
		Возврат;
	КонецПопытки;
	
	Попытка
		Сессии = СеансСлужебный_Сессии(СохраненныеНастройки);
	Исключение
		ОшибкаИнфо = ИнформацияОбОшибке();
		Ядро.Ошибка_Обработать("Восстановить сессии", ОшибкаИнфо);
		СеансСлужебный_ПоказатьФормуАвторизации("Авторизация", ПриНачалеСеанса);
		Возврат;
	КонецПопытки;
	
	Контекст = Новый Соответствие;
	ЕстьОшибки = Ложь;
	
	Для Каждого НастройкаСеанса Из СохраненныеНастройки Цикл
		
		ИдентификаторЯщика = НастройкаСеанса.ИдентификаторЯщика;
		Сертификат = ЛокальныеСертификаты.Получить(НастройкаСеанса.ОтпечатокСертификата);
		Сессия = Сессии.Получить(НастройкаСеанса.КлючСессии);
		
		Попытка
			
			СтрокаКонтекста = Сеанс_НоваяСтрока(ИдентификаторЯщика, Сессия, Сертификат);
			
		Исключение
			
			ЕстьОшибки = Истина;
			ОшибкаИнфо = ИнформацияОбОшибке();
			Ядро.Ошибка_Обработать("Восстановление контекста", ОшибкаИнфо);
			
			Прервать;
			
		КонецПопытки;
		
		Контекст.Вставить(ИдентификаторЯщика, СтрокаКонтекста);
		
	КонецЦикла;
	
	Если ЕстьОшибки Или Не ЗначениеЗаполнено(Контекст) Тогда
		СеансСлужебный_ПоказатьФормуАвторизации("Авторизация", ПриНачалеСеанса);
	Иначе
		СеансСлужебный_ОбработатьПолучениеКонтекста(Контекст, ПриНачалеСеанса);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция СеансСлужебный_ОписанияСертификатов(СохраненныеНастройки)
	
	Ядро = Модуль_ЯдроНаКлиенте();
	ЛокальныеСертификаты = Новый Соответствие;
	
	Для Каждого НастройкаСеанса Из СохраненныеНастройки Цикл
		
		Отпечаток = НастройкаСеанса.ОтпечатокСертификата;
		Сертификат = ЛокальныеСертификаты.Получить(Отпечаток);
		
		Если ЗначениеЗаполнено(Отпечаток)
			И Не ЗначениеЗаполнено(Сертификат) Тогда
			
			СертификатДанные = Ядро.Сертификаты_ДанныеСертификата(Отпечаток);
			СертификатBase64 = Ядро.Сертификаты_СертификатВBase64(Отпечаток);
			Сертификат = Ядро.Сертификаты_ОписаниеСертификата(СертификатДанные);
			Сертификат.Вставить("Base64", СертификатBase64);
			
			ЛокальныеСертификаты.Вставить(Отпечаток, Сертификат);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЛокальныеСертификаты;
	
КонецФункции

&НаКлиенте
Функция СеансСлужебный_Сессии(СохраненныеНастройки)
	
	Ядро = Модуль_ЯдроНаКлиенте();
	Сессии = Новый Соответствие;
	
	СохраненныеСхемы = Новый Массив;
	Для Каждого НастройкаСеанса Из СохраненныеНастройки Цикл
		Если СохраненныеСхемы.Найти(НастройкаСеанса.СхемаАутентификации) = Неопределено Тогда
			СохраненныеСхемы.Добавить(НастройкаСеанса.СхемаАутентификации);
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(СохраненныеСхемы) Тогда
		Возврат Сессии;
	ИначеЕсли СохраненныеСхемы.Количество() > 1 Тогда
		Ошибка = "Одновременно может использоваться только одна схема аутентификации";
		ВызватьИсключение Ошибка;
	Иначе
		СхемаАутентификации = СохраненныеСхемы[0];
	КонецЕсли;
	
	ДоступныеСхемы = ДоступныеСхемыАутентификации(ЗначенияФункциональныхОпций);
	Если ДоступныеСхемы.Найти(СхемаАутентификации) = Неопределено Тогда
		Ошибка = СтрЗаменить("Схема аутентификации '%1' не поддерживается или отключена по функциональным опциям"
			, "%1", СхемаАутентификации);
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если СхемаАутентификации = СхемаАутентификацииПорталБраузер() Тогда
		
		НастройкаСеанса = СохраненныеНастройки[0];
		Сессия = СеансСлужебный_СессияПортал(НастройкаСеанса);
		Сессии.Вставить(НастройкаСеанса.КлючСессии, Сессия);
		
	Иначе
		
		Для Каждого НастройкаСеанса Из СохраненныеНастройки Цикл
			
			ТребуетсяОбновитьТокенДоступа = СеансСлужебный_СессияИстекает(НастройкаСеанса.ТокенДоступаСрокДействия);
			
			КлючСессии = НастройкаСеанса.КлючСессии;
			
			Если Не ТребуетсяОбновитьТокенДоступа Тогда
				Сессия = Ядро.КонтекстСеанса_ВосстановитьСессию(НастройкаСеанса);
			ИначеЕсли СхемаАутентификации = СхемаАутентификацииДиадокСертификат() Тогда
				Сессия = АвторизацияСлужебный_СессияПоСертификату(НастройкаСеанса.ОтпечатокСертификата);
			Иначе
				Ошибка = СтрЗаменить("Для схемы аутентификации '%1' обновление токена доступа не поддерживается!", "%1", СхемаАутентификации);
				ВызватьИсключение Ошибка;
			КонецЕсли;
			
			Если Сессия.Ключ <> КлючСессии Тогда
				Ошибка = "Изменился ключ сессии, требуется актуализировать контекст сеанса";
				ВызватьИсключение Ошибка;
			КонецЕсли;
			
			Сессии.Вставить(КлючСессии, Сессия);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Сессии;
	
КонецФункции

&НаСервере
Функция СеансСлужебный_СессияПортал(Знач НастройкаСеанса)
	
	Если НастройкаСеанса.ИмяПриложения <> АутхПриложение.Имя Тогда
		Ошибка = "Изменилось имя клиента аутентификации. Требуется актуализировать контекст сеанса.";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	КлючСессии = НастройкаСеанса.КлючСессии;
	Аутх = МодульАутхСлужебныйНаСервере();
	Ядро = Модуль_Ядро();
	
	ПортальнаяСессия = Аутх.ПолучитьСессию();
	Сессия = Ядро.Новый_СессияПорталБраузер(КлючСессии, ПортальнаяСессия);
	
	Возврат Сессия;
	
КонецФункции

// Открывает форму авторизации в режиме выбора ящиков для работы
//
// Параметры:
//  ПриИзмененииКонтекстаСеанса - ОписаниеОповещения - обработчик, который будет вызван
//                                                     после изменения контекста сеанса
//
&НаКлиенте
Процедура Сеанс_РедактироватьКонтекст(Знач ПриИзмененииКонтекстаСеанса) Экспорт
	
	СеансСлужебный_ПоказатьФормуАвторизации("ВыборОрганизаций", ПриИзмененииКонтекстаСеанса);
	
КонецПроцедуры

// Открывает форму авторизации
//
// Параметры:
//  Режим - Строка - "Авторизация" или "ВыборОрганизаций"
//  ПриЗакрытииФормыАвторизации - ОписаниеОповещения - оповещение, которое необходимо вызвать
//                                                     после закрытия формы авторизации.
//
&НаКлиенте
Процедура СеансСлужебный_ПоказатьФормуАвторизации(Знач Режим, Знач ПриЗакрытииФормыАвторизации)
	
	ПараметрыЗакрытияФормы = Новый Структура;
	ПараметрыЗакрытияФормы.Вставить("ПриЗакрытииФормыАвторизации", ПриЗакрытииФормыАвторизации);
	ПараметрыЗакрытияФормы = Новый ФиксированнаяСтруктура(ПараметрыЗакрытияФормы);
	
	ПриЗакрытииФормыАвторизацииСлужебный = НовыйОписаниеОповещения(
		"СеансСлужебныйОбработчик_ПриЗакрытииФормыАвторизации",
		ЭтаФорма,
		ПараметрыЗакрытияФормы
	);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийРежимФормы", Режим);
	ПараметрыФормы.Вставить("ОбщийКонтекстКлиентСервер", Объект.ОбщийКонтекстКлиентСервер);
	
	ОткрытьФормуЛок(
		ПутьКФормам + "АвторизацияУправляемая",
		ПараметрыФормы,
		ЭтаФорма,
		Неопределено,
		Неопределено,
		Неопределено,
		ПриЗакрытииФормыАвторизацииСлужебный,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца
	);
	
КонецПроцедуры

// Конструктор строки контекста сеанса
//
// Параметры:
//  ИдентификаторЯщика - Строка - идентификатор ящика организации
//  Сессия - Структура, ФиксированнаяСтруктура - см. Ядро.МодельСессияПользователя
//  Сертификат - Структура, ФиксированнаяСтруктура - Ядро.Сертификаты_ОписаниеСертификата + двоичка (Base64)
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. Ядро.МодельСтрокаКонтекстаСеанса
//
&НаКлиенте
Функция Сеанс_НоваяСтрока(Знач ИдентификаторЯщика, Знач Сессия, Знач Сертификат) Экспорт
	
	Результат = СеансСлужебный_НоваяСтрокаВызовСервера(ИдентификаторЯщика, Сессия, Сертификат);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция СеансСлужебный_НоваяСтрокаВызовСервера(Знач ИдентификаторЯщика, Знач Сессия, Знач Сертификат)
	
	Ядро = Модуль_Ядро();
	Результат = Ядро.СоздатьСтрокуКонтекстаСеанса(ИдентификаторЯщика, Сессия, Сертификат);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция СеансСлужебный_НастройкиЯщиков()
	
	Ядро = Модуль_Ядро();
	Настройки = Ядро.КонтекстСеанса_СохраненныеНастройки();
	
	Возврат Настройки;
	
КонецФункции

&НаСервереБезКонтекста
Функция СеансСлужебный_СессияИстекает(Знач ТокенДоступаСрокДействия)
	
	ПрогнозируемаяДлительностьСессии = 14400; // 4 часа
	РасчетныйСрокДействия = ТекущаяУниверсальнаяДата() + ПрогнозируемаяДлительностьСессии;
	
	Результат = (ТокенДоступаСрокДействия < РасчетныйСрокДействия);
	
	Возврат Результат;
	
КонецФункции

// Обработчик закрытия формы авторизации
//
// Параметры:
//  ЗаполненныйКонтекст - Соответствие - Информация о доступных ящиках и их настройках
//  ПараметрыЗакрытияФормы - ФиксированнаяСтруктура - содержит ключи:
//   * ПриЗакрытииФормыАвторизации - ОписаниеОповещения - обработчик, который нужно вызвать изменении контекста сеанса
//
&НаКлиенте
Процедура СеансСлужебныйОбработчик_ПриЗакрытииФормыАвторизации(Знач ЗаполненныйКонтекст, Знач ПараметрыЗакрытияФормы = Неопределено) Экспорт
	
	СеансСлужебный_ОбработатьПолучениеКонтекста(ЗаполненныйКонтекст, ПараметрыЗакрытияФормы.ПриЗакрытииФормыАвторизации);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СхемаАутентификацииПорталБраузер()
	Возврат "oidc/device_flow";
КонецФункции

