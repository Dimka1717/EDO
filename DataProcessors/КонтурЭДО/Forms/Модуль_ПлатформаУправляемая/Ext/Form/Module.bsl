		ИмяФормыЯдро = "Обработка.КонтурДиадокСтдСтр.Форма.Клиент";
		Если ПодключатьМодулиИзМакетов Тогда
			ИмяФормыЯдро = "Внешняя" + ИмяФормыЯдро;
		КонецЕсли;
		
		// BSLLS:GetFormMethod-off
		_МодульСтдСтрНаКлиенте = ПолучитьФорму(ИмяФормыЯдро, , ЭтаФорма);
