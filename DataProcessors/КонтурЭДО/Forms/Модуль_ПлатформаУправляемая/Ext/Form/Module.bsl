&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НужноИнициализироватьКонтекст = Не Параметры.Свойство("ОбщийКонтекстКлиентСервер", Объект.ОбщийКонтекстКлиентСервер);
	
	Модуль = ОбработкаОбъект();
	
	Если НужноИнициализироватьКонтекст Тогда
		Модуль.ИнициализироватьОбщийКонтекст(УникальныйИдентификатор);
		Объект.ОбщийКонтекстКлиентСервер = Модуль.ОбщийКонтекстКлиентСервер;
	КонецЕсли;
	
	// BSLLS:UnusedLocalVariable-off
	ИспользуетсяПодсистемаДиадок = Объект.ОбщийКонтекстКлиентСервер.ИспользуетсяПодсистемаДиадок;
	ПутьКФормам = Модуль.Метаданные().ПолноеИмя() + ".Форма.";
	// BSLLS:UnusedLocalVariable-on
	
	ПроверяемыеСвойства = Новый Структура;
	ПроверяемыеСвойства.Вставить("ИспользуемоеИмяФайла");
	ЗаполнитьЗначенияСвойств(ПроверяемыеСвойства, Модуль);
	
	ЭтоВнешняяОбработка = (ПроверяемыеСвойства.ИспользуемоеИмяФайла <> Неопределено);
	ОписаниеЯдра = Объект.ОбщийКонтекстКлиентСервер.ПодключенныеОбработки["КонтурДиадокЯдро"];
	ПодключатьМодулиИзМакетов = (ЭтоВнешняяОбработка Или ОписаниеЯдра.ИсточникБиблиотеки = "Макет");
	
	Ядро = Модуль_Ядро();
	
	Конфиг = Неопределено;
	Если Параметры.Свойство("КонфигурационныйФайл", Конфиг) Тогда
		Ядро.КонфигурационныйФайл_ЗагрузитьПараметры(Конфиг);
	КонецЕсли;
	
	ЗначенияФункциональныхОпций = Ядро.ОбщийКонтекст_Прочитать("ФункциональныеОпции");
	
	// BSLLS:UnusedLocalVariable-off
	АутхПровайдер = Ядро.АутхКонфигурацияПровайдера();
	// BSLLS:UnusedLocalVariable-on
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	// BSLLS:UnusedLocalVariable-off
	АутхПриложение = Ядро.АутхКонфигурацияПриложения();
	АутхПрокси = Ядро.АутхНастройкиПрокси();
	// BSLLS:UnusedLocalVariable-on
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииРаботыМодуля(Знач ПродуктоваяАналитика) Экспорт
	
	Ядро = Модуль_ЯдроНаКлиенте();
	Ядро.Метрики_Отправить();
	
	ПриЗавершенииРаботыМодуляВызовСервера(ПродуктоваяАналитика);
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииРаботыМодуляВызовСервера(Знач ПродуктоваяАналитика)
	
	Модуль = РеквизитФормыВЗначение("Объект");
	Модуль.ПроверитьЗависимости();
	
	Ядро = Модуль_Ядро();
	
	Ядро.ПродуктоваяАналитика_ОтправитьДанныеБезопасно(ПродуктоваяАналитика);
	
	Ядро.Метрика_ДобавитьСтатистику_ИспользованиеПМ();
	
	_ИмяФормы = НазваниеОсновнойФормы();
	_Действие = "Инициализация модуля";
	_Открытие = Ложь;
	Ядро.Метрика_ДобавитьПоведение_ДействиеСФормой(
		_ИмяФормы,
		_Действие,
		_Открытие
	);
	
	Ядро.ЗавершитьРаботуЯдра();
	
	Модуль.ЗавершитьРаботуМодуля();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииРаботыМодуляОткрытогоИзРасширения() Экспорт
	
