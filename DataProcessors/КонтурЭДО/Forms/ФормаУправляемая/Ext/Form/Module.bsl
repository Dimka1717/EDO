&НаСервере
Процедура СформироватьМетрикуДействияПереходаВМодульИзДокумента1С()
	
	Ядро = Модуль_ЯдроНаСервере();
	
	ДействиеМетрики = Ядро.Метрика_НазваниеДействий().ПерейтиВМодуль;
	КатегорияМетрики = Ядро.Метрика_НазваниеКатегории().ДействияИзДокумента1С;
	МеткаМетрики = "Нажать кнопку";
	ПредставлениеМетрики = "Документ1С";
	TraceId = "РаботаИзИнтерфейса1С" + ИсточникОткрытия.УникальныйИдентификатор();
	
	Ядро.Метрика_ДобавитьПоведение(
		КатегорияМетрики,
		ДействиеМетрики,
		МеткаМетрики,
		Неопределено,
		ПредставлениеМетрики,
		TraceId
	);
	
	ДопПеременные = Новый Соответствие;
	ДопПеременные.Вставить("Источник", СокрЛП(ТипЗнч(ИсточникОткрытия)));
	
	ИдентификаторЯщика = Ядро.ДокументыУчета_ИдентификаторЯщикаОрганизацииДокумента(ИсточникОткрытия);
	
	Ядро.Метрика_ДобавитьСтатистику_ДляОрганизации(
		ИдентификаторЯщика,
		КатегорияМетрики,
		ДействиеМетрики,
		Неопределено,
		ДопПеременные,
		ПредставлениеМетрики,
		TraceId
	);
	
КонецПроцедуры

