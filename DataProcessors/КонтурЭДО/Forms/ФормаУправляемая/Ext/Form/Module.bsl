	ПараметрыФормы.Вставить("ОбщийКонтекстКлиентСервер", Объект.ОбщийКонтекстКлиентСервер);
	
	// BSLLS:GetFormMethod-off
	_МодульПлатформа = ПолучитьФорму(ПутьКФормам + "Модуль_ПлатформаУправляемая", ПараметрыФормы, ЭтаФорма);
	// BSLLS:GetFormMethod-on
	
	Возврат _МодульПлатформа;
	
КонецФункции

