Функция ДанныеКонтрагента(Знач ИдентификаторОрганизации, Знач ИденификаторКонтрагента)
	// BSLLS:MissingReturnedValueDescription-on
	// BSLLS:MissingParameterDescription-on
	Модуль_Ядро = Модуль_ЯдроНаСервере();
	
