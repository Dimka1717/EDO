&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	#Если ВебКлиент Тогда
	Если НЕ ОбработкаОбъект().ВозможенЗапускВВебКлиенте() Тогда
		Сообщить("Для работы модуля в веб-клиенте требуется версия платформы 8.3.3.721 или выше");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	#КонецЕсли
	
	ПараметрКонтекстСеанса = Неопределено;
	Параметры.Свойство("КонтекстСеанса", ПараметрКонтекстСеанса);
	
	УстановитьКонтекстФормы(ЭтаФорма, ПараметрКонтекстСеанса);
	УстановитьПредставлениеТекущегоПользователяДиадок(ЭтаФорма);
	
	ИнициализироватьОбщийКонтекстКлиентСерверНаСервере();
	
	ЕстьСистемаХранения = СистемаХраненияОпределена();
	ИспользуетсяПодсистемаДиадок = Объект.ОбщийКонтекстКлиентСервер.ИспользуетсяПодсистемаДиадок;
	
	Модуль = ОбработкаОбъект();
	ПутьКФормам = Модуль.Метаданные().ПолноеИмя() + ".Форма.";
	
	ПроверяемыеСвойства = Новый Структура;
	ПроверяемыеСвойства.Вставить("ИспользуемоеИмяФайла");
	ЗаполнитьЗначенияСвойств(ПроверяемыеСвойства, Модуль);
	
	ЭтоВнешняяОбработка = (ПроверяемыеСвойства.ИспользуемоеИмяФайла <> Неопределено);
	ОписаниеЯдра = Объект.ОбщийКонтекстКлиентСервер.ПодключенныеОбработки["КонтурДиадокЯдро"];
	ПодключатьМодулиИзМакетов = (ЭтоВнешняяОбработка Или ОписаниеЯдра.ИсточникБиблиотеки = "Макет");
	
	ВерсияОбработки = Модуль.ВерсияОбработки();
	ЭтоПервыйЗапуск = (СохраненныеНастройкиГлавнойФормы() = Неопределено);
	
	Ядро = Модуль_ЯдроНаСервере();
	СохраненнаяВерсияПриЗапуске = Ядро.ЗначениеНастройки_СохраненнаяВерсияМодуля();
	СтруктураДанныхСтрокиСпискаСтрокой = Ядро.КолонкиСпискаДокументовСтрокой();
	
	Параметры.Свойство("ИсточникОткрытия", ИсточникОткрытия);
	
	ЗаполнитьФормуИзСохраненныхНастроек();
	ЗаполнитьНастройкиПериодаПриЗапуске();
	УстановитьВидимостьКнопок();
	НастроитьФорму();
	УстановитьЗаголовокФормы();
	УстановитьЗаголовокКнопкиАвторизацииПоУмолчанию();
	ИнициализироватьНастройкуИВидимостьКнопкиЛентыКонтрагентов();
	ИнициализироватьНастройку_НеПоказыватьОнбордингЛентыКонтрагентов();
	
КонецПроцедуры

