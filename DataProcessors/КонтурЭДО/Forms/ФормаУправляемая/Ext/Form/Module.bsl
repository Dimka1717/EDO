&НаСервере
Функция ЗначенияФункциональныхОпций()
	
	Модель = Новый Структура;
	Модель.Вставить("НастройкиГосключ", Ложь);
	
	ЗначенияОпций = Объект.ОбщийКонтекстКлиентСервер.ФункциональныеОпции;
	
	ТипБулево = Тип("Булево");
	
	Значение = ЗначенияОпций.Получить("Sign.GosKeySign");
	Если ЗначениеЗаполнено(Значение) Тогда
		Модель.НастройкиГосключ = XMLЗначение(ТипБулево, Значение);
	КонецЕсли;
	
	Результат = Новый ФиксированнаяСтруктура(Модель);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
