	Результат = Кэш_Прочитать("ФормаПрогресса");
	
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = ПолучитьФормуОбработки("ИндикацияПрогрессаОбработкиДанныхУправляемая", ЭтаФорма);
	Кэш_Поместить("ФормаПрогресса", Результат);
	
	Возврат Результат;
	
КонецФункции

