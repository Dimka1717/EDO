&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИсточникОповещения = ИдентификаторОсновнойФормы();
	
	Если Не ЭтаФорма.Открыта()
		ИЛИ ИсточникОповещения <> Источник Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ИмяСобытия = "Диадок_ОбновитьГлавныйСписок" Тогда
		
		НовыйРежимОтображенияДокументов = Неопределено;
		
		УстановитьЗаголовокФормы();
		
		ОбновитьСписок(
			НовыйРежимОтображенияДокументов,
			Параметр
		);
		
	ИначеЕсли ИмяСобытия = "Диадок_УстановитьПакетВСтрокуГлавногоСписка" Тогда
		
		Если Элементы.СписокДокументов.ТекущиеДанные.Ключ = Параметр.КлючСтроки Тогда
			Элементы.СписокДокументов.ТекущиеДанные.Пакет = Параметр.Пакет;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

