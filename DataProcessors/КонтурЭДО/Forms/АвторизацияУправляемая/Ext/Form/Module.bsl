
&НаСервере
Перем _ОбработкаОбъект;

&НаСервере
Перем _МодульЯдроНаСервере;

&НаКлиенте
Перем _МодульПлатформаНаКлиенте;

////////////////////////////////////////////////////////////////////////////////
// СЕРВИСНЫЕ МЕТОДЫ

&НаСервере
Функция ОбработкаОбъект()
	
	Если _ОбработкаОбъект = Неопределено Тогда
		_ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	КонецЕсли;
	
	Возврат _ОбработкаОбъект;
	
КонецФункции

&НаКлиенте
Функция ОсновнаяФорма() Экспорт
	
	Результат = ВладелецФормы.ОсновнаяФорма();
	
	Возврат Результат;
	
КонецФункции

// Возвращает форму для вызова сервера без контекста вызывающей формы
// 
// Возвращаемое значение:
//  ФормаКлиентскогоПриложения
//
&НаКлиенте
Функция Модуль_Платформа() Экспорт
	
	Если _МодульПлатформаНаКлиенте = Неопределено Тогда
		_МодульПлатформаНаКлиенте = ВладелецФормы.Модуль_Платформа();
	КонецЕсли;
	
	Возврат _МодульПлатформаНаКлиенте;
	
КонецФункции

&НаКлиенте
Функция Модуль_ЯдроНаКлиенте()
	
	Платформа = Модуль_Платформа();
	Результат = Платформа.Модуль_ЯдроНаКлиенте();
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция Модуль_ЯдроНаСервере()
	
	Если _МодульЯдроНаСервере = Неопределено Тогда
		Модуль = ОбработкаОбъект();
		_МодульЯдроНаСервере = Модуль.Модуль_Ядро();
	КонецЕсли;
	
	Возврат _МодульЯдроНаСервере;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗначениеПараметраРежимФормы = Неопределено;
	
	Параметры.Свойство("ОбщийКонтекстКлиентСервер", Объект.ОбщийКонтекстКлиентСервер);
	Параметры.Свойство("ТекущийРежимФормы", ЗначениеПараметраРежимФормы);
	
	Если ЗначениеПараметраРежимФормы = РежимФормыВыборСертификата() Тогда
		ТекущийРежимФормы = РежимФормыВыборСертификата();
	ИначеЕсли Модуль_ЯдроНаСервере().КонтекстСеанса_ЕстьСтроки() Тогда
		ТекущийРежимФормы = РежимФормыВыборОрганизации();
	Иначе
		ТекущийРежимФормы = РежимФормыАвторизация();
	КонецЕсли;
	
	ИнициализироватьРежимыФормы(Параметры);
	ИнициализироватьАдресКартинкиТарифа();
	УстановитьУсловноеОформление();
	УстановитьНачальныеНастройкиФормы();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьАдресКартинкиТарифа()
	
	КартинкаТарифа =  КартинкаТарифСтартовый();
	
	АдресКартинкиТарифа = ПоместитьВоВременноеХранилище(КартинкаТарифа, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Функция ЗначенияФункциональныхОпций()
	
	Модель = Новый Структура;
	Модель.Вставить("СпособВходаСертификат", Истина);
	Модель.Вставить("СпособВходаЛогин", Истина);
	Модель.Вставить("СпособВходаПорталБраузер", Истина);
	
	Ядро = Модуль_ЯдроНаСервере();
	ЗначенияОпций = Ядро.ОбщийКонтекст_Прочитать("ФункциональныеОпции");
	
	ТипБулево = Тип("Булево");
	
	Значение = ЗначенияОпций.Получить("Authorization.Tab.Certificate");
	Если ЗначениеЗаполнено(Значение) Тогда
		Модель.СпособВходаСертификат = XMLЗначение(ТипБулево, Значение);
	КонецЕсли;
	
	Значение = ЗначенияОпций.Получить("Authorization.Tab.Password");
	Если ЗначениеЗаполнено(Значение) Тогда
		Модель.СпособВходаЛогин = XMLЗначение(ТипБулево, Значение);
	КонецЕсли;
	
	Значение = ЗначенияОпций.Получить("Authorization.Tab.Portal");
	Если ЗначениеЗаполнено(Значение) Тогда
		Модель.СпособВходаПорталБраузер = XMLЗначение(ТипБулево, Значение);
	КонецЕсли;
	
	Результат = Новый ФиксированнаяСтруктура(Модель);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ДоступныеСпособыВхода(ЗначенияФО)
	
	Результат = Новый СписокЗначений;
	
	Если ЗначенияФО.СпособВходаПорталБраузер Тогда
		Результат.Добавить(ТипАвторизацииПорталБраузер(), "Портал (через браузер)");
	КонецЕсли;
	
	Если ЗначенияФО.СпособВходаСертификат Тогда
		Результат.Добавить(ТипАвторизацииДиадокСертификат(), "По сертификату");
	КонецЕсли;
	
	Если ЗначенияФО.СпособВходаЛогин Тогда
		Результат.Добавить(ТипАвторизацииДиадокЛогин(), "По паролю");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция КартинкаТарифСтартовый()
	
	МодульОбъекта = ОбработкаОбъект();
	ВсеКартинки = МодульОбъекта.БиблиотекаКартинок();
	
	Возврат ВсеКартинки.ТарифСтартовый;
	
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ТекущийРежимФормы = РежимФормыАвторизация()
		Или ТекущийРежимФормы = РежимФормыВыборОрганизации() Тогда
		ЗаполнитьТаблицуСертификатов();
	КонецЕсли;
	
	ПереключитьРежимФормыПриОткрытии();
	
	Если ТекущийРежимФормы = РежимФормыАвторизация()
		ИЛИ ТекущийРежимФормы = РежимФормыВыборОрганизации() Тогда
		
		НазваниеФормы	 = Метрика_НазваниеФормы();
		Категория		 = Метрика_ВозможныеКатегории().Авторизация;
		Действие		 = Метрика_ВозможныеДействия().ОткрытиеФормы;
		
		ДопПеременные = Новый Соответствие;
		ДопПеременные.Вставить("Количество сертификатов", ТаблицаСертификатов.Количество());
		Метрика_ДобавитьСводноеСобытие(НазваниеФормы, Категория, Действие, "Нажать кнопку", НазваниеФормы, ДопПеременные);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьРежимФормыПриОткрытии()
	
	ПереключитьРежимФормы();
	
	//Если модулю не удается получить доступ к сертификатам, то форма автоматически открывается на закладке “По паролю”
	Если ТекущийРежимФормы = РежимФормыАвторизация()
		И НетДоступаКСертификатам() Тогда
		
		РежимАвторизации = ТипАвторизацииДиадокЛогин();
		ПереключитьРежимФормы();
		
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// Управление режимами формы

&НаСервере
Процедура ИнициализироватьРежимыФормы(ПараметрыФормы)
	
	Если ТекущийРежимФормы = РежимФормыАвторизация() 
		Или ТекущийРежимФормы = РежимФормыВыборОрганизации() Тогда
		
		ЗначенияФО = ЗначенияФункциональныхОпций();
		СпособыВхода = ДоступныеСпособыВхода(ЗначенияФО);
		Логин = НастройкиФормы_ПрочитатьЛогин();
		РежимАвторизации = НастройкиФормы_ПрочитатьСпособВхода(СпособыВхода);
		НастроитьКомандыПереключенияСпособаВхода(СпособыВхода);
		ЗаполнитьПараметрыКонтекстаСеанса();
		ЗаполнитьАктивныеСоединения();
		
	ИначеЕсли ТекущийРежимФормы = РежимФормыВыборСертификата() Тогда
		
		ПараметрыФормы.Свойство("Организация", Организация);
		ПараметрыФормы.Свойство("ОрганизацияBoxId", ОрганизацияBoxId);
		
		ОписанияСертификатов = Неопределено;
		Если ПараметрыФормы.Свойство("ОписанияСертификатов", ОписанияСертификатов)
			И ОписанияСертификатов <> Неопределено Тогда
			
			ТаблицаСертификатов.Очистить();
			Для Каждого ОписаниеСертификата Из ОписанияСертификатов Цикл
				ЗаполнитьЗначенияСвойств(ТаблицаСертификатов.Добавить(), ОписаниеСертификата);
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
		Ошибка = "ValueError: ТекущийРежимФормы = [" + СокрЛП(ТекущийРежимФормы) + "]";
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыКонтекстаСеанса()
	
	Ядро = Модуль_ЯдроНаСервере();
	ТекущиеНастройки = Ядро.КонтекстСеанса_СохраненныеНастройки();
	
	Для Каждого Настройка Из ТекущиеНастройки Цикл
		Запись = НастройкиСеанса.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Настройка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАктивныеСоединения()
	
	Ядро = Модуль_ЯдроНаСервере();
	ТекущийКонтекст = Ядро.КонтекстСеанса_СтрокиКонтекста(Истина);
	
	Буфер = Новый Соответствие;
	
	Для Каждого Элемент Из ТекущийКонтекст Цикл
		
		Сессия = Элемент.Значение.Сессия;
		
		Если Буфер.Получить(Сессия.Ключ) = Неопределено Тогда
			Буфер.Вставить(Сессия.Ключ, Сессия);
		КонецЕсли;
		
	КонецЦикла;
	
	ТекущиеСоединения = Новый ФиксированноеСоответствие(Буфер);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция РежимФормыАвторизация()
	Возврат "Авторизация";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РежимФормыВыборОрганизации()
	Возврат "ВыборОрганизаций";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РежимФормыВыборСертификата()
	Возврат "ВыборСертификата";
КонецФункции

// Видимость элементов и страниц формы в зависимости от ревизита ТекущийРежимФормы
//
&НаКлиенте
Процедура ПереключитьРежимФормы()
	
	Если ТекущийРежимФормы = РежимФормыАвторизация() Тогда
		
		НастроитьФормуРежимАвторизация();
		
	ИначеЕсли ТекущийРежимФормы = РежимФормыВыборОрганизации() Тогда
		
		ЗаполнитьДоступныеОрганизации();
		НастроитьФормуРежимВыборОрганизации();
		
	ИначеЕсли ТекущийРежимФормы = РежимФормыВыборСертификата() Тогда
		
		НастроитьФормуРежимВыборСертификата();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьФормуРежимВыборОрганизации()
	
	ЭтаФорма.Заголовок = "Выбор организации для работы в модуле";
	
	УстановитьКнопкуПоУмолчанию(Элементы.ПриступитьКРаботе);
	
	Элементы.СтраницыДействия.ТекущаяСтраница = Элементы.СтраницаОрганизации;
	Если ЗначениеЗаполнено(ДоступныеОрганизации) Тогда
		Элементы.ГруппаОрганизации.ТекущаяСтраница = Элементы.СтраницаДоступныеОрганизации;
	Иначе
		Элементы.ГруппаОрганизации.ТекущаяСтраница = Элементы.СтраницаНетОрганизаций;
	КонецЕсли;
	
	НастроитьКолонкиСертификатаВТаблицеОрганизаций();
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьКолонкиСертификатаВТаблицеОрганизаций()
	
	ВидимостьКолонок = (ТаблицаСертификатов.Количество() > 0);
	
	Элементы.ГруппаДанныеСертификата.Видимость							 = ВидимостьКолонок;
	Элементы.ДоступныеОрганизацииКартинкаСертификат.Видимость			 = ВидимостьКолонок;
	Элементы.ДоступныеОрганизацииНаименованиеСертификата.Видимость		 = ВидимостьКолонок;
	Элементы.ДоступныеОрганизацииОписаниеСертификата.Видимость			 = ВидимостьКолонок;
	Элементы.ДоступныеОрганизацииКартинкаИзменитьСертификат.Видимость	 = ВидимостьКолонок;
	Элементы.ДоступныеОрганизацииРедактированиеСертификата.Видимость	 = ВидимостьКолонок;
	
	Если ВидимостьКолонок Тогда
		ЗначениеФиксации = ФиксацияВТаблице.Лево;
	Иначе
		ЗначениеФиксации = ФиксацияВТаблице.Нет;
	КонецЕсли; 
	
	Элементы.ГруппаДанныеОрганизации.ФиксацияВТаблице			 = ЗначениеФиксации;
	Элементы.ДоступныеОрганизацииНаименование.ФиксацияВТаблице	 = ЗначениеФиксации;
	Элементы.ДоступныеОрганизацииИНН_КПП.ФиксацияВТаблице		 = ЗначениеФиксации;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьФормуРежимАвторизация()
	
	Если РежимАвторизации = ТипАвторизацииДиадокСертификат() Тогда
		
		Если ТаблицаСертификатов.Количество() = 0 Тогда
			Элементы.РежимыАвторизации.ТекущаяСтраница = Элементы.СтраницаВходПоСертификатуНедоступен;
		Иначе
			Элементы.РежимыАвторизации.ТекущаяСтраница = Элементы.СтраницаВходПоСертификату;
		КонецЕсли;
		
		Элементы.Декорация_НетСертификата.Видимость = Истина;
		Элементы.ЗавершитьСессию.Видимость = Ложь;
		
	ИначеЕсли РежимАвторизации = ТипАвторизацииДиадокЛогин() Тогда
		
		Элементы.РежимыАвторизации.ТекущаяСтраница = Элементы.СтраницаВходПоЛогину;
		Элементы.Декорация_НетСертификата.Видимость = Ложь;
		Элементы.ЗавершитьСессию.Видимость = Ложь;
		
	ИначеЕсли РежимАвторизации = ТипАвторизацииПорталБраузер() Тогда
		
		СессияАктивна = ЕстьАктивнаяПортальнаяСессия(ТекущиеСоединения);
		ТекстВходЧерезПортал = "Нажмите кнопку ""Авторизоваться"" для перехода на страницу портала в браузере.";
		Если СессияАктивна Тогда
			ТекстВходЧерезПортал = "Авторизация уже пройдена. Для смены пользователя завершите предыдущую сессию.";
		КонецЕсли;
		
		Элементы.РежимыАвторизации.ТекущаяСтраница = Элементы.СтраницаВходЧерезПортал;
		Элементы.Декорация_НетСертификата.Видимость = Ложь;
		Элементы.ЗавершитьСессию.Видимость = СессияАктивна;
		Элементы.НадписьВходЧерезПортал.Заголовок = ТекстВходЧерезПортал;
		
	Иначе
		ВызватьИсключение "ValueError: РежимАвторизации = [" + СокрЛП(РежимАвторизации) + "]";
	КонецЕсли;
	
	ЭтаФорма.Заголовок = "Авторизация";
	
	УстановитьКнопкуПоУмолчанию(Элементы.Авторизоваться);
	
	Элементы.Декорация_НетСертификата.Видимость = (РежимАвторизации = ТипАвторизацииДиадокСертификат());
	Элементы.СтраницыДействия.ТекущаяСтраница = Элементы.СтраницаАвторизация;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЕстьАктивнаяПортальнаяСессия(Знач Сессии)
	
	Результат = Ложь;
	
	Для Каждого Элемент Из Сессии Цикл
		
		Если Элемент.Значение.ЭтоПортальнаяСессия Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура НастроитьФормуРежимВыборСертификата()
	
	ЭтаФорма.Заголовок = "Выбор сертификата";
	
	УстановитьКнопкуПоУмолчанию(Элементы.СохранитьВыборСертификата);

	Элементы.ПереключениеРежимаВхода.Видимость					 = Ложь;
	Элементы.ГруппаДействияСтраницаАвторизация.Видимость		 = Ложь;
	Элементы.ГруппаДействияСтраницаАвторизацияВыбор.Видимость	 = Истина;
	
	Элементы.ДекорацияВыборСертификата.Видимость	 = Истина;
	Элементы.ДекорацияВыборСертификата.Заголовок	 = "Выберите сертификат для авторизации " + Организация;
	
	Элементы.СтраницыДействия.ТекущаяСтраница = Элементы.СтраницаАвторизация;
	
	Элементы.ГруппаДанныеСертификата.Видимость = (РежимАвторизации = ТипАвторизацииДиадокСертификат());

КонецПроцедуры

&НаКлиенте
Процедура УстановитьКнопкуПоУмолчанию(ЭлементКнопки)
	
	ШрифтКнопки = Новый Шрифт(ЭлементКнопки.Шрифт, , , Ложь);
	ЭлементКнопки.КнопкаПоУмолчанию	 = Истина;
	ЭлементКнопки.Шрифт				 = ШрифтКнопки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВариантИнтерфейсаКлиентскогоПриложения()
	
	ВариантыИнтерфейса	 = ВозможныеВариантыИнтерфейсаКлиентскогоПриложения();
	Результат			 = ВариантыИнтерфейса.Такси;
	Настройки			 = ХранилищеСистемныхНастроек.Загрузить("Общее/НастройкиКлиентскогоПриложения");
	Если Настройки <> Неопределено Тогда
		
		Если Строка(Настройки.ВариантИнтерфейсаКлиентскогоПриложения) = ВариантыИнтерфейса.Версия8_2 Тогда
			Результат = ВариантыИнтерфейса.Версия8_2;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ВозможныеВариантыИнтерфейсаКлиентскогоПриложения()

	Результат = Новый Структура;
	Результат.Вставить("Такси"		, "Такси");
	Результат.Вставить("Версия8_2"	, "Версия 8.2");
	
	Возврат Результат;
	
КонецФункции 
 

////////////////////////////////////////////////////////////////////////////////
// Настройки

&НаСервере
Процедура УстановитьНачальныеНастройкиФормы()
	
	ПодсказкаВводаЛогин = Новый Структура("ПодсказкаВвода", "Электронная почта");
	ЗаполнитьЗначенияСвойств(Элементы.Логин, ПодсказкаВводаЛогин);
	
	ПодсказкаВводаПароль = Новый Структура("ПодсказкаВвода", "Пароль");
	ЗаполнитьЗначенияСвойств(Элементы.Пароль, ПодсказкаВводаПароль);
	
	Если НЕ ОбработкаОбъект().ПриложениеСтаршеВерсии("8.3.7") Тогда
		Элементы.НетСертификатовПодробности.АвтоМаксимальнаяШирина = Ложь;
	КонецЕсли;
	
	Если НЕ ОбработкаОбъект().ПриложениеСтаршеВерсии("8.3.3") Тогда
		
		ВариантыИнтерфейса			 = ВозможныеВариантыИнтерфейсаКлиентскогоПриложения();
		ТекущийВариантИнтерфейса	 = ВариантИнтерфейсаКлиентскогоПриложения();
		
		Если ТекущийВариантИнтерфейса = ВариантыИнтерфейса.Версия8_2 Тогда
			УстановитьЦветРамкиТаблицФормы();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение		 = Новый ПолеКомпоновкиДанных("ТаблицаСертификатов.ОшибкаАвторизации"); 
	ЭлементОтбора.ВидСравнения		 = ВидСравненияКомпоновкиДанных.Равно; 
	ЭлементОтбора.ПравоеЗначение	 = Истина;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(220, 20, 60));
	
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ТаблицаСертификатовВыбран");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ТаблицаСертификатовПредставление");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ТаблицаСертификатовНаименование");
	
	Если НЕ ОбработкаОбъект().ПриложениеСтаршеВерсии("8.3.3") Тогда
		Элементы.Декорация_ГоризонтальнаяЛиния.ЦветРамки = Новый Цвет(240, 240, 240);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЦветРамкиТаблицФормы()
	
	Цвет = Новый Цвет();
	Элементы.ТаблицаСертификатов.ЦветРамки	 = Цвет;
	Элементы.ДоступныеОрганизации.ЦветРамки	 = Цвет;
	
КонецПроцедуры

// Возвращает логин пользователя, сохраненный в настройках
//
// Возвращаемое значение:
//  Строка
//
&НаСервереБезКонтекста
Функция НастройкиФормы_ПрочитатьЛогин()
	
	Результат = "";
	
	Значение = ХранилищеНастроекДанныхФорм.Загрузить("Диадок", "Логин");
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Результат = СокрЛП(Значение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция НастройкиФормы_ПрочитатьСпособВхода(СпособыВхода)
	
	Результат = ХранилищеНастроекДанныхФорм.Загрузить("Диадок", "СпособВхода");
	Если СпособыВхода.НайтиПоЗначению(Результат) = Неопределено Тогда
		// Например, способ входа, использовавшийся ранее, отключили функциональными опциями
		Результат = СпособыВхода[0].Значение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Процедура НастройкиФормы_Записать(Логин, СпособВхода)
	
	КлючОбъекта = "Диадок";
	ХранилищеНастроекДанныхФорм.Сохранить(КлючОбъекта, "Логин", Логин);
	ХранилищеНастроекДанныхФорм.Сохранить(КлючОбъекта, "СпособВхода", СпособВхода);
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// Авторизация

&НаСервере
Процедура НастроитьКомандыПереключенияСпособаВхода(СпособыВхода)
	
	ТекущиеКоманды = Элементы.ПереключениеРежимаВхода.СписокВыбора;
	ТекущиеКоманды.Очистить();
	
	Для Каждого Элемент Из СпособыВхода Цикл
		ТекущиеКоманды.Добавить(Элемент.Значение, Элемент.Представление);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ТипАвторизацииДиадокСертификат()
	Возврат "Сертификат";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТипАвторизацииДиадокЛогин()
	Возврат "Логин";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТипАвторизацииПорталБраузер()
	Возврат "Портал";
КонецФункции

&НаКлиенте
Процедура КомандаАвторизоваться(Команда)
	
	Метрика_НачатьПолучениеСессий(Команда);
	Авторизоваться();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаЗавершитьСессию(Команда)
	
	Метрика_ЗавершитьСессии(Команда);
	ЗавершитьСессию();
	ПереключитьРежимФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьСессию()
	
	Платформа = Модуль_Платформа();
	
	Для Каждого Элемент Из ТекущиеСоединения Цикл
		
		Сессия = Элемент.Значение;
		
		Если Сессия.ЭтоПортальнаяСессия Тогда
			Платформа.Авторизация_СброситьПортальнуюСессию();
		КонецЕсли;
		
		Метрика_ЗакрытаСессия(Сессия);
		
	КонецЦикла;
	
	ЗакрытьАктивныеСоединения();
	
КонецПроцедуры

&НаКлиенте
Процедура Авторизоваться()
	
	ЗакрытьАктивныеСоединения();
	ДоступныеОрганизации.Очистить();
	
	ПараметрыПолученияСессии = Новый Структура;
	ПараметрыПолученияСессии.Вставить("РежимАвторизации", РежимАвторизации);
	
	Платформа = Модуль_Платформа();
	ПриПолученииСессии = Платформа.НовыйОписаниеОповещения(
		"Обработчик_ПриПолученииСессии",
		ЭтаФорма,
		ПараметрыПолученияСессии
	);
	
	Если РежимАвторизации = ТипАвторизацииДиадокСертификат() Тогда
		
		НачатьПолучениеСессийПоСертификатам(ПриПолученииСессии);
		
	ИначеЕсли РежимАвторизации = ТипАвторизацииДиадокЛогин() Тогда
		
		НачатьПолучениеСессииПоЛогину(ПриПолученииСессии);
		
	ИначеЕсли РежимАвторизации = ТипАвторизацииПорталБраузер() Тогда
		
		НачатьПолучениеСессииЧерезБраузер(ПриПолученииСессии);
		
	Иначе
		ВызватьИсключение "ValueError: РежимАвторизации = [" + СокрЛП(РежимАвторизации) + "]";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Обработчик_ПриПолученииСессии(СессияИлиМассив, ПараметрыПолученияСессии) Экспорт
	
	Если Не ЗначениеЗаполнено(СессияИлиМассив) Тогда
		Возврат;
	КонецЕсли;
	
	ТипПараметра = ТипЗнч(СессияИлиМассив);
	Если ТипПараметра = Тип("Массив") Или ТипПараметра = Тип("ФиксированныйМассив") Тогда
		ПолученныеСессии = СессияИлиМассив;
	Иначе
		ПолученныеСессии = Новый Массив;
		ПолученныеСессии.Добавить(СессияИлиМассив);
	КонецЕсли;
	
	Буфер = Новый Соответствие;
	Для Каждого Сессия Из ПолученныеСессии Цикл
		Буфер.Вставить(Сессия.Ключ, Сессия);
		Метрика_ПолученаСессия(Сессия);
	КонецЦикла;
	
	ТекущиеСоединения = Новый ФиксированноеСоответствие(Буфер);
	
	ТекущийРежимФормы = РежимФормыВыборОрганизации();
	ПереключитьРежимФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПолучениеСессииПоЛогину(ПриПолученииСессии)
	
	АвторизацияВозможна = Истина;
	
	Если НЕ ЗначениеЗаполнено(Логин) Тогда
		Метрика_ЗаписатьОшибку("Логин не заполнен", Метрика_ВозможныеКатегории().ПоЛогину, Метрика_ВозможныеДействия().Авторизоваться, "НеЗаполненоПоле");
		АвторизацияВозможна = Ложь;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Пароль) Тогда
		Метрика_ЗаписатьОшибку("Пароль не заполнен", Метрика_ВозможныеКатегории().ПоЛогину, Метрика_ВозможныеДействия().Авторизоваться, "НеЗаполненоПоле");
		АвторизацияВозможна = Ложь;
	КонецЕсли;
	
	Если Не АвторизацияВозможна Тогда
		
		мПоказатьПредупреждение(
			"Введите электронную почту и пароль
			|для авторизации"
		);
		
		Возврат;
		
	КонецЕсли;
	
	Отказ = Ложь;
	Платформа = Модуль_Платформа();
	
	Попытка
		
		Сессия = Платформа.Авторизация_СессияПоЛогину(Логин, Пароль);
		
	Исключение
		
		Отказ = Истина;
		ОшибкаИнфо = ИнформацияОбОшибке();
		
		ДопПеременные = Новый Соответствие;
		ДопПеременные.Вставить("ТипАвторизации", ТипАвторизацииДиадокЛогин());
		
		Если ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаНеверныйКлючАПИ()) Тогда
			
			ПоказатьОшибкуНевалидныйКлючАПИ();
			
			ДопПеременные.Вставить("ИдентификаторОшибки", "НекорректныйКлючАпи");
			ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
			
		ИначеЕсли ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаНеверныйЛогинПароль()) Тогда
			
			ТекстОшибки = НСтр("ru = 'Не удалось авторизоваться.
			|Проверьте электронную почту и пароль'");
			мПоказатьПредупреждение(ТекстОшибки);
			
			ДопПеременные.Вставить("ИдентификаторОшибки", "НеУдалосьАвторизоваться");
			ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
			
		Иначе
			
			ДопПеременные.Вставить("ИдентификаторОшибки", "НеизвестнаяОшибка");
			ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
			
			ВызватьИсключение;
			
		КонецЕсли;
		
	КонецПопытки;
	
	Если Не Отказ Тогда
		Платформа.ВыполнитьОбработкуОповещенияЛок(ПриПолученииСессии, Сессия);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПолучениеСессийПоСертификатам(ПриПолученииСессии)
	
	Для Каждого Запись Из ТаблицаСертификатов Цикл
		Запись.ОшибкаАвторизации = Ложь;
		Запись.Авторизован = Ложь;
	КонецЦикла;
	
	ВыбранныеСтроки = ТаблицаСертификатов.НайтиСтроки(Новый Структура("Выбран", Истина));
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
		
		ТекстОшибки = "Выберите сертификат для авторизации.";
		Категория = Метрика_ВозможныеКатегории().ПоСертификату;
		Действие = Метрика_ВозможныеДействия().Авторизоваться;
		Метрика_ЗаписатьОшибку(ТекстОшибки, Категория, Действие, "НеВыбранСертификат");
		мПоказатьПредупреждение(ТекстОшибки);
		
		Возврат;
		
	КонецЕсли;
	
	ЕстьУстаревшиеСертификаты = ПроверитьСертификатыНаУстаревшийГОСТ(ВыбранныеСтроки);
	
	Если ЕстьУстаревшиеСертификаты Тогда
		
		ТекстОшибки = 
		"Сертификаты устарели. Обновите их на
		|ГОСТ-2012 через сервисный центр.";
		Категория = Метрика_ВозможныеКатегории().ПоСертификату;
		Действие = Метрика_ВозможныеДействия().Авторизоваться;
		Метрика_ЗаписатьОшибку(ТекстОшибки, Категория, Действие, "УстаревшийГост");
		мПоказатьПредупреждение(ТекстОшибки);
		
		Возврат;
		
	КонецЕсли;
	
	Платформа = Модуль_Платформа();
	
	Отказ = Ложь;
	ПолученныеСессии = Новый Массив;
	
	Для Каждого Запись Из ВыбранныеСтроки Цикл
		
		Если Отказ Тогда
			Прервать;
		КонецЕсли;
		
		Отпечаток = Запись.ОтпечатокСертификата;
		
		Попытка
			
			Сессия = Платформа.Авторизация_СессияПоСертификату(Отпечаток);
			ПолученныеСессии.Добавить(Сессия);
			
		Исключение
			
			Отказ = Истина;
			ОшибкаИнфо = ИнформацияОбОшибке();
			
			ДопПеременные = Новый Соответствие;
			ДопПеременные.Вставить("ТипАвторизации", ТипАвторизацииДиадокСертификат());
			
			Если ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаНеверныйКлючАПИ()) Тогда
				
				ПоказатьОшибкуНевалидныйКлючАПИ();
				
				ДопПеременные.Вставить("ИдентификаторОшибки", "НекорректныйКлючАпи");
				ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
				
			ИначеЕсли ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаСертификатНеАвторизован()) Тогда
				
				ТекстОшибки = 
				"По сертификату нет доступа в Диадок:
				|- отпечаток %1
				|- выдан %2
				|
				|Попробуйте авторизоваться в веб-версии, следуя подсказкам сервиса.
				|Если авторизация в веб-версии не помогла, обратитесь в поддержку.";
				
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%1", Отпечаток);
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%2", Запись.Наименование);
				
				мПоказатьПредупреждение(ТекстОшибки);
				
				ДопПеременные.Вставить("ИдентификаторОшибки", "НетДоступа");
				ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
				
			ИначеЕсли ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаКриптоПользовательНеВвелПинкод()) Тогда
				
				ТекстОшибки = 
				"Ошибка доступа к контейнеру сертификата:
				|- отпечаток %1
				|- выдан %2
				|
				|Необходимо ввести PIN-код.";
				
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%1", Отпечаток);
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%2", Запись.Наименование);
				
				мПоказатьПредупреждение(ТекстОшибки);
				
				ДопПеременные.Вставить("ИдентификаторОшибки", "ПользовательОтказалсяОтВводаПинкода");
				ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
				
			Иначе
				
				ДопПеременные.Вставить("ИдентификаторОшибки", "НеизвестнаяОшибка");
				ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
				
				ВызватьИсключение;
				
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если Не Отказ Тогда
		Платформа.ВыполнитьОбработкуОповещенияЛок(ПриПолученииСессии, ПолученныеСессии);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПолучениеСессииЧерезБраузер(ПриПолученииСессии)
	
	Платформа = Модуль_Платформа();
	
	Попытка
		
		Платформа.Авторизация_НачатьПолучениеСессииЧерезБраузер(ПриПолученииСессии);
		
	Исключение
		
		ОшибкаИнфо = ИнформацияОбОшибке();
		
		ДопПеременные = Новый Соответствие;
		ДопПеременные.Вставить("ТипАвторизации", ТипАвторизацииПорталБраузер());
		
		Если ЯвляетсяОшибкойКатегории(ОшибкаИнфо, ОшибкаНеверныйКлючАПИ()) Тогда
			
			ПоказатьОшибкуНевалидныйКлючАПИ();
			
			ДопПеременные.Вставить("ИдентификаторОшибки", "НекорректныйКлючАпи");
			ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
			
		Иначе
			
			ДопПеременные.Вставить("ИдентификаторОшибки", "НеизвестнаяОшибка");
			ОбработатьОшибкуПолученияСессииВызовСервера(ОшибкаИнфо, ДопПеременные);
			
			ВызватьИсключение;
			
		КонецЕсли;
		
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОшибкуПолученияСессииВызовСервера(Знач ОшибкаИнфо, Знач ДопПеременные)
	
	КатегорияМетрики = "Авторизация";
	ДействиеМетрики = "ПолучитьСессию";
	
	Ядро = Модуль_ЯдроНаСервере();
	Ядро.Метрика_ДобавитьОшибку(КатегорияМетрики, ДействиеМетрики, ОшибкаИнфо, ДопПеременные);
	Ядро.Ошибка_Обработать("Авторизация", ОшибкаИнфо);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЯвляетсяОшибкойКатегории(Знач Ошибка, Знач Категория)
	
	Если Категория = ОшибкаСертификатНеАвторизован() Тогда
		Результат = ЭтоОшибкаСертификатНеАвторизован(Ошибка);
	ИначеЕсли Категория = ОшибкаНеверныйКлючАПИ() Тогда
		Результат = ЭтоОшибкаНеверныйКлючАПИ(Ошибка);
	ИначеЕсли Категория = ОшибкаНеверныйЛогинПароль() Тогда
		Результат = ЭтоОшибкаНеверныйЛогинПароль(Ошибка);
	ИначеЕсли Категория = ОшибкаКриптоПользовательНеВвелПинкод() Тогда
		Результат = ЭтоОшибкаКриптоПользовательНеВвелПинкод(Ошибка);
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоОшибкаСертификатНеАвторизован(Знач Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	// HTTP-ответ с ошибкой вида "401 Certificate with thumbprint <ОТПЕЧАТОК> is not authorized"
	Результат = (Найти(ТекстОшибки, "401") И Найти(ТекстОшибки, "certificate with thumbprint") И Найти(ТекстОшибки, "is not authorized"));
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоОшибкаНеверныйКлючАПИ(Знач Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	Результат = (Найти(ТекстОшибки, "invalid api client id") > 0);
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоОшибкаНеверныйЛогинПароль(Знач Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	// HTTP-ответ с ошибкой вида "401 Wrong password provided for login <user@mail>"
	Результат = (Найти(ТекстОшибки, "401") И Найти(ТекстОшибки, "wrong password provided for login"));
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоОшибкаКриптоПользовательНеВвелПинкод(Знач Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	// Источник ошибки - библиотека CRYPTOAPI
	// Десятичный код ошибки - 2148532334
	// Шестнадцатиричный код ошибки - 0x8010006E
	Результат = Найти(ТекстОшибки, НРег("CRYPTOAPI[0x8010006E]")) > 0;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОшибкаНеверныйКлючАПИ()
	Возврат "InvalidAPIKey";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОшибкаНеверныйЛогинПароль()
	Возврат "InvalidLoginOrPassword";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОшибкаСертификатНеАвторизован()
	Возврат "CertIsNotAuthorized";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОшибкаКриптоПользовательНеВвелПинкод()
	Возврат "CRYPTOAPI[0x8010006E]";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОшибкаНеизвестная()
	Возврат "НеизвестнаяОшибка";
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// Соеднинения

&НаКлиенте
Процедура ПоказатьОшибкуНевалидныйКлючАПИ()
	
	Платформа = Модуль_Платформа();
	
	ДополнительныеПараметры = Новый Структура;
	
	ОповещениеОЗакрытииФормыОшибок = Платформа.НовыйОписаниеОповещения(
			"ОповещениеОЗакрытииФормыОшибкиКлючаАПИ",
			ЭтаФорма, 
			ДополнительныеПараметры);
	
	ТекстОшибки = НСтр(
		"ru = 'Версия модуля устарела. Требуется обновление.
		|Для продолжения работы скачайте и установите новую
		|версию по кнопке ниже.'"
	);
	
	КнопкаПоУмолчанию = КодВозвратаДиалога.ОК;
	
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КнопкаПоУмолчанию, "Скачать обновление модуля");
	СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Закрыть");
	
	мПоказатьВопрос(ТекстОшибки, СписокКнопок, , КнопкаПоУмолчанию, "", , ОповещениеОЗакрытииФормыОшибок);
	
КонецПроцедуры

&НаКлиенте
Процедура ОповещениеОЗакрытииФормыОшибкиКлючаАПИ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.ОК Тогда
		Возврат;
	КонецЕсли;
	
	Метрика_ПриНажатииКнопкиСкачатьНовуюВерсию();
	
	ГлавнаяФорма = ОсновнаяФорма();
	ГлавнаяФорма.ОткрытьФормуОбновления();
	
	Метрика_ЗаписатьСтатистикуСкачатьОбновлениеМодуля();
	
КонецПроцедуры

&НаКлиенте
Процедура Метрика_ПриНажатииКнопкиСкачатьНовуюВерсию()
	
	НазваниеФормы = "КлючАпиНеДействителен";
	Категория = Метрика_ВозможныеКатегории().НекорректныйКлючАпи;
	Действие = Метрика_ВозможныеДействия().СкачатьОбновлениеМодуля;
	Метка = "Нажатие кнопки";
	
	Модуль_ЯдроНаКлиенте().Метрика_ДобавитьПоведение_НажатиеКнопки(НазваниеФормы, Категория, Действие, Метка);
	
КонецПроцедуры

&НаКлиенте
Процедура Метрика_ЗаписатьСтатистикуСкачатьОбновлениеМодуля()
	
	Категория = Метрика_ВозможныеКатегории().НекорректныйКлючАпи;
	Действие = Метрика_ВозможныеДействия().СкачатьОбновлениеМодуля;
	
	Модуль_ЯдроНаКлиенте().Метрика_ДобавитьСтатистику_СУчетомЗаполненияКонтекста(Категория, Действие);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьАктивныеСоединения()
	
	ТекущиеСоединения = Новый ФиксированноеСоответствие(Новый Соответствие);
	
КонецПроцедуры

