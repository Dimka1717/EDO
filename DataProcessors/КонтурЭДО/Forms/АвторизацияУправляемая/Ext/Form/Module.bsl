&НаКлиенте
Процедура Метрика_ПриступитьКРаботе(Команда)
	
	Переменные = Новый Соответствие;
	
	ВыбранныеОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("Использовать", Истина));
	
	УникальныеСессии = Новый Массив;
	УникальныеОтпечатки = Новый Массив;
	УникальныеПользователи = Новый Массив;
	
	Для Каждого Запись Из ВыбранныеОрганизации Цикл
		
		Сессия = ТекущиеСоединения.Получить(Запись.КлючСессии);
		
		Переменные.Вставить(Сессия.СхемаАутентификации, Истина);
		
		Если УникальныеСессии.Найти(Сессия.Ключ) = Неопределено Тогда
			УникальныеСессии.Добавить(Сессия.Ключ);
		КонецЕсли;
		
		Если УникальныеПользователи.Найти(Сессия.Пользователь.Идентификатор) = Неопределено Тогда
			УникальныеПользователи.Добавить(Сессия.Пользователь.Идентификатор);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Запись.ОтпечатокСертификата)
			И УникальныеОтпечатки.Найти(Запись.ОтпечатокСертификата) = Неопределено Тогда
			УникальныеОтпечатки.Добавить(Запись.ОтпечатокСертификата);
		КонецЕсли;
		
	КонецЦикла;
	
	Переменные.Вставить("КоличествоЯщиков", ВыбранныеОрганизации.Количество());
	Переменные.Вставить("КоличествоСессий", УникальныеСессии.Количество());
	Переменные.Вставить("КоличествоСертификатов", УникальныеОтпечатки.Количество());
	Переменные.Вставить("КоличествоПользователей", УникальныеПользователи.Количество());
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	Категория = Ядро.Метрика_НазваниеКатегории().Авторизация;
	Действие = Команда.Имя;
	Метка = "";
	
	Ядро.Метрика_ДобавитьПоведение(Категория, Действие, Метка, Переменные, ИмяФормы);
	
КонецПроцедуры

