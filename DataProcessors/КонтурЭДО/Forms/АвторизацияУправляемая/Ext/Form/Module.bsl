&НаКлиенте
Процедура КомандаПриступитьКРаботе(Команда)
	
	Метрика_ПриступитьКРаботе(Команда);
	ПриступитьКРаботе();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриступитьКРаботе()
	
	ОрганизацииДляВхода = ДоступныеОрганизации.НайтиСтроки(Новый Структура("Использовать", Истина));
	
	Если Не ЗначениеЗаполнено(ОрганизацииДляВхода) Тогда
		
		мПоказатьПредупреждение("Не выбрано ни одной организации для работы");
		Метрика_ПриступитьКРаботе_НеВыбранаОрганизация();
		Возврат;
		
	КонецЕсли;
	
	Если Не ОрганизацииИмеютОдинаковыйТариф(ОрганизацииДляВхода) Тогда
		
		ТекстОшибки = НСтр("ru='Вы попытались авторизоваться под организациями с разными
								|тарифными планами. Одновременное использование тарифов
								|""Стартовый"" и ""Универсальный"" невозможно.
								|Выберите организации, которые используют один тариф.'");
		
		мПоказатьПредупреждение(ТекстОшибки);
		Метрика_ПриступитьКРаботе_ВыбраныРазныеТарифы();
		Возврат;
		
	КонецЕсли;
	
	ЕстьЯщикиССертификатом = Ложь;
	Для Каждого Запись Из ОрганизацииДляВхода Цикл
		Если ЗначениеЗаполнено(Запись.ОтпечатокСертификата) Тогда
			ЕстьЯщикиССертификатом = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если РежимАвторизации = ТипАвторизацииДиадокСертификат()
		Или ЕстьЯщикиССертификатом Тогда
		
		ЯщикиБезСертификата = Новый Массив;
		
		Для Каждого Запись Из ОрганизацииДляВхода Цикл
			
			Если ЗначениеЗаполнено(Запись.ОтпечатокСертификата) Тогда
				Продолжить;
			КонецЕсли;
			
			ЯщикиБезСертификата.Добавить(Запись.BoxId);
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЯщикиБезСертификата) Тогда
			
			ТекстОшибки = "Выберите сертификат для каждой организации.";
			мПоказатьПредупреждение(ТекстОшибки);
			Метрика_ПриступитьКРаботе_НеУказанСертификат(ЯщикиБезСертификата);
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Платформа = Модуль_Платформа();
	КлиентскиеСертификаты = ОписанияВыбранныхСертификатов();
	
	ЗаполненныйКонтекст = Новый Соответствие;
	
	Для Каждого Запись Из ОрганизацииДляВхода Цикл
		
		АдресЯщика = Запись.BoxId;
		Соединение = ТекущиеСоединения.Получить(Запись.КлючСессии);
		Сертификат = КлиентскиеСертификаты.Получить(Запись.ОтпечатокСертификата);
		СтрокаКонтекста = Платформа.Сеанс_НоваяСтрока(АдресЯщика, Соединение, Сертификат);
		
		ЗаполненныйКонтекст.Вставить(АдресЯщика, СтрокаКонтекста);
		
	КонецЦикла;
	
	НастройкиФормы_Записать(Логин, РежимАвторизации);
	
	Закрыть(ЗаполненныйКонтекст);
	
КонецПроцедуры

&НаКлиенте
Функция ОписанияВыбранныхСертификатов()
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	Результат = Новый Соответствие;
	
	ОрганизацииДляВхода = ДоступныеОрганизации.НайтиСтроки(Новый Структура("Использовать", Истина));
	
	Для Каждого Запись Из ОрганизацииДляВхода Цикл
		
		ОтпечатокСертификата = Запись.ОтпечатокСертификата;
		Если Не ЗначениеЗаполнено(ОтпечатокСертификата)
			Или Результат.Получить(ОтпечатокСертификата) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СертификатДанные = Ядро.Сертификаты_ДанныеСертификата(ОтпечатокСертификата);
		СертификатBase64 = Ядро.Сертификаты_СертификатВBase64(ОтпечатокСертификата);
		СертификатОписание = Ядро.Сертификаты_ОписаниеСертификата(СертификатДанные);
		СертификатОписание.Вставить("Base64", СертификатBase64);
		
		Результат.Вставить(ОтпечатокСертификата, СертификатОписание);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОрганизацииИмеютОдинаковыйТариф(ОрганизацииДляВхода)
	
	Тарифы = Новый Соответствие;
	
	Для Каждого Запись Из ОрганизацииДляВхода Цикл
		Тарифы.Вставить(Запись.Тариф, Истина);
	КонецЦикла;
	
	Результат = (Тарифы.Количество() <= 1);
	
	Возврат Результат;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ДЕКОРАЦИИ ФОРМЫ

&НаКлиенте
Процедура НетСертификатовПоказатьПодробностиНажатие(Элемент)
	
	Метрика_НетСертификатовПоказатьПодробности(Элемент);
	
	Элементы.НетСертификатовПодробности.Видимость = НЕ Элементы.НетСертификатовПодробности.Видимость;
	
КонецПроцедуры

&НаКлиенте
Процедура Декорация_ЗабылиПарольНажатие(Элемент)
	
	НазваниеФормы	 = Метрика_НазваниеФормы();
	Категория		 = Метрика_ВозможныеКатегории().ПоЛогину;
	Действие		 = Метрика_ВозможныеДействия().ЗабылиПароль;
	ДопПеременные	 = Новый Соответствие;
	ДопПеременные.Вставить("Логин", Логин);
	
	Метрика_ДобавитьСводноеСобытие(НазваниеФормы, Категория, Действие, "Нажать кнопку", НазваниеФормы, ДопПеременные, , Истина);
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	АдресаИнтернетРесурсов = Ядро.Перечисление_АдресаИнтернетРесурсов();
	
	ПерейтиПоНавигационнойСсылке(АдресаИнтернетРесурсов.СтраницаСменыПароля);
	
КонецПроцедуры

