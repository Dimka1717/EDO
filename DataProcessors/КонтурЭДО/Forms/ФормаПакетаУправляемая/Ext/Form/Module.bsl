Функция Модуль_ЯдроНаКлиенте()
	
	Платформа = Модуль_Платформа();
	Результат = Платформа.Модуль_ЯдроНаКлиенте();
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция Модуль_СинхронноМодальныеВызовы()
	
	Если _МодульСМВНаКлиенте = Неопределено Тогда
		
		// BSLLS:GetFormMethod-off
		_МодульСМВНаКлиенте = ПолучитьФорму(ПутьКФормам + "Модуль_СинхронныеМодальныеВызовы", , ЭтаФорма);
		// BSLLS:GetFormMethod-on
		
	КонецЕсли;
	
	Возврат _МодульСМВНаКлиенте;
	
КонецФункции

&НаКлиенте
Функция ОсновнаяФорма() Экспорт
	
