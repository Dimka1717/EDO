&НаКлиенте
Процедура ЗавершитьПереходПоВнешнейСсылке(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Метрика_Статистика_ОтменитьПереходПоСсылкеВHTMLPDF(
			ДополнительныеПараметры.ВнешняяСсылка,
			ДополнительныеПараметры.ИмяЭлемента);
		Возврат;
	КонецЕсли;
	
	МодульПлатформа = Модуль_Платформа();
	МодульПлатформа.ОповеститьИлиПерейтиПоСсылке(
		ДополнительныеПараметры.ВнешняяСсылка);
	
	Метрика_Статистика_ПерейтиПоСсылкеВHTMLPDF(
		ДополнительныеПараметры.ВнешняяСсылка,
		ДополнительныеПараметры.ИмяЭлемента);
	
КонецПроцедуры

&НаКлиенте
Процедура ОшибкиДокументаHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	АдресСсылки = Неопределено;
	
	ДанныеСобытия.Свойство("href", АдресСсылки);
	
	Если ЗначениеЗаполнено(АдресСсылки) Тогда
		
		Если СтрНайтиЛок(АдресСсылки, "ИНСТРУКЦИЯКАКЗАПОЛНИТЬОСНОВАНИЕ") > 0 Тогда
			
			ЗапуститьПриложение("https://support.kontur.ru/pages/viewpage.action?pageId=83865688");
			
		ИначеЕсли СтрНайтиЛок(АдресСсылки, "ИНСТРУКЦИЯКАКЗАПОЛНИТЬГТД") > 0 Тогда
			
			ЗапуститьПриложение("https://support.kontur.ru/pages/viewpage.action?pageId=83865678");
			
		ИначеЕсли СтрНайтиЛок(АдресСсылки, "ПЕРЕКЛЮЧИТЬФОРМАТФНС") > 0 Тогда
			
			Если ЕстьИндивидуальныеНастройкиКонтрагента() Тогда
				КонтрагентОткрытие(Неопределено, Ложь);
			Иначе
				ОрганизацияОткрытие(Неопределено, Ложь);
			КонецЕсли;
			
		ИначеЕсли СтрНайтиЛок(АдресСсылки, "ВКЛЮЧИТЬКОНВЕРТАЦИЮСТАВОКНДС") > 0 Тогда
			
			ЗапроситьВключениеКонвертацииСтавокНДС();
			
		ИначеЕсли СтрНайтиЛок(АдресСсылки, "ОТКЛЮЧИТЬКОНВЕРТАЦИЮСТАВОКНДС") > 0 Тогда
			
			ЗапроситьОтключениеКонвертацииСтавокНДС();
			
		ИначеЕсли СтрНайтиЛок(АдресСсылки, "https://") = 0 Тогда
			
			//На 8.2.19 href может иметь вид e1c://filev/C/base/СПРАВОЧНИК.КОНТРАГЕНТЫ:22F75233-F1AF-11E6-B215-448500D3D235
			ПозицияРазделителя = СтрНайтиЛок(АдресСсылки, "/");
			
			Пока ПозицияРазделителя > 0 Цикл
				АдресСсылки = Прав(АдресСсылки, СтрДлина(АдресСсылки) - ПозицияРазделителя);
				ПозицияРазделителя = СтрНайтиЛок(АдресСсылки, "/");
			КонецЦикла;
			
			СсылкаНаЭлементДанных = Документы_СсылкаНаЭлементДанныхИзГиперссылки(АдресСсылки);
			
			Если СсылкаНаЭлементДанных <> Неопределено Тогда
				Модуль_Платформа = Модуль_Платформа();
				Модуль_Платформа.ПоказатьЗначениеЛок(СсылкаНаЭлементДанных);
			КонецЕсли;
			
		Иначе
			ЗапуститьПриложение(АдресСсылки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция Документы_СсылкаНаЭлементДанныхИзГиперссылки(Знач ТекстГиперссылки)
	
	Результат = Неопределено;
	
	ВидМетаданных = Неопределено;
	
	Если Лев(ТекстГиперссылки, 11) = "СПРАВОЧНИК." Тогда
		ГруппаМетаданных = Справочники;
		ТекстГиперссылки = Сред(ТекстГиперссылки, 12);
	ИначеЕсли Лев(ТекстГиперссылки, 9) = "ДОКУМЕНТ." Тогда
		ГруппаМетаданных = Документы;
		ТекстГиперссылки = Сред(ТекстГиперссылки, 10);
	КонецЕсли;
	
	Если ГруппаМетаданных = Неопределено Тогда
		Возврат Результат; // не удалось вычислить ссылку
	КонецЕсли;
	
	ПодгруппаМетаданных = Лев(ТекстГиперссылки, СтрДлина(ТекстГиперссылки) - 37); // конкретный вид справочника/документа.
	ГуидСтрокой = Прав(ТекстГиперссылки, 36);
	Гуид = Новый УникальныйИдентификатор(ГуидСтрокой);
	
	Результат = ГруппаМетаданных[ПодгруппаМетаданных].ПолучитьСсылку(Гуид);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗапроситьВключениеКонвертацииСтавокНДС()
	
	ЗаголовокПредупреждения = НСтр("ru = 'Автоматическая замена некорректных ставок НДС'");
	
	КнопкаПоУмолчанию = КодВозвратаДиалога.Отмена;
	
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КодВозвратаДиалога.ОК, "Включить");
	СписокКнопок.Добавить(КнопкаПоУмолчанию, "Не включать");
	
	ТекстПредупреждения = НСтр(
		"ru='Если вы соглашаетесь на замену невалидной ставки НДС,
		|то замена будет выполняться для всех формализованных
		|документов, для всех сотрудников, которые работают
		|в текущей информационной базе 1С.
		|Включить автоматическую замену ставок НДС?'"
	);
	
	Таймаут = 0;
	ИмяОбработчика = "ОбработчикВключенияКонвертацииСтавокНДС";
	
	Модуль_Платформа = Модуль_Платформа();
	
	Оповещение = Модуль_Платформа.НовыйОписаниеОповещения(
		ИмяОбработчика,
		ЭтаФорма
