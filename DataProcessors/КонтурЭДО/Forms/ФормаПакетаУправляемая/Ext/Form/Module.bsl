	Результат.Вставить("Исходящие",		"ОтправленныеДокументы");
	Результат.Вставить("Входящие",		"ПолученныеДокументы");
	Результат.Вставить("Внутренние",	"ВнутренниеДокументы");
	
	Возврат Результат
	
КонецФункции

