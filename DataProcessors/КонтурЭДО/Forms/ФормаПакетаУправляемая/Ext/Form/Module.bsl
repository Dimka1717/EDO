&НаКлиенте
Процедура ОбработчикОповеститьОВыполненииКоманды(Параметр1 = Неопределено, Параметр2 = Неопределено) Экспорт
	
	// Имя этого обработчика зарезервировано в модуле Логистики!
	
	Ядро = Модуль_ЯдроНаКлиенте();
	
	ИспользуетсяМодульЛогистики = Ядро.КонтурЛогистика_ИспользуетсяМодульЛогистики();
	
	Если НЕ ИспользуетсяМодульЛогистики Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьСостояниеПеревозочныхДокументов();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСостояниеПеревозочныхДокументов()
	
	Ядро = Модуль_ЯдроНаСервере();
	
	ИспользуетсяМодульЛогистики = Ядро.КонтурЛогистика_ИспользуетсяМодульЛогистики();
	
	Если НЕ ИспользуетсяМодульЛогистики Тогда
		Возврат;
	КонецЕсли;
	
	СостояниеПеревозочных = СостояниеПеревозочныхДокументов();
	
	ИмяКоманды = "ПеревозочныеДокументы";
	
	КнопкаПеревозочныеДокументы = ЭтаФорма.Элементы.Найти(ИмяКоманды);
	КомандаПеревозочныеДокументы = ЭтаФорма.Команды.Найти(ИмяКоманды);
	
	Если НЕ СостояниеПеревозочных.ВидимостьКоманды Тогда
		
		Если КнопкаПеревозочныеДокументы <> Неопределено Тогда
			КнопкаПеревозочныеДокументы.Видимость = Ложь;
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	Если КомандаПеревозочныеДокументы = Неопределено Тогда
		
		КомандаПеревозочныеДокументы = ЭтаФорма.Команды.Добавить(ИмяКоманды);
		КомандаПеревозочныеДокументы.Действие = ИмяКоманды;
		
	КонецЕсли;
	
	Если КнопкаПеревозочныеДокументы = Неопределено Тогда
		
		РодительКнопки = ЭтаФорма.Элементы.ГруппаКомандыПакета;
		
		КнопкаПеревозочныеДокументы = ЭтаФорма.Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), РодительКнопки);
		КнопкаПеревозочныеДокументы.ИмяКоманды = ИмяКоманды;
		КнопкаПеревозочныеДокументы.Отображение = ОтображениеКнопки.КартинкаИТекст;
		
	КонецЕсли;
	
	КнопкаПеревозочныеДокументы.Заголовок = СостояниеПеревозочных.Заголовок;
	КнопкаПеревозочныеДокументы.Картинка = СостояниеПеревозочных.Картинка;
	КомандаПеревозочныеДокументы.Подсказка = СостояниеПеревозочных.Подсказка;
	
КонецПроцедуры

