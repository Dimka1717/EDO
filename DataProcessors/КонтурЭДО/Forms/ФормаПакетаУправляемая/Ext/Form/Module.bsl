		Метрика_ДобавитьСтатистику_ВключениеКонвертацииСтавокНДС(РезультатДействия);
		
	Иначе
		
		РезультатДействия = "Отказ";
		Метрика_ДобавитьСтатистику_ВключениеКонвертацииСтавокНДС(РезультатДействия);
		
	КонецЕсли;
	
КонецПроцедуры

