//{	Госключ

// Процедура - После ввода СНИЛС
//
// Параметры:
//  РезультатВводаСНИЛС_OID	 - Структура	 - см Модуль_Платформа.РезультатВводаСНИЛС_OID()
//  ДополнительныеПараметры	 - Произвольный	 - Доп параметры
//
&НаКлиенте
Процедура ПослеВводаСНИЛС_OID(РезультатВводаСНИЛС_OID, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(РезультатВводаСНИЛС_OID) Тогда
		Возврат;
	КонецЕсли;
	
	Модуль_Платформа = Модуль_Платформа();
	СпособПодписания = РезультатВводаСНИЛС_OID.ВыбранноеДействие;
	
	Если СпособПодписания = Модуль_Платформа.Перечисление_ВыбранныйСпособПодписанияГосключ().СНИЛС Тогда
		
		ПродолжитьПодписаниеИОтправкуИсходящегоПакетаГосключ(РезультатВводаСНИЛС_OID.ВведенныйСНИЛС, "");
		
	ИначеЕсли СпособПодписания = Модуль_Платформа.Перечисление_ВыбранныйСпособПодписанияГосключ().OID Тогда
		
		ПродолжитьПодписаниеИОтправкуИсходящегоПакетаГосключ("", РезультатВводаСНИЛС_OID.ВведенныйOID);
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

