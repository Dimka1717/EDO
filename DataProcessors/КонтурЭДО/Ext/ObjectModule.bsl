	Если Результат = Неопределено Тогда
		Результат = Ложь;
	КонецЕсли;
	
	Если Результат И НЕ ЭтоВнешняяОбработкаИзФайла() Тогда
		ХранилищеНастроекДанныхФорм.Сохранить("Диадок", "РежимОтладки", Ложь);
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
