Функция ЭтоВнешняяОбработкаИзФайла()
	
	Результат = ЭтоВнешняяОбработка();
	
	Если Результат Тогда
		Результат = Найти(ЭтотОбъект.ИспользуемоеИмяФайла,".epf") > 0;
	КонецЕсли;
	
