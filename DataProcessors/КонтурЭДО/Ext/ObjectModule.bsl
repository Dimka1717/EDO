	ТелоHTML = СтрЗаменить(ТелоHTML, "[КартинкаПолучитьИзменения]" , КартинкаПолучитьИзменения);
	ТелоHTML = СтрЗаменить(ТелоHTML, "[КартинкаОбновить]" , КартинкаОбновить);
