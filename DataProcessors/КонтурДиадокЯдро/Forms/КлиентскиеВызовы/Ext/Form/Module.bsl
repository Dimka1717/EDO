&НаКлиенте
Функция ПараметрыОповещенияИзСтрокиHTMLСообщения(СтрокаОповещения) Экспорт
	
	// BSLLS:DeprecatedFind-off
	ПозПрефикса = Найти(НРег(СтрокаОповещения), НРег("alert:"));
	ДлинаПрефикса = СтрДлина("alert:");
	
	Если ПозПрефикса = 0 Тогда
		ПозПрефикса = Найти(НРег(СтрокаОповещения), НРег("alertandclose:"));
		ДлинаПрефикса = СтрДлина("alertandclose:");
	КонецЕсли;
	// BSLLS:DeprecatedFind-on
	
	СтрокаОповещенияБезПрефикса = Сред(СтрокаОповещения, ПозПрефикса + ДлинаПрефикса);
	
	ЧастиСтроки = РазделитьСтрокуЛок(СтрокаОповещенияБезПрефикса, "?");
	
	ОбработчикОповещения = ЧастиСтроки[0];
	ЧастиСтроки.Удалить(0);
	
	Если ЗначениеЗаполнено(ЧастиСтроки) Тогда
		РезультатОповещения = СоединитьСтроку(ЧастиСтроки, "?");
	Иначе
		РезультатОповещения = Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ОбработчикОповещения", ОбработчикОповещения);
	Результат.Вставить("РезультатОповещения", РезультатОповещения);
	
	Возврат Результат;
	
КонецФункции

