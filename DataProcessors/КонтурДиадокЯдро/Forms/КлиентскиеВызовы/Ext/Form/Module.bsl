КонецФункции

&НаКлиенте
Функция Авторизация_ПоСертификату(ОтпечатокСертификата) Экспорт
	
	Результат = Неопределено;
	
	Сертификат = Сертификаты_ДанныеСертификата(ОтпечатокСертификата);
	
	ЗашифрованныйТокен = Токен_ПолучитьПоСертификатуНаСервере(Сертификат.ДвоичныеДанные);
	
	Если ЗначениеЗаполнено(ЗашифрованныйТокен) Тогда
		РасшифрованныйТокен = Токен_Расшифровать(ЗашифрованныйТокен);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РасшифрованныйТокен) Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
		"ru = 'Не удалось выполнить авторизацию по сертификату с отпечатком %1'"), ОтпечатокСертификата);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = Токен_ПодтвердитьАутентификациюНаСервере(РасшифрованныйТокен, ОтпечатокСертификата);
	
	Возврат Результат;
	
КонецФункции

// Авторизуется на сервере ДД по логину и паролю
//
// Параметры:
//  Логин - Строка
//  Пароль - Строка
//  ТекстОшибки - Строка - параметр в который записывается подробный текст ошибки при неудачной авторизации
// 
// Возвращаемое значение:
//  Строка - токен авторизации
//
&НаКлиенте
Функция Авторизация_ПоПаролю(Логин, Пароль, ТекстОшибки = "") Экспорт
	
	Токен = Неопределено;
	
	Попытка
		Токен = Токен_ПолучитьПоПаролюНаСервере(Логин, Пароль);
	Исключение
		
		ВидОперации		 = "Авторизация по логину";
		ТекстОшибки		 = "Не удалось выполнить авторизацию по логину %1. По причине: %2";
		ТекстОшибки		 = Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Логин, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки);
		
		Возврат Токен;
		
	КонецПопытки;
	
	Авторизация_ДобавитьСтрокуПоЛогинуНаСервере(Логин, Токен);
	
	Возврат Токен;
	
КонецФункции

&НаКлиенте
Функция Токен_Расшифровать(ЗашифрованныйТокен)
	
	Результат = РасшифроватьДанные(ЗашифрованныйТокен);
	
	Результат = Base64Строка(Результат);
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.ПС, "");
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция Авторизация_ПроверкаАвторизации(Сертификат = Неопределено, Логин = Неопределено, Пароль = Неопределено) Экспорт
	
	Результат = Авторизация_ПроверкаАвторизацииВызовСервера(
		Сертификат,
		Логин,
		Пароль
	);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция Авторизация_ПроверкаАвторизацииВызовСервера(Сертификат, Логин, Пароль)
	
	Ядро = ОбработкаОбъект();
	
	Результат = Ядро.Авторизация_ПроверкаАвторизации(
