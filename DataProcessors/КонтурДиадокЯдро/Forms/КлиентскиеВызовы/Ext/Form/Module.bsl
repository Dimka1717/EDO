&НаСервере
Функция ПодключитьМодульНаСервере(ИмяМодуля)
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	ОбработкаОбъект.Модуль_Отключить(ИмяМодуля);
	
	СоответствиеМодулейИФункций = СоответствиеМодулейИФункций();
	
	ИмяФункции = СоответствиеМодулейИФункций[ИмяМодуля];
	
	// BSLLS:UnusedLocalVariable-off
	// BSLLS:ExecuteExternalCode-off
	Модуль = Вычислить("ОбработкаОбъект." + ИмяФункции + "(ОбработкаОбъект)");
	// BSLLS:UsingExternalCodeTools-on
	// BSLLS:ExecuteExternalCode-on
	
	// После подключения модуля нужно передать на клиента новый общий контекст.
	Объект.ОбщийКонтекстКлиентСервер = ОбработкаОбъект.ОбщийКонтекстКлиентСервер;
	
	ПодключенныеОбработки = ОбработкаОбъект.СвойствоСтруктуры(Объект.ОбщийКонтекстКлиентСервер,
			"ПодключенныеОбработки",
			Новый Соответствие);
	
	Результат = ПодключенныеОбработки.Получить(ИмяМодуля);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция КэшМодулей_Прочитать(ИмяМодуля)
	
	Результат = Неопределено;
	
	Если РежимОтладкиВключен() Тогда
		Возврат Результат;
	КонецЕсли;
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если ЗначениеЗаполнено(КэшМодулей) Тогда
		Результат = КэшМодулей[ИмяМодуля];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура КэшМодулей_Поместить(ИмяМодуля, Модуль)
	
	Если РежимОтладкиВключен() Тогда
		Возврат;
	КонецЕсли;
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если КэшМодулей = Неопределено Тогда
		
		КэшМодулей = Новый Соответствие;
		
		Кэш_Поместить("КэшМодулей", КэшМодулей);
		
	КонецЕсли;
	
	КэшМодулей.Вставить(ИмяМодуля, Модуль);
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКэшМодулей()
	
	Если РежимОтладкиВключен() Тогда
		Возврат;
	КонецЕсли;
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если Не ЗначениеЗаполнено(КэшМодулей) Тогда
		Возврат;
	КонецЕсли;
	
	СвойстваДляОчистки = Новый Структура;
	СвойстваДляОчистки.Вставить("КонтурДиадокЯдро");
	СвойстваДляОчистки.Вставить("ОсновнойМодуль");
	
	Для Каждого Элемент Из КэшМодулей Цикл
		
		Модуль = Элемент.Значение;
		
		Если Модуль <> Неопределено Тогда
			
			ЗаполнитьЗначенияСвойств(Модуль, СвойстваДляОчистки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	КэшМодулей.Очистить();
	
КонецПроцедуры

