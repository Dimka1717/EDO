&НаКлиентеНаСервереБезКонтекста
Функция СоответствиеМодулейИФункций()
	
	Результат = Новый Структура;
	
	Результат.Вставить("КонтурДиадокВнешниеСервисы", "Модуль_ВнешниеСервисы");
	Результат.Вставить("КонтурДиадокВызовыПМ", "Модуль_ВызовыПМ");
