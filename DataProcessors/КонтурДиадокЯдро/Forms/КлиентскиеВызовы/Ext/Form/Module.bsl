// Возвращает строки контекста сеанса за исключением служебной строки,
// а также за исключением строк где требуется оплата сервиса.
//
// Параметры:
//  ДобавитьНеоплаченные - Булево - Истина, если строки где требуется оплата сервиса
//                                  нужно включить в результат.
//
// Возвращаемое значение:
//   - Соответствие - см. описание СоздатьКонтекстСеанса()
//
&НаКлиенте
Функция КонтекстСеанса_СтрокиКонтекста(ДобавитьНеоплаченные = Ложь) Экспорт
	
	Результат = Новый Соответствие;
	
	ХранилищеКонтекста = ХранилищеКонтекстаСеанса();
	
	Если ЗначениеЗаполнено(ХранилищеКонтекста) Тогда
		
		Для Каждого КлючИЗначение Из ХранилищеКонтекста Цикл
			
			СтрокаКонтекста = КлючИЗначение.Значение;
			
			ТребуетсяОплатаСервиса = СтрокаКонтекста.ТребуетсяОплатаСервиса;
			ЭтоСлужебнаяУчетнаяЗапись = НЕ ЗначениеЗаполнено(СтрокаКонтекста.BoxId);
			
			Если (НЕ ТребуетсяОплатаСервиса ИЛИ ДобавитьНеоплаченные) И НЕ ЭтоСлужебнаяУчетнаяЗапись Тогда
				
				Результат.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ФиксированныеДанныеЛок(Результат);
	
КонецФункции

