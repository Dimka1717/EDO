Функция ПодписьДанных(BoxId, ДвоичныеДанные, Знач ОтпечатокСертификата = "") Экспорт 
	
	Если Не ЗначениеЗаполнено(ОтпечатокСертификата) Тогда
		ОтпечатокСертификата = КонтекстСеанса_ПрочитатьВызовСервера(BoxId, "ОтпечатокСертификата");
	КонецЕсли;
	
	Если ОтпечатокСертификата = "" Тогда 
		ВызватьИсключение "Подписание доступно только при авторизации по сертификату";	
	КонецЕсли;
	
	Результат = ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи) Экспорт
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ДвоичныеДанные"		 , ДвоичныеДанные);
	ПараметрыСобытия.Вставить("ДвоичныеДанныеПодписи", ДвоичныеДанныеПодписи);
	
	ПодписьВерна = ПодключаемыйМодуль_ОбработатьСобытие("ПроверитьПодпись", ПараметрыСобытия);
	
	Если ПодписьВерна = Неопределено Тогда
		
		Попытка
			
			Если ИспользоватьВнешнююКриптографию() Тогда
				
				ОписаниеСертификата = ВнешниеСервисы_ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
				
			Иначе
				
				ОписаниеСертификата = МенеджерКриптографии_ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
				
			КонецЕсли;
			
			Результат			= ЗначениеЗаполнено(ОписаниеСертификата);
		Исключение
			
			ВидОперации		 = "Проверка подписи";
			ТекстСообщения	 = "Не удалось проверить подпись";
			ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ТекстСообщения);
			
			Результат = Ложь;
			
		КонецПопытки;
		
	Иначе
		Результат = ПодписьВерна;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

