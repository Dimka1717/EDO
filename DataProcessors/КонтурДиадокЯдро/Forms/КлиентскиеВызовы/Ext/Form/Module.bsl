КонецПроцедуры

&НаКлиенте
Функция Метрика_НазваниеКатегории() Экспорт
	
	Результат = Кэш_Прочитать("Метрика_НазваниеКатегорииНаКлиенте");
	
	Если Результат = Неопределено Тогда
		
		Результат = Метрика_НазваниеКатегорииВызовСервера();
		
		Кэш_Поместить("Метрика_НазваниеКатегорииНаКлиенте", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция Метрика_НазваниеКатегорииВызовСервера()
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.Метрика_НазваниеКатегории();
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция Метрика_НазваниеДействий() Экспорт

	Результат = Кэш_Прочитать("Метрика_НазваниеДействийНаКлиенте");
	
	Если Результат = Неопределено Тогда
		
		Результат = Метрика_НазваниеДействийВызовСервера();
		
		Кэш_Поместить("Метрика_НазваниеДействийНаКлиенте", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция Метрика_НазваниеДействийВызовСервера()
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.Метрика_НазваниеДействий();
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция Метрика_НазваниеДействияМаршрутизации(Действие) Экспорт
	
	Результат = "";
	
	ДействияЭДО = Перечисление_ДействияЭДО();
	ВозможныеДействияМетрики = Метрика_НазваниеДействий();

	Если Действие = ДействияЭДО.ПередатьНаСогласование Тогда
		Результат = ВозможныеДействияМетрики.ПередатьНаСогласование;
	ИначеЕсли Действие = ДействияЭДО.ПередатьНаПодпись Тогда
		Результат = ВозможныеДействияМетрики.ПередатьНаПодпись;
	ИначеЕсли Действие = ДействияЭДО.ПередатьПоМаршруту Тогда
		Результат = ВозможныеДействияМетрики.ПередатьПоМаршруту;
	ИначеЕсли Действие = ДействияЭДО.Согласование Тогда
		Результат = ВозможныеДействияМетрики.Согласовать;	
	ИначеЕсли Действие = ДействияЭДО.ОтказВСогласовании Тогда
		Результат = ВозможныеДействияМетрики.ОтказатьВСогласовании;
	Иначе
		Результат = "";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает новый уникальный идентификатор замера и записывает его в общий для всех обработок кэш.
//
// Параметры:
//  КлючЗамера - Строка - Ключ в структуре идентификаторов замеров.
// 
// Возвращаемое значение:
//   Строка	- Уникальный идентификатор замера.
//
&НаКлиенте
Функция ЗаписатьЗамерID(КлючЗамера)
		
	ИдентификаторыЗамера = ОбщийКонтекст_Прочитать("ЗамерID");
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторыЗамера) Тогда
		ИдентификаторыЗамера = Новый Соответствие;
	КонецЕсли;
	
	ИдентификаторЗамера = Новый УникальныйИдентификатор();
	
	ИдентификаторыЗамера.Вставить(КлючЗамера, ИдентификаторЗамера);
	
	ОбщийКонтекст_Поместить("ЗамерID", ИдентификаторыЗамера);
	
	Возврат ИдентификаторЗамера;
	
КонецФункции

// Возвращает уникальный идентификатор замера и удаляет его из структуры идентификаторов.
// Если структура идентификаторов окажется пустой, то элемент кэша ЗамерID будет удален из кэша.
// 
// Параметры:
//  КлючЗамера - Строка - Ключ в структуре идентификаторов замеров.
// 
// Возвращаемое значение:
//   Строка	- Уникальный идентификатор замера из кэша.
//
&НаКлиенте
Функция ПрочитатьЗамерID(КлючЗамера, Очищать = Ложь)
		
	ИдентификаторыЗамера = ОбщийКонтекст_Прочитать("ЗамерID");
	
	Результат = ИдентификаторыЗамера.Получить(КлючЗамера);
	
	Если Очищать Тогда
		ИдентификаторыЗамера.Удалить(КлючЗамера);
		
		ОбщийКонтекст_Поместить("ЗамерID", ИдентификаторыЗамера);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Записывает событие метрики в топик "Feedback"
//
// Параметры:
//  Категория - Строка - Категория событий, к которой относится данное событие
//  Действие - Строка - Действие, породившее данное событие
//  ПроизвольныеПеременные - Структура, Соответствие - (Необязательный) дополнительные параметры, которые нужно добавить в метрику
//  TraceID - Строка - (Необязательные) идентификатор трассировки
//
&НаКлиенте
Процедура Метрика_ЗаписатьОбратнуюСвязь(Категория, Действие, ПроизвольныеПеременные = Неопределено, TraceID = Неопределено) Экспорт
	
	Метрика_ЗаписатьОбратнуюСвязьНаСервере(Категория, Действие, ПроизвольныеПеременные, TraceID);
	
КонецПроцедуры

&НаСервере
Процедура Метрика_ЗаписатьОбратнуюСвязьНаСервере(Категория, Действие, ПроизвольныеПеременные = Неопределено, TraceID = Неопределено) Экспорт
	
	Модуль_Ядро = ОбработкаОбъект();
	
	Модуль_Ядро.Метрика_ЗаписатьОбратнуюСвязь(Категория, Действие, ПроизвольныеПеременные, TraceID);
		
КонецПроцедуры

// Дополняет переменные метрики BaseID
//
// Параметры:
//  Переменные	 - Структура - переменные метрики Возможно Неопределено 
//
&НаКлиенте
Процедура ДополнитьПеременныеМетрики_BaseId(Переменные)
	
	BaseID = ОбщийКонтекст_ИдентификаторБазы1С();
	
	Если НЕ ЗначениеЗаполнено(Переменные) Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	Переменные.Вставить("BaseID", BaseID);

КонецПроцедуры

// Дополняет переменные метрики BoxID
//
// Параметры:
//  Переменные	 - Структура - переменные метрики Возможно Неопределено
//
&НаКлиенте
Процедура ДополнитьПеременныеМетрики_BoxId(Переменные)
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	КоллекцияBoxId = Новый Массив;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		КоллекцияBoxId.Добавить(ИдентификаторЯщика);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Переменные) Тогда
		
		Переменные.Вставить("BoxId", КоллекцияBoxId);
		
	Иначе
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxId", КоллекцияBoxId);
		
	КонецЕсли;
	
КонецПроцедуры

// Добавляет произвольные параметры в переменные метрик.
// Значения параметров преобразуются в XML-представления.
//
// Параметры:
//  Переменные - Структура, Соответствие - коллекция переменных
//  ДопПараметры - Структура, Соответствие - добавляемые параметры
//
&НаКлиенте
Процедура ДополнитьПеременныеМетрики_ПроизвольныеПараметры(Переменные, ДопПараметры)
	
	Если НЕ ЗначениеЗаполнено(ДопПараметры) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из ДопПараметры Цикл
		
		Ключ = КлючЗначение.Ключ;
		Значение = КлючЗначение.Значение;
		
		Если ТипЗнч(Значение) = Тип("Массив")
			ИЛИ ТипЗнч(Значение) = Тип("Структура") Тогда
			
			Результат = Значение;
			
		Иначе
			
			Результат = XMLСтрокаНаСервереБезКонтекста(Значение);
			
		КонецЕсли;
		
		Переменные.Вставить(Ключ, Результат);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция XMLСтрокаНаСервереБезКонтекста(Значение)
	
	Возврат XMLСтрока(Значение);
	
КонецФункции

//#КонецОбласти

//#Область Конструкторы_объектов_метрики

&НаКлиенте
Функция НовоеСобытиеМетрики(Категория, Действие
	, Метка			 = Неопределено
	, Представление	 = Неопределено)
	
	Результат = Новый Структура;
	
	Результат.Вставить("Category"	, Категория);
	Результат.Вставить("Action"		, Действие);
	
	Если ЗначениеЗаполнено(Метка) Тогда
		Результат.Вставить("Label", Метка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Представление) Тогда
		Результат.Вставить("View", Представление);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НоваяМетрика(СобытиеМетрики
	, TraceID			 = Неопределено
	, ОписаниеПеременных = Неопределено
	, ОписаниеПриложения = Неопределено)
	
	МоментВремени = НовыйМоментВремениМетрики();
	
	Результат = Новый Структура;
	
	Результат.Вставить("Path", СобытиеМетрики);
	Результат.Вставить("Time", МоментВремени);
	
	Если ЗначениеЗаполнено(ОписаниеПриложения) Тогда
		Результат.Вставить("AppContext", ОписаниеПриложения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеПеременных) Тогда
		Результат.Вставить("Variables", ОписаниеПеременных);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(TraceID) Тогда
		Результат.Вставить("TraceID", Строка(TraceID));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НовыйСтекСобытийМетрики()
	
	Топики = Новый Структура;
	
	Для Каждого Элемент Из ТопикиМетрики() Цикл
		Топики.Вставить(Элемент.Ключ, Новый Массив);
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Топики", Топики);
	Результат.Вставить("РазмерСтека", 0);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НовыйМоментВремениМетрики()
	
	ТекущаяДатаКомпьютера	 = ТекущаяДата();
	УниверсальнаяДатаСтрокой = УниверсальнаяДатаВФормате_ISO8601(ТекущаяДатаКомпьютера);
	
	Результат = Новый Структура;
	Результат.Вставить("ClientTime"			, УниверсальнаяДатаСтрокой);
	Результат.Вставить("SendFromClientTime"	, УниверсальнаяДатаСтрокой);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НовоеОписаниеПриложения(ВерсияМодуля
	, ОписаниеОС						 = Неопределено
	, ОписаниеБраузера					 = Неопределено
	, ОписаниеПрограммы					 = Неопределено
	, ОписаниеАппаратноогоОбеспечения	 = Неопределено)
	
	Результат = Новый Структура;
	
	Результат.Вставить("AppVersion", ВерсияМодуля);
	
	Если ЗначениеЗаполнено(ОписаниеОС) Тогда
		Результат.Вставить("OS", ОписаниеОС);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеБраузера) Тогда
		Результат.Вставить("Browser", ОписаниеБраузера);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеПрограммы) Тогда
		Результат.Вставить("Platform", ОписаниеПрограммы);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеАппаратноогоОбеспечения) Тогда
		Результат.Вставить("Hardware", ОписаниеАппаратноогоОбеспечения);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//#КонецОбласти

//#Область Отправка_накопленных_событий_метрики

// Отправляет все накопленные события сервера в сервис Контур.Метрика
// и очищает стек событий.
//
&НаКлиенте
Процедура Метрики_Отправить() Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Метрики_Отправить_Принудительно();
	
КонецПроцедуры

// Отправляет все накопленные события сервера или толстого клиента
// в сервис Контур.Метрика, игнорируя значение настройки ЗапретитьРаботуСМетриками,
// и затем очищает стек.
//
&НаКлиенте
Процедура Метрики_Отправить_Принудительно()
	
	СтекСобытий = СтекСобытийМетрики();
	
	Если СтекСобытий.РазмерСтека = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НужноСформироватьОписаниеПеременных = СформироватьОписаниеПеременыхДляМетрикиПередОтправкой();
	
	УдалосьОтправить = Метрика_ОтправитьСтекСобытийВызовСервера(СтекСобытий, НужноСформироватьОписаниеПеременных);
	
	Если Не УдалосьОтправить Тогда
		ОтключитьМетрики();
	КонецЕсли;
	
	ОчиститьСтекСобытийМетрики();
	
КонецПроцедуры

&НаСервере
Функция Метрика_ОтправитьСтекСобытийВызовСервера(СтекСобытий, НужноСформироватьОписаниеПеременных)
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.Метрика_ОтправитьСтекСобытий(СтекСобытий, НужноСформироватьОписаниеПеременных);
	
	Возврат Результат;
	
КонецФункции

//#КонецОбласти

//#Область Описание_окружения

&НаКлиенте
Функция ОписаниеПриложения()
	
	Результат = Кэш_Прочитать("ОписаниеПриложенияДляМетрикиНаКлиенте");
	
	Если Результат = Неопределено Тогда
		
		ВерсияМодуля		 = ОбщийКонтекст_Прочитать("ВерсияМодуля");
		ОписаниеОС			 = ОписаниеОС();
		ОписаниеБраузера	 = ОписаниеБраузера();
		ОписаниеПрограммы	 = ОписаниеПрограммы();
		ОписаниеАппаратноогоОбеспечения = ОписаниеАппаратноогоОбеспечения();
		
		Результат = НовоеОписаниеПриложения(ВерсияМодуля
		, ОписаниеОС
		, ОписаниеБраузера
		, ОписаниеПрограммы
		, ОписаниеАппаратноогоОбеспечения);
		
		Кэш_Поместить("ОписаниеПриложенияДляМетрикиНаКлиенте", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОписаниеОС()
	
	СтрокаТипПлатформы = НРег(ОписаниеСистемнойИнформации().ТипПлатформы);
	
	Если Найти(СтрокаТипПлатформы, "64") > 0 Тогда
		BitSet = "x64";
	Иначе
		BitSet = "x86";
	КонецЕсли;
	
	Если Найти(СтрокаТипПлатформы, НРег("Linux")) <> 0 Тогда
		Name = "Linux";
	ИначеЕсли Найти(СтрокаТипПлатформы, НРег("MacOS")) <> 0 Тогда
		Name = "MacOS";
	ИначеЕсли Найти(СтрокаТипПлатформы, НРег("Windows")) <> 0 Тогда
		Name = "Windows";
	КонецЕсли;
	
	Version = "0.0.0";
	
	Результат = Новый Структура;
	Результат.Вставить("BitSet"	, BitSet);
	Результат.Вставить("Name"	, Name);
	Результат.Вставить("Version", Version);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОписаниеПрограммы()
	
	ОписаниеКонфигурации = ОписаниеКонфигурации();
	
	Name = "1С:Предприятие 8";
	RunMode = ТекущийРежимЗапускаПриложения();
	Version = ВерсияВСемантикДляМетрики(ОписаниеСистемнойИнформации().ВерсияПриложения);
	
	Configuration = ОписаниеКонфигурации.Имя;
	ConfigurationVersion = ВерсияВСемантикДляМетрики(ОписаниеКонфигурации.Версия);
	ConfigurationVersion = СтрЗаменить(ConfigurationVersion, "/", "-");
	
	Результат = Новый Структура;
	Результат.Вставить("Name", Name);
	Результат.Вставить("RunMode", RunMode);
	Результат.Вставить("Version", Version);
	
	Результат.Вставить("Configuration", Configuration);
	Результат.Вставить("ConfigurationVersion", ConfigurationVersion);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОписаниеБраузера()
	
	Результат = Новый Структура;
	
	UserAgent = ОписаниеСистемнойИнформации().ИнформацияПрограммыПросмотра;
	
	Если ЗначениеЗаполнено(UserAgent) Тогда
		Результат.Вставить("UserAgent", UserAgent);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОписаниеАппаратноогоОбеспечения()
	
	TotalMemoryGb = Окр(ОписаниеСистемнойИнформации().ОперативнаяПамять / 1000);
	
	Результат = Новый Структура;
	Результат.Вставить("TotalMemoryGb", TotalMemoryGb);
	
	Возврат Результат; 
	
КонецФункции

