&НаКлиенте
Процедура ДополнитьДанныеДляОбновленияМодуля(ДанныеДляОбновленияМодуля) Экспорт
	
	ТестовыйЗапуск = ОбновлениеМодуля_ЭтоТестовыйЗапуск();
	
	ЗаполнитьОписанияОкруженияИОбновленияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск);	
	
	Если Не ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Тогда
		Возврат;
	КонецЕсли;
		
	ОписаниеРасположения = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	МестоположенияМодуля = ДанныеДляОбновленияМодуля.Перечисления.МестоположенияМодуля;
	
	Если ОписаниеРасположения.Местоположение = МестоположенияМодуля.ФайлНаДиске Тогда
		ТекстОшибки = ПроверитьВозможностьОбновленияФайлаМодуля(ОписаниеРасположения.ПутьКФайлу);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			ДанныеДляОбновленияМодуля.МожноОбновитьМодуль = Ложь;
			ДанныеДляОбновленияМодуля.КомментарийМодуля = ТекстОшибки;
			Возврат;		
		КонецЕсли;		
	КонецЕсли;	
	
	Если МодульДоработан(ДанныеДляОбновленияМодуля) Тогда
		ДанныеДляОбновленияМодуля.МожноОбновитьМодуль = Ложь;
		ДанныеДляОбновленияМодуля.КомментарийМодуля = "МодульДоработан";
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ОбновлениеМодуля_ЭтоТестовыйЗапуск()
	
	Результат = Ложь;
	
	Если РежимАвтотест() 
		Или ДоменПользователяКонтур() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет принадлежность пользователя к домену kontur
//
&НаКлиенте
Функция ДоменПользователяКонтур()
	
	ДоменПользователя = ЗначениеПеременнойОкружения("UserDomain");
	
	Результат = (НРег(ДоменПользователя) = НРег("Kontur"));
	
	Возврат Результат;		
	
КонецФункции

&НаКлиенте
Функция ЗначениеПеременнойОкружения(Имя)
	
	Результат = "";
	
	Попытка
		WSH = Новый COMobject("wscript.shell");
		Результат = WSH.ExpandEnvironmentStrings("%" + Имя + "%");
	Исключение
		_ОписаниеОшибки = ОписаниеОшибки();
		Метрика_ДобавитьОшибку_ОпределениеЗначенияПеременнойОкружения(Имя, _ОписаниеОшибки);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьОписанияОкруженияИОбновленияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск)
	
	Ядро = ОбработкаОбъект();
	
	Ядро.ЗаполнитьОписаниеОкруженияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск);
	
	Ядро.ЗаполнитьОписаниеОбновленияМодуля(ДанныеДляОбновленияМодуля);
	
КонецПроцедуры

&НаКлиенте
Функция ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля)
	
	Результат = Истина;
	
	Если ДанныеДляОбновленияМодуля.МодульЗапущенВпервые 
		 Или ДанныеДляОбновленияМодуля.МодульБылОбновлен
		 Или Не ДанныеДляОбновленияМодуля.МожноОбновитьМодуль
		 Или Не ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля.ЕстьНоваяВерсия Тогда
		 
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет наличие файла модуля и возможность записи в его каталог
//
// Параметры:
//  ПутьКФайлу - Строка - путь к файлу модуля
// 
// Возвращаемое значение:
//  Строка - описание ошибки
//
&НаКлиенте
Функция ПроверитьВозможностьОбновленияФайлаМодуля(ПутьКФайлу)
	
	Результат = "";
	
	Файл = Новый Файл(ПутьКФайлу);
	Каталог	 = Файл.Путь;
	ИмяФайла = Файл.Имя;
	
	Если Не Файл.Существует() Тогда
		Результат = "КаталогФайлаМодуля.НеНайденФайл";
		Возврат Результат;
	КонецЕсли;
	
	Префикс = "Diadoc_WriteTest_";
	Расширение = ".txt";
	УникальнаяЧасть = Строка(Новый УникальныйИдентификатор);
	
	ИмяТестовогоФайла = Префикс + УникальнаяЧасть + Расширение;
	ПутьКТестовомуФайлу	 = ОбъединитьПути(Каталог, ИмяТестовогоФайла);
	
	Попытка
		Запись = Новый ЗаписьТекста(ПутьКТестовомуФайлу);
		Запись.Записать("Тест записи файла перед обновлением " + ИмяФайла);
		Запись.Закрыть();
	Исключение
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
		
		Результат = "КаталогФайлаМодуля.ОшибкаПриЗаписи" + " " + ОписаниеОшибки();
		
	КонецПопытки;
	
	Попытка
		УдалитьФайлы(ПутьКТестовомуФайлу);
	Исключение
		Ошибка = ИнформацияОбОшибке();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Записывает в журнал регистрации описания ошибок, происходящих
// 	в процессе автообновления модуля
//
// Параметры:
//  ОписаниеОшибки - Строка - см. функцию ПодробноеПредставлениеОшибки();
//
&НаСервере
Процедура ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки)
	
	ОбработкаОбъект().ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
	
КонецПроцедуры

&НаКлиенте
Функция МодульДоработан(ДанныеДляОбновленияМодуля)
	
	Результат = Ложь;
	
	Если ЭтоТиповойМодуль() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = Истина;
		
	РезультатПроверки = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыВызовСервера();
	ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ПроверкаХешСуммыМодуля " + РезультатПроверки;
	
	Возврат Результат;
	
КонецФункции

// обновление

&НаКлиенте
Функция ОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Экспорт  
	
	Результат = "";
	
	МоментНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Если Не ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Тогда
		
		Если НужноЗарегистрироватьОшибкуАвтообновленияМодуля(ДанныеДляОбновленияМодуля) Тогда 
			
			Результат = "CriticalRejection";
			Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
			
			Метрика_ДобавитьОшибку_ОшибкаАвтообновленияМодуля(ДанныеДляОбновленияМодуля);
			
		Иначе
			
			Результат = "NormalRejection";
			Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);		
			
		КонецЕсли;
		
		Возврат Результат;
		
	КонецЕсли;
	
	Попытка
		
		ВыполнитьОбновлениеМодуля(ДанныеДляОбновленияМодуля);
		
		Результат = "Success";	
		Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
		
		Метрика_ДобавитьСтатистику_УспешноеАвтообновлениеМодуля(ДанныеДляОбновленияМодуля);
		
	Исключение  
		
		Результат = "Error";
		Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
				
		ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ОбновлениеМодуля" + " " + ОписаниеОшибки();
		Метрика_ДобавитьОшибку_ОшибкаАвтообновленияМодуля(ДанныеДляОбновленияМодуля);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НужноЗарегистрироватьОшибкуАвтообновленияМодуля(ДанныеДляОбновленияМодуля)
	
	Результат = Ложь;
	
	Если ДанныеДляОбновленияМодуля.МодульЗапущенВпервые 
		 Или ДанныеДляОбновленияМодуля.МодульБылОбновлен Тогда
		Возврат Результат; // не должно быть процесса обновления -> значит нет ошибок
	КонецЕсли;
	
	НетНовойВерсии = Не ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля.ЕстьНоваяВерсия;
	Если НетНовойВерсии Тогда
		СервисВернулПричинуОтказа = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.КомментарийСервиса);
		ПроизошлаОшибкаПриСбореДанныхДляОбновления = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.ОписаниеОшибки);
		Если СервисВернулПричинуОтказа Или ПроизошлаОшибкаПриСбореДанныхДляОбновления Тогда
			Результат = Истина;
		КонецЕсли;
		Возврат Результат; // если НетНовойВерсии -> значит нет процесса обновления -> значит уже не важно, что НельзяОбновитьМодуль
	КонецЕсли;
	
	НельзяОбновитьМодуль = Не ДанныеДляОбновленияМодуля.МожноОбновитьМодуль;
	Если НельзяОбновитьМодуль Тогда
		МодульНашелПричинуОтказа = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.КомментарийМодуля);
		ПроизошлаОшибкаПриСбореДанныхДляОбновления = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.ОписаниеОшибки);
		Если МодульНашелПричинуОтказа Или ПроизошлаОшибкаПриСбореДанныхДляОбновления Тогда
			Результат = Истина;
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;

КонецФункции

&НаКлиенте
Процедура ВыполнитьОбновлениеМодуля(ДанныеДляОбновленияМодуля)
	
	МестоположенияМодуля = ДанныеДляОбновленияМодуля.Перечисления.МестоположенияМодуля;
	РасположениеМодуля   = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	ОписаниеОбновления   = ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля;
		
	ПутьКФайлу		 = РасположениеМодуля.ПутьКФайлу;
	СсылкаНаФайл 	 = ОписаниеОбновления.СсылкаНаФайл;
	Местоположение	 = РасположениеМодуля.Местоположение;
	ВнешняяОбработка = РасположениеМодуля.Ссылка;
	
	Если Местоположение = МестоположенияМодуля.ФайлНаДиске Тогда
		
		ВыполнитьОбновлениеМодуляВФайлеНаДиске(ПутьКФайлу, СсылкаНаФайл);
		
	ИначеЕсли Местоположение = МестоположенияМодуля.ЭлементСправочника Тогда
		
		ВыполнитьОбновлениеМодуляВСправочнике(ВнешняяОбработка, СсылкаНаФайл);
		
	ИначеЕсли Местоположение = МестоположенияМодуля.РасширениеКонфигурации Тогда
		
		ВыполнитьОбновлениеРасширенияКонфигурацииДиадок(СсылкаНаФайл);
		
	Иначе // этого сценария не должно быть
		
		ВызватьИсключение "НекорректноеРасположениеМодуля: " + Местоположение;
		
	КонецЕсли;
	
КонецПроцедуры

// Получает новую версию модуля из сервиса обновлений
// 	и записывает его файл на диске
//
// Параметры:
//  ПутьКФайлу		- Строка    - путь к файлу на диске, в который нужно записать новую версию модуля;
//  СсылкаНаФайл    - Строка 	- ссылка на файл в сервисе обновлений;
//
&НаКлиенте
Процедура ВыполнитьОбновлениеМодуляВФайлеНаДиске(ПутьКФайлу, СсылкаНаФайл)
	
	ФайлНовойВерсии = ФайлНовойВерсииМодуляВФайлеНаДискеВызовСервера(СсылкаНаФайл);
	
	ФайлНовойВерсии.Записать(ПутьКФайлу);
	
КонецПроцедуры

&НаСервере
Функция ФайлНовойВерсииМодуляВФайлеНаДискеВызовСервера(СсылкаНаФайл)
	
	Ядро = ОбработкаОбъект();
	
	Результат = Ядро.ФайлНовойВерсииМодуля(СсылкаНаФайл);
	
	Ядро.ОбновлениеМодуля_ВыполнитьТестовоеПодключениеМодуля(Результат);
	
	Возврат Результат;
	
КонецФункции

// Получает новую версию модуля из сервиса обновлений
// 	и обновляет его в справочнике внешних обработок
//
// Параметры:
//  ВнешняяОбработка 	- СправочникСсылка - элемент в справочнике внешних обработок,
//                                        	 в который нужно записать файл модуля;
//  СсылкаНаФайл    	- Строка 		   - ссылка на файл в сервисе обновлений;
//
&НаСервере
Процедура ВыполнитьОбновлениеМодуляВСправочнике(ВнешняяОбработка, СсылкаНаФайл)
	
	Ядро = ОбработкаОбъект();
	
	Ядро.ВыполнитьОбновлениеМодуляВСправочнике(ВнешняяОбработка, СсылкаНаФайл);
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьОбновлениеРасширенияКонфигурацииДиадок(СсылкаНаФайл)
	
	Ядро = ОбработкаОбъект();
	
	Ядро.ВыполнитьОбновлениеРасширенияКонфигурацииДиадок(СсылкаНаФайл);
	
КонецПроцедуры

