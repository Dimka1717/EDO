Функция Документ_ДвоичныеДанные(Документ)
	
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента");
	ДанныеХранилища = СвойствоСтруктуры(ХранилищеКонтента, "Данные");
	
	Если ТипЗнч(ДанныеХранилища) = Тип("ДвоичныеДанные") Тогда
		
		Результат = ДанныеХранилища;
		
	ИначеЕсли ЭтоАдресВременногоХранилища(ДанныеХранилища) Тогда
		
		Результат = ПолучитьИзВременногоХранилища(ДанныеХранилища);
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
