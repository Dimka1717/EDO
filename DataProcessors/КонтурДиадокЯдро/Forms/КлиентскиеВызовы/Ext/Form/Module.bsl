// Возвращает системную информацию клиента, если есть клиентское приложение.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура:
//    * ВерсияОС - Строка - версия операционной системы
//    * ВерсияПриложения - Строка - версия 1С:Предприятия
//    * ТипПлатформы - Строка - представление типа платформы
//    * ИдентификаторКлиента - УникальныйИдентификатор - уникальный идентификатор клиента
//    * ИнформацияПрограммыПросмотра - Строка - информация о веб-браузере
//    * ИмяКомпьютера - Строка - имя компьютера
//    * ЯзыкСистемы - Строка - используемый системой язык
//    * ЯзыкИнтерфейса - Строка - код языка интерфейса пользователя
//    * ВидКлиента - Строка - см. ВидКлиента()
//
&НаКлиенте
Функция СистемнаяИнформацияНаКлиенте() Экспорт
	
	СисИнфо = Новый СистемнаяИнформация;
	
	Данные = Новый Структура;
	Данные.Вставить("ВерсияОС", СисИнфо.ВерсияОС);
	Данные.Вставить("ВерсияПриложения", СисИнфо.ВерсияПриложения);
	Данные.Вставить("ТипПлатформы", Строка(СисИнфо.ТипПлатформы));
	Данные.Вставить("ИдентификаторКлиента", СисИнфо.ИдентификаторКлиента);
	Данные.Вставить("ИнформацияПрограммыПросмотра", СисИнфо.ИнформацияПрограммыПросмотра);
	Данные.Вставить("ИмяКомпьютера", ИмяКомпьютера());
	Данные.Вставить("ЯзыкСистемы", ТекущийЯзыкСистемы());
	Данные.Вставить("ЯзыкИнтерфейса", ЯзыкИнтерфейсаПользователя());
	Данные.Вставить("ВидКлиента", ВидКлиента());
	
	Результат = Новый ФиксированнаяСтруктура(Данные);
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЯзыкИнтерфейсаПользователя()
	
	#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентУправляемоеПриложение Или ТолстыйКлиентОбычноеПриложение Тогда
	Результат = ТекущийЯзык().КодЯзыка;
	#Иначе
	Результат = ТекущийЯзык();
	#КонецЕсли
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидКлиента()
	
	Результат = "<undefined>";
	
	#Если ТонкийКлиент Тогда
		Результат = "Тонкий клиент";
	#ИначеЕсли ТолстыйКлиентОбычноеПриложение Тогда
		Результат = "Толстый клиент обычное приложение";
	#ИначеЕсли ТолстыйКлиентУправляемоеПриложение Тогда
		Результат = "Толстый клиент управляемые формы";
	#ИначеЕсли ВебКлиент Тогда
		Результат = "Веб клиент";
	#ИначеЕсли НаСервере Тогда
		Результат = "Сервер";
	#ИначеЕсли ВнешнееСоединение Тогда
		Результат = "Внешнее соединение";
	#КонецЕсли
	
	Возврат Результат;
	
КонецФункции

