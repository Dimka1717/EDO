// Возвращает признак доступности интеграции с Логистикой
// 
// Возвращаемое значение:
//  Булево - признак доступности интеграции с Логистикой
//
&НаКлиенте
Функция КонтурЛогистика_ИспользуетсяМодульЛогистики() Экспорт
	
	ИспользуетсяМодульЛогистики = ОбщийКонтекст_Прочитать("ИспользуетсяМодульЛогистики");
	
	Результат = (ИспользуетсяМодульЛогистики = Истина);
	
	Возврат Результат;
	
КонецФункции

// Открывает Рабочий стол модуля Логистики
//
// Параметры:
//  Период - СтандартныйПериод - Период для Рабочего стола
//
&НаКлиенте
Процедура КонтурЛогистика_ОткрытьРабочийСтол(Период) Экспорт
	
	РаботаСЛогистикой = Модуль_РаботаСЛогистикой(ЭтаФорма);
	
	ТекстОшибки = РаботаСЛогистикой.ОткрытьРабочийСтол(Период);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		Действие = Метрика_НазваниеДействий().ПереходВРабочийСтол;
		КонтурЛогистика_ОбработатьОшибкуВызовСервера(Действие, ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

// Открывает форму с перевозочными документами
//
// Параметры:
//  ФормаВызова		 - Форма	 - Форма, из которой происходит вызов
//  ДокументыУчета	 - Массив	 - Коллекция ссылок на учетные документы пакета
//
&НаКлиенте
Процедура КонтурЛогистика_ОткрытьПеревозочныеДокументы(ФормаВызова, ДокументыУчета) Экспорт
	
	РаботаСЛогистикой = Модуль_РаботаСЛогистикой(ЭтаФорма);
	
	ТекстОшибки = РаботаСЛогистикой.ОткрытьПеревозочныеДокументы(ФормаВызова, ДокументыУчета);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		
		Действие = Метрика_НазваниеДействий().ПереходВСвязанныеДокументы;
		КонтурЛогистика_ОбработатьОшибкуВызовСервера(Действие, ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура КонтурЛогистика_ОбработатьОшибкуВызовСервера(Действие, ТекстОшибки)
	
	Ядро = ОбработкаОбъект();
	
	Ядро.КонтурЛогистика_ОбработатьОшибку(Действие, ТекстОшибки);
	
КонецПроцедуры

//}		ЛОГИСТИКА