//#Область Регистрация_статистики

// Добавляет запись в DD_Statistics с категорией, действием, меткой и представлением.
//
// Параметры:
//  Категория - Строка - идентификатор категории ошибки
//  Действие - Строка - идентификатор действия
//  Метка - Строка - заголовок или название;
//  ДопПеременные - Структура, Соответствие - (Необязательный) значения дополнительных переменных
//  ПредставлениеМетрики - Строка - форма, интерфейс события;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см функцию TraceId();
&НаКлиенте
Процедура Метрика_ДобавитьСтатистику(
	Категория, 
	Действие, 
	Метка = Неопределено, 
	ДопПеременные = Неопределено, 
	ПредставлениеМетрики = "", 
	TraceId = "") Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ПеременныеМетрики = Новый Соответствие;
	
	ДополнитьПеременныеМетрики_BaseId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_BoxId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ПроизвольныеПараметры(ПеременныеМетрики, ДопПеременные);
	
	ДобавитьСисИнфо = Истина;
	
	Метрика_ЗаписатьСтатистику(
		Категория, 
		Действие, 
		Метка, 
		ПеременныеМетрики, 
		ДобавитьСисИнфо, 
		TraceId, 
		ПредставлениеМетрики);
	
КонецПроцедуры


&НаКлиенте
Процедура Метрика_ДобавитьСтатистику_ПоКонтексту(Категория, Действие, Метка = Неопределено, ДопПеременные = Неопределено, ПредставлениеМетрики = "", TraceId = "") Экспорт
	
	Если НЕ ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторБазы1С = ОбщийКонтекст_ИдентификаторБазы1С();
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID", АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId));
		Переменные.Вставить("UserID", СтрокаКонтекста.ОписаниеПользователя.Id);
		Переменные.Вставить("BaseID", ИдентификаторБазы1С);
		Переменные.Вставить("IsTest", СтрокаКонтекста.Ящик.Организация.Тестовая);
		
		Если ДопПеременные <> Неопределено Тогда
			Для Каждого Переменная Из ДопПеременные Цикл
				Переменные.Вставить(Переменная.Ключ, Переменная.Значение);
			КонецЦикла;
		КонецЕсли;
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, Метка, Переменные, , TraceId, ПредставлениеМетрики);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Метрика_ДобавитьСтатистику_СУчетомЗаполненияКонтекста(КатегорияМетрики, ДействиеМетрики, Метка = Неопределено, ДопПеременные = Неопределено, ПредставлениеМетрики = "", TraceId = "") Экспорт

	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьСтатистику_ПоКонтексту(КатегорияМетрики, ДействиеМетрики, Метка, ДопПеременные, ПредставлениеМетрики, TraceId);
	Иначе
		Метрика_ДобавитьСтатистику_ДляОрганизации("", КатегорияМетрики, ДействиеМетрики, Метка, ДопПеременные, ПредставлениеМетрики, TraceId);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Метрика_ДобавитьСтатистику_МассовоеДействиеПоДокументам(
	Категория,
	Действие,
	ДокументыДляОбработки,
	ИсточникОткрытия = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторБазы1С = ОбщийКонтекст_ИдентификаторБазы1С();
	
	СоответствиеДокументов = Новый Соответствие;
	
	СоответствиеОрганизаций1С = Новый Соответствие;
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		
		СлужебнаяИнформация = СвойствоСтруктуры(Документ, "СлужебнаяИнформация");
		КонтрактМЧД = СвойствоСтруктуры(СлужебнаяИнформация, "КонтрактМЧД");
		РегНомерМЧД = СвойствоСтруктуры(КонтрактМЧД, "Идентификатор", "");
		
		// может прийти как массив строк списка, так и массив документов
		Если Документ.Свойство("Идентификаторы") Тогда
			
			BoxId = Документ.Идентификаторы.BoxId;
			
		Иначе
			
			Организация1С = Документ.Организация;
			BoxId = СоответствиеОрганизаций1С[Организация1С];
			Если BoxId = Неопределено Тогда
				BoxId = Организации_ИдентификаторПоСсылке(Организация1С);
				СоответствиеОрганизаций1С.Вставить(Организация1С, BoxId);
			КонецЕсли;
			
		КонецЕсли;
		
		ЗначениеСоответствия = СоответствиеДокументов[BoxId];
		Если ЗначениеСоответствия = Неопределено Тогда
			ЗначениеСоответствия = Новый Структура();
			ЗначениеСоответствия.Вставить("КоличествоДокументов", 0);
			ЗначениеСоответствия.Вставить("РегНомерМЧД" , РегНомерМЧД);
			ЗначениеСоответствия.Вставить("Документ1С" , "");
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ЗначениеСоответствия.Документ1С) Тогда
			Документ1С = СвойствоСтруктуры(Документ, "ДокументУчета");
			Если Не ЗначениеЗаполнено(Документ1С) Тогда
				Документ1С = СвойствоСтруктуры(Документ, "Документ");
			КонецЕсли;
			ЗначениеСоответствия.Вставить("Документ1С" , Документ1С);
		КонецЕсли;
		
		КоличествоДокументов = ЗначениеСоответствия.КоличествоДокументов;
		ЗначениеСоответствия.КоличествоДокументов = КоличествоДокументов + 1;
		
		СоответствиеДокументов.Вставить(BoxId, ЗначениеСоответствия);
		
	КонецЦикла;
	
	Для Каждого Элемент Из СоответствиеДокументов Цикл
		
		ЗначениеСоответствия = Элемент.Значение;
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID", АдресЯщикаВИдентификатор(Элемент.Ключ));
		Переменные.Вставить("Количество документов", ЗначениеСоответствия.КоличествоДокументов);
		Переменные.Вставить("Рег.номер МЧД", ЗначениеСоответствия.РегНомерМЧД);
		Переменные.Вставить("BaseID", ИдентификаторБазы1С);
		
		Если ЗначениеЗаполнено(ЗначениеСоответствия.Документ1С) Тогда
			Переменные.Вставить("doc1CId", СокрЛП(ЗначениеСоответствия.Документ1С.УникальныйИдентификатор()));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИсточникОткрытия) Тогда
			Переменные.Вставить("Источник", СокрЛП(ТипЗнч(ИсточникОткрытия)));
		КонецЕсли;
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
		
	КонецЦикла;
	
КонецПроцедуры

