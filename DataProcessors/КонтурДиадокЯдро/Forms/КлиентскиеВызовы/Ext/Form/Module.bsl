// Процедура вызывает регистрацию ошибки в журнал и сообщение пользователю.
//
// Параметры:
//  ВидОперации			 - Строка - вид операции при которой возникла ошибка.
//  Ошибка - ИнформацияОбОшибке, Строка - структурированная информация об ошибке или текст ошибки
//  ТекстСообщения		 - Строка - текст сообщения пользователю.
//  ИдентификаторФормы	 - УникальныйИдентификатор	 - см. процедуру СообщитьПользователю
//  ПолеФормыСообщения	 - Строка					 - см. процедуру СообщитьПользователю
//
&НаКлиенте
Процедура Ошибка_Обработать(ВидОперации,
	Ошибка,
	ТекстСообщения	 = Неопределено,
	ИдентификаторФормы = Неопределено,
	ПолеФормыСообщения = Неопределено
	) Экспорт
	
	Если ТипЗнч(Ошибка) = Тип("ИнформацияОбОшибке") Тогда
		ПодробныйТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
	Иначе
		ПодробныйТекстОшибки = СокрЛП(Ошибка);
	КонецЕсли;
	
	Ошибка_ОбработатьВызовСервера(
		ВидОперации,
		ПодробныйТекстОшибки,
		ТекстСообщения,
		ИдентификаторФормы,
		ПолеФормыСообщения
	);
	
КонецПроцедуры

&НаСервере
Процедура Ошибка_ОбработатьВызовСервера(Знач ВидОперации,
	Знач ПодробныйТекстОшибки,
	Знач ТекстСообщения	 = Неопределено,
	Знач ИдентификаторФормы = Неопределено,
	Знач ПолеФормыСообщения = Неопределено)
	
	ПодробныйТекстОшибки = _ЗаменитьНедопустимыеСимволыXML(ПодробныйТекстОшибки, " ");
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.Ошибка_Обработать(
		ВидОперации,
		ПодробныйТекстОшибки,
		Неопределено,
		ТекстСообщения,
		ИдентификаторФормы,
		ПолеФормыСообщения
	);
	
КонецПроцедуры

// Заменяет недопустимые символы в XML-строке на заданные символы.
//
// Параметры:
//   Текст - Строка - строка, в которой требуется выполнить замену недопустимых символов.
//   СимволЗамены - Строка - строка, на которую требуется выполнить замену недопустимого символа в XML-строке.
// 
// Возвращаемое значение:
//    Строка
//
&НаКлиентеНаСервереБезКонтекста
Функция _ЗаменитьНедопустимыеСимволыXML(Знач Текст, СимволЗамены = " ")
	
#Если Не ВебКлиент Тогда
	ПозицияНачала = 1;
	Позиция = НайтиНедопустимыеСимволыXML(Текст, ПозицияНачала);
	Пока Позиция > 0 Цикл
		НедопустимыйСимвол = Сред(Текст, Позиция, 1);
		Текст = СтрЗаменить(Текст, НедопустимыйСимвол, СимволЗамены);
		ПозицияНачала = Позиция + СтрДлина(СимволЗамены);
		Если ПозицияНачала > СтрДлина(Текст) Тогда
			Прервать;
		КонецЕсли;
		Позиция = НайтиНедопустимыеСимволыXML(Текст, ПозицияНачала);
	КонецЦикла;
	
	Возврат Текст;
#Иначе
	// Коды символов от 0 до 2^16-1, которые метод НайтиНедопустимыеСимволыXML
	// считает недопустимыми: 0-8, 11-12, 14-31, 55296-57343.
	Итог = "";
	ДлинаСтроки = СтрДлина(Текст);
	
	Для НомерСимвола = 1 По ДлинаСтроки Цикл
		Символ = Сред(Текст, НомерСимвола, 1);
		КодСимвола = КодСимвола(Символ);
		
		Если КодСимвола < 9
		 Или КодСимвола > 10    И КодСимвола < 13
		 Или КодСимвола > 13    И КодСимвола < 32
		 Или КодСимвола > 55295 И КодСимвола < 57344 Тогда
			
			Символ = СимволЗамены;
		КонецЕсли;
		Итог = Итог + Символ;
	КонецЦикла;
	
	Возврат Итог;
#КонецЕсли
	
КонецФункции

// Формирует и выводит сообщение, которое может быть "привязано" к форме.
//
// Параметры:
//  ТекстСообщения     - Строка                  - текст выводимого сообщения.
//  ИдентификаторФормы - УникальныйИдентификатор - идентификатор формы, к которой должно быть "привязано" сообщение.
//                                                 Если не указан, сообщение привязывается к активному окну.
//  ПолеФормы          - Строка                  - путь к реквизиту формы, для которого нужно вывести сообщение.
//
// Варианты вызова:
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'")) - Сообщение будет "привязано" к активной форме.
//
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'"),
//   ОбщийКонтекстКлиентСервер.ИдентификаторФормы)       - Сообщение будет "привязано" к основной форме.
//
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'"),
//   ОбщийКонтекстКлиентСервер.ИдентификаторФормы,
//   "Объект.СписокДокументов[2]")                             - Сообщение выводится в списке документов основной формы
//                                                               рядом со строкой с индексом 2.
//
&НаКлиенте
Процедура Ошибка_СообщитьПользователю(ТекстСообщения, ИдентификаторФормы = Неопределено, ПолеФормы = Неопределено) Экспорт
	
	Сообщение = Новый СообщениеПользователю;
	
	Сообщение.Текст = ТекстСообщения;
	
	Если ЗначениеЗаполнено(ИдентификаторФормы) Тогда
		Сообщение.ИдентификаторНазначения = ИдентификаторФормы;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолеФормы) Тогда
		Сообщение.Поле = ПолеФормы;
	КонецЕсли;
	
	Сообщение.Сообщить();
	
КонецПроцедуры

