Процедура Метрика_НачатьЗамер_СУчетомЗаполненияКонтекстаПоКонтекстуОднойЗаписью(КатегорияМетрики, ДопПеременные = Неопределено) Экспорт
	
	ЭтоНачалоЗамера = Истина;
	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;
	
КонецПроцедуры

// Вызывает процедуру записи окончания замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики  - Строка - Наименование категории замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
&НаКлиенте
Процедура Метрика_ЗавершитьЗамер_СУчетомЗаполненияКонтекстаПоКонтекстуОднойЗаписью(КатегорияМетрики, ДопПеременные = Неопределено) Экспорт
	
	ЭтоНачалоЗамера = Ложь;
	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;
	
КонецПроцедуры

