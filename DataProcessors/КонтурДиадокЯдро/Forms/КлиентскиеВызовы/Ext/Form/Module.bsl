&НаКлиенте
Функция Документы_Расшифровать(Идентификаторы, ОтправлятьРезультатПроверкиПодписи = Истина) Экспорт
	
	Результат = ХранениеДанных_ДанныеХранилища(Идентификаторы, "ХранилищеКонтента");
	
	ТребуетсяРасшифровка = Результат.ТребуетсяРасшифровка;
	
	Если ТребуетсяРасшифровка Тогда
		
		РасшифрованныеДанные	= РасшифроватьДанные(Результат.ЗашифрованныеДанные);
		Результат.Данные		= РасшифрованныеДанные;
		
		ПодписьВерна = Документы_ПроверитьПодпись(Результат);
		
		Результат.Подпись.ПодписьВерна	= ПодписьВерна;
		Результат.ТребуетсяРасшифровка	= Ложь;
		
		Документы_ОтправитьРезультатПроверкиПодписиВызовСервера(Результат, Идентификаторы, ПодписьВерна, ОтправлятьРезультатПроверкиПодписи);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура Документы_ОтправитьРезультатПроверкиПодписиВызовСервера(ДанныеХранилища, Идентификаторы, ПодписьВерна, ОтправлятьРезультатПроверкиПодписи)
	
	Если ОтправлятьРезультатПроверкиПодписи Тогда
		
		ОбработкаОбъект = ОбработкаОбъект();
		
		Попытка
			ОбработкаОбъект.Документы_ОтправитьРезультатПроверкиПодписи(Идентификаторы, ПодписьВерна);
		Исключение
			
			ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Если Найти(НРег(ТекстОшибки), НРег("InvalidDocumentState")) > 0
				ИЛИ Найти(НРег(ТекстОшибки), НРег("Состояние документа не позволяет выполнить действие")) > 0 Тогда
				// Отметка о проверке подписи уже установлена.
			Иначе
				ВызватьИсключение;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЕсли;
	
	ХранениеДанных_ЗаписатьДанныеХранилищаВызовСервера(ДанныеХранилища, "ХранилищеКонтента", Идентификаторы.ДокументЭДО);
	
КонецПроцедуры

&НаКлиенте
Функция Документы_ПроверитьПодпись(ДанныеХранения)
	
	ДвоичныеДанные			= ДанныеХранения.Данные;
	ДвоичныеДанныеПодписи	= ДанныеХранения.Подпись.ДанныеПодписи;
	
	Результат = ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция Документы_ВыполнитьДействиеСДокументами(ДокументыДляОбработки, Знач Действие = "",
	Знач ОтпечатокСертификата = "") Экспорт
	
	Если Действие = Перечисление_ДействияЭДО().АннулироватьШаблон Тогда
		Возврат Документы_АннулироватьШаблоны(ДокументыДляОбработки);
	КонецЕсли;
	
	ПодготовленныеДанные = Документы_ДанныеДляMessagePatchToPostВызовСервера(ДокументыДляОбработки, Действие);
	
	Документы_ПодписатьДанныеДляMessagePatchToPost(ПодготовленныеДанные, ОтпечатокСертификата);
	
	Результат = Документы_ОтправитьДанныеДляMessagePatchToPostВызовСервера(ПодготовленныеДанные);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция Документы_ДанныеДляMessagePatchToPostВызовСервера(ДокументыДляОбработки, Действие)
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.Документы_ДанныеДляMessagePatchToPost(ДокументыДляОбработки, Действие);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура Документы_ПодписатьДанныеДляMessagePatchToPost(ДанныеДляMessagePatchToPost, Знач ОтпечатокСертификата = "") Экспорт
	
	Перем SignedContent;
	
	Для Каждого ДанныеСообщения Из ДанныеДляMessagePatchToPost Цикл
		
		Для Каждого КоллекцияДействия Из ДанныеСообщения.Значение.Коллекции Цикл
			
			Если КоллекцияДействия.Ключ = "UniversalMessages" Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ЭлементКоллекции Из КоллекцияДействия.Значение Цикл
				
				BoxId = ЭлементКоллекции.Документ.Идентификаторы.BoxId;
				
				ДанныеПодписи	= ПодписьДанных(BoxId, ЭлементКоллекции.Данные, ОтпечатокСертификата);
				ДанныеПодписи	= Base64Строка(ДанныеПодписи);
				
				Если ЭлементКоллекции.Attachment.Свойство("Signature") Тогда
					
					ЭлементКоллекции.Attachment.Signature = ДанныеПодписи;
					
				ИначеЕсли ЭлементКоллекции.Attachment.Свойство("SignedContent", SignedContent) Тогда
					
					SignedContent.Content	= Base64Строка(ЭлементКоллекции.Данные);
					SignedContent.Signature	= ДанныеПодписи;
					
				Иначе
					ВызватьИсключение "Не найден контейнер размещения подписи данных!";
				КонецЕсли;
				
				ЭлементКоллекции.Данные = Неопределено;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция Документы_ОтправитьДанныеДляMessagePatchToPostВызовСервера(ПодготовленныеДанные)
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.Документы_ОтправитьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
	
	Возврат Результат;
	
КонецФункции

