// Записывает событие метрики в топик "Behavior"
//
// Параметры:
//  Категория  - Строка - категория события;
//  Действие   - Строка - выполняемое действие;
//  Место      - Строка - место возникновения события;
//  Событие    - Строка - описание события;
//  Переменные - Структура, Соответствие - произвольная информация;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см. функцию TraceId();
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если вместе с событием
//                                         нужно отправить описание окружения;
//
&НаКлиенте
Процедура Метрика_ЗаписатьПоведение(Категория, Действие
	, Представление = Неопределено
	, Метка = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина
	, TraceID = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если TraceID = Неопределено Тогда
		TraceID = TraceId();
	КонецЕсли;
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, Метка, Представление);
	
	ЗарегистрироватьСобытиеМетрики(ТопикиМетрики().Behavior, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

// Записывает событие метрики в топик "Statistics"
//
// Параметры:
//  Категория  - Строка - категория события;
//  Действие   - Строка - выполняемое действие;
//  Событие    - Строка - описание события;
//  Переменные - Структура, Соответствие - произвольная информация;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см. функцию TraceId();
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если вместе с событием
//                                         нужно отправить описание окружения;
//
&НаКлиенте
Процедура Метрика_ЗаписатьСтатистику(Категория, Действие
	, Метка	 = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина
	, TraceID	 = Неопределено
	, ПредставлениеМетрики = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если TraceID = Неопределено ИЛИ TraceID = "" Тогда
		TraceID = TraceId();
	КонецЕсли;
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, Метка, ПредставлениеМетрики);
	
	ЗарегистрироватьСобытиеМетрики(ТопикиМетрики().Statistics, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

// Записывает событие метрики в топик "Log"
//
// Параметры:
//  Категория  - Строка - категория события;
//  Действие   - Строка - выполняемое действие;
//  Событие    - Строка - описание события;
//  Переменные - Структура, Соответствие - произвольная информация;
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если вместе с событием
//                                         нужно отправить описание окружения;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см. функцию TraceId();
//
&НаКлиенте
Процедура Метрика_ЗаписатьЛог(Категория, Действие
	, Метка	 = Неопределено
	, Переменные = Неопределено
	, TraceID	 = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если TraceID = Неопределено Тогда
		TraceID = TraceId();
	КонецЕсли;
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, Метка);
	
	ЗарегистрироватьСобытиеМетрики(ТопикиМетрики().Log, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

// Записывает событие метрики в топик "Health"
//
// Параметры:
//  Категория  - Строка - категория события;
//  Действие   - Строка - выполняемое действие;
//  Событие    - Строка - описание события;
//  Переменные - Структура, Соответствие - произвольная информация;
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если вместе с событием
//                                         нужно отправить описание окружения;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см. функцию TraceId();
//
&НаКлиенте
Процедура Метрика_ЗаписатьЗамер(Категория, Действие
	, Представление = Неопределено
	, Метка = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина
	, TraceID = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если TraceID = Неопределено Тогда
		TraceID = TraceId();
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если Действие = ВариантыДействий.Start Тогда
		ЗамерID = ЗаписатьЗамерID(Категория);
	ИначеЕсли Действие = ВариантыДействий.Finish Тогда
		ЗамерID = ПрочитатьЗамерID(Категория);
		
		ИдентификаторБазы1С = ОбщиеНастройки_ПрочитатьВызовСервера("ИдентификаторБазы1С");
		Переменные.Вставить("BaseID", ИдентификаторБазы1С);
	КонецЕсли;
	
	Переменные.Вставить("ЗамерID", ЗамерID);
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, Метка, Представление);
	
	ЗарегистрироватьСобытиеМетрики(ТопикиМетрики().Health, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

// Записывает событие метрики о начале замера в топик "Health"
//
// Параметры:
//  TraceID    - Строка - идентификатор замера
//  Категория  - Строка - категория события;
//  Место      - Строка - место замера;
//  Переменные - Соответствие, Структура - произвольные данные;
//  ДобавитьСистемнуюИнформацию - Булево    - Истина, если вместе с событием
//                                            нужно отправить описание окружения;
//
&НаКлиенте
Процедура Метрика_НачатьЗамер(TraceID, Категория
	, Место		 = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Действие = "start";
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, , Место);
	
	ЗарегистрироватьСобытиеМетрики(ТопикиМетрики().Health, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

// Записывает событие метрики об окончании замера в топик "Health"
//
// Параметры:
//  TraceID    - Строка - идентификатор замера
//  Категория  - Строка - категория события;
//  Место      - Строка - место замера;
//  Переменные - Соответствие, Структура - произвольные данные;
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если вместе с событием
//                                         нужно отправить описание окружения;
//
&НаКлиенте
Процедура Метрика_ЗакончитьЗамер(TraceID, Категория
	, Место		 = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина) Экспорт
	
