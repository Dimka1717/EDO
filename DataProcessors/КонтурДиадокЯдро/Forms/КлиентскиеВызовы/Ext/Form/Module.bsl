// Замер для нескольких организаций. Создает одну запись замера для всех элементов контекста.
//
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные    - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
&НаКлиенте
Процедура Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные = Неопределено)

	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если ЭтоНачалоЗамера Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	КоллекцияBoxId = Новый Массив;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		
		КоллекцияBoxId.Добавить(ИдентификаторЯщика);
		
	КонецЦикла;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID", КоллекцияBoxId);
	
	Если ДопПеременные <> Неопределено Тогда
		Для каждого Переменная Из ДопПеременные Цикл
			Переменные.Вставить(Переменная.Ключ, Переменная.Значение);			
		КонецЦикла; 
	КонецЕсли;
	
	Метрика_ЗаписатьЗамер(КатегорияМетрики, Действие, , , Переменные);

КонецПроцедуры

// Замер для нескольких организаций. Создает по одной записи замера для каждого элемента контекста.
// 
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные    - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
// 
&НаКлиенте
Процедура Метрика_ДобавитьЗамер_ПоКонтексту(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные = Неопределено)

	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если ЭтоНачалоЗамера Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
	
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID", АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId));
		
		Если ДопПеременные <> Неопределено Тогда
			Для каждого Переменная Из ДопПеременные Цикл
				Переменные.Вставить(Переменная.Ключ, Переменная.Значение);			
			КонецЦикла; 
		КонецЕсли;
		
		Метрика_ЗаписатьЗамер(КатегорияМетрики, Действие, , , Переменные);
		
	КонецЦикла;

КонецПроцедуры

// Замер для одной организации. Создает запись замера при пустом контексте.
// 
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные    - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
// 
&НаКлиенте
Процедура Метрика_ДобавитьЗамер_ДляОрганизации(BoxId, КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные = Неопределено)

	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если ЭтоНачалоЗамера Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	Переменные = Новый Соответствие;
	
	Если ЗначениеЗаполнено(BoxId) Тогда
		Переменные.Вставить("BoxID",	АдресЯщикаВИдентификатор(BoxId));
	КонецЕсли;
	
	Если ДопПеременные <> Неопределено Тогда
		Для каждого Переменная Из ДопПеременные Цикл
			Переменные.Вставить(Переменная.Ключ, Переменная.Значение);			
		КонецЦикла; 
	КонецЕсли;
	
	Метрика_ЗаписатьЗамер(КатегорияМетрики, Действие, , , Переменные);

КонецПроцедуры

// Вызывает процедуру записи замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики  - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера   - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//  ЗамерОднойЗаписью - Булево - Определяет способ записи замера по контексту.
//     * Истина - Одна запись замера для всего контекста;
//     * Ложь   - Запись замера для каждого элемента контекста.
//
&НаКлиенте
Процедура Метрика_ДобавитьЗамер_СУчетомЗаполненияКонтекста(КатегорияМетрики, ЭтоНачалоЗамера = Истина, ДопПеременные = Неопределено, ЗамерОднойЗаписью = Истина) Экспорт

	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		
		Если ЗамерОднойЗаписью Тогда
			Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
		Иначе
			Метрика_ДобавитьЗамер_ПоКонтексту(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
		КонецЕсли;
		
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;

КонецПроцедуры

// Вызывает процедуру записи начала замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики  - Строка - Наименование категории замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
