КонецФункции

&НаСервере
Функция ПодключаемыйМодуль_ОбработатьСобытиеНаСервереВызовСервера(ИмяСобытия, Параметры)
	
	ОбработкаОбъект = ОбработкаОбъект();
	
	Результат = ОбработкаОбъект.ПодключаемыйМодуль_ОбработатьСобытие(ИмяСобытия, Параметры);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура КонтурПлагины_ЗаписатьОшибкуИнициализацииБиблиотеки()
	
	Ошибка = "Модуль не инициализирован (КонтурПлагины)!";
	Операция = "Диадок.Плагины";
	
	Ошибка_Обработать(Операция, Ошибка);
	
КонецПроцедуры

&НаКлиенте
Процедура КонтурПлагины_ОбработатьСобытие(ИмяСобытия, Параметры, Результат)
	
	Если Не ИспользоватьПлагины() Тогда
		Возврат;
	КонецЕсли;
	
	МодульКП = Модуль_КонтурПлагины(ЭтаФорма);
	
	Если МодульКП = Неопределено Тогда
		КонтурПлагины_ЗаписатьОшибкуИнициализацииБиблиотеки();
		Возврат;
	КонецЕсли;
	
	ВладелецНовойФормы = Модуль_ВызовыПМ(ЭтаФорма);
	МодульКП.ВладелецФормы = ВладелецНовойФормы;
	
	Контекст = КонтурПлагины_КонтекстВызова();
	
	Попытка
		
		Параметры.Вставить("РезультатОбработки", Результат);
		МодульКП.ОбработатьСобытие(ИмяСобытия, Параметры, Контекст);
		Параметры.Свойство("РезультатОбработки", Результат);
		
	Исключение
		
		ВидОперации = "Обработка события плагинов на клиенте";
		ТекстСообщения = "Не удалось обработать событие";
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ТекстСообщения);
		
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Функция Модуль_ПМ(ВызывающийМодуль) Экспорт
	
	Результат = Неопределено;
	
	Если ИспользоватьПМ() Тогда
		
		ИмяМодуля = "ПМ";
		ИмяФормыМодуля = "ПодключаемыйМодуль";
		Результат = СоздатьМодуль(ИмяМодуля, ИмяФормыМодуля); 
		
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

