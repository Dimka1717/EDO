&НаКлиенте
Функция СоздатьМодуль(ИмяМодуля, ИмяНовойФормы, ВладелецНовойФормы = Неопределено)
	
	Результат = КэшМодулей_Прочитать(ИмяМодуля);
	
	Если Результат = Неопределено Тогда
		
		ОписаниеОбработки = ПодключенныеОбработки_Прочитать(ИмяМодуля);
		
		Если НЕ ЗначениеЗаполнено(ОписаниеОбработки) Тогда
			
			ПодключитьМодуль(ИмяМодуля);
			ОписаниеОбработки = ПодключенныеОбработки_Прочитать(ИмяМодуля);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОписаниеОбработки) Тогда
			
			Если ВладелецНовойФормы = Неопределено Тогда
				ВладелецНовойФормы = ЭтаФорма;
			КонецЕсли;
			
			ПолноеИмяФормы = ПолноеИмяФормыБиблиотеки(ИмяМодуля, ИмяНовойФормы);
			
			ПредставлениеОшибки = "";
			
			Попытка
				Результат = ПолучитьФорму(ПолноеИмяФормы, , ВладелецНовойФормы);
			Исключение
				ПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
			
			Если Результат = Неопределено Тогда
				
				ПодключитьМодуль(ИмяМодуля);
				
				Попытка
					Результат = ПолучитьФорму(ПолноеИмяФормы, , ВладелецНовойФормы);
				Исключение
					ПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				КонецПопытки;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПредставлениеОшибки) Тогда
				
				Если ОбязательноНаличиеКлиентскойЧасти(ИмяМодуля) Тогда
					
					ВидОперации = НСтр("ru = 'Подключение модуля'");
					ПодробныйТекстОшибки = "Форма: " + ПолноеИмяФормы + Символы.ПС + ПредставлениеОшибки;
					ТекстСообщения = Общее_ПодставитьПараметрыВСтроку("Не удалось подключить модуль %1!", ПолноеИмяФормы);
					
					Ошибка_Обработать(ВидОперации, ПодробныйТекстОшибки, ТекстСообщения);
					
				КонецЕсли;
				
				Возврат Результат;
				
			КонецЕсли;
			
			КэшМодулей_Поместить(ИмяМодуля, Результат);
			
			ПолученныеФормы_ДобавитьОписание(ИмяМодуля, Результат)
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОбязательноНаличиеКлиентскойЧасти(Знач ИмяМодуля)
	
