	ИмяМодуля = ИнтеграционныйМодуль_ПолучитьИмяМакета();
	ИмяФормыМодуля = "ПодключаемыйМодуль";
	Результат = СоздатьМодуль(ИмяМодуля, ИмяФормыМодуля);
	
