//  Структура:
//    * Форма - ФормаКлиентскогоПриложения - форма, для которой вызвано событие.
//    * Назначение - Строка - назначение формы. Допустимые значения: "СопоставлениеНоменклатуры".
//    * СтандартныйЭлемент - Строка - идентификатор стандартного элемента, для которого вызвано событие.
//                                    Допустимые значения: "Характеристика", "Упаковка".
//                         - Неопределено - событие вызвано для элемента, добавленного в переопределяемой части.
//
&НаКлиентеНаСервереБезКонтекста
Функция КонтекстСобытияФормыСопоставленияНоменклатуры()
	
	Результат = Новый Структура;
	Результат.Вставить("Форма");
	Результат.Вставить("Назначение", "СопоставлениеНоменклатуры");
	Результат.Вставить("СтандартныйЭлемент", Неопределено);
	
	Возврат Результат;
	
КонецФункции

