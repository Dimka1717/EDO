//#Область Регистрация_поведения

// Добавляет запись в DD_Behavior с категорией, действием, меткой и представлением.
//
// Параметры:
//  Категория - Строка - Path_Category
//  Действие - Строка - Path_Action
//  Метка - Строка - Path_Label
//  ДопПеременные - Структура, Соответствие - (Необязательный) значения дополнительных переменных
//  ПредставлениеМетрики - Строка - Path_View
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см функцию TraceId();
&НаКлиенте
Процедура Метрика_ДобавитьПоведение(
	Категория,
	Действие,
	Метка = Неопределено,
	ДопПеременные = Неопределено,
	ПредставлениеМетрики = "",
	TraceId = "") Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ПеременныеМетрики = Новый Соответствие;
	
	ДополнитьПеременныеМетрики_BaseId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_BoxId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ПроизвольныеПараметры(ПеременныеМетрики, ДопПеременные);
	
	ДобавитьСисИнфо = Ложь;
	
	Метрика_ЗаписатьПоведение(
		Категория,
		Действие,
		ПредставлениеМетрики,
		Метка,
		ПеременныеМетрики,
		ДобавитьСисИнфо,
		TraceId
	);
	
КонецПроцедуры

&НаКлиенте
Процедура Метрика_ДобавитьПоведение_Согласования(НазваниеФормы, НазваниеКнопки
	, ЗаголовокФормы
	, ЗаголовокКнопки
	, СтатусСогласования
	, BoxId) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория	 = "Основные действия";
	Действие	 = "buttonClick";
	Место		 = НазваниеФормы;
	Событие		 = НазваниеКнопки;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxId"				, АдресЯщикаВИдентификатор(BoxId));
	Переменные.Вставить("СтатусСогласования", СтатусСогласования);
	Переменные.Вставить("Элемент.Заголовок"	, ЗаголовокКнопки);
	Переменные.Вставить("Форма.Заголовок"	, ЗаголовокФормы);
	
