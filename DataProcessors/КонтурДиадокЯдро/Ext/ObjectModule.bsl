// Возвращает значение из общего для всех обработок кэша
//
// Параметры:
//  Ключ - Строка - см. процедуру Кэш_Поместить.
//
// Возвращаемое значение: 
//   Произвольный - см. процедуру Кэш_Поместить.
//
Функция Кэш_Прочитать(Ключ) Экспорт
	
	Кэш = ХранилищеКэш();
	
	Результат = Кэш.Получить(Ключ);
	
	Возврат Результат;
	
КонецФункции

// Помещает значение в общий для всех обработок кэш
//
// Параметры:
//  Ключ     - Строка       - уникальный ключ помещаемого значения.
//  Значение - Произвольный - помещаемое значение.
//
Процедура Кэш_Поместить(Ключ, Значение) Экспорт
	
	Кэш = ХранилищеКэш();
	
	Кэш.Вставить(Ключ, Значение);
	
	ХранилищеКэш_Установить(Кэш);
	
КонецПроцедуры

// Очищает общий для всех обработок кэш.
//
Процедура Кэш_Очистить()
	
	Кэш = ХранилищеКэш();
	
	Если Не ЗначениеЗаполнено(Кэш) Тогда
		Возврат;
	КонецЕсли;
	
	ТипыКоллекций = Новый Соответствие;
	ТипыКоллекций.Вставить(Тип("Массив")			, Истина);
	ТипыКоллекций.Вставить(Тип("Структура")			, Истина);
	ТипыКоллекций.Вставить(Тип("Соответствие")		, Истина);
	ТипыКоллекций.Вставить(Тип("СписокЗначений")	, Истина);
	ТипыКоллекций.Вставить(Тип("ДеревоЗначений")	, Истина);
	ТипыКоллекций.Вставить(Тип("ТаблицаЗначений")	, Истина);
	
	Для Каждого Элемент Из Кэш Цикл
		
		ТипЗначения = ТипЗнч(Элемент.Значение);
		
		Если ТипыКоллекций[ТипЗначения] = Истина Тогда
			Элемент.Значение.Очистить();
		КонецЕсли;
		
	КонецЦикла;
	
	Кэш.Очистить();
	
	ХранилищеКэш_Установить(Кэш);
	
КонецПроцедуры

// Получает коллекцию, в которой хранится кэш
//
Функция ХранилищеКэш()
	
	Если ОбщийКэш = Неопределено Тогда
		
		Если ЭтоОбычноеПриложение() Тогда
			
			ОбщийКэш = ОбщийКонтекст_Прочитать("ОбщийКэш");
			
		Иначе
			
			АдресВХ	 = ОбщийКонтекст_Прочитать("АдресОбщийКэш");
			ОбщийКэш = ВременноеХранилище_Прочитать(АдресВХ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ОбщийКэш;
	
КонецФункции

// Записывает кэш во временное хранилище
// или в общий контекст для обычного приложения
//
// Параметры:
//  НовыйКэш - Соответствие - кэш, который нужно записать во временное хранилище
//
Процедура ХранилищеКэш_Установить(НовыйКэш)
	
	ОбщийКэш = НовыйКэш;
	
	Если Не ЭтоОбычноеПриложение() Тогда
		АдресВХ = ОбщийКонтекст_Прочитать("АдресОбщийКэш");
		ВременноеХранилище_Поместить(НовыйКэш, АдресВХ);
	КонецЕсли;
	
КонецПроцедуры

// Добавляет в общий контекст адрес во временном хранилище
// или соответствие для обычного приложения, в котором будет хранится кэш
//
// Параметры:
//  УИД - УникальныйИдентификатор - идентификатор для записи временное хранилище
//
Процедура ХранилищеКэш_Инициализировать(УИД)
	
	ОбщийКэш = Новый Соответствие;
	
	Если ЭтоОбычноеПриложение() Тогда
		ОбщийКонтекст_Поместить("ОбщийКэш", ОбщийКэш);
	Иначе
		АдресВХ = ВременноеХранилище_Поместить(ОбщийКэш, УИД);
		ОбщийКонтекст_Поместить("АдресОбщийКэш", АдресВХ);
	КонецЕсли;
	
КонецПроцедуры

