// Возвращает из кэш обработку по имени связанного с ней модуля
//
// Параметры:
//  ИмяМодуля - Строка- имя модуля, по которому нужно получить обработку
// 
// Возвращаемое значение:
//  ОбработкаОбъект
//
Функция КэшМодулей_Прочитать(ИмяМодуля)
	
	Результат = Неопределено;
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если ЗначениеЗаполнено(КэшМодулей) Тогда
		
		Результат = КэшМодулей[ИмяМодуля];
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Помещает в кэш обработку по имени связанного с ней модуля
//
// Параметры:
//  ИмяМодуля       - Строка          - имя связанного с обработокой модуля
//  ОбъектОбработки - ОбработкаОбъект - обработка, которую нужно поместить в кэш
//
Процедура КэшМодулей_Поместить(ИмяМодуля, ОбъектОбработки)
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если КэшМодулей = Неопределено Тогда
		КэшМодулей = Новый Соответствие;
	КонецЕсли;
	
	КэшМодулей.Вставить(ИмяМодуля, ОбъектОбработки);
	
	Кэш_Поместить("КэшМодулей", КэшМодулей);
	
КонецПроцедуры

// Очищает кэш объектов обработок модулей
// удаляет в объектах ссылки ядро
//
Процедура КэшМодулей_Очистить()
	
	КэшМодулей = Кэш_Прочитать("КэшМодулей");
	
	Если Не ЗначениеЗаполнено(КэшМодулей) Тогда
		Возврат;
	КонецЕсли;
	
	СвойстваДляОчистки = Новый Структура;
	СвойстваДляОчистки.Вставить("КонтурДиадокЯдро");
	СвойстваДляОчистки.Вставить("ОсновнойМодуль");
	
	Для Каждого Элемент Из КэшМодулей Цикл
		
		Модуль = Элемент.Значение;
		
		Если Модуль <> Неопределено Тогда
			
			ЗаполнитьЗначенияСвойств(Модуль, СвойстваДляОчистки);
			
			Попытка
				Модуль.ЗавершениеРаботыМодуля();
			Исключение
				ИнформацияОбОшибке = ИнформацияОбОшибке();
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
	КэшМодулей.Очистить();
	
	Кэш_Поместить("КэшМодулей", КэшМодулей);
	
КонецПроцедуры

// Добавляет в подключенные обработки описание основного модуля
//
// Параметры:
//  ОсновнойМодуль - ОбработкаОбъект - обработка, которая считается основным модулем
//
