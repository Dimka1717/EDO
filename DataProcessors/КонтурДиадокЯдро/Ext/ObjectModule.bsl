// Заполняет мету в контракте электронного документа
//
// Параметры:
//  Документ - Структура - электронный документ (см. Контракт_Документ)
//  Данные - ФиксированнаяСтруктура - значения для заполнения меты (см. Документы_МетаданныеНеформализованного)
//  ИмяФайлаВложения - Строка - имя файла отправляемого документа
//
Процедура Документы_ЗаполнитьМетуНеформализованного(Документ, Данные, ИмяФайлаВложения)
	
	Документ.Метаданные.FileName = ИмяФайлаВложения;
	Документ.Метаданные.DocumentDate = Данные.Дата;
	Документ.Метаданные.DocumentNumber = Данные.Номер;
	
	Если Документ.Метаданные.Свойство("TotalSum") Тогда
		Документ.Метаданные.TotalSum = Данные.Сумма;
	КонецЕсли;
	
	Если Документ.Метаданные.Свойство("TotalVat") Тогда
		Документ.Метаданные.TotalVat = Данные.СуммаНДС;
	КонецЕсли;
	
	Если Документ.Метаданные.Свойство("CurrencyCode") Тогда
		Документ.Метаданные.CurrencyCode = Данные.КодВалюты;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет информацию о файле вложения в контракте электронного документа
//
// Параметры:
//  Документ - Структура - электронный документ (см. Контракт_Документ)
//  Вложение - ДвоичныеДанные, ТабличныйДокумент - файл вложения
//  ИмяФайлаВложения - Строка - имя файла вложения
//
Процедура Документы_ЗаполнитьВложение(Документ, Вложение, ИмяФайлаВложения)
	
	Если ТипЗнч(Вложение) = Тип("ДвоичныеДанные") Тогда
		
		Файл = Вложение;
		
	Иначе
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("pdf");
		Вложение.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
		Файл = Новый ДвоичныеДанные(ИмяВременногоФайла);
		УдалитьФайлы(ИмяВременногоФайла);
		
	КонецЕсли;
	
	ХранилищеКонтента = Документ.Документооборот.ХранилищеКонтента;
	ХранилищеКонтента.Данные = Файл;
	ХранилищеКонтента.ИмяФайла = ИмяФайлаВложения;
	
КонецПроцедуры

Функция Документы_ЭтоСФ(Документ, ТолькоСФ = Ложь) Экспорт
	
	ТипДокумента		= Документ.Тип.ТипДокумента;
	ФункцияДокумента	= Документ.Тип.ФункцияДокумента;
	
	Результат = ТипДокумента = "Invoice"
			ИЛИ ТипДокумента = "InvoiceCorrection"
			ИЛИ ФункцияДокумента = "СЧФ"
			ИЛИ ФункцияДокумента = "Invoice";
			
	Если НЕ ТолькоСФ Тогда
				
		Результат = Результат 	
			ИЛИ ФункцияДокумента = "СЧФДОП"
			ИЛИ ФункцияДокумента = "КСЧФДИС"
			ИЛИ ФункцияДокумента = "InvoiceAndBasic";
			
	КонецЕсли;	
			
	Возврат Результат;
	
КонецФункции

