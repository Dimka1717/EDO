Функция Новый_СписокДокументов() Экспорт
	
	КлючКэша = СписокДокументов_КлючКэшаКонтрактаСпискаДокументов();
	Результат = Кэш_Прочитать(КлючКэша);
	
	Если Результат = Неопределено Тогда
	
		Результат = Новый ТаблицаЗначений;
		
		ИменаКолонок = КолонкиСпискаДокументовСтрокой();
		ДобавитьКолонкиВТаблицуЗначений(Результат, ИменаКолонок);
		
	Иначе
		Результат = Результат.Скопировать();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_КлючКэшаКонтрактаСпискаДокументов()
	
	Возврат "Новый_СписокДокументов";
	
КонецФункции

Процедура СписокДокументов_ПоместитьВКэшКонтрактСпискаДокументов(ОсновнойМодуль)
	
	Если ОсновнойМодуль <> Неопределено Тогда
		
		Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	    ТЗ = Модуль_ХранениеДанных.Новый_СписокДокументовИзТабличнойЧасти(ОсновнойМодуль.СписокДокументов);
		
		КлючКэша = СписокДокументов_КлючКэшаКонтрактаСпискаДокументов();
		Кэш_Поместить(КлючКэша, ТЗ);
		
	КонецЕсли;
	
КонецПроцедуры

Функция СписокДокументов_Документы(Параметры) Экспорт
	
	Результат = Новый Массив;
	
	ПараметрыСпискаДокументов = Контракт_ПараметрыПолученияСпискаДокументов();
	ЗаполнитьЗначенияСвойств(ПараметрыСпискаДокументов, Параметры);
		
	Режим = Параметры.Режим;
	
	Если Режим = "ОтправкаПакетов" Тогда
		
		Результат			= СписокДокументов_ПодготовленныеПакетыНаОтправку(ПараметрыСпискаДокументов);
		ПакетыНаОтправку	= СписокДокументов_НовыеПакетыНаОтправку(ПараметрыСпискаДокументов);
		ДополнитьТаблицуЗначений(Результат, ПакетыНаОтправку);
		
		ИспользоватьВнутреннийДО = ЗначениеНастройки_ИспользоватьВнутреннийДокументооборот();
		Если ИспользоватьВнутреннийДО Тогда
			ВнутренниеПакетыНовые = ВнутренниеДокументы_ПакетыНаОтправку(ПараметрыСпискаДокументов);
			ДополнитьТаблицуЗначений(Результат, ВнутренниеПакетыНовые);
		КонецЕсли;
		
		СписокДокументов_ДополнитьТаблицуОшибками(Результат);
		
		СписокДокументов_ЗаполнитьСодержимоеПакетаПоВидуПакета(Результат);
		
	ИначеЕсли Режим = "ОтправленныеДокументы" Тогда
		
		Результат = СписокДокументов_ОтправленныеДокументы(ПараметрыСпискаДокументов);
	
	ИначеЕсли Режим = "ПолученныеДокументы" Тогда
		
		Результат = СписокДокументов_ПолученныеДокументы(ПараметрыСпискаДокументов);
		
	ИначеЕсли Режим = "ВнутренниеДокументы" Тогда
		
		Результат = СписокДокументов_ВнутренниеДокументы(ПараметрыСпискаДокументов);
		
	Иначе
		ВызватьИсключение "При получении списка документов, указан неизвестный режим: " + Режим;
	КонецЕсли;
	
	СписокДокументов_УстановитьОтборНаСписок(Результат, ПараметрыСпискаДокументов);
	
	СписокДокументов_ЗаполнитьКлючиПакетов(Результат);
	
	Если Режим = "ОтправкаПакетов" Тогда
		
		Попытка
			СписокДокументов_ЗаполнитьСвязиПакетовНаОтправку(Результат);
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			
			Метрика_ДобавитьОшибку(
				Метрики_КатегорияСписокНаОтправку(),
				"ЗаполнитьСвязиПакетовНаОтправку",
				Ошибка
			);
			
			ВызватьИсключение;
			
		КонецПопытки;
		
	КонецЕсли;
	
	Если Режим <> Перечисление_РежимыПостроенияСпискаДокументов().ОтправкаПакетов
		И КонтурЛогистика_ИспользуетсяМодульЛогистики() Тогда
		КонтурЛогистика_УдалитьИзСпискаПеревозочныеДокументы(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет поле Ключ в строках списка документов значение уникального идентификатора, если документ не был ранее
// отправлен, либо идентификатором пакета документов, если документ уже отправлялся ранее в ящик
//
// Параметры:
//  СписокДокументов - ТаблицаЗначений - список документов
//
Процедура СписокДокументов_ЗаполнитьКлючиПакетов(СписокДокументов)
	
	НомерСтроки = 1;
	
	Для Каждого СтрокаТЗ Из СписокДокументов Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЗ.LetterId) Тогда
			ИдентификаторПакета = СтрокаТЗ.LetterId;
		Иначе
			ИдентификаторПакета = Новый УникальныйИдентификатор;
		КонецЕсли;
		
		СтрокаТЗ.Ключ = ИдентификаторПакета;
		СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняем поле КлючОсновногоПакета в строках списка документов.
// Если это основной пакет, то значение КлючОсновногоПакета равно значению Ключ
// Если это вложенный пакет, то значение КлючОсновногоПакета равно значение Ключ основного строки основного пакета
//
// Параметры:
//  СписокДокументов - ТаблицаЗначений	 - список документов
//
Процедура СписокДокументов_ЗаполнитьСвязиПакетовНаОтправку(СписокДокументов)
	
	ИспользоватьСвязиПакетовНаОтправку = ХранениеДанных_ЕстьНастройкаДобавлятьСчетВПакет();
	
	Если Не ИспользоватьСвязиПакетовНаОтправку Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		
		Если НЕ ЭтоИдентификаторВидаСчет(СтрокаСписка.ВидПакетаID) Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавлятьСчетВПакет = СписокДокументов_ДобавлятьСчетВПакет(СтрокаСписка);
		Если НЕ ДобавлятьСчетВПакет Тогда
			Продолжить;
		КонецЕсли;
		
		СвязанныеДокументы = МенеджерИнтеграции_СвязанныеДокументы(СтрокаСписка.Документ);
		
		Для Каждого ДокументУчета Из СвязанныеДокументы Цикл
			
			Отбор = Новый Структура("Документ", ДокументУчета);
			НайденныеСтроки = СписокДокументов.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаОсновногоПакета Из НайденныеСтроки Цикл
				Если НЕ ЭтоИдентификаторВидаСчет(СтрокаОсновногоПакета.ВидПакетаID) Тогда
					СтрокаСписка.КлючОсновногоПакета 			= СтрокаОсновногоПакета.Ключ;
					СтрокаОсновногоПакета.КлючОсновногоПакета 	= СтрокаОсновногоПакета.Ключ;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	СписокДокументов_ОчиститьКэшНастроекДобавленияСчетаВПакет();
	
КонецПроцедуры

Функция СписокДокументов_ИспользоватьСвязиПакетовНаОтправку() Экспорт
	
	Результат = ХранениеДанных_ЕстьНастройкаДобавлятьСчетВПакет();
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение настройка "Добавлять счет в пакет" для организации или контрагента
//
// Параметры:
//  СтрокаСписка - СтрокаТаблицыЗначений - строка списка документов
// 
// Возвращаемое значение:
//  Булево - Истина, если настройка Добавлять счет в пакет включена
//
Функция СписокДокументов_ДобавлятьСчетВПакет(СтрокаСписка)
	
	КлючНастроек = "ДобавлятьСчетВПакет_ЗначенияНастройки";
	
	НастройкиКэш = Кэш_Прочитать(КлючНастроек);
	Если НастройкиКэш = Неопределено Тогда
		НастройкиКэш = Новый Соответствие;
		Кэш_Поместить(КлючНастроек, НастройкиКэш);
	КонецЕсли;
	
	ОрганизацияИБ 	= СтрокаСписка.Организация;
	КонтрагентИБ 	= СтрокаСписка.Контрагент;
	
	КлючЗначения = XMLСтрока(ОрганизацияИБ) + XMLСтрока(КонтрагентИБ);
	
	Результат = НастройкиКэш.Получить(КлючЗначения);
	Если Результат = Неопределено Тогда
		
		ИдентификаторыСправочника 	= Новый_ИдентификаторыСправочника(ОрганизацияИБ);
		ИдентификаторОрганизации 	= ХранениеДанных_ИдентификаторОрганизации(ИдентификаторыСправочника);
		ИдентификаторыОрганизации 	= Новый_ИдентификаторыСправочника(, ИдентификаторОрганизации);
		
		ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
		
		ИдентификаторыСправочника 	= Новый_ИдентификаторыСправочника(КонтрагентИБ);
		ИдентификаторКонтрагента 	= ХранениеДанных_ИдентификаторКонтрагента(ИдентификаторыСправочника);
		ИдентификаторыКонтрагента 	= Новый_ИдентификаторыСправочника(, ИдентификаторКонтрагента);
		
		ДанныеКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
		
		СохраненноеЗначение = НастройкиДокументов_ЗначениеНастройкиДобавлятьСчетВПакет(ДанныеОрганизации, ДанныеКонтрагента);
		Если СохраненноеЗначение = Неопределено Тогда
			СохраненноеЗначение = НастройкиДокументов_ЗначениеНастройкиДобавлятьСчетВПакет(ДанныеОрганизации);	
		КонецЕсли;
		
		ЗначениеПоУмолчанию 	= Ложь;
		ТипЗначенияНастройки 	= Тип("Булево");
		
		Результат = ЗначениеНастройки(СохраненноеЗначение, ТипЗначенияНастройки, ЗначениеПоУмолчанию);
		
		НастройкиКэш.Вставить(КлючЗначения, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

