// ОТКАЗ В ПОДПИСАНИИ ДОКУМЕНТА

Функция Документы_СтруктураОтказВПодписанииВходящего(Документ)
	
	ИмяКоллекции = "XmlSignatureRejections";
	BoxId = Документ.Идентификаторы.BoxId;
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	ПодписьОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПодписьОтвета", Неопределено);
	
	PowerOfAttorney	= МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	ФормализованныйКонтентОтвета = ТипЗнч(КонтентОтвета) = Тип("ДвоичныеДанные");
	
	ДанныеПодписаны = ЗначениеЗаполнено(ПодписьОтвета);
	
	Если ФормализованныйКонтентОтвета Тогда
		Данные = КонтентОтвета;
	Иначе
		Данные = Документы_ДанныеОтказаВПодписанииВходящего(Документ);
	КонецЕсли;
	
	Если ДанныеПодписаны Тогда
		Content    = Данные;
		Signature  = ПодписьОтвета;
	Иначе
		Content    = "";
		Signature  = "";
	КонецЕсли;
	
	NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Content);
		
	SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Signature);
	
	SignedContent   = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorney);
	Attachment		= АПИ_Новый_ReceiptAttachment(Документ.Идентификаторы.DocumentId, SignedContent);
	
	Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ДанныеОтказаВПодписанииВходящего(Документ)
	
	Результат = Неопределено;
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	DocumentId	= Документ.Идентификаторы.DocumentId;
	
	Комментарий	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", "");
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	SignerContent = Подписант_ЗаполненныйSignerContent(Документ);
	SignatureRejectionGenerationRequestV2 = АПИ_Новый_SignatureRejectionGenerationRequestV2(LetterId, DocumentId, SignerContent, Комментарий.Comment);
	
	Результат = АПИ_GenerateSignatureRejectionXml(ПараметрыСервиса, BoxId, SignatureRejectionGenerationRequestV2);
	
	Возврат Результат;
	
КонецФункции

// Получает двоичные данные xml-файл отказа в подписании документа или предложения для аннулирования.
// Используется в ПМ для генерации упрощенного отказа, без данных МЧД.
//
// Параметры:
//  Идентификаторы		 - Структура - идентификаторы сущности, для которой генерируется отказ
//  ОтпечатокСертификата - Строка	 - отпечаток сертификата
//  ПричинаОтказа		 - Строка	 - Комментарий к отказу
// 
// Возвращаемое значение:
//   - ДвоичныеДанные
//
Функция Документы_ДанныеОтказаВПодписании(Идентификаторы, ОтпечатокСертификата, ПричинаОтказа) Экспорт
	
	Результат = Неопределено;
	
	BoxId = Идентификаторы.BoxId;
	MessageId = Идентификаторы.MessageId;
	EntityId = Идентификаторы.EntityId;
	
	Сертификат = ВнешниеСервисы_Контракт_ОписаниеСертификата();
	Сертификат.ОтпечатокСертификата = ОтпечатокСертификата;
	Сертификат.ЭтоКЭП = Истина;
	
	КонтрактМЧД = Неопределено;
	ПараметрыФормирования = Неопределено;

	SignerContent = ГенерацияXML_УниверсальныйПодписант(Сертификат, КонтрактМЧД, ПараметрыФормирования);
	SignerContent = ДвоичныеДанныеBase64ИзXDTO(SignerContent);
	
	SignatureRejectionGenerationRequestV2 = АПИ_Новый_SignatureRejectionGenerationRequestV2(
		MessageId, 
		EntityId, 
		SignerContent, 
		ПричинаОтказа);
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	Результат = АПИ_GenerateSignatureRejectionXml(ПараметрыСервиса, BoxId, SignatureRejectionGenerationRequestV2);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтруктураУниверсальногоСообщенияДляДействия(Документ, Действие)
	
	Перем UniversalMessage;
	
	BoxId = Документ.Идентификаторы.BoxId;
	LetterId = Документ.Идентификаторы.LetterId;
	EntityId = Документ.Идентификаторы.DocumentId;
	
	ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
	
	Если ФормироватьУС <> Истина Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяКоллекции = "UniversalMessages";
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета");
	
	ТипКонтентаОтвета = ТипЗнч(КонтентОтвета);
	
	Если ТипКонтентаОтвета = Тип("Структура") Тогда
		
		ТекстСообщения = СвойствоСтруктуры(КонтентОтвета, "Comment");
		
	ИначеЕсли ТипКонтентаОтвета = Тип("Строка") Тогда
		
		ТекстСообщения = КонтентОтвета;
		
	ИначеЕсли ТипКонтентаОтвета = Тип("ДвоичныеДанные") Тогда
		
		UniversalMessage = КонтентОтвета;
		
	Иначе
		ТекстСообщения = Неопределено;
	КонецЕсли;
	
	ВариантыОтветаПоДокументу = Перечисление_ВариантыОтветаПоДокументу();
	КодыУниверсальногоСообщения = Перечисление_КодыУниверсальногоСообщения();
	
	Если Действие = ВариантыОтветаПоДокументу.ОтказатьВПодписи
		ИЛИ Действие = ВариантыОтветаПоДокументу.ОтказатьВАннулировании Тогда
		
		КодУС = КодыУниверсальногоСообщения.ОтказВПодписи;
		
		Если Действие = ВариантыОтветаПоДокументу.ОтказатьВАннулировании Тогда
			
			ПредложениеОбАннулировании = Документы_ПредложениеОбАннулировании(Документ);
			EntityId = ПредложениеОбАннулировании.Описание;
			
		КонецЕсли;
		
	ИначеЕсли Действие = ВариантыОтветаПоДокументу.ЗапроситьУточнение Тогда
		
		КодУС = КодыУниверсальногоСообщения.ЗапросУточнения;
		
	Иначе
		
		ТекстИсключения = "Невозможно подготовить данные для выполнения действия: %1";
		ВызватьИсключение Общее_ПодставитьПараметрыВСтроку(ТекстИсключения, Действие);
		
	КонецЕсли;
	
	CodeGroup = УС_КодГруппыУниверсальногоСообщения(КодУС);	
	
	Если UniversalMessage = Неопределено Тогда
		
		Попытка
			ДанныеСообщения = УС_ДанныеУниверсальногоСообщенияПоКонтексту(BoxId, КодУС, ТекстСообщения);
			UniversalMessage = УС_УниверсальноеСообщение(BoxId, LetterId, EntityId, ДанныеСообщения);
		Исключение
			
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			УС_ОбработатьОшибку_СформироватьУниверсальноеСообщение(ТекстОшибки, BoxId, LetterId, EntityId, КодУС);
			
			Возврат Неопределено;
			
		КонецПопытки;
		
	КонецЕсли;
	
	UniversalMessageContent = АПИ_Новый_UnsignedContent(UniversalMessage);
	Attachment = АПИ_Новый_UniversalMessageAttachment(EntityId, UniversalMessageContent, CodeGroup);
	
	Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, UniversalMessage, Документ);
	
	Результат.ЭлементКоллекции.Действие = Действие;
	
	Возврат Результат;
	
КонецФункции

// ЗАПРОС НА УТОЧНЕНИЕ

Функция Документы_СтруктураЗапросаУточненияВходящего(Документ)
	
	ИмяКоллекции  = "CorrectionRequests";
	BoxId = Документ.Идентификаторы.BoxId;
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	ПодписьОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПодписьОтвета", Неопределено);
	
	PowerOfAttorney	= МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	ФормализованныйКонтентОтвета = ТипЗнч(КонтентОтвета) = Тип("ДвоичныеДанные");
	
	ДанныеПодписаны = ЗначениеЗаполнено(ПодписьОтвета);
	
	Если ФормализованныйКонтентОтвета Тогда
		Данные = КонтентОтвета;
	Иначе
		Данные = Документы_ДанныеЗапросаУточнения(Документ);
	КонецЕсли;
	
	Если ДанныеПодписаны Тогда
		Content    = Данные;
		Signature  = ПодписьОтвета;
	Иначе
		Content    = "";
		Signature  = "";
	КонецЕсли;
	
	NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Content);
		
	SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Signature);
	
	SignedContent   = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorney);
	Attachment		= АПИ_Новый_ReceiptAttachment(Документ.Идентификаторы.DocumentId, SignedContent);
	
	Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеЗапросаУточнения(Документ)
	
	Результат = Неопределено;
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	DocumentId	= Документ.Идентификаторы.DocumentId;
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета");
	
	Если ТипЗнч(КонтентОтвета) = Тип("Строка") Тогда
		Комментарий = КонтентОтвета;
	Иначе	
		Комментарий = СвойствоСтруктуры(КонтентОтвета, "Comment", "");
	КонецЕсли;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	SignerContent = Подписант_ЗаполненныйSignerContent(Документ);
	InvoiceCorrectionRequestGenerationRequestV2 = АПИ_Новый_InvoiceCorrectionRequestGenerationRequestV2(LetterId, DocumentId, SignerContent, Комментарий);
	
	Результат = АПИ_GenerateInvoiceCorrectionRequestXml(ПараметрыСервиса, BoxId, InvoiceCorrectionRequestGenerationRequestV2);
	
	Возврат Результат;
	
КонецФункции

// АННУЛИРОВАНИЕ / ОТКАЗ В АННУЛИРОВАНИИ

Функция Документы_ПодписаниеПредложенияОбАннулировании(Документ)
	
	ИмяКоллекции = "Signatures";
	
	ПредложениеОбАннулировании = Документы_ПредложениеОбАннулировании(Документ);
	
	Если ЗначениеЗаполнено(ПредложениеОбАннулировании.Данные) Тогда
		
		PowerOfAttorney	= МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
		
		EntityId	= ПредложениеОбАннулировании.Описание;
		Данные		= ПредложениеОбАннулировании.Данные;
		Attachment	= АПИ_Новый_DocumentSignature(EntityId, "", , , PowerOfAttorney);
		
		Результат	= Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
		
	Иначе
		
		ВидОперации		 		= "Выполнения действия по аннулированию";
		ТекстОшибки		 		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ПредставлениеДокумента	= Документы_ПредставлениеДокумента(Документ, Истина);
		ДопИнформация	 		= "Документ: " + ПредставлениеДокумента;
		ТекстСообщения	 		= НСтр("ru = 'Не удалось получить предложение об аннулировании для подписания'");
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Результат	= Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_НовоеПредложениеОбАннулировании(Документ) Экспорт
	
	ИмяКоллекции = "RevocationRequests";
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	DocumentId	= Документ.Идентификаторы.DocumentId;
	ДокументЭДО	= Документ.Идентификаторы.ДокументЭДО;
	
	Комментарий	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета"	, "");
	
	PowerOfAttorney	= МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Signer					= ЗаполненныйSigner(BoxId);
	RevocationRequestInfo	= АПИ_Новый_RevocationRequestInfo(Комментарий, Signer);
	SignedContent			= АПИ_Новый_SignedContent("", "", , , PowerOfAttorney);
	Attachment	 			= АПИ_Новый_RevocationRequestAttachment(DocumentId, SignedContent);
	
	Попытка
		Данные = АПИ_GenerateRevocationRequestXml(ПараметрыСервиса, BoxId, LetterId, DocumentId, RevocationRequestInfo);
	Исключение
		
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()); 
		ПредставлениеДокумента		 = Документы_ПредставлениеДокумента(Документ, Истина);
		
		ТекстОшибки		 = Документы_ТекстОшибкиАннулирования(ПодробноеПредставлениеОшибки);
		ВидОперации		 = "Выполнения действия по аннулированию";
		ДопИнформация	 = "Документ: " + ПредставлениеДокумента;
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация);
		
	КонецПопытки;
	
	Если Данные = Неопределено Тогда
		Результат = Неопределено;
	Иначе
		Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТекстОшибкиАннулирования(ПодробноеПредставлениеОшибки)

	Результат = ПодробноеПредставлениеОшибки;
	
	Если Найти(ПодробноеПредставлениеОшибки, "Оператор контрагента не поддерживает аннулирование") > 0 Тогда
		Результат = "Оператор контрагента не поддерживает аннулирование.";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ОтказОтПредложенияОбАннулировании(Документ) Экспорт
	
	Результат = Новый Структура;
	
	ИмяКоллекции = "XmlSignatureRejections";
	
	ПредложениеОбАннулировании = Документы_ПредложениеОбАннулировании(Документ);
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	EntityId	= ПредложениеОбАннулировании.Описание;
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	ПодписьОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПодписьОтвета", Неопределено);
	
	PowerOfAttorney	= МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	ФормализованныйКонтентОтвета = ТипЗнч(КонтентОтвета) = Тип("ДвоичныеДанные");
	
	ДанныеПодписаны = ЗначениеЗаполнено(ПодписьОтвета);
	
	Если ФормализованныйКонтентОтвета Тогда
		Данные = КонтентОтвета;
	Иначе
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
		
		Комментарий	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", "");
		
		SignerContent = Подписант_ЗаполненныйSignerContent(Документ);
		
		Попытка
			SignatureRejectionGenerationRequestV2 = АПИ_Новый_SignatureRejectionGenerationRequestV2(LetterId, EntityId, SignerContent, Комментарий);
			Данные = АПИ_GenerateSignatureRejectionXml(ПараметрыСервиса, BoxId, SignatureRejectionGenerationRequestV2);
		Исключение
			
			ВидОперации		 		= "Выполнения действия по аннулированию";
			ТекстОшибки		 		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ПредставлениеДокумента	= Документы_ПредставлениеДокумента(Документ, Истина);
			ДопИнформация	 		= "Документ: " + ПредставлениеДокумента;
			ТекстСообщения	 		= НСтр("ru = 'Не удалось сформировать отказ от предложения об аннулировании'");
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
		КонецПопытки;
		
	КонецЕсли;
	
	Если ДанныеПодписаны Тогда
		Content    = Данные;
		Signature  = ПодписьОтвета;
	Иначе
		Content    = "";
		Signature  = "";
	КонецЕсли;
	
	NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Content);
		
	SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Signature);
	
	SignedContent   = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorney);
	Attachment		= АПИ_Новый_XmlSignatureRejectionAttachment(EntityId, SignedContent);
	
	Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	
	Возврат Результат;
				
КонецФункции

Функция Документы_ПредложениеОбАннулировании(Документ) Экспорт
	
	ИмяХранилища = ?(Документ.Направление = Перечисление_Направления().Исходящее, "ПредложениеОбАннулированииПокупателя", "ПредложениеОбАннулированииПродавца");
	
	Результат = ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, ИмяХранилища);
	
	Возврат Результат;
	
КонецФункции


// ДЕЙСТВИЯ ПОСЛЕ ОТВЕТА

Функция Документы_ПослеОтправкиMessagePatchToPost(ДанныеСообщения, MessagePatch)
	
	Результат = Новый Массив;
	
	Для Каждого КоллекцияДействия Из ДанныеСообщения.Коллекции Цикл
		
		Для Каждого ЭлементКоллекции Из КоллекцияДействия.Значение Цикл
			
			Документ = ЭлементКоллекции.Документ;
			Действие = ЭлементКоллекции.Действие;
			
			Если Действие = Перечисление_ВариантыОтветаПоДокументу().Подписать Тогда
				
				Статус = Перечисление_СтатусыДокументов().Подписан;
				Документы_ОбновлениеПослеПодписанияВходящего(Документ, MessagePatch);
				
			ИначеЕсли Действие = Перечисление_ВариантыОтветаПоДокументу().ОтказатьВПодписи Тогда
				
				Статус = Перечисление_СтатусыДокументов().ОтказаноВПодписиКонтрагенту;
				
			ИначеЕсли Действие = Перечисление_ВариантыОтветаПоДокументу().ЗапроситьУточнение Тогда
				
				Статус = Перечисление_СтатусыДокументов().ОжидаетсяУточнение;	
				
			ИначеЕсли Действие = Перечисление_ВариантыОтветаПоДокументу().Аннулировать Тогда
				
				Если Документ.Статусы.Статус = Перечисление_СтатусыДокументов().ТребуетсяАннулирование Тогда
					Статус = Перечисление_СтатусыДокументов().Аннулирован;
				Иначе
				    Статус = Перечисление_СтатусыДокументов().ОжидаетсяАннулирование;
				КонецЕсли;
				
			ИначеЕсли Действие = Перечисление_ВариантыОтветаПоДокументу().ОтказатьВАннулировании Тогда
				
				Статус = ""; // актуальный статус требуется получить с сервера Диадока.
				
			КонецЕсли;
			
			Документ.РезультатАнализа.ТребуемоеДействиеВДД = "";
			Документ.Статусы.Статус = Статус;
			
			СтруктураРеквизитов = Новый Структура;
			СтруктураРеквизитов.Вставить("ТребуемоеДействиеВДД", "");
			СтруктураРеквизитов.Вставить("Статус", Статус);
			
			ХранениеДанных_ОбновлениеРеквизитовДокумента(Документ.Идентификаторы, СтруктураРеквизитов);
			
			Если ЗначениеЗаполнено(Статус) Тогда
				Документы_ПослеУстановкиСтатуса(Документ.Идентификаторы.ДокументЭДО, Документ.Статусы.Статус);
			КонецЕсли;
			
			Результат.Добавить(Документ);
			
			КатегорияМетрики	= Метрика_НазваниеКатегорииПоДействию(Действие);
			ДействиеМетрики		= Метрика_НазваниеДействияОтветныеДействия(Действие);
			
			Метрика_ДобавитьСтатистику_ДействиеДокументаАПИ(КатегорияМетрики, ДействиеМетрики, Документ);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ОбновлениеПослеПодписанияВходящего(Документ, MessagePatch)
	
	Если Документ.Тип.Формализованный Тогда
		
		ИмяХранилища	= "ТитулПокупателя";
		ДанныеХранения	= Документы_ДанныеТитулаПокупателя(MessagePatch, Документ);
		Документ.Документооборот.Вставить(ИмяХранилища, ДанныеХранения);
		
		ХранениеДанных_ЗаписатьДанныеХранилища(ДанныеХранения, ИмяХранилища, Документ.Идентификаторы.ДокументЭДО);
		
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ДанныеТитулаПокупателя(MessagePatch, Документ)
	
	Результат = Неопределено;
	
	Если ТипЗнч(MessagePatch) = Тип("Структура")
		И MessagePatch.Свойство("Entities") Тогда
		
		Результат = Документы_ДанныхХранения_АПИ(Документ.Идентификаторы, "ТитулПокупателя", MessagePatch.Entities);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ПослеУстановкиСтатуса(ДокументЭДО, Статус)
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ДокументДД",	ДокументЭДО);
	ПараметрыСобытия.Вставить("Статус",		Статус);
	
	ПодключаемыйМодуль_ОбработатьСобытие("ПослеУстановкиСтатусаДокумента", ПараметрыСобытия);
	
КонецПроцедуры


// МАРШРУТИЗАЦИЯ ДОКУМЕНТОВ

Функция Пакеты_МаршрутизироватьДокументы(Пакет) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Пакет",	Неопределено);
	Результат.Вставить("Отказ",	Ложь);
	
	КатегорияМетрики = Метрика_НазваниеКатегории().Согласование;

	Отказ = Ложь;
	
	ПодготовленныеСтруктуры = Пакеты_СтруктураДляМаршрутизацииДокументовПакета(Пакет.Документы);
	
	Для Каждого ПодготовленнаяСтруктура Из ПодготовленныеСтруктуры Цикл
		
		ИдентификаторыMessage = Контракт_ИдентификаторыПакета();
		
		ИдентификаторыMessage.BoxId		= Пакет.Идентификаторы.BoxId;
		ИдентификаторыMessage.LetterId	= ПодготовленнаяСтруктура.Ключ;
		
		OperationId = Новый УникальныйИдентификатор();
		
		Попытка
			
			РезультатОтправки = РезультатPostMessagePatch(ИдентификаторыMessage, ПодготовленнаяСтруктура.Значение, OperationId);
			
			Для Каждого Документ Из Пакет.Документы Цикл
				
				Действие		= Документ.СлужебнаяИнформация.Маршрутизация.Действие;
				ДействиеМетрики	= Метрика_НазваниеДействияМаршрутизации(Действие);
				
				Метрика_ДобавитьСтатистику_ДействиеДокументаАПИ(КатегорияМетрики, ДействиеМетрики, Документ);	
				
			КонецЦикла; 

		Исключение
			
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Для Каждого Документ Из Пакет.Документы Цикл
				
				ВидОперации				= "Маршрутизация документов";
				ТекстСообщения			= "Не удалось выполнить маршрутизацию документов.";
				ПредставлениеДокумента	= Документы_ПредставлениеДокумента(Документ);
				ДопИнформация			= "Документ: " + ПредставлениеДокумента;
				
				Ошибка_Обработать(ВидОперации, ТекстСообщения, ДопИнформация);
				
				Действие		= Документ.СлужебнаяИнформация.Маршрутизация.Действие;
				ДействиеМетрики	= Метрика_НазваниеДействияМаршрутизации(Действие);
				
				Метрика_ДобавитьОшибку_ДляОрганизации(Пакет.Идентификаторы.BoxId, КатегорияМетрики, ДействиеМетрики, ТекстОшибки);
				
			КонецЦикла;
			
			Отказ = Истина;
			
			Прервать;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если НЕ Отказ Тогда
		
		УстановитьСтатусыМаршрутизацииДокументовПакета(Пакет);
		
		//если оставить свойство после успешной маршрутизации, то при отправке пакета он снова попытается маршрутизировать документ
		//и получит ошибку апи
		Для Каждого Документ Из Пакет.Документы Цикл
			Если Документ.СлужебнаяИнформация.Свойство("Маршрутизация") Тогда
				Документ.СлужебнаяИнформация.Удалить("Маршрутизация");
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.Пакет = Пакет;
	Результат.Отказ = Отказ;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_МаршрутизироватьДокументыПакетов(Пакеты) Экспорт
	
	Результат = Новый Массив;
	
	Для каждого Пакет Из Пакеты Цикл
	
		РезультатПоПакету = Пакеты_МаршрутизироватьДокументы(Пакет);
		Результат.Добавить(РезультатПоПакету);
	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_СтруктураДляМаршрутизацииДокументовПакета(ДокументыПакета)
	
	Результат = Новый Соответствие;
	
	Для Каждого Документ Из ДокументыПакета Цикл
		
		Маршрутизация	 = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Маршрутизация");
		Если НЕ ЗначениеЗаполнено(Маршрутизация) Тогда
			Продолжить;
		КонецЕсли; 
		
		BoxId			 = Документ.Идентификаторы.BoxId;
		MessageId		 = Документ.Идентификаторы.LetterId;
		DocumentId		 = Документ.Идентификаторы.DocumentId;
		Действие		 = Документ.СлужебнаяИнформация.Маршрутизация.Действие;
		
		Если Действие = Перечисление_ДействияЭДО().ПередатьНаСогласование Тогда
			
			Attachment	 = ПодготовитьResolutionRequestAttachment(DocumentId, "ApprovementRequest", Маршрутизация);
			ИмяКоллекции = "ResolutionRequests";
			
		ИначеЕсли Действие = Перечисление_ДействияЭДО().ПередатьНаПодпись Тогда
			
			Attachment	 = ПодготовитьResolutionRequestAttachment(DocumentId, "SignatureRequest", Маршрутизация);
			ИмяКоллекции = "ResolutionRequests";
			
		ИначеЕсли Действие = Перечисление_ДействияЭДО().ПередатьПоМаршруту Тогда
			
			Attachment	 = ПодготовитьResolutionRouteAssignment(DocumentId, Маршрутизация);
			ИмяКоллекции = "ResolutionRouteAssignments";
			
		ИначеЕсли Действие = Перечисление_ДействияЭДО().Согласование Тогда
			
			Attachment	 = ПодготовитьResolutionAttachment(DocumentId, "Approve", Маршрутизация);
			ИмяКоллекции = "Resolutions";
			
		ИначеЕсли Действие = Перечисление_ДействияЭДО().ОтказВСогласовании Тогда
			
			Attachment	 = ПодготовитьResolutionAttachment(DocumentId, "Disapprove", Маршрутизация);
			ИмяКоллекции = "Resolutions";
			
		ИначеЕсли Действие = Перечисление_ДействияЭДО().ОтказВЗапросеПодписи Тогда
			
			Attachment	 = ПодготовитьResolutionRequestDenial(BoxId, MessageId, DocumentId, Маршрутизация);
			ИмяКоллекции = "ResolutionRequestDenials";	
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Attachment) Тогда
			
			КоллекцииMessageId = Результат.Получить(MessageId);
			
			Если КоллекцииMessageId = Неопределено Тогда
				
				КоллекцииMessageId = Новый Структура; 
				Результат.Вставить(MessageId, КоллекцииMessageId);
				
			КонецЕсли;
			
			Если НЕ КоллекцииMessageId.Свойство(ИмяКоллекции) Тогда
				КоллекцииMessageId.Вставить(ИмяКоллекции, Новый Массив);
			КонецЕсли;
			
			КоллекцииMessageId[ИмяКоллекции].Добавить(Attachment);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьResolutionRequestAttachment(DocumentId, Type, Маршрутизация)
	
	TargetUserId		= Неопределено;
	TargetDepartmentId	= Неопределено;
	
	Comment = Маршрутизация.Комментарий;
	
	Если ЗначениеЗаполнено(Маршрутизация.UserId) Тогда
		TargetUserId		= Маршрутизация.UserId;
	Иначе
		TargetDepartmentId	= Маршрутизация.DepartmentId;
	КонецЕсли;
	
	Результат = АПИ_Новый_ResolutionRequestAttachment(DocumentId, Type, TargetUserId, TargetDepartmentId, Comment);
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьResolutionRouteAssignment(DocumentId, Маршрутизация)
	
	Comment	= Маршрутизация.Комментарий;
	RouteId	= Маршрутизация.RouteId;
	
	Результат = АПИ_Новый_ResolutionRouteAssignment(DocumentId, RouteId, Comment);
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьResolutionAttachment(DocumentId, ResolutionType, Маршрутизация)
	
	Comment		= Маршрутизация.Комментарий;
	Результат	= АПИ_Новый_ResolutionAttachment(DocumentId, ResolutionType, Comment);
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьResolutionRequestDenial(BoxId, MessageId, DocumentId, Маршрутизация)
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Message = АПИ_GetMessage(ПараметрыСервиса, BoxId, MessageId, DocumentId);
	
	InitialResolutionRequestId 	= EntityIdЗапросаПодписи(Message.Entities);
	Comment						= Маршрутизация.Комментарий;
	
	Результат = АПИ_Новый_ResolutionRequestDenialAttachment(DocumentId, InitialResolutionRequestId, Comment);
	
	Возврат Результат;
	
КонецФункции

Функция EntityIdЗапросаПодписи(Entities)
	
	Результат = "";
	
	SortedEntities = МассивСтруктур_Сортировать(Entities, "RawCreationDate Убыв");
	
	Для Каждого Entity Из SortedEntities Цикл
		
		Если Entity.AttachmentType = "ResolutionRequest" 
			И Entity.ResolutionRequestInfo.RequestType = "SignatureRequest" Тогда
			Результат = Entity.EntityId;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СгруппироватьДокументыПоПакетам(Документы) Экспорт
	
	Перем ДокументыПакета;
	
	СодержимоеПакетов = Новый Структура;
	
	Для Каждого Документ Из Документы Цикл
		
		BoxId		= Документ.Идентификаторы.BoxId;
		LetterId	= Документ.Идентификаторы.LetterId;
		
		КлючПакета = Новый_КлючИдентификатораСообщения(BoxId, LetterId);
		
		Если НЕ СодержимоеПакетов.Свойство(КлючПакета, ДокументыПакета) Тогда
			
			ДокументыПакета = Новый Массив;
			СодержимоеПакетов.Вставить(КлючПакета, ДокументыПакета);
			
		КонецЕсли;
		
		ДокументыПакета.Добавить(Документ);
		
	КонецЦикла;
	
	Результат = Новый Массив;
	
	Для Каждого ЭлементКоллекции Из СодержимоеПакетов Цикл
		
		Пакет = Контракт_Пакет();
		
		ДокументПакета = ЭлементКоллекции.Значение[0];
		
		Пакет.Идентификаторы.BoxId		= ДокументПакета.Идентификаторы.BoxId;
		Пакет.Идентификаторы.LetterId	= ДокументПакета.Идентификаторы.LetterId;
		Пакет.Идентификаторы.ПакетЭДО	= ДокументПакета.Идентификаторы.ПакетЭДО;
		Пакет.Отправитель				= ДокументПакета.Отправитель;
		Пакет.Получатель				= ДокументПакета.Получатель;
		Пакет.Направление				= ДокументПакета.Направление;
		Пакет.ИдентификаторВида			= ДокументПакета.ИдентификаторВидаПакета;
		
		Пакет.Документы = ЭлементКоллекции.Значение;
		
		Результат.Добавить(Пакет);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьСтатусыМаршрутизацииДокументовПакета(Пакет)
	
	ДопСтатусы = Перечисление_ДопСтатусыМаршрутизации();
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДопСтатус = ДопСтатусы[Документ.СлужебнаяИнформация.Маршрутизация.Действие];
		
		Если ЗначениеЗаполнено(ДопСтатус) Тогда
			
			Документ.Статусы.ДополнительныйСтатус = ДопСтатус;
			
			СтруктураРеквизитов = Новый Структура;
			СтруктураРеквизитов.Вставить("ДополнительныйСтатус", ДопСтатус);
			
			ХранениеДанных_ОбновлениеРеквизитовДокумента(Документ.Идентификаторы, СтруктураРеквизитов);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Документы_МассивДокументовДляМаршрутизации(ДокументыЭДО, ПараметрыСогласования) Экспорт
	
	Результат = Новый Массив;
	
	МассивДокументов = ХранениеДанных_МассивДокументов(ДокументыЭДО);
	
	Для Каждого ТекДокумент Из МассивДокументов Цикл
		
		ТекДокумент.СлужебнаяИнформация.Вставить("Маршрутизация", ПараметрыСогласования);
		Результат.Добавить(ТекДокумент);
		
	КонецЦикла;		
	
	Возврат Результат;
	
КонецФункции

