//{		Определение КЭПовости сертификатов 

// Проверяет сертификат на квалифицированность и определяет его тип
//
// Параметры:
//  ПараметрыСервиса	 - Структура
//  ОписаниеСертификата	 - Структура - см. Сертификаты_Контракт_ОписаниеСертификата()
//  СертификатBase64	 - Строка
//  BoxId				 - Строка
//
Процедура Сертификаты_ПроверитьСертификат(ПараметрыСервиса, ОписаниеСертификата, СертификатBase64, BoxId)
	
	КлючКэша = Сертификаты_КлючКэшаРезультатовПроверкиСертификатов();
	
	РезультатыПроверкиСертификатов = Кэш_Прочитать(КлючКэша); 
	
	Если РезультатыПроверкиСертификатов = Неопределено Тогда
		РезультатыПроверкиСертификатов = Новый Соответствие;
	КонецЕсли;
	
	ОтпечатокСертификата = ОписаниеСертификата.ОтпечатокСертификата;
	РезультатПроверки = РезультатыПроверкиСертификатов.Получить(ОтпечатокСертификата);
	
	Если РезультатПроверки = Неопределено Тогда
		
		РезультатПроверки = Сертификаты_РезультатПроверкиСертификата(ПараметрыСервиса, СертификатBase64, BoxId);
		
		ЭтоТестовыйСертификат = Сертификаты_ЭтоТестовыйСертификат(ОписаниеСертификата);
		
		Если ЭтоТестовыйСертификат Тогда
			РезультатПроверки.ЭтоКЭП = Истина;
		КонецЕсли;
		
		РезультатыПроверкиСертификатов.Вставить(ОтпечатокСертификата, РезультатПроверки);
		Кэш_Поместить(КлючКэша, РезультатыПроверкиСертификатов);
		
	КонецЕсли;
	
	ОписаниеСертификата.ЭтоКЭП = РезультатПроверки.ЭтоКЭП;
	
	Если РезультатПроверки.Тип <> Неопределено Тогда
		ОписаниеСертификата.Тип = РезультатПроверки.Тип;
	КонецЕсли;
	
КонецПроцедуры

// Проверяет сертификат на кэповость и определяет его тип через вызов метода АПИ.
// Если в результате проверки возвращается строка,
// значит при проверке произошли ошибки и ответ содержит текст ошибки.
// При ошибках считаем сертификат по умолчанию - КЭП. 
//
// Параметры:
//  ПараметрыСервиса				 - Структура
//  СертификатBase64				 - Строка	 - данные сертификата сконвертированные в строку Base64
//  BoxId							 - Строка
//
// Возвращаемое значение:
//   Булево - Истина, если это КЭП или не удалось выполнить проверку из-за ошибок
//
Функция Сертификаты_РезультатПроверкиСертификата(ПараметрыСервиса, СертификатBase64, BoxId)
	
	Результат = Новый Структура("ЭтоКЭП, Тип");
	
	CertificateVerificationRequest = АПИ_Новый_CertificateVerificationRequest(СертификатBase64);
	
	Ответ = АПИ_VerifyCertificate(ПараметрыСервиса, BoxId, CertificateVerificationRequest);
	
	SubjectType = СвойствоСтруктуры(Ответ, "SubjectType");
	IsValid = СвойствоСтруктуры(Ответ, "IsValid", Истина);
	
	Результат.ЭтоКЭП = IsValid;
	
	Перечисление_SignerType = АПИ_Перечисление_SignerType();
	ТипыСертификатовКЭП = Перечисление_ТипыСертификатовКЭП();
	
	Если SubjectType = Перечисление_SignerType.LegalEntity Тогда
		
		Результат.Тип = ТипыСертификатовКЭП.ЮЛ;
		
	ИначеЕсли SubjectType = Перечисление_SignerType.IndividualEntity Тогда
		
		Результат.Тип = ТипыСертификатовКЭП.ИП;
		
	ИначеЕсли SubjectType = Перечисление_SignerType.PhysicalPerson Тогда
		
		Результат.Тип = ТипыСертификатовКЭП.ФЛ;
		
	Иначе
		Результат.Тип = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

