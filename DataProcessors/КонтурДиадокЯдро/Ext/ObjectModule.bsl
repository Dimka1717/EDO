//{		ИНИЦИАЛИЗАЦИЯ И ЗАВЕРШЕНИЕ РАБОТЫ

// Возвращает новые параметры для инициализации общего контекста
//
// Возвращаемое значение:
//   Структура - содержит свойства:
//    * ВерсияМодуля       - Строка                  - версия вызывающего модуля;
//    * ПолнаяВерсияМодуля - Строка                  - полная версия вызывающего модуля (содержит сборочные метаданные);
//    * КлючРазработчика   - Строка                  - ключ разработчика для обмена данными с сервисом;
//    * ИдентификаторФормы - УникальныйИдентификатор - идентификатор формы для записи значений во временное хранилище;
//    * ОсновнойМодуль     - ОбработкаОбъект         - обработка, которая считается основной;
//    * РежимОтладки       - Булево                  - Истина, если вложенные обработки должны быть созданы из файла,
//                                                     а если файлы изменились, то обработки должны быть загружены повторно
//    * ОбщиеНастройки     - Структура               - см. функцию ХранениеДанных_ОбщиеНастройки() записываются в кэш,
//                                                     необходимы для оптимизации запуска фоновых заданий;
//    * МакетыОбработки    - Структура               - коллекция необходимых макетов, в которой:
//                                                      * Ключ     - имя макета;
//                                                      * Значение - данные макета или путь к файлу с его данными;
//    * АдресDiadocAPI - Строка - точка входа в API Диадока
//    * АдресKonturAPI - Строка - точка входа в API сервисов Контура
//    * АдресUpdateServiceAPI - Строка - точка входа в API сервиса обновлений
//    * АдресSubscriptionsGateway - Строка - точка входа в API шлюза авторизации
//    * Автотест - Булево - Истина, если модуль запущен в режиме тестирования
//    * РасположениеМодуля - Структура, Неопределено - описание способа подключения модуля
//    * ЗапускИзРасширения - Булево - Истина, если модуль подключен как расширение конфигурации
//    * ИмяРасширенияКонтурДиадок - Строка - Идентификатор расширения конфигурации (если модуль подключен как расширение)
//    * ЭтоДлительнаяОперация - Булево - Истина, если инициируется фоновое задание
//    * ПровайдерСервиса - Строка - Идентификатор провайдера облачного сервиса (пустая строка для обычной поставки)
//    * Зависимости - ФиксированныйМассив, Неопределено - список зависимостей (см. Зависимости())
//
Функция ПараметрыИнициализацииОбщегоКонтекста() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ВерсияМодуля", "");
	Результат.Вставить("ПолнаяВерсияМодуля", "");
	Результат.Вставить("КлючРазработчика", "");
	Результат.Вставить("ОсновнойМодуль", Неопределено);
	Результат.Вставить("МакетыОбработки", Неопределено);
	Результат.Вставить("ОбщиеНастройки", Неопределено);
	Результат.Вставить("ИдентификаторФормы", Новый УникальныйИдентификатор);
	Результат.Вставить("РежимОтладки", Ложь);
	Результат.Вставить("АдресDiadocAPI", "https://diadoc-api.kontur.ru");
	Результат.Вставить("АдресKonturAPI", "https://api.kontur.ru");
	Результат.Вставить("АдресUpdateServiceAPI", АдресСервисаОбновленийПоУмолчанию());
	Результат.Вставить("АдресSubscriptionsGateway", АдресШлюзаАвторизацииПоУмолчанию());
	Результат.Вставить("Автотест", Ложь);
	Результат.Вставить("РасположениеМодуля", Неопределено);
	Результат.Вставить("ЗапускИзРасширения", Ложь);
	Результат.Вставить("ЭтоДлительнаяОперация", Ложь);
	Результат.Вставить("ПровайдерСервиса", "");
	Результат.Вставить("ИмяРасширенияКонтурДиадок", "");
	Результат.Вставить("Зависимости", Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Инициализирует общий контекст и общий кэш
//
// Параметры:
//  ПараметрыКонтекста - Структура - см. функцию ПараметрыИнициализацииОбщегоКонтекста()
//
// Возвращаемое значение:
//   Структура - общий контекст, содержит свойства:
//     * ФайловыйРежимРаботы                - Булево - Истина, если база данных работает файловом режиме;
//     * ИспользоватьМетрики                - Булево - Истина, если сбор и отправка статистики разрешена;
//     * ИспользоватьСлужебнуюУчетнуюЗапись - Булево - Истина, если в общих настройках записан логин и
//														пароль служебной учетной записи;
//     * ПараметрыДлительныхОпераций        - Структура - см. Функцию ПараметрыДлительныхОпераций();
//     * ИдентификаторФормы - УникальныйИдентификатор - см. функцию ПараметрыИнициализацииОбщегоКонтекста;
//
Функция ИнициализироватьОбщийКонтекст(ПараметрыКонтекста) Экспорт
	
	УИД = ПараметрыКонтекста.ИдентификаторФормы;
	КоллекцияМакетов = ПараметрыКонтекста.МакетыОбработки;
	ОбщиеНастройки = ПараметрыКонтекста.ОбщиеНастройки;
	ОсновнойМодуль = ПараметрыКонтекста.ОсновнойМодуль;
	
	ЭтоДлительнаяОперация = СвойствоСтруктуры(ПараметрыКонтекста, "ЭтоДлительнаяОперация", Ложь);
	Если НЕ ЭтоДлительнаяОперация Тогда
		ХранилищеКэш_Инициализировать(УИД);
	КонецЕсли;
	
	Макеты_Установить(КоллекцияМакетов);
	ПодключенныеОбработки_ДобавитьЯдро();
	ПодключенныеОбработки_ДобавитьОсновнойМодуль(ОсновнойМодуль);
	
	ОбщийКонтекст_ДобавитьБазовыеПараметры(ПараметрыКонтекста);
	ОбщийКонтекст_Поместить("ИспользуетсяПодсистемаДиадок", ИспользоватьПодсистемуДиадока());
	ОбщийКонтекст_Поместить("ИспользуетсяРасширениеПодсистемыХранения", ИспользуетсяРасширениеПодсистемыХранения());
	ОбщийКонтекст_Поместить("ИспользуетсяМодульЛогистики", КонтурЛогистика_МодульДоступенДляИнтеграции());
	ОбщийКонтекст_Поместить("__Зависимости", ПараметрыКонтекста.Зависимости);
	
	Если ЗначениеЗаполнено(ОбщиеНастройки) Тогда
		ХранениеДанных_ОбщиеНастройки_УстановитьКэш(ОбщиеНастройки);
	КонецЕсли;
	
	ОбщийКонтекст_ДополнитьЗначениямиИзОбщихНастроек(ОбщийКонтекстКлиентСервер);
	
	СписокДокументов_ПоместитьВКэшКонтрактСпискаДокументов(ОсновнойМодуль);
	
	Возврат ОбщийКонтекстКлиентСервер;
	
КонецФункции

Процедура ИнициализироватьФункциональныеОпции() Экспорт
	
	ДанныеФункциональныхОпций = ФункциональныеОпции_Получить(); 
	
	ОбщийКонтекст_Поместить("ФункциональныеОпции", ДанныеФункциональныхОпций);	
	
КонецПроцедуры

// Очищает общий контекст, кэш модулей и общий кэш
// и вложенные в них коллекции.
//
Процедура ЗавершитьРаботуЯдра() Экспорт
	
	Метрики_Отправить();
	
	КэшМодулей_Очистить();
	
	Кэш_Очистить();
	
	ОбщийКонтекст_Очистить();
	
КонецПроцедуры

// Запускает обработчики обновления версии модуля и записывает новый номер версии.
//
// Параметры:
//  НовыйНомерВерсии - Строка - номер текущей версии корневой обработки в формате "РР.ВВ.ПП.СС", где
//                              РР - номер редакции, ВВ - номер версии, ПП - номер патча, СС - номер сборки.
//
Процедура ОбработатьЗапускНовойВерсииМодуля(Знач НовыйНомерВерсии) Экспорт
	
	СохраненныйНомерВерсии = ЗначениеНастройки_СохраненнаяВерсияМодуля();
	
	Если СохраненныйНомерВерсии = НовыйНомерВерсии Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоПервыйЗапуск(СохраненныйНомерВерсии) Тогда
		КонвертацияНастроек_СконвертироватьНастройки();
	Иначе
		УправлениеПМ_ПриЗапускеНовойВерсииМодуля();
	КонецЕсли;
	
	УстановитьЗначениеНастройки_СохраненнаяВерсияМодуля(НовыйНомерВерсии);

	ПослеОбновленияВерсииМодуля();

КонецПроцедуры

Процедура ПослеОбновленияВерсииМодуля()
	
	ИспользоватьПодсистемуДиадока = ОбщийКонтекст_Прочитать("ИспользуетсяПодсистемаДиадок");

	Если ИспользоватьПодсистемуДиадока = Ложь Тогда
		ХранениеДанных_ЗаменитьСвойстваПодразделенийКонтрагентовПриОбновлении_1С();
	КонецЕсли;
	
КонецПроцедуры

//}		ИНИЦИАЛИЗАЦИЯ И ЗАВЕРШЕНИЕ РАБОТЫ


