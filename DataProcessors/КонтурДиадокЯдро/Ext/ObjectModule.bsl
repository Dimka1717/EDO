// Возвращает настройки прокси в формате контракта КоннекторHTTP
// см. КонтурДиадокКоннекторHTTP.СоздатьНастройкиПрокси,
// см. КонтурДиадокКоннекторHTTP.СоздатьНастройкиПроксиДляПротокола
// или Неопределено, если прокси не используется
//
// Возвращаемое значение:
//   - Неопределено, Структура - см. КонтурДиадокКоннекторHTTP.СоздатьНастройкиПрокси
//
Функция АутхНастройкиПрокси() Экспорт
	
	НастройкиПроксиУМ = ОбщиеНастройки_НастройкиПрокси();
	РежимПрокси = НастройкиПроксиУМ.РежимПрокси;
	
	Если РежимПрокси = "UseProxy" Тогда
		
		КоннекторHTTPЛок = Модуль_КоннекторHTTP();
		Результат = КоннекторHTTPЛок.СоздатьНастройкиПрокси();
		Результат.ИспользоватьСистемныеНастройки = Ложь;
		
		КоннекторНастройкиПроксиДляПротокола = КоннекторHTTPЛок.СоздатьНастройкиПроксиДляПротокола();
		
		КоннекторНастройкиПроксиДляПротокола.Сервер = НастройкиПроксиУМ.АдресПроксиСервера;
		КоннекторНастройкиПроксиДляПротокола.Порт = НастройкиПроксиУМ.ПортПроксиСервера;
		КоннекторНастройкиПроксиДляПротокола.Пользователь = НастройкиПроксиУМ.ЛогинПроксиСервера;
		КоннекторНастройкиПроксиДляПротокола.Пароль = НастройкиПроксиУМ.ПарольПроксиСервера;
		
		Результат.ПротоколОбщий = КоннекторНастройкиПроксиДляПротокола;
		
	ИначеЕсли РежимПрокси = "UseDefaultProxy" Тогда
		
		// Будет использован прокси по умолчанию:
		// либо из файла inetcfg.xml, если он расположен на данной машине, либо из настроек Internet Explorer.
		// Пример файла inetcfg.xml можно найти в официальной документации:
		// https://its.1c.ru/db/v8doc#content:26:1:issogl1_3.13.inetcfg.xml

		КоннекторHTTPЛок = Модуль_КоннекторHTTP();
		Результат = КоннекторHTTPЛок.СоздатьНастройкиПрокси();
		Результат.ИспользоватьСистемныеНастройки = Истина;
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает описание текущей конфигурации клиента аутентификации.
// Конфигурация формируется:
// - в соответствии с настройками информационной базы, если они установлены
// - по данным конфигурационного файла, если он содержит все параметры клиента OAuth
// - с дефолтными параметрами в остальных случаях
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельАутхКонфигурацияПриложения
//
Функция АутхКонфигурацияПриложения() Экспорт
	
	Настройки = АутхКонфигурацияПриложенияНастройки();
	КонфигФайл = АутхКонфигурацияПриложенияКонфигФайл();
	
	Если Настройки.Использовать Тогда
		Данные = МодельАутхКонфигурацияПриложения();
		Данные.Имя = Настройки.Имя;
		Данные.Ключ = Настройки.Ключ;
		Данные.Разрешения = АутхРазрешенияПриложения();
	ИначеЕсли ЗначениеЗаполнено(КонфигФайл) Тогда
		Данные = КонфигФайл;
	Иначе
		Данные = АутхКонфигурацияПриложенияПоУмолчанию();
	КонецЕсли;
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

