// Возвращает коллекцию действий ЭДО, которые требуют проверку КЭП при работе с документом
// 
// Возвращаемое значение:
//  Соответствие - Ключ - строка, описывающая действие ЭДО (см. Перечисление_ДействияЭДО)
//					Значение - признак Булево, что действие требует проверку КЭП
//
Функция КЭП_ДействияЭДОТребующиеПроверку()
	
	ДействияЭДО = Перечисление_ДействияЭДО();
	
	Результат = Новый Массив;
	Результат.Добавить(ДействияЭДО.Отправить);
	Результат.Добавить(ДействияЭДО.ПодписатьИОтправить);
	Результат.Добавить(ДействияЭДО.ПереотправитьПакет);
	Результат.Добавить(ДействияЭДО.Аннулировать);
	Результат.Добавить(ДействияЭДО.ОтправитьОтвет);
	Результат.Добавить(ДействияЭДО.Подписать);
	Результат.Добавить(ДействияЭДО.ПодписатьВходящий);
	
	ТребуетсяФормироватьУС = УС_ТребуетсяФормироватьУниверсальныеСообщения();
	
	Если НЕ ТребуетсяФормироватьУС Тогда
		
		Результат.Добавить(ДействияЭДО.ОтказатьВПодписи);
		Результат.Добавить(ДействияЭДО.ОтказатьВАннулировании);
		Результат.Добавить(ДействияЭДО.ЗапроситьУточнение);
		Результат.Добавить(ДействияЭДО.ОтправитьИзвещениеОПолучении	);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

// Проверяет можно ли выполнить действие по организации с учётом КЭП авторизованного сертификата.
// И возвращает список ошибок проверок если действие заблокировано
//
// Параметры:
//	BoxId			- Строка - 
//	ДействиеЭДО		- Строка - значение перечисления Перечисление_ДействияЭДО()
//
// Возвращаемое значение:
//  Неопределено - ошибок проверки КЭП нет, действие разрешено
//  ФиксированныйМассив - список ошибок КЭП, см. КЭП_ПолучитьОшибкиПоСтрокамКонтекста()
//
Функция КЭП_ДоступноДействиеЭДО(ДействиеЭДО, BoxId) Экспорт
	
	Результат = Неопределено;
	
	ДействияТребующиеПроверку = КЭП_ДействияЭДОТребующиеПроверку();
	
	Если ДействияТребующиеПроверку.Найти(ДействиеЭДО) <> Неопределено Тогда
		
		Результат = КЭП_ПолучитьОшибкиПоBoxID(BoxId);
		
		Если ЗначениеЗаполнено(Результат) Тогда
			
			Для каждого ОписаниеОшибкиКЭП Из Результат Цикл
			
				ПредставлениеОшибки = Общее_ПодставитьПараметрыВСтроку(
					"Нельзя выполнить действие. Сертификат %1 не является квалифицированным.",
					ОписаниеОшибкиКЭП.НаименованиеСертификата
				);
				
				Ошибка_Обработать(ДействиеЭДО, ПредставлениеОшибки);
				
			
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет для BoxID наличие ошибки КЭП.
// 
// Параметры:
//	BoxId - Строка - 
//
// Возвращаемое значение:
//	ФиксированныйМассив    - см. КЭП_ПолучитьОшибкиПоСтрокамКонтекста()
//
Функция КЭП_ПолучитьОшибкиПоBoxID(BoxID) Экспорт
	
	Если НЕ ЗначениеЗаполнено(BoxID) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxID);
	
	Результат = КЭП_ПолучитьОшибкиПоСтрокеКонтекста(СтрокаКонтекста);
	
	Возврат Результат;
	
КонецФункции 

// Проверяет для каждой строки контекста ошибки КЭП.
// 
// Возвращаемое значение:
//	ФиксированныйМассив    -  элементы Новый_ОписаниеОшибкиПроверкиКЭП()
//
Функция КЭП_ПолучитьОшибкиПоСтрокамКонтекста() Экспорт
	
	Результат = Новый Массив;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста(Ложь);
	
	Для каждого КлючЗначение Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		
		ОписаниеОшибокКЭП = КЭП_ПолучитьОшибкиПоСтрокеКонтекста(СтрокаКонтекста);
		
		Если ЗначениеЗаполнено(ОписаниеОшибокКЭП) Тогда
			
			ДополнитьМассив(Результат, ОписаниеОшибокКЭП);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый ФиксированныйМассив(Результат);
	
КонецФункции 

// Проверяет для переданной строки контекста ошибки КЭП.
// 
// Параметры:
//	СтрокаКонтекста - ФиксированнаяСтруктура - см. МодельСтрокаКонтекстаСеанса
//
// Возвращаемое значение:
//	ФиксированныйМассив - список ошибок КЭП, элемент массива см Новый_ОписаниеОшибкиПроверкиКЭП()
//
Функция КЭП_ПолучитьОшибкиПоСтрокеКонтекста(СтрокаКонтекста)
	
	Результат = Новый Массив;
	
	Если СтрокаКонтекста.ТребуетсяОплатаСервиса
		Или Не ЗначениеЗаполнено(СтрокаКонтекста.Сертификат) Тогда
		Возврат Новый ФиксированныйМассив(Результат);
	КонецЕсли;
	
	Если Не СтрокаКонтекста.Сертификат.ЭтоКЭП Тогда
		
		ОписаниеОшибки = Новый_ОписаниеОшибкиПроверкиКЭП(
			СтрокаКонтекста.Сертификат.Наименование,
			СтрокаКонтекста.Ящик.Организация.Наименование,
			СтрокаКонтекста.Ящик.Адрес
		);
		
		Результат.Добавить(ОписаниеОшибки);
		
	КонецЕсли;
	
	Возврат Новый ФиксированныйМассив(Результат);
	
КонецФункции 

// Готовит текст в разметке HTML для информирования пользователя о дальнейших действиях
// в случае, если возникли проблемы с сертификатами КЭП
//
// Параметры:
//	СписокОшибокКЭП - Массив 	- см. Новый_ОписаниеОшибкиПроверкиКЭП()
