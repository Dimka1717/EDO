//	последующей отправки отмены фиксации маркированной продукции
// Параметры:
//  boxId - Строка - идентификатор ящика
//  ИНН   - Строка - ИНН организации
//
// Возвращаемое значение:
// Массив - Коллекция структур в составе которой поля
//		для формирования MessagePatchToPost для отмены фиксации
//
Функция ОтменаФиксации_ПолучитьДанные(BoxId, ИНН) Экспорт
	
	Результат = Новый Массив;
	
	ПраваПользователя = ПраваПользователяЯщикаОрганизации(BoxId);
	
	Если НЕ ПраваПользователя.CanSignDocuments Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивДокументов = Новый Массив;
	
	ВнутренниеДокументы = ОтменаФиксации_СписокДокументовВнутренние(BoxId);
	ИсходящиеДокументы = ОтменаФиксации_СписокДокументовИсходящие(BoxId);
	
	ДополнитьМассив(МассивДокументов, ВнутренниеДокументы);
	ДополнитьМассив(МассивДокументов, ИсходящиеДокументы);
	
	Для Каждого Document Из МассивДокументов Цикл
		
		ИмяФайла = Document.FileName;
		ДвоичныеДанныеКонтента = Новый_ДвоичныйКонтентОтменыФиксации(
				ИмяФайла,
				ИНН);
		
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("MessageId", Document.MessageId);
		СтруктураДанных.Вставить("DocumentId", Document.EntityId);
		СтруктураДанных.Вставить("Content", ДвоичныеДанныеКонтента);
		Результат.Добавить(СтруктураДанных);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОтменаФиксации_СписокДокументовВнутренние(boxId)
	
	Результат = Новый Массив;
	
	AfterIndexKey = "";
	
	Пока Истина Цикл
		
		FilterCategory = "Any.InternalHaveToCancelTtGisFixation";
		DocumentList = ОтменаФиксации_СписокДокументов(
				boxId,
				FilterCategory,
				AfterIndexKey);
		
		Если НЕ ЗначениеЗаполнено(DocumentList.Documents) Тогда
			Прервать;
		КонецЕсли;
		
		Для Каждого Document Из DocumentList.Documents Цикл
			
			AfterIndexKey = Document.IndexKey;
			Результат.Добавить(Document);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОтменаФиксации_СписокДокументовИсходящие(boxId)
	
	Результат = Новый Массив;
	
	AfterIndexKey = "";
	
	Пока Истина Цикл
		
		FilterCategory = "Any.OutboundHaveToCancelTtGisFixation";
		DocumentList = ОтменаФиксации_СписокДокументов(
				boxId,
				FilterCategory,
				AfterIndexKey);
		
		Если НЕ ЗначениеЗаполнено(DocumentList.Documents) Тогда
			Прервать;
		КонецЕсли;
		
		Для Каждого Document Из DocumentList.Documents Цикл
			
			AfterIndexKey = Document.IndexKey;
			Результат.Добавить(Document);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ДвоичныйКонтентОтменыФиксации(Знач ИмяФайла, Знач ИНН) Экспорт
	
	ИДФайл = СтрЗаменить(ИмяФайла, ".xml", "");
	ИДФайл = "FIX_" + ИДФайл;
	
	ОтменаФиксации = Новый_ОтменаФиксации(ИДФайл, ИНН);
	
	СтроковыеДанныеОтвета = ПарсерJSON_Записать(ОтменаФиксации);
	Результат = ДвоичныеДанныеИзСтроки(СтроковыеДанныеОтвета);
	
	Возврат Результат;

КонецФункции

Функция Новый_ОтменаФиксации(Знач ИДФайл, Знач ИНН)
	
	Результат = Новый Структура;
	Результат.Вставить("inn", ИНН);
	Результат.Вставить("fixation_document_id", ИДФайл); 
	
	Возврат Результат;

КонецФункции

// Возвращает массив документов из ящика boxId, подходящих под определенный фильтр
//
// Параметры:
//  boxId            - Строка - идентификатор ящика
//  FilterCategory   - Строка - фильтр списка документов
//  afterIndexKey    - Строка - уникальный ключ документа, позволяющий итерироваться
//                               по всему списку документов, удовлетворяющих фильтру
//
// Возвращаемое значение:
//  Структура - см. функцию Модуль_МетодыAPI().DD_API_DS_DocumentList()
//
Функция ОтменаФиксации_СписокДокументов(boxId, FilterCategory, afterIndexKey)
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Попытка
		
		Результат = АПИ_GetDocuments(
				ПараметрыСервиса,
				boxId,
				filterCategory,
				Неопределено,
				Неопределено,
				Неопределено,
				Неопределено,
				Неопределено,
				Неопределено,
				Неопределено,
				Неопределено,
				afterIndexKey);
		
	Исключение
		
		Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
		
		Результат = Модуль_МетодыAPI.DD_API_DS_DocumentList();
		
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОтменаФиксации_ОбработатьОшибку_GetDocuments(
			ТекстОшибки,
			afterIndexKey,
			boxId,
			filterCategory);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Процедура ОтменаФиксации_Подписать(ОтпечатокСертификата, ДанныеОтменыФиксации) Экспорт
	
	Для Каждого СтруктураДанных Из ДанныеОтменыФиксации Цикл
		
		ДвоичныеДанныеПодписи = ПодписатьДанные(
				СтруктураДанных.Content,
				ОтпечатокСертификата);
		
		СтруктураДанных.Вставить("Signature", ДвоичныеДанныеПодписи);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтменаФиксации_Отправить(BoxId, ДанныеОтменыФиксации) Экспорт
	
	ИмяСобытия = "Диадок.ОтправкаОтменыФиксации";
	
	ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаРегистрации.Информация,
		Неопределено,
		Неопределено,
		"Начало отправки");
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	ДанныеМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(BoxId);
	
	PowerOfAttorney = Неопределено;
	Если ДанныеМЧД.ТребуетсяМЧД И ЗначениеЗаполнено(ДанныеМЧД.МЧД) Тогда
		КонтрактМЧД = ДанныеМЧД.СписокМЧД.Получить(ДанныеМЧД.МЧД);
		PowerOfAttorney = АПИ_Новый_PowerOfAttorneyToPost(КонтрактМЧД);
	КонецЕсли;
	
	Для Каждого СтруктураДанных Из ДанныеОтменыФиксации Цикл
		
		Если НЕ СтруктураДанных.Свойство("Signature") Тогда
			Продолжить;
		КонецЕсли;
		
		MessageId = СтруктураДанных.MessageId;
		DocumentId = СтруктураДанных.DocumentId;
		
		SignedContent = АПИ_Новый_SignedContent(
				СтруктураДанных.Content,
				СтруктураДанных.Signature,
				Неопределено,
				Неопределено,
				PowerOfAttorney);
		
		TtGisFixationCancellationRequestAttachment = АПИ_Новый_TtGisFixationCancellationRequestAttachment(
				DocumentId,
				SignedContent);
		
		TtGisFixationCancellationRequests = Новый Массив;
		TtGisFixationCancellationRequests.Добавить(TtGisFixationCancellationRequestAttachment);
		
		MessagePatchToPost = АПИ_Новый_MessagePatchToPost(BoxId, MessageId);
		MessagePatchToPost.Вставить(
			"TtGisFixationCancellationRequests",
			TtGisFixationCancellationRequests);
		
		Попытка
			
			АПИ_PostMessagePatch(ПараметрыСервиса, MessagePatchToPost);
			
		Исключение
			
			ВидОперации = "Отправка отмены фиксации ГИСМТ";
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения = "Не удалось отправить отмену фиксации";
			ДопИнформация = "Документ: " + СформироватьСсылкуВБраузере(BoxId, MessageId, DocumentId);
			
			Ошибка_Обработать(
				ВидОперации,
				ТекстОшибки,
				ДопИнформация,
				ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	ЗаписьЖурналаРегистрации(
		ИмяСобытия,
		УровеньЖурналаРегистрации.Информация,
		Неопределено,
		Неопределено,
		"Окончание отправки");
	
КонецПроцедуры

Процедура ОтменаФиксации_ОбработатьОшибку_GetDocuments(ТекстОшибки, Знач afterIndexKey, Знач boxId, Знач filterCategory)
	
	ВидОперации = "Получение документов отмены фиксации";
	ТекстСообщения = "Не удалось получить список документов, требующих отмены фиксации";
	
	ДопИнформация = Новый Массив;
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("boxId: %1", boxId));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("filterCategory: %1", filterCategory));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("afterIndexKey: %1", afterIndexKey));
	
	Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
	
КонецПроцедуры

