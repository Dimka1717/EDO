// Регистрирует метрики на запуск модуля
//
Процедура МетрикиКонтур_ЗаписатьСобытие_Запуск() Экспорт
	
	Если Не ИспользоватьМетрикиКонтур() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "Запуск";
	Действие = "ЗапускМодуля";
	
	Событие = МетрикиКонтур_НовоеСобытие(Категория, Действие);
	Событие.AppContext.Hardware.Вставить("CoresCount", 1);
	
	МетрикиКонтур_Записать(Событие);
	
КонецПроцедуры

// Регистрирует метрики на авторизацию
//
Процедура МетрикиКонтур_ЗаписатьСобытие_Авторизация() Экспорт
	
	Если Не ИспользоватьМетрикиКонтур() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "Авторизация";
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого СтрокаКонтекста Из СтрокиКонтекста Цикл
		
		КонтекстЯщика = СтрокаКонтекста.Значение;
		
		BoxId = КонтекстЯщика.Box.BoxIdGuid;
		
		СхемаАутентификации = КонтекстЯщика.Сессия.СхемаАутентификации;
		
		Если СхемаАутентификации = СхемаАутентификацииДиадокПароль() Тогда
			Действие = "Пароль";
		ИначеЕсли СхемаАутентификации = СхемаАутентификацииДиадокСертификат() Тогда
			Действие = "Сертификат";
		ИначеЕсли СхемаАутентификации = СхемаАутентификацииПорталБраузер() Тогда
			Действие = "oidc_deviceflow";
		Иначе
			Ошибка = Общее_ПодставитьПараметрыВСтроку("Неизвестная схема аутентификации (%1)", СхемаАутентификации);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		Событие = МетрикиКонтур_НовоеСобытие(Категория, Действие, BoxId);
		МетрикиКонтур_Записать(Событие);
		
	КонецЦикла;
	
КонецПроцедуры

// Регистрирует метрики на запись настроек организаций (из МПЗ)
//
// Параметры:
//  НастроенныеBoxId - Массив из Строка - список BoxId
//
Процедура МетрикиКонтур_ЗаписатьСобытие_Настройка(НастроенныеBoxId) Экспорт
	
	Если Не ИспользоватьМетрикиКонтур() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "Настройка";
	Действие = "СтартовыйПомощник";
	
	Для Каждого BoxId Из НастроенныеBoxId Цикл
		
		Событие = МетрикиКонтур_НовоеСобытие(Категория, Действие, BoxId);
		МетрикиКонтур_Записать(Событие);
		
	КонецЦикла;
	
КонецПроцедуры

