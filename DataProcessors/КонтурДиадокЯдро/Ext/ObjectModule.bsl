Функция Документы_ВидыДокументовДляПодписания(Документы) Экспорт
	
	Результат = Новый Соответствие;
	
	Для Каждого Документ Из Документы Цикл
		
		BoxId			= Документ.Идентификаторы.BoxId;
		ТипДокумента	= Документ.Тип.ТипДокумента;
		ТипКонтента		= Документ.Тип.ТипКонтента;
		
		Если Не Документы_ФормироватьОтветныйТитул(Документ) Тогда
			ТипКонтента = "";
		КонецЕсли;
		
		КлючВидаДокумента = BoxId + "_" + ТипДокумента + "_" + ТипКонтента;
		
		Если Результат.Получить(КлючВидаДокумента) = Неопределено Тогда
			
			ДанныеДляПодписания = Новый Структура;
			ДанныеДляПодписания.Вставить("BoxId",			BoxId);
			ДанныеДляПодписания.Вставить("ТипДокумента",	ТипДокумента);
			ДанныеДляПодписания.Вставить("ТипКонтента",		ТипКонтента);
			ДанныеДляПодписания.Вставить("ДанныеОтвета",	Неопределено);
			
			Результат.Вставить(КлючВидаДокумента, ДанныеДляПодписания);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

