Функция ХранениеДанных_УчастникДО_Контрагенты(ИдентификаторыКонтрагента, ИдентификаторыОрганизации)
	
	УчастникиЭДО = Кэш_Прочитать("УчастникиЭДО_Контрагенты");
	
	Если УчастникиЭДО = Неопределено Тогда
		
		УчастникиЭДО = Новый Соответствие;
		Кэш_Поместить("УчастникиЭДО_Контрагенты", УчастникиЭДО);
		
	КонецЕсли;
	
	КлючКонтрагента = Новый_КлючИдентификаторовСправочника(ИдентификаторыКонтрагента);
	КлючОрганизации = Новый_КлючИдентификаторовСправочника(ИдентификаторыОрганизации);
	
	Ключ = КлючКонтрагента + "-" + КлючОрганизации;
	
	Результат = УчастникиЭДО.Получить(Ключ);
	
	Если Результат = Неопределено Тогда
	
		Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
		Результат = Модуль_ХранениеДанных.Контрагенты_УчастникДО(ИдентификаторыКонтрагента, ИдентификаторыОрганизации);
		
		Если ЗначениеЗаполнено(Результат.Наименование) Тогда
			УчастникиЭДО.Вставить(Ключ, Результат);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

