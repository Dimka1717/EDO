КонецФункции

Процедура СписокДокументов_ДополнитьТаблицуОшибками(ТаблицаДокументов)
	
	Для каждого СтрокаСписка Из ТаблицаДокументов Цикл
	
		Ключ = Новый_КлючИдентификатораСтроки(СтрокаСписка.Документ, СтрокаСписка.ВидПакетаID);
		
	    ТекстОшибки = КэшОшибокСтрокСписка_Получить(Ключ);
		
		Если ТекстОшибки <> Неопределено Тогда
			СтрокаСписка.ОшибкиПроверкиТекст = ТекстОшибки;
		КонецЕсли;
			
	КонецЦикла; 
	
КонецПроцедуры	

Функция Новый_КлючИдентификатораСтроки(ДокументУчета, ВидПакета)
	
	Если ЗначениеЗаполнено(ДокументУчета) Тогда
		Результат = "УИД_" + ДокументУчета.УникальныйИдентификатор() + "_ID_" + ВидПакета;
	Иначе
		Результат = Неопределено;
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Процедура КэшОшибокСтрокСписка_Поместить(ИдентификаторСтроки, ТекстОшибки)
	
	Если ИдентификаторСтроки <> Неопределено Тогда
		
		ОшибкиСтрокиСписка = Кэш_Прочитать("ОшибкиСтрокиСписка");
		
		Если ОшибкиСтрокиСписка = Неопределено Тогда
			
			ОшибкиСтрокиСписка = Новый Соответствие;
			Кэш_Поместить("ОшибкиСтрокиСписка", ОшибкиСтрокиСписка);
			
		КонецЕсли;
		
		ОшибкиСтрокиСписка.Вставить(ИдентификаторСтроки, ТекстОшибки);
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура КэшОшибокСтрокСписка_Удалить(ИдентификаторСтроки)
	
	Если ИдентификаторСтроки <> Неопределено Тогда
		
		ОшибкиСтрокиСписка = Кэш_Прочитать("ОшибкиСтрокиСписка");
		
		Если ОшибкиСтрокиСписка <> Неопределено Тогда
			
			ОшибкиСтрокиСписка.Удалить(ИдентификаторСтроки);
			Кэш_Поместить("ОшибкиСтрокиСписка", ОшибкиСтрокиСписка);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция КэшОшибокСтрокСписка_Получить(ИдентификаторСтроки)
	
	Результат = Неопределено;
	
	Если ИдентификаторСтроки <> Неопределено Тогда
		
		ОшибкиСтрокиСписка = Кэш_Прочитать("ОшибкиСтрокиСписка");
		
		Если ОшибкиСтрокиСписка <> Неопределено Тогда
			Результат = ОшибкиСтрокиСписка.Получить(ИдентификаторСтроки);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаписатьОшибкуВалидацииПолучателяПереотправляемогоПакета(ДанныеЭД, ПредставлениеДокумента, Контрагент)
	
	ПараметрыФормы = ПараметрыФормыЭлементаСправочника_КонтрагентыДиадок(ДанныеЭД);
			
	Если ЭтоУправляемоеПриложение() Тогда
		
		ИмяОткрываемойФормы = "ФормаЭлементаСправочникаУправляемая";
		
	Иначе
		
		ИмяОткрываемойФормы = "ФормаЭлементаСправочника";
		
	КонецЕсли;
	
	ПараметрыСсылки = СписокОшибок_НовыеПараметрыРасшифровки("");
	ПараметрыСсылки.Вставить("ПараметрыФормы"	, ПараметрыФормы);
	ПараметрыСсылки.Вставить("ИмяФормы"			, ИмяОткрываемойФормы);
	
	РасшифровкаОшибок		= Новый Массив;
	ПредставлениеСсылки		= "Контрагент";
	ДействиеОткрытьФорму	= СписокОшибок_Перечисление_ВидыДействийСпискаОшибок().ОткрытьФормуОбработки;
	
	СписокОшибок_ДобавитьРасшифровкуВМассив(
		РасшифровкаОшибок,
		ПараметрыСсылки,
		ПредставлениеСсылки,
		ДействиеОткрытьФорму
	);
	
	ВидОперации = "Отправка документа";
	
	ТекстСообщения =
		НСтр(
			"ru='Для документа " + ПредставлениеДокумента + " нельзя выполнить действие: переотправить.
			|Контрагент """ + Контрагент + """ не сопоставлен. Перейдите в карточку контрагента и сопоставьте его. '"
		);
	
	СписокОшибок_ДобавитьОшибку(
		ВидОперации,
		ТекстСообщения,
		РасшифровкаОшибок
	);
	
КонецПроцедуры

Функция ПараметрыФормыЭлементаСправочника_КонтрагентыДиадок(ДанныеЭД)
	
	ОрганизацияСсылка	= Неопределено;
	КонтрагентСсылка	= Неопределено;
			
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(
		ОрганизацияСсылка,
		ДанныеЭД.Отправитель.BoxId
	);
	
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(
		КонтрагентСсылка,
		ДанныеЭД.Получатель.BoxId
	);
	
	ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	ДанныеКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ID"				, ДанныеКонтрагента.ID);
	ПараметрыФормы.Вставить("ДанныеКонтрагента"	, ДанныеКонтрагента);
	ПараметрыФормы.Вставить("ДанныеОрганизации"	, ДанныеОрганизации);
	ПараметрыФормы.Вставить("ИмяСправочника"	, "Контрагенты");
	
	Возврат ПараметрыФормы; 
	
КонецФункции

Функция ТаблицаСвойстваТипОснованияПоВидуДокумента()
	
	ВидыДокументов = ВидыЭлектронныхСчетовНаОплату();
	
	Результат = ХранениеДанных_ТаблицаСвойстваТипОснованияПоВидуДокумента(ВидыДокументов);
	
	Возврат Результат;
	
КонецФункции

// ОТВЕТНЫЕ ДЕЙСТВИЯ ДОКУМЕНТА

// Возвращает список действий в Диадоке, которые можно выполнить с документом
// Если наличие ошибок в контенте документа неизвестно, то возвращаются все доступные действия
//
// Параметры:
//  ДокументЭДО - СправочникСсылка.Диадок_Документы - Документ Диадока
//  ОшибокНет  - Неопределено, Булево - Флаг наличия ошибок в контенте документа.
//                  Варианты значения:
//                      Неопределено - Наличие ошибок неизвестно
//                      Истина       - Ошибок нет
//                      Ложь         - Ошибки есть
//
// Возвращаемое значение - СписокЗначений - список элементов из Перечисление_ВариантыОтветаПоДокументу
//
Функция Документы_ВариантыОтветныхДействий(ДокументЭДО, ОшибокНет = Неопределено) Экспорт
	
	Результат = Новый СписокЗначений;
	
	Документ = Документы_СохраненныйДокумент(ДокументЭДО);
	
	BoxId = Документ.Идентификаторы.BoxId;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	
	Если Не ЗначениеЗаполнено(СтрокаКонтекста)
		Или Не ЗначениеЗаполнено(СтрокаКонтекста.Сертификат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ВариантыОтветаПоДокументу = Перечисление_ВариантыОтветаПоДокументу();
	
	Если Документы_МожноПодписатьВходящий(Документ) Тогда
		
		Если ОшибокНет <> Ложь Тогда
			Результат.Добавить(ВариантыОтветаПоДокументу.Подписать, "Подписать");
		КонецЕсли;
		
		Если ОшибокНет <> Истина Тогда
			Результат.Добавить(ВариантыОтветаПоДокументу.ОтказатьВПодписи, "Отказать в подписи");
		КонецЕсли;
		
	КонецЕсли;
	
	Если Документы_МожноЗапроситьУточнениеВходящегоДокумента(Документ) Тогда
		
		Если ОшибокНет <> Истина Тогда
			Результат.Добавить(ВариантыОтветаПоДокументу.ЗапроситьУточнение, "Запросить уточнение");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ПолучитьПустойКонтентОтвета(ДокументЭДО, Вердикт) Экспорт
	
	Документ	= Документы_СохраненныйДокумент(ДокументЭДО);
	ТипКонтента	= Документ.Тип.ТипКонтента;

	ТипКонтентаОтвета	= Документы_ТипКонтентаОтвета(ТипКонтента, Вердикт);
	Результат			= ГенерацияXML_ПолучитьПустуюПротоСтруктуру(ТипКонтентаОтвета, Истина);
		
	Возврат Результат;	
	
КонецФункции

Функция Документы_ТипКонтентаОтвета(ТипКонтента, Вердикт) Экспорт
	
	ОписаниеФорматаКонтента = Списки_ОписаниеФорматаКонтента(ТипКонтента);
	
	Если Вердикт = "Подписать" Тогда
		
		Результат = ОписаниеФорматаКонтента.XDTO_AcceptanceContent;
		
	ИначеЕсли Вердикт = "ОтказатьВПодписи" Тогда
		
		Результат = ОписаниеФорматаКонтента.XDTO_RejectionContent;
		
	ИначеЕсли Вердикт = "ЗапроситьУточнение" Тогда
		
		Результат = ОписаниеФорматаКонтента.XDTO_CorrectionRequestContent;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ЗаполнитьОтветПоДокументу(Документ, Действие, Ответ) Экспорт
	
	Документ.СлужебнаяИнформация.Вставить("КонтентОтвета", Ответ);
	Документ.РезультатАнализа.ТребуемоеДействиеВДД = Действие;
	
КонецПроцедуры	

Функция Документы_ОтправитьОтветНаВходящий(Документ) Экспорт 
	
	Результат = Истина;
	
	Действие = Документ.РезультатАнализа.ТребуемоеДействиеВДД;

	ДокументыДляОбработки = Новый Массив;
	ДокументыДляОбработки.Добавить(Документ);	
	
	ПодготовленныеДанные = Документы_ДанныеДляMessagePatchToPost(ДокументыДляОбработки);
	
	Попытка
		Документы_ПодписатьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
		Документы_ОтправитьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
	Исключение
		
		ВидОперации		 		= "Отправка ответа на документ";
		ТекстОшибки		 		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ПредставлениеДокумента	= Документы_ПредставлениеДокумента(Документ);
		ДопИнформация			= "Документ: " + ПредставлениеДокумента;
		ТекстСообщения			= Общее_ПодставитьПараметрыВСтроку("Не удалось отправить документ %1", ПредставлениеДокумента);
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		КатегорияМетрики	= Метрика_НазваниеКатегорииПоДействию(Действие);
		ДействиеМетрики		= Метрика_НазваниеДействияОтветныеДействия(Действие);
			
		Метрика_ДобавитьОшибку_ДляОрганизации(Документ.Идентификаторы.BoxId, КатегорияМетрики, ДействиеМетрики, ТекстОшибки);

		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ВыполнитьДействиеСДокументами(ДокументыДляОбработки, Знач Действие = "",
	Знач ОтпечатокСертификата = "") Экспорт
	
	Если Действие = Перечисление_ДействияЭДО().АннулироватьШаблон Тогда
		Возврат Документы_АннулироватьШаблоны(ДокументыДляОбработки);
	КонецЕсли;
	
	Результат = Новый Массив;
	
	ПодготовленныеДанные = Документы_ДанныеДляMessagePatchToPost(ДокументыДляОбработки, Действие);
	
	Попытка
		Документы_ПодписатьДанныеДляMessagePatchToPost(ПодготовленныеДанные, ОтпечатокСертификата);
		Результат = Документы_ОтправитьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
	Исключение
		
		ВидОперации = "Обработка документов";
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ДопИнформация = "Действие: " + Действие;
		ТекстСообщения = Общее_ПодставитьПараметрыВСтроку("Не удалось выполнить действие %1", Действие);
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеДляMessagePatchToPost(ДокументыДляОбработки, Знач Действие = "") Экспорт
	
	Результат = Новый Структура;

	ДействияТребующиеМЧД = МЧД_ДействияТребующиеДоверенность();
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		
		ДействиеДляДокумента = Действие;
		Если НЕ ЗначениеЗаполнено(ДействиеДляДокумента) Тогда
			ДействиеДляДокумента = Документ.РезультатАнализа.ТребуемоеДействиеВДД;
		КонецЕсли;
		
		ОписаниеОшибкиПроверкиКЭП = КЭП_ДоступноДействиеЭДО(ДействиеДляДокумента, Документ.Идентификаторы.BoxID);
		Если ЗначениеЗаполнено(ОписаниеОшибкиПроверкиКЭП) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ДействияТребующиеМЧД.Получить(ДействиеДляДокумента) = Истина Тогда
			Документ_ДополнитьСведениямиМЧД(Документ);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДействиеДляДокумента) Тогда
			
			ПодготовленныеДанные = Документы_ДанныеДляВыполненияДействияСДокументом(Документ, ДействиеДляДокумента);
			
			Если ЗначениеЗаполнено(ПодготовленныеДанные) Тогда
				
				BoxId		= Документ.Идентификаторы.BoxId;
				LetterId	= Документ.Идентификаторы.LetterId;
				
				КлючИдентификатораСообщения = Новый_КлючИдентификатораСообщения(BoxId, LetterId);
				
				ДанныеСообщения = СвойствоСтруктуры(Результат, КлючИдентификатораСообщения);
				
				Если ДанныеСообщения = Неопределено Тогда
					
					ИдентификаторыСообщения = Новый Структура("BoxId, LetterId", BoxId, LetterId);
					Коллекции = Новый Структура;
					
					ДанныеСообщения = Новый Структура("Идентификаторы, Коллекции", ИдентификаторыСообщения, Коллекции);
					Результат.Вставить(КлючИдентификатораСообщения, ДанныеСообщения);
					
				КонецЕсли;
				
				Для Каждого ПодготовленныеДанныеКоллекции Из ПодготовленныеДанные Цикл
					
					ЭлементыКоллекции = СвойствоСтруктуры(ДанныеСообщения.Коллекции, ПодготовленныеДанныеКоллекции.ИмяКоллекции);
					
					Если ЭлементыКоллекции = Неопределено Тогда
						
						ЭлементыКоллекции = Новый Массив;
						ДанныеСообщения.Коллекции.Вставить(ПодготовленныеДанныеКоллекции.ИмяКоллекции, ЭлементыКоллекции);
						
					КонецЕсли;
					
					ЭлементыКоллекции.Добавить(ПодготовленныеДанныеКоллекции.ЭлементКоллекции);
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	МЧД_УдалитьКонтекстДляГрупповыхДействий();
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеДляВыполненияДействияСДокументом(Документ, Действие)
	
	Результат = Новый Массив;
	
	BoxId = Документ.Идентификаторы.BoxId;

	ВариантыОтвета = Перечисление_ВариантыОтветаПоДокументу();
	ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
	
	Если Действие = ВариантыОтвета.Подписать Тогда
		
		ДанныеДляДействия = Документы_СтруктураПодписанияВходящего(Документ);

	ИначеЕсли Действие = ВариантыОтвета.Аннулировать Тогда
		
		Если Документ.Статусы.Статус = Перечисление_СтатусыДокументов().ТребуетсяАннулирование Тогда
			
			ДанныеДляДействия = Документы_ПодписаниеПредложенияОбАннулировании(Документ);
			
		Иначе
			
			ДанныеДляДействия = Документы_НовоеПредложениеОбАннулировании(Документ);
			
		КонецЕсли;

	ИначеЕсли Действие = ВариантыОтвета.ПодписатьПромежуточнойПодписью Тогда
		
		ДанныеДляДействия = Документы_СтруктураПодписания(Документ);
		
	ИначеЕсли Действие = Перечисление_ДействияЭДО().ПодписатьСогласующейПодписью Тогда
		
		ДанныеДляДействия = Документы_СтруктураПодписания(Документ, Истина);
		
	ИначеЕсли Действие = ВариантыОтвета.ОтказатьВПодписи И ФормироватьУС = Неопределено Тогда
		
		ДанныеДляДействия = Документы_СтруктураОтказВПодписанииВходящего(Документ);
		
	ИначеЕсли Действие = ВариантыОтвета.ОтказатьВАннулировании И ФормироватьУС = Неопределено Тогда
		
		ДанныеДляДействия = Документы_ОтказОтПредложенияОбАннулировании(Документ);
		
	ИначеЕсли Действие = ВариантыОтвета.ЗапроситьУточнение И ФормироватьУС = Неопределено Тогда
		
		ДанныеДляДействия = Документы_СтруктураЗапросаУточненияВходящего(Документ);	
		
	ИначеЕсли Действие = ВариантыОтвета.ОтказатьВПодписи
		ИЛИ Действие = ВариантыОтвета.ОтказатьВАннулировании 
		ИЛИ Действие = ВариантыОтвета.ЗапроситьУточнение Тогда
		
		ДанныеДляДействия = Документы_СтруктураУниверсальногоСообщенияДляДействия(Документ, Действие);
		
	Иначе
		
		ТекстИсключения = "Невозможно подготовить данные для выполнения действия: %1";
		ВызватьИсключение Общее_ПодставитьПараметрыВСтроку(ТекстИсключения, Действие);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеДляДействия) Тогда
		
		ДанныеДляДействия.ЭлементКоллекции.Действие = Действие;
		Результат.Добавить(ДанныеДляДействия);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ПодписатьДанныеДляMessagePatchToPost(ДанныеДляMessagePatchToPost, Знач ОтпечатокСертификата = "") Экспорт
	
	Перем SignedContent;
	
	Для Каждого ДанныеСообщения Из ДанныеДляMessagePatchToPost Цикл
		
		Для Каждого КоллекцияДействия Из ДанныеСообщения.Значение.Коллекции Цикл
			
			Если КоллекцияДействия.Ключ = "UniversalMessages" Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ЭлементКоллекции Из КоллекцияДействия.Значение Цикл
				
				ДанныеДляПодписания = ЭлементКоллекции.Данные;
				
				Если ЗначениеЗаполнено(ДанныеДляПодписания) Тогда
					
					BoxId = ЭлементКоллекции.Документ.Идентификаторы.BoxId;
					
					ДанныеПодписи	= ПодписьДанных(BoxId, ДанныеДляПодписания, ОтпечатокСертификата);
					ДанныеПодписи	= Base64Строка(ДанныеПодписи);
					
					Если ЭлементКоллекции.Attachment.Свойство("Signature") Тогда
						
						ЭлементКоллекции.Attachment.Signature = ДанныеПодписи;
						
					ИначеЕсли ЭлементКоллекции.Attachment.Свойство("SignedContent", SignedContent) Тогда
						
						SignedContent.Content	= Base64Строка(ДанныеДляПодписания);
						SignedContent.Signature	= ДанныеПодписи;
						
					Иначе
						ВызватьИсключение "Не найден контейнер размещения подписи данных!";
					КонецЕсли;
					
					ЭлементКоллекции.Данные = Неопределено;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Документы_ОтправитьДанныеДляMessagePatchToPost(ДанныеДляMessagePatchToPost) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого ДанныеСообщения Из ДанныеДляMessagePatchToPost Цикл
		
		КоллекцииДляPostMessagePatch = Новый Структура;
		
		Для Каждого Коллекция Из ДанныеСообщения.Значение.Коллекции Цикл
			
			ДанныеКоллекции = Новый Массив;
			
			Для Каждого ЭлементКоллекции Из Коллекция.Значение Цикл
				ДанныеКоллекции.Добавить(ЭлементКоллекции.Attachment);
			КонецЦикла;
			
			КоллекцииДляPostMessagePatch.Вставить(Коллекция.Ключ, ДанныеКоллекции);
			
		КонецЦикла;
		
		РезультатОтправки = РезультатPostMessagePatch(ДанныеСообщения.Значение.Идентификаторы, КоллекцииДляPostMessagePatch);
		ОбработанныеДокументы = Документы_ПослеОтправкиMessagePatchToPost(ДанныеСообщения.Значение, РезультатОтправки.MessagePatch);
		
		Для Каждого Документ Из ОбработанныеДокументы Цикл
			Результат.Добавить(Документ);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ)
	
	Результат = Новый Структура("ИмяКоллекции, ЭлементКоллекции");
	
	ЭлементКоллекции = Новый Структура("Attachment, Данные, Документ, Действие");
	
	ЭлементКоллекции.Attachment	= Attachment;
	ЭлементКоллекции.Данные		= Данные;
	ЭлементКоллекции.Документ	= Документ;
	
	Результат.ИмяКоллекции		= ИмяКоллекции;
	Результат.ЭлементКоллекции	= ЭлементКоллекции;
	
	Возврат Результат;
	
КонецФункции


Функция Документы_АннулироватьШаблоны(МассивДокументов) Экспорт
	
	Результат = Новый Массив;
	
	СообщенияИДокументы = Документы_СообщенияДляАннулированияШаблонов(МассивДокументов);
	
	Для каждого Элемент Из СообщенияИДокументы Цикл
		
		Сообщение		 = Элемент.Сообщение;
		ПервыйДокумент	 = Элемент.Документы[0];
		BoxId	 = ПервыйДокумент.Идентификаторы.BoxId;
		LetterId = ПервыйДокумент.Идентификаторы.LetterId;
		
		Попытка
			Документы_ОтправитьСообщениеАннулированияШаблонов(Сообщение, BoxId, LetterId);
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
			ВидОперации = НСтр("ru = 'Аннулирование шаблонов'");
			ТекстСообщения = НСтр("ru = 'Не удалось аннулировать шаблоны'");
			Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
			
			Прервать;
			
		КонецПопытки;
		
		Документы_ОбновитьСтатусШаблоновПослеАннулирования(МассивДокументов);
		
		ДополнитьМассив(Результат, Элемент.Документы);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ОбновитьСтатусШаблоновПослеАннулирования(МассивДокументов)
	
	СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();
	НаправленияДокументов = Перечисление_Направления();
	
	Для каждого Документ Из МассивДокументов Цикл
		
		Если Документ.Направление = НаправленияДокументов.Исходящее Тогда
			НовыйСтатус = СтатусыДокументовЭДО.Отозван;
		Иначе
			НовыйСтатус = СтатусыДокументовЭДО.Отклонен;
		КонецЕсли;
		
		ХранениеДанных_ОбновлениеРеквизитовДокумента(Документ.Идентификаторы, Новый Структура("Статус", НовыйСтатус));
		
		Документ.Статусы.Статус = НовыйСтатус;
		
		Если ЗначениеЗаполнено(НовыйСтатус) Тогда
			Документы_ПослеУстановкиСтатуса(Документ.Идентификаторы.ДокументЭДО, НовыйСтатус);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Документы_СообщенияДляАннулированияШаблонов(МассивДокументов)
	
	СоответствиеСообщений = Новый Соответствие;
	
	Для Каждого Документ Из МассивДокументов Цикл
		
		BoxId = Документ.Идентификаторы.BoxId;
		LetterId = Документ.Идентификаторы.LetterId;
		DocumentId = Документ.Идентификаторы.DocumentId;
		КлючСообщения = BoxId + LetterId;
		
		Комментарий = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", "");
		
		Элемент = СоответствиеСообщений[КлючСообщения];
		
		Если Элемент = Неопределено Тогда
			
			Элемент = Новый Структура("Сообщение, Документы");
			
			Элемент.Сообщение = АПИ_Новый_TemplatePatchToPost();
			Элемент.Документы = Новый Массив;
			
			СоответствиеСообщений.Вставить(КлючСообщения, Элемент);
			
		КонецЕсли;
		
		RefusalAttachment = АПИ_Новый_TemplateRefusalAttachment(DocumentId);
		RefusalAttachment.Comment = Комментарий;
		
		Элемент.Сообщение.Refusals.Добавить(RefusalAttachment);
		Элемент.Документы.Добавить(Документ);
		
	КонецЦикла;
	
	Результат = Новый Массив;
	
	Для Каждого Элемент Из СоответствиеСообщений Цикл
		Результат.Добавить(Элемент.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ОтправитьСообщениеАннулированияШаблонов(Сообщение, BoxId, LetterId)
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Результат = АПИ_PostTemplatePatch(ПараметрыСервиса, Сообщение, BoxId, LetterId);
	
	Возврат Результат;
	
КонецФункции


// ПОДПИСАНИЕ ДОКУМЕНТА

Функция Документы_СтруктураПодписанияВходящего(Документ)
	
	DocumentId = Документ.Идентификаторы.DocumentId;
	BoxId = Документ.Идентификаторы.BoxId;
	
	КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	ПодписьОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПодписьОтвета", Неопределено);
	
	ДанныеПодписаны = ЗначениеЗаполнено(ПодписьОтвета);
	
	PowerOfAttorney = МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	Если ДанныеПодписаны Тогда
		Signature = ПодписьОтвета;
	Иначе
		Signature = "";
	КонецЕсли;
	
	Если Документы_ФормироватьОтветныйТитул(Документ) Тогда
		
		ФормализованныйКонтентОтвета = ТипЗнч(КонтентОтвета) = Тип("ДвоичныеДанные");
		
		Если ФормализованныйКонтентОтвета Тогда
			Данные = КонтентОтвета;
		Иначе
			Данные = Документы_ДанныеПодписанияВходящего(Документ);
		КонецЕсли;
		
		Если ДанныеПодписаны Тогда
			Content = Данные;
		Иначе
			Content = "";
		КонецЕсли;
		
		NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
			BoxId,
			Content);
			
		SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
			BoxId,
			Signature);
		
		SignedContent = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorney);
		
		ИмяКоллекции	= "RecipientTitles";
		Attachment	 	= АПИ_Новый_ReceiptAttachment(DocumentId, SignedContent);
		
	Иначе
		
		ДанныеХранилищаКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
		
		Если ДанныеХранилищаКонтента = Неопределено Тогда
			Данные = Документы_ДвоичныеДанныеКонтента(Документ.Идентификаторы);
		Иначе
			Данные = ДанныеХранилищаКонтента.Данные;
		КонецЕсли;
		
		ИмяКоллекции	= "Signatures";
		Attachment	 	= АПИ_Новый_DocumentSignature(DocumentId, Signature, , , PowerOfAttorney);
		
	КонецЕсли;
	
	Результат = Неопределено;
	
	Если Данные <> Неопределено Тогда
		Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_СтруктураПодписания(Документ, СогласующаяПодпись = Ложь)
	
	DocumentId = Документ.Идентификаторы.DocumentId;
	
	ДанныеХранилищаКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
	
	Если ДанныеХранилищаКонтента = Неопределено Тогда
		Данные = Документы_ДвоичныеДанныеКонтента(Документ.Идентификаторы);
	Иначе
		Данные = ДанныеХранилищаКонтента.Данные;
	КонецЕсли;
	
	ИмяКоллекции = "Signatures";
	Attachment = АПИ_Новый_DocumentSignature(DocumentId, "", , СогласующаяПодпись);
	
	Если Данные <> Неопределено Тогда
		Результат = Новый_ЭлементКоллекцииMessagePatchToPost(ИмяКоллекции, Attachment, Данные, Документ);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеПодписанияВходящего(Документ) Экспорт
	
	Результат = Неопределено;
	ТипКонтента = Документ.Тип.ТипКонтента;
	ПротоСтруктура = СвойствоСтруктуры(
			Документ.СлужебнаяИнформация,
			"КонтентОтвета",
			Неопределено);
	
	Если ПротоСтруктура <> Неопределено Тогда
		
		СторонаТитула = "Покупатель";
		BoxId = Документ.Идентификаторы.BoxId;
		ФорматКонтента = Списки_ОписаниеФорматаКонтента(НРег(ТипКонтента));
		ВидТитула = ФорматКонтента.API_DocumentTitleType;
		XDTO_AcceptanceContent = ФорматКонтента.XDTO_AcceptanceContent;
		
		Документы_ПроверитьЗаполнитьДатуПодписания(ПротоСтруктура, Документ);
		
		ПротоКонтентXDTO = ГенерацияXML_ПротоКонтент_В_ПротоКонтентXDTO(ПротоСтруктура, XDTO_AcceptanceContent);
		ОписаниеПолномочийПодписанта = ПолномочияПодписанта_Получить(BoxId, ВидТитула, СторонаТитула);
		
		Если ЗначениеЗаполнено(ОписаниеПолномочийПодписанта.Ошибки) Тогда
			
			ВидОперации = "Подписание входящего документа";
			ПредставлениеДокумента = Документы_ПредставлениеДокумента(Документ, Истина);
			ШаблонТекстаОшибки = НСтр(
					"ru='Не удалось подписать документ %1 по причине: в модуле не заполнены полномочия подписанта.
					|
					|Необходимо заполнить полномочия и повторить попытку отправки документов.
					|
					|Для заполнения перейдите по ссылке: '");
			
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонТекстаОшибки, ПредставлениеДокумента);
			
			ПараметрыФормыЗаполненияПолномочийПодписанта = Новый Структура;
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("АдресЯщика", BoxId);
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("ТипКонтента", ТипКонтента);
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("ПокупательПродавец", СторонаТитула);
			
			ПараметрыСсылки = СписокОшибок_НовыеПараметрыРасшифровки("");
			ПараметрыСсылки.Вставить("ОбработчикОповещения", "ОбработчикОповещения_ОткрытьФормуЗаполненияПолномочийПодписанта");
			ПараметрыСсылки.Вставить("РезультатОповещения", ПараметрыФормыЗаполненияПолномочийПодписанта);
			
			РасшифровкаОшибок = Новый Массив;
			ПредставлениеСсылки = "Заполнить полномочия";
			ДействиеОткрытьФорму = СписокОшибок_Перечисление_ВидыДействийСпискаОшибок().ВыполнитьОповещение;
			
			СписокОшибок_ДобавитьРасшифровкуВМассив(
				РасшифровкаОшибок,
				ПараметрыСсылки,
				ПредставлениеСсылки,
				ДействиеОткрытьФорму
			);
			
			ТекстСообщения = "Не удалось подписать входящий документ " + ПредставлениеДокумента;
			ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
			
			Ошибка_Обработать(
				ВидОперации,
				ТекстОшибки,
				,
				ТекстСообщения,
				ИдентификаторФормы,
				,
				РасшифровкаОшибок);
			
			Возврат Неопределено;
			
		КонецЕсли;
		
		Документы_ЗаполнитьПротоСтруктуруПодписантом(Документ, ПротоКонтентXDTO, СторонаТитула);
		
		ДанныеХранилищаКонтента = СвойствоСтруктуры(
				Документ.Документооборот,
				"ХранилищеКонтента",
				Неопределено);
		
		Если ДанныеХранилищаКонтента = Неопределено Тогда
			
			ДанныеХранилищаКонтента = ХранениеДанных_ДанныеХранилища(
					Документ.Идентификаторы,
					"ХранилищеКонтента");
			
			Если ДанныеХранилищаКонтента.Данные = Неопределено
				И ДанныеХранилищаКонтента.ТребуетсяРасшифровка Тогда
				
				ДанныеХранилищаКонтента = Документы_Расшифровать(Документ.Идентификаторы, Ложь);
				
			КонецЕсли;
			
		КонецЕсли;
		
		ДанныеТитулаПродавца = ДанныеХранилищаКонтента.Данные;
		ДанныеПодписиПродавца = ДанныеХранилищаКонтента.Подпись.ДанныеПодписи;
		
		Если ЭтоФормализованныйАктСверки405(Документ.Тип.ТипКонтента) Тогда
			ИдентификаторыУчастников = Новый Структура;
			ИдентификаторыУчастников.Вставить("ИдентификаторОтправителя", Документ.Отправитель.FNSParticipantId);
			ИдентификаторыУчастников.Вставить("ИдентификаторПолучателя", Документ.Получатель.FNSParticipantId);
		КонецЕсли;
		
		ОбъектXDTO = ГенерацияXML_ОтветныйТитул(
				ПротоКонтентXDTO,
				ДанныеТитулаПродавца,
				ДанныеПодписиПродавца,
				ТипКонтента,
				ИдентификаторыУчастников);
		
		Если ОбъектXDTO = Неопределено Тогда
			ВызватьИсключение "Не реализовано получение ответного титула для документа с типом контента " + ТипКонтента;
		КонецЕсли;
		
		Результат = ГенерацияXML_ОбъектXDTO_В_ДвоичныеДанные(ОбъектXDTO);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ПроверитьЗаполнитьДатуПодписания(ПротоСтруктура, Документ)
	
	ЗаполнитьДатуПодписанияПоДатеДокумента = Ложь;
	Если ПротоСтруктура.Свойство("ДополнительныеПараметры") Тогда
		ЗаполнитьДатуПодписанияПоДатеДокумента = ПротоСтруктура.ДополнительныеПараметры.ЗаполнитьДатуПодписанияПоДатеДокумента;
	КонецЕсли;
	
	Если Не ЗаполнитьДатуПодписанияПоДатеДокумента Тогда
		Возврат;		
	КонецЕсли;
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	КлючДатаПодписания = Документы_КлючДатыПодписанияТитулаПокупателя(ТипКонтента);
 
	ПротоСтруктура[КлючДатаПодписания] = Документ.Реквизиты.Дата;
	
КонецПроцедуры

Функция Документы_КлючДатыПодписанияТитулаПокупателя(ТипКонтента)
	
	Перем ИмяПоля;
	
	ИменаПолей = Новый Структура;
	ИменаПолей.Вставить("rezru"	 , "AcceptanceDate");
	ИменаПолей.Вставить("tovtorg", "AcceptanceDate");
	ИменаПолей.Вставить("utd"	 , "AcceptanceDate");
	ИменаПолей.Вставить("ucd"	 , "AcceptanceDate");
	ИменаПолей.Вставить("ucd736" , "AcceptanceDate");
	ИменаПолей.Вставить("utd820" , "AcceptanceDate");
	ИменаПолей.Вставить("utd970" , "AcceptanceDate");
	ИменаПолей.Вставить("torg12" , "ShipmentReceiptDate");
	ИменаПолей.Вставить("act"	 , "SignatureDate");
	ИменаПолей.Вставить("torg2"	 , "CompilationInfoDate");
	
	Если Не ИменаПолей.Свойство(ТипКонтента, ИмяПоля) Тогда
		ТекстОшибки = ПараметрыВСтроку("Неожиданный тип контента (%1)", ТипКонтента);
		ВызватьИсключение ТекстОшибки;		
	КонецЕсли;
	
	Возврат ИмяПоля;
	
КонецФункции

