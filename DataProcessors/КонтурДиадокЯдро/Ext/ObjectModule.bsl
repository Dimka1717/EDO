// Формирует представление коллекции внешних статусов.
//
// @СлужебныйПрограммныйИнтерфейс
//
// Параметры:
//  ВнешниеСтатусы - Структура - см. Новый_ВнешниеСтатусы
// 
// Возвращаемое значение:
//  Строка - общее представление внешних статусов.
//
Функция СписокДокументов_ПредставлениеВнешнихСтатусов(ВнешниеСтатусы) Экспорт
	
	Подстроки = Новый Массив;
	Разделитель = "; ";
	
	СтатусГИСМТ = ВнешниеСтатусы_СтатусГИСМТ(ВнешниеСтатусы);
	ПредставлениеГИСМТ = ВнешниеСтатусы_ПредставлениеСтатусаГИСМТ(СтатусГИСМТ);
	Если ЗначениеЗаполнено(ПредставлениеГИСМТ) Тогда
		Подстроки.Добавить(ПредставлениеГИСМТ);
	КонецЕсли;
	
	СтатусКонтурЛогистика = ВнешниеСтатусы_СтатусКонтурЛогистика(ВнешниеСтатусы);
	ПредставлениеКонтурЛогистика = ВнешниеСтатусы_ПредставлениеСтатусаКонтурЛогистика(СтатусКонтурЛогистика);
	Если ЗначениеЗаполнено(ПредставлениеКонтурЛогистика) Тогда
		Подстроки.Добавить(ПредставлениеКонтурЛогистика);
	КонецЕсли;
	
	Результат = СоединитьСтроку(Подстроки, Разделитель);
	
	Возврат Результат;
	
КонецФункции

