// ОТПРАВКА ШАБЛОНОВ

Функция Пакеты_ОтправитьШаблоны(Пакет)
	
	Отказ = Ложь;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(Пакет.Идентификаторы.BoxId);
	TemplateToPost	 = ПодготовитьTemplateToPost(Пакет);
	OperationId		 = Пакеты_ИдентификаторОперации(Пакет);
	
	Попытка
		
		РезультатОтправки = АПИ_PostTemplate(ПараметрыСервиса, TemplateToPost, OperationId);
		
	Исключение
		
		Отказ = Истина;
		
		Ошибка				 = ИнформацияОбОшибке();
		ТекстОшибки			 = ПодробноеПредставлениеОшибки(Ошибка);
		ПредставлениеПакета	 = ПредставлениеПакета(Пакет);
		ВидОперации			 = "Отправка пакета шаблонов";
		ДопИнформация		 = "Пакет: " + ПредставлениеПакета;
		ТекстСообщения		 = Общее_ПодставитьПараметрыВСтроку("Не удалось отправить пакет-шаблон %1", ПредставлениеПакета);
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	КонецПопытки;
	
	Если НЕ Отказ Тогда
		Template = РезультатОтправки.Template;
		ЗаполнитьИдентификаторыПослеОтправкиПакета(Пакет, Template);
		ЗаполнитьИдентификаторыПослеОтправкиШаблонов(Пакет, Template);
	КонецЕсли;
	
	Результат = НЕ Отказ;
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьTemplateToPost(Пакет)
	
	FromBoxId		 = Пакет.Отправитель.BoxId;
	ToBoxId			 = Пакет.Получатель.BoxId;
	FromDepartmentId = Пакет.Отправитель.DepartmentId;
	ToDepartmentId	 = Пакет.Получатель.DepartmentId;
	
	LockMode				 = Пакет.ПараметрыШаблона.LockMode;
	MessageFromBoxId		 = Пакет.ПараметрыШаблона.MessageFromBoxId;
	MessageToBoxId			 = Пакет.ПараметрыШаблона.MessageToBoxId;
	MessageToDepartmentId	 = Пакет.ПараметрыШаблона.MessageToDepartmentId;
	MessageProxyBoxId		 = Пакет.ПараметрыШаблона.MessageProxyBoxId;
	MessageProxyDepartmentId = Пакет.ПараметрыШаблона.MessageProxyDepartmentId;
	
	Результат = АПИ_Новый_TemplateToPost(FromBoxId, ToBoxId, MessageFromBoxId, MessageToBoxId);
	
	Результат.FromDepartmentId			 = FromDepartmentId;
	Результат.ToDepartmentId			 = ToDepartmentId;
	Результат.MessageToDepartmentId		 = MessageToDepartmentId;
	Результат.MessageProxyBoxId			 = MessageProxyBoxId;
	Результат.MessageProxyDepartmentId	 = MessageProxyDepartmentId;
	
	Если ЗначениеЗаполнено(LockMode) Тогда
		Результат.LockMode = LockMode;
	ИначеЕсли Пакет.Заблокирован Тогда
		Результат.LockMode = "Full";
	КонецЕсли;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		DocumentAttachment = ПодготовитьTemplateDocumentAttachment(Документ);
		Результат.DocumentAttachments.Добавить(DocumentAttachment);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьTemplateDocumentAttachment(Документ)
	
	ХранилищеКонтента	 = Документ.Документооборот.ХранилищеКонтента;
	ТипДокумента		 = Документ.Тип.ТипДокумента;
	ТипКонтента			 = Документ.Тип.ТипКонтента;
	ФункцияДокумента	 = Документ.Тип.ФункцияДокумента;
	Формализованный		 = Документ.Тип.Формализованный;
	ОписаниеТипа		 = Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
	ПараметрыШаблона	 = Документ.ПараметрыШаблона;
	ПараметрыОтправки	 = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПараметрыОтправки");
	
	Контент = АПИ_Новый_UnsignedContent(ХранилищеКонтента.Данные);
	Результат = АПИ_Новый_TemplateDocumentAttachment(Контент, ОписаниеТипа.TypeNamedId);
	
	Результат.Вставить("CustomDocumentId",	Документ.Ключ);
	Результат.Вставить("RefusalDisabled",	ПараметрыШаблона.RefusalDisabled);
	
	Если ЗначениеЗаполнено(Документ.Комментарий) Тогда
		Результат.Вставить("Comment", Документ.Комментарий);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыШаблона.PredefinedRecipientTitle)
		И ТипЗнч(ПараметрыШаблона.PredefinedRecipientTitle) = Тип("ДвоичныеДанные") Тогда
		
		PredefinedRecipientTitle = Новый Структура;
		
		UnsignedContent = АПИ_Новый_UnsignedContent(ПараметрыШаблона.PredefinedRecipientTitle);
		
		PredefinedRecipientTitle.Вставить("UnsignedContent", UnsignedContent);
		
		Результат.Вставить("PredefinedRecipientTitle", PredefinedRecipientTitle);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыШаблона.EditingSettingId) Тогда
		Результат.Вставить("EditingSettingId", ПараметрыШаблона.EditingSettingId);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыОтправки) Тогда
		Если ЗначениеЗаполнено(ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись) Тогда
			Результат.Вставить("NeedRecipientSignature", ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись);
		КонецЕсли;
	КонецЕсли;
	
	Если Не Формализованный Тогда
		
		МетаданныеДокумента = ПолучитьМетаданныеДокументаДляОтправки(ОписаниеТипа, Документ, Ложь);
		
		Если ЗначениеЗаполнено(МетаданныеДокумента) Тогда
			Результат.Вставить("Metadata", МетаданныеДокумента);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьИдентификаторыПослеОтправкиШаблонов(Пакет, Template)
	
	КлючиДокументов = Новый Соответствие;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		КлючиДокументов.Вставить(Строка(Документ.Ключ), Документ);
	КонецЦикла;
	
	Для Каждого Entity Из Template.Entities Цикл
		
		Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(Entity, "DocumentInfo") Тогда
			
			CustomDocumentId = Entity.DocumentInfo.CustomDocumentId;
			
			Документ = КлючиДокументов.Получить(CustomDocumentId);
			
			Если Документ <> Неопределено Тогда
				
				Документ.ПараметрыШаблона.MessageFromBoxId			 = Template.MessageFromBoxId;
				Документ.ПараметрыШаблона.MessageToBoxId			 = Template.MessageToBoxId;
				Документ.ПараметрыШаблона.MessageToDepartmentId		 = Template.MessageToDepartmentId;
				
				Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(Template, "MessageProxyBoxId") Тогда
					Документ.ПараметрыШаблона.MessageProxyBoxId = Template.MessageProxyBoxId;
				КонецЕсли;
				
				Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(Template, "MessageProxyDepartmentId") Тогда
					Документ.ПараметрыШаблона.MessageProxyDepartmentId = Template.MessageProxyDepartmentId;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры


