Функция АПИ_GetPowerOfAttorneyInfo(ПараметрыСервиса, BoxId, MessageId, EntityId)
	
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Попытка
		
		PowerOfAttorney = Модуль_МетодыAPI.DD_API_GetPowerOfAttorneyInfo(ПараметрыСервиса, BoxId, MessageId, EntityId);
		
	Исключение
		
