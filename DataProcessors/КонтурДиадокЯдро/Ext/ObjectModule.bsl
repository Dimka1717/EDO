//
// Возвращаемое значение:
//	Результат - Неопределено
//
Функция Подразделения_ОбновитьСправочникФоном(КонтрагентыЭДО, ОрганизацияЭДО) Экспорт
	
	Перем Результат;
	
	BoxId	= ОрганизацияЭДО.ID;
	MyOrgId	= ОрганизацияЭДО.OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	ПодразделенияКонтрагентов = Подразделения_НоваяТаблицаКонтрактов();
	
	Для Каждого ДанныеКонтрагентаЭДО Из КонтрагентыЭДО Цикл
		
		Контрагент = АПИ_GetCounteragent(ПараметрыСервиса, MyOrgId, ДанныеКонтрагентаЭДО.OrgId);
		
		МассивDepartments = Контрагент.Organization.Departments;
		
		Для Каждого Department Из МассивDepartments Цикл
			
			Если ИдентификаторЗаполнен(Department.DepartmentId) Тогда
				
				Подразделение = Подразделения_НовоеПодразделение(Контрагент.Organization, Department);
				
				НоваяСтрока = ПодразделенияКонтрагентов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Подразделение);
				
			КонецЕсли;
			
		КонецЦикла;	

	КонецЦикла;
	
	ХранениеДанных_ВыполнитьПакетноеОбновлениеСправочника(ПодразделенияКонтрагентов, КонтрагентыЭДО);
	
	Возврат Результат;
	
КонецФункции


