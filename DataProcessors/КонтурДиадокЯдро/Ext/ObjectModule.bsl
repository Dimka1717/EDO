Функция ДокументыУчета_ВидПакетаОтправляемогоДокумента(РеквизитыДокумента)
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника();
	ИдентификаторыОрганизации.ID = Организации_ИдентификаторПоСсылке(РеквизитыДокумента.Организация);
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника();
	ИдентификаторыКонтрагента.ID = Контрагенты_ИдентификаторПоСсылке(РеквизитыДокумента.Контрагент);
	
	РеквизитыОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	РеквизитыКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
	
	НастройкиПакетовНаОтправку = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(
		РеквизитыОрганизации,
		РеквизитыКонтрагента
	);
	КлючНастройки = "КатегорияПакета";
	КатегорияПоУмолчанию = "ОсновнойПакет";
	
	КатегорияПакета = РеквизитыДокумента.КатегорияПакета;
	Если КатегорияПакета = КатегорияПоУмолчанию И ИспользоватьПодсистемуДиадока() Тогда
		КатегорияПакета = "Основной пакет";
	КонецЕсли;
	
	НастройкаПакета = МассивСтруктур_Найти(НастройкиПакетовНаОтправку, КатегорияПакета, КлючНастройки);
	
	ВидПакетаID = НастройкаПакета.ВидПакета;
	
	Если РеквизитыДокумента.ДокументБезНДС Тогда
		
		Если ВидПакетаID = "ID_ОсновнойПакет" Тогда
			ВидПакетаID = "ID_ТОРГ12_Акт_БезНДС";
		Иначе
			ВидПакетаID = СтрЗаменить(ВРЕГ(ВидПакетаID), "_РАЗДЕЛЬНО", "");
			ВидПакетаID = ВидПакетаID + "_БезНДС";
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = ВидПакетаID;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыУчета_ИдентификаторЯщикаОрганизацииДокумента(ДокументУчета) Экспорт
	
