// КОНВЕРТАЦИЯ СТАВОК НДС В КОНТЕНТЕ

Функция ТребуетсяКонвертацияСтавокНДС()
	
	Результат = ЕстьПодключаемыйМодуль()
		И ДоступнаКонвертацияСтавокНДС()
		И ЗначениеНастройки_КонвертироватьСтавкиНДС();
	
	Возврат Результат;
	
КонецФункции

Функция ТребуетсяВалидацияСтавокНДС()
	
	Результат = ЕстьПодключаемыйМодуль()
		И ДоступнаКонвертацияСтавокНДС()
		И НЕ ЗначениеНастройки_КонвертироватьСтавкиНДС();
	
	Возврат Результат;
	
КонецФункции

Функция ДоступнаКонвертацияСтавокНДС()
	
	Результат = Ложь;
	
	ЗначенияОпций = ОбщийКонтекст_Прочитать("ФункциональныеОпции");
	ТипБулево = Тип("Булево");
	
	Значение = ЗначенияОпций.Получить("ConversionTaxRate");
	Если ЗначениеЗаполнено(Значение) Тогда
		Результат = XMLЗначение(ТипБулево, Значение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьПредупрежденияКонвертацииСтавокНДС(СписокПредупреждений)
	
	Ключ = "Группа";
	Значение = "КонвертацияСтавокНДС";
	
	СобытияКонвертацииСтавокНДС = МассивСтруктур_Найти(СписокПредупреждений, Значение, Ключ);
	
	Результат = (СобытияКонвертацииСтавокНДС <> Неопределено);
	
	Возврат Результат;
	
КонецФункции
