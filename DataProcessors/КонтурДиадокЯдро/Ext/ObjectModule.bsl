// Возвращает признак что сертификат тестовый.
//
// Параметры:
//  ОписаниеСертификата - Структура - см. Сертификаты_Контракт_ОписаниеСертификата();
//
// Возвращаемое значение:
//   Булево - Истина, если сертификат выпущен тестовым УЦ, см. ЗначениеНастройки_ОрганизацияИздателяТестовогоСертификата()
//
Функция Сертификаты_ЭтоТестовыйСертификат(ОписаниеСертификата)
	
	ИздательТестовый = ЗначениеНастройки_ОрганизацияИздателяТестовогоСертификата();
	Если НЕ ЗначениеЗаполнено(ИздательТестовый) Тогда
		ИздательТестовый = ОрганизацияИздателяТестовогоСертификатаПоУмолчанию();
	КонецЕсли;
	
	НормализованныйИздательИзСерта = нРег(СокрЛП(ОписаниеСертификата.ОрганизацияИздателя));
	НормализованныйИздательТестовый = нРег(СокрЛП(ИздательТестовый));
	
	Результат = НормализованныйИздательИзСерта = НормализованныйИздательТестовый;
	
	Возврат Результат;

КонецФункции

