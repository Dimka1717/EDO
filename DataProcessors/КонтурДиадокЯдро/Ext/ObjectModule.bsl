Функция Документы_ФункцияДокументаДляXML(ТипДокумента, ФункцияДокумента) Экспорт
	
	Если НРег(ТипДокумента) = НРег("UniversalTransferDocument")
		ИЛИ НРег(ТипДокумента) = НРег("UniversalTransferDocumentRevision") Тогда
		
		Результат = ФункцияУПДДляXML(ФункцияДокумента);
		
	ИначеЕсли НРег(ТипДокумента) = НРег("UniversalCorrectionDocument")
		ИЛИ НРег(ТипДокумента) = НРег("UniversalCorrectionDocumentRevision") Тогда
		
		Результат = ФункцияУКДДляXML(ФункцияДокумента);
		
	ИначеЕсли НРег(ТипДокумента) = НРег("Torg2") Тогда
		
		Результат = ФункцияТорг2ДляXML(ФункцияДокумента);
		
	// Контур.Логистика
	ИначеЕсли НРег(ТипДокумента) = НРег("logisticswaybill") Тогда
		
		Результат = ФункцияДокумента;
	// Контур.Логистика
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

