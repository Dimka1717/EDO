// Готовит текст в разметке HTML для информирования пользователя о проблемах отправки приглашений с вложениями в роуминг
//
// Параметры:
//	Контрагенты - Массив -  массив контрактов контрагентов, см. Ядро.Контракт_КонтрагентЭДО()
//
// Возвращаемое значение:
//	Строка
//
Функция Контрагенты_ОтправкаПриглашенийСВложениямиРоуминг_СписокОшибокВТекстHTML(Контрагенты) Экспорт
	
	ЭлементыДокументаHTML = Новый Массив;
	
	Начало =
	"<HTML>
	|	<HEAD>
	|		<style type=text/css>
	|			body {font-family: Segoe UI}
	|			h4 {padding-bottom: 0em; font-weight:bold; font-size: 12pt}
	|			ul.box {padding-left: 3em}
	|			ul.sub {font-size: 10pt}
	|			p.footer {font-size: 10pt}
	|			li {margin-left: 10px;}
	|		</style>
	|	</HEAD>
	|<BODY scroll=auto>
	|<h4>Контрагенты из роуминга</h4>";
	
	ЭлементыДокументаHTML.Добавить(Начало);
	
	ШаблонСтрокиСпискаHTML = "<li>%1</li>";
	
	Для каждого КонтрактКонтрагента Из Контрагенты Цикл

		ТекстСтрокиСпискаHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиСпискаHTML, КонтрактКонтрагента.Наименование);
		ЭлементыДокументаHTML.Добавить(ТекстСтрокиСпискаHTML);		
	
	КонецЦикла;
	
	Подвал = "<p class=""footer"">Вложение можно отправить через раздел отправки документов</p>";	
	ЭлементыДокументаHTML.Добавить(Подвал);
	
	Окончание ="</BODY></HTML>";
	ЭлементыДокументаHTML.Добавить(Окончание);

	Результат = СоединитьСтроку(ЭлементыДокументаHTML, Символы.ПС);
	
	Возврат Результат;
	
