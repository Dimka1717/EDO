Функция ТехИнфо_Биллинг(КонтекстЯщика)
	
	ПодпискаИдентификатор = КонтекстЯщика.СервисПодпискиНаМодуль.Идентификатор;
	
	Если ПодпискаИдентификатор = КонтурШлюзАвторизации_ИмяСервисаСтартовыйУМ() Тогда
		ПодпискаПредставление = "Стартовый";
	ИначеЕсли КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(ПодпискаИдентификатор) Тогда
		ПодпискаПредставление = "Универсальный";
	Иначе
		ПодпискаПредставление = "Нет данных";
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ПодпискаИдентификатор", ПодпискаИдентификатор);
	Результат.Вставить("ПодпискаПредставление", ПодпискаПредставление);
	Результат.Вставить("ТребуетсяОплата", КонтекстЯщика.ТребуетсяОплатаСервиса);
	
	ДанныеЛС = Новый Массив;
	
	ШаблонПредставленияЛС = "ID: %1";
	ШаблонНастроекЛС = "Продукт %1, Оплата плательщиком: %2";
	ШаблонСервисов = "Сервисы: %1";
	
	Для Каждого ДанныеЛицевогоСчета Из КонтекстЯщика.ЛицевыеСчета Цикл
		
		СервисыЛС = Новый Массив;
		
		Для Каждого ДоступныйСервисЛицевогоСчета Из ДанныеЛицевогоСчета.ДоступныеСервисы Цикл
			
			Если СервисыЛС.Найти(ДоступныйСервисЛицевогоСчета.Идентификатор) = Неопределено Тогда
				СервисыЛС.Добавить(ДоступныйСервисЛицевогоСчета.Идентификатор);
			КонецЕсли;
			
		КонецЦикла;
		
		Если СервисыЛС.Количество() = 0 Тогда
			СервисыЛС.Добавить(Ложь);
		КонецЕсли;
		
		КодПродукта = ДанныеЛицевогоСчета.КодПродукта;
		
		Если КодПродукта = КонтурШлюзАвторизации_КодПродукта() Тогда
			ИмяПродукта = КонтурШлюзАвторизации_ИмяПродукта();
		ИначеЕсли КодПродукта = КонтурШлюзАвторизации_КодПродуктаEDI() Тогда
			ИмяПродукта = КонтурШлюзАвторизации_ИмяПродуктаEDI();
		Иначе
			ИмяПродукта = КодПродукта;
		КонецЕсли;
		
		ПредставлениеЛС = Общее_ПодставитьПараметрыВСтроку(
			ШаблонПредставленияЛС,
			ДанныеЛицевогоСчета.ЛицевойСчет);
		
		НастройкиЛС = Общее_ПодставитьПараметрыВСтроку(
			ШаблонНастроекЛС,
			ИмяПродукта,
			ДанныеЛицевогоСчета.ОплатаПлательщиком);
			
		СервисыЛС = Общее_ПодставитьПараметрыВСтроку(
			ШаблонСервисов,
			СоединитьСтроку(СервисыЛС, ", "));
			
		ДанныеЛС.Добавить(ПредставлениеЛС);
		ДанныеЛС.Добавить(НастройкиЛС);
		ДанныеЛС.Добавить(СервисыЛС);
		
	КонецЦикла;
	
	Результат.Вставить("ЛицевыеСчета", ДанныеЛС);
	
	Возврат Результат;
	
КонецФункции

Функция ТехИнфо_НастройкиОрганизации(BoxId)
	
	Если Не ЗначениеЗаполнено(BoxId) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	
	Идентификаторы			= Новый_ИдентификаторыСправочника(, BoxId);
	ДанныеОрганизации		= Организации_ЗаполненныеРеквизиты(Идентификаторы);
	
	ЗаписыватьКомментарийПриОтправке =
		(ДанныеОрганизации.ЗаписыватьКомментарииВДокументы1С
		И ЗначениеЗаполнено(ДанныеОрганизации.ТекстКомментарияОтправка));
	
	ЗаписыватьКомментарийПриСоздании =
		(ДанныеОрганизации.ЗаписыватьКомментарииВДокументы1С
		И ЗначениеЗаполнено(ДанныеОрганизации.ТекстКомментарияПолучение));
		
	Результат.Вставить("ОтпечатокСертификата", ДанныеОрганизации.ОтпечатокСертификатаНаСервере);
	Результат.Вставить("ПередаватьМЧДФайлом", НастройкиДокументов_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации));
	Результат.Вставить("ШифроватьДокументы", ДанныеОрганизации.ШифроватьДокументы);
	Результат.Вставить("ЗаписыватьКомментарийПриОтправке", ЗаписыватьКомментарийПриОтправке);
	Результат.Вставить("ЗаписыватьКомментарийПриСоздании", ЗаписыватьКомментарийПриСоздании);
	Результат.Вставить("УказыватьОтсутствиеОснованияУПД", ДанныеОрганизации.УказыватьОтсутствиеОснованияУПД);
	Результат.Вставить("ОтправлятьНепроведенныеДокументы", ДанныеОрганизации.ОтправлятьНепроведенныеДокументы);
	Результат.Вставить("ДатаСинхронизацииДокументооборота", ДанныеОрганизации.ДатаГраницыСинхронизации);
	Результат.Вставить("ДатаСинхронизацииКонтрагентов", ДанныеОрганизации.ДатаСинхронизацииСтатусовКонтрагентов);
	
	Возврат Результат;
	
