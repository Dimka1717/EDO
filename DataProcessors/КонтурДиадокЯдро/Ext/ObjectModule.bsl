Функция ПредложенияДляПокупки_ОснованиеПредложенияДляПакета(ПредложениеДляПокупки)
	
	ОснованияПредложения = ПредложенияДляПокупки_ОснованияПредложения();
	
	Если ПредложениеДляПокупки.ОстатокТрафика = Неопределено Тогда
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.ДатаОкончания) Тогда
			
			Если ПредложениеДляПокупки.СрокДействияИстек Тогда
				Результат = ОснованияПредложения.PackagePeriodIsExpired;
			Иначе
				Результат = ОснованияПредложения.PackagePeriodIsSoonToBeExpired;
			КонецЕсли;
			
		Иначе 
			Результат = ОснованияПредложения.PackageIsOut;
		КонецЕсли;
		
	ИначеЕсли ПредложениеДляПокупки.ОстатокТрафика = 0 Тогда
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.ДатаОкончания) Тогда
			
			Если ПредложениеДляПокупки.СрокДействияИстек Тогда
				Результат = ОснованияПредложения.PackageIsOut;
			Иначе
				Результат = ОснованияПредложения.PackageAreExhausted;
			КонецЕсли;
			
		Иначе 
			Результат = ОснованияПредложения.PackageAreExhausted;
		КонецЕсли;
		
	Иначе
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.ДатаОкончания) Тогда
			
			Если ПредложениеДляПокупки.СрокДействияИстек Тогда
				Результат = ОснованияПредложения.PackagePeriodIsExpired;
			Иначе
				Результат = ОснованияПредложения.PackageIsRunningOut;
			КонецЕсли;
			
		Иначе 
			Результат = ОснованияПредложения.PackageAreSoonToBeExhausted;
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция ПредложенияДляПокупки_ОснованиеПредложенияДляПодписки(ПредложениеДляПокупки)
	
	ОснованияПредложения = ПредложенияДляПокупки_ОснованияПредложения();
	
	Если ЗначениеЗаполнено(ПредложениеДляПокупки.ДатаОкончания)
		И НЕ ПредложениеДляПокупки.СрокДействияИстек Тогда
		Результат = ОснованияПредложения.SubscriptionPeriodIsSoonToBeExpired;
	Иначе
		Результат = ОснованияПредложения.SubscriptionPeriodIsExpired;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

