		ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
		
		Ответ = АПИ_GetDocumentTypes(ПараметрыСервиса, BoxId);
		
		Для Каждого DocumentType Из Ответ.DocumentTypes Цикл
			Результат.Вставить(DocumentType.Name, DocumentType);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
