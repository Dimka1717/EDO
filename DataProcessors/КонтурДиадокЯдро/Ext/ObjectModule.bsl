Функция МЧД_КлючДанныхМЧДИзПодключаемогоМодуля()

	Возврат "ДанныеМЧДИзПодключаемогоМодуля";
	
КонецФункции

Функция МЧД_КонтрактМЧДИзПодключаемогоМодуля(ИдентификаторЯщика, ДанныеМЧД)
	
	Если ЗначениеЗаполнено(ДанныеМЧД.ДоверительИНН) Тогда
		Результат = Контракт_МЧД();
		Результат.Идентификатор = ДанныеМЧД.Идентификатор;
		Результат.Доверитель.ИНН = ДанныеМЧД.ДоверительИНН;
		
		Если ЗначениеЗаполнено(ДанныеМЧД.ПредставительИНН) Тогда
			Результат.Представитель.ИНН = ДанныеМЧД.ПредставительИНН;
		Иначе
			Сертификат = КонтекстСеанса_Прочитать(ИдентификаторЯщика, "Сертификат", Ложь);
			ПредставительИНН = "";
			Если ЗначениеЗаполнено(Сертификат) Тогда
				Сертификат.Свойство("ИНН", ПредставительИНН);
			КонецЕсли;
			Результат.Представитель.ИНН = ПредставительИНН;
		КонецЕсли;
		
	Иначе
		КонтекстМЧД = МЧД_ПолучитьКонтекстДляГрупповыхДействий(ИдентификаторЯщика);
		
		Результат = КонтекстМЧД.СписокМЧД.Получить(ДанныеМЧД.Идентификатор);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет служебный контекст МЧД для подписания документов.
// ВАЖНО после выполнения необходимых действий НЕ ЗАБЫТЬ выполнить метод МЧД_ОчиститьДанныеМЧДИзПодключаемогоМодуля()
//
// Параметры:
//  BoxId - Строка - Идентификатор ящика, для которого необходимо добавить МЧД
//  ДанныеМЧД - Структура - см. функцию Контракт_МЧД()
//
Процедура МЧД_ЗаполнитьДанныеМЧДИзПодключаемогоМодуля(BoxId, ДанныеМЧД) Экспорт
	
	КлючЗначения = МЧД_КлючДанныхМЧДИзПодключаемогоМодуля();
	
	КэшДанныхМЧД = Кэш_Прочитать(КлючЗначения);
	Если КэшДанныхМЧД = Неопределено Тогда
		КэшДанныхМЧД = Новый Соответствие;
	КонецЕсли;
	
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(BoxId);
	
	КонтрактМЧД = МЧД_КонтрактМЧДИзПодключаемогоМодуля(ИдентификаторЯщика, ДанныеМЧД);
	КэшДанныхМЧД.Вставить(ИдентификаторЯщика, КонтрактМЧД);
	Кэш_Поместить(КлючЗначения, КэшДанныхМЧД);
	
КонецПроцедуры

Функция МЧД_ДанныеМЧДИзПодключаемогоМодуля(BoxId) Экспорт
	
	КлючЗначения = МЧД_КлючДанныхМЧДИзПодключаемогоМодуля();
	
	КэшДанныхМЧД = Кэш_Прочитать(КлючЗначения);
	
	Если КэшДанныхМЧД = Неопределено Тогда
		
		Результат = Неопределено;
		
	Иначе
		
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(BoxId);
		
		Результат = КэшДанныхМЧД.Получить(ИдентификаторЯщика);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура МЧД_ОчиститьДанныеМЧДИзПодключаемогоМодуля() Экспорт
	
	КлючЗначения = МЧД_КлючДанныхМЧДИзПодключаемогоМодуля();
	Кэш_Поместить(КлючЗначения, Неопределено);
	
КонецПроцедуры

// Контракт для полученных файлов МЧД из сервиса
//
// Возвращаемое значение:
//  Структура - содержит поля:
//   * Идентификатор				 - Строка - идентификатор доверенности;
//   * Данные						 - ДвоичныеДанные - файл МЧД;
//   * ИмяФайла						 - Строка - Имя файла доверенности на диске;
//   * Подпись						 - Структура - Подпись МЧД, см. Контракт_Подпись;
//   * ДанныеФайловДелегированныхМЧД - Массив из Структура - описание файлов делегированных МЧД, см. Контракт_ДанныеФайловМЧД;
//
Функция Контракт_ДанныеФайловМЧД()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("ИННДоверителя", "");
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("ИмяФайла", "");
	Результат.Вставить("Подпись", Контракт_Подпись());
	Результат.Вставить("ДанныеФайловДелегированныхМЧД", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ЦепочкаДелегированияДоверенности_HTML(ОписаниеСобытияМЧД) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(ОписаниеСобытияМЧД.BoxId);
	ИнформацияОДоверенности = АПИ_GetPowerOfAttorneyInfo(ПараметрыСервиса, ОписаниеСобытияМЧД.BoxId, ОписаниеСобытияМЧД.MessageId, ОписаниеСобытияМЧД.EntityId);
	
	Результат = МЧД_ЦепочкаДелегированияДоверенности_СформироватьHTML(ИнформацияОДоверенности, ОписаниеСобытияМЧД);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ЦепочкаДелегированияДоверенности_СформироватьHTML(ИнформацияОДоверенности, ОписаниеСобытияМЧД)
	
	ТелоHTML = "";
	
	ЗаголовокЦелеваяДоверенность = "Целевая доверенность:";
	ЗаголовокСтатусДоверенности = "Статус:";
	
	МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСтрокуЗаголовковРазделаHTML(ТелоHTML, ЗаголовокЦелеваяДоверенность, ЗаголовокСтатусДоверенности);
	
	МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСведенияОДоверенностиHTML(ТелоHTML, ИнформацияОДоверенности, ОписаниеСобытияМЧД, Истина);
	
	ЗаголовокЦепочкаДелегирования = "Доверенности в цепочке передоверия:";
	
	МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСтрокуЗаголовковРазделаHTML(ТелоHTML, ЗаголовокЦепочкаДелегирования);
	
	Для Каждого ДелегированнаяМЧД Из ИнформацияОДоверенности.ДелегированныеМЧД Цикл
		
		МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСведенияОДоверенностиHTML(ТелоHTML, ДелегированнаяМЧД, ОписаниеСобытияМЧД, Ложь);
		
	КонецЦикла;
	
	ТекстHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ТекстHTML;
	
	Результат = Общее_ПодставитьПараметрыВСтроку(ТекстHTML, ТелоHTML);
	
	Возврат Результат;
	
КонецФункции

Процедура МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСтрокуЗаголовковРазделаHTML(ТелоHTML, ЗаголовокЛевойКолонки, ЗаголовокПравойКолонки = "")
	
	ШаблонВыделенногоПоляHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ШаблонВыделенногоПоляHTML;
	ШаблонСтрокиТаблицыHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ШаблонСтрокиТаблицыHTML;
	
	РазделHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонВыделенногоПоляHTML,
												ЗаголовокЛевойКолонки);
	
	ДополнительныйЗаголовокHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонВыделенногоПоляHTML,
												ЗаголовокПравойКолонки);
	
	СтрокаЗаголовкаРазделаHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиТаблицыHTML,
																РазделHTML,
																ДополнительныйЗаголовокHTML);
	
	ТелоHTML = ТелоHTML + СтрокаЗаголовкаРазделаHTML;
	
КонецПроцедуры

Процедура МЧД_ЦепочкаДелегированияДоверенности_ДобавитьСведенияОДоверенностиHTML(ТелоHTML, ИнформацияОДоверенности, ОписаниеСобытияМЧД, МожноСкачатьФайлыДоверенности)
	
	ШаблонОписаниеДоверенностиHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ШаблонОписаниеДоверенностиHTML;
	
	ДоверительПредставитель = Документы_СобытияМЧД_ДоверительПредставитель(ИнформацияОДоверенности);
	
	СрокДействия = "";
	Если ЗначениеЗаполнено(ИнформацияОДоверенности.СрокДействия) Тогда
		СрокДействия = "До " + Формат(ИнформацияОДоверенности.СрокДействия, "ДФ=dd.MM.yyyy");
	КонецЕсли;
	
	СсылкаНаСтраницуПроверкиДоверенностиНаСайтеФНС = ПодготовитьСсылкуНаСтраницуПроверкиДоверенностиНаСайтеФНС(ИнформацияОДоверенности);
	ОписанияПроверокМЧДСтрокой = "";
	ПараметрыГиперссылки = Новый_ПараметрыГиперссылкиПроверкиМЧД(СсылкаНаСтраницуПроверкиДоверенностиНаСайтеФНС, ОписанияПроверокМЧДСтрокой, ИнформацияОДоверенности.Идентификатор);
	СериализованныеПараметрыГиперссылкиПроверкиМЧД = СериализоватьПараметрыГиперссылки(ПараметрыГиперссылки);
	СсылкаОповещениеПроверитьДоверенность = ПараметрыОповещенияВСтрокуHTMLСообщения("ОбработатьНажатие_ПроверитьДоверенностьНаСайтеФНС", СериализованныеПараметрыГиперссылкиПроверкиМЧД);
	ДействиеСДоверенностью = ОписаниеСобытияМЧД.Описание;
	
	ОписаниеДоверенностиHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонОписаниеДоверенностиHTML,
															ДоверительПредставитель,
															СрокДействия,
															ДействиеСДоверенностью,
															СсылкаОповещениеПроверитьДоверенность);
	
	Если МожноСкачатьФайлыДоверенности Тогда
		
		ШаблонГиперссылкиHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ШаблонГиперссылкиHTML;
		
		ПараметрыГиперссылки = Новый_ПараметрыГиперссылкиДляДействийСМЧД(ОписаниеСобытияМЧД.BoxId,
																				ОписаниеСобытияМЧД.MessageId,
																				ОписаниеСобытияМЧД.EntityId,
																				ИнформацияОДоверенности.Идентификатор);
		
		СериализованныеПараметры = СериализоватьПараметрыГиперссылки(ПараметрыГиперссылки);
		СсылкаОповещения = ПараметрыОповещенияВСтрокуHTMLСообщения("ОбработатьНажатие_СкачатьФайлыДоверенности", СериализованныеПараметры);
		ПредставлениеСсылки = Документы_СобытияМЧД_ПредставлениеГиперссылкиДляСкачивания(Истина);
		ГиперссылкаСкачатьФайлыДоверенности = Общее_ПодставитьПараметрыВСтроку(ШаблонГиперссылкиHTML, СсылкаОповещения, ПредставлениеСсылки);
		ОписаниеДоверенностиHTML = ОписаниеДоверенностиHTML + ГиперссылкаСкачатьФайлыДоверенности;
		
	КонецЕсли;
	
	ШаблонСтрокиТаблицыHTML = МЧД_ШаблоныHTMLЦепочкиДелегированияДоверенности().ШаблонСтрокиТаблицыHTML;
	ОписанияПроверокМЧД = ОписаниеСобытияМЧД.ОписанияПроверокМЧД;
	
	ПроверкиДоверенностиHTML = "";
	ШаблонСтрокаСписка = "<li>%1</li>";
	Если ОписанияПроверокМЧД.Количество() = 1 Тогда
		ПроверкиДоверенностиHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокаСписка, ОписанияПроверокМЧД[0]);
	Иначе
		Для Каждого ОписаниеПроверки Из ОписанияПроверокМЧД Цикл
			ПроверкиДоверенностиHTML = ПроверкиДоверенностиHTML + Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокаСписка, "- " + ОписаниеПроверки);
		КонецЦикла;
	КонецЕсли;
	Если ЗначениеЗаполнено(ПроверкиДоверенностиHTML) Тогда
		ПроверкиДоверенностиHTML = Общее_ПодставитьПараметрыВСтроку("<ul style=""list-style-type: none"">%1</ul>", ПроверкиДоверенностиHTML);	
	КонецЕсли;
	
	СведенияОДоверенностиHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиТаблицыHTML,
																ОписаниеДоверенностиHTML,
																ПроверкиДоверенностиHTML);
	
	ТелоHTML = ТелоHTML + СведенияОДоверенностиHTML;
	
КонецПроцедуры

