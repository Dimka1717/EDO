// Подставляет параметры в строку, максимальное число параметров - 9.
//
// Параметры:
//  ШаблонСтроки - Строка - шаблон содержащий маркеры подстановки вида: "%1..%N"
//                        . Нумерация маркеров начинается с 1.
//                          N не может быть более 9.
//  Параметр1  - Строка - подставляемые параметры.
//  Параметр2  - Строка - подставляемые параметры.
//  Параметр3  - Строка - подставляемые параметры.
//  Параметр4  - Строка - подставляемые параметры.
//  Параметр5  - Строка - подставляемые параметры.
//  Параметр6  - Строка - подставляемые параметры.
//  Параметр7  - Строка - подставляемые параметры.
//  Параметр8  - Строка - подставляемые параметры.
//  Параметр9  - Строка - подставляемые параметры.
//
// Возвращаемое значение:
//   Строка - строка шаблона с подставленными параметрами.
//
// BSLLS:NumberOfParams-off
// BSLLS:NumberOfOptionalParams-off
Функция Общее_ПодставитьПараметрыВСтроку(ШаблонСтроки,
		Параметр1,
		Параметр2 = Неопределено,
		Параметр3 = Неопределено,
		Параметр4 = Неопределено,
		Параметр5 = Неопределено,
		Параметр6 = Неопределено,
		Параметр7 = Неопределено,
		Параметр8 = Неопределено,
		Параметр9 = Неопределено) Экспорт
	
	Результат = СтрЗаменить(ШаблонСтроки, "%1", Параметр1);
	Результат = СтрЗаменить(Результат, "%2", Параметр2);
	Результат = СтрЗаменить(Результат, "%3", Параметр3);
	Результат = СтрЗаменить(Результат, "%4", Параметр4);
	Результат = СтрЗаменить(Результат, "%5", Параметр5);
	Результат = СтрЗаменить(Результат, "%6", Параметр6);
	Результат = СтрЗаменить(Результат, "%7", Параметр7);
	Результат = СтрЗаменить(Результат, "%8", Параметр8);
	Результат = СтрЗаменить(Результат, "%9", Параметр9);
	
	Возврат Результат;
	
КонецФункции
// BSLLS:NumberOfParams-on
// BSLLS:NumberOfOptionalParams-on

// Формирует представление числа прописью без самого чтсла в соответствии с заданными форматной строкой и параметрами предмета исчисления.
// Аналог ЧислоПрописью().
//
// Параметры:
//  ПараЧислометр					 - Число - Число, которое необходимо преобразовать в строку прописью.
//  ФорматнаяСтрока				 - Строка - см. ЧислоПрописью()
//  ПараметрыПредметаИсчисления	 - Строка - см. ЧислоПрописью()
//
// Возвращаемое значение:
//   Строка - предмет исчисления без самого числа 
//
// Пример:
// Число	 = 4;
// ПараметрыПредметаИсчисления	 = "организации,организаций,организаций,м,,,,м,0";
// Возвращаемое значение:		 = "организаций";
//
Функция Общее_ПолучитьСклоненияСтрокиПоЧислу(Число, ФорматнаяСтрока, ПараметрыПредметаИсчисления) Экспорт
	
	Результат = СтрЗаменить(ЧислоПрописью(Число, ФорматнаяСтрока, ПараметрыПредметаИсчисления), ЧислоПрописью(Число, ФорматнаяСтрока,",,,м,,,,м,0"), "");
	Возврат Результат;
	
КонецФункции


// Разделяет строку на части по указанным символам-разделителям.
// По аналогии с глобальным методом СтрРазделить, добавленным в платформу версии 8.3.6.
//
// Параметры:
//  Строка         - Строка - разделяемая строка;
//  Разделитель    - Строка - строка символов, каждый из которых является индивидуальным разделителем;
//  ВключатьПустые - Булево - Ложь, если пустые части строки включать в результат не нужно.
// 
// Возвращаемое значение:
//   Массив - массив со строками, которые получились в результате разделения исходной строки.
//
Функция РазделитьСтрокуЛок(Знач Строка, Разделитель = ",", ВключатьПустые = Истина) Экспорт
	
	Результат = Новый Массив;
	
	МассивРазделителей = Новый Массив;
	
	Для Сч = 1 По СтрДлина(Разделитель) Цикл
		СимволРазделителя = Сред(Разделитель, Сч, 1);
		МассивРазделителей.Добавить(СимволРазделителя);
	КонецЦикла;
	
	Пока Истина Цикл
		
		Поз = 0;
		
		Для Каждого СимволРазделителя Из МассивРазделителей Цикл
			
			Поз = Найти(Строка, СимволРазделителя);
			
			Если Поз > 0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если Поз = 0 Тогда
			Подстрока	 = СокрЛП(Строка);
			Строка		 = "";
		Иначе
			Подстрока	 = СокрЛП(Лев(Строка, Поз - 1));
			Строка		 = Сред(Строка, Поз + 1);
		КонецЕсли;
		
		Если ВключатьПустые ИЛИ ЗначениеЗаполнено(Подстрока) Тогда
			Результат.Добавить(Подстрока);
		КонецЕсли;
		
		Если Поз = 0 Тогда
			Прервать; // Нет разделителя, за которым могла бы быть следующая часть строки.
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Соединяет массив переданных строк в одну строку с указанным разделителем.
// По аналогии с глобальным методом СтрСоединить, добавленным в платформу версии 8.3.6.
// ВАЖНО: В результирующую строку добавляются только непустые значения!
// Платформенный метод СтрСоединить объединяет строки безусловно.
// Нужно это учитывать, если в качестве разделителя задана непустая строка.
// 
// Параметры:
//  Строки - Массив, ФиксированныйМассив - коллекция объединяемых строк.
//  Разделитель - Строка - Строка, которая будет вставлена между объединяемыми строками.
//                         Если параметр не задан, строки будут объединены слитно друг с другом.
//
// Возвращаемое значение:
//   Строка - строка, содержащая соединенные исходные строки с разделителем между ними.
//
// Пример:
//   
//   Строки = Новый Массив;
//   Строки.Добавить("Элемент0");
//   Строки.Добавить("");
//   Строки.Добавить("Элемент2");
//   
//   СоединитьСтроку(Строки, "#") = "Элемент0#Элемент2"
//   СтрСоединить(Строки, "#") = "Элемент0##Элемент2"
//   СоединитьСтроку(Строки, "") = СтрСоединить(Строки, "") = "Элемент0Элемент2"
//
Функция СоединитьСтроку(Строки, Разделитель = "") Экспорт
	
	// Аналог: ЭДО_Служебные_МассивВСтроку
	// Отличия:
	// По умолчанию Разделитель = "", раньше Разделитель = Символы.ПС;
	// В параметр "Строки" не поддерживает тип "Строка".
	
	Результат		 = "";
	ТекРазделитель	 = "";
	
	Если ЗначениеЗаполнено(Строки) Тогда
		
		Для Каждого Строка Из Строки Цикл
			
			Если ЗначениеЗаполнено(Строка) Тогда
				Результат		 = Результат + ТекРазделитель + Строка;
				ТекРазделитель	 = Разделитель;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Сокращает строку до нужной длины, при этом обрезанная часть хешируется,
// обеспечивая уникальность строки. Проверяет длину строки на входе и, в случае
// превышения максимальной длины, преобразует ее конец по алгоритму MD5 в
// уникальную строку из 32 символов.
//
// Параметры:
//  Строка            - Строка - исходная строка произвольной длины.
//  МаксимальнаяДлина - Число  - требуемое максимальное количество символов в строке,
//                               минимальное значение: 32.
// 
// Возвращаемое значение:
//   Строка - строка, не превышающая максимальную длину.
//
Функция Общее_СократитьСтрокуКонтрольнойСуммой(Строка, МаксимальнаяДлина) Экспорт
	
	Результат = Строка;
	
	ДлинаИсходнойСтроки = СтрДлина(Строка);
	
	Если ДлинаИсходнойСтроки > МаксимальнаяДлина Тогда
		
		БинарныеДанные = ДвоичныеДанныеИзСтроки(Строка);
		ИмяХешФункции = "MD5";
		
		ХешСтрока = Хэш_Рассчитать(БинарныеДанные, ИмяХешФункции);
		ХешСтрока = СтрЗаменить(ХешСтрока, " ", "");
		
		ДлинаХешСтроки = СтрДлина(ХешСтрока);
		
		Если МаксимальнаяДлина < ДлинаХешСтроки Тогда
			
			Ошибка = НСтр("ru = 'Параметр МаксимальнаяДлина не может быть меньше %1 (длина строки, закодированной по алгоритму %2)'");
			Ошибка = Общее_ПодставитьПараметрыВСтроку(Ошибка, ДлинаХешСтроки, ИмяХешФункции);
			ВызватьИсключение Ошибка;
			
		КонецЕсли;
		
		Результат = Лев(Результат, МаксимальнаяДлина - ДлинаХешСтроки) + ХешСтрока;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Записывает строку в двоичные данные
//
// Параметры:
//  Строка - Строка - строка, которую нужно записать в двоичные данные
//  Кодировка - КодировкаТекста, Строка - (необязательный) кодировка текста;
// 
// Возвращаемое значение:
//  ДвоичныеДанные
//
Функция ДвоичныеДанныеИзСтроки(Строка, Кодировка = "UTF-8")
	
	Если ПриложениеСтаршеВерсии("8.3.10") Тогда
		
		ИмяФайла = ПолучитьИмяВременногоФайла();
		Текст = Новый ТекстовыйДокумент;
		Текст.УстановитьТекст(Строка);
		Текст.Записать(ИмяФайла, Кодировка);
		Результат = Новый ДвоичныеДанные(ИмяФайла);
		
		Попытка
			УдалитьФайлы(ИмяФайла);
		Исключение
			Ошибка = ИнформацияОбОшибке();
			ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
			Ошибка_ДобавитьВЖурналРегистрации(ТекстОшибки);
		КонецПопытки;
		
	Иначе
		Результат = Вычислить("ПолучитьДвоичныеДанныеИзСтроки(Строка, Кодировка)");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает строку из двоичных данных
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные - двоичные данные которые содержат текст
//  Кодировка - КодировкаТекста, Строка - (необязательный) кодировка текста;
// 
// Возвращаемое значение:
//  Строка
//
Функция СтрокаИзДвоичныхДанных(ДвоичныеДанные, Кодировка = "UTF-8") Экспорт
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
	
	ДвоичныеДанные.Записать(ИмяВременногоФайла);	
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.Прочитать(ИмяВременногоФайла, Кодировка);
	
	УдалитьФайлы(ИмяВременногоФайла);
	
	Возврат ТекстовыйДокумент.ПолучитьТекст();
	
КонецФункции

// Проверяет, что в переданной строке только цифы 0..9
//
// Параметры:
//  Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//  Булево - Истина, если в строке только цифры, иначе Ложь
//
Функция ВСтрокеТолькоЦифры(Строка)
	
	Результат = Истина;
	
	КодСимвола0 = КодСимвола("0");
	КодСимвола9 = КодСимвола("9");
	
	ДлинаСтроки = СтрДлина(Строка);
	
	Для Сч = 1 По ДлинаСтроки Цикл
		
		КодСимвола = КодСимвола(Строка, Сч);
		
		Если КодСимвола < КодСимвола0
			Или КодСимвола > КодСимвола9 Тогда
			Результат = Ложь;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает массив переданных параметров в порядке их расположения
// 
// Параметры:
//  Параметр0 - Произвольный - значение, которое будет добавлено в массив по индексу 0
//  Параметр1 - Произвольный - значение, которое будет добавлено в массив по индексу 1
//  Параметр2 - Произвольный - значение, которое будет добавлено в массив по индексу 2
//  Параметр3 - Произвольный - значение, которое будет добавлено в массив по индексу 3
//  Параметр4 - Произвольный - значение, которое будет добавлено в массив по индексу 4
//
// Возвращаемое значение:
//   Массив - массив переданных параметров.
//
Функция ПараметрыВМассив(Параметр0 = NULL
	, Параметр1 = NULL
	, Параметр2 = NULL
	, Параметр3 = NULL
	, Параметр4 = NULL) Экспорт
	
	Результат = Новый Массив(5);
	
	Результат[0] = Параметр0;
	Результат[1] = Параметр1;
	Результат[2] = Параметр2;
	Результат[3] = Параметр3;
	Результат[4] = Параметр4;
	
	Для Сч = -Результат.ВГраница() По 0 Цикл
		
		Если Результат[-Сч] = NULL Тогда
			Результат.Удалить(-Сч);
		Иначе
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Подставляет параметры в строку, максимальное число параметров - 5.
//
// Параметры:
//  ШаблонСтроки - Строка - шаблон строки с параметрами;
//  Параметр<n>	 - Строка - подставляемый параметр.
//
// Пример:
//  Общее_ПодставитьПараметрыВСтрокуНаСервере(НСтр("ru='%1 пошел в %2'"), "Вася", "Зоопарк") = "Вася пошел в Зоопарк".
// 
// Возвращаемое значение:
//  Строка - строка с подставленными параметрами.
//
Функция ПараметрыВСтроку(ШаблонСтроки
						, Параметр1
						, Параметр2 = Неопределено
						, Параметр3 = Неопределено
						, Параметр4 = Неопределено
						, Параметр5 = Неопределено) Экспорт
	
	Результат = СтрЗаменить(ШаблонСтроки, "%1", Параметр1);
	Результат = СтрЗаменить(Результат	, "%2", Параметр2);
	Результат = СтрЗаменить(Результат	, "%3", Параметр3);
	Результат = СтрЗаменить(Результат	, "%4", Параметр4);
	Результат = СтрЗаменить(Результат	, "%5", Параметр5);
	
	Возврат Результат;
	
КонецФункции

// Возвращает строку для вычисления значений параметров из массива в порядке их расположения
// 
// Параметры:
//  МассивПараметров - Массив - см. функцию ПараметрыВМассив()
//
// Возвращаемое значение:
//   Строка - строка для вычисления значений параметров из массива.
//
Функция СтрокаИзМассиваПараметров(МассивПараметров, ИмяМассива = "МассивПараметров")
	
	Результат	 = "";
	Разделитель	 = "";
	
	Если ЗначениеЗаполнено(МассивПараметров) Тогда
		
		Для Сч = 0 По МассивПараметров.ВГраница() Цикл
			
			Если МассивПараметров[Сч] = NULL Тогда
				Результат = Результат + Разделитель;
			Иначе
				Результат = Результат + Разделитель + ИмяМассива + "[" + Сч + "]";
			КонецЕсли;
			
			Разделитель = ", ";
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеВМассив(Значение) Экспорт
	
	Если ТипЗнч(Значение) = Тип("Массив") Тогда
		
		Результат = Значение;
		
	Иначе
		
		Результат = Новый Массив;
		Результат.Добавить(Значение);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Удаляет повторяющиеся элементы массива.
//
// Параметры:
//  Массив - Массив - массив произвольных значений.
//
// Возвращаемое значение:
//  Массив;
Функция Общее_СвернутьМассив(Массив) Экспорт
	Результат = Новый Массив;
	ДополнитьМассив(Результат, Массив, Истина);
	Возврат Результат;
КонецФункции

// Возвращает значение свойства структуры или значение по умолчанию,
// если в структуре нет такого свойства.
// 
// Параметры:
//  Структура           - Структура    - Структура, которая может содержать вложенные структуры.
//  Ключ                - Строка       - Имя ключа структуры,
//  ЗначениеПоУмолчанию - Произвольный - (необязательный) возвращается в случае если в структуре нет указанного свойства.
// 
// Возвращаемое значение:
//   Произвольный - Значение свойства структуры или ЗначениеПоУмолчанию,
//                  если в структуре нет такого свойства.
//
Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено) Экспорт
	
	Перем Значение;
	
	Результат = ЗначениеПоУмолчанию;
	
	Если ЭтоСтруктура(Структура) И ЗначениеЗаполнено(Ключ) Тогда
		
		Если Структура.Свойство(Ключ, Значение) Тогда
			Результат = Значение;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеСоответствия(Соответствие, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Перем Результат;
	
	Результат = Соответствие.Получить(Ключ);
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Результат = ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции

// Определяет, является ли переданное значение структурой или фиксированной структурой.
// 
// Параметры:
//  Значение - Произвольный - значение, которое нужно проверить.
// 
// Возвращаемое значение:
//   Булево - Истина, если переданое значение является структрой или фиксированной структурой.
//
Функция ЭтоСтруктура(Значение)
	
	Результат = Ложь;
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Структура")
		Или ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет, является ли переданное значение массивом или фиксированным массивом
// 
// Параметры:
//  Значение - Произвольный - значение, которое нужно проверить
// 
// Возвращаемое значение:
//  Булево - Истина, если переданое значение является массивом или фиксированным массивом
//
Функция ЭтоМассив(Значение)
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Массив")
		Или ТипЗначения = Тип("ФиксированныйМассив") Тогда
		Результат = Истина;
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОтличияСтруктур(ОсновнаяСтруктура, СравниваемаяСтруктура)
	
	Результат = Новый Структура;
	
	Если ЗначениеЗаполнено(ОсновнаяСтруктура) Тогда
		
		Для Каждого текПоле Из ОсновнаяСтруктура Цикл
			
			ЗначениеСравнение = ?(СравниваемаяСтруктура.Свойство(текПоле.Ключ), СравниваемаяСтруктура[текПоле.Ключ], Неопределено);
			
			Если ТипЗнч(ЗначениеСравнение) = Тип("Структура") Тогда
				
				Если НЕ СтруктурыСовпадаютЛок(текПоле.Значение, ЗначениеСравнение) Тогда
					Расхождения = ОтличияСтруктур(текПоле.Значение, ЗначениеСравнение);
					Результат.Вставить(текПоле.Ключ, Расхождения);
				КонецЕсли;
				
			Иначе
				
				ЕстьЗначенияДляСравнения = (ЗначениеЗаполнено(текПоле.Значение)
					ИЛИ ЗначениеЗаполнено(ЗначениеСравнение));
				
				Если ЕстьЗначенияДляСравнения
					И текПоле.Значение <> ЗначениеСравнение Тогда
					
					Результат.Вставить(текПоле.Ключ, ЗначениеСравнение);
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли ЗначениеЗаполнено(СравниваемаяСтруктура) Тогда
		
		Для Каждого текПоле Из СравниваемаяСтруктура Цикл
			
			Результат.Вставить(текПоле.Ключ, текПоле.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СтруктурыСовпадаютЛок(Данные1, Данные2)
	
	Результат = Ложь;
	
	Если ТипЗнч(Данные1) <> ТипЗнч(Данные2) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(Данные1) = Тип("Структура")
		ИЛИ ТипЗнч(Данные1) = Тип("ФиксированнаяСтруктура") Тогда
		
		Если Данные1.Количество() <> Данные2.Количество() Тогда
			Возврат Результат;
		КонецЕсли;
		
		Для Каждого КлючИЗначение Из Данные1 Цикл
			
			СтароеЗначение = Неопределено;
			
			Если НЕ Данные2.Свойство(КлючИЗначение.Ключ, СтароеЗначение)
				ИЛИ НЕ СтруктурыСовпадаютЛок(КлючИЗначение.Значение, СтароеЗначение) Тогда
				
				Возврат Результат;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Результат = Истина;
		
		Возврат Результат;
		
	КонецЕсли;
	
	Возврат Данные1 = Данные2;
	
КонецФункции

// Создает копию коллекции значений.
//
// Параметры:
//  Источник - Структура, ФиксированнаяСтруктура, Соответствие, ФиксированноеСоответствие,
//    Массив, ФиксированныйМассив, СписокЗначений, ТаблицаЗначений - коллекция значений,
//    которую необходимо скопировать.
//
// Возвращаемое значение:
//  Структура, Соответствие, Массив, СписокЗначений, ТаблицаЗначений - копия исходной коллекции значений.
//
Функция КопияКоллекцииЗначений(Источник) Экспорт
	
	Результат = Неопределено;
	
	ТипИсточника = ТипЗнч(Источник);
	
	Если ТипИсточника = Тип("Структура")
		ИЛИ ТипИсточника = Тип("ФиксированнаяСтруктура") Тогда
		Результат = Общее_СкопироватьСтруктуру(Источник);
	ИначеЕсли ТипИсточника = Тип("Соответствие")
		ИЛИ ТипИсточника = Тип("ФиксированноеСоответствие") Тогда
		Результат = Общее_СкопироватьСоответствие(Источник);
	ИначеЕсли ТипИсточника = Тип("Массив")
		ИЛИ ТипИсточника = Тип("ФиксированныйМассив") Тогда
		Результат = Общее_СкопироватьМассив(Источник);
	ИначеЕсли ТипИсточника = Тип("СписокЗначений") Тогда
		Результат = Общее_СкопироватьСписокЗначений(Источник);
	ИначеЕсли ТипИсточника = Тип("ТаблицаЗначений") Тогда
		Результат = Источник.Скопировать();
	ИначеЕсли ТипИсточника = Тип("ДанныеФормыКоллекция") Тогда
		Результат = Источник.Выгрузить();
	Иначе
		Результат = Источник;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Создает копию значения типа Структура.
//
// Параметры:
//  Источник - Структура - структура для копирования.
// 
// Возвращаемое значение:
//  Структура - копия исходной структуры.
//
Функция Общее_СкопироватьСтруктуру(Источник)
	
	Результат = Новый Структура;
	
	Для Каждого КлючИЗначение Из Источник Цикл
		Результат.Вставить(КлючИЗначение.Ключ, КопияКоллекцииЗначений(КлючИЗначение.Значение));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создает копию значения типа Соответствие.
//
// Параметры:
//  Источник - Соответствие - соответствие для копирования.
// 
// Возвращаемое значение:
//  Соответствие - копия исходного соответствия.
//
Функция Общее_СкопироватьСоответствие(Источник)
	
	Результат = Новый Соответствие;
	
	Для Каждого КлючИЗначение Из Источник Цикл
		Результат.Вставить(КлючИЗначение.Ключ, КопияКоллекцииЗначений(КлючИЗначение.Значение));
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

// Создает копию значения типа Массив.
//
// Параметры:
//  Источник - Массив - массив для копирования.
// 
// Возвращаемое значение:
//  Массив - копия исходного массива.
//
Функция Общее_СкопироватьМассив(Источник)
	
	Результат = Новый Массив;
	
	Для Каждого Элемент Из Источник Цикл
		Результат.Добавить(КопияКоллекцииЗначений(Элемент));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создает копию значения типа СписокЗначений.
//
// Параметры:
//  Источник - СписокЗначений - список значений для копирования.
// 
// Возвращаемое значение:
//  СписокЗначений - копия исходного списка значений.
//
Функция Общее_СкопироватьСписокЗначений(Источник)
	
	Результат = Новый СписокЗначений;
	
	Для Каждого ЭлементСписка Из Источник Цикл
		
		Результат.Добавить(КопияКоллекцииЗначений(ЭлементСписка.Значение), 
							ЭлементСписка.Представление, 
							ЭлементСписка.Пометка, 
							ЭлементСписка.Картинка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьНаличиеОбъектаМетаданных(СтрокаМетаданных) Экспорт
	
	Результат = Истина;
	
	ТекПолеМетаданных	= Метаданные;
	МассивИмен			= РазделитьСтрокуЛок(СтрокаМетаданных, ".");
	КоличествоИмен		= МассивИмен.Количество();
	
	// КоличествоИмен = 2 для проверки наличия объекта, например 					Справочники.Диадок_ДополнительныеСправочники
	// КоличествоИмен = 4 для проверки наличия реквизита\ресурса и т.д., например	Справочники.Диадок_ДополнительныеСправочники.Реквизиты.ИмяСправочника
	// КоличествоИмен = 6 для проверки наличия реквизита таб. части, например		Справочники.Диадок_ДополнительныеСправочники.ТабличныеЧасти.ДополнительныеРеквизиты.Реквизиты.ЗначениеСтрока
	
	Если НЕ (КоличествоИмен = 2 Или КоличествоИмен = 4 Или КоличествоИмен = 6) Тогда
		Результат = Ложь;
	Иначе
		
		КоличествоПоисков = КоличествоИмен / 2;
		
		Для н = 1 По КоличествоПоисков Цикл
			
			ТекПолеМетаданных = ТекПолеМетаданных[МассивИмен[н * 2 - 2]].Найти(МассивИмен[н * 2 - 1]);
			
			Если ТекПолеМетаданных = Неопределено Тогда
				Результат = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции

Процедура ПроверитьДоступностьОбъектаМетаданных(СписокОшибок, ПолноеИмя,
												ПравоЧтение		= Истина,
												ПравоДобавление	= Истина,
												ПравоИзменение	= Истина,
												ПравоУдаление	= Ложь) Экспорт
	
	ПозицияТочки	= Найти(ПолноеИмя, ".");
	ВидМетаданных	= Лев(ПолноеИмя, ПозицияТочки - 1);
	ИмяОбъекта		= Сред(ПолноеИмя, ПозицияТочки + 1);
	
	ОбъектМетаданных = Метаданные[ВидМетаданных].Найти(ИмяОбъекта);
	
	Если ОбъектМетаданных = Неопределено Тогда
		СписокОшибок.Добавить("В конфигурации отсутствует: " + ПолноеИмя);
	Иначе
		
		Если ПравоЧтение Тогда
			Если НЕ ПравоДоступа("Чтение", ОбъектМетаданных) Тогда
				СписокОшибок.Добавить("У вас недостаточно прав на чтение: " + ПолноеИмя);
			КонецЕсли;
		КонецЕсли;
		
		// С платформы 8.3.10 нельзя проверить право "Добавление" для регистра сведений
		Если ВидМетаданных <> "РегистрыСведений" Тогда
			Если ПравоДобавление Тогда
				Если НЕ ПравоДоступа("Добавление", ОбъектМетаданных) Тогда
					СписокОшибок.Добавить("У вас недостаточно прав на добавление: " + ПолноеИмя);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ПравоИзменение Тогда
			Если НЕ ПравоДоступа("Изменение", ОбъектМетаданных) Тогда
				СписокОшибок.Добавить("У вас недостаточно прав на изменение: " + ПолноеИмя);
			КонецЕсли;
		КонецЕсли;
		
		Если ПравоУдаление Тогда
			Если НЕ ПравоДоступа("Удаление", ОбъектМетаданных) Тогда
				СписокОшибок.Добавить("У вас недостаточно прав на удаление: " + ПолноеИмя);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьРезультатЗапроса(Запрос, ИмяПоля = "Ссылка", ПустоеЗначение = Неопределено) Экспорт
	
	Результат = ПустоеЗначение;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		Результат = Выборка[ИмяПоля];
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбщийМодуль_ПолучитьБезопасно(ИмяОбщегоМодуля)
	
	Если ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули." + ИмяОбщегоМодуля) Тогда
		
		Результат = Вычислить(ИмяОбщегоМодуля);
		
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр("ru = 'Не обнаружен общий модуль %1'"), ИмяОбщегоМодуля);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Преобразует идентификатор в адрес ящика в Диадоке
// 
// Параметры:
//  ИД - Строка - идентификатор ящика.
// 
// Возвращаемое значение:
//   Строка - адрес ящика.
//
Функция ИдентификаторВАдресЯщика(ИД) Экспорт
	
	Результат = "";
	
	Если ЗначениеЗаполнено(ИД) Тогда
		
		ДлинаИД = СтрДлина(ИД);
		
		Если ДлинаИД = 32 Тогда 
			
			Результат = ИД + "@diadoc.ru";
			
		ИначеЕсли ДлинаИД = 36 Тогда
			
			Результат = СтрЗаменить(ИД, "-", "") + "@diadoc.ru";
			
		ИначеЕсли ДлинаИД = 42 Тогда
			
			Результат = ИД;
			
		Иначе
			
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
			"ru = 'Некорректный идентификатор ящика %1'"), ИД);
			
			ВызватьИсключение ТекстОшибки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Преобразует идентификатор в адрес ящика в Диадоке
// 
// Параметры:
//  ИД - Строка - идентификатор ящика.
// 
// Возвращаемое значение:
//   Строка - адрес ящика.
//
Функция АдресЯщикаВИдентификатор(АдресЯщика) Экспорт
	
	АдресЯщикаБезПробелов = СокрЛП(АдресЯщика);
	ИД = СтрЗаменить(АдресЯщикаБезПробелов, "@diadoc.ru", "");
	ДлинаИД = СтрДлина(ИД);
	Результат = "";
	
	Если ДлинаИД = 32 Тогда // 00000000000000000000000000000000
		
		Результат = Сред(ИД, 1, 8)
			+ "-" + Сред(ИД, 9, 4)
			+ "-" + Сред(ИД, 13, 4)
			+ "-" + Сред(ИД, 17, 4)
			+ "-" + Сред(ИД, 21, 12);
		
	ИначеЕсли ДлинаИД = 36 Тогда // 00000000-0000-0000-0000-000000000000
		
		Результат = ИД;
		
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
					"ru = 'Некорректный адрес ящика %1'"), АдресЯщика);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Преобразует дату по часовому поясу компьютера в универсальную
// и затем приводит её к строке в формате ISO8601
//
// Параметры
//  ДатаПоМестномуВремени - Дата - дата по часовому поясу компьютера
//
// Возвращаемое значение:
//   Строка - дата строкой
//
Функция УниверсальнаяДатаВФормате_ISO8601(ДатаПоМестномуВремени)
	
	УниверсальнаяДата = УниверсальнаяДата(ДатаПоМестномуВремени);
	
	Результат = Формат(УниверсальнаяДата, "ДФ=yyyy-MM-ddTHH:mm:ss+00:00");
	
	Возврат Результат;
	
КонецФункции

// Преобразует дату по часовому поясу компьютера в универсальную (GMT+00:00).
// Для 8.1 преобразование не выполняется.
//
// Параметры
//  ДатаПоМестномуВремени - Дата - дата по часовому поясу компьютера, которую нужно преобразовать
//
// Возвращаемое значение:
//   Дата - универсальная дата
//
Функция УниверсальнаяДата(ДатаПоМестномуВремени)
	
	Результат = УниверсальноеВремя(ДатаПоМестномуВремени);
	
	Возврат Результат;
	
КонецФункции

Функция ДатаXML_в_Дата1С(Строка) Экспорт
	
	Если ТипЗнч(Строка) = Тип("Дата") Тогда	
		Результат = Строка;
	ИначеЕсли ПустаяСтрока(Строка) Тогда
		Результат = Дата(1, 1, 1);
	Иначе
		Результат = Дата(Прав(Строка, 4), Сред(Строка, 4, 2), Лев(Строка, 2));	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЧислоИзСтрокиЛок(Знач Строка)
	
	Результат = 0;
	
	Если ЗначениеЗаполнено(Строка) Тогда
		
		ОписаниеТипа = Новый ОписаниеТипов("Число");
		Результат = ОписаниеТипа.ПривестиЗначение(Строка);
		
		Если Не ЗначениеЗаполнено(Результат) Тогда	
			
			Строка = СтрЗаменить(Строка, ",", ".");
			Строка = СтрЗаменить(Строка, " ", "");
			Строка = СтрЗаменить(Строка, Символы.НПП, "");
			
			Если ЗначениеЗаполнено(Строка) Тогда
				Результат = Число(Строка);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

