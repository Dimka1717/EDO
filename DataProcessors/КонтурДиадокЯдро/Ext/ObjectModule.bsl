// Определяет подключеный интеграционный модуль
// или берет модуль по умолчанию
// для работы с текущей конфигурацией
// в случае автоматического определения записывает настройку 
// для дальнейшего использования
//
// Возвращаемое значение:
//   Строка - Имя модуля интеграции или пустая строка
//
Функция ИнтеграционныйМодуль_Получить() Экспорт
	
	ИмяНастройкиИнтеграционныйМодуль = "ИмяИнтеграционногоМодуля"; 
	
	Результат = ОбщиеНастройки_Прочитать(ИмяНастройкиИнтеграционныйМодуль); 
	
	СброситьИМПриОбновленииРедакцииКонфигурации(Результат);
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		
		Результат = ИнтеграционныйМодуль_ПоУмолчанию();
		
		Если ЗначениеЗаполнено(Результат) Тогда
			ОбщиеНастройки_Поместить(ИмяНастройкиИнтеграционныйМодуль, Результат)
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтеграционныйМодуль_ПолучитьИмяМакета() Экспорт
	
	МаркерИМ = ИнтеграционныйМодуль_Получить();
	
	Результат = ПолучитьИмяМакетаПоМаркеру(МаркерИМ);
	
	Возврат Результат;
	
КонецФункции

// Функция - Получить имя макета по маркеру
//
// Параметры:
//  МаркерИМ - Строка - Маркер интеграционного модуля
//
// Возвращаемое значение:
//  Строка,Неопределено - Имя макета интеграционного модуля или неопределено если не найден
//
Функция ПолучитьИмяМакетаПоМаркеру(МаркерИМ) Экспорт
	
	СоответствиеМакетам = Новый Соответствие;
	СоответствиеМакетам.Вставить("ПМ_ААА_5", "КонтурДиадокИнтеграцияААА5");
	СоответствиеМакетам.Вставить("ПМ_ААА_6", "КонтурДиадокИнтеграцияААА6");
	СоответствиеМакетам.Вставить("ПМ_БГУ_20", "КонтурДиадокИнтеграцияБГУ20");
	СоответствиеМакетам.Вставить("ПМ_БП_20", "КонтурДиадокИнтеграцияБП20");
	СоответствиеМакетам.Вставить("ПМ_БП_30", "КонтурДиадокИнтеграцияБП30");
	СоответствиеМакетам.Вставить("ПМ_Розница_2", "КонтурДиадокИнтеграцияРозница2");
	СоответствиеМакетам.Вставить("ПМ_ТорговыеСети", "КонтурДиадокИнтеграцияТС");
	СоответствиеМакетам.Вставить("ПМ_УНФ_16", "КонтурДиадокИнтеграцияУНФ16");
	СоответствиеМакетам.Вставить("ПМ_УТ_103", "КонтурДиадокИнтеграцияУТ103");
	СоответствиеМакетам.Вставить("ПМ_УТ_11", "КонтурДиадокИнтеграцияУТ11");
	
	Результат = СоответствиеМакетам.Получить(МаркерИМ);
	
	Возврат Результат;
	
КонецФункции

Процедура СброситьИМПриОбновленииРедакцииКонфигурации(Результат)
	
	ИмяМетаКонфигурации	= Метаданные.Имя; 
	ВерсияКонфигурации	= Метаданные.Версия;
	
	//При переходе с Розницы 2.3 на Розницу 3.0 меняется ИМ
	Если Результат = ИмяИМ_Розница2() Тогда
		
		КонфигурацияСовпадает	= Найти(НРег(ИмяМетаКонфигурации), НРег("Розница")) > 0;
		ВерсияПодходит			= (СравнитьВерсии(ВерсияКонфигурации, "3.0") >= 0);
		
		Если КонфигурацияСовпадает И ВерсияПодходит Тогда
			Результат = Неопределено;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Проверяет возможность подключения макета обработки
// путем вызова экспортного метода СведенияОВнешнейОбработке
// Параметры:
//  ДвоичныеДанныеМодуля	 - ДвоичныеДанные - Данные макета обработки.
// 
// Возвращаемое значение:
//  Булево - Истина если модуль подключился и Ложь если не удалось
//
Функция Модуль_ПроверитьВозможностьПодключения(ИмяМодуля, ДвоичныеДанныеМодуля, ВызыватьИсключение = Ложь) Экспорт
	
	Результат = Истина;
	
	ПодключенныйМодуль = Неопределено;
	
	Попытка
		
		Если Не ЭтоВнешняяОбработка() Тогда
			ПодключенныйМодуль = Модуль_СоздатьИзКонфигурации(ИмяМодуля);
		Иначе
			ПодключенныйМодуль = ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанныеМодуля);
		КонецЕсли;
		
		СведенияОВнешнейОбработке = ПодключенныйМодуль.СведенияОВнешнейОбработке();
	Исключение
		
		Результат = Ложь;
		
		Если ВызыватьИсключение Тогда
			
			ВызватьИсключение КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			
		КонецЕсли;
		
	КонецПопытки;

	Возврат Результат;
	
КонецФункции

// Проверяет возможность подключения типового модуля
// путем вызова экспортного метода СведенияОВнешнейОбработке
//
// Возвращаемое значение:
//  Булево - Истина если модуль подключился и Ложь если не удалось
//
Функция ТиповойМодуль_ПроверитьВозможностьПодключения() Экспорт
	
	Результат = Истина;
	
	ПодключенныйМодуль = Неопределено;
	
	РежимОтладки = Ложь;
	КаталогСМодулем = "";
	
	Попытка
		
		ПодключенныйМодуль = Модуль_ТиповойМодуль(ЭтотОбъект, РежимОтладки, КаталогСМодулем);
		ПодключенныйМодуль.СведенияОВнешнейОбработке();
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		Ошибка_Обработать(
			"Проверка подключения библиотеки ТиповойМодуль",
			ПодробноеПредставлениеОшибки(Ошибка),
			Неопределено,
			КраткоеПредставлениеОшибки(Ошибка));
		
		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Определеяет идентификатор текущей конфигурации по имени и номеру версии метаданных.
// 
// Возвращаемое значение:
//  Строка - [ИмяКонфигурации][НомерРедакции][НомерПодредакции].
//
Функция ИдентификаторТекущейКонфигурации()
	
	РазделительВерсий = ".";
	ВключатьПустые = Истина;
	ЧастиНомераВерсии = РазделитьСтрокуЛок(
		Метаданные.Версия,
		РазделительВерсий,
		ВключатьПустые
	);
	
	НомерРедакции = "";
	Если ЧастиНомераВерсии.Количество() > 0 Тогда
		НомерРедакции = ЧастиНомераВерсии[0];
	КонецЕсли;
	
	НомерПодредакции = "";
	Если ЧастиНомераВерсии.Количество() > 1 Тогда
		НомерПодредакции = ЧастиНомераВерсии[1];
	КонецЕсли;
	
	ЧастиИдентификатора = Новый Массив;
	ЧастиИдентификатора.Добавить(Метаданные.Имя);
	ЧастиИдентификатора.Добавить(НомерРедакции);
	ЧастиИдентификатора.Добавить(НомерПодредакции);
	
	Результат = СоединитьСтроку(ЧастиИдентификатора);
	
	Возврат Результат;
	
КонецФункции


//Определяет что конфигурация не поддерживается модулем
//
//Возвращаемое занчение:
// Структура - Истина если конфигурация не поддерживается, Ложь если поддерживается.
//
Функция КонфигурацияНеПоддерживается() Экспорт
	
	Результат = Ложь;
	
	ТаблицаСовместимостиИМ = ТаблицаСовместимостиИнтеграционныхМодулей();
	
	ИдентификаторКонфигурации = ИдентификаторТекущейКонфигурации();
	
	КлючевыеПоля = Новый Структура;
	КлючевыеПоля.Вставить("ИдентификаторКонфигурации", ИдентификаторКонфигурации);
	НайденныеЗаписи = ТаблицаСовместимостиИМ.НайтиСтроки(КлючевыеПоля);	
	
	Результат = НайденныеЗаписи.Количество() = 0;	
	
	Возврат Результат;
	
КонецФункции

//Определяет что релиз поддерживаемой конфигурации не поддерживается модулем
//
//Возвращаемое занчение:
// Булево - Истина если конфигурация не поддерживается, Ложь если поддерживается.
//
Функция КонфигурацияУстарела() Экспорт
	
	Результат = Ложь;
	
	ТаблицаСовместимостиИМ = ТаблицаСовместимостиИнтеграционныхМодулей();
	
	ИдентификаторКонфигурации = ИдентификаторТекущейКонфигурации();
	ВерсияКонфигурации = Метаданные.Версия;
	
	КлючевыеПоля = Новый Структура;
	КлючевыеПоля.Вставить("ИдентификаторКонфигурации", ИдентификаторКонфигурации);
	НайденныеЗаписи = ТаблицаСовместимостиИМ.НайтиСтроки(КлючевыеПоля);
	
	Для Каждого Запись Из НайденныеЗаписи Цикл
		
		Результат = (СравнитьВерсии(ВерсияКонфигурации, Запись.ВерсияКонфигурации) < 0);
		
		Если Результат Тогда
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

//Определяет минимальный релиз поддерживаемой конфигурации
//
//Возвращаемое занчение:
// Строка - Версия конфигурации минимальная для работы.
//
Функция МинимальнаяВерсияПоддерживаемойКонфигурации() Экспорт
	
	Результат = "0.0.0";
	
	ТаблицаСовместимостиИМ = ТаблицаСовместимостиИнтеграционныхМодулей();
	ИдентификаторКонфигурации = ИдентификаторТекущейКонфигурации();
	
	КлючевыеПоля = Новый Структура;
	КлючевыеПоля.Вставить("ИдентификаторКонфигурации", ИдентификаторКонфигурации);
	
	НайденныеЗаписи = ТаблицаСовместимостиИМ.НайтиСтроки(КлючевыеПоля);
	Если НайденныеЗаписи.Количество() > 0 Тогда
		Результат = НайденныеЗаписи[0].ВерсияКонфигурации;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтеграционныйМодуль_ПоУмолчанию()
	
	Результат = "";
	
	ТаблицаСовместимостиИМ = ТаблицаСовместимостиИнтеграционныхМодулей();
	
	ИдентификаторКонфигурации = ИдентификаторТекущейКонфигурации();
	ВерсияКонфигурации = Метаданные.Версия;
	
	КлючевыеПоля = Новый Структура;
	КлючевыеПоля.Вставить("ИдентификаторКонфигурации", ИдентификаторКонфигурации);
	НайденныеЗаписи = ТаблицаСовместимостиИМ.НайтиСтроки(КлючевыеПоля);
	
	Для Каждого Запись Из НайденныеЗаписи Цикл
		
		ВерсияПодходит = (СравнитьВерсии(ВерсияКонфигурации, Запись.ВерсияКонфигурации) >= 0);
		
		Если ВерсияПодходит Тогда
			Результат = Запись.ИнтеграционныйМодуль;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

// Формирует таблицу для подбора интеграционного модуля, подходящего для заданной конфигурации.
//
// Возвращаемое значение:
//  ТаблицаЗначений:
//    * ИдентификаторКонфигурации - Строка - маркер конфигурации
//    * ВерсияКонфигурации - Строка - Минимальная версия конфигурации (в формате "РР.ПП.ВВ")
//       ** РР - номер редакции
//       ** ПП - номер подредакции
//       ** ВВ - номер версии
//    * ИнтеграционныйМодуль - Строка идентификатор подходящего интеграционного модуля
//
Функция ТаблицаСовместимостиИнтеграционныхМодулей()
	
	КвалификаторыСтроки = Новый КвалификаторыСтроки(200);
	
	ТаблицаСовместимостиИМ = Новый ТаблицаЗначений;
	
	ТаблицаСовместимостиИМ.Колонки.Добавить("ИдентификаторКонфигурации", Новый ОписаниеТипов("Строка", , КвалификаторыСтроки));
	ТаблицаСовместимостиИМ.Колонки.Добавить("ВерсияКонфигурации", Новый ОписаниеТипов("Строка", , КвалификаторыСтроки));
	ТаблицаСовместимостиИМ.Колонки.Добавить("ИнтеграционныйМодуль", Новый ОписаниеТипов("Строка", , КвалификаторыСтроки));
	ТаблицаСовместимостиИМ.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка", , КвалификаторыСтроки));
	
	ЕстьОграниченияПоТарифу = ЕстьОграниченияПоТарифу();
	
	ЭтоУправляемоеПриложение = ЭтоУправляемоеПриложение();
	
	Если НЕ ЭтоУправляемоеПриложение Тогда
		ДобавитьИнтеграционныйМодуль_ПМ_БП_20(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_УТ_103(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_ААА_5(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
	Иначе
		ДобавитьИнтеграционныйМодуль_ПМ_БГУ_20(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_ААА_6(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_БП_30(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_УТ_11(ТаблицаСовместимостиИМ, ЕстьОграниченияПоТарифу);
		ДобавитьИнтеграционныйМодуль_ПМ_УНФ_16(ТаблицаСовместимостиИМ);
		ДобавитьИнтеграционныйМодуль_ПМ_Розница_2(ТаблицаСовместимостиИМ);
	КонецЕсли;
	
	Возврат ТаблицаСовместимостиИМ;
	
КонецФункции

// Получает идентификатор и представление интеграционного модуля по идентификатору конфигурации.
//
// Параметры:
// 
// Возвращаемое значение:
//  Структура - описание ИМ:
//    * Модуль - Строка - Идентификатор ИМ
//    * Представление - Строка - Пользовательское представление ИМ
//
Функция ИнтеграционныйМодульПоИдентификаторуКонфигурации() Экспорт
	
	ТаблицаСовместимостиИМ = ТаблицаСовместимостиИнтеграционныхМодулей();
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаСовместимости.ИнтеграционныйМодуль КАК ИнтеграционныйМодуль,
	|	ТаблицаСовместимости.Представление КАК Представление
	|ПОМЕСТИТЬ ВТ_ИнтеграционныеМодули
	|ИЗ
	|	&ДанныеТаблицыСовместимости КАК ТаблицаСовместимости
	|ГДЕ
	|	ТаблицаСовместимости.ИдентификаторКонфигурации = &ИдентификаторКонфигурации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИнтеграционныеМодули.ИнтеграционныйМодуль КАК ИнтеграционныйМодуль,
	|	ВТ_ИнтеграционныеМодули.Представление КАК Представление
	|ИЗ
	|	ВТ_ИнтеграционныеМодули КАК ВТ_ИнтеграционныеМодули";
	
	ИдентификаторКонфигурации = ИдентификаторТекущейКонфигурации();
	
	Запрос.УстановитьПараметр("ДанныеТаблицыСовместимости", ТаблицаСовместимостиИМ);
	Запрос.УстановитьПараметр("ИдентификаторКонфигурации", ИдентификаторКонфигурации);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выборка.Следующий();
	
	СтруктураМодуля = Новый Структура;
	СтруктураМодуля.Вставить("Представление", Выборка.Представление);
	СтруктураМодуля.Вставить("Модуль", Выборка.ИнтеграционныйМодуль);
	
	Возврат СтруктураМодуля;
	
КонецФункции 

// Формирует список с представлениями интеграционных модулей
// 
// Возвращаемое значение:
//  СписокЗначений
//
Функция ПользовательскиеПредставленияИнтеграционныхМодулей() Экспорт
	
	ТаблицаМодулей = ТаблицаСовместимостиИнтеграционныхМодулей();
	
	ТаблицаМодулей.Свернуть("ИнтеграционныйМодуль, Представление");
	
	Результат = Новый СписокЗначений;
	
	Для Каждого Запись Из ТаблицаМодулей Цикл
		Результат.Добавить(Запись.ИнтеграционныйМодуль, Запись.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

