Функция ТехИнфо_СборкаМодуля(Настройки)
	
	Модуль_Плагин = Модуль_Плагин(ЭтотОбъект);
	
	ИспользуетсяПодсистемаДиадок = ОбщийКонтекстКлиентСервер.ИспользуетсяПодсистемаДиадок;
	
	Если ИспользуетсяПодсистемаДиадок Тогда
		ВариантПоставки = ?(ОбщийКонтекстКлиентСервер.ИспользуетсяРасширениеПодсистемыХранения, "Расширение", "Встроенная");
		СистемаХранения = Общее_ПодставитьПараметрыВСтроку("ПодсистемаДиадок/%1", ВариантПоставки);
	Иначе
		СистемаХранения = "ТиповаяПодсистема1С";
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("UserAgent", Заголовок_UserAgent());
	Результат.Вставить("Версия", ОбщийКонтекстКлиентСервер.ПолнаяВерсияМодуля);
	Результат.Вставить("Расположение", ТехИнфо_РасположениеМодуля());
	Результат.Вставить("МодульТиповой", ТехИнфо_МодульТиповой());
	Результат.Вставить("ИнтеграционныйМодуль", Настройки.ИмяИнтеграционногоМодуля);
	Результат.Вставить("СистемаХранения", СистемаХранения);
	Результат.Вставить("РежимОтладки", РежимОтладкиВключен());
