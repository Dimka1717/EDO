Функция СтруктураДатыИзСтроки(Знач Строка, Разделитель = ".") 
	
	Результат = Новый Структура;
	Результат.Вставить("День",	1);
	Результат.Вставить("Месяц",	1);
	Результат.Вставить("Год",	1);
	
	МассивДаты = РазделитьСтрокуЛок(Строка, Разделитель);
	
	Если МассивДаты.Количество() = 3 Тогда
		Результат.День	= МассивДаты[0];
		Результат.Месяц	= МассивДаты[1];
		Результат.Год	= МассивДаты[2];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

