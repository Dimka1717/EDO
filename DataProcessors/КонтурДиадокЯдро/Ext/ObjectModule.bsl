// Контракт списка экстренных уведомлений.
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//    * Заголовок - Строка - текст заголовка уведомления
//    * Текст - Строка - содержимое уведомления
//    * ДатаНачала - Дата - дата начала периода отображения уведомления
//    * ДатаОкончания - Дата - дата окончания периода отображения уведомления
//    * Ид - Строка - идентификатор уведомления в сервисе
//    * Приоритет - Строка - возможные значения low / medium / high
//    * Прочитано - Булево - Истина, если уведомление помечено как прочитанное.
//    * Важное - Булево - Истина, если уведомление имеет высокий приоритет.
//
Функция Контракт_СписокУведомлений()
	
	Результат = Новый ТаблицаЗначений;
	
	Результат.Колонки.Добавить("Заголовок", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Текст", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("ТипКонтента", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	Результат.Колонки.Добавить("ДатаОкончания", Новый ОписаниеТипов("Дата"));
	Результат.Колонки.Добавить("Ид", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Приоритет", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Прочитано", Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("Важное", Новый ОписаниеТипов("Булево"));
	
	Возврат Результат;
	
КонецФункции

// Получает список уведомлений из сервиса
//
// Параметры:
//  Фильтр - Структура - Параметры отбора уведомлений
// 
// Возвращаемое значение:
//  Массив из ОтветУведомление:
//    * Контент - Соответствие - содержимое уведомления
//    * ДатаНачала - Дата
//    * ДатаОкончания - Дата
//    * Ид - Строка
//    * Приоритет - Строка - low / medium / high
//
Функция Уведомления_ПолучитьСписок(Фильтр)
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		Результат = УведомленияСлужебный_ПолучитьСписок(Фильтр);
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияУведомления(),
			Метрика_ДействиеПолучениеСпискаУведомлений(),
			НачалоЗамера
		);
		
	Исключение
		
		Результат = Новый Массив;
		
		ВидОперации = НСтр("ru = 'Получение списка экстренных уведомлений пользователя'");
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		
		Ошибка_Обработать(ВидОперации, ИнформацияОбОшибке);
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияУведомления(),
			Метрика_ДействиеПолучениеСпискаУведомлений(),
			ИнформацияОбОшибке
		);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция УведомленияСлужебный_ПолучитьСписок(Фильтр)
	
	ОписаниеКонфигурации = ОписаниеКонфигурации();
	
	УведомленияПользователей = Модуль_АпдейтКлиент();
	
	Запрос = УведомленияПользователей.ЗапросУведомлений();
	Запрос.ИдИБ = Строка(_ИдентификаторИнформационнойБазыДиадок());
	Запрос.Версия = ЗначениеНастройки_СохраненнаяВерсияМодуля();
	Запрос.ДопПараметры.Вставить("conf_version", ОписаниеКонфигурации.Версия);
	Запрос.ДопПараметры.Вставить("conf_name", ОписаниеКонфигурации.Имя);
	Запрос.ДопПараметры.Вставить("platform_version", ОписаниеСистемнойИнформации().ВерсияПриложения);
	Запрос.ДопПараметры.Вставить("storage_subsystem", ПодсистемаХранения());
	
	Если ЗначениеЗаполнено(Фильтр) Тогда
		ДополнитьСтруктуру(Запрос.ДопПараметры, Фильтр, Истина);
	КонецЕсли;
	
	ОтветУведомления = УведомленияПользователей.ПолучитьУведомления(ИдентификаторПродукта(), Запрос);
	Результат = ОтветУведомления.Список;
	
	Возврат Результат;
	
КонецФункции 

