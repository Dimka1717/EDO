Функция Списки_ОписаниеТипаДокументаAPI(TypeNamedId, FormatVersion, Знач FunctionName) Экспорт
	
	FunctionName = ?(FunctionName = Неопределено И TypeNamedId <> Неопределено, "", FunctionName);
	
	Если FunctionName = Неопределено 
		И TypeNamedId <> Неопределено Тогда
		FunctionName = "";
	КонецЕсли;
	
	FunctionName = Документы_ФункцияДокументаДляXML(TypeNamedId, FunctionName);
	
	ОписаниеТиповДокументовAPI = Кэш_Прочитать("ОписаниеТиповДокументовAPI");
	
	Если ОписаниеТиповДокументовAPI = Неопределено Тогда
		
		ОписаниеТиповДокументовAPI = Новый Соответствие;
		
		ТипыДокументовAPI = ПредопределенныеСписки_ТипыДокументовAPI();
		
		Для Каждого СтрокаТЗ Из ТипыДокументовAPI Цикл
			
			КлючFormatVersion = "";
			КлючVersion = "";
			
			Если ЗначениеЗаполнено(СтрокаТЗ.TypeNamedId)
				ИЛИ ЗначениеЗаполнено(СтрокаТЗ.FormatVersion)
				ИЛИ ЗначениеЗаполнено(СтрокаТЗ.FunctionName) Тогда
				
				КлючFormatVersion = КлючFormatVersion + СтрокаТЗ.TypeNamedId + "-" + СтрокаТЗ.FormatVersion + "-" + СтрокаТЗ.FunctionName;
				КлючVersion = КлючVersion + СтрокаТЗ.TypeNamedId + "-" + СтрокаТЗ.Version + "-" + СтрокаТЗ.FunctionName;
				
			КонецЕсли;
			
			ОписаниеТипаДокументаAPI = Общее_СтрокаТаблицыЗначенийВСтруктуру(СтрокаТЗ);
			ОписаниеТиповДокументовAPI.Вставить(КлючVersion, ОписаниеТипаДокументаAPI);
			
			Если ОписаниеТиповДокументовAPI.Получить(КлючFormatVersion) = Неопределено Тогда
				ОписаниеТиповДокументовAPI.Вставить(КлючFormatVersion, ОписаниеТипаДокументаAPI);
			КонецЕсли;
			
		КонецЦикла;
		
		Кэш_Поместить("ОписаниеТиповДокументовAPI", ОписаниеТиповДокументовAPI);
		
	КонецЕсли;
	
	Ключ = "" + TypeNamedId + "-" + FormatVersion + "-" + FunctionName;
	
	Результат = ОписаниеТиповДокументовAPI.Получить(Ключ);
	
	Если Результат = Неопределено Тогда
		Результат = ОписаниеТиповДокументовAPI.Получить(""); //Неизвестный тип документа
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Списки_НазваниеДокументаAPI(TypeNamedId) Экспорт
	
	НазванияДокументовAPI = Кэш_Прочитать("НазванияДокументовAPI");
	
	Если НазванияДокументовAPI = Неопределено Тогда
		
		НазванияДокументовAPI = Новый Соответствие;
		
		ТипыДокументовAPI = ПредопределенныеСписки_ТипыДокументовAPI();
		
		Для Каждого СтрокаТЗ Из ТипыДокументовAPI Цикл
			НазванияДокументовAPI.Вставить(СтрокаТЗ.TypeNamedId, СтрокаТЗ.Title);
		КонецЦикла;
		
		Кэш_Поместить("НазванияДокументовAPI", НазванияДокументовAPI);
		
	КонецЕсли;
	
	Результат = НазванияДокументовAPI.Получить(TypeNamedId);
	
	Если Результат = Неопределено Тогда
		Результат = TypeNamedId; //Неизвестный тип документа
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредопределенныеСписки_ТипыДокументовAPI() Экспорт
	
	Результат = Кэш_Прочитать("ТипыДокументовAPI");
	
	Если Результат = Неопределено Тогда
		
		Результат	= ТипыДокументовAPI_НоваяТаблица();
		СтрокаТЗ	= Результат.Вставить(0); // первая строка -  неизвестный тип
		
		СтрокаТЗ.Title				= "Неизвестный тип документа";
		СтрокаТЗ.Metadata			= Новый Структура;
		СтрокаТЗ.SupportsEncrypting	= Ложь;

		ТипыДокументовAPI = ХранениеДанных_СписокЭлементовДопСправочника("ТипыДокументовAPI", "ХранилищеОписания");
		
		Для Каждого ТипДокумента Из ТипыДокументовAPI Цикл
			
			DocumentType = ТипДокумента.ХранилищеОписания;
			
			Если ЗначениеЗаполнено(DocumentType) Тогда
			
				Для Каждого FunctionType Из DocumentType.Functions Цикл		
					Для Каждого VersionType Из FunctionType.Versions Цикл
						Для Каждого VersionsTitle Из VersionType.Titles Цикл
							
							СтрокаТЗ = Результат.Добавить();
							
							FunctionName = ?(НРег(FunctionType.Name) = "default", "", FunctionType.Name);
							
							СтрокаТЗ.ТипДокументаAPI			= ТипДокумента.Ссылка;
							СтрокаТЗ.ГруппировкаДокументов		= ТипыДокументовAPI_ГруппировкаДляТипа(DocumentType.Name);
							СтрокаТЗ.TypeNamedId				= DocumentType.Name;
							СтрокаТЗ.Title 						= DocumentType.Title;
							СтрокаТЗ.RequiresFnsRegistration	= DocumentType.RequiresFnsRegistration;
							СтрокаТЗ.FunctionName				= FunctionName;
							СтрокаТЗ.FormatVersion				= ТипыДокументовAPI_ПриведенныйТипКонтента(VersionType.Version);
							СтрокаТЗ.Version 					= VersionType.Version;
							СтрокаТЗ.SupportsEncrypting 		= VersionType.SupportsEncrypting;
							СтрокаТЗ.Workflows 					= VersionType.Workflows;
							СтрокаТЗ.MetadataItems				= VersionsTitle.MetadataItems;
							СтрокаТЗ.EncryptedMetadataItems		= VersionsTitle.EncryptedMetadataItems;
							
							СтрокаТЗ.MetadataNames 				= Новый Массив; // поля меты для незашифрованного документа
							СтрокаТЗ.EncryptedMetadataNames 	= Новый Массив; // поля меты для зашифрованного документа
							СтрокаТЗ.Metadata 					= Новый Структура; //структура всей меты
							СтрокаТЗ.IsActual 					= VersionType.IsActual;
							
							Для Каждого Meta Из СтрокаТЗ.MetadataItems Цикл
								СтрокаТЗ.MetadataNames.Добавить(Meta.Id);
								СтрокаТЗ.Metadata.Вставить(Meta.Id);
							КонецЦикла;
							
							Для Каждого Meta Из СтрокаТЗ.EncryptedMetadataItems Цикл
								СтрокаТЗ.EncryptedMetadataNames.Добавить(Meta.Id);
								СтрокаТЗ.Metadata.Вставить(Meta.Id);
							КонецЦикла;
							
							Прервать; // Ответные титулы идут вторыми в коллекции Titles - их пропускаем.
							
						КонецЦикла;				
					КонецЦикла;			
				КонецЦикла;
			
			КонецЕсли; 
					
		КонецЦикла;
		
		Результат.Сортировать("TypeNamedId, FunctionName, IsActual Убыв, Version Убыв"); // по умолчанию будем брать самую свежую версию формата
		
		Кэш_Поместить("ТипыДокументовAPI", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТипыДокументовAPI_ПриведенныйТипКонтента(FormatVersion)
	
	Результат = Лев(FormatVersion, Найти(FormatVersion, "_") - 1);
	
	Если НРег(Результат) = "proformainvoice" Тогда
		Результат = "xmlproformainvoice";
	КонецЕсли;
	
	Возврат Результат;
	
