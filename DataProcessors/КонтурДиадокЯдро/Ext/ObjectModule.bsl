// Создает внешнюю обработку без предупреждения об опасных действиях
//
// Параметры:
//  ДвоичныеДанныеИлиИмяФайла - ДвочиныеДанные - двоичные данные внешней обработки
//  ИмяВнешнейОбработки - Строка - Идентификатор внешней обработки для подключения
//
// Возвращаемое значение:
//   ОбработкаОбъект - объект созданной внешней обработки
//
Функция ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанныеИлиИмяФайла, ИмяВнешнейОбработки = Неопределено)
	
	// В обычном приложении, создание внешней обработки всегда выполняется из файла.
	
	ЭтоИмяФайла = ТипЗнч(ДвоичныеДанныеИлиИмяФайла) = Тип("Строка");
	
	Если ЭтоИмяФайла ИЛИ ЭтоОбычноеПриложение() Тогда
		
		Если ЭтоИмяФайла Тогда
			
			Результат = ВнешниеОбработки_Создать(ДвоичныеДанныеИлиИмяФайла);
			
		Иначе
			
			ИмяВремФайла = ПолучитьИмяВременногоФайла("epf");
			
			ДвоичныеДанныеИлиИмяФайла.Записать(ИмяВремФайла);
			
			Результат = ВнешниеОбработки_Создать(ИмяВремФайла);
			
			УдалитьФайлы(ИмяВремФайла);
			
		КонецЕсли;
		
	Иначе
		
		Результат = Неопределено;
		
		АдресОбработки = ВременноеХранилище_Поместить(ДвоичныеДанныеИлиИмяФайла);
		ИмяОбработки = ПодключитьВнешнююОбработку(АдресОбработки, ИмяВнешнейОбработки);
		// BSLLS:UsingExternalCodeTools-off
		Результат = ВнешниеОбработки.Создать(ИмяОбработки, Ложь);
		// BSLLS:UsingExternalCodeTools-on
		
		УдалитьИзВременногоХранилища(АдресОбработки);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Создает внешнюю обработку из файла.
//
// Параметры:
//  ИмяФайла - Строка - полное имя файла с учетом пути.
//
// Возвращаемое значение:
//   ОбработкаОбъект - объект созданной внешней обработки.
//
Функция ВнешниеОбработки_Создать(ИмяФайла)
	// BSLLS:UsingExternalCodeTools-off
	БезопасныйРежим = Ложь;
	ЗащитаОтОпасныхДействий = ОписаниеЗащитыБезПредупреждений();
	
	Если ПриложениеСтаршеВерсии("8.3.11") ИЛИ ЗащитаОтОпасныхДействий = Неопределено Тогда
		
		Результат = ВнешниеОбработки.Создать(ИмяФайла, БезопасныйРежим);
		
	Иначе
		
		Результат = ВнешниеОбработки.Создать(ИмяФайла, БезопасныйРежим, ЗащитаОтОпасныхДействий);
		
	КонецЕсли;
	
	Возврат Результат;
	// BSLLS:UsingExternalCodeTools-on
КонецФункции

// Получает сведения о внешней обработке
//
// Параметры:
//  ФайлОбработки - ДвоичныеДанные - файл внешней обработки
// 
// Возвращаемое значение:
//  Структура - см. ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке
//    
//
Функция ВнешниеОбработки_Сведения(ФайлОбработки)
	
	ОбъектОбработки = ВнешниеОбработки_СоздатьБезПредупреждений(ФайлОбработки);
	Результат = ОбъектОбработки.СведенияОВнешнейОбработке();
	
	Если Не Результат.Свойство("Имя") Тогда
		ОбъектМетаданных = ОбъектОбработки.Метаданные();
		Результат.Вставить("Имя", ОбъектМетаданных.Имя);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Подключает внешнюю обработку по адресу во временном хранилище
// или навигационной ссылке.
//
// Параметры:
//  АдресОбработки - Строка - адрес двоичных данных обработки во временном хранилище.
//
// Возвращаемое значение:
//   Строка - имя подключенной внешней обработки.
//
Функция ПодключитьВнешнююОбработку(АдресОбработки, ИмяВнешнейОбработки = Неопределено)
	
	БезопасныйРежим			 = Ложь;
	ЗащитаОтОпасныхДействий	 = ОписаниеЗащитыБезПредупреждений();
	
	Если ЗащитаОтОпасныхДействий = Неопределено Тогда
		
		// BSLLS:UsingExternalCodeTools-off
		Результат = ВнешниеОбработки.Подключить(АдресОбработки, ИмяВнешнейОбработки, БезопасныйРежим);
		// BSLLS:UsingExternalCodeTools-on
		
	Иначе
		
		// BSLLS:UsingExternalCodeTools-off
		Результат = ВнешниеОбработки.Подключить(АдресОбработки, ИмяВнешнейОбработки, БезопасныйРежим, ЗащитаОтОпасныхДействий);
		// BSLLS:UsingExternalCodeTools-on
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

