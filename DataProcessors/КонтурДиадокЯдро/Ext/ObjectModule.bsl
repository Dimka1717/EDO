Процедура СчетаНаОплату_ПроверитьСброситьКодВалюты(Мета)
	
	ОКВ = ОбщероссийскийКлассификаторВалют();
	СоответствуетОКВ = (ОКВ.Получить(Мета.КодВалюты) <> Неопределено);
	
	Если Не СоответствуетОКВ Тогда
		Буфер = Новый Структура(Мета);
		Буфер.КодВалюты = "";
		Мета = Новый ФиксированнаяСтруктура(Буфер);
	КонецЕсли;
	
КонецПроцедуры

Процедура Общее_ПреобразоватьТаблицыЗначенийВМассивыСтруктур(Структура)
	
	Для Каждого ЭлементСтруктуры Из Структура Цикл
		
		Если ТипЗнч(ЭлементСтруктуры.Значение) = Тип("Структура") Тогда
			
			Общее_ПреобразоватьТаблицыЗначенийВМассивыСтруктур(ЭлементСтруктуры.Значение);
			
		ИначеЕсли ТипЗнч(ЭлементСтруктуры.Значение) = Тип("Массив") Тогда
			
			Для Каждого ЭлементМассива Из ЭлементСтруктуры.Значение Цикл
				
				Если ТипЗнч(ЭлементМассива) = Тип("Структура") Тогда
					Общее_ПреобразоватьТаблицыЗначенийВМассивыСтруктур(ЭлементМассива);
				КонецЕсли;
				
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(ЭлементСтруктуры.Значение) = Тип("ТаблицаЗначений") Тогда
			
			МассивСтруктурИзТаблицы = ТаблицаЗначенийВМассивСтруктур(ЭлементСтруктуры.Значение);
			
			Структура[ЭлементСтруктуры.Ключ] = МассивСтруктурИзТаблицы; 
			
			Для Каждого ЭлементМассива Из МассивСтруктурИзТаблицы Цикл
				
				Общее_ПреобразоватьТаблицыЗначенийВМассивыСтруктур(ЭлементМассива);
		
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

