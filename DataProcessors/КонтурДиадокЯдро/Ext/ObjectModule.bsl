// Инициализирует параметры прокси-сервера
//
// Параметры:
//  НастройкиПрокси - Структура - см. АПИ_Новый_НастройкиПрокси
//
// Возвращаемое значение:
//  ИнтернетПрокси - Настроенный Интернет Прокси
//
Функция НовыйИнтернетПрокси(НастройкиПрокси)
	
	РежимПрокси = НастройкиПрокси.РежимПрокси;
	
	Если РежимПрокси = "UseProxy" Тогда
		
		Результат = Новый ИнтернетПрокси;
		
		АдресПроксиСервера = НастройкиПрокси.АдресПроксиСервера;
		Порт = НастройкиПрокси.ПортПроксиСервера;
		Логин = НастройкиПрокси.ЛогинПроксиСервера;
		Пароль = НастройкиПрокси.ПарольПроксиСервера;
		
		Если НЕ ЗначениеЗаполнено(АдресПроксиСервера) Тогда
			ВызватьИсключение "Заполните настройки прокси";
		КонецЕсли;
		
		Протокол1 = "http";
		Протокол2 = "https";
		Если ЗначениеЗаполнено(Логин) Тогда
			
			Если РежимСовместимостиКонфигурацииНижеВерсии("8.3.6") Тогда
				
				Результат.Установить(Протокол1, АдресПроксиСервера, Порт);
				Результат.Установить(Протокол2, АдресПроксиСервера, Порт);
				
				Результат.Пользователь = Логин;
				Результат.Пароль = Пароль;
				
			ИначеЕсли РежимСовместимостиКонфигурацииНижеВерсии("8.3.7") Тогда
				
				Результат.Установить(Протокол1, АдресПроксиСервера, Порт, Логин, Пароль);
				Результат.Установить(Протокол2, АдресПроксиСервера, Порт, Логин, Пароль);
				
			Иначе
				
				Результат.Установить(Протокол1, АдресПроксиСервера, Порт, Логин, Пароль, Ложь);
				Результат.Установить(Протокол2, АдресПроксиСервера, Порт, Логин, Пароль, Ложь);
				
			КонецЕсли;
			
		Иначе
			
			Результат.Установить(Протокол1, АдресПроксиСервера, Порт);
			Результат.Установить(Протокол2, АдресПроксиСервера, Порт);
			
		КонецЕсли;
		
	ИначеЕсли РежимПрокси = "UseDefaultProxy" Тогда
		
		Результат = Новый ИнтернетПрокси(Истина);
		// Будет использован прокси по умолчанию:
		// либо из файла inetcfg.xml, если он расположен на данной машине, либо из настроек Internet Explorer.
		// Пример файла inetcfg.xml можно найти в официальной документации:
		// https://its.1c.ru/db/v8doc#content:26:1:issogl1_3.13.inetcfg.xml
		
	Иначе
		
		Результат = Новый ИнтернетПрокси(Ложь);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получение идентификатора лицевого счета Диадок
//
// Параметры:
//  ПараметрыСервиса - Структура - Контракт ПараметрыСервиса_Диадок 
//  BoxId			 - Строка - Идентификатор ящика организации
// 
// Возвращаемое значение:
//  Строка - Идентификатор лицевого счета диадок
//  Неопределено - Если не удалось найти
//
Функция АПИ_ИдентификаторЛицевогоСчетаДиадок(ПараметрыСервиса, BoxId) Экспорт
	
	AccountId			= Неопределено;
	ИДПродуктаДиадок	= 7;
	
	Модуль_МетодыAPI 	= Модуль_МетодыAPI(ЭтотОбъект);
	ОтветАПИ 			= Модуль_МетодыAPI.DD_API_GetBillingAccounts(ПараметрыСервиса, BoxId);
	
	СчетаКлиента 		= СвойствоСтруктуры(ОтветАПИ, "BillingAccounts");
	Если СчетаКлиента = Неопределено Тогда
		СчетаКлиента = Новый Массив;
	КонецЕсли;
	
	Для Каждого Счет Из СчетаКлиента Цикл 
		ИдПродукта = СвойствоСтруктуры(Счет, "ProductId");
		Если ИдПродукта = ИДПродуктаДиадок Тогда
			AccountId = СвойствоСтруктуры(Счет, "AccountId");
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	
	Возврат AccountId;
	
КонецФункции 

