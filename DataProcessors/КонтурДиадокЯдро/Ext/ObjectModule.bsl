Процедура Справочники_ВыполнитьСинхронизацию(ДобавитьКонтрагентовДляПриглашения = Истина) Экспорт
	
	КонтекстСеанса = КонтекстСеанса_ОбновитьДанныеЯщиков();
	
	Для Каждого ТекСтрока Из КонтекстСеанса Цикл
		
		СтрокаКонтекста = ТекСтрока.Значение;
		
		Если СтрокаКонтекста.ТребуетсяОплатаСервиса = Истина Тогда
			
			Наименование = СвойствоСтруктуры(СтрокаКонтекста.Box, "Title");
			
			ВидОперации = "Синхронизация справочников";
			ТекстОшибки = "Не оплачен доступ к сервису АПИ";
			ТекстСообщения = "Не удалось синхронизировать справочники";
			ДопИнформация = "Организация: " + Наименование + ", BoxId: " + СтрокаКонтекста.BoxId;
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
			Продолжить;
			
		КонецЕсли;
		
		Идентификаторы = Новый_ИдентификаторыСправочника(СтрокаКонтекста.ОрганизацияДиадок, СтрокаКонтекста.BoxId);
		ТекущаяОрганизация = Организации_ЗаполненныеРеквизиты(Идентификаторы);
		
		Если ЗначениеЗаполнено(ТекущаяОрганизация.ID) Тогда
			
			Организации_ВыполнитьСинхронизацию(ТекущаяОрганизация, СтрокаКонтекста.Box);
			Контрагенты_ВыполнитьСинхронизацию(ТекущаяОрганизация, ДобавитьКонтрагентовДляПриглашения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТипыДокументовAPI_Обновить();
	
КонецПроцедуры

