Процедура КонтурШлюзАвторизации_ОбработатьОтсутствиеПодписки(ДанныеДляЯщика)
	
	ТребуетсяОплатаМодуля = Истина;
	
	Для Каждого ДанныеЛицевогоСчета Из ДанныеДляЯщика.ЛицевыеСчета Цикл
		
		ЛицевойСчет = ДанныеЛицевогоСчета.ЛицевойСчет;
		КодПродукта = ДанныеЛицевогоСчета.КодПродукта;
		
		ПодпискаНаМодульНеТребуется = КонтурШлюзАвторизации_ДляЛицевогоСчетаПодпискаНаМодульНеТребуется(ЛицевойСчет);
		
		Если ПодпискаНаМодульНеТребуется Тогда
			
			ИдентификаторСлужебногоСервиса = КонтурШлюзАвторизации_ИдентификаторСервисаБезПроверки();
			
			СервисПодпискиНаМодуль = Новый_СервисПодпискиСлужебный(ИдентификаторСлужебногоСервиса,
																	ЛицевойСчет,
																	КодПродукта);
			ТребуетсяОплатаМодуля = Ложь;
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТребуетсяОплатаМодуля Тогда
		
		СервисПодпискиНаМодуль = Новый_СервисПодпискиСлужебный("Нет подписки");
		
	КонецЕсли;
	
	ДанныеДляЯщика.СервисПодпискиНаМодуль = СервисПодпискиНаМодуль;
	ДанныеДляЯщика.ТребуетсяОплатаМодуля = ТребуетсяОплатаМодуля;
	
КонецПроцедуры

Функция КонтурШлюзАвторизации_ИдентификаторСервисаБезПроверки()
	
	Возврат "Проверка подписки на модуль отключена";
	
КонецФункции

Функция КонтурШлюзАвторизации_ИдентификаторСервисаНетДанных()
	
	Возврат "Нет данных";
	
КонецФункции

Функция КонтурШлюзАвторизации_ДляЛицевогоСчетаПодпискаНаМодульНеТребуется(ЛицевойСчет)
	
	Результат = Ложь;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Попытка
		
		ТелоОтвета = Модуль_МетодыAPI.Kontur_API_ЛицевыеСчетаБезПодпискиНаМодуль(ПараметрыСервиса);
		ЛицевыеСчетаБезПодписки = ПарсерJSON_Прочитать(ТелоОтвета);
		
	Исключение
		
		ЛицевыеСчетаБезПодписки = Новый Массив;
		
	КонецПопытки;

	Результат = (ЛицевыеСчетаБезПодписки.Найти(ЛицевойСчет) <> Неопределено);
	
	Если НЕ Результат Тогда
		Результат = (ЛицевыеСчетаБезПодписки.Найти(ПустойИдентификатор()) <> Неопределено);
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

// Получить активные подписки для всех лицевых счетов из текущего контекста
// 
// Возвращаемое значение:
//  Соответствие - Данные биллинга для лицевых счетов
//   * Ключ - Строка - идентификатор ящика Диадока
//   * Значение - Массив - активные подписки, см. Контракт_СервисПодписки()
//
Функция КонтурШлюзАвторизации_АктивныеПодпискиДляВсехЛицевыхСчетов()
	
	Результат = Новый Соответствие;
	
	ОбработанныеТокены = Новый Соответствие;
	
	СтрокиКонтекстаСеанса = КонтекстСеанса_СтрокиКонтекста(Истина);
	
	Для Каждого КлючЗначение Из СтрокиКонтекстаСеанса Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		Токен = СтрокаКонтекста.Токен;
		
		Если ОбработанныеТокены.Получить(Токен) = Неопределено Тогда
			ОбработанныеТокены.Вставить(Токен, Истина);
		Иначе
			Продолжить;
		КонецЕсли;
		
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		ПараметрыСервиса = ПараметрыСервиса_Диадок(ИдентификаторЯщика);
		
		ШлюзАвторизации = Модуль_ШлюзАвторизации(ПараметрыСервиса);
		ИмяПродукта = КонтурШлюзАвторизации_ИмяПродукта();
		
		Попытка
			
			ДанныеБиллинга = ШлюзАвторизации.АктивныеПодпискиБиллинга(ИмяПродукта);
			КонтурШлюзАвторизации_ДополнитьДанныеАктивныхПодписок(Результат, ДанныеБиллинга);
            
		Исключение
			
			ВидОперации	 = НСтр("ru = 'Получение активных подписок лицевых счетов'");
			ТекстОшибки	 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки);
			Метрика_ДобавитьОшибку_ПолучениеДанныхБиллинга(ИдентификаторЯщика, ТекстОшибки);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура КонтурШлюзАвторизации_ДополнитьДанныеАктивныхПодписок(Результат, ДанныеБиллинга)
	
	Для Каждого ДанныеBoxId Из ДанныеБиллинга Цикл
		
		BoxId = ДанныеBoxId.Ключ;
		
		Для Каждого ДанныеБиллингаЛицевогоСчета Из ДанныеBoxId.Значение Цикл
			
			АктивныеПодпискиЛС = КонтурШлюзАвторизации_ДанныеАктивныхПодписокЛицевогоСчета(ДанныеБиллингаЛицевогоСчета);
			
			Если ЗначениеЗаполнено(АктивныеПодпискиЛС) Тогда
				
				АктивныеПодпискиЯщика = Результат.Получить(BoxId);
				
				Если АктивныеПодпискиЯщика = Неопределено Тогда
					
					Результат.Вставить(BoxId, АктивныеПодпискиЛС);
					
				Иначе
					
					ДополнитьМассив(АктивныеПодпискиЯщика, АктивныеПодпискиЛС);
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

Функция КонтурШлюзАвторизации_ДанныеАктивныхПодписокЛицевогоСчета(ДанныеБиллингаЛицевогоСчета)
	
	ЛицевойСчет = ДанныеБиллингаЛицевогоСчета.Идентификатор;
	КодПродукта = ДанныеБиллингаЛицевогоСчета.КодПродукта;
	
	Результат = Новый Массив;
	
	Для Каждого ДанныеПодписки Из ДанныеБиллингаЛицевогоСчета.Подписки Цикл
		
		Для Каждого ДанныеСервиса Из ДанныеПодписки.Сервисы Цикл
			
			ТребуетсяДобавить = КонтурШлюзАвторизации_ТребуетсяДобавитьСервисАктивнойПодписки(ДанныеСервиса, КодПродукта);
			
			Если ТребуетсяДобавить Тогда
				
				СервисПодписки = Новый_СервисПодписки(ДанныеПодписки, ДанныеСервиса, ЛицевойСчет, КодПродукта);
				Результат.Добавить(СервисПодписки);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

Функция КонтурШлюзАвторизации_ТребуетсяДобавитьСервисАктивнойПодписки(ДанныеСервиса, КодПродукта)
	
	ИмяСервиса = ДанныеСервиса.Имя;
	
	ЭтоПодпискаНаМодуль = КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(ИмяСервиса);
	ЭтоПодпискаНаПлагин = КонтурШлюзАвторизации_ЭтоПодпискаНаПлагин(ИмяСервиса);
	ЭтоПодпискаНаПакетДиадока = КонтурШлюзАвторизации_ЭтоПодпискаНаПакетДиадока(ИмяСервиса, КодПродукта);
	ЭтоПодпискаНаМаршрут = КонтурШлюзАвторизации_ЭтоПодпискаНаМаршрут(ИмяСервиса);
	
	Если ЭтоПодпискаНаМодуль ИЛИ ЭтоПодпискаНаПлагин Тогда
		
		Результат = Истина;
		
	ИначеЕсли ЭтоПодпискаНаПакетДиадока ИЛИ ЭтоПодпискаНаМаршрут Тогда
		
		Если ЗначениеЗаполнено(ДанныеСервиса.Ресурсы) Тогда
			
			БезлимитноеОграничениеРесурсаПодписки = КонтурШлюзАвторизации_БезлимитноеОграничениеРесурсаПодписки();
			
			ДанныеРесурсаСервиса = ДанныеСервиса.Ресурсы[0];
			
			Результат = ЗначениеЗаполнено(ДанныеРесурсаСервиса.Количество)
						ИЛИ ДанныеРесурсаСервиса.Ограничение = БезлимитноеОграничениеРесурсаПодписки;
			
		Иначе
			
			Результат = Ложь;
			
		КонецЕсли; 
		
	Иначе
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

