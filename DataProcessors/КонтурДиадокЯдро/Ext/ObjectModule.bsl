		Результат.Добавить(ResolutionRoute.ChainId, ResolutionRoute.Name);
	КонецЦикла;
	
	Результат.СортироватьПоПредставлению();
	Результат.Вставить(0, "", "");
	
	Возврат Результат;
	
КонецФункции

//TODO - перевести на контракты подразделений
Функция ПодразделенияОрганизации(Знач BoxId) Экспорт 
	
	BoxId = ИдентификаторВАдресЯщика(BoxId);
	
	ИдентификаторыВладельца	= Новый_ИдентификаторыСправочника(, BoxId);
	Подразделения			= ХранениеДанных_ПодразделенияВладельца(ИдентификаторыВладельца);
	
	Результат = Новый Массив;
	
	Для Каждого Стр Из Подразделения Цикл
		
		Если Стр.Id_РодительПодразделения = "" Тогда
			ParentDepartmentId = ПустойИдентификатор();
		Иначе
			ParentDepartmentId = Стр.Id_РодительПодразделения;
		КонецЕсли;
		
		Подразделение = Новый Структура;
		Подразделение.Вставить("DepartmentId",			Стр.Id);
		Подразделение.Вставить("Name",					Стр.Наименование);
		Подразделение.Вставить("Abbreviation",			Стр.Аббревиатура);
		Подразделение.Вставить("ParentDepartmentId",	ParentDepartmentId);
		
		Результат.Добавить(Подразделение);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


// ИСТОРИЯ ДОКУМЕНТООБОРОТА

Функция Документы_ИсторияДО(Идентификаторы) Экспорт
	
	Результат = Новый Массив;
	
	BoxId = Идентификаторы.BoxId;
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	ТаблицаСобытий = Документы_СобытияДО(ПараметрыСервиса, Идентификаторы);
	
	ТипыВложения = АПИ_Перечисление_AttachmentType();
	
	Для Каждого СтрокаТЗ Из ТаблицаСобытий Цикл
		
		ИсторияДО = Контракт_ИсторияДО();
		ЗаполнитьЗначенияСвойств(ИсторияДО, СтрокаТЗ);
		
		ОтобразитьКакОшибку = (СтрокаТЗ.AttachmentType = ТипыВложения.XmlSignatureRejection)
			ИЛИ (СтрокаТЗ.AttachmentType = ТипыВложения.OuterDocflow
				И Найти(ВРег(СтрокаТЗ.Описание), "ОШИБКА") > 0);
		
		Если ОтобразитьКакОшибку Тогда
			ИсторияДО.Тип = "error";
		Иначе
			ИсторияДО.Тип = ?(ИсторияДО.BoxId = BoxId, "outgoing", "ingoing");
		КонецЕсли;
		
		Если СтрокаТЗ.AttachmentType = ТипыВложения.OuterDocflow Тогда
			
			ЭтоСобытиеГИСМТ = (СтрокаТЗ.DocflowNamedId = ИдентификаторВнешнегоДО_ГИСМТ());
			ЭтоСобытиеПКФНС = (СтрокаТЗ.DocflowNamedId = ИдентификаторВнешнегоДО_ПКФНС());
			ЭтоСобытиеДТС = (СтрокаТЗ.DocflowNamedId = ИдентификаторВнешнегоДО_ДТС());
			ЭтоОписаниеОшибки = (Найти(ВРег(ИсторияДО.Описание), "ОШИБКА") > 0);
			
			Если ЭтоСобытиеПКФНС Тогда
				ИсторияДО.DocflowNamedId = СтрокаТЗ.DocflowNamedId;
				ИсторияДО.Тип = СтрокаТЗ.ТипСобытия;
				ИсторияДО.Детализация = СтрокаТЗ.Детализация;
			КонецЕсли;
			
			Если СтрокаТЗ.СохранятьКонтент Тогда
				
				Если ЭтоСобытиеДТС Тогда
					
					ИсторияДО.ПараметрыСохранения.ПредставлениеСсылки = "Детализация";
					ИсторияДО.ПараметрыСохранения.ИмяОбработчика = "Обработчик_СохранитьКвитанциюДТС";
					ИсторияДО.ПараметрыСохранения.ПараметрОбработчика = СтрокаТЗ.EntityId;
					
				Иначе
					
					ИсторияДО.ПараметрыСохранения.ПредставлениеСсылки = "Детализация";
					ИсторияДО.ПараметрыСохранения.ИмяОбработчика = "Обработчик_СохранитьДетализацию";
					ИсторияДО.ПараметрыСохранения.ПараметрОбработчика = СтрокаТЗ.EntityId;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если ЭтоСобытиеГИСМТ И ЭтоОписаниеОшибки Тогда
				ИсторияДО.ИнструкцияURL = Перечисление_АдресаИнтернетРесурсов().Инструкция_СтатусВнешнегоДО_Ошибка;
			КонецЕсли;
			
		КонецЕсли;
		
		Результат.Добавить(ИсторияДО);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СобытияДО(ПараметрыСервиса, Идентификаторы) Экспорт
	// BSLLS:NestedStatements-off
	// BSLLS:CognitiveComplexity-off
	// BSLLS:CyclomaticComplexity-off
	
	Результат = Новый_ТаблицаСобытийИсторииДО();
	
	ТипВложения = АПИ_Перечисление_AttachmentType();
	
	BoxId = Идентификаторы.BoxId;
	LetterId = Идентификаторы.LetterId;
	DocumentId = Идентификаторы.DocumentId;
	
	ДолжностиПользователей = ДолжностиПользователей(ПараметрыСервиса, BoxId);
	МаршрутыСогласования = МаршрутыСогласования(ПараметрыСервиса, BoxId);
	
	ИдентификаторыОтмененныхСущностей = Новый Массив;
	AttachmentComments = Новый Массив;
	ИдентификаторыСущностейУСДляУдаления = Новый Массив;
	
	DocumentDirection = "";
	ПодписанСРазногласиями = Ложь;
	ОтказаноВПодписи = Ложь;
	
	Message = АПИ_GetMessage(ПараметрыСервиса, BoxId, LetterId, DocumentId, , Истина);
	SortedEntities = МассивСтруктур_Сортировать(Message.Entities, "RawCreationDate, EntityType");
	
	MessageId = Message.MessageId;
	
	Для Каждого Entity Из SortedEntities Цикл
		
		AttachmentType = СвойствоСтруктуры(Entity, "AttachmentType");
		
		Если AttachmentType = "Cancellation" Тогда
			ИдентификаторыОтмененныхСущностей.Добавить(Entity.ParentEntityId);
			Продолжить;
		КонецЕсли;
		
		Если AttachmentType = ТипВложения.CustomData
			ИЛИ AttachmentType = ТипВложения.InvoiceConfirmation
			ИЛИ AttachmentType = ТипВложения.RoamingConfirmation 
			ИЛИ AttachmentType = ТипВложения.PowerOfAttorney 
			ИЛИ AttachmentType = ТипВложения.PowerOfAttorneyStatus Тогда
			Продолжить;
		КонецЕсли;
		
		EntityId = Entity.EntityId;
		EntityType = СвойствоСтруктуры(Entity, "EntityType");
		ParentEntityId = СвойствоСтруктуры(Entity, "ParentEntityId");
		RawCreationDate = СвойствоСтруктуры(Entity, "RawCreationDate");
		Content = СвойствоСтруктуры(Entity, "Content");
		IsApprovementSignature = СвойствоСтруктуры(Entity, "IsApprovementSignature");
		DocumentInfo = СвойствоСтруктуры(Entity, "DocumentInfo");
		SendTimestampTicks = 0;
		
		Если НЕ DocumentInfo = Неопределено Тогда
			DocumentDirection = СвойствоСтруктуры(DocumentInfo, "DocumentDirection", "");
			
			RecipientResponseStatus = СвойствоСтруктуры(DocumentInfo, "RecipientResponseStatus", "");
			ПодписанСРазногласиями = (RecipientResponseStatus = "WithRecipientPartiallySignature");
			ОтказаноВПодписи = (RecipientResponseStatus = "RecipientSignatureRequestRejected");
			SendTimestampTicks = СвойствоСтруктуры(DocumentInfo, "SendTimestampTicks", 0);
			
		КонецЕсли;
		
		Событие = Неопределено;
		СобытиеРодитель = Результат.Найти(ParentEntityId, "EntityId");
		
		Если AttachmentType = ТипВложения.InvoiceReceipt И СобытиеРодитель = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ParentAttachmentType = "";
		Если НЕ СобытиеРодитель = Неопределено Тогда
			ParentAttachmentType = СобытиеРодитель.AttachmentType;
		КонецЕсли;
		
		Если Message.MessageType = "Template" Тогда
			
			Событие = Результат.Добавить();
			Событие.AttachmentType = AttachmentType;
			Событие.RawCreationDate = RawCreationDate;
			Событие.Дата = МестноеВремя(Ticks_2_Date(RawCreationDate));
			
			Если AttachmentType = ТипВложения.TemplateTransformation Тогда
				
				Событие.Подписант = ФамилияИО(Entity.TemplateTransformationInfo.Author);
				Событие.BoxId = Message.TemplateToLetterTransformationInfo.LetterFromBoxId;
				
				TransformedToDocumentId = СвойствоСтруктуры(Entity.TemplateTransformationInfo, "TransformedToDocumentId");
				Если НЕ TransformedToDocumentId = Неопределено Тогда
					
					DocumentEntityId = TransformedToDocumentId.EntityId;
					DocumentMessageId = TransformedToDocumentId.MessageId;
					
					Событие.ДокументURL = СформироватьСсылкуВБраузере(BoxId, DocumentMessageId, DocumentEntityId);
					
				КонецЕсли;
				
				Если Событие.BoxId = Message.FromBoxId Тогда
					Событие.Организация = Message.FromTitle;
				Иначе
					Событие.Организация = Message.ToTitle;
				КонецЕсли;
				
			ИначеЕсли AttachmentType = ТипВложения.TemplateRefusal Тогда
				
				MessageFromBoxId = АдресЯщикаВИдентификатор(Message.FromBoxId);
				TemplateRefusalInfo = Entity.TemplateRefusalInfo;
				
				Событие.Подписант = ФамилияИО(TemplateRefusalInfo.Author);
				Событие.BoxId = TemplateRefusalInfo.BoxId;
				Событие.Комментарий = TemplateRefusalInfo.Comment;
				
				Если MessageFromBoxId = TemplateRefusalInfo.BoxId Тогда
					Событие.Организация = Message.FromTitle;
				Иначе
					Событие.Организация = Message.ToTitle;
				КонецЕсли;
				
			Иначе
				
				Событие.BoxId = АдресЯщикаВИдентификатор(Message.FromBoxId);
				Событие.Организация = Message.FromTitle;
				Событие.EntityId = EntityId;
				Событие.Шаблон = Истина;
				
			КонецЕсли;
				
			Событие.ПодписанСРазногласиями = ПодписанСРазногласиями;
			Событие.ОтказаноВПодписи = ОтказаноВПодписи;
			
			Описание = ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие);
			Событие.Описание = Описание;
				
		ИначеЕсли EntityType = "Attachment" И ЭтоВложениеИсторииДО(AttachmentType) Тогда
			// новое событие добавляем в следующих случаях:
			// 1 - любая сущность Attachment с типом отличным от AttachmentComment и RoamingNotification
			// 2 - согласующая подпись
			// 3 - ответная подпись (определяется по заполненному BoxId в событии родителя)
			
			Если EntityId <> DocumentId ИЛИ SendTimestampTicks <> 0 Тогда
				
				Событие = Результат.Добавить();
				Событие.EntityId = EntityId;
				Событие.AttachmentType = AttachmentType;
				Событие.ParentAttachmentType = ParentAttachmentType;
				Событие.RawCreationDate = RawCreationDate;
				Событие.Дата = МестноеВремя(Ticks_2_Date(Событие.RawCreationDate));
				
				ДанныеМаршрутизации = ДанныеМаршрутизации(AttachmentType, Entity, BoxId);
				ЗаполнитьЗначенияСвойств(Событие, ДанныеМаршрутизации);
				
				Событие.Подписант = ФамилияИО(ДанныеМаршрутизации.Author);
				Событие.Должность = ДолжностиПользователей.Получить(ДанныеМаршрутизации.Author);
				Событие.Маршрут = МаршрутыСогласования.Получить(ДанныеМаршрутизации.RouteId);
				
				Событие.ПодписанСРазногласиями = ПодписанСРазногласиями;
				Событие.ОтказаноВПодписи = ОтказаноВПодписи;
					
				Если AttachmentType = ТипВложения.InvoiceCorrectionRequest
					ИЛИ AttachmentType = ТипВложения.XmlSignatureRejection
					ИЛИ AttachmentType = ТипВложения.RevocationRequest Тогда
					//Или (AttachmentType = "XmlSignatureRejection" И Событие.ParentAttachmentType = "RevocationRequest") Тогда
					
					Если ЭтоВложениеТЭДО(Entity.ContentTypeId) Тогда
						Событие.Комментарий = КомментарийСобытияИсторииДО_ТЭДО(Content);
					Иначе
						Событие.Комментарий = КомментарийСобытияИсторииДО(Content);
					КонецЕсли;
					
					Описание = ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие);
					
				ИначеЕсли AttachmentType = ТипВложения.OuterDocflow Тогда // Данные внешнего ДО
					
					OuterDocflow = Entity.OuterDocflow;
					
					Если OuterDocflow.DocflowNamedId = ИдентификаторВнешнегоДО_ГИСМТ() Тогда
						
						Status = OuterDocflow.Status;
						
						Описание = Status.FriendlyName;
						
						Если ТипЗнч(Status.Details) = Тип("Массив")
							И ЗначениеЗаполнено(Status.Details) Тогда
							
							Комментарий = Status.Details[0].Text; // пока берем только первый элемент
							
						Иначе
							Комментарий = Status.Description;
						КонецЕсли;
						
						Комментарий = _ЗаменитьНедопустимыеСимволыXML(Комментарий);
						
						Событие.DocflowNamedId = OuterDocflow.DocflowNamedId;
						Событие.Комментарий = Комментарий;
						Событие.СохранятьКонтент = ДоступноСохранениеДетализацииГИСМТ(Status.NamedId);
						
					КонецЕсли;
					
					Если OuterDocflow.DocflowNamedId = ИдентификаторВнешнегоДО_ПКФНС() Тогда
						
						ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
						
						MessageFromBoxId = АдресЯщикаВИдентификатор(Message.FromBoxId);
						CurrentBox = АдресЯщикаВИдентификатор(Идентификаторы.BoxId);
						
						Если MessageFromBoxId <> CurrentBox Тогда
							Событие.Организация = Message.FromTitle;
						Иначе
							Событие.Организация = Message.ToTitle;
						КонецЕсли;
						
						Status = OuterDocflow.Status;
						Событие.DocflowNamedId = OuterDocflow.DocflowNamedId;
						Описание = Status.FriendlyName;
						Событие.ТипСобытия = Status.Type;
						Событие.Детализация = ПоместитьВоВременноеХранилище(Status, ИдентификаторФормы);
						
					КонецЕсли;
					
					Если OuterDocflow.DocflowNamedId = ИдентификаторВнешнегоДО_ДТС() Тогда
						
						Status = OuterDocflow.Status;
						
						Описание = Status.FriendlyName;
						
						Если ТипЗнч(Status.Details) = Тип("Массив")
							И ЗначениеЗаполнено(Status.Details) Тогда
							
							Комментарий = Status.Details[0].Text; // пока берем только первый элемент
							
						Иначе
							Комментарий = Status.Description;
						КонецЕсли;
						
						Комментарий = _ЗаменитьНедопустимыеСимволыXML(Комментарий);
						
						Событие.DocflowNamedId = OuterDocflow.DocflowNamedId;
						Событие.Комментарий = Комментарий;
						Событие.СохранятьКонтент = ДоступноСохранениеДетализацииДТС(Status.NamedId);
						
					КонецЕсли;
					
				ИначеЕсли AttachmentType = ТипВложения.MoveDocument Тогда
					
					MoveDocumentInfo = СвойствоСтруктуры(Entity, "MoveDocumentInfo");
					ИдентификаторПодразделения = СвойствоСтруктуры(MoveDocumentInfo, "MovedToDepartment");
					ИдентификаторыСправочника = Новый_ИдентификаторыСправочника(, ИдентификаторПодразделения);
					ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
					Подразделение = Подразделения_ЗаполненныеРеквизиты(ИдентификаторыСправочника, ИдентификаторыОрганизации, Истина);
					
					Событие.DepartmentId = ИдентификаторПодразделения;
					Событие.Department = Подразделение.Наименование;
					
					Описание = ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие);
					
				ИначеЕсли AttachmentType = ТипВложения.UniversalMessage Тогда // События УС
					
					ИнформацияОбУС = Документы_ИсторияДО_ИнформацияОбУС(Entity.UniversalMessageInfo);
					ДанныеУС = Документы_ИсторияДО_ДанныеУС(Entity.Content);
					
					Описание = ОписаниеСобытияИсторииДО_УС(ИнформацияОбУС, ParentAttachmentType);
					Событие.Комментарий = ДанныеУС.ТекстСообщения;
					Событие.Подписант = ОписаниеСобытияИсторииДО_УС_Подписант(ДанныеУС);
					
					ИдентификаторОтправителяУС = ИнформацияОбУС.ИдентификаторСоздателя;
					MessageFromBoxId = АдресЯщикаВИдентификатор(Message.FromBoxId);
					Если MessageFromBoxId = ИдентификаторОтправителяУС Тогда
						Событие.Организация = Message.FromTitle;
					Иначе
						Событие.Организация = Message.ToTitle;
					КонецЕсли;
					
					Если Документы_ИсторияДО_ЕстьДубльСобытияВФорматеУС(ИнформацияОбУС,
						SortedEntities, ParentEntityId, AttachmentType) Тогда
						
						ИдентификаторыСущностейУСДляУдаления.Добавить(EntityId);
						
					КонецЕсли;
					
				Иначе
					
					Описание = ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие);
						
				КонецЕсли;
				
				Событие.Описание = Описание;
				
				Origin = СвойствоСтруктуры(DocumentInfo, "Origin");
				OriginMessageId = СвойствоСтруктуры(Origin, "MessageId");
				OriginMessageType = СвойствоСтруктуры(Origin, "MessageType");
				
				Если OriginMessageType = "Template" И ЗначениеЗаполнено(OriginMessageId) Тогда
					Событие.ШаблонДокументаURL = СформироватьСсылкуВБраузере(BoxId, OriginMessageId, EntityId, Истина);
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли EntityType = "Signature" И НЕ СобытиеРодитель = Неопределено Тогда
			
			SignerBoxId = СвойствоСтруктуры(Entity, "SignerBoxId");
			АдресЯщикаПодписанта = АдресЯщикаВИдентификатор(SignerBoxId);
			
			Если ЗначениеЗаполнено(СобытиеРодитель.BoxId) ИЛИ IsApprovementSignature Тогда
				
				Событие = Результат.Добавить();
				Событие.EntityId = СобытиеРодитель.EntityId;
				Событие.AttachmentType = СобытиеРодитель.AttachmentType;
				Событие.ParentAttachmentType = ParentAttachmentType;
				Событие.IsApprovementSignature = IsApprovementSignature;
				
			Иначе
				Событие = СобытиеРодитель;
			КонецЕсли;
			
			ParentEntity = МассивСтруктур_Найти(SortedEntities, Entity.ParentEntityId, "EntityId");
			ИмяФайлаПодписи = "";
			ИмяФайлаПодписи = СвойствоСтруктуры(ParentEntity, "FileName");
			ИмяФайлаПодписи = СтрЗаменить(ИмяФайлаПодписи, ".xml", "_SGN.sgn" );
			
			ДанныеSignature = АПИ_GetSignatureInfo(
				ПараметрыСервиса,
				BoxId, 
				MessageId, 
				EntityId);
				
			ДанныеSignature.Вставить("ДанныеПодписи", Content.Data);
			ДанныеSignature.Вставить("ИмяФайлаПодписи", ИмяФайлаПодписи);
			ДанныеSignature.Вставить("PowerOfAttorneyAttachmentStatus", Entity.PowerOfAttorneyAttachmentStatus);
			
			ПредставлениеСобытияПодписи = ПредставлениеСобытияПодписи(
						Событие.AttachmentType,
						Событие.ParentAttachmentType);
			ДанныеSignature.Вставить("ПредставлениеСобытияПодписи", ПредставлениеСобытияПодписи);
			
			Событие.Подписант = Документы_ИсторияДО_ПредставлениеПодписанта(ДанныеSignature);
			Событие.Должность = Документы_ИсторияДО_Должность(ДанныеSignature);
			
			Если ЗначениеЗаполнено(АдресЯщикаПодписанта) Тогда
				
				ДанныеОрганизации = АПИ_GetBox(
					ПараметрыСервиса, 
					АдресЯщикаПодписанта);
					
				Если ЗначениеЗаполнено(ДанныеОрганизации) Тогда
						
					Событие.Организация = ДанныеОрганизации.Title; 
					
				КонецЕсли;
				
			КонецЕсли;
			
			ДанныеSignature.Вставить("НаименованиеОрганизацииПодписанта", Событие.Организация);
			
			Событие.BoxId = АдресЯщикаПодписанта;
			Событие.RawCreationDate = RawCreationDate;
			Событие.Дата = МестноеВремя(Ticks_2_Date(Событие.RawCreationDate));
			Событие.ДанныеПодписи = Content.Data;
			
			ЭлектроннаяПодписьИМЧД = Контракт_ЭлектроннаяПодписьИМЧД();
			ЭлектроннаяПодписьИМЧД.ДанныеЭлектроннойПодписи = ДанныеSignature;
			
			ДанныеМЧДДляПодписи = Документы_ИсторияДО_ДанныеМЧД(
					EntityId, 
					SortedEntities,
					BoxID, 
					MessageId, 
					ПараметрыСервиса);
					
			ЭлектроннаяПодписьИМЧД.ДанныеМЧД = ДанныеМЧДДляПодписи;
			
			Событие.АдресЭлектроннаяПодписьИМЧД = ПоместитьВоВременноеХранилище(ЭлектроннаяПодписьИМЧД, ИдентификаторФормы);
			
			Событие.ПодписанСРазногласиями = ПодписанСРазногласиями;
			Событие.ОтказаноВПодписи = ОтказаноВПодписи;
			
			Описание = ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие);
			Событие.Описание = Описание;
			
		ИначеЕсли AttachmentType = ТипВложения.AttachmentComment Тогда
			
			// обработаем комментарии в другом цикле, т.к. они, почему-то, могут идти выше событий
			AttachmentComments.Добавить(Entity);
			
		КонецЕсли;
		
	КонецЦикла;

	Документы_ИсторияДО_ДополнитьКомментарии(Результат, AttachmentComments);
	Документы_ИсторияДО_УдалитьПоИдентификаторам(Результат, ИдентификаторыОтмененныхСущностей);
	Документы_ИсторияДО_УдалитьПоИдентификаторам(Результат, ИдентификаторыСущностейУСДляУдаления);
	
	Результат.Сортировать("RawCreationDate");
	
	Возврат Результат;
	
	// BSLLS:CyclomaticComplexity-on
	// BSLLS:CognitiveComplexity-on
	// BSLLS:NestedStatements-on	
КонецФункции

Функция ЭтоВложениеИсторииДО(ТипВложения)
	
	ТипыВложений = АПИ_Перечисление_AttachmentType();
	
	ИсключаемыеВложения = Новый Массив;
	ИсключаемыеВложения.Добавить(ТипыВложений.AttachmentComment);
	ИсключаемыеВложения.Добавить(ТипыВложений.RoamingNotification);
	
	Результат = (ИсключаемыеВложения.Найти(ТипВложения) = Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоВложениеТЭДО(ТипВложения)
	
	ТипыВложений = Перечисление_ТипыКонтентовТЭДО();
	
	ВложенияТЭДО = Новый Массив;
	Для Каждого Элемент Из ТипыВложений Цикл
		ВложенияТЭДО.Добавить(Элемент.Значение);
	КонецЦикла;
	
	Результат = (ВложенияТЭДО.Найти(ТипВложения) <> Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция Контракт_ЭлектроннаяПодписьИМЧД()
	
	Результат = Новый Структура;
