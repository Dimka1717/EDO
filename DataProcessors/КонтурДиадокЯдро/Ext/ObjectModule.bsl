//{		ДОПОЛНИТЕЛЬНЫЕ ОТЧЕТЫ И ОБРАБОТКИ

Процедура ДополнительныеОтчетыИОбработки_СоздатьОбновить(ДополнительнаяОбработкаСсылка, ФайлОбработки, ИмяОбработки, Группа = Неопределено)
	
	Если ЗначениеЗаполнено(ДополнительнаяОбработкаСсылка) Тогда
		ДополнительнаяОбработкаОбъект = ДополнительнаяОбработкаСсылка.ПолучитьОбъект();
	Иначе
		МенеджерХранилища = Справочники.ДополнительныеОтчетыИОбработки;
		ДополнительнаяОбработкаОбъект = МенеджерХранилища.СоздатьЭлемент();
	КонецЕсли;
	
	ОписаниеОбработки = ВнешниеОбработки_Сведения(ФайлОбработки);
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Вид", Перечисления.ВидыДополнительныхОтчетовИОбработок.ДополнительнаяОбработка);
	ЗначенияЗаполнения.Вставить("Наименование", ОписаниеОбработки.Наименование);
	ЗначенияЗаполнения.Вставить("БезопасныйРежим", ОписаниеОбработки.БезопасныйРежим);
	ЗначенияЗаполнения.Вставить("Информация", ОписаниеОбработки.Информация);
	ЗначенияЗаполнения.Вставить("Версия", ОписаниеОбработки.Версия);
	ЗначенияЗаполнения.Вставить("Публикация", Перечисления.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется);
	ЗначенияЗаполнения.Вставить("ИмяОбъекта", ИмяОбработки);
	ЗначенияЗаполнения.Вставить("ИмяФайла", ИмяОбработки + ".epf");
	Если ЗначениеЗаполнено(Группа) Тогда
		ЗначенияЗаполнения.Вставить("Родитель", Группа);
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДополнительнаяОбработкаОбъект, ЗначенияЗаполнения);
	
	ПоставляемыеКоманды = ОписаниеОбработки.Команды;
	КомандыОбъекта = ДополнительнаяОбработкаОбъект.Команды;
	КомандыОбъекта.Очистить();
	
	ВариантыЗапуска = Перечисления.СпособыВызоваДополнительныхОбработок;
	
	Для Каждого ОписаниеКоманды Из ПоставляемыеКоманды Цикл
		
		Команда = КомандыОбъекта.Добавить();
		Команда.Идентификатор = ОписаниеКоманды.Идентификатор;
		Команда.Представление = ОписаниеКоманды.Представление;
		Команда.ВариантЗапуска = ВариантыЗапуска[ОписаниеКоманды.Использование];
		Команда.ПоказыватьОповещение = ОписаниеКоманды.ПоказыватьОповещение;
		Команда.Модификатор = ОписаниеКоманды.Модификатор;
		Команда.Скрыть = ОписаниеКоманды.Скрыть;
		
	КонецЦикла;
	
	ДополнительнаяОбработкаОбъект.ХранилищеОбработки = Новый ХранилищеЗначения(ФайлОбработки);
	
	ДополнительнаяОбработкаОбъект.Записать();
	
КонецПроцедуры

Функция ДополнительныеОтчетыИОбработки_НайтиСоздатьГруппу(Наименование)
	
	Ссылка = ДополнительныеОтчетыИОбработки_НайтиГруппу(Наименование);
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		
		Ссылка = ДополнительныеОтчетыИОбработки_СоздатьГруппу(Наименование);
		
	КонецЕсли;
	
	Возврат Ссылка;
	
