// Регистрирует целевое действие, связанное с отправкой нового документа в сервис (постинг).
//
// Параметры:
//  Пакет - Структура - отправляемый пакет документов (см. Контракт_Пакет)
//
Процедура МетрикиКонтур_ЗаписатьСобытие_ОбработкаИсходящегоДокумента(Пакет)
	
	НаправленияЭД = Перечисление_Направления();
	
	Если Пакет.Направление <> НаправленияЭД.Исходящее Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "ЦелевоеДействие";
	Действие = "ОбработкаИсходящегоДокумента";
	BoxId = АдресЯщикаВИдентификатор(Пакет.Отправитель.BoxId);
	
	Событие = МетрикиКонтур_НовоеСобытие(Категория, Действие, BoxId);
	МетрикиКонтур_Записать(Событие);
	
КонецПроцедуры

// Регистрирует целевое действие, связанное обработкой существующего электронного документа (патчинг)
//
// Параметры:
//  BoxId - Строка - Идентификатор ящика
//  ДействияПатчинга - Массив из Строка - имена элементов коллекции MessagePatchToPost
//
Процедура МетрикиКонтур_ЗаписатьСобытие_ОбработкаДокумента(BoxId, ДействияПатчинга)
	
	ЦелевыеMessagePatchToPost = Новый Массив;
	ЦелевыеMessagePatchToPost.Добавить("RecipientTitles");
	ЦелевыеMessagePatchToPost.Добавить("Signatures");
	ЦелевыеMessagePatchToPost.Добавить("XmlSignatureRejections");
	ЦелевыеMessagePatchToPost.Добавить("Resolutions");
	ЦелевыеMessagePatchToPost.Добавить("ResolutionRequests");
	ЦелевыеMessagePatchToPost.Добавить("ResolutionRequestCancellations");
	ЦелевыеMessagePatchToPost.Добавить("ResolutionRequestDenials");
	ЦелевыеMessagePatchToPost.Добавить("ResolutionRequestDenialCancellations");
	ЦелевыеMessagePatchToPost.Добавить("ResolutionRouteRemovals");
	ЦелевыеMessagePatchToPost.Добавить("RevocationRequests");
	
	НужноОтправитьМетрику = Ложь;
	
	Для Каждого ДействиеПатчинга Из ДействияПатчинга Цикл
		
		Если ЦелевыеMessagePatchToPost.Найти(ДействиеПатчинга) <> Неопределено Тогда
			НужноОтправитьМетрику = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НужноОтправитьМетрику Тогда
		
		Действие = "ОбработкаДокумента";
		BoxId = АдресЯщикаВИдентификатор(BoxId);
		
		Событие = МетрикиКонтур_НовоеСобытие("ЦелевоеДействие", Действие, BoxId);
		МетрикиКонтур_Записать(Событие);
		
	КонецЕсли;
	
КонецПроцедуры

// Конструктор описания события в модели Pipe.API
//
// Параметры:
//  Категория - Строка - идентификатор Path.Category
//  Действие - Строка - идентификатор Path.Action
//  BoxId - Строка - (Необязательный) идентификатор ящика
// 
// Возвращаемое значение:
//  Структура - модель события
//
Функция МетрикиКонтур_НовоеСобытие(Категория, Действие, Знач BoxId = Неопределено)
	
	Если ЗначениеЗаполнено(BoxId) Тогда
		
		BoxId = АдресЯщикаВИдентификатор(BoxId);
		
		КонтекстЯщика = КонтекстСеанса_СтрокаКонтекста(BoxId);
		
		Marker = Общее_ПодставитьПараметрыВСтроку("%1-%2", КонтекстЯщика.ИНН, КонтекстЯщика.КПП);
		
		PortalSession = НовыйPortalSession(КонтекстЯщика.ОписаниеПользователя.Id);
		NormativeSession = НовыйNormativeSession(Marker, BoxId);
		
	КонецЕсли;
	
	СобытиеПуть = НовоеСобытиеМетрикиКонтур(Категория, Действие);
	Результат = НоваяМетрикаКонтур(СобытиеПуть);
	
	AppContext = НовыйAppContext();
	Session = НовыйSession();
	ClientInfo = НовыйClientInfo();
	
	Если ЗначениеЗаполнено(PortalSession) Тогда
		Session.Вставить("PortalSession", PortalSession);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(NormativeSession) Тогда
		Session.Вставить("NormativeSession", NormativeSession);
	КонецЕсли;
	
	Результат.AppContext = AppContext;
	Результат.Session = Session;
	Результат.ClientInfo = ClientInfo;
	
	Возврат Результат;
	
КонецФункции

// Отправляет событие метрики в сервис сбора метрик. Записывает метрику в лог-файл.
//
// Параметры:
//  Событие - Структура - описание события (см. МетрикиКонтур_НовоеСобытие)
//
Процедура МетрикиКонтур_Записать(Событие)
	
	TopicKey = МетрикиКонтурСлужебный_CommonStatistics();
	Метрика_Логирование(TopicKey, Событие);
	
	МетрикиКонтурСлужебный_Отправить(Событие);
	
КонецПроцедуры

Процедура МетрикиКонтурСлужебный_Отправить(Событие)
	
	Если МетрикиОтключены() Тогда
		Возврат;
	КонецЕсли;
	
	ИмяТопика = МетрикиКонтурСлужебный_CommonStatistics();
	
	СтекСобытий = НовыйСтекСобытийМетрики();
	СтекСобытий.Топики[ИмяТопика].Добавить(Событие);
	
	МетрикиОтправлены = ОтправитьСтекСобытийМетрики(СтекСобытий);
	
	Если НЕ МетрикиОтправлены Тогда
		ОтключитьМетрики();
	КонецЕсли;
	
КонецПроцедуры

