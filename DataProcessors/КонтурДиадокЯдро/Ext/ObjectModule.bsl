//Область Управление ПМ. Программный интерфейс

Процедура УправлениеПМ_ПроверитьВерсииФайловИВыгрузитьВСервис() Экспорт
	
	УправлениеПМ_ПроверитьИзменитьЗначениеНастройкиЗапретаВыгрузкиПМвСервис();
	
	Если НЕ УправлениеПМ_ВозможнаРаботаССервисом() Тогда
		Возврат;
	КонецЕсли;
	
	КоллекцияДанных = УправлениеПМ_СведенияОПодключенныхМодулях();
	
	Для Каждого ОписаниеПМ Из КоллекцияДанных Цикл
		
		УправлениеПМ_ОбновитьПМизСервиса(ОписаниеПМ);
		
		УправлениеПМ_ВыгрузитьПМвСервис(ОписаниеПМ);
		
	КонецЦикла;
	
КонецПроцедуры

//КонецОбласти Управление ПМ. Программный интерфейс

//Область Управление ПМ. Обновление в ИБ

// Скачивает файл ПМ из сервиса, обновляет его (на диске или в справочнике) и подключает к модулю
//
// Параметры:
//  ОписаниеПМ	 - Структура - заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ)
//
Процедура УправлениеПМ_ОбновитьПМизСервиса(ОписаниеПМ)
	
	ЗапрещеноОбновлениеПМ = УправлениеПМ_ЗначениеНастройки_ЗапретитьОбновлениеПМизСервисаДиадок();
	Если ЗапрещеноОбновлениеПМ Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеПМ.ХэшСуммаФайлаОбновления)
		И ОписаниеПМ.ХэшСуммаФайла <> ОписаниеПМ.ХэшСуммаФайлаОбновления Тогда
		
		ФайлОбновления = УправлениеПМ_СкачатьНовуюВерсиюПМ(ОписаниеПМ);
		Если ФайлОбновления <> Неопределено Тогда
			УправлениеПМ_ПодключитьНовуюВерсиюПМ(ФайлОбновления, ОписаниеПМ);	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Скачивает файл ПМ из сервиса, обновляет его (на диске или в справочнике) и подключает к модулю
//
// Параметры:
//  ОписаниеПМ	 - Структура - заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ)
//
// Возвращаемое значение:
//  ДвоичныеДанные, Неопределено - двоичные данные файла ПМ, если удалось скачать.
//
Функция УправлениеПМ_СкачатьНовуюВерсиюПМ(ОписаниеПМ)
	
	Перем Результат;
	
	ТипМодуляAPI 	= ОписаниеПМ.ТипМодуляAPI;
	ИдентификаторПМ	= ОписаниеПМ.ИдентификаторОбновления;
	
	ИдентификаторИБ = ОбщийКонтекст_ИдентификаторБазы1С();
	
	Попытка

		Результат = АПИ_УправлениеПМ_ЗагрузитьФайлОбновления(ИдентификаторИБ, ТипМодуляAPI, ИдентификаторПМ);

	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		Ошибка_ДобавитьВЛог(ОписаниеОшибки);
		
		Метрика_ДобавитьОшибку_ПриСкачиванииФайлаПМизСервиса(ОписаниеОшибки, ОписаниеПМ);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Заменяет ПМ на диске или в справочнике (в зависимости от того, где подключен ПМ) и подключает к модулю
//
// Параметры:
//  ФайлПМ		 - ДвоичныеДанные 	- двоичные данные нового ПМ, полученные из сервиса
//  ОписаниеПМ	 - Структура 		- заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ)
//
Процедура УправлениеПМ_ПодключитьНовуюВерсиюПМ(ФайлПМ, ОписаниеПМ)
	
	ВариантРасположенияПМ 	= ОписаниеПМ.Местоположение;
	
	Если ВариантРасположенияПМ = ВариантРасположенияОбработкиФайл() Тогда
		
		УправлениеПМ_ОбновитьФайлПМнаДиске(ФайлПМ, ОписаниеПМ);
		
	ИначеЕсли ВариантРасположенияПМ = ВариантРасположенияОбработкиСправочник() Тогда
		
		УправлениеПМ_ОбновитьФайлПМвСправочнике(ОписаниеПМ, ФайлПМ);
		
	КонецЕсли;
	
КонецПроцедуры

// Обновляет файл ПМ, расположенный на диске
//
// Параметры:
//  ОписаниеПМ	 - Структура 		- заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ) 
//  НовыйФайлПМ	 - ДвоичныеДанные 	- двоичные данные нового ПМ, полученные из сервиса 
//
Процедура УправлениеПМ_ОбновитьФайлПМнаДиске(НовыйФайлПМ, ОписаниеПМ)
	
	ПутьКФайлуБэкапа = УправлениеПМ_СделатьБэкапФайлаПМ(ОписаниеПМ);
	Если ПутьКФайлуБэкапа = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ФайлИзменен = УправлениеПМ_ЗаменитьФайлПМ(НовыйФайлПМ, ОписаниеПМ);
	Если ФайлИзменен Тогда
		УспешноПодключен = УправлениеПМ_ПодключитьНовыйФайлПМ(ОписаниеПМ);
	Иначе
		УспешноПодключен = Ложь;
	КонецЕсли;
	
	Если УспешноПодключен Тогда
		ОписаниеПМ.ДвоичныеДанные 	= НовыйФайлПМ;
		ОписаниеПМ.ХэшСуммаФайла 	= ОписаниеПМ.ХэшСуммаФайлаОбновления;
	ИначеЕсли ФайлИзменен Тогда
		УправлениеПМ_ВосстановитьПМнаДискеИзБэкапа(ПутьКФайлуБэкапа, ОписаниеПМ);	
	КонецЕсли;
	
	УдалитьФайлы(ПутьКФайлуБэкапа);
	
КонецПроцедуры

// Обновляет файл ПМ, расположенный в справочнике внешних обработок
//
// Параметры:
//  ОписаниеПМ	 - Структура 		- заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ) 
//  НовыйФайлПМ	 - ДвоичныеДанные 	- двоичные данные нового ПМ, полученные из сервиса 
//
Процедура УправлениеПМ_ОбновитьФайлПМвСправочнике(ОписаниеПМ, НовыйФайлПМ)
	
	Попытка
		
		МетаданныеОбъектаКонфигурации = ОписаниеПМ.ПутьКФайлу.Метаданные();
		
		Если ВРег(МетаданныеОбъектаКонфигурации.ПолноеИмя()) = ВРег("Справочник.ДополнительныеОтчетыИОбработки") Тогда
			ИмяРеквизита = "ХранилищеОбработки";
			
		ИначеЕсли ВРег(МетаданныеОбъектаКонфигурации.ПолноеИмя()) = ВРег("Справочник.ВнешниеОбработки") Тогда
			ИмяРеквизита = "ХранилищеВнешнейОбработки";
			
		Иначе
			
			ВызватьИсключение "Не найден справочник дополнительных обработок";
			
		КонецЕсли;
 
		Модуль_ПМ_Отключить();
		
		ОбъектКонфигурации = ОписаниеПМ.ПутьКФайлу.ПолучитьОбъект();
		ОбъектКонфигурации[ИмяРеквизита] = Новый ХранилищеЗначения(НовыйФайлПМ);
		ОбъектКонфигурации.Записать();
	
		Модуль_ПМ(ЭтотОбъект);
		
		ОписаниеПМ.ДвоичныеДанные 	= НовыйФайлПМ;
		ОписаниеПМ.ХэшСуммаФайла 	= ОписаниеПМ.ХэшСуммаФайлаОбновления;
				
	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		
		ШаблонТекстаОшибки ="Произошла ошибка при обновлении ПМ в справочнике доп. обработок.
		|Имя обработки в справочнике: %1
		|Описание ошибки: %2";
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонТекстаОшибки, ОписаниеПМ.ИмяФайла, ОписаниеОшибки);
		
		Ошибка_ДобавитьВЛог(ТекстОшибки);
		
		Метрика_ДобавитьОшибку_ПриОбновленииФайлаПМ(ТекстОшибки, ОписаниеПМ);
		
	КонецПопытки;
	
КонецПроцедуры

//КонецОбласти Управление ПМ. Обновление в ИБ

//Область Управление ПМ. Выгрузка ПМ в сервис

// Выгружает подключаемый модуль в удаленную базу ПМ (через API)
//
// Параметры:
//  ОписаниеПМ	 - Структура - сведения о выгружаемом подключаемом модуле
//		* см. Контракт_ОписаниеПМ
//
Процедура УправлениеПМ_ВыгрузитьПМвСервис(ОписаниеПМ)
	
	ЗапрещенаВыгрузкаПМ = УправлениеПМ_ЗначениеНастройки_ЗапретитьВыгрузкуПМвСервисДиадок();
	ФайлИзменился = УправлениеПМ_ХэшСуммаФайлаИзменилась(ОписаниеПМ);
	
	Если ЗапрещенаВыгрузкаПМ Или НЕ ФайлИзменился Тогда
		Возврат;		
	КонецЕсли;
	
	ИдентификаторИБ = ОбщийКонтекст_ИдентификаторБазы1С();
	
	ФайлБылОбновлен = (ОписаниеПМ.ХэшСуммаФайла = ОписаниеПМ.ХэшСуммаФайлаОбновления);
	
	Попытка
		
		Если ФайлБылОбновлен Или Не ЗначениеЗаполнено(ОписаниеПМ.Идентификатор) Тогда
			ОписаниеПМвСервисе = АПИ_УправлениеПМ_ВыгрузитьВСервис(ОписаниеПМ, ИдентификаторИБ);
			ОписаниеПМ.Идентификатор = ОписаниеПМвСервисе.id;
		Иначе 
			ОписаниеПМвСервисе = АПИ_УправлениеПМ_ОбновитьВСервисе(ОписаниеПМ, ИдентификаторИБ);
		КонецЕсли;
		
	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		Ошибка_ДобавитьВЛог(ОписаниеОшибки);
		
		Метрика_ДобавитьОшибку_ПриВыгрузкеПМвСервис(ОписаниеОшибки, ОписаниеПМ);
		
	КонецПопытки;
		
КонецПроцедуры

// ВАЖНО! Если в настройках модуля установлено для ЗапретитьОбновлениеПМизСервисаДиадок значение Ложь,
// то значение настройки ЗапретитьВыгрузкуПМвСервисДиадок также меняется на Ложь, поскольку если 
// разрешено обновление ПМ, то нам обязательно требуется выгрузка актуальных ПМ в сервис.
// Не очевидно для пользователя. Последствия разделения настройки отдельно на выгрузку и отдельно на обновление.
// И отсутствия этих настроек в интерфейсе модуля.
// 
Процедура УправлениеПМ_ПроверитьИзменитьЗначениеНастройкиЗапретаВыгрузкиПМвСервис()
	
	ЗапрещеноОбновлениеПМ = УправлениеПМ_ЗначениеНастройки_ЗапретитьОбновлениеПМизСервисаДиадок();
	ЗапрещенаВыгрузкаПМ = УправлениеПМ_ЗначениеНастройки_ЗапретитьВыгрузкуПМвСервисДиадок();
	
	Если НЕ ЗапрещеноОбновлениеПМ И ЗапрещенаВыгрузкаПМ Тогда
		ОбщиеНастройки_Поместить("ЗапретитьВыгрузкуПМвСервисДиадок", Ложь);	
	КонецЕсли;
	
КонецПроцедуры

//КонецОбласти Управление ПМ. Выгрузка ПМ в сервис

//Область Управление ПМ. Сведения о подключаемых модулях

// Контракт сведения о подключаемом модуле
// 
// Возвращаемое значение:
//  Структура - содержит сведения о ПМ
//		- ИмяФайла 					- Строка - имя файла (например, имя файла, как оно задано в системе)
//		- Местоположение			- Строка - значение программного перечисления см. Перечисление_ВариантыМестоположенияПМ()
//		- ПутьКФайлу				- Строка - произвольное значение. Путь к файлу на диске или имя файла в справочнике доп. обработок.
//		- ТипМодуляAPI				- Строка - значение программного перечисления см. АПИ_Перечисление_ТипыПМ()
//		- ХэшСуммаФайла				- Строка - MD5 хэш-сумма файла
//		- ХэшСуммаФайлаВСервисе		- Строка - MD5 хэш-сумма последнего выгруженного файла в сервис
//		- ХэшСуммаФайлаОбновления	- Строка - MD5 хэш-сумма файла обновления из сервиса
//		- ИдентификаторИБ			- Строка - идентификатор текущей ИБ см. ЗначениеНастройки_ИдентификаторБазы1С()
//		- Описание					- Строка - произвольная доп. информация о модуле
//		- ДвоичныеДанные			- ДвоичныеДанные - двоичные данные файла
//
Функция Контракт_ОписаниеПМ()

	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор"			, "");
	Результат.Вставить("ИдентификаторОбновления", "");
	Результат.Вставить("ИмяФайла"				, "");
	Результат.Вставить("Местоположение"			, "");
	Результат.Вставить("ПутьКФайлу"				, "");
	Результат.Вставить("ТипМодуляAPI"			, "");
	Результат.Вставить("Описание"				, "");
	Результат.Вставить("ХэшСуммаФайла"			, "");
	Результат.Вставить("ХэшСуммаФайлаВСервисе"	, "");
	Результат.Вставить("ХэшСуммаФайлаОбновления", "");
	
	Результат.Вставить("ДвоичныеДанные"	, Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Возращает коллекцию с информацией о подключенных модулях (УМ и/или Стандарт)
// 
// Возвращаемое значение:
//  Массив - элементы массива содержат данные о ПМ
//   Элемент массива - Структура - см. Контракт_ОписаниеПМ()
//
Функция УправлениеПМ_СведенияОПодключенныхМодулях()
	
	Результат = Новый Массив;
	
	УправлениеПМ_ДобавитьСведенияОПодключаемомМодуле(Результат);
	
	УправлениеПМ_ДобавитьСведенияОПодключаемомМодулеСтандарт(Результат);
	
	Возврат Результат;
	
КонецФункции

// Возращает коллекцию с информацией о подключенном модуле УМ
//
// Параметры:
//  КоллекцияПМ	 - Массив - коллекция, куда необходимо поместить сведения о ПМ
// 
// Возвращаемое значение:
//  Структура - заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ)
//
Процедура УправлениеПМ_ДобавитьСведенияОПодключаемомМодуле(КоллекцияПМ)
	
	ТипыМодулейAPI = АПИ_Перечисление_ТипыПМ();
    
	НастройкиМодуля = ХранениеДанных_ОбщиеНастройки();
	
	ОписаниеПМ = УправлениеПМ_ПолучитьОписаниеПМ(НастройкиМодуля, ТипыМодулейAPI.ПМУниверсальногоМодуля);
	Если ОписаниеПМ <> Неопределено Тогда
		КоллекцияПМ.Добавить(ОписаниеПМ);
	КонецЕсли;
	
КонецПроцедуры

// Возращает коллекцию с информацией о подключенном модуле Стандарт
//
// Параметры:
//  КоллекцияПМ	 - Массив - коллекция, куда необходимо поместить сведения о ПМ
// 
// Возвращаемое значение:
//  Структура - заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ)
//
Процедура УправлениеПМ_ДобавитьСведенияОПодключаемомМодулеСтандарт(КоллекцияПМ)

	ТипыМодулейAPI = АПИ_Перечисление_ТипыПМ();
    
	НастройкиМодуля = ХранениеДанных_НастройкиМодуляСтандарт();
	
	ОписаниеПМ = УправлениеПМ_ПолучитьОписаниеПМ(НастройкиМодуля, ТипыМодулейAPI.ПМСтандарта);
	Если ОписаниеПМ <> Неопределено Тогда
		КоллекцияПМ.Добавить(ОписаниеПМ);
	КонецЕсли;

КонецПроцедуры

// Заполняет сведения о подключенном модуле
//
// Параметры:
//  Настройки	 - Структура - общие настройки или настройки модуля Стандарт (см. ХранениеДанных_ОбщиеНастройки()
//								или ХранениеДанных_НастройкиМодуляСтандарт())
// 
// Возвращаемое значение:
//  Структура - контракт сведений о ПМ (см. Контракт_ОписаниеПМ) 
//
Функция УправлениеПМ_ПолучитьОписаниеПМ(Настройки, ТипМодуляAPI)
	
	Результат = Неопределено;
	
	Если НЕ Настройки.ИспользоватьПодключаемыйМодуль Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяФайла 				= "";
	ПутьКФайлу 				= "";
	ДвоичныеДанные	 		= Неопределено;
	
	ВариантРасположения = Настройки.МестонахождениеПодключаемогоМодуля;
	
	Если ВариантРасположения = ВариантРасположенияОбработкиФайл() Тогда
		
		ДвоичныеДанные 	= ДвоичныеДанныеФайла(Настройки.ПодключаемыйМодульПуть);
		ПутьКФайлу		= Настройки.ПодключаемыйМодульПуть;
		ИмяФайла 		= РеквизитыИмениФайла(Настройки.ПодключаемыйМодульПуть).Имя;
		
	ИначеЕсли ВариантРасположения = ВариантРасположенияОбработкиСправочник() Тогда
		
		ДвоичныеДанные 	= ОбновленияМодуля_ДвоичныеДанныеВнешнейОбработки(Настройки.ПодключаемыйМодульСсылка);
		ПутьКФайлу		= Настройки.ПодключаемыйМодульСсылка;
		
		Если ПроверитьНаличиеОбъектаМетаданных("Справочники.ДополнительныеОтчетыИОбработки.Реквизиты.ИмяФайла") Тогда
			ЗначенияРеквизитов = Общее_ЗначенияРеквизитовОбъекта(Настройки.ПодключаемыйМодульСсылка, "ИмяФайла");
			ИмяФайла = ЗначенияРеквизитов.ИмяФайла;
		Иначе
			ЗначенияРеквизитов = Общее_ЗначенияРеквизитовОбъекта(Настройки.ПодключаемыйМодульСсылка, "Наименование");
			ИмяФайла = Общее_ПодставитьПараметрыВСтроку("%1.epf", ЗначенияРеквизитов.Наименование);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДвоичныеДанные <> Неопределено Тогда
		
		Результат = Контракт_ОписаниеПМ();
		
		Результат.ИмяФайла 			= ИмяФайла;
		Результат.Местоположение 	= ВариантРасположения;
		Результат.ПутьКФайлу 		= ПутьКФайлу;
		Результат.ДвоичныеДанные 	= ДвоичныеДанные;
		Результат.ТипМодуляAPI	 	= ТипМодуляAPI;
		
		Попытка
			
			ИмяФункции = "MD5";
			Результат.ХэшСуммаФайла = ВРег(ВнешниеСервисы_РассчитатьХэш(ДвоичныеДанные, ИмяФункции));
			
			УправлениеПМ_ДополнитьСведенияИзСервиса(Результат);
			
		Исключение
			
			Результат.ХэшСуммаФайла = "";
			
			ОписаниеОшибки = ОписаниеОшибки();
			Ошибка_ДобавитьВЛог(ОписаниеОшибки);
			
			Метрика_ДобавитьОшибку_ПриВыгрузкеПМвСервис(ОписаниеОшибки, Результат);
			
		КонецПопытки;
        	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Дополняет поля контракта сведений о ПМ данными из сервиса:
//	- Идентификатор ПМ
//	- Хэш сумма последнего выгруженного ПМ
//	- Хэш сумма обновления (если есть)
//
// Параметры:
//  ОписаниеПМ	 - Структура - сведения о выгружаемом подключаемом модуле
//		* см. Контракт_ОписаниеПМ
//
Процедура УправлениеПМ_ДополнитьСведенияИзСервиса(ОписаниеПМ)

	ТипМодуляAPI 	= ОписаниеПМ.ТипМодуляAPI;
	ХэшСуммаФайла	= ОписаниеПМ.ХэшСуммаФайла;
	ИдентификаторИБ = ОбщийКонтекст_ИдентификаторБазы1С();
	
	ДанныеСервиса = АПИ_УправлениеПМ_ОписаниеПоследнегоПМ(ИдентификаторИБ, ТипМодуляAPI);
	Если ДанныеСервиса <> Неопределено Тогда
		ОписаниеПМ.Идентификатор 			= ДанныеСервиса.id;
		ОписаниеПМ.ХэшСуммаФайлаВСервисе 	= ВРег(ДанныеСервиса.hash_md5);
	КонецЕсли;

	ОписаниеОбновления = АПИ_УправлениеПМ_ОписаниеФайлаОбновления(ИдентификаторИБ, ТипМодуляAPI, ХэшСуммаФайла); 
	Если ОписаниеОбновления <> Неопределено
		И ОписаниеОбновления.updated > ДанныеСервиса.updated Тогда
		ОписаниеПМ.ИдентификаторОбновления = ОписаниеОбновления.id;
		ОписаниеПМ.ХэшСуммаФайлаОбновления = ВРег(ОписаниеОбновления.hash_md5);
	КонецЕсли;
	
КонецПроцедуры

//КонецОбласти Управление ПМ. Сведения о подключаемых модулях

//Область Управление ПМ. Служебные методы

// Проверяет возможность выгрузки ПМ в сервис. Обновление ПМ и выгрузка в сервис не возможны, если выполняется хотя бы одно условие:
//	- НЕ включен режим тестовой выгрузки в сервис (настраивается в параметрах запуска 1с)
//	- пользователь системы находится в домене *kontur.ru
//	- включена отладка модуля
//	- модуль запущен в режиме автотестов (определяется параметром запуска Автотест) 
//	- это НЕ тестовая база
// 
// Возвращаемое значение:
//  Булево - Истина - будет выполнена попытка обновления ПМ, если есть, и выгрузка ПМ в сервис
//
Функция УправлениеПМ_ВозможнаРаботаССервисом()
	
	Результат = Истина;
	
	Если УправлениеПМ_РежимТестовойВыгрузкиВСервис() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если РежимОтладкиВключен()
		Или Общее_ЭтоКопияИнформационнойБазы()
		Или ОбновлениеМодуля_ЭтоТестовыйЗапуск() Тогда	
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция УправлениеПМ_ЗначениеНастройки_ЗапретитьОбновлениеПМизСервисаДиадок()
	
	ИмяНастройки = УправлениеПМ_ИмяНастройкиЗапретитьОбновлениеПМизСервисаДиадок();
	СохраненноеЗначение = ОбщиеНастройки_Прочитать(ИмяНастройки);
	ТипНастройки = Тип("Булево");
	ЗначениеПоУмолчанию = Истина;
	
	Результат = ЗначениеНастройки(СохраненноеЗначение, ТипНастройки, ЗначениеПоУмолчанию);
	
	Возврат Результат;
	
КонецФункции

Функция УправлениеПМ_ЗначениеНастройки_ЗапретитьВыгрузкуПМвСервисДиадок()

	СохраненноеЗначение = ОбщиеНастройки_Прочитать("ЗапретитьВыгрузкуПМвСервисДиадок");
	ТипНастройки = Тип("Булево");
	ЗначениеПоУмолчанию = Ложь;
	
	Результат = ЗначениеНастройки(СохраненноеЗначение, ТипНастройки, ЗначениеПоУмолчанию);
	
	Возврат Результат;
	
КонецФункции

Функция УправлениеПМ_ИмяНастройкиЗапретитьОбновлениеПМизСервисаДиадок()

	Возврат "ЗапретитьОбновлениеПМизСервисаДиадок";
	
КонецФункции

Процедура УправлениеПМ_УдалитьСтарыеЗаписиНастроек()
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	ИмяНастройки = "ЗапретитьСинхронизациюПМсСервисомДиадок";
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	Модуль_ХранениеДанных.ОбщиеНастройки_УдалитьЗапись(ИмяНастройки);
	
КонецПроцедуры

Процедура УправлениеПМ_ВключитьФункциональностьОбновленияПМ()
	
	ЗапретитьОбновлениеПМ = УправлениеПМ_ЗначениеНастройки_ЗапретитьОбновлениеПМизСервисаДиадок();
	Если ЗапретитьОбновлениеПМ Тогда
		
		ИдентификаторИБ = ОбщийКонтекст_ИдентификаторБазы1С();
		ОбновлениеЗаблокировано = АПИ_УправлениеПМ_ОбновлениеЗаблокировано(ИдентификаторИБ);
		
		Если НЕ ОбновлениеЗаблокировано Тогда
			ИмяНастройки = УправлениеПМ_ИмяНастройкиЗапретитьОбновлениеПМизСервисаДиадок();
			ЗначениеНастройки = Ложь;
			ОбщиеНастройки_Поместить(ИмяНастройки, ЗначениеНастройки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УправлениеПМ_ПриЗапускеНовойВерсииМодуля()
	
	УправлениеПМ_УдалитьСтарыеЗаписиНастроек();	
	УправлениеПМ_ВключитьФункциональностьОбновленияПМ();
	
КонецПроцедуры

Функция УправлениеПМ_РежимТестовойВыгрузкиВСервис()
	
	Результат = СвойствоСтруктуры(ОбщийКонтекстКлиентСервер, "ТестВыгрузкиПМвСервис", Ложь);
	
	Возврат Результат;
	
КонецФункции

