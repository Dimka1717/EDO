Процедура HTML_СобытияЛентыКонтрагентовДобавитьКнопку(
		СтрокаКнопки, 
		ИмяДействия, 
		ТекстКнопки, 
		ИдентификаторКонтрагента)
	
	Оповещение = ПараметрыОповещенияВСтрокуHTMLСообщения(
		ИмяДействия, 
		ИдентификаторКонтрагента);
		
	КнопкаHTML = "<div class=""buttondiv""><a href=""" 
		+ Оповещение 
		+ """ class=""button"">" 
		+ ТекстКнопки 
		+ "</a></div>";
	
	СтрокаКнопки = СтрокаКнопки + КнопкаHTML;
	
КонецПроцедуры

// BSLLS:CognitiveComplexity-off
// BSLLS:CyclomaticComplexity-off
// BSLLS:NumberOfParams-off
// BSLLS:MissingParameterDescription-off
Процедура HTML_СобытияЛентыКонтрагентовСтрокаСтатуса(
		Результат,
		Знач ДанныеОрганизации,
		Знач СтрокаКонтрагента,
		Знач ЕстьСопоставление,
		Знач Статус,
		Знач ТипСобытия,
		Знач ДатаСобытия,
		Знач Комментарий)
	
	ПеречислениеСтатусы = Перечисление_СтатусыКонтрагентов();
	ИдентификаторКонтрагента = СтрокаКонтрагента.ID;
	НаименованиеКонтрагента = СтрокаКонтрагента.Наименование;
	МожноОбмениватьсяДокументами = "Можно обмениваться документами";
	ОбычныйСтатус = "status";
	СтатусЗеленый = "success";
	СтатусКрасный = "reject";
	КонецБлока = "</div>";
	
	ИдентификаторФНСОператора = ИдентификаторФНСИзИдентификаторУчастникаЭДО(
			СтрокаКонтрагента.ИдентификаторУчастникаЭДО);
	
	ОператорЭДО = "";
	Если ИдентификаторФНСОператора <> ИдентификаторОператораКонтур() Тогда
		
		ОператорЭДО = ПредставлениеОператораЭДО(
				ИдентификаторФНСОператора,
				ДанныеОрганизации.ID);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаКонтрагента.КПП) Тогда
		ШаблонИННКПП = "%1 - %2";
	Иначе
		ШаблонИННКПП = "%1";
	КонецЕсли;
	
	ТекстИННКПП = Общее_ПодставитьПараметрыВСтроку(
			ШаблонИННКПП,
			СтрокаКонтрагента.ИНН,
			СтрокаКонтрагента.КПП);
	
	Если ЗначениеЗаполнено(ОператорЭДО) Тогда
		ШаблонСтроки = "%1 / %2 / %3";
	Иначе
		ШаблонСтроки = "%1 / %2";
	КонецЕсли;
	
	ТекстЗаголовкаСтроки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонСтроки,
			НаименованиеКонтрагента,
			ТекстИННКПП,
			ОператорЭДО);
	
	Результат = Результат + "<div class=""content"">";
	Результат = Результат + "<div class=""company"">"
		+ ТекстЗаголовкаСтроки
		+ КонецБлока;
	
	КлассСтатуса = "";
	ПредставлениеСтатуса = "";
	СтрокаКнопки = "";
	
	// BSLLS:IfElseIfEndsWithElse-off
	Если ТипСобытия = "CounteragentInvitedMe"
		И Статус = ПеречислениеСтатусы.ПриглашаютВас Тогда
		
		КлассСтатуса = ОбычныйСтатус;
		ПредставлениеСтатуса = "Контрагент приглашает обмениваться документами";
		HTML_СобытияЛентыКонтрагентовДобавитьКнопку(
			СтрокаКнопки,
			"ПосмотретьПриглашениеКонтрагента",
			"Посмотреть приглашение",
			ИдентификаторКонтрагента);
		
	ИначеЕсли ТипСобытия = "IInvitedCounteragent"
		И Статус = ПеречислениеСтатусы.ОжидаетсяОтвет Тогда
		
		КлассСтатуса = ОбычныйСтатус;
		ПредставлениеСтатуса = "Ждем ответ на приглашение";
		
		Если НЕ ЕстьСопоставление Тогда
			HTML_СобытияЛентыКонтрагентовДобавитьКнопкуОткрытьСопоставление(
				ИдентификаторКонтрагента,
				СтрокаКнопки);
		КонецЕсли;
		
	ИначеЕсли ТипСобытия = "CounteragentAcceptedInvitation"
		И Статус = ПеречислениеСтатусы.ПартнерскиеОтношения Тогда
		
		Если НЕ ЕстьСопоставление Тогда
			КлассСтатуса = ОбычныйСтатус;
			ПредставлениеСтатуса = "Контрагент принял приглашение";
			HTML_СобытияЛентыКонтрагентовДобавитьКнопкуОткрытьСопоставление(
				ИдентификаторКонтрагента,
				СтрокаКнопки);
		Иначе
			КлассСтатуса = СтатусЗеленый;
			ПредставлениеСтатуса = МожноОбмениватьсяДокументами;
		КонецЕсли;
		
	ИначеЕсли ТипСобытия = "IAcceptedInvitation"
		И Статус = ПеречислениеСтатусы.ПартнерскиеОтношения Тогда
		
		Если НЕ ЕстьСопоставление Тогда
			КлассСтатуса = ОбычныйСтатус;
			ПредставлениеСтатуса = "Мы приняли приглашение";
			HTML_СобытияЛентыКонтрагентовДобавитьКнопкуОткрытьСопоставление(
				ИдентификаторКонтрагента,
				СтрокаКнопки);
		Иначе
			КлассСтатуса = СтатусЗеленый;
			ПредставлениеСтатуса = МожноОбмениватьсяДокументами;
		КонецЕсли;
		
	ИначеЕсли ТипСобытия = "CounteragentRejectedInvitation" Тогда
		
		КлассСтатуса = СтатусКрасный;
		ПредставлениеСтатуса = "Контрагент отклонил наше приглашение";
		
	ИначеЕсли ТипСобытия = "IRejectedInvitation" Тогда
		
		КлассСтатуса = СтатусКрасный;
		ПредставлениеСтатуса = "Мы отклонили приглашение контрагента";
		
	ИначеЕсли ТипСобытия = "CounteragentBrokeUpWithMe" Тогда
		
		КлассСтатуса = СтатусКрасный;
		ПредставлениеСтатуса = "Контрагент заблокировал нас";
		
	ИначеЕсли ТипСобытия = "IBrokeUpWithCounteragent" Тогда
		
		КлассСтатуса = СтатусКрасный;
		ПредставлениеСтатуса = "Мы заблокировали контрагента";
		
	ИначеЕсли ТипСобытия = "CounteragentWithdrewInvitation" Тогда
		
		КлассСтатуса = ОбычныйСтатус;
		ПредставлениеСтатуса = "Контрагент отозвал свое приглашение";
		
	ИначеЕсли ТипСобытия = "IWithdrewInvitation" Тогда
		
		КлассСтатуса = ОбычныйСтатус;
		ПредставлениеСтатуса = "Мы отозвали свое приглашение";
		
	ИначеЕсли ТипСобытия = "IForgotCounteragent"
		ИЛИ ТипСобытия = "CounteragentForgotMe" Тогда
		
		КлассСтатуса = СтатусКрасный;
		ПредставлениеСтатуса = "Отношения с контрагентом разорваны";
		
	ИначеЕсли ТипСобытия = "IMadeCounteragent"
		ИЛИ ТипСобытия = "CounteragentMadeMe" Тогда
		
		Если НЕ ЕстьСопоставление Тогда
			КлассСтатуса = ОбычныйСтатус;
			ПредставлениеСтатуса = "Отношения с контрагентом установлены";
			HTML_СобытияЛентыКонтрагентовДобавитьКнопкуОткрытьСопоставление(
				ИдентификаторКонтрагента,
				СтрокаКнопки);
		Иначе
			КлассСтатуса = СтатусЗеленый;
			ПредставлениеСтатуса = МожноОбмениватьсяДокументами;
		КонецЕсли;
		
	КонецЕсли;
	// BSLLS:IfElseIfEndsWithElse-on
	
	// Проверка на комментарий, если это событие отказа или разрыва
	Если КлассСтатуса = СтатусКрасный Тогда
		
		Если НЕ ЗначениеЗаполнено(Комментарий)
			И НЕ Статус = ПеречислениеСтатусы.РаботаетВДиадок
			И (ТипСобытия = "CounteragentInvitedMe"
				ИЛИ ТипСобытия = "IInvitedCounteragent") Тогда
			
			ДанныеПриглашения = Контрагенты_СведенияОПриглашении(
					ДанныеОрганизации.ID,
					ДанныеОрганизации.OrgId,
					СтрокаКонтрагента.OrgID);
			
			Комментарий = ДанныеПриглашения.Комментарий;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Комментарий) Тогда
			
			ЗаголовокФормыПредупреждения = "Вас заблокировали";
			ТекстПредупреждения = НаименованиеКонтрагента
				+ " добавила вас в список ""Заблокированные"", 
				|и вы не сможете больше обмениваться документами";
			
			Если ТипСобытия = "IForgotCounteragent"
				ИЛИ ТипСобытия = "IWithdrewInvitation"
				ИЛИ ТипСобытия = "IBrokeUpWithCounteragent"
				ИЛИ ТипСобытия = "IRejectedInvitation" Тогда
				
				ЗаголовокФормыПредупреждения = "Вы заблокировали контрагента";
				ТекстПредупреждения = "Вы добавили "
					+ НаименованиеКонтрагента
					+ " в список ""Заблокированные"", 
					|и вы не сможете больше обмениваться документами";
				
			КонецЕсли;
			
			ДанныеДляОповещения = Новый Структура;
			ДанныеДляОповещения.Вставить("Комментарий", Комментарий);
			ДанныеДляОповещения.Вставить("ЗаголовокФормыПредупреждения", ЗаголовокФормыПредупреждения);
			ДанныеДляОповещения.Вставить("ТекстПредупреждения", ТекстПредупреждения);
			
			СтрокаДляОповещения = ПарсерJSON_Записать(ДанныеДляОповещения);
			ДанныеДляОповещенияДвоичные = ДвоичныеДанныеИзСтроки(СтрокаДляОповещения);
			СтрокаBase64 = Base64Строка(ДанныеДляОповещенияДвоичные);
			СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ВК, "");
			СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ПС, "");
			
			HTML_СобытияЛентыКонтрагентовДобавитьКнопку(
				СтрокаКнопки,
				"ПосмотретьКомментарииКонтрагента",
				"Посмотреть комментарий",
				СтрокаBase64);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(КлассСтатуса) Тогда
		HTMLСтатус = "<div class=""" + КлассСтатуса + """>" + ПредставлениеСтатуса + КонецБлока;
		Результат = Результат + HTMLСтатус;
	КонецЕсли;
	
	Результат = Результат + СтрокаКнопки;
	Результат = Результат + "
		|<div class=""timestamp"">" + ДатаСобытия + КонецБлока;
	Результат = Результат + КонецБлока;
	
КонецПроцедуры
// BSLLS:CognitiveComplexity-on
// BSLLS:CyclomaticComplexity-on
// BSLLS:NumberOfParams-on
// BSLLS:MissingParameterDescription-on

Процедура HTML_СобытияЛентыКонтрагентовДобавитьКнопкуОткрытьСопоставление(
