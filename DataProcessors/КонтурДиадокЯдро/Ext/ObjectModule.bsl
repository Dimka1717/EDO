// Получить авторизацию биллинга для ящика организации
//
// Параметры:
//  BoxId - Строка - идентификатор ящика.
//  ПараметрыСервиса - Структура - см. функцию ПараметрыСервиса_Диадок();
// 
// Возвращаемое значение:
//  Структура - Данные биллинга для ящика
//   * ЛицевыеСчета - Массив - Массив лицевых счетов ящика
//   * СервисПодпискиНаМодуль - Структура - см. Контракт_СервисПодписки()
//   * ТребуетсяОплатаМодуля - Булево - признак наличия оплаченной подписки на модуль
//
Функция КонтурШлюзАвторизации_АвторизацияБиллинга(BoxId, Знач ПараметрыСервиса)
	
	Результат = Неопределено;
	
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(BoxId);
	
	КлючКэша = КонтурШлюзАвторизации_ДанныеБиллингаКлючКэша();
	
	Кэш = Кэш_Прочитать(КлючКэша);
	
	Если Кэш = Неопределено Тогда
		Кэш = Новый Соответствие;
	КонецЕсли;
	
	ДанныеБиллингаДляТокена = Кэш.Получить(ПараметрыСервиса.Токен);
	
	Если ДанныеБиллингаДляТокена = Неопределено 
		ИЛИ ДанныеБиллингаДляТокена.Получить(ИдентификаторЯщика) = Неопределено Тогда
		
		ШлюзАвторизации = Модуль_ШлюзАвторизации(ПараметрыСервиса);
		ИмяПродукта = КонтурШлюзАвторизации_ИмяПродукта();
		
		Попытка
			
			АвторизацияБиллинга = ШлюзАвторизации.АвторизацияБиллинга(ИмяПродукта);
			ДанныеБиллингаДляТокена = КонтурШлюзАвторизации_ОбработанныеДанныеАвторизации(АвторизацияБиллинга);
			
			Кэш.Вставить(ПараметрыСервиса.Токен, ДанныеБиллингаДляТокена);
			Кэш_Поместить(КлючКэша, Кэш);
			
		Исключение
			
			ВидОперации	 = НСтр("ru = 'Получение списка подписок для продукта'");
			ТекстОшибки	 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки);
			Метрика_ДобавитьОшибку_ПолучениеДанныхБиллинга(ИдентификаторЯщика, ТекстОшибки);
			
		КонецПопытки;
		
	КонецЕсли;
	
	Если ДанныеБиллингаДляТокена <> Неопределено Тогда
		Результат = ДанныеБиллингаДляТокена.Получить(ИдентификаторЯщика);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		Результат = Контракт_ДанныеБиллингаДляЯщика();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонтурШлюзАвторизации_ОбработанныеДанныеАвторизации(ДанныеБиллинга)
	
	Результат = Новый Соответствие;
	
	Для Каждого ДанныеBoxId Из ДанныеБиллинга Цикл
		
		ДанныеДляЯщика = Контракт_ДанныеБиллингаДляЯщика();
		
		ДоступныйСервисПодпискиНаМодуль = Неопределено;
		
		Для Каждого ДанныеБиллингаЛицевогоСчета Из ДанныеBoxId.Значение Цикл
			
			ЛицевойСчет = ДанныеБиллингаЛицевогоСчета.Идентификатор;
			КодПродукта = ДанныеБиллингаЛицевогоСчета.КодПродукта;
			ОплатаПлательщиком = ДанныеБиллингаЛицевогоСчета.ОплатаПлательщиком;
			
			ДанныеЛицевогоСчета = Новый_ЛицевойСчет(ЛицевойСчет, КодПродукта, ОплатаПлательщиком);
			
			Для Каждого ДанныеПодписки Из ДанныеБиллингаЛицевогоСчета.Подписки Цикл
				
				Для Каждого ДанныеСервиса Из ДанныеПодписки.Сервисы Цикл
					
					СервисПодписки = Новый_СервисПодписки(ДанныеПодписки, ДанныеСервиса, ЛицевойСчет, КодПродукта); 
					ДанныеЛицевогоСчета.ДоступныеСервисы.Добавить(СервисПодписки);
					
					КонтурШлюзАвторизации_ОпределитьСервисПодпискиНаМодуль(ДоступныйСервисПодпискиНаМодуль, СервисПодписки);
                    
				КонецЦикла;
				
			КонецЦикла;
			
			ДанныеДляЯщика.ЛицевыеСчета.Добавить(ДанныеЛицевогоСчета);
			
		КонецЦикла;
		
		Если ДоступныйСервисПодпискиНаМодуль <> Неопределено Тогда
			
			ДанныеДляЯщика.СервисПодпискиНаМодуль = ДоступныйСервисПодпискиНаМодуль;
			ДанныеДляЯщика.ТребуетсяОплатаМодуля = Ложь;
			
		Иначе
			
			КонтурШлюзАвторизации_ОбработатьОтсутствиеПодписки(ДанныеДляЯщика);
			
		КонецЕсли;
		
		Результат.Вставить(ДанныеBoxId.Ключ, ДанныеДляЯщика);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура КонтурШлюзАвторизации_ОпределитьСервисПодпискиНаМодуль(ДоступныйСервисПодпискиНаМодуль, СервисПодписки)
	
	ИмяСервисаСтартовыйУМ = КонтурШлюзАвторизации_ИмяСервисаСтартовыйУМ();
	
	ЭтоСервисПодпискиНаМодуль = КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(СервисПодписки.Идентификатор);
	
	Если ЭтоСервисПодпискиНаМодуль
		И (ДоступныйСервисПодпискиНаМодуль = Неопределено
		ИЛИ ДоступныйСервисПодпискиНаМодуль.Идентификатор = ИмяСервисаСтартовыйУМ) Тогда
		
		ДоступныйСервисПодпискиНаМодуль = СервисПодписки;
		
	КонецЕсли;

КонецПроцедуры

Функция КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(ИмяСервиса)
	
