// Возвращает таблицу для заполнения подробных результатов операции группового подбора и сопоставления контрагентов
// 
// Возвращаемое значение:
//  ТаблицаЗначений - результаты сопоставления контрагентов информационной базы с контрагентами ЭДО
//   * Ссылка - СправочникСсылка.Контрагенты
//   * ИНН- Строка - ИНН контрагента
//   * КПП- Строка - КПП контрагента
//   * Статус - Строка - статус партнерских отношений (см. Контрагенты_СтатусыПодбораСопоставления)
//   * Количество - Число - Количество найденных контрагентов сервиса по заданным ИНН-КПП с учетом статуса партнерства
//
Функция Контрагенты_ДетальныеДанныеГрупповогоСопоставления()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Ссылка");
	Результат.Колонки.Добавить("ИНН");
	Результат.Колонки.Добавить("КПП");
	Результат.Колонки.Добавить("Статус");
	Результат.Колонки.Добавить("Количество");
	
	Возврат Результат;
	
КонецФункции

// Возвращает итоговые результаты группового сопоставления контрагентов
//
// Параметры:
//  КоличествоДанныхДляСопоставления - Число - Количество контрагентов, для которых выполняются действия поиска и сопоставления.
//  АдресВХ - Строка - Адрес детальных данных во временном хранилище
//  ДетальныеДанные - ТаблицаЗначений - Расшифровка результата выполнения группвого сопоставления.
// 
// Возвращаемое значение:
//  Структура - Результат поиска строк для сопоставления:
//   * КоличествоДанныхДляСопоставления - Количество контрагентов, для которых выполняются действия поиска и сопоставления.
//   * КоличествоНеНайденных - Количество контрагентов, для которых не нашлось данных для сопоставления.
//   * КоличествоИмеющихДубли - Количество контрагентов, для которых были найдены дубли получателей у разных операторов ЭДО.
//   * КоличествоСопоставленных - Количество успешно сопоставленных контрагентов.
//   * ДетальныеДанные - Адрес детальных данных во временном хранилище.
//
Функция Контрагенты_РезультатГрупповогоСопоставленияV2(КоличествоДанныхДляСопоставления, АдресВХ, ДетальныеДанные)
	
	СтатусыПодбораСопоставления = Контрагенты_СтатусыПодбораСопоставления();
	
	ОтборСопоставленных = Новый Структура;
	ОтборСопоставленных.Вставить("Статус", СтатусыПодбораСопоставления.Сопоставлен);
	СопоставленныеКонтрагенты = ДетальныеДанные.НайтиСтроки(ОтборСопоставленных);
	
	ОтборНеНайден = Новый Структура;
	ОтборНеНайден.Вставить("Статус", СтатусыПодбораСопоставления.НеНайден);
	КонтрагентыНеНайдены = ДетальныеДанные.НайтиСтроки(ОтборНеНайден);
	
	ОтборЕстьДубли = Новый Структура;
	ОтборЕстьДубли.Вставить("Статус", СтатусыПодбораСопоставления.ЕстьДубли);
	КонтрагентыСДублями = ДетальныеДанные.НайтиСтроки(ОтборЕстьДубли);
	
	КоличествоСопоставленных = СопоставленныеКонтрагенты.Количество();
	КоличествоИмеющихДубли = КонтрагентыСДублями.Количество();
	КоличествоНеНайденных = КонтрагентыНеНайдены.Количество();
	
	Результат = Новый Структура;
	Результат.Вставить("КоличествоСопоставляемых", КоличествоДанныхДляСопоставления);
	Результат.Вставить("КоличествоНеНайденных", КоличествоНеНайденных);
	Результат.Вставить("КоличествоИмеющихДубли", КоличествоИмеющихДубли);
	Результат.Вставить("КоличествоСопоставленных", КоличествоСопоставленных);
	Результат.Вставить("ДетальныеДанные", АдресВХ);
	
	Возврат Результат;
	
КонецФункции

// Подбирает контрагентов сервиса по ИНН и КПП.
// Полученная выборка сортируется по приоритету найденной записи.
// Приоритет зависит от статуса партнерства, признака роуминга и параметров поиска (ИНН+КПП или ИНН).
//
// Параметры:
//  ТаблицаКонтрактов - ТаблицаЗначений - сведения о контрагентах сервиса (см. Контрагенты_КонтрагентыСервисаПоИНН)
//  ИНН - Строка - ИНН контрагента
//  КПП - Строка - КПП контрагента
//
// Возвращаемое значение:
//  ТаблицаЗначений - сведения о найденных контрагентах:
//   * ID - Строка - идентификатор ящика контрагента
//   * Ссылка - СправочникСсылка.Диадок_ЮрФизЛица - контрагент ЭДО
//   * ИНН - Строка - ИНН контрагента
//   * КПП - Строка - КПП контрагента
//   * Роуминговый - Булево - истина, если это роуминговый ящик
//   * Статус - Строка - статус партнерских отношений (см. Перечисление_СтатусыКонтрагентов)
//   * Приоритет - Число - чем меньше, тем выше приоритет
//                                                                                         
Функция Контрагенты_ПодобратьКонтрагентовСервиса(ТаблицаКонтрактов, ИНН, КПП)
	
	ТребуемыеКолонки = "ID, Ссылка, ИНН, КПП, Роуминговый, Статус";
	
	КонтрагентыСервиса = ТаблицаКонтрактов.Скопировать(, ТребуемыеКолонки);
	
	Результат = ТаблицаКонтрактов.СкопироватьКолонки(ТребуемыеКолонки);
	Результат.Колонки.Добавить("Приоритет");
	
	ОтборПоИННКПП = Новый Структура;
	ОтборПоИННКПП.Вставить("ИНН", ИНН);
	ОтборПоИННКПП.Вставить("КПП", КПП);
	
	НайденныеЗаписи = КонтрагентыСервиса.Скопировать(ОтборПоИННКПП);
	
	Для Каждого НайденнаяЗапись Из НайденныеЗаписи Цикл
		
		ДобавитьПодходящиеКонтрагенты(
			Результат,
			НайденнаяЗапись,
			"ИННКПП"
		);
		
	КонецЦикла;
	
	ОтборПоИНН = Новый Структура;
	ОтборПоИНН.Вставить("ИНН", ИНН);
	НайденныеЗаписи = КонтрагентыСервиса.НайтиСтроки(ОтборПоИНН);
	
	Для Каждого НайденнаяЗапись Из НайденныеЗаписи Цикл
		
		ДобавитьПодходящиеКонтрагенты(
			Результат,
			НайденнаяЗапись,
			"ИНН"
		);
		
	КонецЦикла;
	
	Результат.Сортировать("Приоритет");
	
	Возврат Результат;
	
КонецФункции

// Возвращает коллекцию контрагентов с одинаковым приоритетом.
//
// Параметры:
//  РезультатПоиска - ТаблицаЗначений - Сведения о найденных контрагентах (см. метод Контрагенты_ПодобратьКонтрагентовСервиса).
// 
// Возвращаемое значение:
//  Массив - Контрагенты сервиса, отобранные по реквизитам ИНН-КПП или ИНН, с учетом приоритета статуса партнерства.
//
Функция Контрагенты_ВыбратьКонтрагентовСОдинаковымПриоритетом(РезультатПоиска)
	
	Результат = Новый Массив;
	
	Если РезультатПоиска.Количество() > 0 Тогда
		
		ПриоритетнаяСтрока = РезультатПоиска[0];
		
		ОтборПроверкиДублей = Новый Структура;
		ОтборПроверкиДублей.Вставить("Приоритет", ПриоритетнаяСтрока.Приоритет);
		
		РезультатОтбора = РезультатПоиска.НайтиСтроки(ОтборПроверкиДублей);
		
		Для Каждого ЭлементОтбора Из РезультатОтбора Цикл
			
			Результат.Добавить(ЭлементОтбора);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Подбирает и сопоставляет конотрагентов информационной базы и контрагентов ЭДО по ИНН-КПП или ИНН с учетом приоритета сопоставления.
//
// Параметры:
//  ДетальныеДанные - ТаблицаЗначений - таблица для записи сведений о результатах поиска и сопоставления контрагентов.
//  ТаблицаПорция - ТаблицаЗначений - таблица значений контрагентов 1С, для сопоставления.
//  ТаблицаКонтрактов - ТаблицаЗначений - таблица значений контрагентов ДД, для сопоставления.
//
Процедура Контрагенты_ПодобратьСопоставитьКонтрагентов(ДетальныеДанные, ТаблицаПорция, ТаблицаКонтрактов)
	
	КоличествоНеНайденных = 0;
	КоличествоИмеющихДубли = 0;
	
	СтатусыПодбораСопоставления = Контрагенты_СтатусыПодбораСопоставления();
	
	Для Каждого СтрокаПорция Из ТаблицаПорция Цикл
		
		НайденныеЗаписи = Контрагенты_ПодобратьКонтрагентовСервиса(
			ТаблицаКонтрактов,
			СтрокаПорция.ИНН,
			СтрокаПорция.КПП
		);
		
		КонтрагентыСОдинаковымПриоритетом = Контрагенты_ВыбратьКонтрагентовСОдинаковымПриоритетом(НайденныеЗаписи);
		
		ЕстьПриоритетнаяСтрока = (КонтрагентыСОдинаковымПриоритетом.Количество() = 1);
		
		ЕстьДублиКонтрагентов = (КонтрагентыСОдинаковымПриоритетом.Количество() > 1);
		
		НетПриоритетныхСтрок = (КонтрагентыСОдинаковымПриоритетом.Количество() = 0);
		
		Если ЕстьПриоритетнаяСтрока Тогда
			
			ПриоритетнаяЗапись = КонтрагентыСОдинаковымПриоритетом[0];
			
			КонтрагентИБ = СтрокаПорция.Ссылка;
			
			ИдентификаторыЭДО = Новый_ИдентификаторыСправочника(ПриоритетнаяЗапись.Ссылка, ПриоритетнаяЗапись.ID);
			
			Контрагенты_СопоставитьКонтрагентов(КонтрагентИБ, ИдентификаторыЭДО);
			
			Статус = СтатусыПодбораСопоставления.Сопоставлен;
			
		ИначеЕсли ЕстьДублиКонтрагентов Тогда
			
			Статус = СтатусыПодбораСопоставления.ЕстьДубли;
			
		ИначеЕсли НетПриоритетныхСтрок Тогда
			
			Статус = СтатусыПодбораСопоставления.НеНайден;
			
		КонецЕсли;
		
		НоваяСтрока = ДетальныеДанные.Добавить();
		НоваяСтрока.Ссылка = СтрокаПорция.Ссылка;
		НоваяСтрока.ИНН = СтрокаПорция.ИНН;
		НоваяСтрока.КПП = СтрокаПорция.КПП;
		НоваяСтрока.Статус = Статус;
		НоваяСтрока.Количество = КонтрагентыСОдинаковымПриоритетом.Количество();
		
	КонецЦикла;
	
КонецПроцедуры

Функция Контрагенты_СтатусыПодбораСопоставления()
	
	Результат = Новый Структура;
	Результат.Вставить("Сопоставлен", "Сопоставлен");
	Результат.Вставить("ЕстьДубли", "ЕстьДубли");
	Результат.Вставить("НеНайден", "НеНайден");
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаписатьОшибкуПоискаСтрокиСопоставления(ДанныеПоиска)
	
	ВидОперации = НСтр("ru='Ошибка группового сопоставления'");
	
	ШаблонТекстаСообщения = НСтр(
		"ru='При обработке результата поиска контрагентов для сопоставления произошла ошибка.
		|%1 ИНН-КПП: %2-%3'"
	);
	
	ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(
		ШаблонТекстаСообщения,
		ДанныеПоиска.Ссылка,
		ДанныеПоиска.ИНН,
		ДанныеПоиска.КПП
	);
	
	СписокОшибок_ДобавитьОшибку(
		ВидОперации,
		ТекстСообщения
	);
	
КонецПроцедуры

Функция Контрагенты_СтатусыРезультатовОтправкиПриглашения()
	
	Результат = Новый Структура;
	Результат.Вставить("ПриглашениеОтправлено", "ПриглашениеОтправлено");
	Результат.Вставить("ОтправленоВРоумингБезВложения", "ОтправленоВРоумингБезВложения");
	Результат.Вставить("НетАвтороуминга", "НетАвтороуминга");
	Результат.Вставить("ОшибкаОтправки", "ОшибкаОтправки");
	
	Возврат Результат;
	
КонецФункции

// Возвращает таблицу для заполнения подробных результатов отправки приглашений контрагентам
// 
// Возвращаемое значение:
//  ТаблицаЗначений - результаты отправки приглашений
//   * Наименование - Наименование контрагента
//   * ИНН- Строка - ИНН контрагента
//   * КПП- Строка - КПП контрагента
//   * Статус - Строка - Статус отправки приглашения (см. Контрагенты_СтатусыРезультатовОтправкиПриглашения)
//   * ОператорЭДО - Строка - Представление оператора ЭДО
//
Функция Контрагенты_ДетальныеДанныеОтправкиПриглашений()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Наименование");
	Результат.Колонки.Добавить("ИНН");
	Результат.Колонки.Добавить("КПП");
	Результат.Колонки.Добавить("Статус");
	Результат.Колонки.Добавить("ОператорЭДО");
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаписатьОшибкуОтправкиПриглашения(НаименованиеКонтрагента, ИННКонтрагента, КППКонтрагента, РезультатОтправкиПриглашения)
	
	ВидОперации = НСтр("ru='Отправка приглашения контрагенту'");
	КодОшибки = РезультатОтправкиПриглашения.КодОшибки;
	ТекстОшибки = РезультатОтправкиПриглашения.РезультатОтвета;
	
	ШаблонСообщения = НСтр(
		"ru=' При отправке приглашения контрагенту %1 ИНН-КПП: %2-%3 произошла ошибка:
		|Код ошибки: %4
		|Текст ошибки: %5'"
	);
	
	ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(
		ШаблонСообщения,
		НаименованиеКонтрагента,
		ИННКонтрагента,
		КППКонтрагента,
		КодОшибки,
		ТекстОшибки
	);
	
	СписокОшибок_ДобавитьОшибку(
		ВидОперации,
		ТекстСообщения
	);
	
КонецПроцедуры

// Возвращает HTML-страницу представления перечня контрагентов ИБ,
// для которых были найдены дубли среди контрагентов ЭДО.
//
// Параметры:
//  АдресРезультатовСопоставления - Строка - Адрес во временно хранилище,
//  по которому помещены детальные данные результатов группового сопоставления контрагентов.
//  см. метод Контрагенты_ДетальныеДанныеГрупповогоСопоставления
// 
// Возвращаемое значение:
//  Строка - Код HTML-страницы для формы ФормаHTMLСообщения
//
Функция HTMLОшибкиГрупповогоСопоставленияКонтрагентов(АдресРезультатовСопоставления) Экспорт
	
	Картинки = БиблиотекаКартинок();
	КартинкаОнлайнКонсультант = Картинки.КартинкаОнлайнКонсультант_Base64;
	СтрокаОповещенияЦП = ПараметрыОповещенияВСтрокуHTMLСообщения("ОбработатьНажатие_ОткрытьЦентрПоддержки");
	
	СтатусыПодбораСопоставления = Контрагенты_СтатусыПодбораСопоставления();
	ДетальныеДанные = ВременноеХранилище_Прочитать(АдресРезультатовСопоставления);
	
	ОтборЕстьДубли = Новый Структура;
	ОтборЕстьДубли.Вставить("Статус", СтатусыПодбораСопоставления.ЕстьДубли);
	КонтрагентыСДублями = ДетальныеДанные.НайтиСтроки(ОтборЕстьДубли);
	
	ШаблонНачало =
	"<HTML>
	|	<HEAD>
	|		<style type=text/css>
	|			body {font-family: Segoe UI}
	|			h4 {padding-bottom: 0em}
	|			ul.box {padding-left: 3em}
	|			li {font-size: 10pt}
	|			p.footer {font-size: 10pt}
	|		</style>
	|	</HEAD>
	|	<BODY scroll=auto>
	|";
	
	ШаблонЦП = ЦП_ШаблонHTMLКнопкаТехПоддержки();
	
	ШаблонПреамбулаОписания = "Для следующих контрагентов 1С найдено несколько контрагентов Диадок. Выполните сопоставление вручную:";
	
	ШаблонОкончание =
	"		<BR>
	|	</BODY>
	|</HTML>";
	
	ЭлементыДокументаHTML = Новый Массив;
	ЭлементыДокументаHTML.Добавить(ШаблонНачало);
	ЭлементыДокументаHTML.Добавить(ШаблонЦП);
	ЭлементыДокументаHTML.Добавить("<BR>");
	ЭлементыДокументаHTML.Добавить("<BR>");
	ЭлементыДокументаHTML.Добавить(ШаблонПреамбулаОписания);
	ЭлементыДокументаHTML.Добавить("<UL>");
	
	Для каждого ЭлементДанных Из КонтрагентыСДублями Цикл
		
		ШаблонЭлементСпискаОшибок = Общее_ПодставитьПараметрыВСтроку(
			"<li>%1 ИНН-КПП %2-%3 найдено %4 шт.</li>",
			ЭлементДанных.Ссылка,
			ЭлементДанных.ИНН,
			ЭлементДанных.КПП,
			ЭлементДанных.Количество
		);
		
		ЭлементыДокументаHTML.Добавить(ШаблонЭлементСпискаОшибок);
		
	КонецЦикла;
	
	ЭлементыДокументаHTML.Добавить("</UL>");
	ЭлементыДокументаHTML.Добавить(ШаблонОкончание);
	
	Результат = СоединитьСтроку(ЭлементыДокументаHTML, Символы.ПС);
	
	Возврат Результат;
	
КонецФункции

