// Проверяет текущее состояние уведомлений пользователя.
//
// Параметры:
//  КлючНастроек - Строка - Идентификатор формы-владельца уведомлений
//  Фильтр - Структура - Параметры для отбора уведомлений
// 
// Возвращаемое значение:
//  Строка - идентификатор состояния уведомлений (см. Перечисление_СостоянияУведомленийПользователя)
//
Функция УведомленияПользователей_ТекущееСостояние(КлючНастроек, Фильтр)
	
	СписокУведомлений = Уведомления_ПолучитьСписок(Фильтр);
	
	ВозможныеСостоянияУведомлений = Перечисление_СостоянияУведомленийПользователя();
	
	Результат = ВозможныеСостоянияУведомлений.НетУведомлений;
	
	ОтметкиОПрочтении = УведомленияПользователей_ПрочитатьТаблицуСостояний(КлючНастроек);
	
	Для Каждого Уведомление Из СписокУведомлений Цикл
		
		Важное = УведомленияПользователей_ЭтоВажноеУведомление(Уведомление.Приоритет);
		Прочитано = УведомленияПользователей_ОтметкаОПрочтении(Уведомление.Ид, ОтметкиОПрочтении);
		
		Если Важное
			И НЕ Прочитано Тогда
			Результат = ВозможныеСостоянияУведомлений.ЕстьВажныеНеПрочитанные;
			Прервать;
		КонецЕсли;
		
		Если НЕ Прочитано Тогда
			Результат = ВозможныеСостоянияУведомлений.ЕстьНеПрочитанные;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

