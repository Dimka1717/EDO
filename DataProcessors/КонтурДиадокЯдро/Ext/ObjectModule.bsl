// Заполняет контекст типового модуля для обычных форм.
//
// Параметры:
//  ТиповойМодуль	- ВнешняяОбработка	- объект модуля.
//  РежимОтладки	- Булево			- режим отладки включен/выключен.
//  КаталогСМодулем	- Строка			- каталог вложенных обработок для отладки.
//
Процедура ИнициализироватьТиповойМодульОФ(ТиповойМодуль, РежимОтладки = Ложь, КаталогСМодулем = "") Экспорт
	
	Отказ = Ложь;
	
	ИмяМодуляИнтеграции = ЗначениеНастройки_ИмяТиповогоМодуляИнтеграции();
	Если Не ЗначениеЗаполнено(ИмяМодуляИнтеграции) Тогда
		ИмяМодуляИнтеграции = ИмяСтандартногоИнтеграционногоМодуля();
	КонецЕсли;
	
	ТочностьЦены = ЗначениеНастройки_ТочностьЦены();
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ТочностьЦены", ТочностьЦены);
	
	Модуль_ГенерацияXML		= Модуль_ГенерацияXML(ЭтотОбъект);
	Модуль_ПечатныеФормы	= Модуль_ПечатныеФормы(ЭтотОбъект);
	
	Попытка
		
		ТиповойМодуль.КэшМодулей().Вставить("ГенерацияXML",	Модуль_ГенерацияXML);
		ТиповойМодуль.КэшМодулей().Вставить("ПечатныеФормы", Модуль_ПечатныеФормы);
		
		ТиповойМодуль.ИмяМодуляИнтеграции	  = ИмяМодуляИнтеграции;
		ТиповойМодуль.ЗапущенКакВнешнийМодуль = Истина;
		ТиповойМодуль.РежимОтладки            = РежимОтладки;
		ТиповойМодуль.КаталогОбработок        = КаталогСМодулем;
		
		ТиповойМодуль.Инициализировать(ДопПараметры);
		ТиповойМодуль.ЗаполнитьПрофильКонфигурации(Отказ);
		ТиповойМодуль.ИнициализироватьМодулиЯдра(Отказ);
		ТиповойМодуль.ОдинСАдаптер_Инициализировать(Отказ);
		ТиповойМодуль.ИнициализироватьВнешнийПодключаемыйМодуль();
		
	Исключение
		
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВидОперации		 = НСтр("ru = 'Инициализация типового модуля'");
		ДопИнформация	 = Общее_ПодставитьПараметрыВСтроку(НСтр("ru = 'Типовой модуль интеграции %1'"), ИмяМодуляИнтеграции);
		ТекстСообщения	 = "Не удалось инициализировать типовой модуль!";
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ТиповойМодуль.ИмяМодуляИнтеграции)
		И ТиповойМодуль.ИмяМодуляИнтеграции <> ИмяМодуляИнтеграции Тогда
		
		ОбщиеНастройки_Поместить("ИмяТиповогоМодуляИнтеграции", ТиповойМодуль.ИмяМодуляИнтеграции);
		
	КонецЕсли;
	
КонецПроцедуры

