		ТекстСообщения = "Не удалось получить информацию о доверенности.";
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
		
	КонецПопытки;
	
	Результат = АПИ_ЗаполненныйКонтрактМЧД(PowerOfAttorney);
	
