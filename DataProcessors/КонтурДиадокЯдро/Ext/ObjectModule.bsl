КонецФункции

// Возвращает коллекцию сохраненных в информационной базе настроек документов на отправку.
//
// Параметры:
//  ДанныеОрганизации	 - 	Структура - см. функцию Контракт_ОрганизацияЭДО()
//  ДанныеКонтрагента	 - 	Структура - см. функцию Контракт_КонтрагентЭДО()
// 
// Возвращаемое значение:
//  Массив - значения массива - заполненные контракты настроек (см. Новый_НастройкаДокументаНаОтправку) 
//
Функция НастройкиДокументов_НастройкиДокументовНаОтправку(ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт

	Результат = Новый Массив;
	
	ОписаниеВидовДокументов = СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыДокументов");
	
	Если НЕ ЗначениеЗаполнено(ОписаниеВидовДокументов) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторыВидовДокументов = ОписаниеВидовДокументов.ВыгрузитьКолонку("ID");
	
	НастройкиПечатныхФорм 	= ХранениеДанных_НастройкиПФпоВидамДокументов(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента); 
	ФорматыВидовДокументов 	= ХранениеДанных_ФорматыВидовДокументов(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
	
	Для Каждого ОписаниеВидаДокумента Из ОписаниеВидовДокументов Цикл
		
		ВидДокумента = ОписаниеВидаДокумента.ID;
		
		Настройка = Новый_НастройкаДокументаНаОтправку();
		
		Настройка.ВидДокумента			= ВидДокумента;
		Настройка.Наименование			= ОписаниеВидаДокумента.Наименование;
		Настройка.Формализованный		= ЗначениеЗаполнено(ОписаниеВидаДокумента.ТипКонтентаAPI);
		Настройка.ФорматыКонтента		= НастройкиДокументов_ФорматыКонтента(ОписаниеВидаДокумента);
		
		Настройка.НастройкиПечатныхФорм	= НастройкиПечатныхФорм.Получить(ВидДокумента);
		
		ЭтоСчетНаОплату = (ОписаниеВидаДокумента.ТипДокументаAPI = Тип_СчетНаОплату()
			Или ОписаниеВидаДокумента.ТипДокументаAPI = Тип_СчетНаОплатуФормализованный()
			Или ОписаниеВидаДокумента.ТипДокументаAPI = Тип_СчетОфертаНаОплатуФормализованный());
		
		Если ЭтоСчетНаОплату Тогда
			ФормироватьНаОсновании = НастройкиДокументов_ОснованияВидовДокументов_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
			Если Не ЗначениеЗаполнено(ФормироватьНаОсновании) Тогда
				ЭтоНастройкиКонтрагента = (ДанныеКонтрагента <> Неопределено);
				Если ЭтоНастройкиКонтрагента Тогда 
					// возьмем настройку из организации
					ФормироватьНаОсновании = НастройкиДокументов_ОснованияВидовДокументов_Прочитать(ВидДокумента, ДанныеОрганизации);
				КонецЕсли;		
			КонецЕсли;
			Если Не ЗначениеЗаполнено(ФормироватьНаОсновании) Тогда
				ФормироватьНаОсновании = МенеджерИнтеграции_ОснованияВидовДокументов_ЗначениеПоУмолчанию(ВидДокумента);
			КонецЕсли;
			Настройка.ФормироватьНаОсновании = ФормироватьНаОсновании;
		КонецЕсли;		
		
		ФорматКонтента = ФорматыВидовДокументов.Получить(ВидДокумента);
		
		Если ФорматКонтента = Неопределено Тогда
			ФорматКонтента = ОписаниеВидаДокумента.ТипКонтентаAPI;
		КонецЕсли;
		
		Если ФорматКонтента = "" Тогда
			ФорматКонтента = Настройка.ФорматыКонтента[0].Значение;
		КонецЕсли;
		
		Настройка.ФорматКонтента = ФорматКонтента;
		
		Результат.Добавить(Настройка);
			
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Коллекция заполненных значениями по умолчанию контрактов настроек пакетов на отправку.
//
// Параметры:
//  ОписаниеВидовПакетов - ТаблицаЗначений - см. СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
// 
// Возвращаемое значение:
//  Массив - содержит заполненные контракты настроек пакетов на отправку (см. Новый_НастройкаПакетаНаОтправку)
//
Функция НастройкиДокументов_НастройкиПакетовНаОтправкуПоУмолчанию(ОписаниеВидовПакетов)
	
	Перем НастройкаКатегорииПакетов;
	
	Результат = Новый Массив;

	ТекущаяКатегория = Неопределено;
	
	Для Каждого ОписаниеВидаПакета Из ОписаниеВидовПакетов Цикл
		
		КатегорияПакета = ОписаниеВидаПакета.КатегорияПакета;
		Если ЗначениеЗаполнено(ОписаниеВидаПакета.БазовыйВидПакета)
			ИЛИ Не ЗначениеЗаполнено(ОписаниеВидаПакета.НаименованиеКатегории) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТекущаяКатегория <> КатегорияПакета Тогда
			
			ТекущаяКатегория = КатегорияПакета;
			
			НастройкаКатегорииПакетов = Новый_НастройкаПакетаНаОтправку();
			
			НастройкаКатегорииПакетов.КатегорияПакета 		= ОписаниеВидаПакета.КатегорияПакета;
			НастройкаКатегорииПакетов.НаименованиеКатегории = ОписаниеВидаПакета.НаименованиеКатегории;
			НастройкаКатегорииПакетов.ВидПакета 			= ОписаниеВидаПакета.ID;
			НастройкаКатегорииПакетов.ОтправлятьПакет		= Истина;
			НастройкаКатегорииПакетов.ВнутреннийДО = ОписаниеВидаПакета.ВнутреннийДО;
			
			Результат.Добавить(НастройкаКатегорииПакетов);
			
		КонецЕсли;
		
		НастройкаКатегорииПакетов.ВидыПакетов.Добавить(
			ОписаниеВидаПакета.ID,
			ОписаниеВидаПакета.Наименование);	
			
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

