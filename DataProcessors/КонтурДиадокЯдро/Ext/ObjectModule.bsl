	Переменные.Вставить("КоличествоКА", НастройкиПлагина.МассивКонтрагентов.Количество());
	
	Метрика_ДобавитьСтатистику_ПоКонтексту(КатегорияМетрики, ДействиеМетрики, , Переменные);
	
