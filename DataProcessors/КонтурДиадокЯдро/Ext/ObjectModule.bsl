		Результат.Вставить("СкачиваниеДокументов", "Скачивание документов");
		Результат.Вставить("СозданиеДокументов", "Создание документов");
		Результат.Вставить("СопоставлениеДокументов", "Сопоставление документов");
		Результат.Вставить("ПередатьВПодразделение", "Передать в подразделение");
		Результат.Вставить("Согласование", "Согласование");
		Результат.Вставить("ПодписаниеВходящегоДокумента", "Подписание входящего документа");
		Результат.Вставить("ОтправкаДокумента", Метрики_КатегорияОтправкаДокумента());
