КонецПроцедуры

Процедура Контрагенты_ОбновлениеПодразделений(Организация, ТаблицаКонтрактов)
	
	Если Не ЗначениеЗаполнено(ТаблицаКонтрактов) Тогда
		Возврат;
	КонецЕсли;
	
	СтатусПартнерскиеОтношения = Перечисление_СтатусыКонтрагентов().ПартнерскиеОтношения;
	
	КоллекцияСтрокДляОбработки = ТаблицаКонтрактов.НайтиСтроки(Новый Структура("Статус", СтатусПартнерскиеОтношения));
	ТаблицаКонтрактовДляОбработки = ТаблицаКонтрактов.Скопировать(КоллекцияСтрокДляОбработки);
	
	КоличествоФоновыхЗаданий = ФоновоеЗадание_МаксимальноеКоличество();
	
	ПорцииДанныхКонтрагентовЭДО = РазбитьТаблицуЗначенийНаПорции(ТаблицаКонтрактовДляОбработки, КоличествоФоновыхЗаданий);
	
	ОчередьЗадач = Новый Массив;
	
	ИмяМетода = "Подразделения_ОбновитьСправочникФоном";
	
	Для Каждого КонтрагентыЭДО Из ПорцииДанныхКонтрагентовЭДО Цикл
		
		ПараметрыМетода = Новый Массив;
		ПараметрыМетода.Добавить(КонтрагентыЭДО);
		ПараметрыМетода.Добавить(Организация);
		
		ОписаниеЗадачи = Новый_ОписаниеЗадачиВФоне(ИмяМетода, ПараметрыМетода);
		ОчередьЗадач.Добавить(ОписаниеЗадачи);
		
	КонецЦикла;
	
	ОчередьЗадач_Обработать(ОчередьЗадач);
	
КонецПроцедуры

// СПИСКИ КОНТРАГЕНТОВ

// Отвязывает контрагента Диадок от Контрагента 1С и стирает настройки документов
//
// Параметры:
//	Идентификаторы - Структура - см. метод "Контракт_ИдентификаторыСправочника()"
//	ДанныеОрганизации - Структура - см. метод "Контракт_ОрганизацияЭДО()"
//
Процедура Контрагенты_ОтвязатьКонтрагента(Идентификаторы, ДанныеОрганизации) Экспорт

	СопоставленныеЗаписи = Контрагенты_МассивСопоставленныхВ1С(Идентификаторы);
	
	Если НЕ ЗначениеЗаполнено(СопоставленныеЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	ЗначенияРеквизитов = Новый Структура;
	ЗначенияРеквизитов.Вставить("СвязанныеСправочники", Новый Массив);
	ЗначенияРеквизитов.Вставить("ID_ОсновноеПодразделение", "");
	
	ДанныеКонтрагента = Контрагенты_ЗаполненныеРеквизиты(Идентификаторы);
	
	НастройкиДокументов_УдалитьНастройкиДокументов(ДанныеОрганизации, ДанныеКонтрагента);
	
	Контрагенты_ОбновлениеРеквизитов(Идентификаторы, ЗначенияРеквизитов);
	
	
КонецПроцедуры

Функция Контрагенты_ЗаполненныйСписок(ПараметрыСписка) Экспорт
	
	Перем Результат;
	
	Если ЗначениеЗаполнено(ПараметрыСписка.Ключ) Тогда
		Результат = Кэш_Прочитать(ПараметрыСписка.Ключ);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		Результат = ХранениеДанных_ТаблицаКонтрагентовЭДО(ПараметрыСписка);
		
		Если ПараметрыСписка.ДобавитьКоличествоДокументовЗаПериод Тогда
			Результат.Колонки.Добавить("ДокументовЗаПериод", Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(10)));
			Контрагенты_ДополнитьТаблицуКоличествомДокументовЗаПериод(Результат, ПараметрыСписка.Отбор.ОрганизацияЭДО);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПараметрыСписка.Ключ) Тогда
			Кэш_Поместить(ПараметрыСписка.Ключ, Результат);
		КонецЕсли;
		
	КонецЕсли;	
		
	Возврат Результат;
	
КонецФункции

// Контрагенты список для раздела ваши контрагенты
//
// Параметры:
//  ОрганизацияЭДО - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО) 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - список контрагентов со статусами МойКонтрагент, Пригласил, Приглашен
//
Функция Контрагенты_СписокДляРазделаВашиКонтрагенты(ОрганизацияЭДО) Экспорт
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаПартнеровДляРазделаКонтрагентов(ОрганизацияЭДО);
	
	Список = ХранениеДанных_ТаблицаКонтрагентовЭДО(ПараметрыСписка);
	
	Результат = Контрагенты_ТаблицыСправочникаКонтрагентов(Список, ОрганизацияЭДО.ID);
	
	Результат.Сортировать("ОрганизацияЛиквидирована Возр, Статус Возр");
	
	Возврат Результат;
	
КонецФункции

// Контрагенты список для раздела поиск и приглашение
//
// Параметры:
//  ОрганизацияЭДО - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
// 
// Возвращаемое значение:
//  ТаблицаЗначений - список контрагентов со статусами РаботаетВДиадок, Заблокирован, Заблокировал 
//
Функция Контрагенты_СписокДляРазделаПоискИПриглашение(ОрганизацияЭДО) Экспорт
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаДляПриглашения(ОрганизацияЭДО);
	
	Список = ХранениеДанных_ТаблицаКонтрагентовЭДО(ПараметрыСписка);
	
	Результат = Контрагенты_ТаблицыСправочникаКонтрагентов(Список, ОрганизацияЭДО.ID);
	
	Результат.Сортировать("ОрганизацияЛиквидирована Возр, Статус Убыв");
	
	Контрагенты_ДополнитьТаблицуКоличествомДокументовЗаПериод(
		Результат,
		ОрганизацияЭДО
	);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТаблицыСправочникаКонтрагентов(СписокКонтрагентов, IDОрганизации)
	
	Результат = НовыйТаблицаКонтрагентов();
	
	Для Каждого КонтрагентЭДО Из СписокКонтрагентов Цикл
		
		Если ЕстьСтатусОрганизацияЛиквидирована(КонтрагентЭДО.Статус) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Результат.Добавить();
		
		ЗаполнитьСтрокуСпискаКонтрагентов(
			НоваяСтрока,
			КонтрагентЭДО,
			IDОрганизации
		);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьСтатусОрганизацияЛиквидирована(СтатусКонтрагента)
	
	ДополнительныйСтатус = "Организация ликвидирована";
	
	Результат = (СтрНайтиЛок(СтатусКонтрагента, ДополнительныйСтатус) <> 0);
	
	Возврат Результат;
	
КонецФункции

Функция НовыйТаблицаКонтрагентов()
	
	Длина0 = 0;
	ТипСтрока0 = ОписаниеТипаСтрока(Длина0);
	
	Длина10 = 10;
	ТипСтрока10 = ОписаниеТипаСтрока(Длина10);
	
	Длина15 = 15;
	ТипСтрока15 = ОписаниеТипаСтрока(Длина15);
	
	Разрядность10 = 10;
	ДробнаяЧасть0 = 0;
	ТипЧисло10 = ОписаниеТипаЧисло(Разрядность10, ДробнаяЧасть0, ДопустимыйЗнак.Неотрицательный);
	
	ТипДата = ОписаниеТипаДата(ЧастиДаты.Дата);
	
	ТипКонтрагента = Справочники_ТипЗначенияОбъекта("Контрагенты");
	ТипСправочникКонтрагенты = Новый ОписаниеТипов(ТипКонтрагента);
	
	ТипБулево = Новый ОписаниеТипов("Булево");
	ТипМассив = Новый ОписаниеТипов("Массив");
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Пометка", ТипБулево);
	Результат.Колонки.Добавить("Наименование", ТипСтрока0);
	Результат.Колонки.Добавить("ИНН", ТипСтрока15);
	Результат.Колонки.Добавить("КПП", ТипСтрока10);
	Результат.Колонки.Добавить("Ссылка", ТипСправочникКонтрагенты);
	Результат.Колонки.Добавить("Статус", ТипСтрока0);
	Результат.Колонки.Добавить("ДокументовЗаПериод", ТипЧисло10);
	Результат.Колонки.Добавить("ДанныеКонтрагента", ТипСтрока0);
	Результат.Колонки.Добавить("ID", ТипСтрока0);
	Результат.Колонки.Добавить("ОператорЭДО", ТипСтрока0);
	Результат.Колонки.Добавить("ИдентификаторУчастникаЭДО", ТипСтрока0);
	Результат.Колонки.Добавить("ОрганизацияЛиквидирована", ТипБулево);
	Результат.Колонки.Добавить("ДатаИзменения", ТипДата);
	Результат.Колонки.Добавить("Комментарий", ТипСтрока0);
	Результат.Колонки.Добавить("ДатаЛиквидации", ТипСтрока0);
	Результат.Колонки.Добавить("Роуминговый", ТипБулево);
	Результат.Колонки.Добавить("РеквизитыСвязанныхСправочников", ТипМассив);
	
	Возврат Результат;
	
КонецФункции

