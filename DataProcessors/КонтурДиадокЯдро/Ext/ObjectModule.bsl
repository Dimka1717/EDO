	КлючИБ = ОблачныеНастройки_ТокенДоступа();
	
	СервисОбновлений = Модуль_АпдейтКлиент(
		ЗаголовокАвторизации,
		КлючИБ
	);
	
	ИдентификаторПродукта = ИдентификаторПродукта();
	ИдентификаторБазы = Строка(_ИдентификаторИнформационнойБазыДиадок());
	
	ОтборНастроек = СервисОбновлений.ОтборНастроек();
	ОтборНастроек.КлючНастроек = КлючНастроек;
	
	СервисОбновлений.УдалитьНастройкиИБ(
		ИдентификаторПродукта,
		ИдентификаторБазы,
		ОтборНастроек
	);
	
