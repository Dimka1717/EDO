	Для Каждого Документ Из Результат.Документы Цикл
		Документы_ЗаполнитьХранилищеКонтента(Документ);
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

Функция Пакеты_ПодготовитьПакетДляОтправки(СтрокаСписка, ПроверятьXDTO = Истина) Экспорт
	
	Пакет = Пакеты_ПодготовитьПакет(СтрокаСписка, ПроверятьXDTO);
	
	Если Пакет.Документы.Количество() = 0 Тогда
		
		ПакетПодготовленДляОтправки = Ложь;
		
		ВидОперации			= "Отправка пакета документов";
		ПредставлениеПакета	= ПредставлениеПакета(Пакет);
		ТекстСообщения		= "Не удалось отправить пакет %1
							  |Пакет не содержит документов.";
		ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПредставлениеПакета);
		ИдентификаторФормы	= ОбщийКонтекст_Прочитать("ИдентификаторФормы");
			
		Ошибка_Обработать(ВидОперации, , , ТекстСообщения, ИдентификаторФормы);
		
	Иначе
		ПакетПодготовленДляОтправки = Пакеты_ПодготовитьОтправкуБольшогоПакета(Пакет);
	КонецЕсли;
	
	Если ПакетПодготовленДляОтправки Тогда
		
		Результат = Пакет;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПодготовитьПакетыДляОтправки(СтрокиСписка, ПроверятьXDTO = Истина) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого СтрокаСписка Из СтрокиСписка Цикл
		
		Попытка
			Пакет = Пакеты_ПодготовитьПакетДляОтправки(СтрокаСписка, ПроверятьXDTO);
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			
			КонтекстОшибки = Общее_ПодставитьПараметрыВСтроку(
				"Вид пакета: %1 (%2)
				|Документ: %3",
				СтрокаСписка.ВидПакета,
				СтрокаСписка.ВидПакетаID,
				Строка(СтрокаСписка.Документ)
			);
			
			Ошибка_Добавить(
				"Отправка пакета документов",
				Ошибка,
				КонтекстОшибки
			);
			
			Продолжить;
			
		КонецПопытки;
		
		Результат.Добавить(Пакет);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПодготовитьОтправкуБольшогоПакета(Пакет) Экспорт
	
	Результат = Истина;
	
	МаксКоличествоДокументовMessageToPost = Пакеты_МаксКоличествоДокументовMessageToPost();
	ОтправкаБольшогоПакета = Пакет.Документы.Количество() > МаксКоличествоДокументовMessageToPost;
	
	Если НЕ Пакеты_ПакетОтправлен(Пакет) И ОтправкаБольшогоПакета Тогда
		
		ЗашифрованныйПакет = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ЗашифрованныйПакет", Ложь);
	
		Если ЗашифрованныйПакет Тогда
			
			Результат = Ложь;
			
			ВидОперации			= "Отправка пакета документов";
			ПредставлениеПакета	= ПредставлениеПакета(Пакет);
			ТекстСообщения		= "Не удалось отправить пакет %1
								  |Шифрование пакета более, чем из %2 документов недоступно. 
								  |Отключите шифрование в настройках организации или сократите количество документов в пакете.";
			ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПредставлениеПакета, МаксКоличествоДокументовMessageToPost);
			ИдентификаторФормы	= ОбщийКонтекст_Прочитать("ИдентификаторФормы");
			
			Ошибка_Обработать(ВидОперации, , , ТекстСообщения, ИдентификаторФормы);
			
		Иначе
			
			Пакет.СлужебнаяИнформация.Вставить("ОтложеннаяОтправка", Истина);
			Результат = Пакеты_ОтправитьИСохранить(Пакет);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПодготовитьИОтправитьПакеты(СтрокиСписка, ПараметрыСогласования = Неопределено) Экспорт
	
	ДействиеЭДО		 = Перечисление_ДействияЭДО().ПодписатьИОтправить;
	ЭтоСогласование	 = ПараметрыСогласования <> Неопределено;
	
	Для Каждого СтрокаСписка Из СтрокиСписка Цикл
		
		ОшибкиОтправки = СтрокаСписка.ОшибкиПроверкиТекст;
		
		Если ЗначениеЗаполнено(ОшибкиОтправки) Тогда
			
			ПерезаполняемыйПакет = Контракт_ИдентификаторыПакета();
			
			Если ЗначениеЗаполнено(СтрокаСписка.Пакет) Тогда
				ПерезаполняемыйПакет.ПакетЭДО = СтрокаСписка.Пакет;
			КонецЕсли;
			
			Пакет = СписокДокументов_ОбновитьДанныеСтрокиПакетаНаОтправку(СтрокаСписка);
			
			Если Пакет = Неопределено Тогда
				// не удалось перезаполнить пакет документов
				Пакет = Пакеты_ПодготовитьПакет(СтрокаСписка);
			Иначе
				
				Пакет.Идентификаторы.ПакетЭДО = ПерезаполняемыйПакет.ПакетЭДО;
				
				ПараметрыПереотправки = Пакет.СлужебнаяИнформация.ПараметрыПереотправки;
				ПараметрыПереотправки.ВыполнитьУдалениеНеактуальныхДокументовПакета = Истина;
				
			КонецЕсли;
			
		Иначе
			Пакет = Пакеты_ПодготовитьПакет(СтрокаСписка);
		КонецЕсли;
		
		Если НЕ ЭтоСогласование Тогда
			
			ОписаниеОшибкиПроверкиКЭП = КЭП_ДоступноДействиеЭДО(ДействиеЭДО, Пакет.Идентификаторы.BoxID);
			Если ЗначениеЗаполнено(ОписаниеОшибкиПроверкиКЭП) Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		Пакеты_ПодготовитьОтправкуБольшогоПакета(Пакет);
		Пакеты_ПередПодписаниемПакетаНаОтправку(Пакет);
		
		Если ЭтоСогласование Тогда
			Для Каждого ОписаниеДокумента Из Пакет.Документы Цикл
				ОписаниеДокумента.СлужебнаяИнформация.Вставить("Маршрутизация", ПараметрыСогласования);
			КонецЦикла;
		КонецЕсли;
		
		Пакеты_ПодписатьПакетНаОтправку(Пакет);
		Пакеты_ОтправитьИСохранить(Пакет);
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Процедура Пакеты_ПодготовитьИОтправитьПакетыВФоне(СписокДокументовДляОтправки) Экспорт
	
	КоличествоФоновыхЗаданий = ФоновоеЗадание_МаксимальноеКоличество();
	
	ВсегоСтрок	 = СписокДокументовДляОтправки.Количество();
	РазмерПорции = Макс(Окр(ВсегоСтрок/КоличествоФоновыхЗаданий), 1);
	ОчередьЗадач = Новый Массив;
	ПорцияДанных = Новый Массив;
	ИмяМетода	 = "Пакеты_ПодготовитьИОтправитьПакеты";
	Сч			 = 0;
	
	Для ОбратныйИндекс = - (ВсегоСтрок - 1) По 0 Цикл
		
		ПорцияДанных.Добавить(СписокДокументовДляОтправки[-ОбратныйИндекс]);
		
		Сч = Сч + 1;
		ЭтоПоследняяСтрокаПорции = (Сч % РазмерПорции = 0);
		ЭтоПоследняяСтрокаСписка = (Сч = ВсегоСтрок);
		
		Если ЭтоПоследняяСтрокаПорции Или ЭтоПоследняяСтрокаСписка Тогда
			
			ПараметрыМетода = Новый Массив;
			ПараметрыМетода.Добавить(ПорцияДанных);
			
			ОписаниеЗадачи = Новый_ОписаниеЗадачиВФоне(ИмяМетода, ПараметрыМетода);
			ОчередьЗадач.Добавить(ОписаниеЗадачи);
			
			ПорцияДанных = Новый Массив;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОчередьЗадач_Обработать(ОчередьЗадач);
	
КонецПроцедуры

Функция Пакеты_ДокументыПакетов(ИдентификаторыПакетов) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого ИдентификаторыПакета Из ИдентификаторыПакетов Цикл
		
		ДокументыПакета = ХранениеДанных_МассивКонтрактовДокументовПакета(ИдентификаторыПакета);
		
		Для Каждого Документ Из ДокументыПакета Цикл
			Результат.Добавить(Документ);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция - Пакеты новый исходящий пакет
// 	Используется для установки параметров отправителя и получателя для нового пакета если указаны параметры
// Параметры:
//  Организация	 - Организация 1С - 
//  Контрагент	 - Контрагент 1С - 
// 
// Возвращаемое значение:
//   - Пакет заполненнный по переданным параметрам
//
Функция Пакеты_НовыйИсходящийПакет(Организация = Неопределено, Контрагент = Неопределено) Экспорт   
	
	Пакет = Контракт_Пакет();
	Пакет.Направление = Перечисление_Направления().Исходящее;
	
	Пакет_УстановитьОрганизацию(Пакет, Организация);
	
	Пакет_УстановитьКонтрагента(Пакет, Контрагент);
		
	BoxId = "";
	Если ЗначениеЗаполнено(Пакет.Отправитель.BoxId) Тогда
		BoxId = АдресЯщикаВИдентификатор(Пакет.Отправитель.BoxId);
	КонецЕсли;
	
	Пакет.Идентификаторы.BoxId = BoxId;
	
	Возврат Пакет;
КонецФункции  

Процедура Пакет_УстановитьОрганизацию(Пакет, Организация = Неопределено)
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(Организация);
	BoxID = ХранениеДанных_ИдентификаторОрганизации(ИдентификаторыОрганизации);
	ИдентификаторыОрганизации.ID = BoxID;
	СписокОрганизаций = Организации_СписокОрганизацийПоКонтексту();
	
	Если Не ЗначениеЗаполнено(BoxID) 
		 И  СписокОрганизаций.Количество() = 1 Тогда
		ИдентификаторыОрганизации = СписокОрганизаций[0];
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторыОрганизации.ID) Тогда
		Возврат;
	КонецЕсли;
	
	Пакет.Отправитель = Организации_ЗаполнитьУчастникаДО(ИдентификаторыОрганизации);
	
КонецПроцедуры

Процедура Пакет_УстановитьКонтрагента(Пакет, Контрагент1С = Неопределено) 
	
	Отправитель = Пакет.Отправитель;

	Если НЕ ЗначениеЗаполнено(Отправитель.BoxID) Тогда 
		Возврат;
	КонецЕсли;
	
	ИдентификаторыОрганизации 	 = Новый_ИдентификаторыСправочника(Отправитель.ОрганизацияЭДО, Отправитель.BoxID);
	ИдентификаторыКонтрагента	 = Новый_ИдентификаторыСправочника(Контрагент1С); 
	
	BoxID 						 = ХранениеДанных_ИдентификаторКонтрагента(ИдентификаторыКонтрагента);
	ИдентификаторыКонтрагента.ID = BoxID;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторыКонтрагента.ID) Тогда
		Возврат;
	КонецЕсли;
	
	Пакет.Получатель 		= Контрагенты_ЗаполнитьУчастникаДО(ИдентификаторыКонтрагента, ИдентификаторыОрганизации);

КонецПроцедуры

//Отвязывает пакет от документа учета если все документы пакета отвязаны от документов учета
//
//Параметры:
//	Идентификаторы	 - Структура -  идентификаторы пакета
//
//Возвращаемое значение:
//	Булево - Истина если пакет отвязан от документа учета
//
Функция Пакеты_ОтвязатьПакетОтДокументаУчета(Идентификаторы) Экспорт
	
	Результат = Ложь;
	
	Пакет = ХранениеДанных_ДанныеПакета(Идентификаторы);
	
	Если Пакет.ДокументУчета <> Неопределено Тогда
		
		МожноОтвязатьПакетОтДокументаУчета = Истина;
		
		Для каждого ДокументПакета Из Пакет.Документы Цикл
			
			Если ДокументПакета.ДокументУчета <> Неопределено Тогда
				МожноОтвязатьПакетОтДокументаУчета = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если МожноОтвязатьПакетОтДокументаУчета Тогда
			
			Пакет.ДокументУчета = Неопределено; 
			ХранениеДанных_ЗаписатьПакет(Пакет);
			
			Результат = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ПОДГОТОВКА К ОТПРАВКЕ

Функция Пакеты_ПодготовитьПакет(СтрокаСписка, ПроверятьXDTO = Истина) Экспорт
	
	Результат = Контракт_Пакет();
	
	Если СтрокаСписка <> Неопределено Тогда
		
		ПакетЭДО = СтрокаСписка.Пакет;
		LetterId = СтрокаСписка.LetterId;
		
		Если ЗначениеЗаполнено(ПакетЭДО) ИЛИ ЗначениеЗаполнено(LetterId) Тогда
			Результат = Пакеты_СохраненныйПакетПоСтроке(СтрокаСписка);
		Иначе	
			Результат = Пакеты_НовыйПакет(СтрокаСписка, ПроверятьXDTO);
		КонецЕсли;
		
		Пакеты_ДобавитьВПакетДокументыСДиска(Результат, СтрокаСписка.Ключ);
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция Пакеты_НовыйПакет(СтрокаСписка, ПроверятьXDTO)

	Результат = Пакеты_ПодготовитьНовыйПакет(СтрокаСписка);
	
	Если ЗначениеЗаполнено(Результат.ПараметрыШаблона.LockMode)
		И НРег(Результат.ПараметрыШаблона.LockMode) <> НРег("None") Тогда
		Результат.Заблокирован = Истина;
	КонецЕсли;
	
	Пакеты_ЗаполнитьМетаданныеДокументов(Результат, Ложь, ПроверятьXDTO);
	Пакеты_ЗаполнитьСвязиДокументамиОснованиями(Результат);
	Пакеты_ЗаполнитьНеобходимостьШифрованияДокументов(Результат);
	Пакеты_ВалидацияДокументов(Результат);
	
	ПодключаемыйМодуль_ОбработатьСобытие("ПослеПодготовкиПакета", Новый Структура("Пакет", Результат));
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПодготовитьНовыйПакет(СтрокаСписка, ЗаполнитьДокументыБезКонтента = Ложь)
	
	Результат = Контракт_Пакет();
	
	Результат.Состояние = Перечисление_СтатусыПакетов().Подготовлен;
	
	ДанныеИзСтроки = СписокДокументов_ДанныеПакетаНаОтправкуПоСтрокеСписка(СтрокаСписка);
	ЗаполнитьЗначенияСвойств(Результат, ДанныеИзСтроки, "Направление, Отправитель, Получатель, ДокументУчета, ДопРеквизиты, Заблокирован, Шаблон");
	ЗаполнитьЗначенияСвойств(Результат.Реквизиты, ДанныеИзСтроки.Реквизиты);
	ДополнитьСтруктуру(Результат.СлужебнаяИнформация, ДанныеИзСтроки.СлужебнаяИнформация);
	
	Результат.ИдентификаторВида		= ДанныеИзСтроки.ИдентификаторВидаПакета;
	Результат.Идентификаторы.BoxId	= АдресЯщикаВИдентификатор(ДанныеИзСтроки.Отправитель.BoxId);
	
	Пакеты_ЗаполнитьПараметрыОтправки(Результат, ЗаполнитьДокументыБезКонтента);
	
	Если НЕ ЗаполнитьДокументыБезКонтента Тогда
		
		Если Результат.Направление = Перечисление_Направления().Внутреннее Тогда
			
			Результат.Отправитель.DepartmentId = Подразделения_ИдентификаторПодразделенияОрганизации(
				СтрокаСписка.ПодразделениеОтправитель,
				Результат.Отправитель.BoxId
			);
			
			Результат.Получатель.DepartmentId = Подразделения_ИдентификаторПодразделенияОрганизации(
				СтрокаСписка.ПодразделениеПолучатель,
				Результат.Получатель.BoxId
			);
			
		КонецЕсли;
		
		Пакеты_ЗаполнитьПараметрыПереотправки(Результат);
		Пакеты_ЗаполнитьПараметрыМаршрутизацииПоПодразделениям(Результат);
		
	КонецЕсли;
	
	Параметры = Новый Структура;
	Параметры.Вставить("Пакет",			Результат);
	Параметры.Вставить("СтрокаСписка",	СтрокаСписка);
	
	Попытка
		
		ПодключаемыйМодуль_ОбработатьСобытие("ПодготовитьПакет", Параметры);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ШаблонОшибки =
		"Не удалось подготовить пакет (ВидПакета=%1, ДокументУчета=%2) по причине:
		|%3";
		
		СсылкаНаОбъект = СтрокаСписка.Документ;
		
		ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			Результат.ИдентификаторВида,
			СсылкаНаОбъект,
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ПодготовкаПакета",
			УровеньЖурналаРегистрации.Ошибка,
			Неопределено,
			СсылкаНаОбъект,
			ПодробнаяОшибка
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Пакеты_ДобавитьДокументыСвязанныхПакетов(Результат, СтрокаСписка, ЗаполнитьДокументыБезКонтента);	
	
	Возврат Результат;
	
КонецФункции

// Добавляет в основной пакет документы из связанного пакета. Если строка списка документов содержит
// связанный пакет (значения КлючОсновногоПакета и Ключ не совпадают), тогда получаем документы пакета
// и добавляем их в основной
//
// Параметры:
//  Пакет							 - Структура - основной пакет (описание полей см. Контракт_Пакет)
//  СтрокаСписка					 - СтрокаТаблицыЗначений - строка списка документов
//  ЗаполнитьДокументыБезКонтента	 - Булево - признак необходимости заполнения пакета без контента
//
Процедура Пакеты_ДобавитьДокументыСвязанныхПакетов(Пакет, СтрокаСписка, ЗаполнитьДокументыБезКонтента)
	
	ДобавитьДокументыДругихПакетов = (СтрокаСписка.КлючОсновногоПакета = СтрокаСписка.Ключ);
	
	Если ДобавитьДокументыДругихПакетов Тогда
		
		СтрокиСвязанныхПакетов = СписокДокументов_ПолучитьСтрокиСвязанныхПакетов(СтрокаСписка);
		
		Для Каждого СтрокаДобавляемогоПакета Из СтрокиСвязанныхПакетов Цикл
			
			ДобавитьДокументыПакета = (СтрокаДобавляемогоПакета.КлючОсновногоПакета <> СтрокаДобавляемогоПакета.Ключ);
			
			Если ДобавитьДокументыПакета Тогда
				
				СвязанныйПакет = Пакеты_ПодготовитьНовыйПакет(СтрокаДобавляемогоПакета, ЗаполнитьДокументыБезКонтента);
			
				Для Каждого Документ Из СвязанныйПакет.Документы Цикл
					Пакет.Документы.Добавить(Документ);			
				КонецЦикла;
				
				ОписаниеСвязанногоПакета = Контракт_ОписаниеСвязанногоПакета();
				
				ОписаниеСвязанногоПакета.ИдентификаторВида = СвязанныйПакет.ИдентификаторВида;
				ОписаниеСвязанногоПакета.ДокументУчета = СвязанныйПакет.ДокументУчета;
				
				Пакет.СлужебнаяИнформация.ПараметрыОтправки.СвязанныеПакеты.Добавить(ОписаниеСвязанногоПакета);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

// Возвращает строки связанных пакетов, найденных в списке документов
//
// Параметры:
//  СтрокаСписка - СтрокаТаблицыЗначений - строка списка документов
// 
// Возвращаемое значение:
//  Массив - массив строк таблицы списка документов
//
Функция СписокДокументов_ПолучитьСтрокиСвязанныхПакетов(СтрокаСписка)
	
	Если Не ЗначениеЗаполнено(СтрокаСписка.Ключ) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	КэшСпискаДокументов = СписокДокументов_ПолучитьИзЛокальногоКэша();
	
	Отбор = Новый Структура("КлючОсновногоПакета", СтрокаСписка.Ключ);
	Результат = КэшСпискаДокументов.НайтиСтроки(Отбор);

	Возврат Результат;
	
КонецФункции

// Возвращает список документов, ранее помещенный в кэш
// Используется для оптимизации. Удаляется из кэша, как только обработка списка заканчивается
//
// Возвращаемое значение:
//  ТаблицаЗначений - список документов
//
Функция СписокДокументов_ПолучитьИзЛокальногоКэша()
	
	ИмяКлюча = "СписокДокументов_ЛокальныйКэш";
	
	Результат = Кэш_Прочитать(ИмяКлюча);
	Если Результат = Неопределено Тогда
		
		АдресКэшаСпискаДокументов = ОбщийКонтекст_Прочитать("АдресКэшаСпискаДокументов");
		Результат = ПолучитьИзВременногоХранилища(АдресКэшаСпискаДокументов);
		
		СписокДокументов_ПоместитьВЛокальныйКэш(Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Удаляет список документов из кэша
//
Процедура СписокДокументов_ОчиститьЛокальныйКэш() Экспорт
	
	ИмяКлюча = "СписокДокументов_ЛокальныйКэш";
	
	Кэш_Поместить(ИмяКлюча, Неопределено);
	
КонецПроцедуры

// Контракт описания связанного пакета
// 
// Возвращаемое значение:
//  Структура - контракт
//		ИдентификаторВида - Строка - идентификатор вида документа
//		ДокументУчета - Любая ссылка - ссылка на документ 1С
//
Функция Контракт_ОписаниеСвязанногоПакета() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("ИдентификаторВида", "");
	Результат.Вставить("ДокументУчета", Неопределено);
	
	Возврат Результат;
	
КонецФункции	

Процедура Пакеты_ЗаполнитьПараметрыОтправки(Пакет, ЗаполнитьДокументыБезКонтента)
	
	Пакет.СлужебнаяИнформация.Вставить("ПараметрыОтправки", Контракт_ПараметрыОтправкиПакета());
	Пакет.СлужебнаяИнформация.ПараметрыОтправки.ЗаполнитьДокументыБезКонтента = ЗаполнитьДокументыБезКонтента;

КонецПроцедуры

Процедура Пакеты_ЗаполнитьПараметрыПереотправки(Пакет)
	
	ПереотправляемыйПакет = ХранениеДанных_ПереотправляемыйПакет(Пакет.ДокументУчета);
	
	Если ЗначениеЗаполнено(ПереотправляемыйПакет) Тогда
		
		ПараметрыПереотправки = Контракт_ПараметрыПереотправкиДокумента();
		ПараметрыПереотправки.ПереотправляемыйПакет.LetterID = ПереотправляемыйПакет;
		
		Пакет.СлужебнаяИнформация.Вставить("ПараметрыПереотправки", ПараметрыПереотправки);
		
	КонецЕсли;

КонецПроцедуры

Процедура Пакеты_ЗаполнитьПараметрыМаршрутизацииПоПодразделениям(Пакет)
	
	Если Пакет.Направление = Перечисление_Направления().Внутреннее Тогда
		// Для внутренних документов подразделение определяется
		// при построении списка пакетов на отправку
		Возврат;
	КонецЕсли;
	
	ИспользоватьМаршрутизациюПоПодразделениям = ЗначениеНастройки_ИспользоватьСопоставлениеПодразделений();
	
	ТребуетсяПрочитатьМаршрутизацию = (ИспользоватьМаршрутизациюПоПодразделениям И ЕстьИнтеграционныйМодуль());
	
	Если НЕ ТребуетсяПрочитатьМаршрутизацию Тогда
		Возврат;
	КонецЕсли;
	
	Документ1С = Пакет.ДокументУчета;
	
	Модуль_МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	ПоляМаршрутизации = Модуль_МенеджерИнтеграции.ЗначенияПолейМаршрутизацииПоПодразделениям(Документ1С);
	
	IdВладельцаПодразделения = Пакет.Отправитель.BoxId;
	IdПодразделенияОтправителя = Подразделения_ИдентификаторПодразделенияОрганизации(
			ПоляМаршрутизации.Отправитель,
			IdВладельцаПодразделения);
	
	Если ЗначениеЗаполнено(IdПодразделенияОтправителя) Тогда
		Пакет.Отправитель.DepartmentId = IdПодразделенияОтправителя;
	КонецЕсли;
	
	IdВладельцаПодразделения = Пакет.Получатель.BoxId;
	IdПодразделенияПолучателя = Подразделения_ИдентификаторПодразделенияКонтрагента(
			ПоляМаршрутизации.Получатель,
			IdВладельцаПодразделения);
	
	Если ЗначениеЗаполнено(IdПодразделенияПолучателя) Тогда
		Пакет.Получатель.DepartmentId = IdПодразделенияПолучателя;
	КонецЕсли;
	
КонецПроцедуры

// Получает идентификатор подразделения в ящике организации, сопоставленного с указанным объектом
// информационной базы. Допускается передавать массив ссылок для поиска сопоставленных подразделений.
// В этом случае порядок элементов массива определяет приоритет поиска, а функция возвращает первый
// найденный идентификатор.
//
// Параметры:
//  СсылкаИлиМассив - ЛюбаяСсылка, Массив из ЛюбаяСсылка - объект для поиска сопоставленного подразделения
//  ИдентификаторОрганизации - Строка - идентификатор ящика организации
// 
// Возвращаемое значение:
//  Строка - идентификатор подразделения в ящике организации.
//
Функция Подразделения_ИдентификаторПодразделенияОрганизации(СсылкаИлиМассив, ИдентификаторОрганизации) Экспорт
	
	Результат = "";
	Если Не ЗначениеЗаполнено(СсылкаИлиМассив) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(СсылкаИлиМассив) = Тип("Массив") Тогда
		ОбъектыИнформационнойБазы = СсылкаИлиМассив;
	Иначе
		ОбъектыИнформационнойБазы = Новый Массив;
		ОбъектыИнформационнойБазы.Добавить(СсылкаИлиМассив);
	КонецЕсли;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ДляОрганизации = Истина;
	
	Для НомерПриоритета = 0 По ОбъектыИнформационнойБазы.ВГраница() Цикл
		
		СсылкаНаОбъект = ОбъектыИнформационнойБазы[НомерПриоритета];
		
		Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат = Модуль_ХранениеДанных.Подразделения_ИдентификаторПоСвязаннымСправочникам(
			СсылкаНаОбъект,
			ИдентификаторОрганизации,
			ДляОрганизации
		);
		
		Если ЗначениеЗаполнено(Результат) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Получает идентификатор подразделения в ящике организации, сопоставленного с указанным объектом
// информационной базы. Допускается передавать массив ссылок для поиска сопоставленных подразделений.
// В этом случае порядок элементов массива определяет приоритет поиска, а функция возвращает первый
// найденный идентификатор.
//
// Параметры:
//  СсылкаИлиМассив - ЛюбаяСсылка, Массив из ЛюбаяСсылка - объект для поиска сопоставленного подразделения
//  ИдентификаторКонтрагента - Строка - идентификатор ящика контрагента
// 
// Возвращаемое значение:
//  Строка - идентификатор подразделения в ящике контрагента.
//
Функция Подразделения_ИдентификаторПодразделенияКонтрагента(СсылкаИлиМассив, ИдентификаторКонтрагента) Экспорт
	
	Результат = "";
	Если Не ЗначениеЗаполнено(СсылкаИлиМассив) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(СсылкаИлиМассив) = Тип("Массив") Тогда
		ОбъектыИнформационнойБазы = СсылкаИлиМассив;
	Иначе
		ОбъектыИнформационнойБазы = Новый Массив;
		ОбъектыИнформационнойБазы.Добавить(СсылкаИлиМассив);
	КонецЕсли;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ДляОрганизации = Ложь;
	
	Для НомерПриоритета = 0 По ОбъектыИнформационнойБазы.ВГраница() Цикл
		
		СсылкаНаОбъект = ОбъектыИнформационнойБазы[НомерПриоритета];
		
		Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат = Модуль_ХранениеДанных.Подразделения_ИдентификаторПоСвязаннымСправочникам(
			СсылкаНаОбъект,
			ИдентификаторКонтрагента,
			ДляОрганизации
		);
		
		Если ЗначениеЗаполнено(Результат) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ЗаполнитьНеобходимостьШифрованияДокументов(Пакет) Экспорт
	
	Если Пакет.Шаблон Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(Пакет.Отправитель.ОрганизацияЭДО, Пакет.Отправитель.BoxId);
	ИдентификаторыКонтрагента	= Новый_ИдентификаторыСправочника(Пакет.Получатель.ОрганизацияЭДО,	Пакет.Получатель.BoxId);
	
	ТребуетсяШифрование	= Документы_ТребуетсяШифрованиеДокументов(ИдентификаторыОрганизации, ИдентификаторыКонтрагента);

	ЗашифрованныйПакет = Ложь;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ТипКонтента 		= Документ.Тип.ТипКонтента;
		ТипДокумента 		= Документ.Тип.ТипДокумента;
		ФункцияДокумента 	= Документ.Тип.ФункцияДокумента;
		
		ОписаниеВидаДокумента = Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
		
		ТребуетсяШифрованиеДокумента = ТребуетсяШифрование И ОписаниеВидаДокумента.SupportsEncrypting;
		
		Документ.СлужебнаяИнформация.ПараметрыОтправки.Вставить("ЗашифрованныйПакет", ТребуетсяШифрованиеДокумента);
		
		Если ТребуетсяШифрованиеДокумента Тогда
			ЗашифрованныйПакет = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	ТребуетсяШифрованиеПакета = (ТребуетсяШифрование И ЗашифрованныйПакет);
	
	Пакет.СлужебнаяИнформация.Вставить("ЗашифрованныйПакет", ТребуетсяШифрованиеПакета);
	
КонецПроцедуры

Процедура Пакеты_ЗаполнитьМетаданныеДокументов(Пакет, ОбновитьПодписанта, ПроверятьXDTO)
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		МетаданныеПротоСтруктуры = Документы_МетаданныеПротоСтруктуры(Документ);
		ЗаполнитьЗначенияСвойств(Документ.Метаданные, МетаданныеПротоСтруктуры);
		
		Если Документ.Тип.Формализованный Тогда
			
			ЗаполнитьКонтентXML = НЕ Документ.Документооборот.Свойство("ХранилищеКонтента") 
								ИЛИ НЕ ЗначениеЗаполнено(Документ.Документооборот.ХранилищеКонтента.Данные)
								ИЛИ ОбновитьПодписанта;
								
			Если ЗаполнитьКонтентXML Тогда 
				Документы_ЗаполнитьФормализованныйКонтентXML(Документ, ПроверятьXDTO);
			КонецЕсли;
			
		КонецЕсли;
		
		Документы_ЗаполнитьРеквизитыПодготовленногоДокумента(Документ);
		
	КонецЦикла;	
	
КонецПроцедуры

Процедура Пакеты_ВалидацияДокументов(Пакет) Экспорт
	
	ТекстОшибкиПакета			= "";
	ТекстОшибкиПакетаБезСсылок	= "";
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ОшибкиВалидации	= Документы_ОшибкиВалидацииДокумента(Документ);
		
		Если ЗначениеЗаполнено(ОшибкиВалидации) Тогда
			
			ТекстОшибкиДокумента = "";
			
			Для Каждого ОшибкаВалидации Из ОшибкиВалидации Цикл
				ТекстОшибкиДокумента = ТекстОшибкиДокумента + Символы.ПС + ОшибкаВалидации.ТекстОшибки;
			КонецЦикла;
			
			ТекстОшибкиДокумента = СокрЛП(ТекстОшибкиДокумента);
			ТекстОшибкиДокумента = СтрЗаменить(ТекстОшибкиДокумента, "<", "");
			ТекстОшибкиДокумента = СтрЗаменить(ТекстОшибкиДокумента, ">", "");
			
			ТекстОшибкиПакета = ТекстОшибкиПакета + Символы.ПС + ТекстОшибкиДокумента;
			
			ВидОперации		= "Валидация документов";
			Представление	= Документы_ПредставлениеДокумента(Документ);
			ДопИнформация	= "Документ: " + Представление;
			
			НачалоСсылки = "a href";
			КонецСсылки = "/a";
			
			ПозицияСсылки = Найти(ТекстОшибкиДокумента, НачалоСсылки);
			
			Пока ПозицияСсылки > 0 Цикл
				
				ПозицияОкончанияСсылки = Найти(ТекстОшибкиДокумента, КонецСсылки);
				
				ДлинаСсылки	= ПозицияОкончанияСсылки + СтрДлина(КонецСсылки) + 1 - ПозицияСсылки;
				ТекстСсылки = Сред(ТекстОшибкиДокумента, ПозицияСсылки - 1, ДлинаСсылки);
				
				ТекстОшибкиДокумента = СтрЗаменить(ТекстОшибкиДокумента, ТекстСсылки, "");
				
				ПозицияСсылки = Найти(ТекстОшибкиДокумента, НачалоСсылки);
				
			КонецЦикла;
			
			ТекстОшибкиПакетаБезСсылок = ТекстОшибкиПакетаБезСсылок + Символы.ПС + ТекстОшибкиДокумента;
			
			Ошибка_Обработать(ВидОперации, , ДопИнформация, ТекстОшибкиДокумента);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Ключ = Новый_КлючИдентификатораСтроки(Пакет.ДокументУчета, Пакет.ИдентификаторВида);
	
	Если ЗначениеЗаполнено(ТекстОшибкиПакета) Тогда
		
		ТекстОшибкиПакета = СокрЛП(ТекстОшибкиПакета);
		Пакет.СлужебнаяИнформация.Вставить("ОшибкиОтправки", ТекстОшибкиПакета);
		
		ТекстОшибкиПакетаБезСсылок = СокрЛП(ТекстОшибкиПакетаБезСсылок);
	    КэшОшибокСтрокСписка_Поместить(Ключ, ТекстОшибкиПакетаБезСсылок);
		
	Иначе
		
		Пакет.СлужебнаяИнформация.Вставить("ОшибкиОтправки", "");
		КэшОшибокСтрокСписка_Удалить(Ключ);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Пакеты_ПредупрежденияДокументов(Документ) Экспорт
	
	Если НЕ Документ.СлужебнаяИнформация.Свойство("Контент") Тогда
		Возврат;
	КонецЕсли;
	
	ИсходныйТипКонтента = Документ.Тип.ТипКонтента;
	
	ГодФормата = "2025";
	МесяцФормата = "4";
	ДеньФормата = "1";
	ДатаОкончания820Формата = Дата(ГодФормата, МесяцФормата, ДеньФормата);
	ДатаПоМоскве = ТекущаяУниверсальнаяДата() + 10800;
	
	Если ИсходныйТипКонтента = ТипКонтента_utd970() Тогда
		
		Если Не Документ.СлужебнаяИнформация.Свойство("СписокПредупреждений") Тогда
			Документ.СлужебнаяИнформация.Вставить("СписокПредупреждений", Новый Массив);
		КонецЕсли;
		
		Модуль_ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
		Модуль_ГенерацияXML.ВалидацияUTD970_Предупреждения(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.СписокПредупреждений
		);
	ИначеЕсли ИсходныйТипКонтента = ТипКонтента_utd820() И ДатаПоМоскве >= ДатаОкончания820Формата Тогда
		АдресаИнтернетРесурсов = Перечисление_АдресаИнтернетРесурсов();
		СправкаПоАктуальнымФорматам = АдресаИнтернетРесурсов.СправкаПоАктуальнымФорматам;
		
		Если Не Документ.СлужебнаяИнформация.Свойство("СписокПредупреждений") Тогда
			Документ.СлужебнаяИнформация.Вставить("СписокПредупреждений", Новый Массив);
		КонецЕсли;

		ТекстПредупреждения =
		"Документ в устаревшем формате и не имеет юридическую силу.
        |Переключите в <a href=ПЕРЕКЛЮЧИТЬФОРМАТФНС>настройке документов</a> на
		|<a href=""" + СправкаПоАктуальнымФорматам + """>действующий</a> формат ФНС.";
				
		ОписаниеПредупреждения = Новый Структура;
		ОписаниеПредупреждения.Вставить("Группа", "ФорматДокумента");
		ОписаниеПредупреждения.Вставить("Текст", ТекстПредупреждения);
		Документ.СлужебнаяИнформация.СписокПредупреждений.Добавить(ОписаниеПредупреждения);
		
	КонецЕсли;
	
КонецПроцедуры

// Заполняет в документах пакета коллекцию InitialDocumentIds
// идентификаторами документов оснований.
//
// Параметры:
//  Пакет - Структура - см. фукнцию Контракт_Пакет()
//
Процедура Пакеты_ЗаполнитьСвязиДокументамиОснованиями(Пакет)
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДокументыОснования = Документ.СлужебнаяИнформация.ДокументыОснования;
		
		Если Не ЗначениеЗаполнено(ДокументыОснования) Тогда
			Продолжить;
		КонецЕсли;
		
		МассивИД = ХранениеДанных_ИдентификаторыОтправленныхДокументовПоДокументам1С(Документ, ДокументыОснования);
		
		Если Не ЗначениеЗаполнено(МассивИД) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Документ.Связи.InitialDocumentIds = Неопределено Тогда
			Документ.InitialDocumentIds = МассивИД;
		Иначе
			ДополнитьМассив(Документ.Связи.InitialDocumentIds, МассивИД);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_ДобавитьДокументВПакет(Пакет, Документ1С, ВидДокументаСтрокой, ДополнительныеПараметры = Неопределено) Экспорт
	
	ЗаполнитьДокументыБезКонтента = Пакет.СлужебнаяИнформация.ПараметрыОтправки.ЗаполнитьДокументыБезКонтента;
	
	ВидДокумента = Списки_ОписаниеВидаДокумента(ВидДокументаСтрокой);
	
	Если ВидДокумента = Неопределено Тогда
		
		ВидОперации			= "Добавление документа в пакет";
		ТекстСообщения		= "Не удалось добавить документ в пакет %1
							  |Не определен вид документа %2";
		ПредставлениеПакета	= ПредставлениеПакета(Пакет);
		ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПредставлениеПакета, ВидДокументаСтрокой);
		
		Если ЗаполнитьДокументыБезКонтента Тогда
			Ошибка_Обработать(ВидОперации, ТекстСообщения);
		Иначе
			Ошибка_Обработать(ВидОперации, , , ТекстСообщения);
		КонецЕсли;
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ТипДокумента		= ВидДокумента.ТипДокументаAPI;
	ТипКонтента			= ВидДокумента.ТипКонтентаAPI;
	ФункцияДокумента	= ВидДокумента.ФункцияДокументаAPI;
	ТипКонтентаДляОтправки = "";
	
	ЕстьБазовыйВидДокумента = ЗначениеЗаполнено(ВидДокумента.БазовыйВидДокумента);
	
	Если ЕстьБазовыйВидДокумента Тогда
		ВидДокументаПараметровОтправки = ВидДокумента.БазовыйВидДокумента;
	Иначе
		ВидДокументаПараметровОтправки = ВидДокументаСтрокой;
	КонецЕсли;
	
	ПараметрыОтправкиВидаДокумента = Документы_ПараметрыОтправкиВидаДокумента(ВидДокументаПараметровОтправки, Пакет.Отправитель, Пакет.Получатель);
	
	ФорматОтправки			= ПараметрыОтправкиВидаДокумента.ФорматОтправки;
	НастройкиПечатныхФорм	= ПараметрыОтправкиВидаДокумента.НастройкиПечатныхФорм;
	
	ФорматыОтправкиДокументов = Перечисление_ФорматыОтправкиДокументов();
	
	Если ФорматОтправки = ФорматыОтправкиДокументов.epf Тогда
		
		ТипДокумента	= Документы_ТипДокументаПриОтправкеВПФ(ТипДокумента);
		ТипКонтента		= "";
		
	ИначеЕсли ФорматОтправки = НастройкаОтправки_utd970_820() Тогда
		
		ТипКонтента = ТипКонтента_utd970();
		ТипКонтентаДляОтправки = ТипКонтента_utd820();
		
	ИначеЕсли ФорматОтправки = НастройкаОтправки_utd820_970() Тогда
		
		ТипКонтента = ТипКонтента_utd820();
		ТипКонтентаДляОтправки = ТипКонтента_utd970();
		
	Иначе
		
		ВыбранФорматКонтента = ЗначениеЗаполнено(ФорматОтправки) И НЕ ФорматыОтправкиДокументов.Свойство(ФорматОтправки);
		
		Если ВыбранФорматКонтента Тогда
			ТипКонтента = ФорматОтправки;
		КонецЕсли;
	
	КонецЕсли;
	
	Результат = Пакеты_НовыйДокумент(Пакет, ТипДокумента, ТипКонтента, ФункцияДокумента);
	
	Результат.ИдентификаторВида	= ВидДокументаСтрокой;
	Результат.ДокументУчета		= Документ1С;
	
	Если ЗаполнитьДокументыБезКонтента Тогда
		
		ОсновнаяПечатнаяФорма = ?(ФорматОтправки = ФорматыОтправкиДокументов.epf, НастройкиПечатныхФорм.ОсновнаяПечатнаяФорма, Неопределено);
		Документы_ЗаполнитьДокументБезКонтента(Результат, ОсновнаяПечатнаяФорма);
		
	Иначе
		
		Документы_ПодготовитьСлужебнуюИнформациюДляОтправки(Результат);
		
		Если ФорматОтправки = ФорматыОтправкиДокументов.epf Тогда
			ПодключаемыйМодуль_ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме(Результат, НастройкиПечатныхФорм.ОсновнаяПечатнаяФорма);
		ИначеЕсли ФорматОтправки = ФорматыОтправкиДокументов.pf_1c Тогда	
			МенеджерИнтеграции_ПодготовитьЭлектронныйДокументСредствамиКонфигурации(Результат);
		Иначе
			Документы_ПодготовитьЭлектронныйДокумент(Пакет, Результат, ДополнительныеПараметры, ТипКонтентаДляОтправки);
		КонецЕсли;
		
	КонецЕсли;
	
	Пакет.Документы.Добавить(Результат);
	
	Если НЕ ЕстьБазовыйВидДокумента Тогда
		Пакеты_ДобавитьДополнительныеПечатныеФормыКДокументу(Пакет, Результат, НастройкиПечатныхФорм.ДополнительныеПечатныеФормы);
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции

// Конвертирует контент электронного документа в указанный формат.
// Если конвертация между текущим и новым форматом не поддерживается,
// генерируется исключительная ситуация
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ()
//  ТипКонтентаДляОтправки - Строка - идентификатор целевого типа контента.
//
Процедура Документы_Конвертировать(Документ, Знач ТипКонтентаДляОтправки)
	
	ИсходныйТипКонтента = Документ.Тип.ТипКонтента;
	
	Если Не ЗначениеЗаполнено(ТипКонтентаДляОтправки)
		Или ИсходныйТипКонтента = ТипКонтентаДляОтправки Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не Документ.СлужебнаяИнформация.Свойство("ОшибкиКонвертации") Тогда
		Документ.СлужебнаяИнформация.Вставить("ОшибкиКонвертации", Новый Массив);
	КонецЕсли;
	
	Документ.Тип.ТипКонтента = ТипКонтентаДляОтправки;
	
	Если ИсходныйТипКонтента = ТипКонтента_utd970()
		И ТипКонтентаДляОтправки = ТипКонтента_utd820() Тогда
		
		Документ.СлужебнаяИнформация.Контент = УПД970_Конвертировать_в820(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.ОшибкиКонвертации
		);
		
	ИначеЕсли ИсходныйТипКонтента = ТипКонтента_utd820()
		И ТипКонтентаДляОтправки = ТипКонтента_utd970() Тогда
		
		Документ.СлужебнаяИнформация.Контент = УПД820_Конвертировать_в970(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.ОшибкиКонвертации
		);
		
	Иначе
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"КонвертацияФорматов(ValueError): Неожиданные значения параметров (ИсходныйТип = %1, НовыйТип = %2)",
			ИсходныйТипКонтента,
			ТипКонтентаДляОтправки
		);
		
		Документ.Тип.ТипКонтента = ИсходныйТипКонтента;
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Документы_КонвертироватьСтавкиНДС(Документ)
	
	Если НЕ ТребуетсяКонвертацияСтавокНДС() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Документ.СлужебнаяИнформация.Свойство("СписокПредупреждений") Тогда
		Документ.СлужебнаяИнформация.Вставить("СписокПредупреждений", Новый Массив);
	КонецЕсли;
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	
	Модуль_ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	
	Если ТипКонтента = ТипКонтента_utd970() Тогда
		
		Документ.СлужебнаяИнформация.Контент = Модуль_ГенерацияXML.УПД970_КонвертироватьСтавкиНДС(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.СписокПредупреждений
		);
		
	ИначеЕсли ТипКонтента = ТипКонтента_ucd736() Тогда
		
		Документ.СлужебнаяИнформация.Контент = Модуль_ГенерацияXML.УКД736_КонвертироватьСтавкиНДС(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.СписокПредупреждений
		);
		
	ИначеЕсли ТипКонтента = ТипКонтента_proformainvoice29()
		ИЛИ ТипКонтента = ТипКонтента_invoiceoffer29() Тогда
		
		Документ.СлужебнаяИнформация.Контент = Модуль_ГенерацияXML.Счет29_КонвертироватьСтавкиНДС(
			Документ.СлужебнаяИнформация.Контент,
			Документ.СлужебнаяИнформация.СписокПредупреждений
		);
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
	Если ЕстьПредупрежденияКонвертацииСтавокНДС(Документ.СлужебнаяИнформация.СписокПредупреждений) Тогда
		
		КатегорииМетрик = Метрика_НазваниеКатегории();
		Категория = КатегорииМетрик.КонвертацияНДС22;
		
		ДействияМетрик = Метрика_НазваниеДействий();
		Действие = ДействияМетрик.ВыполненаОперацияКонвертации;
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID", Документ.Идентификаторы.BoxId);
		ДополнитьПеременныеМетрики_BaseId(Переменные);
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
		
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ПараметрыОтправкиВидаДокумента(ВидДокумента, Отправитель, Получатель)
	
	Результат = Новый Структура("ФорматОтправки, НастройкиПечатныхФорм");
	
	Идентификаторы		= Новый_ИдентификаторыСправочника(Отправитель.ОрганизацияЭДО, Отправитель.BoxId);
	ДанныеОрганизации	= ХранениеДанных_ДанныеОрганизации(Идентификаторы);
	
	Идентификаторы		= Новый_ИдентификаторыСправочника(Получатель.ОрганизацияЭДО, Получатель.BoxId);
	ДанныеКонтрагента	= ХранениеДанных_ДанныеКонтрагента(Идентификаторы);
	
	Результат.ФорматОтправки		= НастройкиДокументов_ФорматВидаДокумента(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Результат.НастройкиПечатныхФорм = НастройкиПечатныхФорм_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТипДокументаПриОтправкеВПФ(Знач ТипДокумента)
	
	ТипДокумента = ВРег(ТипДокумента);
	
	Если ТипДокумента = ВРег(Тип_Накладная()) Тогда
		
		Результат = Тип_НакладнаяНеформализованная();
		
	ИначеЕсли ТипДокумента = ВРег(Тип_АктОбОказанииУслуг()) Тогда
		
		Результат = Тип_АктОбОказанииУслугНеформализованный();
		
	ИначеЕсли ТипДокумента = ВРег(Тип_СчетНаОплату()) Тогда
		
		Результат = Тип_СчетНаОплату();
		
	ИначеЕсли ТипДокумента = ВРег(Тип_АктСверки()) Тогда
		
		Результат = Тип_АктСверки();
		
	Иначе
		Результат = Тип_Неформализованный();
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ДобавитьДополнительныеПечатныеФормыКДокументу(Пакет, Документ, ДополнительныеПечатныеФормы)
	
	Для Каждого ПечатнаяФорма Из ДополнительныеПечатныеФормы Цикл
		
		НовыйДокумент = Пакеты_НовыйДокумент(Пакет, "Nonformalized");
		НовыйДокумент.ДокументУчета = Документ.ДокументУчета;
		
		Если Пакет.СлужебнаяИнформация.ПараметрыОтправки.ЗаполнитьДокументыБезКонтента Тогда
			Документы_ЗаполнитьДокументБезКонтента(НовыйДокумент, ПечатнаяФорма);
		Иначе
			Документы_ПодготовитьСлужебнуюИнформациюДляОтправки(НовыйДокумент);
			ПодключаемыйМодуль_ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме(НовыйДокумент, ПечатнаяФорма);
		КонецЕсли;
		
		Пакет.Документы.Добавить(НовыйДокумент);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Документы_ПодготовитьЭлектронныйДокумент(Пакет, Документ, ДополнительныеПараметры, ТипКонтентаДляОтправки)
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(Пакет.Отправитель.BoxID);
	
	Попытка
		
		Интеграция_ПодготовитьЭлектронныйДокумент(Документ, СтрокаКонтекста.ОписаниеПользователя, ДополнительныеПараметры);
		Документы_Конвертировать(Документ, ТипКонтентаДляОтправки);
		Документы_КонвертироватьСтавкиНДС(Документ);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ШаблонОшибки =
		"Не удалось подготовить документ (ВидДокумента=%1, ДокументУчета=%2) по причине:
		|%3";
		
		СсылкаНаОбъект = Документ.ДокументУчета;
		
		ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			Документ.ИдентификаторВида,
			Строка(СсылкаНаОбъект),
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ПодготовкаЭлектронногоДокумента",
			УровеньЖурналаРегистрации.Ошибка,
			Неопределено,
			СсылкаНаОбъект,
			ПодробнаяОшибка
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Контент = Документ.СлужебнаяИнформация.Контент;
	
	Если ТипЗнч(Контент) = Тип("ОбъектXDTO") Тогда
		Документ.СлужебнаяИнформация.Контент = ОбъектXDTOВСтруктуру(Контент);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодключаемыйМодуль_ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме(Документ, ПечатнаяФорма)
	
	Если ВПФ_ИспользоватьНовыйАлгоритмПодготовкиДокумента() Тогда
		Интеграция_ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме(Документ, ПечатнаяФорма);
		Возврат;
	КонецЕсли;
	
	Попытка
		ИдентификаторКоманды = ПечатнаяФорма.Команды[0].Идентификатор; //TODO: вынести в хранение данных
	Исключение
		ИдентификаторКоманды = Неопределено;
	КонецПопытки;
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Документ", Документ);
	ПараметрыПМ.Вставить("ВнешняяПечатнаяФорма", ПечатнаяФорма);
	ПараметрыПМ.Вставить("ИдентификаторКоманды", ИдентификаторКоманды);
	
	РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытие("ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме", ПараметрыПМ);
	
	Если Документ.Тип.Формализованный Тогда
		
		Документ.ИмяФайла = "";
		Документ.Метаданные.FileName = "";
		
	КонецЕсли;
	
КонецПроцедуры

// Выбор способа получения сведений определяется именем текущего интеграционного модуля.
// Если в интеграционном модуле не реализован интерфейс для получения содержимого и меты
// электронного счета на оплату, эти сведения будут получены "по-старому", 
// через библиотеку ТиповойМодульУФ или ТиповойМодульОФ.
//
// После перевода всех ИМ на новый интерфейс, этот метод следует удалить
// 
// Возвращаемое значение:
//  Булево - Истина, если следует использовать новый программный интерфейс.
//
Функция ФормироватьСчетаНаОплатуСредствамиУМ() Экспорт
	
	НеподдерживаемыеИМ = Новый Массив;
	НеподдерживаемыеИМ.Добавить(ИмяИМ_АльфаАвто6());
	
	ТекущийИМ = ИнтеграционныйМодуль_Получить();
	
	Результат = (НеподдерживаемыеИМ.Найти(ТекущийИМ) = Неопределено);
	
	Возврат Результат;
	
КонецФункции

Процедура МенеджерИнтеграции_ПодготовитьЭлектронныйДокументСредствамиКонфигурации(ДокументДиадок)
	
	Модуль_МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	Если Не Модуль_МенеджерИнтеграции.ЭтоИдентификаторВидаНеформализованныйСчет(ДокументДиадок.ИдентификаторВида) Тогда
		
		Ошибка = ПараметрыВСтроку(
			"Формирование электронного документа по форме 1С не поддерживается для документов данного вида!
			|Ссылка = %1
			|ВидДокумента = %2",
			Строка(ДокументДиадок.ДокументУчета),
			ДокументДиадок.ИдентификаторВида
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	СсылкаНаОбъект = ДокументДиадок.ДокументУчета;
	
	Если ФормироватьСчетаНаОплатуСредствамиУМ() Тогда
		
		Мета = Документы_МетаданныеНеформализованногоБезопасно(СсылкаНаОбъект, ДокументДиадок.Тип);
		ПФ = Модуль_МенеджерИнтеграции.СчетаНаОплату_ПечатнаяФорма1С(СсылкаНаОбъект);
		
		ДокументДиадок.Метаданные.DocumentDate = Мета.Дата;
		ДокументДиадок.Метаданные.DocumentNumber = Мета.Номер;
		ДокументДиадок.Метаданные.FileName = Мета.ИмяФайлаВложения;
		
		ДокументДиадок.Метаданные.TotalSum = Мета.Сумма;
		ДокументДиадок.Метаданные.TotalVat = Мета.СуммаНДС;
		ДокументДиадок.Метаданные.CurrencyCode = Мета.КодВалюты;
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
		ПФ.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
		
		ДокументДиадок.Документооборот.ХранилищеКонтента.Данные = Новый ДвоичныеДанные(ИмяВременногоФайла);
		
		УдалитьФайлы(ИмяВременногоФайла);
		
	Иначе
		
		ДанныеПечатнойФормы = Модуль_МенеджерИнтеграции.ПодготовитьЭлектронныйДокументСредствамиКонфигурации(ДокументДиадок);
		
		ДокументДиадок.Метаданные.DocumentDate = ДанныеПечатнойФормы.Дата;
		ДокументДиадок.Метаданные.DocumentNumber = ДанныеПечатнойФормы.Номер;
		ДокументДиадок.Метаданные.FileName = ДанныеПечатнойФормы.ИмяФайла;
		
		ДокументДиадок.Метаданные.TotalSum = ДанныеПечатнойФормы.Сумма;
		ДокументДиадок.Метаданные.TotalVat = ДанныеПечатнойФормы.СуммаНДС;
		ДокументДиадок.Метаданные.CurrencyCode = ДанныеПечатнойФормы.КодВалюты;
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
		ДанныеПечатнойФормы.Таблица.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
		
		ДокументДиадок.Документооборот.ХранилищеКонтента.Данные = Новый ДвоичныеДанные(ИмяВременногоФайла);
		
		УдалитьФайлы(ИмяВременногоФайла);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Документы_ЗаполнитьДокументБезКонтента(Документ, ПечатнаяФорма)
	
	ТипДокумента = ВРег(Документ.Тип.ТипДокумента);
	
	Если ПечатнаяФорма <> Неопределено 
		И ТипДокумента = ВРег(Тип_Неформализованный()) Тогда
		
		Документ.ИмяФайла = ПечатнаяФорма.Наименование;
		
	КонецЕсли;
	
	РазворачиватьПоДокументам = ОбщиеНастройки_Прочитать("РазворачиватьПакетыНаОтправкуПоДокументам");
	
	Если РазворачиватьПоДокументам Тогда
		
		Если Не ЗначениеЗаполнено(Документ.ИмяФайла) И Не Документ.Тип.Формализованный Тогда
			Документ.ИмяФайла = Документ.Тип.Представление;
		КонецЕсли;
		
		ПараметрыПМ = Новый Структура;
		ПараметрыПМ.Вставить("Документ", Документ);
		
		ПодключаемыйМодуль_ОбработатьСобытие("ЗаполнитьРеквизитыДокумента", ПараметрыПМ);
		
	КонецЕсли;
	
КонецПроцедуры

Функция Пакеты_НовыйДокумент(Пакет, ТипДокумента, ТипКонтента="", ФункцияДокумента="") Экспорт
	
	Результат = Контракт_Документ();
	
	ОписаниеТипаДокумента = Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
	
	ДанныеХранения = Контракт_ДанныеХранения();
	Результат.Документооборот.Вставить("ХранилищеКонтента", ДанныеХранения);
	
	BoxId = "";
	Если ЗначениеЗаполнено(Пакет.Отправитель.BoxID) Тогда
		BoxId = АдресЯщикаВИдентификатор(Пакет.Отправитель.BoxID);
	КонецЕсли;

	Результат.ИдентификаторВидаПакета	= Пакет.ИдентификаторВида;
	Результат.Шаблон					= Пакет.Шаблон;
	Результат.Направление				= Пакет.Направление;
	Результат.Идентификаторы.BoxID		= BoxId;
	Результат.Метаданные 				= КопияКоллекцииЗначений(ОписаниеТипаДокумента.Metadata);
	Результат.Состояние					= Перечисление_СтатусыПакетов().Подготовлен;
	
	Результат.Тип.ТипДокумента		= ТипДокумента;
	Результат.Тип.ТипКонтента		= ТипКонтента;
	Результат.Тип.ФункцияДокумента	= ФункцияДокумента;
	Результат.Тип.Представление		= ОписаниеТипаДокумента.Title;
	Результат.Тип.Формализованный	= Списки_ОписаниеФорматаКонтента(ТипКонтента).Формализованный;
	
	Результат.Отправитель	= Пакет.Отправитель;
	Результат.Получатель	= Пакет.Получатель;
	
	ПараметрыОтправки = Контракт_ПараметрыОтправкиДокумента();
			
	Результат.СлужебнаяИнформация.Вставить("ПараметрыОтправки", ПараметрыОтправки);

	Возврат Результат;
	
КонецФункции

Процедура Документы_ПодготовитьСлужебнуюИнформациюДляОтправки(Документ)
	
	ФорматКонтента = Списки_ОписаниеФорматаКонтента(Документ.Тип.ТипКонтента);
	Контент = ГенерацияXML_ПолучитьПустуюПротоСтруктуру(ФорматКонтента.XDTO_SellerContent);
	ПараметрыГенерацииXML = Контракт_ПараметрыГенерацииXML();
	
	Документ.СлужебнаяИнформация.Вставить("Контент", Контент);
	Документ.СлужебнаяИнформация.Вставить("ПараметрыГенерацииXML", ПараметрыГенерацииXML);
	Документ.СлужебнаяИнформация.Вставить("ДокументыОснования", Новый Массив);
	
КонецПроцедуры

Функция ПредставлениеПакета(Пакет)
	
	ВидПакета = Списки_ОписаниеВидаПакета(Пакет.ИдентификаторВида);
	
