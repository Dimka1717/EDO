Функция ПодключаемыйМодуль_ОбработатьСобытие(ИмяСобытия, Параметры = Неопределено) Экспорт
	
	// При наличии ПМ с версией API <  2, вызываем только его событие.
	// Для ПМ с версией API >= 2, все события, при успешном своем выполнении, всегда должны возвращать какой-либо результат:
	// либо результат своего выполнения, либо как минимум Истина (зависит от алгоритма события).
	// Если событие возвращает Неопределено, тогда считаем, что обработчик-переопределения события в ПМ отсутствует и обращаемся к ИМ.
	// После исполнения события в ИМ, его результат пробуем опять отдать в ПМ, добавив в параметры ключ "Результат_ИМ".
	// В обработчиках событий ПМ, если требуется только обработка результата типового ИМ - используем код вида:
	//
	// Если ТипЗнч(Параметры) = Тип("Структура") И Параметры.Свойство("Результат_ИМ") Тогда
	//		//АЛГОРИТМ_ОБРАБОТКИ_РЕЗУЛЬТАТА_ИНТЕГРАЦИОННОГО_МОДУЛЯ
	//		Возврат Результат;
	// КонецЕсли;
	
	Результат = Неопределено;
	
	Если Параметры = Неопределено Тогда
		ИсходныеПараметры = Новый Структура;
	Иначе
		ИсходныеПараметры = Параметры;
	КонецЕсли;
	
	Параметры = ПодключаемыйМодуль_СовместимыеПараметры(ИмяСобытия, ИсходныеПараметры);

	ПМ = Модуль_ПМ(ЭтотОбъект);
	ИМ = Модуль_ИМ(ЭтотОбъект);
	
	Если ПМ = Неопределено И ИМ = Неопределено Тогда
		
		Результат = Неопределено;
		
	ИначеЕсли ПМ = Неопределено И ИМ <> Неопределено Тогда
		
		Результат = ИМ.ОбработатьСобытие(ИмяСобытия, Параметры);
		
	Иначе
		
		СтараяВерсияПМ = ПМ.ЭДО_ВерсияAPIПодключаемогоМодуля() < 2;
		
		Результат = ПМ.ОбработатьСобытие(ИмяСобытия, Параметры);
		
		Если НЕ СтараяВерсияПМ
			И Результат = Неопределено
			И ИМ <> Неопределено Тогда
			
			Если ТипЗнч(Параметры) = Тип("Структура") Тогда
				Параметры_ПМ = Параметры;
			Иначе // Есть событие СопоставитьНоменклатуруПоставщика, в котором параметром передается ТЗ, а не структура (легаси).
				Параметры_ПМ = Новый Структура;
				Параметры_ПМ.Вставить("ДанныеДляОбработки", Параметры);
			КонецЕсли;
			
			Результат_ИМ = ИМ.ОбработатьСобытие(ИмяСобытия, Параметры);
			
			Параметры_ПМ.Вставить("Результат_ИМ", Результат_ИМ);
			
			Результат_ПМ = ПМ.ОбработатьСобытие(ИмяСобытия, Параметры_ПМ);
			
			Результат = ?(Результат_ПМ = Неопределено, Результат_ИМ, Результат_ПМ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(ИмяСобытия, Параметры, Результат);
	
	ПодключаемыйМодуль_СконвертироватьРезультат(ИмяСобытия, Параметры, ИсходныеПараметры, Результат);
	
	Возврат Результат;
	
КонецФункции

// Реализует первый вызов функций подключаемого модуля и возвращает их результат.
//
// Параметры:
//  ИмяСобытия - Строка - идентификатор функции ПМ (см. https://developer.kontur.ru/Docs/Diadoc_UM/Functions_PM.html)
//  ПараметрыПМ - Произвольный - параметры функции ПМ
//
// Возвращаемое значение:
//  Произвольный - результат функции ПМ.
//  Неопределено - если ПМ не используется или обработчик функции отсутствует или отключен.
//
Функция ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(ИмяСобытия, ПараметрыПМ)
	
	ПМ = Модуль_ПМ(ЭтотОбъект);
	
	Если ПМ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = ПМ.ОбработатьСобытие(ИмяСобытия, ПараметрыПМ);
	
	Возврат Результат;
	
КонецФункции

// Реализует повторный вызов функции подключаемого модуля с передачей в неё дополнительного параметра
// с результатом функции интеграционного модуля. Если функция ПМ вовзвращает Неопределено, это значит,
// что ПМ не используется или обработчик функции отсутствует или отключен. В таком случае возвращается
// результат функции интеграционного модуля.
//
// Параметры:
//  ИмяСобытия - Строка - идентификатор функции ПМ (см. https://developer.kontur.ru/Docs/Diadoc_UM/Functions_PM.html)
//  ПараметрыПМ - Произвольный - параметры функции подключаемого модуля.
//  РезультатИМ - Произвольный - результат функции "коробочного" интеграционного модуля.
//
// Возвращаемое значение:
//  Произвольный - результат функции ПМ или результат функции ИМ если нет ПМ или в нем нет обработчика
//
Функция ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(ИмяСобытия, ПараметрыПМ, РезультатИМ)
	
	ПМ = Модуль_ПМ(ЭтотОбъект);
	
	Если ПМ = Неопределено Тогда
		Возврат РезультатИМ;
	КонецЕсли;
	
	ПараметрыПМ.Вставить("Результат_ИМ", РезультатИМ);
	Результат = ПМ.ОбработатьСобытие(ИмяСобытия, ПараметрыПМ);
	
	Если Результат = Неопределено Тогда
		Результат = РезультатИМ;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, нужно ли после первого выхода из ПМ вызывать функцию интеграционного модуля.
// Вызов функции ИМ и передача её результата в ПМ через параметр "Результат_ИМ"
// производится в следующих случаях:
//  * подключаемый модуль не используется
//  * Используется подключаемый модуль с версией АПИ 2 или выше, а функция ПМ вернула Неопределено
//
// Параметры:
//  РезультатПМ - Произвольный - результат первого вызова функции подключаемого модуля.
//
// Возвращаемое значение:
//  Булево - Истина, если требуется выполнить "коробочную" функцию и передать её результат в ПМ.
//
Функция ПодключаемыйМодуль_ТребуетсяВызватьИМ(РезультатПМ)
	
	ПМ_ДопустимаяВерсияАПИ = 2;
	
	ПМ = Модуль_ПМ(ЭтотОбъект);
	Если ПМ = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если РезультатПМ = Неопределено
		И ПМ.ЭДО_ВерсияAPIПодключаемогоМодуля() >= ПМ_ДопустимаяВерсияАПИ Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Обработчик события ПМ "ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме".
// Формирует вложение и заполняет мету электронного документа по внешней печатной форме.
// https://developer.kontur.ru/Docs/Diadoc_UM/func/ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме.html
//
// Параметры:
//  Документ - Структура - описание электронного документа (см. Контракт_Документ)
//  ПечатнаяФорма - СправочникСсылка.ДополнительныеОтчетыИОбработки, СправочникСсылка.ВнешниеОбработки - хранилище обработки с ВПФ
// 
Процедура Интеграция_ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме(Документ, ПечатнаяФорма)
	
	ИмяСобытия = "ПодготовитьЭлектронныйДокументПоВнешнейПечатнойФорме";
	
	ИдентификаторКоманды = ВПФ_ИдентификаторКоманды(ПечатнаяФорма);
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Документ", Документ);
	ПараметрыПМ.Вставить("ВнешняяПечатнаяФорма", ПечатнаяФорма);
	ПараметрыПМ.Вставить("ИдентификаторКоманды", ИдентификаторКоманды);
	
	РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(РезультатПМ) Тогда
		
		СсылкаНаОбъект = Документ.ДокументУчета;
		Данные = Документы_МетаданныеНеформализованногоБезопасно(СсылкаНаОбъект, Документ.Тип);
		ТабличныйДокумент = ВПФ_ПечатнаяФорма(СсылкаНаОбъект, ПечатнаяФорма);
		НазваниеДокумента = Документ.Тип.Представление;
		Если Документ.Тип.ТипДокумента = Тип_Неформализованный() Тогда
			НазваниеДокумента = ВПФ_ПредставлениеКоманды(ПечатнаяФорма);
		КонецЕсли;
		
		ИмяФайлаВложения = ФС_ИмяФайлаВложенияPDF(
			НазваниеДокумента,
			Данные.Номер,
			Данные.Дата
		);
		
		ЗаполнитьЗначенияСвойств(Документ.Реквизиты, Данные);
		Документы_ЗаполнитьМетуНеформализованного(Документ, Данные, ИмяФайлаВложения);
		Документы_ЗаполнитьВложение(Документ, ТабличныйДокумент, ИмяФайлаВложения);
		
		СлужебнаяИнформация = Документ.СлужебнаяИнформация;
		СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись = Истина;
		
		РезультатИМ = Истина;
		РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
			ИмяСобытия,
			ПараметрыПМ,
			РезультатИМ
		);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		РезультатПМ
	);
	
	Если Документ.Тип.Формализованный Тогда
		
		Документ.ИмяФайла = "";
		Документ.Метаданные.FileName = "";
		
	КонецЕсли;
	
КонецПроцедуры

// Обработчик события ПМ "ПодготовитьЭлектронныйДокумент"
//
// Параметры:
//  Документ - Структура - электронный документ (см. Контракт_Документ)
//  ПользовательСервиса - Структура - информация о пользователе Диадока (см. Контракт_ОписаниеПользователя)
//  ДополнительныеПараметры - Структура, Неопределено - Дополнительные параметры, определенные в событии ПодготовитьПакет
//
Процедура Интеграция_ПодготовитьЭлектронныйДокумент(Документ, ПользовательСервиса, ДополнительныеПараметры)
	
	ДанныеСотрудника = Новый Структура;
	ДанныеСотрудника.Вставить("Id", ПользовательСервиса.Id);
	ДанныеСотрудника.Вставить("ФИО", ПользовательСервиса.ФИО);
	ДанныеСотрудника.Вставить("Фамилия", ПользовательСервиса.Фамилия);
	ДанныеСотрудника.Вставить("Имя", ПользовательСервиса.Имя);
	ДанныеСотрудника.Вставить("Отчество", ПользовательСервиса.Отчество);
	ДанныеСотрудника.Вставить("Должность", ПользовательСервиса.Должность);
	ДанныеСотрудника.Вставить("ИННСертификата", ПользовательСервиса.ИННСертификата);
	ДанныеСотрудника = ФиксированныеДанные(ДанныеСотрудника);
	
	Если УПД970_ИспользоватьРежимСовместимостиФорматов(Документ.Тип.ТипКонтента) Тогда
		УПД970_ПодготовитьЭлектронныйДокументВРежимеСовместимости(Документ, ДанныеСотрудника, ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	ИмяСобытия = "ПодготовитьЭлектронныйДокумент";
	
	ДокументУстаревший = ПодключаемыйМодуль_УстаревшийДокумент(Документ);
