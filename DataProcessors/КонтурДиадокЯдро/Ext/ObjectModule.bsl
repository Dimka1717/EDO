Функция ВПФ_ИдентификаторКоманды(ПечатнаяФорма)
	
	Результат = Неопределено;
	
	ОбъектМетаданных = ПечатнаяФорма.Метаданные();
	ТабличнаяЧастьКоманды = ОбъектМетаданных.ТабличныеЧасти.Найти("Команды");
	
	Если ТабличнаяЧастьКоманды <> Неопределено
		И Общее_ЕстьРеквизитМетаданных(ТабличнаяЧастьКоманды, "Идентификатор") Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ВсеКоманды.НомерСтроки КАК НомерСтроки,
		|	ВсеКоманды.Идентификатор КАК Идентификатор
		|ИЗ
		|	&ПолноеИмяТаблицы КАК ВсеКоманды
		|ГДЕ
		|	ВсеКоманды.Ссылка = &ПечатнаяФорма
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|";
		
		ТекстЗапроса = СтрЗаменить(
			ТекстЗапроса,
			"&ПолноеИмяТаблицы",
			ОбъектМетаданных.ПолноеИмя() + ".Команды"
		);
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("ПечатнаяФорма", ПечатнаяФорма);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			Результат = Выборка.Идентификатор;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВПФ_ПредставлениеКоманды(ПечатнаяФорма)
	
	Результат = Неопределено;
	
	ОбъектМетаданных = ПечатнаяФорма.Метаданные();
	ТабличнаяЧастьКоманды = ОбъектМетаданных.ТабличныеЧасти.Найти("Команды");
	
	Если ТабличнаяЧастьКоманды <> Неопределено
		И Общее_ЕстьРеквизитМетаданных(ТабличнаяЧастьКоманды, "Представление") Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ВсеКоманды.НомерСтроки КАК НомерСтроки,
		|	ВсеКоманды.Представление КАК Представление
		|ИЗ
		|	&ПолноеИмяТаблицы КАК ВсеКоманды
		|ГДЕ
		|	ВсеКоманды.Ссылка = &ПечатнаяФорма
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|";
		
		ТекстЗапроса = СтрЗаменить(
			ТекстЗапроса,
			"&ПолноеИмяТаблицы",
			ОбъектМетаданных.ПолноеИмя() + ".Команды"
		);
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("ПечатнаяФорма", ПечатнаяФорма);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			Результат = Выборка.Представление;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Результат = СокрЛП(ПечатнаяФорма.Наименование);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВПФ_ПечатнаяФорма(СсылкаНаОбъект, ПечатнаяФорма)
	
	ИдентификаторКоманды = ВПФ_ИдентификаторКоманды(ПечатнаяФорма);
	ОбъектыНазначения = Новый Массив;
	ОбъектыНазначения.Добавить(СсылкаНаОбъект);
	
	ПараметрыИсточника = Новый Структура;
	ПараметрыИсточника.Вставить("ИдентификаторКоманды", ИдентификаторКоманды);
	ПараметрыИсточника.Вставить("ОбъектыНазначения", ОбъектыНазначения);
	
	// Возвращаемые параметры типового метода
	РезультатПечати = Неопределено;
	ОбъектыПечати = Новый СписокЗначений;
	ПараметрыВывода = Неопределено;
	
	МодульДополнительныеОтчетыИОбработки = Вычислить("ДополнительныеОтчетыИОбработки");
	МодульДополнительныеОтчетыИОбработки.ПечатьПоВнешнемуИсточнику(
		ПечатнаяФорма,
		ПараметрыИсточника,
		РезультатПечати,
		ОбъектыПечати,
		ПараметрыВывода
	);
	
	Если Не ЗначениеЗаполнено(РезультатПечати) Тогда
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"Не удалось сформировать внешнюю печатную форму!
			|Объект = %1
			|Печатная форма = %2
			|Команда = %3",
			Строка(СсылкаНаОбъект),
			Строка(ПечатнаяФорма),
			ИдентификаторКоманды
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	ОписаниеПечатнойФормы = РезультатПечати[0];
	
	Результат = ОписаниеПечатнойФормы.ТабличныйДокумент;
	
	Возврат Результат;
	
КонецФункции

// Формирует имя файла в формате PDF по его названию, номеру и дате.
// При этом в имени файла символы, не поддерживаемые файловой системой,
// заменяются на "_"
//
// Параметры:
//  ИмяДокумента - Строка - название документа
//  НомерДокумента - Строка - номер документа
//  ДатаДокумента - Дата - дата документа
// 
// Возвращаемое значение:
//  Строка - имя файла вида "<Название> № <Номер> от <Дата>.pdf"
//
Функция ФС_ИмяФайлаВложенияPDF(Знач ИмяДокумента, Знач НомерДокумента, Знач ДатаДокумента)
	
	ЧастиИмени = Новый Массив;
	ЧастиИмени.Добавить(ИмяДокумента);
	
	Если ЗначениеЗаполнено(НомерДокумента) Тогда
		ЧастиИмени.Добавить(" №");
		ЧастиИмени.Добавить(НомерДокумента);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаСтрокой = Формат(ДатаДокумента, "ДФ=dd.MM.yyyy");
		ЧастиИмени.Добавить(" от ");
		ЧастиИмени.Добавить(ДатаСтрокой);
	КонецЕсли;
	
	ЧастиИмени.Добавить(".pdf");
	
	ИмяФайла = СоединитьСтроку(ЧастиИмени, "");
	
	Результат = ФС_ЗаменитьНедопустимыеСимволыВПути(ИмяФайла);
	
	Возврат Результат;
	
КонецФункции

// Заменяет символы, которые не допускаются в путях файловой системы, на "_"
//
// Параметры:
//  ИсходнаяСтрока - Строка - любая строка
// 
// Возвращаемое значение:
//  Строка.
//
Функция ФС_ЗаменитьНедопустимыеСимволыВПути(Знач Путь)
	
	Результат = Путь;
	
	НедопустимыеЗнаки = """/\[]:;|=?*<>";
	НедопустимыеЗнаки = НедопустимыеЗнаки + Символы.Таб + Символы.ПС;
	
	Пока СтрДлина(НедопустимыеЗнаки) > 0 Цикл
		
		ТекСимвол = Лев(НедопустимыеЗнаки, 1);
		Если Найти(Результат, ТекСимвол) <> 0 Тогда
			Результат = СтрЗаменить(Результат, ТекСимвол, "_");
		КонецЕсли;
		НедопустимыеЗнаки = Сред(НедопустимыеЗнаки, 2);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


