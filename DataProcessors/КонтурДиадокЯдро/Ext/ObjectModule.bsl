	|</div>";
	// BSLLS:LineLength-on
	
	HTMLШаблоны.Вставить("ТаблицаСтилей"		, ТаблицаСтилей);
	HTMLШаблоны.Вставить("КнопкиТехПоддрежки"	, КнопкиТехПоддрежки);
	
КонецПроцедуры

Функция ПараметрыОповещенияИзСтрокиHTMLСообщения(СтрокаОповещения) Экспорт
	
	ПозПрефикса		 = Найти(НРег(СтрокаОповещения), НРег("alert:"));
	ДлинаПрефикса	 = СтрДлина("alert:");
	
	Если ПозПрефикса = 0 Тогда
		ПозПрефикса		 = Найти(НРег(СтрокаОповещения), НРег("alertandclose:"));
		ДлинаПрефикса	 = СтрДлина("alertandclose:");
	КонецЕсли;
	
	СтрокаОповещенияБезПрефикса = Сред(СтрокаОповещения, ПозПрефикса + ДлинаПрефикса);
	
	ЧастиСтроки = РазделитьСтрокуЛок(СтрокаОповещенияБезПрефикса, "?");
	
	ОбработчикОповещения = ЧастиСтроки[0];
	ЧастиСтроки.Удалить(0);
	
	Если ЗначениеЗаполнено(ЧастиСтроки) Тогда
		РезультатОповещения = СоединитьСтроку(ЧастиСтроки, "?");
	Иначе
		РезультатОповещения = Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ОбработчикОповещения",	ОбработчикОповещения);
	Результат.Вставить("РезультатОповещения",	РезультатОповещения);
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыОповещенияВСтрокуHTMLСообщения(ОбработчикОповещения, РезультатОповещения = Неопределено, ЗакрыватьФормуСообщения = Ложь) Экспорт
	
	Если ЗакрыватьФормуСообщения Тогда
		Результат = "alertandclose:";
	Иначе
		Результат = "alert:";
	КонецЕсли;
	
	Результат = Результат + ОбработчикОповещения;
	
	Если РезультатОповещения <> Неопределено Тогда
		Результат = Результат + "?" + РезультатОповещения;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РеквизитыОрганизацииИзКонтекста(BoxId) Экспорт
	
	Результат = Новый Структура;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	
	Результат.Вставить("Наименование",	СтрокаКонтекста.ОрганизацияНаименование);
	Результат.Вставить("ИНН",			СтрокаКонтекста.ИНН);
	Результат.Вставить("КПП",			СтрокаКонтекста.КПП);
	Результат.Вставить("BoxId",			СтрокаКонтекста.BoxId);
	
	Возврат Результат;
	
КонецФункции

// Формирует текстовое представление технической информации в формате Markdown.
//
// Параметры:
//  ТехИнфо - ФиксированнаяСтруктура - см. ТехническаяИнформацияV2
// 
// Возвращаемое значение:
//  Строка - текстовое представление технической информации.
//
Функция ТехническаяИнформацияКакТекст(ТехИнфо) Экспорт
	
	ПустаяСтрока = "";
	
	Текст = Новый ТекстовыйДокумент;
	
	Текст.ДобавитьСтроку("# Техническая информация");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	Мета = ТехИнфо.Мета;
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Мета);
	
	Текст.ДобавитьСтроку("## Информационная база");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	Данные = ТехИнфо.ИнформационнаяБаза;
	
	Текст.ДобавитьСтроку("### Конфигурация информационной базы");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Конфигурация);
	
	Текст.ДобавитьСтроку("### Свойства информационной базы");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Свойства);
	
	Текст.ДобавитьСтроку("## Конфигурация модуля");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	Данные = ТехИнфо.КонфигурацияМодуля;
	
	Текст.ДобавитьСтроку("### Сборка");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Сборка);
	
	Текст.ДобавитьСтроку("### Пользовательский интеграционный модуль");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ПодключаемыйМодуль);
	
	Текст.ДобавитьСтроку("### Пользовательский интеграционный модуль (для Стандарта)");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ПодключаемыйМодульСтандарт);
	
	Текст.ДобавитьСтроку("### Общие настройки");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Настройки);
	
	Текст.ДобавитьСтроку("### Плагины");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Плагины);
	
	Текст.ДобавитьСтроку("### Функциональные опции");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	
	Если ЗначениеЗаполнено(Данные.ФункциональныеОпции) Тогда
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ФункциональныеОпции);
	Иначе
		Текст.ДобавитьСтроку("Нет данных");
		Текст.ДобавитьСтроку(ПустаяСтрока);
	КонецЕсли;
	
	Текст.ДобавитьСтроку("### OAuth-клиент");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.OAuthКлиент);
	
	Если Данные.Свойство("КонфигурационныйФайл")
		И ЗначениеЗаполнено(Данные.КонфигурационныйФайл) Тогда
		
		Текст.ДобавитьСтроку("### Конфигурационный файл");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.КонфигурационныйФайл);
		
	КонецЕсли;
	
	Текст.ДобавитьСтроку("## Интеграции");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	Данные = ТехИнфо.Интеграции;
	
	Текст.ДобавитьСтроку("### Интеграция с сервисом Контур.Маркировка");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ИнтеграцияКонтурМаркировка);

	Текст.ДобавитьСтроку("### Интеграция с сервисом Контур.Логистика");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ИнтеграцияКонтурЛогистика);
	
	Текст.ДобавитьСтроку("### Интеграция с сервисом Контур.Интеграция");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.ИнтеграцияКонтурИнтеграция);
	
	Текст.ДобавитьСтроку("## Системная информация");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	Данные = ТехИнфо.СистемнаяИнформация;
	
	Текст.ДобавитьСтроку("### Серверный контекст");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.НаСервере);
	
	Если Данные.Свойство("НаКлиенте")
		И ЗначениеЗаполнено(Данные.НаКлиенте) Тогда
		
		Текст.ДобавитьСтроку("### Клиентский контекст");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.НаКлиенте);
		
	КонецЕсли;
	
	Текст.ДобавитьСтроку("## Контекст сеанса");
	Текст.ДобавитьСтроку(ПустаяСтрока);
	
	Если ТехИнфо.Свойство("КонтекстСеанса")
		И ЗначениеЗаполнено(ТехИнфо.КонтекстСеанса) Тогда
		
		Данные = ТехИнфо.КонтекстСеанса;
		
		Текст.ДобавитьСтроку("### Ящик");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Ящик);
		
		Текст.ДобавитьСтроку("### Аутентификация");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Аутентификация);
		
		Текст.ДобавитьСтроку("### Сертификат");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Сертификат);
		
		Текст.ДобавитьСтроку("### Биллинг");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Биллинг);
		
		Текст.ДобавитьСтроку("### Настройки организации");
		Текст.ДобавитьСтроку(ПустаяСтрока);
		ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные.Настройки);
		
	Иначе
		Текст.ДобавитьСтроку("Нет данных");
		Текст.ДобавитьСтроку(ПустаяСтрока);
	КонецЕсли;
	
	Результат = Текст.ПолучитьТекст();
	
	Возврат Результат;
	
КонецФункции

Процедура ТехническаяИнформацияСлужебный_ДополнитьТекст(Текст, Данные)
	
	Для Каждого КлючИЗначение Из Данные Цикл
		
		Ключ = КлючИЗначение.Ключ;
		Значение = КлючИЗначение.Значение;
		
		Если ЭтоМассив(Значение) Тогда
			
			Если ЗначениеЗаполнено(Значение) Тогда
				
				Текст.ДобавитьСтроку(Ключ + ":");
				
				Для Каждого Элемент Из Значение Цикл
					Строка = Общее_ПодставитьПараметрыВСтроку("- %1", Элемент);
					Текст.ДобавитьСтроку(Строка);
				КонецЦикла;
				
			Иначе
				
				Строка = Общее_ПодставитьПараметрыВСтроку("%1: Нет данных", Ключ);
				Текст.ДобавитьСтроку(Строка);
				
			КонецЕсли;
			
		Иначе
			
			Строка = Общее_ПодставитьПараметрыВСтроку("%1: %2", Ключ, Значение);
			Текст.ДобавитьСтроку(Строка);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Текст.ДобавитьСтроку("");
	
КонецПроцедуры

// Собирает информацию для технической поддержки.
//
// Параметры:
//  BoxId - Строка - (Необязательный) адрес или идентификатор ящика
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - содержит ключи:
//   * ИнформационнаяБаза - ФиксированнаяСтруктура - описание информационной базы:
//      ** Конфигурация - ФиксированнаяСтруктура - см. ТехИнфо_КонфигурацияИБ
//      ** Свойства - ФиксированнаяСтруктура - см. ТехИнфо_СвойстваИБ
//   * КонфигурацияМодуля - ФиксированнаяСтруктура - сведения о сборке и настройках:
//      ** Сборка - ФиксированнаяСтруктура - см. ТехИнфо_СборкаМодуля
//      ** ПодключаемыйМодуль - ФиксированнаяСтруктура - см. ТехИнфо_ПодключаемыйМодульУМ
//      ** ПодключаемыйМодульСтандарт - ФиксированнаяСтруктура - см. ТехИнфо_ПодключаемыйМодульСтандарт
//      ** Настройки - ФиксированнаяСтруктура - см. ТехИнфо_ОбщиеНастройки
//      ** Плагины - ФиксированнаяСтруктура - см. ТехИнфо_Плагины
//      ** ИнтеграцияКонтурМаркировка - ФиксированнаяСтруктура - см. ТехИнфо_ИнтеграцияКМ
//      ** ФункциональныеОпции - ФиксированноеСоответствие - см. ФункциональныеОпции_Получить
//      ** КонфигурационныйФайл - ФиксированноеСоответствие - см. КонфигурационныйФайл_ЗначенияПараметров
//   * СистемнаяИнформация - ФиксированнаяСтруктура - системная информация клиентского и серверного контекста:
//      ** НаСервере - ФиксированнаяСтруктура - В режиме "Толстый клиент (обычное приложение)" содержит
//                                              сведения о клиентской машине (см. ТехИнфо_СистемнаяИнформация)
//      ** НаКлиенте - ФиксированнаяСтруктура - (Необязательный) В режиме "Толстый клиент (обычное приложение)"
//                                              не заполняется (см. Ядро.КлиентскиеВызовы.СистемнаяИнформацияНаКлиенте)
//   * КонтекстЯщика - ФиксированнаяСтруктура - (Необязательный) Сведения о сеансе в контексте ящика Диадока.
//                                              Не формируется, если ящик не указан или его нет в контексте сеанса.
//      ** Ящик - ФиксированнаяСтруктура - см. ТехИнфо_Ящик
//      ** Аутентификация - ФиксированнаяСтруктура - см. ТехИнфо_Аутентификация
//      ** Сертификат - ФиксированнаяСтруктура - см. ТехИнфо_Сертификат
//      ** Биллинг - ФиксированнаяСтруктура - см. ТехИнфо_Биллинг
//      ** Настройки - ФиксированнаяСтруктура - см. ТехИнфо_НастройкиОрганизации
//
Функция ТехническаяИнформацияV2(Знач BoxId = "") Экспорт
	
	НастройкиУМ = ХранениеДанных_ОбщиеНастройки();
	НастройкиСтандарт = ХранениеДанных_НастройкиМодуляСтандарт();
	
	Данные = Новый Структура;
	
	Данные.Вставить("Мета", ТехИнфо_Мета());
	
	Данные.Вставить("ИнформационнаяБаза", Новый Структура);
	Данные.ИнформационнаяБаза.Вставить("Конфигурация", ТехИнфо_КонфигурацияИБ());
	Данные.ИнформационнаяБаза.Вставить("Свойства", ТехИнфо_СвойстваИБ());
	
	Данные.Вставить("КонфигурацияМодуля", Новый Структура);
	Данные.КонфигурацияМодуля.Вставить("Сборка", ТехИнфо_СборкаМодуля(НастройкиУМ));
	Данные.КонфигурацияМодуля.Вставить("ПодключаемыйМодуль", ТехИнфо_ПодключаемыйМодуль(НастройкиУМ));
	Данные.КонфигурацияМодуля.Вставить("ПодключаемыйМодульСтандарт", ТехИнфо_ПодключаемыйМодуль(НастройкиСтандарт));
	Данные.КонфигурацияМодуля.Вставить("Настройки", ТехИнфо_ОбщиеНастройки(НастройкиУМ, НастройкиСтандарт));
	Данные.КонфигурацияМодуля.Вставить("Плагины", ТехИнфо_Плагины());
	Данные.КонфигурацияМодуля.Вставить("ФункциональныеОпции", ОбщийКонтекст_Прочитать("ФункциональныеОпции"));
	Данные.КонфигурацияМодуля.Вставить("КонфигурационныйФайл", КонфигурационныйФайл_ЗначенияПараметров());
	Данные.КонфигурацияМодуля.Вставить("OAuthКлиент", ТехИнфо_АутхКонфигурацияПриложения());
	
	Данные.Вставить("Интеграции", Новый Структура);
	Данные.Интеграции.Вставить("ИнтеграцияКонтурМаркировка",
		ТехИнфо_ИнтеграцияКонтурМаркировка(НастройкиУМ.ИспользоватьСервисКонтурМаркировка));
	Данные.Интеграции.Вставить("ИнтеграцияКонтурЛогистика", ТехИнфо_ИнтеграцияКонтурЛогистика());
	Данные.Интеграции.Вставить("ИнтеграцияКонтурИнтеграция", ТехИнфо_ИнтеграцияКонтурИнтеграция());
	
	Данные.Вставить("СистемнаяИнформация", Новый Структура);
	Данные.СистемнаяИнформация.Вставить("НаСервере", ТехИнфо_СистемнаяИнформация());
	Данные.СистемнаяИнформация.Вставить("НаКлиенте", ОбщийКонтекст_Прочитать("СисИнфоНаКлиенте"));
	
	КонтекстСеанса = КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	Если ЗначениеЗаполнено(КонтекстСеанса) Тогда
		
		Данные.Вставить("КонтекстСеанса", Новый Структура);
		Данные.КонтекстСеанса.Вставить("Ящик", ТехИнфо_Ящик(КонтекстСеанса.Ящик));
		Данные.КонтекстСеанса.Вставить("Аутентификация", ТехИнфо_Аутентификация(КонтекстСеанса.Сессия));
		Данные.КонтекстСеанса.Вставить("Сертификат", ТехИнфо_Сертификат(КонтекстСеанса.Сертификат));
		Данные.КонтекстСеанса.Вставить("Биллинг", ТехИнфо_Биллинг(КонтекстСеанса));
		Данные.КонтекстСеанса.Вставить("Настройки", ТехИнфо_НастройкиОрганизации(BoxId));
		
	КонецЕсли;
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

Функция ТехИнфо_Мета()
	
	ДатаФормирования = УниверсальнаяДата(ТекущаяДатаСеанса());
	ДатаФормированияСтрокой = Формат(ДатаФормирования, "ДФ=dd.MM.yyyy HH.mm.ss");
	
	Результат = Новый Структура;
	Результат.Вставить("ДатаФормирования", ДатаФормированияСтрокой);
	
	Возврат Результат;
	
КонецФункции

Функция ТехИнфо_Ящик(Ящик)
	
	Результат = Новый Структура;
	Результат.Вставить("Идентификатор", ПустойУникальныйИдентификатор());
	Результат.Вставить("Адрес", ТехИнфо_НеопределенноеЗначение());
	Результат.Вставить("Наименование", ТехИнфо_НеопределенноеЗначение());
	Результат.Вставить("ИННКПП", ТехИнфо_НеопределенноеЗначение());
	
	Если ЗначениеЗаполнено(Ящик) Тогда
		
		Результат.Идентификатор = Новый УникальныйИдентификатор(Ящик.Идентификатор);
		Результат.Адрес = Ящик.Адрес;
		Результат.Наименование = Ящик.Наименование;
		Результат.ИННКПП = Ящик.Организация.ИНН;
		
		Если ЗначениеЗаполнено(Ящик.Организация.КПП) Тогда
			Результат.ИННКПП = Результат.ИННКПП + "-" + Ящик.Организация.КПП;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТехИнфо_Аутентификация(Сессия)
	
	Результат = Новый Структура;
	Результат.Вставить("ПользовательИдентификатор", ПустойУникальныйИдентификатор());
	Результат.Вставить("ПользовательПредставление", ТехИнфо_НеопределенноеЗначение());
	Результат.Вставить("СхемаАутентификации", ТехИнфо_НеопределенноеЗначение());
	Результат.Вставить("ТокенДоступаСрокДействия", '00010101');
	
	Если ЗначениеЗаполнено(Сессия) Тогда
		Результат.ПользовательИдентификатор = Новый УникальныйИдентификатор(Сессия.Пользователь.Идентификатор);
		Результат.ПользовательПредставление = Сессия.Пользователь.Представление;
		Результат.ТокенДоступаСрокДействия = Сессия.УниверсальнаяДатаОкончания;
		Результат.СхемаАутентификации = Сессия.СхемаАутентификации;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТехИнфо_Сертификат(Сертификат)
	
	Результат = Новый Структура;
	Результат.Вставить("Отпечаток", ТехИнфо_НеопределенноеЗначение());
	Результат.Вставить("СубъектНаименование", ТехИнфо_НеопределенноеЗначение()); // Кому выдан
	Результат.Вставить("ПодписьТип", ТехИнфо_НеопределенноеЗначение()); // КЭП/НЭП
	Результат.Вставить("ВладелецТип", ТехИнфо_НеопределенноеЗначение()); // ЮЛ/ИП/ФЛ
	Результат.Вставить("ДатаВыдачи", '00010101');
	Результат.Вставить("СрокДействия", '00010101');
	
	Если ЗначениеЗаполнено(Сертификат) Тогда
		Результат.Отпечаток = Сертификат.ОтпечатокСертификата;
		Результат.СубъектНаименование = Сертификат.Наименование;
		Результат.ПодписьТип = ?(Сертификат.ЭтоКЭП, "КЭП", "НЭП");
		Результат.ВладелецТип = Сертификат.Тип;
		Результат.ДатаВыдачи = Сертификат.ДатаВыдачи;
		Результат.СрокДействия = Сертификат.СрокДействия;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

