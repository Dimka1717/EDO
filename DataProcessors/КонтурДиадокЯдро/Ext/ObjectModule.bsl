// Проверяет доступность сервиса Диадок API.
//
// Параметры:
//  НастройкиПрокси  - Структура - см. метод "АПИ_Новый_НастройкиПрокси". Если Неопределено, то настройки прокси будут взяты из ИБ.
//  ТекстОшибки		 - Строка 	 - текст ошибки, возвращаемой в вызывающий метод, возникающей в случае исключительной ситуации при выполнении программы.
// 
// Возвращаемое значение:
//  Булево 	- результат проверки соединения. Истина - сервис Диадок API доступен.
//
Функция АПИ_ПроверитьСоединениеDiadocAPI(НастройкиПрокси = Неопределено, ТекстОшибки = "") Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	ПараметрыСервиса.ИспользоватьНовоеСоединение = Истина;
	
	Если ЗначениеЗаполнено(НастройкиПрокси) Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыСервиса.НастройкиПрокси, НастройкиПрокси);
	КонецЕсли;
	
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Попытка
		
		Ответ = Модуль_МетодыAPI.ПроверитьСоединение(ПараметрыСервиса);
		Результат = Истина;
		
	Исключение
		
		Результат = Ложь;
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат Результат;
	
