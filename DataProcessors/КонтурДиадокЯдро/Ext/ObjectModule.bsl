// Возвращает подключенные в сервисе доп. функции у организации
//
// Параметры:
//  boxId - Строка - идентификатор ящика организации в сервисе
// 
// Возвращаемое значение:
//  Структура
//
Функция КонтекстСеанса_ДополнительныеФункцииЯщика(ПараметрыСервиса, boxId)
	
	Результат = Контракт_ДополнительныеФункцииЯщика();
	
	Ответ		= АПИ_GetOrganizationFeatures(ПараметрыСервиса, boxId);
	Features	= Ответ.Features;
	
	Результат.РазрешеноШифрование = (Features.Найти("AllowSendEncryptedDocuments") <> Неопределено);
	Результат.РазрешенаСогласующаяПодпись = (Features.Найти("AllowApprovementSignature") <> Неопределено);
	Результат.РазрешенаПересылкаТретьейСтороне = (Features.Найти("AllowDocumentsForwarding") <> Неопределено);
	Результат.РазрешенаОтправкаЧерезПромежуточногоПолучателя = (Features.Найти("AllowProxifiedDocuments") <> Неопределено);
	Результат.РазрешенаОтправкаЗаблокированныхПакетов = (Features.Найти("AllowSendLockedPackets") <> Неопределено);
	Результат.ВыводитьНаименованиеТовараСКодами = (Features.Найти("EnableProductNameAlongWithCodes") <> Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция КонтекстСеанса_ТребуетсяМЧД(ОписаниеСертификата, ИНН)
	
	Результат = Ложь;
	
	Если ОписаниеСертификата.ЭтоКЭП Тогда
		Результат = (ИНН <> ОписаниеСертификата.ИНН);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет в сервисе Диадок регистрацию ФНС для сертификата.
// Если требуется, то отправляет заявление на регистрацию сертификата в ФНС.
//
// Параметры:
//  ПараметрыСервиса - Структура		- см. функцию ПараметрыСервиса_Диадок();
//  BoxId			 - Строка			- Идентификатор ящика организации
//  СертификатBase64 - ДвоичныеДанные	- двоичные данные сертификата;
//
Функция Сертификаты_ЕстьРегистрацияФНС(ПараметрыСервиса, BoxId, СертификатBase64)
	
	Результат = АПИ_ПроверитьРегистрациюСертификатаВФНСЧерезДиадок(ПараметрыСервиса, BoxId, СертификатBase64);
	
	Если НЕ Результат Тогда
		
		АПИ_SendFnsRegistrationMessage(ПараметрыСервиса, BoxId, СертификатBase64);
		
		Результат = АПИ_ПроверитьРегистрациюСертификатаВФНСЧерезДиадок(ПараметрыСервиса, BoxId, СертификатBase64);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

