//    * ОписаниеОшибки - Строка - текст ошибки создания объекта
//
Функция Интеграция_ПолучитьЗаполненныйОбъектДокумента1С(Документ, ИдентификаторОперации, ДополнительныеПараметры)
	
	ИмяСобытия = "ПолучитьЗаполненныйОбъектДокумента1С";
	
