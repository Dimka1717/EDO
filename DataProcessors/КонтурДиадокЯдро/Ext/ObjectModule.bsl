// Возвращает коллекцию с информацией о роуминговых операторах
//
// Параметры:
//	BoxId - Строка - идентификатор организации в Диадок
//
// Возвращаемое значение:
//	Соответсвие 
//   * Ключ        - Строка - FnsId оператора в нижнем регистре;
//   * Значение    - Структура - см Новый_ИнформацияОбОператореРоуминга() 
Функция Роуминг_ИнформацияОбОператорахЭДО(BoxId)
	
	Ключ = "Роуминг_ИнформацияОбОператорахЭДО";
	
	Результат = Кэш_Прочитать(Ключ);
	
	Если Результат = Неопределено Тогда
	
		Результат = Новый Соответствие;
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
		
		СписокОператоровЭДО = АПИ_GetRoamingOperators(ПараметрыСервиса, BoxId);
		
		Для Каждого ЭлементКоллекции Из СписокОператоровЭДО Цикл
			
			ИнформацияОбОператоре = Новый_ИнформацияОбОператореРоуминга();
			
			ИнформацияОбОператоре.Идентификатор 		= ЭлементКоллекции.FnsId;
			ИнформацияОбОператоре.Наименование			= ЭлементКоллекции.Name;
			ИнформацияОбОператоре.ПризнакДоступности	= ЭлементКоллекции.IsActive;
			
			ПоддерживаетМЧД = МассивСтруктур_Найти(ЭлементКоллекции.Features, "SupportsPowerOfAttorney", "Name") <> Неопределено;
			ИнформацияОбОператоре.ПоддерживаетМЧД = ПоддерживаетМЧД;
			
			Результат.Вставить(нРег(ИнформацияОбОператоре.Идентификатор), ИнформацияОбОператоре);
			
		КонецЦикла;
		
		Кэш_Поместить(Ключ, Результат);
	
	КонецЕсли;
	
	Возврат Результат; 
	
КонецФункции

Функция Новый_ИнформацияОбОператореРоуминга()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор"		, "");
	Результат.Вставить("Наименование"		, "");
	Результат.Вставить("ПризнакДоступности"	, Истина);
	Результат.Вставить("ПоддерживаетМЧД"	, Истина);
	
	Возврат Результат;
	
КонецФункции

// Проверяет, является участник документооборота (ДО) роуминговым
//
// Параметры:
//  УчастникДО	 - Структура - см. функцию Контракт_УчастникДокументооборота()
// 
// Возвращаемое значение:
//  Булево - Истина - участник ДО роуминговый
//			 Ложь - участник ДО локальный
//
Функция УчастникДокументооборотаВРоуминге(УчастникДО)
	
	Результат = ЭтоРоуминговыйИдентификаторУчастникаЭДО(УчастникДО.FNSParticipantId);
	
	Возврат Результат;
	
КонецФункции

// Проверяет идентификатор на принадлженость к роумингу
//
// Параметры:
//  Идентификатор	 - Строка - идентификатор который нужно проверить на принадлженость к роумингу
// 
// Возвращаемое значение:
//  Булево - Истина - Идентификатор роуминговый
//			 Ложь - Идентификатор локальный
//
Функция ЭтоРоуминговыйИдентификаторУчастникаЭДО(Идентификатор)
	
	ИдентификаторОператораКонтур = ИдентификаторОператораКонтур();
	
	Результат = Лев(Идентификатор, 3) <> ИдентификаторОператораКонтур;
	
	Возврат Результат;
	
КонецФункции

// Проверяет что оператор поддерживает МЧД
//
// Параметры:
//  BoxID			 - Строка - идентификатор организии, используется для проверки подписки АПИ
//  ИдентификаторФНС - Строка - идентификатор оператора, FNSParticipantId
//
// Возвращаемое значение:
//   Булево - Истина, если оператор поддерживает отправку МЧД
//
Функция МЧД_ОператорЭДОПоддерживаетДоверенности(BoxID, ИдентификаторУчастникаЭДО)Экспорт
	
	Результат = Истина;
	
	Если ЭтоРоуминговыйИдентификаторУчастникаЭДО(ИдентификаторУчастникаЭДО) Тогда
	
		ИнформацияОбОператораторах = Роуминг_ИнформацияОбОператорахЭДО(BoxID);
		ИдентификаторФНС = ИдентификаторФНСИзИдентификаторУчастникаЭДО(ИдентификаторУчастникаЭДО);
		
		ОписаниеОператора = ИнформацияОбОператораторах.Получить(нРег(ИдентификаторФНС));
		Если ОписаниеОператора <> Неопределено Тогда
			Результат = ОписаниеОператора.ПоддерживаетМЧД;
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеОператораЭДО(ИдентификаторФНС, BoxID) Экспорт
	
	ИдентификаторФНС_Контура = ИдентификаторОператораКонтур();
	
	Если НРег(ИдентификаторФНС) = НРег(ИдентификаторФНС_Контура) Тогда
		Результат = ПредставлениеОператораКонтур();
	Иначе
		Результат = ПредставлениеРоуминговогоОператора(ИдентификаторФНС, BoxID);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеОператораКонтур()
	
	Результат = "СКБ ""Контур""";
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеРоуминговогоОператора(ИдентификаторФНС, BoxID)
	
	ИнформацияОбОператораторах = Роуминг_ИнформацияОбОператорахЭДО(BoxID);
	
	ИнформацияОбОператоре = ИнформацияОбОператораторах.Получить(нРег(ИдентификаторФНС));
	
	Если ЗначениеЗаполнено(ИнформацияОбОператоре) Тогда
		Результат = ИнформацияОбОператоре.Наименование;
	Иначе
		Результат = "Неизвестный оператор";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

