// Возвращает доступные типы всех предложений
//
// Параметры:
//  ПредложенияДляВсехЛицевыхСчетов	 - Массив - коллекция предложений
// 
// Возвращаемое значение:
//   - Структура - структура с ключами типов предложений 
//
Функция ЛичныйКабинет_ДоступныеТипыПредложений(ПредложенияДляВсехЛицевыхСчетов) Экспорт
	
	Результат = Новый Структура;
	
	Для Каждого КлючЗначение Из ЛичныйКабинет_ТипыПредложений() Цикл
		
		Результат.Вставить(КлючЗначение.Значение, Ложь);
		
	КонецЦикла;
	
	ДанныеПредложений = ЛичныйКабинет_ДанныеПредложений(ПредложенияДляВсехЛицевыхСчетов);
	
	Для Каждого ТекущееПредложение Из ДанныеПредложений Цикл
		
		Результат.Вставить(ТекущееПредложение.ТипПредложения, Истина);
			
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает для Личного кабинета данные предложений и активных подписок  по текущему контексту
// 
// Возвращаемое значение:
//   - Массив - содержит коллекцию структур Контракт_ДанныеЛичногоКабинета()
//
Функция ЛичныйКабинет_ДанныеПредложенийИПодписок() Экспорт
	
	ПредложенияДляВсехЛицевыхСчетов = ПредложенияДляПокупки_ПредложенияДляВсехЛицевыхСчетов();
	
	Результат = ЛичныйКабинет_ДанныеПредложений(ПредложенияДляВсехЛицевыхСчетов);
	
	АктивныеПодпискиДляВсехЛицевыхСчетов = КонтурШлюзАвторизации_АктивныеПодпискиДляВсехЛицевыхСчетов();
	ДанныеПодписок = ЛичныйКабинет_ДанныеАктивныхПодписок(АктивныеПодпискиДляВсехЛицевыхСчетов);
	
	ДополнитьМассив(Результат, ДанныеПодписок);
	
	КлючиСортировки = Новый Массив;
	КлючиСортировки.Добавить("ОрганизацияНаименование");
	КлючиСортировки.Добавить("BoxId");
	КлючиСортировки.Добавить("ЭтоРекомендация");
	КлючиСортировки.Добавить("ЭтоПредложение Убыв");
	КлючиСортировки.Добавить("Приоритет");
	КлючиСортировки.Добавить("ДатаНачала");
	КлючиСортировки.Добавить("ДатаОкончания");
	
	СтрокаСортировки = СоединитьСтроку(КлючиСортировки, ",");
	Результат = МассивСтруктур_Сортировать(Результат, СтрокаСортировки);
	
	ЛичныйКабинет_ВыполнитьРазметкуГруппировкиДанных(Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ДанныеПредложений(ПредложенияДляВсехЛицевыхСчетов)
	
	Результат = Новый Массив;
	
	Для Каждого КлючЗначение Из КонтекстСеанса_СтрокиКонтекста(Истина) Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		
		ДанныеПредложенийДляЯщика = Новый Массив;
		
		Для Каждого ДанныеЛицевогоСчета Из СтрокаКонтекста.ЛицевыеСчета Цикл
			
			ЛицевойСчет = ДанныеЛицевогоСчета.ЛицевойСчет;
			
			ПредложенияДляПокупки = ПредложенияДляВсехЛицевыхСчетов.Получить(ЛицевойСчет);
			
			Если ПредложенияДляПокупки <> Неопределено Тогда
				
				Для Каждого ПредложениеДляПокупки Из ПредложенияДляПокупки Цикл
					
					ДанныеПредложения = ЛичныйКабинет_ДанныеДляПредложения(ПредложениеДляПокупки, СтрокаКонтекста, ЛицевойСчет);
					ЛичныйКабинет_ДобавитьТекущееПредложениеДляЯщика(СтрокаКонтекста, ДанныеПредложенийДляЯщика, ДанныеПредложения);
					
				КонецЦикла;
				
			КонецЕсли;
			
			ЛичныйКабинет_СкорректироватьСоставПредложенийДляЯщика(ДанныеПредложенийДляЯщика);
			
		КонецЦикла;
		
		ЛичныйКабинет_СкорректироватьВажностьПредложенийПриНаличииПромо(ДанныеПредложенийДляЯщика);
		ДополнитьМассив(Результат, ДанныеПредложенийДляЯщика);
		
		ЛичныйКабинет_ДанныеПредложенийДобавитьОплатуМодуляПоЗаявке(Результат, ДанныеПредложенийДляЯщика, СтрокаКонтекста);
        
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ЛичныйКабинет_ДобавитьТекущееПредложениеДляЯщика(СтрокаКонтекста, ДанныеПредложенийДляЯщика, ДанныеПредложения)
	
	СценарийПредложения = ДанныеПредложения.ИсходныеДанные.Сценарий;
	ЭтоПредложениеНаПервуюПодпискуМодуля = ПредложенияДляПокупки_ЭтоПерваяПодпискаНаМодуль(СценарийПредложения);
	
	Если ЭтоПредложениеНаПервуюПодпискуМодуля 
		И НЕ СтрокаКонтекста.ТребуетсяОплатаСервиса Тогда
		
		СервисПодпискиНаМодуль = СтрокаКонтекста.СервисПодпискиНаМодуль;
		ИдентификаторСервисаПодписки = СервисПодпискиНаМодуль.Идентификатор;
		
		// Не показываем предложения на покупку для исключений и при ошибках доступа к Биллингу
		НеДобавлятьПредложение = (ИдентификаторСервисаПодписки = КонтурШлюзАвторизации_ИдентификаторСервисаБезПроверки()
								ИЛИ ИдентификаторСервисаПодписки = КонтурШлюзАвторизации_ИдентификаторСервисаНетДанных());
		
		Если НеДобавлятьПредложение Тогда
			Возврат;
		КонецЕсли;
		
		ДатаОкончанияПодпискиНаМодуль = СервисПодпискиНаМодуль.ДатаОкончания;
		
		// KStore не отдает дату окончания действующего промо, поэтому ориентируемся на 10 дней до окончания подписки
		Если ЗначениеЗаполнено(ДатаОкончанияПодпискиНаМодуль) Тогда
			
			ПорогДляОтображенияПредложения = 864000;
			НеДобавлятьПредложение = ДатаОкончанияПодпискиНаМодуль - ТекущаяДатаСеанса() > ПорогДляОтображенияПредложения;
			
			Если НеДобавлятьПредложение Тогда
				Возврат;
			Иначе
				
				ТипыПредложений = ЛичныйКабинет_ТипыПредложений();
				
				ДанныеПредложения.ТипПредложения = ТипыПредложений.ПодпискаНаМодульЗаканчивается;
				ДанныеПредложения.ДатаОкончания = ДатаОкончанияПодпискиНаМодуль;
				ДанныеПредложения.ЭтоПредложениеВажное = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеПредложенийДляЯщика.Добавить(ДанныеПредложения);
	
КонецПроцедуры

Процедура ЛичныйКабинет_СкорректироватьСоставПредложенийДляЯщика(ДанныеПредложенийДляЯщика)
	
	ЕстьПромоНизкийТрафикПакетов = Ложь;
	
	Сценарий_ПромоНизкийТрафикПакетов = ПредложенияДляПокупки_Сценарий_ПромоНизкийТрафикПакетов();
	
	Для Каждого ПредложениеДляПокупки Из ДанныеПредложенийДляЯщика Цикл
		
		Если ПредложениеДляПокупки.СценарийПредложения = Сценарий_ПромоНизкийТрафикПакетов Тогда
			ЕстьПромоНизкийТрафикПакетов = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЕстьПромоНизкийТрафикПакетов Тогда
		
		Сценарий_Пакет = ПредложенияДляПокупки_Сценарий_Пакет();
		
		Для й = -ДанныеПредложенийДляЯщика.ВГраница() По 0 Цикл
			
			ТекИндекс = -й;
			
			Если ДанныеПредложенийДляЯщика[ТекИндекс].СценарийПредложения = Сценарий_Пакет Тогда
				ДанныеПредложенийДляЯщика.Удалить(ТекИндекс);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЛичныйКабинет_ДанныеПредложенийДобавитьОплатуМодуляПоЗаявке(ДанныеПредложений,
																		ДанныеПредложенийДляЯщика,
																		СтрокаКонтекста)
	
	Если СтрокаКонтекста.ТребуетсяОплатаСервиса Тогда
		
		НетПредложенияНаПокупкуМодуля = Истина;
		
		Для Каждого ДанныеПредложения Из ДанныеПредложенийДляЯщика Цикл
			
			Если ДанныеПредложения.ЭтоМодуль Тогда
				
				НетПредложенияНаПокупкуМодуля = Ложь;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если НетПредложенияНаПокупкуМодуля Тогда
			
			ДанныеПредложения = ЛичныйКабинет_ДанныеДляПредложенияОплатыМодуляПоЗаявке(СтрокаКонтекста);
			ДанныеПредложений.Добавить(ДанныеПредложения);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Функция ЛичныйКабинет_ДанныеДляПредложенияОплатыМодуляПоЗаявке(СтрокаКонтекста)
	
	Результат = Новый_ДанныеЛичногоКабинета(СтрокаКонтекста, Неопределено);
	
	Результат.ЛицевойСчет = ПустойИдентификатор();
	Результат.Представление = ЛичныйКабинет_ПредставлениеПодпискиНаМодуль();
	Результат.Описание = "Подписка отсутствует";
	Результат.Действие = "Оставить заявку";
	Результат.Ссылка = Перечисление_АдресаИнтернетРесурсов().СтраницаЗаявкиНаОплату;
	
	Результат.ЭтоПредложение = Истина;
	Результат.ТипПредложения = ЛичныйКабинет_ТипыПредложений().ПодпискаНаМодульЗакончилась;
	Результат.ЭтоПредложениеВажное = Истина;
	
	Результат.ЭтоМодуль = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ДанныеДляПредложения(ПредложениеДляПокупки, СтрокаКонтекста, ЛицевойСчет)
	
	Результат = Новый_ДанныеЛичногоКабинета(СтрокаКонтекста, ЛицевойСчет);
	
	МеткаПереходаИзМодуля = "&from=diadoc_1C";
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	Результат.Представление = ЛичныйКабинет_ПредставлениеПредложения(ПредложениеДляПокупки);
	Результат.Описание = ЛичныйКабинет_ОписаниеПредложения(ПредложениеДляПокупки);
	Результат.ДатаНачала = Неопределено;
	Результат.ДатаОкончания = ПредложениеДляПокупки.ДатаОкончания;
	Результат.Количество = ПредложениеДляПокупки.ОстатокТрафика;
	Результат.Использовано = Неопределено;
	Результат.Действие = ЛичныйКабинет_ДействиеПредложения(ПредложениеДляПокупки);
	
	Результат.СценарийПредложения = СценарийПредложения;
	Результат.Ссылка = ПредложениеДляПокупки.Ссылка + МеткаПереходаИзМодуля;
	Результат.ЭтоПредложение = Истина;
	Результат.ЭтоПредложениеВажное = ЛичныйКабинет_ЭтоВажноеПредложение(ПредложениеДляПокупки);
	Результат.ЭтоРекомендация = ПредложенияДляПокупки_ЭтоРекомендация(СценарийПредложения);
	Результат.ЭтоПредложениеПромо = ПредложенияДляПокупки_ЭтоПодпискаНаПромоМодуля(СценарийПредложения);
	Результат.ЭтоМодуль = ПредложенияДляПокупки_ЭтоПодпискаНаМодульИлиПромо(СценарийПредложения);
	Результат.ЭтоПакет = ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения);
	Результат.ЭтоПлагин = ПредложенияДляПокупки_ЭтоРекомендацияПлагинов(СценарийПредложения);
	
	Результат.ТипПредложения = ЛичныйКабинет_ТипПредложения(ПредложениеДляПокупки);
	Результат.ИсходныеДанные = ПредложениеДляПокупки;
	Результат.Приоритет = ПредложениеДляПокупки.Приоритет;
	
	Возврат Результат;
	
КонецФункции

// BSLLS:CyclomaticComplexity-off
// BSLLS:CognitiveComplexity-off

Функция ЛичныйКабинет_ТипПредложения(ПредложениеДляПокупки)
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	ЭтоВажно = ЛичныйКабинет_ЭтоВажноеПредложение(ПредложениеДляПокупки);
	ЕстьДатаОкончания = ЗначениеЗаполнено(ПредложениеДляПокупки.ДатаОкончания);
	
	ЭтоМодуль = ПредложенияДляПокупки_ЭтоПодпискаНаМодульИлиПромо(СценарийПредложения);
	ЭтоПромоМодуля = ПредложенияДляПокупки_ЭтоПодпискаНаПромоМодуля(СценарийПредложения);
	ЭтоПакет = ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения);
	ЭтоПромоПакетов = ПредложенияДляПокупки_ЭтоПодпискаНаПромоПакетов(СценарийПредложения);
	ЭтоМаршрут = ПредложенияДляПокупки_ЭтоПодпискаНаМаршрут(СценарийПредложения);
	ЭтоКоннектор = ПредложенияДляПокупки_ЭтоПодпискаНаКоннекторы(СценарийПредложения);
	ЭтоAPI = ПредложенияДляПокупки_ЭтоПодпискаНаAPI(СценарийПредложения);
	ЭтоСертификат = ПредложенияДляПокупки_ЭтоПодпискаНаСертификат(СценарийПредложения);
	ЭтоРекомендацияПлагинов = ПредложенияДляПокупки_ЭтоРекомендацияПлагинов(СценарийПредложения);
	ЭтоРекомендацияПакетов = ПредложенияДляПокупки_ЭтоРекомендацияПакетов(СценарийПредложения);
	
	ПодпискаНаМодульЗакончилась = ЭтоМодуль И ЭтоВажно;
	ПодпискаНаМодульЗаканчивается = ЭтоМодуль И ЕстьДатаОкончания;
	ПакетЗакончился = ЭтоПакет И ЭтоВажно ИЛИ ЭтоПромоПакетов;
	МаршрутЗакончился = ЭтоМаршрут И ЭтоВажно;
	СертификатЗакончился = ЭтоСертификат И ЭтоВажно;
	
	ТипыПредложений = ЛичныйКабинет_ТипыПредложений();
	
	Если ПодпискаНаМодульЗакончилась Тогда
		
		Результат = ТипыПредложений.ПодпискаНаМодульЗакончилась;
		
	ИначеЕсли ПодпискаНаМодульЗаканчивается Тогда	
		
		Результат = ТипыПредложений.ПодпискаНаМодульЗаканчивается;
		
	ИначеЕсли ЭтоПромоМодуля Тогда
		
		Результат = ТипыПредложений.ПромоМодуля;
		
	ИначеЕсли ПакетЗакончился Тогда
		
		Результат = ТипыПредложений.ПакетЗакончился;
		
	ИначеЕсли ЭтоПакет Тогда
		
		Результат = ТипыПредложений.ПакетЗаканчивается;
		
	ИначеЕсли МаршрутЗакончился Тогда
		
		Результат = ТипыПредложений.МаршрутЗакончился;
		
	ИначеЕсли ЭтоМаршрут Тогда
		
		Результат = ТипыПредложений.МаршрутЗаканчивается;
		
	ИначеЕсли ЭтоКоннектор Тогда
		
		Результат = ТипыПредложений.ЛицензияНаКоннекторы;
		
	ИначеЕсли ЭтоAPI Тогда
		
		Результат = ТипыПредложений.ЛицензияНаAPI;
		
	ИначеЕсли СертификатЗакончился Тогда
		
		Результат = ТипыПредложений.СертификатЗакончился;
		
	ИначеЕсли ЭтоСертификат Тогда
		
		Результат = ТипыПредложений.СертификатЗаканчивается;
		
	ИначеЕсли ЭтоРекомендацияПлагинов Тогда
		
		Результат = ТипыПредложений.РекомендацияПлагинов;
		
	ИначеЕсли ЭтоРекомендацияПакетов Тогда
		
		Результат = ТипыПредложений.РекомендацияПакетов;
		
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// BSLLS:CyclomaticComplexity-on
