	// http://api-docs.diadoc.ru/ru/latest/proto/GetDocflowEventsRequest.html
	
	Модуль_АПИ = Модуль_МетодыAPI(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(FromTicks) Тогда
		FromTimestamp = Модуль_АПИ.DD_API_DS_Timestamp(FromTicks);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ToTicks) Тогда
		ToTimestamp = Модуль_АПИ.DD_API_DS_Timestamp(ToTicks);
	КонецЕсли;
	
	Filter = Модуль_АПИ.DD_API_DS_TimeBasedFilter(FromTimestamp, ToTimestamp);
	Результат = Модуль_АПИ.DD_API_DS_GetDocflowEventsRequest(Filter,
															AfterIndexKey,
															PopulateDocuments,
															InjectEntityContent,
															PopulatePreviousDocumentStates,
															DepartmentId);
	
	Возврат Результат;
	
