Функция НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(
		ДанныеОрганизации,
		ДанныеКонтрагента = Неопределено,
	 	ОписаниеВидовПакетов = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	Если ОписаниеВидовПакетов = Неопределено Тогда
		ОписаниеВидовПакетов = СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
	КонецЕсли;
	
	Результат = НастройкиДокументов_НастройкиПакетовНаОтправкуПоУмолчанию(ОписаниеВидовПакетов);

	КатегорииПакетов = Новый Массив;
	Для Каждого НастройкиКатегорииПакетов Из Результат Цикл
		КатегорииПакетов.Добавить(НастройкиКатегорииПакетов.КатегорияПакета);
	КонецЦикла;                                          
	
	ВидыПакетовНаОтправку = ХранениеДанных_ВидыПакетовНаОтправку(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
	
	Для Каждого НастройкиКатегорииПакетов Из Результат Цикл
		
		КатегорияПакетов = НастройкиКатегорииПакетов.КатегорияПакета;
		
		НастройкаВидаПакета = ВидыПакетовНаОтправку.Получить(КатегорияПакетов);

		НастройкиКатегорииПакетов.ОтправлятьПакет = НастройкаВидаПакета.Отправлять;
		                         
		ОписаниеВидаПакета = ОписаниеВидовПакетов.Найти(НастройкаВидаПакета.ВидПакета, "Ссылка");
		Если ОписаниеВидаПакета <> Неопределено Тогда
			НастройкиКатегорииПакетов.ВидПакета	= ОписаниеВидаПакета.ID;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

