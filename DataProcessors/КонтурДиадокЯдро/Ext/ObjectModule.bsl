// см. ХранениеДанных.Настройки_ВидыПакетовНаОтправку
//
Функция ХранениеДанных_ВидыПакетовНаОтправку(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента)

	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	СохраненныеНастройкиВидовПакетов = Модуль_ХранениеДанных.Настройки_ВидыПакетовНаОтправку(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
	
	Если Не ЗначениеЗаполнено(СохраненныеНастройкиВидовПакетов) И ДанныеКонтрагента <> Неопределено Тогда
		СохраненныеНастройкиВидовПакетов = Модуль_ХранениеДанных.Настройки_ВидыПакетовНаОтправку(КатегорииПакетов, ДанныеОрганизации);
	КонецЕсли;
	
	Результат = Новый Соответствие;
	
	Для Каждого КатегорияПакета Из КатегорииПакетов Цикл
		
		НастройкаВидаПакета = Новый Структура;
		НастройкаВидаПакета.Вставить("ВидПакета", "");
		НастройкаВидаПакета.Вставить("Отправлять", Истина);
		
		Результат.Вставить(КатегорияПакета, НастройкаВидаПакета);	
		
	КонецЦикла;
	
	Для Каждого ЭлементКоллекции Из СохраненныеНастройкиВидовПакетов Цикл
		
		КатегорияПакета = ЭлементКоллекции.Ключ;
		
		ВидПакета	= ЭлементКоллекции.Значение;
		Отправлять 	= ЗначениеЗаполнено(ВидПакета);
		
		НастройкаВидаПакета = Результат.Получить(КатегорияПакета);
		
		НастройкаВидаПакета.ВидПакета 	= ВидПакета;
		НастройкаВидаПакета.Отправлять 	= Отправлять;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

