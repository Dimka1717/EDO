// Получить текущие предложения для покупки для всех лицевых счетов из текущего контекста
// 
// Возвращаемое значение:
//  Соответствие - Данные биллинга для лицевых счетов
//   * Ключ - Строка - идентификатор лицевого счета
//   * Значение - Массив - предложения для покупки, см. Контракт_ПредложениеДляПокупки()
//
Функция ПредложенияДляПокупки_ПредложенияДляВсехЛицевыхСчетов() Экспорт
	
	Результат = Новый Соответствие;
	
	ОбработанныеЛицевыеСчета = Новый Соответствие;
	
	СтрокиКонтекстаСеанса = КонтекстСеанса_СтрокиКонтекста(Истина);
	
	Для Каждого КлючЗначение Из СтрокиКонтекстаСеанса Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		Organization = СтрокаКонтекста.Box.Organization;
		ЛицевыеСчета = СтрокаКонтекста.ЛицевыеСчета;
		
		ТребуетсяОбработать = ПредложенияДляПокупки_ТребуетсяПолучитьПредложенияДляПокупки(Organization, ЛицевыеСчета);
		
		Если НЕ ТребуетсяОбработать Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого ДанныеЛицевогоСчета Из ЛицевыеСчета Цикл
			
			ЛицевойСчетЯщика = ДанныеЛицевогоСчета.ЛицевойСчет;
			
			Если ОбработанныеЛицевыеСчета.Получить(ЛицевойСчетЯщика) = Неопределено Тогда
				ОбработанныеЛицевыеСчета.Вставить(ЛицевойСчетЯщика, Истина);
			Иначе
				Продолжить;
			КонецЕсли;
			
			ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
			ПараметрыСервиса = ПараметрыСервиса_Диадок(ИдентификаторЯщика);
			
			ШлюзАвторизации = Модуль_ШлюзАвторизации(ПараметрыСервиса);
			ИмяПродукта = КонтурШлюзАвторизации_ИмяПродукта();
			
			Попытка
				
				ДанныеСервисаПредложений = ШлюзАвторизации.ПредложенияДляПокупки(ИмяПродукта, ЛицевойСчетЯщика);
				ДанныеПредложенийДляПокупки = КонтурШлюзАвторизации_ОбработанныеПредложенияДляПокупки(ДанныеСервисаПредложений);
				
			Исключение
				
				ВидОперации	 = НСтр("ru = 'Получение предложений для покупки'");
				ТекстОшибки	 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				Ошибка_Обработать(ВидОперации, ТекстОшибки);
				Метрика_ДобавитьОшибку_ПолучениеПредложенийДляПокупки(ЛицевойСчетЯщика, ТекстОшибки, ИдентификаторЯщика);
				
			КонецПопытки;
			
			Если ЗначениеЗаполнено(ДанныеПредложенийДляПокупки) Тогда
				Результат.Вставить(ЛицевойСчетЯщика, ДанныеПредложенийДляПокупки);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПредложенияДляПокупки_ТребуетсяПолучитьПредложенияДляПокупки(Organization, ЛицевыеСчета)
	
	ЭтоРеальнаяОрганизация = Организации_ЭтоРеальнаяОрганизация(Organization);
	ОрганизацияЛиквидирована = Организации_ОрганизацияЛиквидирована(Organization);
	
	Результат = ЛицевыеСчета.Количество() = 1
				И ЛицевыеСчета[0].КодПродукта = КонтурШлюзАвторизации_КодПродукта()
				И ЭтоРеальнаяОрганизация
				И НЕ ОрганизацияЛиквидирована;
	
	Возврат Результат;
	
КонецФункции

Функция КонтурШлюзАвторизации_ОбработанныеПредложенияДляПокупки(ДанныеСервисаПредложений)
	
	Результат = Новый Массив;
	
	ОбрабатываемыеСценарии = ПредложенияДляПокупки_ПриоритетыСценариев();
	
	Для Каждого ТекДанныеДляПокупки Из ДанныеСервисаПредложений Цикл
		
		ПриоритетСценария = ОбрабатываемыеСценарии.Получить(ТекДанныеДляПокупки.Сценарий);
		
		Если ПриоритетСценария <> Неопределено Тогда
			
			ПредложениеДляПокупки = Контракт_ПредложениеДляПокупки();
			
			ЗаполнитьЗначенияСвойств(ПредложениеДляПокупки, ТекДанныеДляПокупки);
			ПредложенияДляПокупки_ЗаполнитьОснованиеПредложения(ПредложениеДляПокупки);
			ПредложениеДляПокупки.Приоритет = ПриоритетСценария;
			
			Результат.Добавить(ПредложениеДляПокупки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПредложенияДляПокупки_ПриоритетыСценариев()
	
	Результат = Новый Соответствие;
	
	Сценарий_ПодпискаНаМодуль = ПредложенияДляПокупки_Сценарий_ПодпискаНаМодуль();
	Сценарий_ПерваяПодпискаНаМодуль = ПредложенияДляПокупки_Сценарий_ПерваяПодпискаНаМодуль();
	Сценарий_Пакет = ПредложенияДляПокупки_Сценарий_Пакет();
	Сценарий_ПромоНизкийТрафикПакетов = ПредложенияДляПокупки_Сценарий_ПромоНизкийТрафикПакетов();
	Сценарий_ПромоПакетов_50 = ПредложенияДляПокупки_Сценарий_ПромоПакетов_50();
	Сценарий_ПромоПакетов_100 = ПредложенияДляПокупки_Сценарий_ПромоПакетов_100();
	Сценарий_ПродлениеМаршрутов = ПредложенияДляПокупки_Сценарий_ПродлениеМаршрутов();
	Сценарий_ПродлениеКоннекторов = ПредложенияДляПокупки_Сценарий_ПродлениеКоннекторов();
	Сценарий_ПродлениеAPI = ПредложенияДляПокупки_Сценарий_ПродлениеAPI();
	Сценарий_ПродлениеСертификатов = ПредложенияДляПокупки_Сценарий_ПродлениеСертификатов();
	Сценарий_ПромоНаМодуль21 = ПредложенияДляПокупки_Сценарий_ПромоНаМодуль21();
	Сценарий_РекомендацияПлагинов = ПредложенияДляПокупки_Сценарий_РекомендацияПлагинов();
	Сценарий_РекомендацияПакетов = ПредложенияДляПокупки_Сценарий_РекомендацияПакетов();
	
	// BSLLS:MagicNumber-off
	Результат.Вставить(Сценарий_ПодпискаНаМодуль, 1);
	Результат.Вставить(Сценарий_ПерваяПодпискаНаМодуль, 2);
	Результат.Вставить(Сценарий_Пакет, 3);
	Результат.Вставить(Сценарий_ПромоНизкийТрафикПакетов, 4);
	Результат.Вставить(Сценарий_ПромоПакетов_50, 5);
