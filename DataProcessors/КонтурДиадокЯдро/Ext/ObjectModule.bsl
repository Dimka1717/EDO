	Результат = Ложь;
	
	Если НЕ ИспользоватьПлагины() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторПлагина = КонтурПлагины_СчетВПакете_ИдентификаторПлагина();
	УстановленныйПлагин = КонтурПлагины_УстановленныйПлагин(ИдентификаторПлагина);
	
	ПлагинСчетВПакетУстановлен = (УстановленныйПлагин.Состояние = КонтурПлагины_СостояниеПлагинаВключен());
	
	Если ПлагинСчетВПакетУстановлен
		И ЕстьИнтеграционныйМодуль() Тогда
		
		Результат = Истина;
		
		НастройкиПлагина = КонтурПлагины_СчетВПакете_НастройкиПлагина();
		Метрика_ДобавитьСтатистику_НастройкиПлагинаСчетВПакете(УстановленныйПлагин, НастройкиПлагина);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонтурПлагины_СчетВПакете_НастройкиПлагина()

	ИдентификаторПлагина = КонтурПлагины_СчетВПакете_ИдентификаторПлагина();
	НастройкиПлагина = КонтурПлагины_НастройкиПлагина(ИдентификаторПлагина);
	
	ОснованиеДляСчета		= СвойствоСтруктуры(НастройкиПлагина, "ФормироватьСчетНаОсновании", "СчетНаОплату");
	ПроверятьДублирование	= СвойствоСтруктуры(НастройкиПлагина, "ПроверятьПакеты", Ложь);
	РежимОтбораКА			= СвойствоСтруктуры(НастройкиПлагина, "ВариантОтбора", "");
	МассивКонтрагентов		= СвойствоСтруктуры(НастройкиПлагина, "МассивКонтрагентов");
	
	Если ЗначениеЗаполнено(МассивКонтрагентов) Тогда
		МассивКонтрагентов = ЗначениеИзСтрокиВнутр(МассивКонтрагентов);
	Иначе
		МассивКонтрагентов = Новый Массив;
	КонецЕсли;
	
	Результат = Новый Структура;
	
	Результат.Вставить("ФормироватьСчетНаОсновании", ОснованиеДляСчета);
	Результат.Вставить("ПроверятьПакеты", ПроверятьДублирование);
	Результат.Вставить("ВариантОтбора", РежимОтбораКА);
	Результат.Вставить("МассивКонтрагентов", МассивКонтрагентов);
	
	Возврат Результат;

КонецФункции

Функция КонтурПлагины_СчетВПакете_ВыполнитьПереходСПлагина() Экспорт
	
	Результат = Ложь;
	
	ВидыДокументовСчетов = ВидыЭлектронныхСчетовНаОплату();
	
	Если ВидыДокументовСчетов.Количество() = 0 Тогда
		НеобходимоВыполнитьКонвертацию = Ложь;
	Иначе
		ОснованиеДляСчетаИзПлагина = КонтурПлагины_СчетВПакете_ОснованиеДляСчета();	
		ДоступныеОснованияДляСчета = МенеджерИнтеграции_СписокОснованийВидаЭлектронногоДокумента(ВидыДокументовСчетов[0]);
		НеобходимоВыполнитьКонвертацию = (ДоступныеОснованияДляСчета.НайтиПоЗначению(ОснованиеДляСчетаИзПлагина) <> Неопределено);
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		Если НеобходимоВыполнитьКонвертацию Тогда
			КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина);	
		КонецЕсли;
		
		ИдентификаторПлагина = КонтурПлагины_СчетВПакете_ИдентификаторПлагина();
		ПлагинОтключен = КонтурПлагины_ОтключитьПлагин(ИдентификаторПлагина);
		
		Если ПлагинОтключен Тогда
			Результат = Истина;
		Иначе
			ТекстОшибки = "Не удалось отключить плагин.";
		КонецЕсли;
		
		КонтурПлагины_СчетВПакете_УстановитьДатуПерехода();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВидОперации = НСтр("ru = 'Конвертация настроек плагина ""Первичные документы и счет на оплату""'");
		ТекстСообщения = "Не удалось выполнить конвертацию настроек плагина.";
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
		
	КонецПопытки;
	
	Если Результат И НеобходимоВыполнитьКонвертацию Тогда
		КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты(ОснованиеДляСчетаИзПлагина);
	КонецЕсли;
	
	Метрика_ДобавитьСтатистику_КонвертацияНастроекПлагинаСчетВПакете(Результат, ТекстОшибки);
	
	Возврат Результат;
	
КонецФункции

Функция КонтурПлагины_СчетВПакете_ОснованиеДляСчета()

	НастройкиПлагина = КонтурПлагины_СчетВПакете_НастройкиПлагина();
	
	Результат = НастройкиПлагина.ФормироватьСчетНаОсновании;
	
	Если Результат = "ЗаказПокупателя"
		И ИнтеграционныйМодуль_Получить() = ИмяИМ_УТ11() Тогда
		
		Результат = "ЗаказКлиента";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты(ОснованиеДляСчетаИзПлагина)
	
	КоличествоДнейДляКонвертации = 31;
	КоличествоСекундВОдномДне = 24*60*60;
	
	ДатаКонвертацииДанных = ТекущаяДата() - КоличествоДнейДляКонвертации * КоличествоСекундВОдномДне;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Модуль_ХранениеДанных.КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты(ДатаКонвертацииДанных, ОснованиеДляСчетаИзПлагина);
	
КонецПроцедуры

