//{		ОБНОВЛЕНИЕ МОДУЛЯ

// Проверяет, что используется типовая сборка модуля.
// 
// Возвращаемое значение:
//  Булево - Истина, если контрольная сумма файла модуля получена и валидна.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция ЭтоТиповойМодуль() Экспорт
	
	РезультатПроверкиХэшСуммы = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммы();
	
	Если Не ЗначениеЗаполнено(РезультатПроверкиХэшСуммы) Тогда
		ТекстОшибки = "Ошибка получения значения из кэша (ЭтоТиповойМодуль)!";
		ОбновлениеМодуля_ОбработатьОшибку(ТекстОшибки);
	КонецЕсли;
	
	Результат = (РезультатПроверкиХэшСуммы = ЗначениеКонтрольнаяСуммаВалидна());
	
	Если НЕ Результат 
		И Автотесты_ЭтоТиповойМодуль() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 

// Принудительно устанавливает признак что модуль типовой
// Значение задается в конфигурационном файле
// 
// Возвращаемое значение:
//  Булево - Истина, если в конфигурационном файле передан ключ Автотесты_ЭтоТиповойМодуль.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция Автотесты_ЭтоТиповойМодуль()
	
	Результат = ОбщийКонтекст_Прочитать("Автотесты_ЭтоТиповойМодуль") = Истина;
	
	Возврат Результат;
	
