Функция Подразделения_РеквизитыПодразделения_АПИ(Идентификаторы, ДанныеВладельца, ДляОрганизации) Экспорт
	
	Результат = Контракт_ПодразделениеЭДО();

	DepartmentId = Идентификаторы.ID;
	
	Organization		= Подразделения_OrganizationВладельца(ДанныеВладельца, ДляОрганизации);
	МассивDepartments	= Organization.Departments;
	
	Для Каждого Department Из МассивDepartments Цикл
		Если Department.DepartmentId = DepartmentId Тогда
			
			Результат = Подразделения_НовоеПодразделение(Organization, Department);
			
		КонецЕсли;
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Функция Подразделения_OrganizationВладельца(ДанныеВладельца, ДляОрганизации = Истина)

	ID = СвойствоСтруктуры(ДанныеВладельца, "ID", "");
	
	Если ДляОрганизации Тогда
		
		СтрокаКонтекста	= КонтекстСеанса_СтрокаКонтекста(ID, Истина);
		Результат		= СтрокаКонтекста.Box.Organization;
		
	Иначе
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок();
		
		КонтрагентАПИ	= АПИ_GetBox(ПараметрыСервиса, ID);
		Результат		= КонтрагентАПИ.Organization;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции // ()
 
Процедура Подразделения_ВыполнитьСинхронизацию(Organization, Владелец)
	
	ТаблицаКонтрактов = Подразделения_ТаблицаКонтрактовПоDepartments(Organization);
	
