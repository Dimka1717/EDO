// Проверяет, доступна ли функция поиска связей запросом
// 
// Возвращаемое значение:
//  Булево - Истина, если в ИМ есть функция поиска запросом.
//
Функция СчетаНаОплату_ИскатьСвязиЗапросом()
	
	ИмяИМ = ИнтеграционныйМодуль_Получить();
	
	МассивИМ = Новый Массив;
	МассивИМ.Добавить(ИмяИМ_БП30());
	МассивИМ.Добавить(ИмяИМ_УТ11());
	МассивИМ.Добавить(ИмяИМ_УТ103());
	МассивИМ.Добавить(ИмяИМ_УНФ16());
	Результат = МассивИМ.Найти(ИмяИМ)<> Неопределено; 
	
	Возврат Результат;
	
КонецФункции

// Находит связи с учетным документом, на основании которого формируется электронный счет на оплату.
//
// Параметры:
//  ОснованиеЭлектронногоСчета - ЛюбаяСсылка - учетный документ (счет, заказ, документ продажи),
//                               на основании которого формируется электронный счет на оплату.
// 
// Возвращаемое значение:
//  Массив из ЛюбаяСсылка.
//
Функция МенеджерИнтеграции_СвязанныеДокументы(ОснованиеЭлектронногоСчета)
	
	Результат = Новый Массив;
	
	Если ЕстьИнтеграционныйМодуль() Тогда
		
		МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
		
		Если СчетаНаОплату_ИскатьСвязиЗапросом() Тогда
			
			Результат = МенеджерИнтеграции.СчетаНаОплату_СвязанныеДокументы(ОснованиеЭлектронногоСчета);
			
		Иначе
			
			Результат = МенеджерИнтеграции.СчетаНаОплату_СвязанныеДокументыПоКритериюОтбора(ОснованиеЭлектронногоСчета);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

