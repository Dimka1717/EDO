Процедура Контрагенты_ОбновитьДанныеКонтрагента(Контрагент, Организация) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(Организация.ID);
	
	Counteragent = АПИ_GetCounteragent(ПараметрыСервиса, Организация.OrgId, Контрагент.OrgId);
	
	НовыйКонтрагент		= Контрагенты_НовыйКонтрагентИзСтруктуры(Counteragent);
	ТаблицаКонтрактов	= Контрагенты_НоваяТаблицаКонтрактов();
	
	НоваяСтрока = ТаблицаКонтрактов.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, НовыйКонтрагент);
	
	ЗаполнитьЗначенияСвойств(НовыйКонтрагент, Контрагент, "Ссылка, СвязанныйСправочник1");
	
	Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов);
	
	ХранениеДанных_ЗаписатьСтатусКонтрагента(НовыйКонтрагент, Организация);
	
	Подразделения_ВыполнитьСинхронизацию(Counteragent.Organization, НовыйКонтрагент);
	
КонецПроцедуры	

