КонецПроцедуры

//#КонецОбласти

//#Область Замеры_длительных_операций

Функция НовыйОписаниеЗамера()
	
	Результат = Новый Структура;
	Результат.Вставить("Категория");
	Результат.Вставить("Действие");
	Результат.Вставить("КлючеваяОперация");
	Результат.Вставить("ВремяНачала");
	Результат.Вставить("ВремяПоследнегоЗамера");
	Результат.Вставить("ВложенныеЗамеры");
	Результат.Вставить("ДополнительныеПеременные");
	
	Возврат Результат;
	
КонецФункции

Функция НачатьЗамерДлительнойОперации(КлючеваяОперация, Действие = "") Экспорт
	
	ТекущееВремя = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Результат = НовыйОписаниеЗамера();
	Результат.Категория					= КлючеваяОперация;
	Результат.Действие					= Действие;
	Результат.КлючеваяОперация			= КлючеваяОперация;
	Результат.ВремяНачала				= ТекущееВремя;
	Результат.ВремяПоследнегоЗамера		= ТекущееВремя;
	Результат.ВложенныеЗамеры			= Новый Структура;
	Результат.ДополнительныеПеременные	= Новый Соответствие;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗафиксироватьЗамерДлительнойОперации(ОписаниеЗамера, ИмяШага, ДополнительныеПеременные = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ОписаниеЗамера) Тогда
		Возврат;
	КонецЕсли;
	
	ТекущееВремя = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Длительность = (ТекущееВремя - ОписаниеЗамера.ВремяПоследнегоЗамера)/1000;
	
	ШагВложенногоЗамера = Новый Структура;
	ШагВложенногоЗамера.Вставить("ВремяНачала",					ОписаниеЗамера.ВремяПоследнегоЗамера);
	ШагВложенногоЗамера.Вставить("ВремяОкончания",				ТекущееВремя);
	ШагВложенногоЗамера.Вставить("Длительность",				Длительность);
	ШагВложенногоЗамера.Вставить("ДополнительныеПеременные",	ДополнительныеПеременные);
	
	КоллекцияВложенныхЗамеров = ОписаниеЗамера.ВложенныеЗамеры;
	
	КоллекцияВложенныхЗамеров.Вставить(ИмяШага, ШагВложенногоЗамера);
	
	ОписаниеЗамера.Вставить("ВремяПоследнегоЗамера", ТекущееВремя);
	
КонецПроцедуры

Процедура ЗакончитьЗамерДлительнойОперации(ОписаниеЗамера, ИмяШага = "", ДополнительныеПеременные = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ОписаниеЗамера) Тогда
		Возврат;
	КонецЕсли;
	
	ВремяНачалаЗамера	 = ОписаниеЗамера.ВремяНачала;
	ИмяКлючевойОперации	 = ОписаниеЗамера.КлючеваяОперация;
	ВложенныеЗамеры		 = ОписаниеЗамера.ВложенныеЗамеры;
	
	ЕстьВложенныеЗамеры = ВложенныеЗамеры.Количество();
	ТекущееВремя = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Длительность = (ТекущееВремя - ВремяНачалаЗамера)/1000;
	Действие = ОписаниеЗамера.Действие;
	
	Если ЕстьВложенныеЗамеры Тогда
		ЗафиксироватьЗамерДлительнойОперации(ОписаниеЗамера, ?(ПустаяСтрока(ИмяШага), "ПоследнийШаг", ИмяШага), ДополнительныеПеременные);
	КонецЕсли;
	
	КоллекцияЗамеровДляЗаписи = Новый Массив;
	
	Для Каждого Замер Из ВложенныеЗамеры Цикл
		
		ДействиеЗамера = Замер.Ключ;
		ДанныеЗамера = Замер.Значение;
		ДлительностьВложенногоЗамера = ДанныеЗамера.Длительность;
		КлючеваяОперация = ИмяКлючевойОперации + "." + Замер.Ключ;
		
		ПараметрыЗамера = Новый Структура;
		ПараметрыЗамера.Вставить("Категория",						ИмяКлючевойОперации);
		ПараметрыЗамера.Вставить("Действие",						ДействиеЗамера);
		ПараметрыЗамера.Вставить("КлючеваяОперация",				КлючеваяОперация);
		ПараметрыЗамера.Вставить("Длительность",					ДанныеЗамера.Длительность);
		ПараметрыЗамера.Вставить("ДатаНачалаКлючевойОперации",		ДанныеЗамера.ВремяНачала);
		ПараметрыЗамера.Вставить("ДатаОкончанияКлючевойОперации",	ДанныеЗамера.ВремяОкончания);
		ПараметрыЗамера.Вставить("ДополнительныеПеременные",		ДанныеЗамера.ДополнительныеПеременные);
		
		КоллекцияЗамеровДляЗаписи.Добавить(ПараметрыЗамера);
		
	КонецЦикла;
	
	ПараметрыЗамера = Новый Структура;
	ПараметрыЗамера.Вставить("Категория",						ИмяКлючевойОперации);
	ПараметрыЗамера.Вставить("Действие",						Действие);
	ПараметрыЗамера.Вставить("КлючеваяОперация",				ИмяКлючевойОперации);
	ПараметрыЗамера.Вставить("Длительность",					Длительность);
	ПараметрыЗамера.Вставить("ДатаНачалаКлючевойОперации",		ВремяНачалаЗамера);
	ПараметрыЗамера.Вставить("ДатаОкончанияКлючевойОперации",	ТекущееВремя);
	ПараметрыЗамера.Вставить("ДополнительныеПеременные",		ДополнительныеПеременные);
	
	КоллекцияЗамеровДляЗаписи.Добавить(ПараметрыЗамера);
	
	ЗаписатьЗамерыДлительнойОперации(КоллекцияЗамеровДляЗаписи);
	
КонецПроцедуры

Процедура ЗаписатьЗамерыДлительнойОперации(КоллекцияЗамеров)
	
	Для Каждого Замер Из КоллекцияЗамеров Цикл
		ЗаписатьЗамер(Замер);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьЗамер(Замер)
	
	Категория		= Замер.Категория;
	Действие		= Замер.Действие;
	Представление	= Неопределено;
	Метка			= Неопределено;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("ДатаНачалаКлючевойОперации",		Замер.ДатаНачалаКлючевойОперации);
	Переменные.Вставить("ДатаОкончанияКлючевойОперации",	Замер.ДатаОкончанияКлючевойОперации);
	Переменные.Вставить("Длительность",						Замер.Длительность);
	
	ДополнительныеПеременныеЗамера = Замер.ДополнительныеПеременные;
	
	Если ЗначениеЗаполнено(ДополнительныеПеременныеЗамера) Тогда
		
		Для Каждого ДопПеременная Из Замер.ДополнительныеПеременные Цикл
			Переменные.Вставить(ДопПеременная.Ключ, ДопПеременная.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	ДобавитьСистемнуюИнформацию = Истина;
	
	КлючИдентификатораТрассировки = "ИдентификаторТрассировки";
	ИдентификаторТрассировки = Переменные.Получить(КлючИдентификатораТрассировки);
	Если ИдентификаторТрассировки <> Неопределено Тогда
		Переменные.Удалить(КлючИдентификатораТрассировки);	
	КонецЕсли;
	
	ЗаписатьЗамерДлительнойОперации(
		Категория,
		Действие,
		Представление,
		Метка,
		Переменные,
		ДобавитьСистемнуюИнформацию,
		ИдентификаторТрассировки
	);
	
КонецПроцедуры

Процедура ЗаписатьЗамерДлительнойОперации(Категория, Действие
	, Представление = Неопределено
	, Метка = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Истина
	, TraceID = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если TraceID = Неопределено Тогда
		TraceID = TraceId();
	КонецЕсли;
	
	TopicKey	= ТопикиМетрики().Health;
	BaseID		= ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Переменные.Вставить("BaseID", BaseID);
	
	СобытиеМетрики = НовоеСобытиеМетрики(Категория, Действие, Метка, Представление);
	
	ЗарегистрироватьСобытиеМетрики(TopicKey, СобытиеМетрики, TraceID, Переменные, ДобавитьСистемнуюИнформацию);
	
КонецПроцедуры

