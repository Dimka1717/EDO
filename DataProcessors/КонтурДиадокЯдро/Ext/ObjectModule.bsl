	Переменные.Вставить("Стандарт: Использовать ПМ", СвойствоСтруктуры(НастройкиМодуляСтандарт, "ИспользоватьПодключаемыйМодуль"));
	Переменные.Вставить("Стандарт: Место хранения ПМ", СвойствоСтруктуры(НастройкиМодуляСтандарт, "ПодключаемыйМодульПредставление"));
	Переменные.Вставить("Стандарт: РежимСовместимостиФорматов155и820", СвойствоСтруктуры(НастройкиМодуляСтандарт, "РежимСовместимостиФорматов155и820"));
	
	// Интеграции
	Переменные.Вставить("МодульКонтурИнтеграция", КонтурИнтеграция_ИспользуетсяПодсистемаИнтеграции());
	
	// Общие настройки: Подписание
	Переменные.Вставить("Способ подписания Госключ", СвойствоСтруктуры(ОбщиеНастройки, "ПодписаниеГосключ"));
	Переменные.Вставить("Способ подписания Сертификат", СвойствоСтруктуры(ОбщиеНастройки, "ПодписаниеСертификат"));

