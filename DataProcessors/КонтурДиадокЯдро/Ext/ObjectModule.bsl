//	Строка
Функция КЭП_HTMLТекст_ТекстСертификатыНеКЭП(СписокОшибокКЭП) Экспорт
	
	АдресаИнтернетРесурсов			= Перечисление_АдресаИнтернетРесурсов();
	СсылкаНаЗакон63ФЗ				= АдресаИнтернетРесурсов.Закон63ФЗ;
	СсылкаНаИнструкцию				= АдресаИнтернетРесурсов.Инструкция_ПричиныОшибкиКЭП;
	СсылкаСтраницаСервисныйЦентр	= АдресаИнтернетРесурсов.СтраницаСервисныйЦентр;
	
	HTMLШаблоны = КЭП_HTMLШаблоны();
	
	РежимОткрытияЦП = ЦП_РежимыОткрытияЦП().СертификатНеКЭП;
	ДобавитьHTMLШаблоныКнопокТехПоддержки(HTMLШаблоны, РежимОткрытияЦП);
	
	Результат = HTMLШаблоны.Начало;
	Результат = Результат + HTMLШаблоны.ТаблицаСтилей;
	Результат = Результат + HTMLШаблоны.НачалоТела;
	
	ПодстрокиТела = Новый Массив;
	
	Подстрока = "<p class=strtextbold_margin1_0_1><b>Сертификат не является квалифицированным</b></p>
	|<p class=strtext_margin1_0_1>Сертификат не соответствует требованиям федерального законодательства -
	|<A href=""" + СсылкаНаЗакон63ФЗ + """>63-ФЗ ""Об электронной подписи""</A>.
	|<p style=""margin-top: -3%""> &nbsp; </p> ";
	
	ПодстрокиТела.Добавить(Подстрока);
	
	ШаблонПредставленияОшибки = "<p class=strtext_margin1_0_1>&nbsp;&nbsp; • &nbsp;&nbsp; %1, сертификат для ""%2""</p>";

	Для каждого ОписаниеОшибкиКЭП Из СписокОшибокКЭП Цикл
	
		Подстрока = Общее_ПодставитьПараметрыВСтроку(ШаблонПредставленияОшибки,
			ОписаниеОшибкиКЭП.НаименованиеОрганизации, 
			ОписаниеОшибкиКЭП.НаименованиеСертификата
		); 
		
		ПодстрокиТела.Добавить(Подстрока);
		
	КонецЦикла;
	
	Подстрока = "<p style=""margin-top: -3%""> &nbsp; </p>
	|<p class=strtext_margin1_0_1>- С подробными причинами ошибки ознакомьтесь в <A href=""" + СсылкаНаИнструкцию + """>инструкции</A>.</p>
	|<p class=strtext_margin1_0_1>- Для перевыпуска сертификата обратитесь в сервисный центр (СЦ) - <A href=""" + СсылкаСтраницаСервисныйЦентр + """>контакты СЦ</A>.</p>
	|<p class=strtext_margin1_0_1>- Если сертификат был перевыпущен, то попробуйте вновь авторизоваться в модуле.</p>";
	ПодстрокиТела.Добавить(Подстрока);
	
	ТекстТела = СоединитьСтроку(ПодстрокиТела, Символы.ПС);
	
	Результат = Результат + ТекстТела;
	Результат = Результат + HTMLШаблоны.КнопкиТехПоддрежки;
	Результат = Результат + HTMLШаблоны.Окончание;
	
	Возврат Результат;
	
КонецФункции 

