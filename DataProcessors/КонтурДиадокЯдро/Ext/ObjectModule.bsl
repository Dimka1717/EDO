// Модель пользователя Диадока
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//   * Идентификатор - Строка - UserId в нижнем регистре
//   * Зарегистрирован - Булево - Ложь, если пользователь с указанным логином был создан в Диадоке, но еще не подтвердил почту
//   * Представление - Строка - Фамилия И.О. или Фамилия Имя
//   * Фамилия - Строка - (необязательный) фамилия пользователя
//   * Имя - Строка - (необязательный) имя пользователя
//   * Отчество - Строка - (необязательный) отчество пользователя
//   * Логин - Строка - (необязательный) электронная почта пользователя
//
Функция МодельПользовательСервиса()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор", "");
