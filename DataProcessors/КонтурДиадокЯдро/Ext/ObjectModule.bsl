//
// Параметры:
//  ИдентификаторыОрганизации - Структура - см. описание Новый_ИдентификаторыСправочника()
// 
// Возвращаемое значение:
//  Булево - Истина, если требуется отправлять электронные документы на основании непроведенных документов учета.
//
Функция ЗначениеНастройки_ОтправлятьНепроведенныеДокументы(Организация1С)
	
	IDОрганизации = Организации_ИдентификаторПоСсылке(Организация1С);
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, IDОрганизации);
	
	ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	Результат = ДанныеОрганизации.ОтправлятьНепроведенныеДокументы;
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьОграниченияПоТарифу() Экспорт
	
	Результат = Ложь;
	
	КонтекстСеансаСтроки = КонтекстСеанса_СтрокиКонтекста();
	ИмяСервисаСтартовыйУМ = КонтурШлюзАвторизации_ИмяСервисаСтартовыйУМ();
	
	Для Каждого СтрокаКонтекста Из КонтекстСеансаСтроки Цикл
		
		Ключ = СтрокаКонтекста.Ключ;
		Значение = СтрокаКонтекста.Значение;
		Если ЗначениеЗаполнено(Значение.СервисПодпискиНаМодуль)
			И Значение.СервисПодпискиНаМодуль.Идентификатор = ИмяСервисаСтартовыйУМ Тогда
			
			Результат = Истина;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

