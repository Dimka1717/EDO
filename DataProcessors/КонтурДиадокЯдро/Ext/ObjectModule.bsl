Функция Документы_ДокументИсходящийМожноПередатьНаПодпись(Документ)
	
	Результат = Ложь;
	
    СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();
    
    Статус = Документ.Статусы.Статус;
	
	НаправленияДокументов = Перечисление_Направления();
	
	Если (Документ.Направление = НаправленияДокументов.Исходящее
			ИЛИ Документ.Направление = НаправленияДокументов.Внутреннее)
		И НЕ Документ.Шаблон Тогда
		
		ДокументОтправлен = Документы_ДокументОтправлен(Документ);
		
		Результат = НЕ ДокументОтправлен
					ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить;
		
	КонецЕсли;			
	
	Возврат Результат;
    
КонецФункции

