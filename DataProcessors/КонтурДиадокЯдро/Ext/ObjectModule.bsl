// Перемещает документы организации между подразделениями
//
// Параметры:
//	BoxId					- Строка - идентификатор организации
//	ToDepartmentId			- Строка - идентификатор подразделения, в которое происходит перемещение
//	ДокументыДляОбработки	- Массив - элементом массива является структура. См. метод "Контракт_Документ" 
//
// Возвращаемое значение:
//	Булево
Функция Документы_ПереместитьМассивДокументовВПодразделение(BoxId, ToDepartmentId, ДокументыДляОбработки) Экспорт 
	
	ПараметрыСервиса		 = ПараметрыСервиса_Диадок(BoxId);
	DocumentsMoveOperation	 = АПИ_Новый_DocumentsMoveOperation(BoxId, ToDepartmentId);
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		Идентификаторы = Документ.Идентификаторы;
		DocumentId = АПИ_Новый_DocumentId(Идентификаторы.LetterId, Идентификаторы.DocumentId);
		DocumentsMoveOperation.DocumentIds.Добавить(DocumentId);
	КонецЦикла;
	
	Результат = АПИ_MoveDocuments(ПараметрыСервиса, DocumentsMoveOperation);
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		
		ОбновляемыеРеквизиты = Новый Структура("DepartmentId", ToDepartmentId);
		ХранениеДанных_ОбновлениеРеквизитовДокумента(Документ.Идентификаторы, ОбновляемыеРеквизиты);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

