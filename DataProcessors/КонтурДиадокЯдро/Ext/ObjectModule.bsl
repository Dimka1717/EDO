		Переменные.Вставить("ТекстОшибки", ТекстОшибки);
	КонецЕсли;
	
	Метрика_ДобавитьСтатистику_ПоКонтексту(КатегорияМетрики, ДействиеМетрики, , Переменные);
	
КонецПроцедуры

// Добавляет событие метрики плагинов в стек событий.
//
// Параметры:
//  СобытиеПлагина - Структура - см. функцию НовоеСобытиеМетрики() в библиотеке плагинов
//
Процедура КонтурПлагины_ЗарегистрироватьСобытиеМетрики(СобытиеПлагина) Экспорт
	
	Если НЕ ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ТипСобытияМетрики = СобытиеПлагина.ТипСобытия;
	Переменные = СобытиеПлагина.Переменные;
	ТекстОшибкиПлагина = СобытиеПлагина.ТекстОшибки;
	ИдентификаторТрассировки = СобытиеПлагина.ИдентификаторТрассировки;
	
	ТопикиМетрики = ТопикиМетрики();
	КатегорияПлагин = Метрики_КатегорияПлагин();
	
	Если ТипСобытияМетрики = ТипСобытияМетрикиПлагина_Ошибка() Тогда
		
		ТопикМетрики = ТопикиМетрики.Log;
		
	ИначеЕсли ТипСобытияМетрики = ТипСобытияМетрикиПлагина_Статистика() Тогда
		
		ТопикМетрики = ТопикиМетрики.Statistics;
		
	ИначеЕсли ТипСобытияМетрики = ТипСобытияМетрикиПлагина_Поведение() Тогда
		
		ТопикМетрики = ТопикиМетрики.Behavior;
		
	ИначеЕсли ТипСобытияМетрики = ТипСобытияМетрикиПлагина_Замер() Тогда
		
		ТопикМетрики = ТопикиМетрики.Health;
		
	Иначе
		
		ВидОперации = "КонтурПлагины.ЗарегистрироватьСобытиеМетрики: " + ТипСобытияМетрики;
		ТекстОшибки = "Событие '" + ТипСобытияМетрики + "' не реализовано";
		Ошибка_Обработать(ВидОперации, ТекстОшибки);
		
		Возврат;
		
	КонецЕсли;
	
	ДополнитьПеременныеМетрики_BaseId(Переменные);
	ДополнитьПеременныеМетрики_Ошибка(Переменные, ТекстОшибкиПлагина);
	
	НовоеСобытиеМетрики = НовоеСобытиеМетрики(
			КатегорияПлагин,
			СобытиеПлагина.Действие,
			СобытиеПлагина.ВерсияПлагина,
			СобытиеПлагина.ИдентификаторПлагина
		);
	
	ЗарегистрироватьСобытиеМетрики(
		ТопикМетрики,
		НовоеСобытиеМетрики,
		ИдентификаторТрассировки,
		Переменные,
		Истина
	);
	
КонецПроцедуры

// Дополняет переменные метрики BaseID
//
// Параметры:
//  Переменные	 - Структура - переменные метрики Возможно Неопределено 
//
Процедура ДополнитьПеременныеМетрики_BaseId(Переменные)
	
	BaseID = ОбщийКонтекст_ИдентификаторБазы1С();
	
	Если НЕ ЗначениеЗаполнено(Переменные) Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	Переменные.Вставить("BaseID", BaseID);

КонецПроцедуры

// Дополняет переменные метрики BoxID
//
// Параметры:
//  Переменные	 - Структура - переменные метрики Возможно Неопределено
//
Процедура ДополнитьПеременныеМетрики_BoxId(Переменные)
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	КоллекцияBoxId = Новый Массив;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		КоллекцияBoxId.Добавить(ИдентификаторЯщика);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Переменные) Тогда
		
		Переменные.Вставить("BoxId", КоллекцияBoxId);
		
	Иначе
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxId", КоллекцияBoxId);
		
	КонецЕсли;
	
КонецПроцедуры

// Добавляет в коллекцию переменных метрики UserId
//
// Параметры:
//  Переменные - Соответствие, Структура - переменные метрики
//
Процедура ДополнитьПеременныеМетрики_UserId(Переменные)
	
	Если Переменные = Неопределено Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	ИдентификаторыПользователей = Новый Массив;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		ТекущийИдентификатор = СтрокаКонтекста.ОписаниеПользователя.Id;
		
		Если ИдентификаторыПользователей.Найти(ТекущийИдентификатор) = Неопределено Тогда
			ИдентификаторыПользователей.Добавить(ТекущийИдентификатор);
		КонецЕсли;
		
	КонецЦикла;
	
	Переменные.Вставить("UserID", ИдентификаторыПользователей);
	
КонецПроцедуры

// Дополняет переменные метрики Ошибка
//
// Параметры:
//  Переменные	 - Структура - переменные метрики Возможно Неопределено
//
Процедура ДополнитьПеременныеМетрики_Ошибка(Переменные, ТекстОшибки)
	
	Если Не ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Переменные) Тогда
		
		Переменные.Вставить("Ошибка", ТекстОшибки);
		
	Иначе
		
		Переменные = Новый Структура;
		Переменные.Вставить("Ошибка", ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

// Добавляет переменную "ТиповойМодуль" (см. Метрика_ЗначениеПеременнойТиповойМодуль)
//
// Параметры:
//  Переменные - Соответствие, Структура - переменные метрики
//
Процедура ДополнитьПеременныеМетрики_ТиповойМодуль(Переменные)
	
	Если Переменные = Неопределено Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	ТиповойМодуль = Метрика_ЗначениеПеременнойТиповойМодуль();
	Переменные.Вставить("ТиповойМодуль", ТиповойМодуль);
	
КонецПроцедуры

// Добавляет переменные с описанием типа электронного документа
//
// Параметры:
//  Переменные	 - Соответствие, Структура	 - переменные метрики
//  ФорматЭД - Структура - см. Контракт_ФорматЭлектронногоДокумента
//
Процедура ДополнитьПеременныеМетрики_ТипЭлектронногоДокумента(Переменные, ФорматЭД)
	
	Если Переменные = Неопределено Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	Переменные.Вставить("TypeNamedId", ФорматЭД.ИмяТипа);
	Переменные.Вставить("Function", ФорматЭД.ФункцияДокумента);
	Переменные.Вставить("Version", ФорматЭД.ВерсияФормата);
	
КонецПроцедуры

// Добавляет переменные с описанием учетного документа
//  * ТипУчетногоДокумента - Строка - XML-представление типа учетного документа
//  * ТипыОснованийУчетногоДокумента - Массив из Строка - XML-представления типов документов-оснований учетного документа
//  * КоличествоОснованийУчетногоДокумента - Число - количество документов-оснований
//
// Параметры:
//  Переменные - Соответствие, Структура - переменные метрики
//  ФорматЭД - Структура - см. Контракт_ФорматЭлектронногоДокумента
//
Процедура ДополнитьПеременныеМетрики_ОписаниеУчетногоДокумента(Переменные, СсылкаНаОбъект)
	
	Если Переменные = Неопределено Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	ТипДанных = XMLТипЗнч(СсылкаНаОбъект);
	ТипУчетногоДокумента = "null";
	Если ТипДанных <> Неопределено Тогда
		ТипУчетногоДокумента = ТипДанных.ИмяТипа;
	КонецЕсли;
	
	ОснованияДокументаУчета = МенеджерИнтеграции_ОснованияДокументаУчета(СсылкаНаОбъект);
	
	ТипыОснований = Новый Массив;
	
	Для Каждого ДокументОснование Из ОснованияДокументаУчета Цикл
		
		ТипДанных = XMLТипЗнч(ДокументОснование);
		ТипОснования = "null";
		Если ТипДанных <> Неопределено Тогда
			ТипОснования = ТипДанных.ИмяТипа;
		КонецЕсли;
		
		Если ТипыОснований.Найти(ТипОснования) = Неопределено Тогда
			ТипыОснований.Добавить(ТипОснования);
		КонецЕсли;
		
	КонецЦикла;
	
	Переменные.Вставить("ТипУчетногоДокумента", ТипУчетногоДокумента);
	Переменные.Вставить("ТипыОснованийУчетногоДокумента", ТипыОснований);
	Переменные.Вставить("КоличествоОснованийУчетногоДокумента", ОснованияДокументаУчета.Количество());
	
КонецПроцедуры

// Добавляет переменные идентификаторы электронного документа
//
// Параметры:
//  Переменные - Соответствие, Структура - переменные метрики
//  ИдентификаторыЭД - Структура - см. Контракт_Идентификаторы
//
Процедура ДополнитьПеременныеМетрики_ИдентификаторыЭлектронногоДокумента(Переменные, ИдентификаторыЭД)
	
	Если Переменные = Неопределено Тогда
		Переменные = Новый Соответствие;
	КонецЕсли;
	
	ИдентификаторыЗаполнены = ЗначениеЗаполнено(ИдентификаторыЭД.DocumentId);
	
	Если Не ИдентификаторыЗаполнены Тогда
		Возврат;
	КонецЕсли;
	
	Переменные.Вставить("BoxId", АдресЯщикаВИдентификатор(ИдентификаторыЭД.BoxId));
	Переменные.Вставить("LetterId", ИдентификаторыЭД.LetterId);
	Переменные.Вставить("DocumentId", ИдентификаторыЭД.DocumentId);
	
КонецПроцедуры

// Добавляет произвольные параметры в переменные метрик.
// Значения параметров преобразуются в XML-представления.
//
// Параметры:
//  Переменные - Структура, Соответствие - коллекция переменных
//  ДопПараметры - Структура, Соответствие - добавляемые параметры
//
Процедура ДополнитьПеременныеМетрики_ПроизвольныеПараметры(Переменные, ДопПараметры)
	
	Если НЕ ЗначениеЗаполнено(ДопПараметры) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из ДопПараметры Цикл
		
		Ключ = КлючЗначение.Ключ;
		Значение = КлючЗначение.Значение;
		
		Переменные.Вставить(Ключ, Значение);
		
	КонецЦикла;
	
КонецПроцедуры

