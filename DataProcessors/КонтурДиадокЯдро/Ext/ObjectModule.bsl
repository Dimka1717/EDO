// Получает сводную информацию о контексте сеанса
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - Строка
//   * Значение - Число, Булево
//  Ключи:
//   # КоличествоЯщиков - Число - Количество ящиков в контексте сеанса пользователя
//   # КоличествоСессий - Число - Количество открытых сессий (полученных токенов доступа)
//   # КоличествоСертификатов - Число - Количество уникальных отпечатков сертификатов
//   # КоличествоПользователей - Число - Количество уникальных UserId
//   # oidc/device_flow - Булево - (Необязательный) Истина, если есть хотя бы один пользователь вошел через портал
//   # dd_auth/password - Булево - (Необязательный) Истина, если есть хотя бы один пользователь вошел по паролю
//   # dd_auth/certificate - Булево - (Необязательный) Истина, если есть хотя бы один пользователь вошел по сертификату
//   # dd_auth/unknown - Булево - (Необязательный) Истина, если способ получения токена неизвестен.
//                                Используется в методах создания контекста из ПМ.
//
Функция Метрика_СводнаяИнформацияКонтекстаСеанса()
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	УникальныеСессии = Новый Массив;
	УникальныеОтпечатки = Новый Массив;
	УникальныеПользователи = Новый Массив;
	
	Результат = Новый Соответствие;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		Сессия = Элемент.Значение.Сессия;
		Сертификат = Элемент.Значение.Сертификат;
		
		Результат.Вставить(Сессия.СхемаАутентификации, Истина);
		
		Если УникальныеСессии.Найти(Сессия.Ключ) = Неопределено Тогда
			УникальныеСессии.Добавить(Сессия.Ключ);
		КонецЕсли;
		
		Если УникальныеПользователи.Найти(Сессия.Пользователь.Идентификатор) = Неопределено Тогда
			УникальныеПользователи.Добавить(Сессия.Пользователь.Идентификатор);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Сертификат)
			И УникальныеОтпечатки.Найти(Сертификат.ОтпечатокСертификата) = Неопределено Тогда
			УникальныеОтпечатки.Добавить(Сертификат.ОтпечатокСертификата);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Вставить("КоличествоЯщиков", СтрокиКонтекста.Количество());
	Результат.Вставить("КоличествоСессий", УникальныеСессии.Количество());
	Результат.Вставить("КоличествоСертификатов", УникальныеОтпечатки.Количество());
	Результат.Вставить("КоличествоПользователей", УникальныеПользователи.Количество());
	
	Возврат Результат;
	
КонецФункции

