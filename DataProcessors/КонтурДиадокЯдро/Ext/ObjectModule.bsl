	ТипыДокументов.Вставить("UcdInvoiceCorrection", 		"InvoiceCorrection");
	ТипыДокументов.Вставить("UcdInvoiceCorrectionRevision", "InvoiceCorrection");
	ТипыДокументов.Вставить("NonformalizedProforma", 		"Nonformalized");
	ТипыДокументов.Вставить("XmlAcceptanceCertificate552", 	"XmlAcceptanceCertificate");
	ТипыДокументов.Вставить("TovTorg", 						"XmlTorg12");
	
	ТипыКонтентов.Вставить("UtdInvoice", 					"utd");
	ТипыКонтентов.Вставить("UtdInvoiceRevision", 			"utd");
	ТипыКонтентов.Вставить("UtdAcceptanceCertificate", 		"utd");
	ТипыКонтентов.Вставить("UtdTorg12", 					"utd");
	ТипыКонтентов.Вставить("UcdInvoiceCorrection", 			"ucd");
	ТипыКонтентов.Вставить("UcdInvoiceCorrectionRevision", 	"ucd");
	ТипыКонтентов.Вставить("NonformalizedProforma", 		"");
	ТипыКонтентов.Вставить("XmlAcceptanceCertificate552", 	"rezru");
	ТипыКонтентов.Вставить("TovTorg", 						"tovtorg");
	
	Результат = Новый Структура("ТипыДокументов, ТипыКонтентов", ТипыДокументов, ТипыКонтентов);
	
