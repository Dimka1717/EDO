// Проверяет, что электронный документ является передаточным документом и счетом-фактурой.
//
// Параметры:
//  ТипЭД - Структура - Тип электронного документа (см. Документ.Тип)
// 
// Возвращаемое значение:
//  Булево - Истина, если это УПД с функцией СЧФДОП.
//
Функция Документы_ЭтоУниверсальныйПередаточныйДокумент(ТипЭД) Экспорт
	
	ТипДокумента = ТипЭД.ТипДокумента;
	ФункцияДокумента = Документы_ФункцияДокументаДляХранения(ТипЭД.ФункцияДокумента);
	
	ЭтоУПД = (ТипДокумента = Тип_УПД() Или ТипДокумента = Тип_ИсправлениеУПД());
	
	Результат = (ЭтоУПД И ФункцияДокумента = Функция_СЧФДОП());
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что электронный документ является счетом-фактурой.
//
// Параметры:
//  ТипЭД - Структура - Тип электронного документа (см. Документ.Тип)
// 
// Возвращаемое значение:
//  Булево - Истина, если это СФ или УПД с функцией СЧФ.
//
Функция Документы_ЭтоСчетФактура(ТипЭД) Экспорт
	
	ТипДокумента = ТипЭД.ТипДокумента;
	ФункцияДокумента = ТипЭД.ФункцияДокумента;
	
	ЭтоУПД = (ТипДокумента = Тип_УПД() Или ТипДокумента = Тип_ИсправлениеУПД());
	ЭтоСФ = (ТипДокумента = Тип_СФ() Или ТипДокумента = Тип_ИсправлениеСФ());
	
	Результат = Ложь;
	
	Если ЭтоУПД И ФункцияДокумента = Функция_СЧФ()
		Или ЭтоСФ Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что электронный документ является передаточным документом.
//
// Параметры:
//  ТипЭД - Структура - Тип электронного документа (см. Документ.Тип)
// 
// Возвращаемое значение:
//  Булево - Истина, если это накладная, акт или УПД с функцией ДОП.
//
Функция Документы_ЭтоПередаточныйДокумент(ТипЭД) Экспорт
	
	Результат = Ложь;
	
	ТипДокумента = ТипЭД.ТипДокумента;
	ФункцияДокумента = ТипЭД.ФункцияДокумента;
	
	ЭтоНакладная = (ТипДокумента = Тип_Накладная());
	ЭтоАктОбОказанииУслуг = (ТипДокумента = Тип_АктОбОказанииУслуг());
	ЭтоНакладнаяРБ = (ТипДокумента = Тип_НакладнаяРеспубликаБеларусь());
	
	ЭтоУПД = (ТипДокумента = Тип_УПД() Или ТипДокумента = Тип_ИсправлениеУПД());
	ЭтоПередаточныйДокумент = (ЭтоНакладная
		Или ЭтоАктОбОказанииУслуг
		Или ЭтоНакладнаяРБ);
	
	Если ЭтоУПД И ФункцияДокумента = Функция_ДОП()
		Или ЭтоПередаточныйДокумент Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
