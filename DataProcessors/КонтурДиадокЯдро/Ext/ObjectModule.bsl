// Получает описание сертификата
//
// Параметры:
//  ДанныеСертификата -  - 
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//   * ДатаВыдачи - Дата - дата выдачи
//   * ИНН - Строка - ИНН владельца
//   * КПП - Строка - КПП владельца
//   * Издатель - Строка - Наименование удостоверяющего центра
//   * ОрганизацияИздателя - Строка - Наименование организации УЦ
//   * Наименование - Строка - Представление сертификата
//   * Организация - Строка - Наименование организации
//   * СрокДействия - Дата - срок действия сертификата
//   * Тип - Строка - тип сертификата (ФЛ/ЮЛ/...)
//   * ЭтоКЭП - Булево - Истина, если это сертификат квалифицированной электронной подписи
//
Функция Сертификаты_ОписаниеСертификата(ДанныеСертификата) Экспорт
	
	Если ИспользоватьВнешнююКриптографию() Тогда
		
		Результат = ВнешниеСервисы_ОписаниеСертификата(ДанныеСертификата);
		
	Иначе
		
		Результат = МенеджерКриптографии_ОписаниеСертификата(ДанныеСертификата);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Сертификаты_СертификатВBase64(ОтпечатокСертификата) Экспорт
	
	Попытка
		
		ПараметрыСобытия = Новый Структура;
		ПараметрыСобытия.Вставить("ОтпечатокСертификата", ОтпечатокСертификата);
		Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПолучитьСертификатВBase64", ПараметрыСобытия);
		
		Если Результат = Неопределено Тогда
			СвойстваСертификата = Сертификаты_ДанныеСертификата(ОтпечатокСертификата);
			Результат = Base64Строка(СвойстваСертификата.ДвоичныеДанные);
		КонецЕсли;
		
	Исключение
		
		ВидОперации		= "Получение сертификата";
		ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения	= Общее_ПодставитьПараметрыВСтроку(НСтр("ru = '""Не удалось получить сертификат с отпечатком ""%1""'"), 
													ОтпечатокСертификата);
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
		
		ВызватьИсключение;
		
	КонецПопытки;

	Возврат Результат;
	
КонецФункции

Функция Сертификаты_ПредставлениеПодписанта(Сертификат, ВыводитьОрганизацию = Истина) Экспорт
	
	Результат = "";
	
	Если НЕ ЗначениеЗаполнено(Сертификат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ВыводитьОрганизацию 
		И ЗначениеЗаполнено(Сертификат.Организация) Тогда
		
		Результат = Результат + Сертификат.Организация + ", ";
		
	КонецЕсли;
	
	Результат = Результат + Сертификат.Наименование;
	
	Возврат Результат;
	
КонецФункции

