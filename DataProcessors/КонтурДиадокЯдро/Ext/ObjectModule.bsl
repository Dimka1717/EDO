Функция ВнутренниеДокументы_ПакетыНаОтправку(Параметры, ОтключитьПроверкуОтправленных = Ложь)
	
	Результат = Новый_СписокДокументов();
	
	Период = Новый СтандартныйПериод(Параметры.НачалоПериода, Параметры.КонецПериода);
	Организация = Неопределено;
	Если Параметры.ВключитьОтборПоОрганизации Тогда
		Организация = Параметры.ОтборПоОрганизации;
	КонецЕсли;
	
	ВидыПакетов = Параметры.МассивВыбранныхВидов;
	
	СвязанныеПодразделения = ВнутренниеДокументыСлужебный_НастройкиОтправки(Организация);
	
	Если Не ЗначениеЗаполнено(СвязанныеПодразделения) Тогда
		Возврат Результат;
	КонецЕсли;
	
	МенеджерВТ = ВнутренниеДокументыСлужебный_ПодготовитьОбщиеТаблицы(СвязанныеПодразделения);
	ИменаТаблиц = ВнутренниеДокументыСлужебный_ПодготовитьТаблицыПакетов(МенеджерВТ, Период, ВидыПакетов);
	
	Если Не ЗначениеЗаполнено(ИменаТаблиц) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Если ОтключитьПроверкуОтправленных Тогда
		
		ХранениеДанных.СписокНаОтправку_ПодготовитьПустуюТаблицуОтправленныеДокументы(МенеджерВТ);
		
	Иначе
		
		ВидыПакетов = Списки_ТаблицаИспользуемыхВидовПакетов();
		ХранениеДанных.СписокНаОтправку_ПодготовитьОтправленныеДокументы(МенеджерВТ, ВидыПакетов);
		
	КонецЕсли;
	
	Для Каждого Элемент Из ИменаТаблиц Цикл
		
		ИмяТаблицы = Элемент.Значение;
		ВидПакетаID = Элемент.Представление;
		ОписаниеВидаПакета = Списки_ОписаниеВидаПакета(ВидПакетаID);
		
		Попытка
			Данные = ВнутренниеДокументыСлужебный_ДанныеДляОтправки(МенеджерВТ, ИмяТаблицы, ВидПакетаID);
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(
				"Не удалось получить данные из таблицы %1 для формирования пакетов %2 по причине:
				|%3",
				ИмяТаблицы,
				ВидПакетаID,
				КраткоеПредставлениеОшибки(Ошибка)
			);
			
			Ошибка_Обработать("СписокНаОтправку.ВнутренниеДокументы", Ошибка, , ТекстСообщения);
			
			Продолжить;
			
		КонецПопытки;
		
		Пока Данные.Следующий() Цикл
			
			СтрокаСписка = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаСписка, Данные);
			СтрокаСписка.Контрагент = Данные.Организация;
			СтрокаСписка.Подразделение = Данные.ПодразделениеОтправитель;
			СтрокаСписка.ПодразделениеОтправитель = Данные.ПодразделениеОтправитель;
			СтрокаСписка.ПодразделениеПолучатель = Данные.ПодразделениеПолучатель;
			СтрокаСписка.ТребуемоеДействие = "Отправить пакет";
			СтрокаСписка.Направление = Перечисление_Направления().Внутреннее;
			СтрокаСписка.ВидПакета = ВидПакетаID;
			
			Если ЗначениеЗаполнено(ОписаниеВидаПакета) Тогда
				СтрокаСписка.ВидПакета = ОписаниеВидаПакета.Наименование;
				СтрокаСписка.Шаблон = (ОписаниеВидаПакета.Шаблон = Истина);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	МенеджерВТ.Закрыть();
	
	Возврат Результат;
	
КонецФункции

// Формирует список отправляемых видов пакетов в разрезе организаций и подразделений
//
// Параметры:
//  ОтборОрганизация - СправочникСсылка - (Необязательный) Ссылка на организацию 1С для отбора
// 
// Возвращаемое значение:
//  ТаблицаЗначений - содержит колонки:
//    * Организация1С - СправочникСсылка - Сущность, сопоставленная с ящиком в Диадоке
//    * Подразделение1С - СправочникСсылка - Сущность, сопоставленная с подразделением в Диадоке
//    * ИдентификаторЯщика - Строка - идентификатор ящика организации в Диадоке (в формате уникального идентификатора)
//    * ВидПакетаID - Строка - идентификатор отправляемого вида пакета
//
Функция ВнутренниеДокументыСлужебный_НастройкиОтправки(Знач ОтборОрганизация = Неопределено)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Организация1С", Справочники_ОписаниеТипаПоля("Организации"));
	Результат.Колонки.Добавить("Подразделение1С", Справочники.ТипВсеСсылки());
	Результат.Колонки.Добавить("ИдентификаторЯщика", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36)));
	Результат.Колонки.Добавить("ВидПакетаID", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(120)));
	
	КонтекстСеанса = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого ТекСтрока Из КонтекстСеанса Цикл
		
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(ТекСтрока.Ключ);
		Идентификаторы = Новый_ИдентификаторыСправочника(, ИдентификаторЯщика);
		ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(Идентификаторы);
		
		СопоставленныеОрганизации = СвойствоСтруктуры(ДанныеОрганизации, "СвязанныеСправочники");
		Если СопоставленныеОрганизации = Неопределено Тогда
			СопоставленныеОрганизации = Организации_СопоставленныеВ1С(Идентификаторы);
		КонецЕсли;
		
		Если СопоставленныеОрганизации.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОтборОрганизация) И СопоставленныеОрганизации.Найти(ОтборОрганизация) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НастройкиПакетов = ВнутренниеДокументыСлужебный_НастройкиПакетов(ДанныеОрганизации);
		Если Не ЗначениеЗаполнено(НастройкиПакетов) Тогда
			Продолжить;
		КонецЕсли;
		
		СписокПодразделений = Подразделения_СписокПодразделений(ДанныеОрганизации);
		
		Для Каждого Организация1С Из СопоставленныеОрганизации Цикл
			
			Если ЗначениеЗаполнено(ОтборОрганизация) И Организация1С <> ОтборОрганизация Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ДанныеПодразделения Из СписокПодразделений Цикл
				
				СопоставленныеПодразделения = Подразделения_СопоставленныеВ1С(ДанныеПодразделения);
				
				Для Каждого Подразделение1С Из СопоставленныеПодразделения Цикл
					
					Для Каждого ИдентификаторПакета Из НастройкиПакетов Цикл
						
						НоваяСтрока = Результат.Добавить();
						НоваяСтрока.Организация1С = Организация1С;
						НоваяСтрока.Подразделение1С = Подразделение1С;
						НоваяСтрока.ИдентификаторЯщика = ИдентификаторЯщика;
						НоваяСтрока.ВидПакетаID = ИдентификаторПакета;
						
					КонецЦикла;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВнутренниеДокументыСлужебный_НастройкиПакетов(ДанныеОрганизации)
	
	Результат = Новый Массив;
	
	НастройкиПакетов = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(ДанныеОрганизации);
	
	ВсеВидыПакетов = ПредопределенныеСписки_ВидыПакетов();
	
	Для Каждого Элемент Из НастройкиПакетов Цикл
		
		Если НЕ Элемент.ВнутреннийДО ИЛИ НЕ Элемент.ОтправлятьПакет Тогда
			Продолжить;
		КонецЕсли;
		
		БазовыйВидПакета = Элемент.ВидПакета;
		
		Результат.Добавить(БазовыйВидПакета);
		
		Для Каждого ВидПакета Из ВсеВидыПакетов Цикл
			
			Если ВидПакета.Значение.БазовыйВидПакета = БазовыйВидПакета Тогда
				Результат.Добавить(ВидПакета.Значение.ID);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Формирует временные таблицы, используемые отправки внутренних документов:
// * ВТ_УчастникиВнутреннегоДокументооборота - содержит колонки:
//    ** Организация1С - СправочникСсылка - Сущность, сопоставленная с ящиком Диадока (например, "Организации")
//    ** Подразделение1С - СправочникСсылка - Сущность, сопоставленная с подразделением Диадока (например, "Склады" или "Подразделения")
// * ВТ_НастройкиВнутреннегоДокументооборота - содержит колонки:
//    ** Организация1С - СправочникСсылка - Сущность, сопоставленная с ящиком Диадока (например, "Организации")
//    ** ВидПакета - Строка - Идентификатор отправляемого вида пакета
// * ВТ_ОтправленныеДокументы - содержит колонки:
//    ** Документ - ДокументСсылка - учетный документ
//    ** ВидПакета - Строка - Идентификатор вида пакета
//    ** КатегорияПакета - Строка - Идентификатор категории пакета
//
// Параметры:
//  СвязанныеПодразделения - ТаблицаЗначений - содержит список сущностей 1С, сопоставленных с ящиками и подразделениями Диадока
//
// Возвращаемое значение:
//  МенеджерВременныхТаблиц - хранилище временных таблиц
//
Функция ВнутренниеДокументыСлужебный_ПодготовитьОбщиеТаблицы(СвязанныеПодразделения)
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.Организация1С КАК Организация1С,
	|	Т.Подразделение1С КАК Подразделение1С
	|ПОМЕСТИТЬ ВТ_УчастникиВнутреннегоДокументооборота
	|ИЗ
	|	&СвязанныеПодразделения КАК Т
	|;
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.Организация1С КАК Организация1С,
	|	Т.ВидПакетаID КАК ВидПакета
	|ПОМЕСТИТЬ ВТ_НастройкиВнутреннегоДокументооборота
	|ИЗ
	|	&СвязанныеПодразделения КАК Т";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.УстановитьПараметр("СвязанныеПодразделения", СвязанныеПодразделения);
	Запрос.ВыполнитьПакет();
	
	Возврат МенеджерВТ;
	
КонецФункции

// Формирует таблицы отправляемых пакетов
//
// Параметры:
//  МенеджерВТ - МенеджерВременныхТаблиц - см. ВнутренниеДокументыСлужебный_ПодготовитьОбщиеТаблицы
//  Период - СтандартныйПериод - период выборки данных
//  ВидыПакетов - Массив из Структура - см. Списки_ОписаниеВидаПакета
// 
// Возвращаемое значение:
//  СписокЗначений - список таблиц, где значение - имя таблицы, а представление - вид пакета
//
Функция ВнутренниеДокументыСлужебный_ПодготовитьТаблицыПакетов(МенеджерВТ, Знач Период, Знач ВидыПакетов)
	
	ТаблицыПакетов = Новый СписокЗначений;
	
	Для Каждого ВидПакетаID Из ВидыПакетов Цикл
		
		Попытка
			ДобавленныеТаблицы = Интеграция_ПодготовитьДанныеДляОтправкиВнутреннихДокументов(МенеджерВТ, ВидПакетаID, Период);
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(
				"Не удалось подготовить таблицы для формирования пакетов %1 по причине:
				|%2",
				ВидПакетаID,
				КраткоеПредставлениеОшибки(Ошибка)
			);
			
			Ошибка_Обработать("СписокНаОтправку.ВнутренниеДокументы", Ошибка, , ТекстСообщения);
			
			Продолжить;
			
		КонецПопытки;
		
		Для Каждого ИмяВТ Из ДобавленныеТаблицы Цикл
			Если ЗначениеЗаполнено(ИмяВТ) Тогда
				ТаблицыПакетов.Добавить(ИмяВТ, ВидПакетаID);
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицыПакетов;
	
КонецФункции

// Формирует выборку из указанной таблицы для отправки внутренних документов
//
// Параметры:
//  МенеджерВТ - МенеджерВременныхТаблиц - хранилище временных таблиц
//  ИмяТаблицы - Строка - полное имя временной таблицы
//  ВидПакетаID - Строка - идентификатор вида пакета
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - итоговая выборка, содержит поля:
//    * ВидПакетаID - Строка - Идентификатор вида пакета
//    * Документ - ЛюбаяСсылка - учетный документ, на основании которого формируется пакет
//    * Организация - СправочникСсылка - сущность, сопоставленная с ящиком Диадока
//    * ПодразделениеОтправитель - СправочникСсылка - сущность, сопоставленная с подразделением-отправителем
//    * ПодразделениеПолучатель - СправочникСсылка - сущность, сопоставленная с подразделением-получателем
//    * НомерДокумента - Строка - номер документа
//    * ДатаДокумента - Дата - дата документа
//    * СуммаДокумента - Число - (Необязательный) сумма документа
//    * ДопРеквизит<N> - Произвольный - (Необязательный) значение для вывода в дополнительную колонку № <N>, где N - от 1 до 5
//
Функция ВнутренниеДокументыСлужебный_ДанныеДляОтправки(МенеджерВТ, Знач ИмяТаблицы, Знач ВидПакетаID)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.*,
	|	&ИдентификаторПакета КАК ВидПакетаID
	|ИЗ
	|	ИдентификаторТаблицы КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтправленныеДокументы КАК ОтправленныеДокументы
	|		ПО Т.Документ = ОтправленныеДокументы.Документ
	|			И (ОтправленныеДокументы.ВидПакетаID = &ИдентификаторПакета)
	|ГДЕ
	|	ОтправленныеДокументы.Документ ЕСТЬ NULL
	|;
	|УНИЧТОЖИТЬ ИдентификаторТаблицы";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИдентификаторТаблицы", ИмяТаблицы);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИдентификаторПакета", """" + ВидПакетаID + """");
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет()[0];
	
	ОбязательныеКолонки = Новый Массив;
	ОбязательныеКолонки.Добавить("Документ");
	ОбязательныеКолонки.Добавить("Организация");
	ОбязательныеКолонки.Добавить("ПодразделениеОтправитель");
	ОбязательныеКолонки.Добавить("ПодразделениеПолучатель");
	ОбязательныеКолонки.Добавить("НомерДокумента");
	ОбязательныеКолонки.Добавить("ДатаДокумента");
	
	ОтсутствующиеКолонки = Новый Массив;
	Для Каждого ИмяКолонки Из ОбязательныеКолонки Цикл
		Если РезультатЗапроса.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
			ОтсутствующиеКолонки.Добавить(ИмяКолонки);
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ОтсутствующиеКолонки) Тогда
		
		КолонкиСтрокой = СоединитьСтроку(ОтсутствующиеКолонки, ", ");
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"ВнутренниеДокументы: ВидПакета = %1, ошибка получения данных для отправки:
			|Таблица %2 не содержит обязательные поля (%3)",
			ВидПакетаID,
			ИмяТаблицы,
			КолонкиСтрокой
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Возврат Выборка;
	
КонецФункции

// Обработчик события "ПодготовитьДанныеДляОтправки".
// - Подключаемый модуль вызывается один раз (только перед вызовом типового обработчика)
// - Типовой обработчик не вызывается, если в ПМ сброшен параметр-флаг "СтандартнаяОбработка"
//
// Параметры:
//  МенеджерВТ - МенеджерВременныхТаблиц - хранилище временных таблиц
//  ВидПакета - Строка - идентификатор вида пакета
//  Период - СтандартныйПериод - Период выборки данных для отправки
// 
// Возвращаемое значение:
//  Массив из Строка - Имена временных таблиц с данными для отправки указанного вида пакетов
//
Функция Интеграция_ПодготовитьДанныеДляОтправкиВнутреннихДокументов(МенеджерВТ, Знач ВидПакета, Знач Период)
	
	ДобавленныеТаблицы = Новый Массив;
	
	ИмяСобытия = "ПодготовитьДанныеДляОтправкиВнутреннихДокументов";
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("СтандартнаяОбработка", Истина);
	ПараметрыПМ.Вставить("НачалоПериода", Период.ДатаНачала);
	ПараметрыПМ.Вставить("КонецПериода", Период.ДатаОкончания);
	ПараметрыПМ.Вставить("ВидПакета", ВидПакета);
	ПараметрыПМ.Вставить("МенеджерВременныхТаблиц", МенеджерВТ);
	
	РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(ИмяСобытия, ПараметрыПМ);
	Если ЗначениеЗаполнено(РезультатПМ) Тогда
		ДополнитьМассив(ДобавленныеТаблицы, РезультатПМ);
	КонецЕсли;
	
	Если ПараметрыПМ.СтандартнаяОбработка
		И ЕстьИнтеграционныйМодуль() Тогда
		
		МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
		РезультатИМ = МенеджерИнтеграции.ВнутренниеДокументы_ПодготовитьДанныеДляОтправки(МенеджерВТ, ВидПакета, Период);
		ДополнитьМассив(ДобавленныеТаблицы, РезультатИМ);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		ДобавленныеТаблицы
	);
	
	Возврат ДобавленныеТаблицы;
	
КонецФункции

Функция СписокДокументов_НовыеПакетыНаОтправку(Параметры)
	
	Попытка
		
		Результат = СписокДокументов_ПакетыНаОтправку(Параметры);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияСписокНаОтправку(),
			"ПолучитьСписокНовыхПакетов",
			Ошибка
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ПакетыНаОтправку(Параметры)
	
	Результат = Новый_СписокДокументов();
	
	Если Модуль_ПМ(ЭтотОбъект) = Неопределено И Модуль_ИМ(ЭтотОбъект) = Неопределено Тогда
		
		ВидОперации = "Получение списка пакетов на отправку";
		ТекстСообщения = "Текущая версия конфигурации не поддерживается. 
			|В разделе ""Расширенные настройки"" 
			|укажите интеграционный или подключаемый модуль.";
		
		Ошибка_Обработать(ВидОперации, , , ТекстСообщения);
		
		Возврат Результат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Для Каждого Элемент Из Параметры Цикл
		Запрос.Параметры.Вставить(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Для Каждого ВидПакета Из МассивВидовПакетов() Цикл
		Запрос.УстановитьПараметр("ВидПакетаID_" + ВидПакета.Идентификатор, ВидПакета.Ссылка);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТаблицаВидовПакетов", Списки_ТаблицаИспользуемыхВидовПакетов());
	Запрос.УстановитьПараметр("ТаблицаВидовДокументов", ТаблицаСвойстваТипОснованияПоВидуДокумента());
	
	ДополненныеПараметры = ХранениеДанных_ДополненныеПараметрыНаОтправку(Запрос.Параметры);
	
	МассивВидовПакетов = СвойствоСтруктуры(Параметры, "МассивВыбранныхВидов", Неопределено);
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ПараметрыЗапроса", Запрос.Параметры);
	ПараметрыСобытия.Вставить("МассивВидовПакетов", МассивВидовПакетов);
	
	ТекстЗапроса = ПодключаемыйМодуль_ОбработатьСобытие("ПолучитьТекстЗапросаДляСпискаПакетовНаОтправкуПоМассивуВидовПакетов", ПараметрыСобытия);
	
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
		
		Запрос.Текст = ТекстЗапроса;
		Выборка = Запрос.Выполнить().Выбрать();
		
		Организации1СИзКонтекста = Новый Массив;
		
		СписокОрганизацийПоКонтексту = Организации_СписокОрганизацийПоКонтексту(Ложь);
		Для Каждого Организация Из СписокОрганизацийПоКонтексту Цикл
			СвязанныеСправочники = Организации_МассивСопоставленныхВ1С(Организация);
			Для Каждого СвязанныйСправочник Из СвязанныеСправочники Цикл
				Организации1СИзКонтекста.Добавить(СвязанныйСправочник);
			КонецЦикла;
		КонецЦикла;
		
		ОтборПоОрганизации = СвойствоСтруктуры(Параметры, "ВключитьОтборПоОрганизации") = Истина;
		ОтборПоКонтрагенту = СвойствоСтруктуры(Параметры, "ВключитьОтборПоКонтрагенту") = Истина;
		
		ВключенаМаршрутизацияПоПодразделениям = ЗначениеНастройки_ИспользоватьСопоставлениеПодразделений();
		
		Пока Выборка.Следующий() Цикл
			
			//Для совместимости со старыми ПМ - отбор по организации и контрагенту дополнительно тут.
			Если Организации1СИзКонтекста.Найти(Выборка.Организация) <> Неопределено Тогда 
				
				СтрокаУдовлетворяетОтбору = СписокДокументов_СтрокаДокументаУдовлетворяетОтбору(Выборка, Параметры, ОтборПоОрганизации, ОтборПоКонтрагенту);
				Если НЕ СтрокаУдовлетворяетОтбору Тогда
					Продолжить;
				КонецЕсли;
				
				ВидПакета = Списки_ОписаниеВидаПакета(Выборка.ВидПакетаID);
				
				СтрокаСписка = Результат.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаСписка, Выборка);
				
				СтрокаСписка.Направление = Перечисление_Направления().Исходящее;
				СтрокаСписка.ТребуемоеДействие = "Отправить пакет";
				
				Если ЗначениеЗаполнено(ВидПакета) Тогда
					СтрокаСписка.ВидПакета = ВидПакета.Наименование;
					СтрокаСписка.Шаблон = (ВидПакета.Шаблон = Истина);
				КонецЕсли;
				
				Если НЕ ВключенаМаршрутизацияПоПодразделениям Тогда
					СтрокаСписка.Подразделение = Организации_ОсновноеПодразделения(СтрокаСписка.Организация);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура СписокДокументов_УстановитьОтборНаСписок(СписокДокументов, Параметры)
	
	Если ЗначениеЗаполнено(СписокДокументов) Тогда
		
		ОтборПоОрганизации = СвойствоСтруктуры(Параметры, "ВключитьОтборПоОрганизации") = Истина;
		ОтборПоКонтрагенту = СвойствоСтруктуры(Параметры, "ВключитьОтборПоКонтрагенту") = Истина;
		
		Если ОтборПоОрганизации ИЛИ ОтборПоКонтрагенту Тогда
		
			ИндексСтроки = СписокДокументов.Количество() - 1;
			Пока ИндексСтроки >= 0 Цикл
				
				СтрокаСписка		 = СписокДокументов[ИндексСтроки];
				СтрокаПрошлаОтбор	 = СписокДокументов_СтрокаДокументаУдовлетворяетОтбору(СтрокаСписка, Параметры, ОтборПоОрганизации, ОтборПоКонтрагенту);
				
				Если НЕ СтрокаПрошлаОтбор Тогда
					СписокДокументов.Удалить(СтрокаСписка);
				КонецЕсли;
				
				ИндексСтроки = ИндексСтроки -1 ;
			КонецЦикла;
		
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция СписокДокументов_СтрокаДокументаУдовлетворяетОтбору(СтрокаСписка, Параметры, ОтборПоОрганизации, ОтборПоКонтрагенту)
	
	Результат = Истина;
	
	Если ОтборПоОрганизации Тогда
		Результат = СписокДокументов_ЗначениеУдовлетворяетОтбору(Параметры.ОтборПоОрганизации, СтрокаСписка.Организация);
	КонецЕсли;
	
	Если Результат И ОтборПоКонтрагенту Тогда
		Результат = СписокДокументов_ЗначениеУдовлетворяетОтбору(Параметры.ОтборПоКонтрагенту, СтрокаСписка.Контрагент);
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции 

Функция СписокДокументов_ЗначениеУдовлетворяетОтбору(ЗначениеОтбора, Знач ЗначениеДляПроверки)

	Результат = Истина;
	
	Если ЗначениеЗаполнено(ЗначениеОтбора) Тогда
		Результат = ЗначениеДляПроверки = ЗначениеОтбора;
	ИначеЕсли ЗначениеЗаполнено(ЗначениеДляПроверки) Тогда
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура СписокДокументов_ДобавитьДокументыВПакетыНаОтправку(СтрокаСписка) Экспорт
	
	РазворачиватьПоДокументам				= ОбщиеНастройки_Прочитать("РазворачиватьПакетыНаОтправкуПоДокументам");
	ПоказыватьКоличествоДокументовВСписке	= ОбщиеНастройки_Прочитать("ПоказыватьКоличествоДокументовВСписке");
	
	Если РазворачиватьПоДокументам Тогда
		
		Если ПустаяСтрока(СтрокаСписка.НомераДокументовПакета) Тогда
			СписокДокументов_РазворачиватьПоДокументам(СтрокаСписка);
		КонецЕсли;

	ИначеЕсли ПоказыватьКоличествоДокументовВСписке Тогда
		
		Если СтрокаСписка.КоличествоДокументовПакета = 0 Тогда
			СписокДокументов_КоличествоДокументовВСписке(СтрокаСписка);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СписокДокументов_ЗаполнитьСодержимоеПакетаПоВидуПакета(СписокДокументов)
	
	РазворачиватьПоДокументам = ОбщиеНастройки_Прочитать("РазворачиватьПакетыНаОтправкуПоДокументам");
	
	Если Не РазворачиватьПоДокументам Тогда
		ВидыПакетовСписка = СписокДокументов.ВыгрузитьКолонку("ВидПакета");
		СписокДокументов.ЗагрузитьКолонку(ВидыПакетовСписка, "СодержимоеПакета");		
	КонецЕсли;
	
КонецПроцедуры

Процедура СписокДокументов_РазворачиватьПоДокументам(СтрокаСписка)
	
	Пакет = СписокДокументов_ПакетБезКонтентаДокументов(СтрокаСписка);

	СодержимоеПакета		= "";
	НомераДокументовПакета	= "";
	ДатыДокументовПакета	= "";
	СуммыДокументовПакета	= "";
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		Тип = Документ.Тип;
		
		Если Тип.Формализованный Тогда
			
			СодержимоеПакета = СодержимоеПакета + Символы.ПС + Тип.Представление;
			
			ФункцияXML = Документы_ФункцияДокументаДляXML(Тип.ТипДокумента, Тип.ФункцияДокумента);
			
			Если ЗначениеЗаполнено(ФункцияXML) Тогда
				СодержимоеПакета = СодержимоеПакета + ", " + ФункцияXML;
			КонецЕсли;	 
			
		Иначе
			СодержимоеПакета = СодержимоеПакета + Символы.ПС + Документ.ИмяФайла;
		КонецЕсли;
		
		НомераДокументовПакета		= НомераДокументовПакета	+ Символы.ПС + Документ.Реквизиты.Номер;
		ДатыДокументовПакета		= ДатыДокументовПакета		+ Символы.ПС + Формат(Документ.Реквизиты.Дата, "ДФ=dd.MM.yyyy");
		СуммыДокументовПакета		= СуммыДокументовПакета		+ Символы.ПС + Формат(Документ.Реквизиты.Сумма, "ЧДЦ=2");
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(НомераДокументовПакета)
		ИЛИ ЗначениеЗаполнено(ДатыДокументовПакета)
		ИЛИ ЗначениеЗаполнено(СуммыДокументовПакета) Тогда
		
		СтрокаСписка.СодержимоеПакета		= СокрЛП(СодержимоеПакета);
		СтрокаСписка.НомераДокументовПакета	= СокрЛП(НомераДокументовПакета);
		СтрокаСписка.ДатыДокументовПакета	= СокрЛП(ДатыДокументовПакета);
		СтрокаСписка.СуммыДокументовПакета	= СокрЛП(СуммыДокументовПакета);
		
	Иначе
		
		СтрокаСписка.СодержимоеПакета		= СтрокаСписка.ВидПакета;
		СтрокаСписка.НомераДокументовПакета	= СтрокаСписка.НомерДокумента;
		СтрокаСписка.ДатыДокументовПакета	= Формат(СтрокаСписка.ДатаДокумента, "ДФ=dd.MM.yyyy");
		СтрокаСписка.СуммыДокументовПакета	= Формат(СтрокаСписка.СуммаДокумента, "ЧДЦ=2");
		
	КонецЕсли;
	
КонецПроцедуры	

Процедура СписокДокументов_КоличествоДокументовВСписке(СтрокаСписка)
	
	Пакет = СписокДокументов_ПакетБезКонтентаДокументов(СтрокаСписка);
	КоличествоДокументовПакета = Пакет.Документы.Количество();
	
	СтрокаСписка.КоличествоДокументовПакета = КоличествоДокументовПакета;
	
КонецПроцедуры

Функция СписокДокументов_ПакетБезКонтентаДокументов(СтрокаСписка)
	
	Если ЗначениеЗаполнено(СтрокаСписка.Пакет) Тогда
		Результат = Пакеты_ПакетИзДанныхСтрокиСписка(СтрокаСписка);
	Иначе
		Результат = Пакеты_ПодготовитьНовыйПакет(СтрокаСписка, Истина);
	КонецЕсли;
	
	Пакеты_ДобавитьВПакетДокументыСДиска(Результат, СтрокаСписка.Ключ);
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ОбновитьДанныеСтрокиПакетаНаОтправку(СтрокаСписка, ОписаниеСвязанногоПакета = Неопределено) Экспорт
	
	Результат = Неопределено;
	
	ПереотправляемыйПакет = Контракт_ИдентификаторыПакета();
	ПереотправляемыйПакет.BoxId		= СтрокаСписка.BoxId;
	ПереотправляемыйПакет.LetterId	= СтрокаСписка.LetterId;
	ПереотправляемыйПакет.ПакетЭДО	= СтрокаСписка.Пакет;
	
	Если ОписаниеСвязанногоПакета = Неопределено Тогда
		ОписаниеСвязанногоПакета = ХранениеДанных_ОсновнойСвязанныйПакет(ПереотправляемыйПакет);
	КонецЕсли;
	
	Если ОписаниеСвязанногоПакета <> Неопределено Тогда
		СтрокаСписка.Документ 		= ОписаниеСвязанногоПакета.ДокументУчета;
		СтрокаСписка.ВидПакетаID 	= ОписаниеСвязанногоПакета.ИдентификаторВида;
	КонецЕсли;
	
	Данные = СписокДокументов_ПерезаполненнаяСтрока(СтрокаСписка);
	
	Если ЗначениеЗаполнено(Данные) Тогда
		
		ПакетОтправлен = ЗначениеЗаполнено(СтрокаСписка.LetterId);
		ПакетПодготовлен = НЕ ПакетОтправлен И ЗначениеЗаполнено(СтрокаСписка.Пакет);
		
		Если ПакетПодготовлен Тогда
			
			ПерезаполняемыйПакет = Пакеты_СохраненныйПакетПоСтроке(СтрокаСписка);
			ПерезаполняемыйПакет.СлужебнаяИнформация.Вставить("ОшибкиОтправки", "");
			Пакеты_Сохранить(ПерезаполняемыйПакет);
			
			Ключ = Новый_КлючИдентификатораСтроки(ПерезаполняемыйПакет.ДокументУчета, ПерезаполняемыйПакет.ИдентификаторВида);
			КэшОшибокСтрокСписка_Удалить(Ключ);
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаСписка, Данные);
		СтрокаСписка.Пакет		= Неопределено;
		СтрокаСписка.LetterId	= "";
		
		Результат = Пакеты_ПодготовитьПакет(СтрокаСписка, Ложь);
		
		ПараметрыПереотправки = Контракт_ПараметрыПереотправкиДокумента();  
		ПараметрыПереотправки.ПереотправляемыйПакет = ПереотправляемыйПакет;
		Результат.СлужебнаяИнформация.Вставить("ПараметрыПереотправки", ПараметрыПереотправки);
		
		Если ПакетОтправлен ИЛИ ПакетПодготовлен Тогда
			СписокДокументов_ДобавитьДокументыСвязанныхПакетовПриПереотправке(Результат, СтрокаСписка);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Добавляет в основной пакет документы из связанного (вложенного) пакета при переотправке.
//
// Параметры:
//  Пакет		 - Структура - заполненный основной пакет ( см. Контракт_Пакет)
//  СтрокаСписка - СтрокаТаблицыЗначений - строка списка документов
//
Процедура СписокДокументов_ДобавитьДокументыСвязанныхПакетовПриПереотправке(Пакет, СтрокаСписка)
	
	ПлагинСчетВПакетУстановлен = КонтурПлагины_ПлагинСчетВПакетУстановлен();
	
	Если ПлагинСчетВПакетУстановлен Тогда
		Возврат;
	КонецЕсли;
	
	ПереотправляемыйПакет = Пакет.СлужебнаяИнформация.ПараметрыПереотправки.ПереотправляемыйПакет;
	
	СвязанныеПакеты = ХранениеДанных_СвязанныеПакеты(ПереотправляемыйПакет);
	
	Если НЕ ЗначениеЗаполнено(СвязанныеПакеты) Тогда
		СвязанныеПакеты = КонтурПлагины_СчетВПакете_СвязанныеПакетыСчетов(Пакет.Отправитель.BoxId,
																		  Пакет.Получатель.BoxId,
																		  ПереотправляемыйПакет,
																		  СтрокаСписка.ДатаОтправки);
	КонецЕсли;
	
	Для Каждого ОписаниеСвязанногоПакета Из СвязанныеПакеты Цикл
		
		Если СтрокаСписка.ВидПакетаID <> ОписаниеСвязанногоПакета.ИдентификаторВида Тогда
			
			СтрокаСпискаСвязанногоПакета = Контракт_СтрокаСпискаДокументов();
	        ЗаполнитьЗначенияСвойств(СтрокаСпискаСвязанногоПакета, СтрокаСписка);			
			
			СвязанныйПакет = СписокДокументов_ОбновитьДанныеСтрокиПакетаНаОтправку(СтрокаСпискаСвязанногоПакета, ОписаниеСвязанногоПакета);
			
			Если СвязанныйПакет <> Неопределено Тогда
				
				Для Каждого Документ Из СвязанныйПакет.Документы Цикл
					Пакет.Документы.Добавить(Документ);			
				КонецЦикла;
				
				Пакет.СлужебнаяИнформация.ПараметрыОтправки.СвязанныеПакеты.Добавить(ОписаниеСвязанногоПакета);
				
			КонецЕсли;			
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Функция КонтурПлагины_СчетВПакете_СвязанныеПакетыСчетов(ОтправительBoxId, ПолучательBoxId, ИдентификаторыПакета, ДатаОтправки)
	
	Результат = Новый Массив;
	
	ПлагинСчетВПакетУстановлен = КонтурПлагины_ПлагинСчетВПакетУстановлен();
	
	Если НЕ ПлагинСчетВПакетУстановлен Тогда
		ДатаПерехода = КонтурПлагины_СчетВПакете_ДатаПерехода();
	КонецЕсли;
	
	Если ПлагинСчетВПакетУстановлен
		ИЛИ ДатаОтправки > КонецДня(ДатаПерехода) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЕстьСчета = Ложь;
	ДокументыУчетаСчетов = Новый Массив;
	ДокументыУчетаРеализаций = Новый Массив;
	
	Пакет = ХранениеДанных_ДанныеПакета(ИдентификаторыПакета);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДокументУчета = Документ.ДокументУчета;
		ТипДокумента = Документ.Тип.ТипДокумента;
		ФункцияДокумента = Документ.Тип.ФункцияДокумента;
		
		Если ТипДокумента = Тип_СчетНаОплату() Тогда
			
			ЕстьСчета = Истина;
			
			Если ЗначениеЗаполнено(ДокументУчета) Тогда
				ДокументыУчетаСчетов.Добавить(ДокументУчета);
			КонецЕсли;
			
		ИначеЕсли ФункцияДокумента = Функция_ДОП()
				ИЛИ ТипДокумента = Тип_Накладная() 
				ИЛИ ТипДокумента = Тип_АктОбОказанииУслуг() Тогда
				
			Если ЗначениеЗаполнено(ДокументУчета) Тогда
				ДокументыУчетаРеализаций.Добавить(ДокументУчета);
			КонецЕсли;	
				
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЕстьСчета
		И ДокументыУчетаСчетов.Количество() = 0 Тогда	
		ДокументыУчетаСчетов = ДокументыУчетаРеализаций;
	КонецЕсли;
	
	Если ДокументыУчетаСчетов.Количество() > 0 Тогда
		
		ВидПакетаДляСчета = КонтурПлагины_СчетВПакете_ВидПакета(ОтправительBoxId, ПолучательBoxId);
		
		Для Каждого ДокументУчета Из ДокументыУчетаСчетов Цикл
			
			ОписаниеСвязанногоПакета = Контракт_ОписаниеСвязанногоПакета();
			ОписаниеСвязанногоПакета.ИдентификаторВида = ВидПакетаДляСчета;
			ОписаниеСвязанногоПакета.ДокументУчета = ДокументУчета;
			
			Результат.Добавить(ОписаниеСвязанногоПакета);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонтурПлагины_СчетВПакете_ВидПакета(ОтправительBoxId, ПолучательBoxId)
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, ОтправительBoxId);
	ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(, ПолучательBoxId);
	ДанныеКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
	
	КатегорияПакета = "СчетНаОплату";
	Результат = НастройкиДокументов_ВидПакетаКатегории(КатегорияПакета, ДанныеОрганизации, ДанныеКонтрагента);
	
	Возврат Результат;
	
КонецФункции

// Возвращает признак того, что строка списка явялется вложенный пакет
//
// Параметры:
//  СтрокаСписка - СтрокаТаблицыЗначений - строка списка документов
// 
// Возвращаемое значение:
//  Булево - 
//
Функция СписокДокументов_ЭтоСтрокаВложенногоПакета(СтрокаСписка) Экспорт

	Результат = Истина;
	
	Если НЕ ЗначениеЗаполнено(СтрокаСписка.КлючОсновногоПакета)
		ИЛИ СтрокаСписка.КлючОсновногоПакета = СтрокаСписка.Ключ Тогда
		
		Результат = Ложь;	
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ПерезаполненнаяСтрока(СтрокаСписка)
	
	Результат = Неопределено;
	
	Запрос = СписокДокументов_ЗапросДанныеСтрокиСпискаПакетовНаОтправку(СтрокаСписка);
	
	УчетныйДокумент = СтрокаСписка.Документ;
	
	ИспользоватьНовуюМеханикуПолученияСписка = ЭтоВидПакетаВнутренний(СтрокаСписка.ВидПакетаID)
		И ЗначениеЗаполнено(УчетныйДокумент)
		И ЗначениеНастройки_ИспользоватьВнутреннийДокументооборот();
	
	Если ИспользоватьНовуюМеханикуПолученияСписка Тогда
		
		// Другая механика для получения списка на отправку по внутренним документам
		
		ПараметрыОтправки = Контракт_ПараметрыПолученияСпискаДокументов();
		ПараметрыОтправки.НачалоПериода = НачалоДня(СтрокаСписка.ДатаДокумента);
		ПараметрыОтправки.КонецПериода = КонецДня(СтрокаСписка.ДатаДокумента);
		ПараметрыОтправки.МассивВыбранныхВидов = ЗначениеВМассив(СтрокаСписка.ВидПакетаID);
		
		ОтключитьПроверкуОтправленных = Истина;
		ВнутренниеПакеты = ВнутренниеДокументы_ПакетыНаОтправку(ПараметрыОтправки, ОтключитьПроверкуОтправленных);
		
		Отбор = Новый Структура("Документ", УчетныйДокумент);
		НайденныеСтроки = ВнутренниеПакеты.НайтиСтроки(Отбор);
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			
			ОбновляемыеКолонки = Новый Массив;
			ОбновляемыеКолонки.Добавить("ВидПакетаID");
			ОбновляемыеКолонки.Добавить("Документ");
			ОбновляемыеКолонки.Добавить("Организация");
			ОбновляемыеКолонки.Добавить("Контрагент");
			ОбновляемыеКолонки.Добавить("НомерДокумента");
			ОбновляемыеКолонки.Добавить("ДатаДокумента");
			ОбновляемыеКолонки.Добавить("СуммаДокумента");
			КолонкиСтрокой = СоединитьСтроку(ОбновляемыеКолонки, ", ");
			
			Результат = Контракт_СтрокаСпискаДокументов();
			ЗаполнитьЗначенияСвойств(Результат, СтрокаСписка);
			ЗаполнитьЗначенияСвойств(Результат, НайденныеСтроки[0], КолонкиСтрокой);
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(Запрос.Текст) Тогда
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Результат = Контракт_СтрокаСпискаДокументов();
			ЗаполнитьЗначенияСвойств(Результат, СтрокаСписка);
			ЗаполнитьЗначенияСвойств(Результат, Выборка);
		КонецЕсли;
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоВидПакетаВнутренний(ВидПакета)
	
	ВидыПакетов = ПредопределенныеСписки_ВидыПакетов();
	
	Результат = ВидыПакетов.Получить(ВидПакета).ВнутреннийДО;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ЗапросДанныеСтрокиСпискаПакетовНаОтправку(СтрокаСписка)
	
	Если ЗначениеЗаполнено(СтрокаСписка.Пакет)
		ИЛИ ЗначениеЗаполнено(СтрокаСписка.LetterId) Тогда
		
		ИдентификаторыПакета = Контракт_ИдентификаторыПакета();
		ИдентификаторыПакета.BoxId		= СтрокаСписка.BoxId;
		ИдентификаторыПакета.LetterId	= СтрокаСписка.LetterId;
		ИдентификаторыПакета.ПакетЭДО	= СтрокаСписка.Пакет;
		
		ДокументУчета = ХранениеДанных_Пакеты_ДокументУчета(ИдентификаторыПакета);
		
		Если ЗначениеЗаполнено(ДокументУчета) Тогда
			СтрокаСписка.Документ = ДокументУчета;
		КонецЕсли;
		
	КонецЕсли;
	
	Организация	= СтрокаСписка.Организация;
	Контрагент	= СтрокаСписка.Контрагент;
	ВидПакетаID	= СтрокаСписка.ВидПакетаID;
	
	НачалоПериода	 = НачалоДня(СтрокаСписка.ДатаДокумента);
	КонецПериода	 = КонецДня(СтрокаСписка.ДатаДокумента);
	
	Запрос = Новый Запрос;
	
	ОписаниеВидаПакета = Списки_ОписаниеВидаПакета(ВидПакетаID);
	
	Если Не ЗначениеЗаполнено(ОписаниеВидаПакета) Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			"Отсутствует описание вида пакета (%1)",
			ВидПакетаID
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	КатегорияПакета = ОписаниеВидаПакета.КатегорияПакета;
	ДоступныеВидыПакета = МассивВидовПакетов(КатегорияПакета);
	
	Для Каждого ВидПакета Из ДоступныеВидыПакета Цикл
		Запрос.УстановитьПараметр("ВидПакетаID_" + ВидПакета.Идентификатор, ВидПакета.Ссылка);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("НачалоПериода"		, НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода"		, КонецПериода);
	Запрос.УстановитьПараметр("Ссылка"				, СтрокаСписка.Документ);
	Запрос.УстановитьПараметр("ТаблицаВидовПакетов"	, Списки_ТаблицаИспользуемыхВидовПакетов());
	Запрос.УстановитьПараметр("ТаблицаВидовДокументов", ТаблицаСвойстваТипОснованияПоВидуДокумента());
	
	ДополненныеПараметры = ХранениеДанных_ДополненныеПараметрыНаОтправку(Запрос.Параметры);
	
	ПараметрыСобытия = Новый Структура("ПараметрыЗапроса, МассивВидовПакетов", Запрос.Параметры, ДоступныеВидыПакета);
	
	ТекстЗапроса = ПодключаемыйМодуль_ОбработатьСобытие("ПолучитьТекстЗапросаДляСпискаПакетовНаОтправкуПоМассивуВидовПакетов", ПараметрыСобытия);
	
	ОтборПоПериоду = " МЕЖДУ &НачалоПериода И &КонецПериода";
	
	ЕстьОтборПоДате		= Найти(ТекстЗапроса, ".Дата" + ОтборПоПериоду) > 0;
	ЕстьОтборПоПериоду	= Найти(ТекстЗапроса, ОтборПоПериоду) > 0;
	
	Если ЕстьОтборПоДате Тогда
		ТекстЗамены = "Истина";
	Иначе  
		ТекстЗамены = "Документ.Ссылка = &Ссылка";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ОтправленныеДокументы.Ссылка ЕСТЬ NULL", Текстзамены);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ОтправленныеДокументы.Документ ЕСТЬ NULL", ТекстЗамены);
		
	Если ЕстьОтборПоДате Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ".Дата" + ОтборПоПериоду, ".Ссылка = &Ссылка");
		
	ИначеЕсли ЕстьОтборПоПериоду Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ОтборПоПериоду, " > &ПустаяДата");
		Запрос.УстановитьПараметр("ПустаяДата", '00010101');
		
	Иначе
		
		ДанныеОДатеДокумента = Новый Структура("Дата");
		ЗаполнитьЗначенияСвойств(ДанныеОДатеДокумента, СтрокаСписка.Документ);
		ДатаДокумента = ДанныеОДатеДокумента.Дата;
		
		Если ЗначениеЗаполнено(ДатаДокумента) Тогда
			
			Запрос.УстановитьПараметр("НачалоПериода",	НачалоДня(ДатаДокумента));
			Запрос.УстановитьПараметр("КонецПериода",	КонецДня(ДатаДокумента));
		
		КонецЕсли;
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "УПОРЯДОЧИТЬ ПО" + Символы.ПС + "	ДатаДокумента, НомерДокумента", "");
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос;
	
КонецФункции

// Проверяет данные строки списка на наличие ошибок, которые могут помешать переотправке пакета
//
// Параметры:
//  СтрокаСписка - Структура - данные строки списка исходящих документов
//
// Возвращаемое значение:
//   Булево - Истина, если данные содержат не корректные значения
//
Функция СписокДокументов_ВалидацияПереотправляемогоПакета(СтрокаСписка) Экспорт
	
	ЕстьОшибкиВПолучателе = СписокДокументов_ВалидацияПолучателяПереотправляемогоПакета(СтрокаСписка);
	
	Возврат ЕстьОшибкиВПолучателе;
	
КонецФункции

Функция СписокДокументов_ВалидацияПолучателяПереотправляемогоПакета(СтрокаСписка)
	
	Результат = Ложь;
	
	Запрос = СписокДокументов_ЗапросДанныеСтрокиСпискаПакетовНаОтправку(СтрокаСписка);
	
	Если Не ЗначениеЗаполнено(Запрос.Текст) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТекстЗапроса = Запрос.Текст;
	
	// Модифициоруем текст запроса для того, чтобы возвращались документы по не сопоставленным контрагентам,
	// т.е. контрагенты, отсутсвующие в ВТ_КэшКонтрагентовПоВидамПакетов 
	ТекстЗапроса = СтрЗаменить(
			ТекстЗапроса,
			"ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов",
			"ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшКонтрагентовПоВидамПакетов КАК ВТ_КэшКонтрагентовПоВидамПакетов"
		);
	
	ТекстЗапроса = СтрЗаменить(
			ТекстЗапроса,
			"И НЕ ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные",
			""
		);
	
	ТекстЗапроса = СтрЗаменить(
			ТекстЗапроса,
			"И ВТ_КэшКонтрагентовПоВидамПакетов.ОтправлятьНепроведенные",
			""
		);
	
	Запрос.Текст = ТекстЗапроса;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ПолучательБылИзменен = (СтрокаСписка.Контрагент <> Выборка.Контрагент);
		
		Если ПолучательБылИзменен Тогда
			
			Результат = Истина;
			
			ОсновнойМодуль = Модуль_ВызовыПМ(ЭтотОбъект);
			
			ДанныеЭД	= ОсновнойМодуль.ДокументИзДанныхСтрокиТЧ(СтрокаСписка);
			Контрагент 	= Выборка.Контрагент;
			ПредставлениеДокумента = СписокДокументов_ПредставлениеДокумента(СтрокаСписка);
			
			ЗаписатьОшибкуВалидацииПолучателяПереотправляемогоПакета(ДанныеЭД, ПредставлениеДокумента, Контрагент);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ПодготовленныеПакетыНаОтправку(Параметры)
	
	Попытка
		Результат = ХранениеДанных_СписокДокументовПодготовленных(Параметры);
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияСписокНаОтправку(),
			"ПолучитьСписокГотовыхПакетов",
			Ошибка
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Для Каждого СтрокаСписка Из Результат Цикл
		
		СтрокаСписка.Статус				= СтрокаСписка.Метка;
		СтрокаСписка.Метка				= "";
		СтрокаСписка.ТребуемоеДействие	= "Отправить пакет";
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

