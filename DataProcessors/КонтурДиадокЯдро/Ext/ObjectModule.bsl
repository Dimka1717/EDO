	Результат.ParentDepartmentId		 = Department.ParentDepartmentId;
	Результат.Наименование				 = Department.Name;
	Результат.СокращенноеНаименование	 = СвойствоСтруктуры(Department, "Abbreviation", "");
	Результат.КПП						 = СвойствоСтруктуры(Department, "Kpp", "");
	
