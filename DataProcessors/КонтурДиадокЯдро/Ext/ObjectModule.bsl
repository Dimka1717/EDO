Функция Документы_УбратьИзИмениФайлаНеиспользуемыеСимволы(Знач СтрокаИмениФайла)
	
	Результат = СтрокаИмениФайла;
	
	НеиспользуемыеСимволы = ":~!@/\#$%^&*=|`""?<>";
	
	Для й = 1 По СтрДлина(НеиспользуемыеСимволы) Цикл
		Результат = СтрЗаменить(Результат, Сред(НеиспользуемыеСимволы, й, 1), "");
	КонецЦикла;
	
	Возврат Результат;	
	
КонецФункции


Функция Сохранение_СохранитьДокументы(ДокументыДляОбработки, ВыполнитьВФоне = Ложь) Экспорт
	
	ТекстОшибки = Сохранение_ПроверитьНастройкиСохраненияДокументов();
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Сообщить(ТекстОшибки, СтатусСообщения.Важное);
		Возврат Ложь;
	КонецЕсли;
	
	ПакетыДляСохранения = СгруппироватьДокументыПоПакетам(ДокументыДляОбработки);
	
	Если ОбщиеНастройки_Прочитать("СохранениеДокументовГруппироватьПоПакетам") = Истина Тогда
		
		ИдентификаторыПакетов = Новый Массив;
		Для Каждого Пакет Из ПакетыДляСохранения Цикл
			ИдентификаторыПакетов.Добавить(Пакет.Идентификаторы);
		КонецЦикла;
		
		ДокументыПакетов = Пакеты_ДокументыПакетов(ИдентификаторыПакетов);
		ПакетыДляСохранения = СгруппироватьДокументыПоПакетам(ДокументыПакетов);
		
	КонецЕсли;
	
	РазрешитьДлительныеОперацииВФоне = ФоновыеОперацииРазрешены();
	
	Если ВыполнитьВФоне
		И РазрешитьДлительныеОперацииВФоне Тогда
		Сохранение_СохранитьДокументыФоном(ПакетыДляСохранения);
	Иначе
		Сохранение_СохранитьДокументыПакетов(ПакетыДляСохранения);
		Сохранение_СообщитьОЗавершении();
	КонецЕсли;
	
	Для Каждого Пакет Из ПакетыДляСохранения Цикл
	
		Для Каждого Документ Из Пакет.Документы Цикл
	    	Метрика_ДобавитьСтатистику_СкачиваниеДокументов("Скачать документы", Документ, Истина);
		КонецЦикла;
		
	КонецЦикла;	
	
	Возврат Истина;
	
КонецФункции

Функция Сохранение_ПроверитьНастройкиСохраненияДокументов()
	
	ТекстОшибки = "";
	
	СохранениеДокументовПуть		= ОбщиеНастройки_Прочитать("СохранениеДокументовПуть");
	СохранениеДокументовСценарий	= ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
	
	Если НЕ ЗначениеЗаполнено(СохранениеДокументовПуть) Тогда
		ТекстОшибки = ТекстОшибки + ?(ЗначениеЗаполнено(ТекстОшибки), Символы.ПС, "")
		+ " - путь к сохраняемым документам";
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СохранениеДокументовСценарий) Тогда
		ТекстОшибки = ТекстОшибки + ?(ЗначениеЗаполнено(ТекстОшибки), Символы.ПС, "") 
		+ " - сценарий сохранения документа";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		ТекстОшибки = "В общих настройках необходимо заполнить:" + Символы.ПС + ТекстОшибки;
	КонецЕсли;
	
	Возврат ТекстОшибки;
	
КонецФункции

Процедура Сохранение_СохранитьДокументыФоном(Пакеты)
	
	ИмяМетода = "Сохранение_СохранитьДокументыПакетов";
	
	КоличествоФоновыхЗаданий = ФоновоеЗадание_МаксимальноеКоличество();
	
	ВсегоПакетов	= Пакеты.Количество();
	РазмерПорции	= Макс(Окр(Пакеты.Количество() / КоличествоФоновыхЗаданий), 1);
	
	ОчередьЗадач	= Новый Массив;
	ПорцияПакетов	= Новый Массив;
	
	Для ИндексПакета = 0 По Пакеты.ВГраница() Цикл
		
		ПорцияПакетов.Добавить(Пакеты[ИндексПакета]);
		ЭтоПоследнийПакет = (ИндексПакета + 1 = ВсегоПакетов);
		
		Если ПорцияПакетов.Количество() >= РазмерПорции
			ИЛИ ЭтоПоследнийПакет Тогда
			
			ПараметрыМетода = Новый Массив;
			ПараметрыМетода.Добавить(ПорцияПакетов);
			
			ОписаниеЗадачи = Новый_ОписаниеЗадачиВФоне(ИмяМетода, ПараметрыМетода);
			
			ОчередьЗадач.Добавить(ОписаниеЗадачи);
			ПорцияПакетов = Новый Массив;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОчередьЗадач_Обработать(ОчередьЗадач);
	
	Сохранение_СообщитьОЗавершении();
	
КонецПроцедуры

Функция Сохранение_СохранитьДокументыПакетов(Пакеты)
	
	СохранениеДокументовСценарий = ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
	
	Для Каждого Пакет Из Пакеты Цикл
		
		ОсновнойДокумент = Сохранение_ОсновнойДокументПакета(Пакет);
		
		Для Каждого Документ Из Пакет.Документы Цикл
			
			BoxId 		= Документ.Идентификаторы.BoxId;
			LetterId 	= Документ.Идентификаторы.LetterId;
			DocumentId 	= Документ.Идентификаторы.DocumentId;
			
			Если СохранениеДокументовСценарий = "ВесьДокументооборот" Тогда
				
				ИмяКонечногоФайла	= Документ.ИмяФайла + ".zip";
				ДвоичныеДанные		= Сохранение_ПолучитьАрхивДокументооборота(Документ.Идентификаторы);
				
				Сохранение_ЗаписатьДвоичныеДанные(ДвоичныеДанные, Документ, ОсновнойДокумент, ИмяКонечногоФайла);
				
			ИначеЕсли СохранениеДокументовСценарий = "ТолькоПечатнаяФорма" Тогда
				
				ДвоичныеДанные		= Документы_ПечатнаяФормаСервераДиадок(Документ.Идентификаторы);
				ИмяКонечногоФайла	= Документы_ПредставлениеДокументаДляСохранения(Документ) + ".pdf";
				
				Сохранение_ЗаписатьДвоичныеДанные(ДвоичныеДанные, Документ, ОсновнойДокумент, ИмяКонечногоФайла);
				
			ИначеЕсли СохранениеДокументовСценарий = "ТолькоДокумент" Тогда
				
				ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
				ДанныеДокументаСМетаданными = АПИ_GetDocument(ПараметрыСервиса, BoxId, LetterId, DocumentId);
				
				КонтентДокумента = ДанныеДокументаСМетаданными.Content;
				
				Если КонтентСодержитДанные(КонтентДокумента) Тогда
					ДанныеДокумента = Base64Значение(КонтентДокумента.Data);
				Иначе
					ДанныеДокумента = АПИ_GetEntityContent(ПараметрыСервиса, BoxId, LetterId, DocumentId);
				КонецЕсли;	
				
				Если Документ.Тип.Формализованный Тогда
					
					ИмяФайлаБезРасширения = Документы_ПредставлениеДокументаДляСохранения(Документ);
					
					Если ДанныеДокументаСМетаданными.IsEncryptedContent Тогда
						
						ИмяКонечногоФайла = ИмяФайлаБезРасширения + ".enc";
						
					Иначе
						
						ИмяКонечногоФайла = ИмяФайлаБезРасширения + ".xml";
						
					КонецЕсли;
						
				Иначе
					
					Message = АПИ_GetMessage(ПараметрыСервиса, BoxId, LetterId, DocumentId, "false", "false");
					
					Для Каждого Entity Из Message.Entities Цикл
						
						Если Entity.EntityId = DocumentId Тогда
							
							Расширение = РеквизитыИмениФайла(Entity.FileName).Расширение;
							
							ДлинаРасширения = СтрДлина(Расширение);
							Если СтрДлина(Документ.ИмяФайла) >= ДлинаРасширения
								И Прав(Документ.ИмяФайла, ДлинаРасширения) = Расширение Тогда
								// расширение уже содержится в имени файла
								Расширение = "";
							КонецЕсли;
							
							ИмяКонечногоФайла = Документы_ПредставлениеДокументаДляСохранения(Документ) + Расширение;
							
							Прервать;
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
				Сохранение_ЗаписатьДвоичныеДанные(ДанныеДокумента, Документ, ОсновнойДокумент, ИмяКонечногоФайла);
				
			Иначе
				ВызватьИсключение "Сценарий " + СохранениеДокументовСценарий + " не реализован";
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция Сохранение_ОсновнойДокументПакета(Пакет)
	
	Результат = Неопределено;
	
	ПриоритетыДокументовПакета = Сохранение_ПриоритетыДокументовПакета();
		
	МаксимальныйПриоритет = -1;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		МассивСлужебный = ПриоритетыДокументовПакета.НайтиСтроки(Новый Структура("TypeNamedId", Документ.Тип.ТипДокумента));
		
		Если МассивСлужебный.Количество() > 0 Тогда
			ТекущийПриоритет = МассивСлужебный[0].Приоритет;
		Иначе
			ТекущийПриоритет = 0;
		КонецЕсли;
		
		Если ТекущийПриоритет > МаксимальныйПриоритет Тогда
			
			Результат = Документ;
			МаксимальныйПриоритет = ТекущийПриоритет;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Сохранение_ПолучитьАрхивДокументооборота(Идентификаторы) Экспорт
	
	BoxId = Идентификаторы.BoxId;
	LetterId = Идентификаторы.LetterId;
	DocumentId = Идентификаторы.DocumentId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Счетчик = 0;
	
	Пока Счетчик < 10 Цикл
		
		Ответ = АПИ_GenerateDocumentZip(ПараметрыСервиса, boxId, letterId, documentId);
		
		Если ЗначениеЗаполнено(Ответ.ВремяОжидания) Тогда
			
			МаксимальноеВремяОжидания = 1800;
			
			Если Ответ.ВремяОжидания > МаксимальноеВремяОжидания Тогда
				
				ШаблонОшибки = НСтр(
					"ru='Превышено максимальное время ожидания генерации архива документооборота: %1
					|BoxId: %2
					|MessageId: %3
					|DocumentId: %4'"
				);
				
				ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
					ШаблонОшибки,
					Ответ.ВремяОжидания,
					boxId,
					letterId,
					documentId
				);
				
				ВызватьИсключение ТекстОшибки;
				
			КонецЕсли;
			
			Таймаут(Ответ.ВремяОжидания);
			Счетчик = Счетчик + 1;
			
		Иначе
			
			nameOnShelf = Ответ.ПутьКФайлуАрхива.ZipFileNameOnShelf;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Счетчик < 10 Тогда
		Результат = АПИ_ShelfDownload(ПараметрыСервиса, nameOnShelf);
	КонецЕсли;	
		
	Возврат Результат;
	
КонецФункции

Процедура Сохранение_ЗаписатьДвоичныеДанные(ДвоичныеДанные, Документ, ОсновнойДокументПакета = Неопределено, ИмяКонечногоФайла)
	
	СохранениеДокументовСценарий = ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
	
	ИмяФайла = Сохранение_ПолноеИмяФайлаДляДокумента(Документ, ОсновнойДокументПакета, ИмяКонечногоФайла);
	
	Если ДвоичныеДанные = Неопределено Тогда
		
		Результат		= Ложь;
		
		ВидОперации		= "Сохранение документов";
		ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения	= "Не удалось получить данные документа";
		ДопИнформация	= "Документ: " + Документы_ПредставлениеДокумента(Документ);
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	Иначе
		
		Попытка
			
			Файл = Новый Файл(ИмяФайла);
			СоздатьКаталог(Файл.Путь);
			ДвоичныеДанные.Записать(ИмяФайла);
			
			Если СохранениеДокументовСценарий = "ВесьДокументооборот" Тогда
				
				РазархивированныйАрхив = Новый ЧтениеZipФайла(ИмяФайла);
				РазархивированныйАрхив.ИзвлечьВсе(Файл.Путь, РежимВосстановленияПутейФайловZIP.НеВосстанавливать);
				УдалитьФайлы(Файл.ПолноеИмя);
				
			КонецЕсли;
			
		Исключение
			
			Результат		= Ложь;
			
			ВидОперации		= "Сохранение документов";
			ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения	= "Не удалось сохранить документ";
			ДопИнформация	= "Документ: " + Документы_ПредставлениеДокумента(Документ);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Сохранение_ПолноеИмяФайлаДляДокумента(Документ, ОсновнойДокументПакета = Неопределено, ИмяКонечногоФайла)
	
	// По умолчанию имя файла для сохранения будет выглядеть так:
	
	// 1. "Сохранять весь документооборот", "Группировать по пакетам"
	// <Корень>\<ИНН контрагента>\<Год>\<Месяц>\<День>\<Представление главного документа пакета>\<Представление сохраняемого документа>\<ИмяКонечногоФайла>
	
	// 2. "Сохранять весь документооборот", Не "Группировать по пакетам",
	// <Корень>\<ИНН контрагента>\<Год>\<Месяц>\<День>\<Представление сохраняемого документа>\<ИмяКонечногоФайла>
	
	// 3. "Сохранять только печатную форму" или "Сохранять только документ", "Группировать по пакетам"
	// <Корень>\<ИНН контрагента>\<Год>\<Месяц>\<День>\<Представление главного документа пакета>\<ИмяКонечногоФайла>
	
	// 4. "Сохранять только печатную форму" или "Сохранять только документ", не "Группировать по пакетам"
	// <Корень>\<ИНН контрагента>\<Год>\<Месяц>\<День>\<ИмяКонечногоФайла>
	
	СохранениеДокументовСценарий				= ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
	СохранениеДокументовГруппироватьПоПакетам	= ОбщиеНастройки_Прочитать("СохранениеДокументовГруппироватьПоПакетам");
	СохранениеДокументовПуть					= ОбщиеНастройки_Прочитать("СохранениеДокументовПуть");
	
	СохранятьВесьДокументооборот	= (СохранениеДокументовСценарий = "ВесьДокументооборот");
	ГруппироватьПоПакетам			= (СохранениеДокументовГруппироватьПоПакетам = Истина);
	
	Если ГруппироватьПоПакетам Тогда
		СтруктураДаты = СтруктураДаты(ОсновнойДокументПакета.Реквизиты.Дата);
	Иначе
		СтруктураДаты = СтруктураДаты(Документ.Реквизиты.Дата);
	КонецЕсли;
	
	МассивЧастейПути = Новый Массив;
	МассивЧастейПути.Добавить(СохранениеДокументовПуть);  // Корень
	
	Если Документ.Направление = Перечисление_Направления().Исходящее Тогда
		Контрагент = Документ.Получатель;
	Иначе
		Контрагент = Документ.Отправитель;
	КонецЕсли;
	
	ИдентификаторыКонтрагента	= Новый_ИдентификаторыСправочника(Контрагент.ОрганизацияЭДО, Контрагент.BoxId);
	ДанныеКонтрагента			= Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
	
	МассивЧастейПути.Добавить(ДанныеКонтрагента.ИНН);
	
	МассивЧастейПути.Добавить(СтруктураДаты.Год);
	МассивЧастейПути.Добавить(СтруктураДаты.Месяц);
	МассивЧастейПути.Добавить(СтруктураДаты.День);
	
	Если ГруппироватьПоПакетам Тогда
		
		ПредставлениеГлавногоДокумента = Документы_ПредставлениеДокументаДляСохранения(ОсновнойДокументПакета);
		МассивЧастейПути.Добавить(ПредставлениеГлавногоДокумента);
		
	КонецЕсли;
	
	Если СохранятьВесьДокументооборот Тогда
		
		ПредставлениеТекущегоДокумента = Документы_ПредставлениеДокументаДляСохранения(Документ);
		МассивЧастейПути.Добавить(ПредставлениеТекущегоДокумента);
		
	КонецЕсли;
	
	МассивЧастейПути.Добавить(ИмяКонечногоФайла);
	
	ИмяФайла = СоединитьСтроку(МассивЧастейПути, "\");
	
	Возврат ИмяФайла;
	
КонецФункции
	
Функция Сохранение_ПриоритетыДокументовПакета()
 	
	Результат = Кэш_Прочитать("ПриоритетыДокументовПакета");
	
	Если Результат = Неопределено Тогда
		
		Результат = ПредопределенныеСписки_ТипыДокументовAPI().Скопировать();
		Результат.Свернуть("ГруппировкаДокументов, TypeNamedId");
		Результат.Колонки.Добавить("Приоритет");
		Результат.ЗаполнитьЗначения(0, "Приоритет");
		
		ГруппировкиИмениКаталогаПакетаСтрокой = ОбщиеНастройки_Прочитать("СохранениеДокументовИмяКаталогаПакета");
		ГруппировкиИмениКаталогаПакета = РазделитьСтрокуЛок(ГруппировкиИмениКаталогаПакетаСтрокой, ";");
		
		ВсегоГруппировок = ГруппировкиИмениКаталогаПакета.Количество();
		
		Счетчик = 0;
		
		Для Каждого Группировка Из ГруппировкиИмениКаталогаПакета Цикл
			
			Отбор = Новый Структура("ГруппировкаДокументов", Группировка);
			СтрокиТЗ = Результат.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаТЗ Из СтрокиТЗ Цикл
				СтрокаТЗ.Приоритет = ВсегоГруппировок - Счетчик; 
			КонецЦикла;
			
			Счетчик = Счетчик + 1;
			
		КонецЦикла;
		
		Кэш_Поместить("ПриоритетыДокументовПакета", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Сохранение_СообщитьОЗавершении()
	
	СохранениеДокументовПуть = ОбщиеНастройки_Прочитать("СохранениеДокументовПуть");
	ТекстСообщения = "Сохранение документов завершено. Путь к сохраненным документам: %1";
	ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, СохранениеДокументовПуть);
	
	Сообщить(ТекстСообщения);
	
КонецПроцедуры

Функция Метрика_ПеременныеСкачиваниеДокумента(Документ)
	
	СохранениеДокументовСценарий				= ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
	СохранениеДокументовГруппироватьПоПакетам	= ОбщиеНастройки_Прочитать("СохранениеДокументовГруппироватьПоПакетам");
	
	ПарамПеременные = Новый Соответствие;
	ПарамПеременные.Вставить("BoxId",								Документ.BoxId);
	ПарамПеременные.Вставить("LetterId",							Документ.LetterId);
	ПарамПеременные.Вставить("DocumentId",							Документ.DocumentId);
	ПарамПеременные.Вставить("Статус",								Документ.Статус);
	ПарамПеременные.Вставить("Направление",							Документ.Направление);
	ПарамПеременные.Вставить("Сценарий сохранения",					СохранениеДокументовСценарий);
	ПарамПеременные.Вставить("Группировать документы по пакетам",	СохранениеДокументовГруппироватьПоПакетам);
	
	Возврат ПарамПеременные;
	
КонецФункции


// ОБНОВЛЕНИЕ КОММЕНТАРИЯ ДОКУМЕНТА УЧЕТА

Процедура Документы_ОбновитьКомментарийДокументаУчета(Документ, Документ1СОбъект = Неопределено) Экспорт
	
	ЭтоОтправка = Документ.Направление = Перечисление_Направления().Исходящее;

	Если ЭтоОтправка Тогда
		Организация = Документ.Отправитель;
	Иначе
		Организация = Документ.Получатель;
	КонецЕсли;
	
	Идентификаторы		= Новый_ИдентификаторыСправочника(, Организация.BoxID);
	ДанныеОрганизации 	= Организации_ЗаполненныеРеквизиты(Идентификаторы);

	Если ЭтоОтправка Тогда
		ТекстКомментария = ДанныеОрганизации.ТекстКомментарияОтправка;
	Иначе
		ТекстКомментария = ДанныеОрганизации.ТекстКомментарияПолучение;
	КонецЕсли;
	
	Если ДанныеОрганизации.ЗаписыватьКомментарииВДокументы1С И ЗначениеЗаполнено(ТекстКомментария) Тогда
		     	
		ПараметрыПМ = Контракт_ПараметрыПМ_ОбновитьКомментарийДокументаУчета();
			
		ПараметрыПМ.Документ		= Документ;
		ПараметрыПМ.ДокументОбъект 	= Документ1СОбъект;
		ПараметрыПМ.Комментарий 	= ТекстКомментария;
		
		ПодключаемыйМодуль_ОбработатьСобытие("ОбновитьКомментарийДокументаУчета", ПараметрыПМ);
		
	КонецЕсли;
	
КонецПроцедуры

