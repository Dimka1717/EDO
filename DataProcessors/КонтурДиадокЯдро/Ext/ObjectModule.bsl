// Возвращает типы предложений для покупки
// 
// Возвращаемое значение:
//   - Структура
//
Функция ЛичныйКабинет_ТипыПредложений() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("ПодпискаНаМодульЗакончилась", "ПодпискаНаМодульЗакончилась");
	Результат.Вставить("ПодпискаНаМодульЗаканчивается", "ПодпискаНаМодульЗаканчивается");
	Результат.Вставить("ПакетЗакончился", "ПакетЗакончился");
	Результат.Вставить("ПакетЗаканчивается", "ПакетЗаканчивается");
	Результат.Вставить("ПромоМодуля", "ПромоМодуля");
	Результат.Вставить("РекомендацияПлагинов", "РекомендацияПлагинов");
	Результат.Вставить("РекомендацияПакетов", "РекомендацияПакетов");
	Результат.Вставить("МаршрутЗакончился", "МаршрутЗакончился");
	Результат.Вставить("МаршрутЗаканчивается", "МаршрутЗаканчивается");
	Результат.Вставить("СертификатЗакончился", "СертификатЗакончился");
	Результат.Вставить("СертификатЗаканчивается", "СертификатЗаканчивается");
	Результат.Вставить("ЛицензияНаКоннекторы", "ЛицензияНаКоннекторы");
	Результат.Вставить("ЛицензияНаAPI", "ЛицензияНаAPI");
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ПредставлениеПредложения(ПредложениеДляПокупки)
	
	КлючПредставления = ПредложениеДляПокупки.Сценарий;
	
	Если ПредложенияДляПокупки_ЭтоПодпискаНаПакет(КлючПредставления) Тогда
		
		Если ПредложениеДляПокупки.ДатаОкончания = Неопределено
			И ПредложениеДляПокупки.ОстатокТрафика = Неопределено Тогда
		
			КлючПредставления = КлючПредставления + ЛичныйКабинет_ПостфиксКлючаПредставленияДляПервойПодпискиНаПакет();
		
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПредложенияДляПокупки_ЭтоПодпискаНаСертификат(КлючПредставления) Тогда
		
		Результат = ЛичныйКабинет_ПредставлениеПредложенияПоСертификату(ПредложениеДляПокупки);
		
	Иначе
		
		ПредставленияПредложений = ЛичныйКабинет_ПредставленияПредложений();
		Результат = ПредставленияПредложений.Получить(КлючПредставления);
		
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		Результат = "";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ПредставленияПредложений()
	
	Результат = Новый Соответствие;
	
	Ключ_ПромоНизкийТрафикПакетов = ПредложенияДляПокупки_Сценарий_ПромоНизкийТрафикПакетов();
	Ключ_ПромоПакетов_50 = ПредложенияДляПокупки_Сценарий_ПромоПакетов_50();
	Ключ_ПромоПакетов_100 = ПредложенияДляПокупки_Сценарий_ПромоПакетов_100();
	Ключ_ПодпискаНаМодуль = ПредложенияДляПокупки_Сценарий_ПодпискаНаМодуль();
	Ключ_ПерваяПодпискаНаМодуль = ПредложенияДляПокупки_Сценарий_ПерваяПодпискаНаМодуль();
	Ключ_Пакет = ПредложенияДляПокупки_Сценарий_Пакет();
	Ключ_ПакетПервый = Ключ_Пакет + ЛичныйКабинет_ПостфиксКлючаПредставленияДляПервойПодпискиНаПакет();
	Ключ_ПродлениеМаршрутов = ПредложенияДляПокупки_Сценарий_ПродлениеМаршрутов();
	Ключ_ПродлениеКоннекторов = ПредложенияДляПокупки_Сценарий_ПродлениеКоннекторов();
	Ключ_ПродлениеAPI = ПредложенияДляПокупки_Сценарий_ПродлениеAPI();
	Ключ_ПродлениеСертификатов = ПредложенияДляПокупки_Сценарий_ПродлениеСертификатов();
	Ключ_РекомендацияПромоНаМодуль21 = ПредложенияДляПокупки_Сценарий_ПромоНаМодуль21();
	Ключ_РекомендацияПлагинов = ПредложенияДляПокупки_Сценарий_РекомендацияПлагинов();
