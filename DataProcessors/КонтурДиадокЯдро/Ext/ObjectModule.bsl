			BoxId,
			СтрокаКонтекста.ИНН,
			ПередаватьМЧДФайлом);
		
		SignerContent = ГенерацияXML_УПД970_УниверсальныйПодписант(СтрокаКонтекста.Сертификат, КонтрактМЧД, ПараметрыФормирования);
		
		Результат = ДвоичныеДанныеBase64ИзXDTO(SignerContent);
		
		Подписант_ПоместитьВКэш(КлючЗначенияВКэше, Результат);
		
