// Проверяет, прочитано ли пользователем уведомление.
//
// Параметры:
//  ИдентификаторУведомления - Строка - идентификатор уведомления
//  ОтметкиОПрочтении - ТаблицаЗначений - (Необязательный) содержит колонки:
//    * Ид - Строка - идентификатор уведомления
//    * Прочитано - Булево - Истина, если прочитано
// 
// Возвращаемое значение:
//  Булево - Истина, если уведомление прочитано пользователем.
//
Функция УведомленияПользователей_ОтметкаОПрочтении(ИдентификаторУведомления, ОтметкиОПрочтении)
	
	СтрокаСостояния = ОтметкиОПрочтении.Найти(ИдентификаторУведомления);
	
	Результат = Ложь;
	Если ЗначениеЗаполнено(СтрокаСостояния) Тогда
		Результат = СтрокаСостояния.Прочитано;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УведомленияПользователей_РазобратьКонтент(НоваяСтрокаУведомлений, КонтентУведомления)
	
	Если НЕ ЗначениеЗаполнено(КонтентУведомления) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(КонтентУведомления) = Тип("Соответствие") 
		Или ТипЗнч(КонтентУведомления) = Тип("ФиксированноеСоответствие") Тогда
		НоваяСтрокаУведомлений.Заголовок = КонтентУведомления.Получить("title");
		НоваяСтрокаУведомлений.Текст = КонтентУведомления.Получить("body");
		НоваяСтрокаУведомлений.ТипКонтента = КонтентУведомления.Получить("type");
	ИначеЕсли ТипЗнч(КонтентУведомления) = Тип("Структура") 
		Или ТипЗнч(КонтентУведомления) = Тип("ФиксированнаяСтруктура") Тогда
		КонтентУведомления.Свойство("title", НоваяСтрокаУведомлений.Заголовок);
		КонтентУведомления.Свойство("body", НоваяСтрокаУведомлений.Текст);
		КонтентУведомления.Свойство("type", НоваяСтрокаУведомлений.ТипКонтента);
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			"Уведомления пользователей: Неожиданный тип контента (%1)",
			ТипЗнч(КонтентУведомления)
		);
		
		Метрика_ДобавитьОшибку_ЗаполнениеКонтентаУведомления(
			ТекстОшибки,
			НоваяСтрокаУведомлений.Ид
		);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Метрика_ДобавитьОшибку_ЗаполнениеКонтентаУведомления(ТекстОшибки, ИДУведомления)
	
	ДопПеременные = Новый Соответствие;
	ДопПеременные.Вставить("Id", ИДУведомления);
	
	КатегорииМетрик = Метрика_НазваниеКатегории();
	ДействияМетрик = Метрика_НазваниеДействий();
	
	Метрика_ДобавитьОшибку_СУчетомЗаполненияКонтекста(
		КатегорииМетрик.ЭкстренноеУведомление,
		ДействияМетрик.ПарсингКонтентаУведомления,
		ТекстОшибки,
		ДопПеременные
	);
	
КонецПроцедуры

