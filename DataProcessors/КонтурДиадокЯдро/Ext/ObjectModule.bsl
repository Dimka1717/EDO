// Возвращает новый уникальный идентификатор замера и записывает его в общий для всех обработок кэш.
//
// Параметры:
//  КлючЗамера - Строка - Ключ в структуре идентификаторов замеров.
// 
// Возвращаемое значение:
//   Строка	- Уникальный идентификатор замера.
//
Функция ЗаписатьЗамерID(КлючЗамера) Экспорт
	
	ИдентификаторыЗамера = Кэш_Прочитать("ЗамерID");
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторыЗамера) Тогда
		ИдентификаторыЗамера = Новый Соответствие;
	КонецЕсли;
	
	ИдентификаторЗамера = Новый УникальныйИдентификатор();
	
	ИдентификаторыЗамера.Вставить(КлючЗамера, ИдентификаторЗамера);
	
	Кэш_Поместить("ЗамерID", ИдентификаторыЗамера);
	
	Возврат ИдентификаторЗамера;

КонецФункции

// Возвращает уникальный идентификатор замера и удаляет его из структуры идентификаторов.
// Если структура идентификаторов окажется пустой, то элемент кэша ЗамерID будет удален из кэша.
// 
// Параметры:
//  КлючЗамера - Строка - Ключ в структуре идентификаторов замеров.
// 
// Возвращаемое значение:
//   Строка	- Уникальный идентификатор замера из кэша.
//
Функция ПрочитатьЗамерID(КлючЗамера, Очищать = Ложь) Экспорт

	ИдентификаторыЗамера = Кэш_Прочитать("ЗамерID");
	
	Результат = ИдентификаторыЗамера.Получить(КлючЗамера);
	
	Если Очищать Тогда
		ИдентификаторыЗамера.Удалить(КлючЗамера);
		
		Кэш_Поместить("ЗамерID", ИдентификаторыЗамера);
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Топики, которые поддерживает Контур.Метрика.
//
// Возвращаемое значение:
//   Структура
//
Функция ТопикиМетрики()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Log", ТопикиМетрики_Log()); // Журнал
	Результат.Вставить("Health", ТопикиМетрики_Health()); // Здоровье
	Результат.Вставить("Behavior"	, "Behavior");	// Поведение
	Результат.Вставить("Feedback"	, "Feedback");	// ОбратнаяСвязь
	Результат.Вставить("Statistics"	, "Statistics");// Статистика
	Результат.Вставить("Common_Statistics", МетрикиКонтурСлужебный_CommonStatistics()); // Общепродуктовые метрики
	Результат.Вставить("ProductAnalytics", ТопикиМетрики_ПродуктоваяАналитика()); // Продуктовая аналитика
	
	Возврат Результат;
	
КонецФункции

