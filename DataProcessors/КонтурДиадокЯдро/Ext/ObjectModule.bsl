Процедура ЗаполнитьПредставителяВКонтрактеМЧД(КонтрактМЧД, Representatives)
	
	Если Representatives.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Representative = Representatives[0];
	
	ТипыПредставителяАПИ = АПИ_Перечисление_PowerOfAttorneyRepresentativeType();
	ТипыПредставителя = Перечисление_ТипыПредставителяМЧД();
	
	Если Representative.Type = ТипыПредставителяАПИ.RepresentativeLegalEntity Тогда
		
		ЗаполнитьПредставителяМЧДДаннымиОрганизацииАПИ(
			КонтрактМЧД.Представитель,
			ТипыПредставителя.ЮЛ,
			Representative.LegalEntity
		);
		
	ИначеЕсли Representative.Type = ТипыПредставителяАПИ.RepresentativeIndividualEntity Тогда
		
		ЗаполнитьПредставителяМЧДДаннымиОрганизацииАПИ(
			КонтрактМЧД.Представитель,
			ТипыПредставителя.ИП,
			Representative.IndividualEntity
		);
		
	ИначеЕсли Representative.Type = ТипыПредставителяАПИ.RepresentativePhysicalEntity Тогда
		
		ЗаполнитьПредставителяМЧДДаннымиФизическогоЛицаАПИ(
			КонтрактМЧД.Представитель,
			Representative.PhysicalEntity
		);
		
	ИначеЕсли Representative.Type = ТипыПредставителяАПИ.RepresentativeLegalSubsidiaryEntity Тогда
		
		ЗаполнитьПредставителяМЧДДаннымиОрганизацииАПИ(
			КонтрактМЧД.Представитель,
			ТипыПредставителя.ФилиалЮЛ,
			Representative.LegalSubsidiaryEntity
		);
		
	ИначеЕсли Representative.Type = ТипыПредставителяАПИ.RepresentativeForeignLegalSubsidiaryEntity Тогда
		
		ЗаполнитьПредставителяМЧДДаннымиОрганизацииАПИ(
			КонтрактМЧД.Представитель,
			ТипыПредставителя.ФилиалИностранногоЮЛ,
			Representative.ForeignLegalSubsidiaryEntity
		);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПредставителяМЧДДаннымиОрганизацииАПИ(ПредставительМЧД, ТипПредставителя, Representative)
	
	Если НЕ ЗначениеЗаполнено(Representative) Тогда
		Возврат;
	КонецЕсли;
	
	ПредставительМЧД.Тип = ТипПредставителя;
	ПредставительМЧД.Наименование = СвойствоСтруктуры(Representative, "OrganizationName");
	ПредставительМЧД.ИНН = СвойствоСтруктуры(Representative, "Inn", "");
	ПредставительМЧД.КПП = СвойствоСтруктуры(Representative, "Kpp", "");
	
КонецПроцедуры

Процедура ЗаполнитьПредставителяМЧДДаннымиФизическогоЛицаАПИ(ПредставительМЧД, PhysicalEntity)
	
	Если НЕ ЗначениеЗаполнено(PhysicalEntity) Тогда
		Возврат;
	КонецЕсли;
	
	ТипыПредставителя = Перечисление_ТипыПредставителяМЧД();
	
	PersonName = СвойствоСтруктуры(PhysicalEntity, "PersonName");
	
	Если ЗначениеЗаполнено(PersonName) Тогда
		
		Фамилия = СвойствоСтруктуры(PersonName, "LastName", "");
		Имя = СвойствоСтруктуры(PersonName, "FirstName", "");
		Отчество = СвойствоСтруктуры(PersonName, "MiddleName", "");
		
		НаименованиеПредставителя = "" + Фамилия + " " + Имя + ?(ЗначениеЗаполнено(Отчество), " " + Отчество, "");
		
	Иначе
		НаименованиеПредставителя = "";
	КонецЕсли;
	
	ПредставительМЧД.Тип = ТипыПредставителя.ФЛ;
	ПредставительМЧД.Наименование = НаименованиеПредставителя;
	ПредставительМЧД.ИНН = СвойствоСтруктуры(PhysicalEntity, "Inn", "");
	
КонецПроцедуры

