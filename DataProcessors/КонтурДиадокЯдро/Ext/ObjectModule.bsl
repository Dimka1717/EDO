// Запускает задание отправки на подпись через госключ.
//
// Параметры:
//  ПараметрыПодписанияГосключ	 - Структура - см. Контракт_ПараметрыПодписанияГосключ
// 
// Возвращаемое значение:
//  Строка - Идентификатор запущенного задания
//
Функция Госключ_НовоеЗаданиеОтправкиНаПодпись(ПараметрыПодписанияГосключ) Экспорт
	
	МассивКонтента = Новый Массив;
	Для Каждого ФайлДляПодписи Из ПараметрыПодписанияГосключ.ФайлыДляПодписи Цикл
		
		Content = Base64Строка(ФайлДляПодписи.ДвоичныеДанные);
		Content_v3 = АПИ_Новый_Content_v3(Content);
		DssSignFile = АПИ_Новый_DssSignFile(Content_v3, ФайлДляПодписи.ИмяФайла);
		МассивКонтента.Добавить(DssSignFile);
		
	КонецЦикла;
	
	GosKeyData = АПИ_Новый_GosKeyData(ПараметрыПодписанияГосключ.СНИЛС, ПараметрыПодписанияГосключ.OID);
	
	DssSignRequestV2 = АПИ_Новый_DssSignRequestV2(МассивКонтента, "GosKeySign", , GosKeyData);
	
	BoxId = ПараметрыПодписанияГосключ.boxId;
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);

	СтруктураTaskId = АПИ_DssSignV2(ПараметрыСервиса, boxId, DssSignRequestV2);
	
	Результат = "";
	Если СтруктураTaskId <> Неопределено Тогда
		Результат = СтруктураTaskId.TaskId;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет запущенное задание на подпись через госключ
//
// Параметры:
//  ИДЗаданияПодписания	 - Строка	 - Идентификатор задания на подписание
//  boxId				 - Строка	 - идентификатор ящика
// 
// Возвращаемое значение:
//  Структура - см. Контракт_РезультатПодписанияГосключ результат подписания ;
//
Функция Госключ_ПроверитьЗаданиеОтправкиНаПодпись(ИДЗаданияПодписания, boxId) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);
	
	DssSignResult = АПИ_DssSignResult(ПараметрыСервиса, boxId, ИДЗаданияПодписания);
	
	Результат = Госключ_РасшифровкаDssSignResult(DssSignResult);
	
	Возврат Результат;
	
КонецФункции

Функция Контракт_РезультатПодписанияФайлаГосключ() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("СтатусПодписания", "");
	Результат.Вставить("ЭлектроннаяПодпись", "");
	
	Возврат Результат;
	
КонецФункции

// Ответ метода Госключ_НовоеЗаданиеОтправкиНаПодпись
// 
// Возвращаемое значение:
//  Структура - содержит поля:
//  * Завершено								- Булево - признак завершения операция подписания
//  * СтатусОперации						- Строка - статус выполнения операции подписания
//  * СписокРезультатовПодписанияФайлов		- Массив из Структура - см. Контракт_РезультатПодписанияФайлаГосключ
//  * ОшибкаПриПодписании					- Булево - признак ошибки при подписании
//  * ПодробноеОписаниеСтатуса				- Строка - обобщенный текст статуса подписания или ошибки
//
Функция Контракт_РезультатПодписанияГосключ() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Завершено", Ложь);
	Результат.Вставить("СтатусОперации", "");
	Результат.Вставить("СписокРезультатовПодписанияФайлов", Новый Массив);
	Результат.Вставить("ОшибкаПриПодписании", Ложь);
	Результат.Вставить("ОтказПользователя", Ложь);
	Результат.Вставить("ПодробноеОписаниеСтатуса", "");
	
	Возврат Результат;
	
КонецФункции

// Расшифровка контракта API подписания Госключ
//
// Параметры:
//  DssSignResult	 - Структура - ответ метода Модуль_МетодыAPI.DD_API_DssSignResult
// 
// Возвращаемое значение:
//  Структура - см. Контракт_РезультатПодписанияГосключ
//
Функция Госключ_РасшифровкаDssSignResult(DssSignResult)
	
	Результат = Контракт_РезультатПодписанияГосключ();
	
	СтатусОперации = СвойствоСтруктуры(DssSignResult, "OperationStatus");
	Если ЗначениеЗаполнено(СтатусОперации) Тогда
		
		СтатусыОперации = Перечисление_СтатусыПодписанияБезНосителя();
		РасшифровкаСтатусовОперации = Госключ_РасшифровкаСтатусовОперацииПриПодписании();
		
		Завершено = Ложь;
		ОшибкаПриПодписании = Ложь;
		ПодробноеОписаниеСтатуса = "";
		ОтказПользователя = Ложь;
		
		Если СтатусОперации = СтатусыОперации.Completed Тогда
			
			Завершено = Истина;
			СписокРезультатовПодписанияФайлов = Новый Массив;
			
			FileSigningResults = DssSignResult.FileSigningResults;
			Для Каждого FileSigningResult Из FileSigningResults Цикл
				
				РезультатПодписанияФайлаГосключ = Контракт_РезультатПодписанияФайлаГосключ();
				РезультатПодписанияФайлаГосключ.СтатусПодписания = FileSigningResult.FileSigningStatus;
				РезультатПодписанияФайлаГосключ.ЭлектроннаяПодпись = FileSigningResult.Signature;
				СписокРезультатовПодписанияФайлов.Добавить(РезультатПодписанияФайлаГосключ);
				
			КонецЦикла;
			
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.Completed;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.Unknown Тогда
			
			Завершено = Истина;
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.Unknown;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.InProgress Тогда
			
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.InProgress;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.CanceledByUser Тогда
			
			Завершено = Истина;
			ОшибкаПриПодписании = Истина;
			ОтказПользователя = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.CanceledByUser;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.Timeout Тогда
			
			Завершено = Истина;
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.Timeout;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.Crashed Тогда
			
			Завершено = Истина;
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.Crashed;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.UserHasUnconfirmedOperation Тогда
			
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.UserHasUnconfirmedOperation;
			
		ИначеЕсли СтатусОперации = СтатусыОперации.OperationRetryRequired Тогда
			
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = РасшифровкаСтатусовОперации.OperationRetryRequired;
			
		Иначе
			
			Завершено = Истина;
			ОшибкаПриПодписании = Истина;
			ПодробноеОписаниеСтатуса = Общее_ПодставитьПараметрыВСтроку(
				"ru = 'Неизвестный статус операции: %1'",
				СтатусОперации);
			
		КонецЕсли;
		
		Результат.Завершено = Завершено;
		Результат.СтатусОперации = СтатусОперации;
		Результат.СписокРезультатовПодписанияФайлов = СписокРезультатовПодписанияФайлов;
		Результат.ОшибкаПриПодписании = ОшибкаПриПодписании;
		Результат.ОтказПользователя = ОтказПользователя;
		Результат.ПодробноеОписаниеСтатуса = ПодробноеОписаниеСтатуса;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Госключ_РасшифровкаСтатусовОперацииПриПодписании()
	
	Результат = Новый Структура;

	РасшифровкаСтатуса = НСтр("ru = 'Неизвестный статус операции'");
	Результат.Вставить("Unknown", РасшифровкаСтатуса);

	РасшифровкаСтатуса = НСтр("ru = 'Операция выполняется или ожидает подтверждения
	|от владельца госключа'");
	Результат.Вставить("InProgress", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'Операция успешно завершена'");
	Результат.Вставить("Completed", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'Владелец госключа отклонил запрос на подтверждение'");
	Результат.Вставить("CanceledByUser", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'Владелец госключа не подтвердил операцию
	|за отведенный промежуток времени'");
	Результат.Вставить("Timeout", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'Произошел сбой при выполнении операции'");
	Результат.Вставить("Crashed", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'У владельца госключа есть другая неподтвержденная операция.
	|Нужно подтвердить или отклонить ее и повторить запрос'");
	Результат.Вставить("UserHasUnconfirmedOperation", РасшифровкаСтатуса);
	
	РасшифровкаСтатуса = НСтр("ru = 'Нужно повторить операцию через 5 минут'");
	Результат.Вставить("OperationRetryRequired", РасшифровкаСтатуса);
	
	Возврат Результат;

КонецФункции

// Возможные статусы подписания без носителя
// 
// Возвращаемое значение:
//  Структура - возможные статусы подписания без носителя
//
Функция Перечисление_СтатусыПодписанияБезНосителя()
	
	Результат = Кэш_Прочитать("Перечисление_СтатусыПодписанияБезНосителя");
	
	Если Результат = Неопределено Тогда
	
		Результат = Новый Структура;
		Результат.Вставить("Unknown", "Unknown");
		Результат.Вставить("InProgress", "InProgress");
		Результат.Вставить("Completed", "Completed");
		Результат.Вставить("CanceledByUser", "CanceledByUser");
		Результат.Вставить("Timeout", "Timeout");
		Результат.Вставить("Crashed", "Crashed");
		Результат.Вставить("UserHasUnconfirmedOperation", "UserHasUnconfirmedOperation");
		Результат.Вставить("OperationRetryRequired", "OperationRetryRequired");
		
		Кэш_Поместить("Перечисление_СтатусыПодписанияБезНосителя", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ОтправитьПакетНаПодписаниеГосключ(Пакет, СНИЛС, OID) Экспорт
	
	ПараметрыПодписанияГосключ = Контракт_ПараметрыПодписанияГосключ();
	ФайлыДляПодписи = Новый Массив;
	BoxId = Пакет.Идентификаторы.BoxId;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДвоичныеДанные = Неопределено;
		ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента");
		
		Если ХранилищеКонтента <> Неопределено Тогда
			
			Если ЭтоАдресИзВременногоХранилища(ХранилищеКонтента.Данные) Тогда
				// BSLLS:MissingTempStorageDeletion-off
				ДвоичныеДанные = ПолучитьИзВременногоХранилища(ХранилищеКонтента.Данные);
				// BSLLS:MissingTempStorageDeletion-on
			Иначе
				ДвоичныеДанные = ХранилищеКонтента.Данные;
			КонецЕсли;
			
		КонецЕсли;
		
		ИмяФайла = Документ.ИмяФайла;
		
		Если ДвоичныеДанные <> Неопределено Тогда
			
			ФайлНаПодписание = Контракт_ФайлНаПодписаниеГосключ();
			ФайлНаПодписание.ДвоичныеДанные = ДвоичныеДанные;
			ФайлНаПодписание.ИмяФайла = ИмяФайла;
			
			ФайлыДляПодписи.Добавить(ФайлНаПодписание);
			
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыПодписанияГосключ.ФайлыДляПодписи = ФайлыДляПодписи;
	Если ЗначениеЗаполнено(СНИЛС) Тогда
		ПараметрыПодписанияГосключ.СНИЛС = СНИЛС;
	ИначеЕсли ЗначениеЗаполнено(OID) Тогда
		ПараметрыПодписанияГосключ.OID = OID;
	Иначе
		// BSLLS:Typo-off
		ВызватьИсключение НСтр("ru = 'Указаны неверные параметры при подписании пакета госключем'");
		// BSLLS:Typo-on
	КонецЕсли;
	ПараметрыПодписанияГосключ.boxId = boxId;
	
	Результат = Госключ_НовоеЗаданиеОтправкиНаПодпись(ПараметрыПодписанияГосключ);
	
	Возврат Результат;
	
КонецФункции

