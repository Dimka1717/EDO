Процедура ЗаполнитьСтрокуСпискаКонтрагентов(НоваяСтрока, КонтрагентЭДО, IDОрганизации)
	
	ЗаполнитьЗначенияСвойств(НоваяСтрока, КонтрагентЭДО);
	
	НоваяСтрока.ОрганизацияЛиквидирована = ЗначениеЗаполнено(КонтрагентЭДО.ДатаЛиквидации);
	
	ДанныеКонтрагентаЭДО = Контракт_КонтрагентЭДО();
	
	ЗаполнитьЗначенияСвойств(ДанныеКонтрагентаЭДО, КонтрагентЭДО);
	
	НоваяСтрока.ДанныеКонтрагента = ЗначениеВСтрокуВнутр(ДанныеКонтрагентаЭДО);
	
	ИдентификаторФНСОператора = ИдентификаторФНСИзИдентификаторУчастникаЭДО(
		ДанныеКонтрагентаЭДО.ИдентификаторУчастникаЭДО);
	
	НоваяСтрока.ОператорЭДО = ПредставлениеОператораЭДО(ИдентификаторФНСОператора, IDОрганизации);
	
КонецПроцедуры

Функция ПредставлениеСвязейВСпискеКонтрагенты(РеквизитыСвязанныхСправочников)
	
	КоличествоСвязанных = РеквизитыСвязанныхСправочников.Количество();
	
	Если КоличествоСвязанных > 1 Тогда
		
		ШаблонПредставления = НСтр("ru='Сопоставлено: %1'");
		
		Результат = Общее_ПодставитьПараметрыВСтроку(
			ШаблонПредставления,
			КоличествоСвязанных
		);
		
	ИначеЕсли КоличествоСвязанных = 1 Тогда
		
		Результат = РеквизитыСвязанныхСправочников[0].Наименование;
		
	Иначе
		
		Результат = "Не выбран";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Выполняет сопоставление контрагентов ЭДО с контрагентами 1С по ИНН и КПП.
// Результат сопоставления сохраняется в информационной базе в виде связи контрагентов.
//
// Параметры:
//  Организация			 - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
//  СтатусКонтрагентаЭДО - Строка	 - значение статуса контрагента ЭДО (варианты статусов см. Модуль_Ядро.Перечисление_СтатусыКонтрагентов)
// 
// Возвращаемое значение:
//  Строка - информационная строка с описанием результата работы функции (количество сопоставленных контрагентов, ошибки)
//
Функция Контрагенты_ГрупповоеСопоставление(Организация, СтатусКонтрагентаЭДО = Неопределено) Экспорт
	
	Результат = НСтр("ru = 'Сопоставлено контрагентов: %1;
						  |Ошибок сопоставления: %2;'");
						  
	РезультатСопоставления = ХранениеДанных_РезультатГрупповогоСопоставленияКонтрагентов(Организация, СтатусКонтрагентаЭДО);
	
	МассивОшибокДублей			= РезультатСопоставления.МассивОшибокДублей;
	МассивОшибокСопоставления	= РезультатСопоставления.МассивОшибокСопоставления;
	
	КоличествоОшибок			= МассивОшибокДублей.Количество() + МассивОшибокСопоставления.Количество();
	КоличествоСопоставленных	= СвойствоСтруктуры(РезультатСопоставления, "КоличествоСопоставленных"	, 0);

	Результат =	Общее_ПодставитьПараметрыВСтроку(Результат, КоличествоСопоставленных, КоличествоОшибок);
	
	Если КоличествоОшибок > 0 Тогда
		
		Результат = Результат 
					+ Символы.ПС
					+ "--------"
					+ Символы.ПС
					+ НСтр("ru = 'Детализация ошибок:'")
					+ Символы.ПС
					+ Символы.ПС
					+ СоединитьСтроку(МассивОшибокДублей		, Символы.ПС + Символы.ПС)
					+ СоединитьСтроку(МассивОшибокСопоставления	, Символы.ПС + Символы.ПС);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Выполняет сопоставление контрагентов ЭДО с контрагентами 1С по ИНН и КПП.
// Сопоставляет контрагентов информационной базы с контрагентами сервиса.
// Контрагенты, которые уже сопоставлены, исключаются из обработки.
// Поиск подходящих контрагентов сервиса выполняется по ИНН и КПП.
// Если нет подходящих контрагентов, запускается поиск по ИНН.
// Если найдено несколько записей, выбирается наиболее приоритетная. При определении приоритета учитываются:
//  - статус партнерских отношений (см. Контрагенты_ПриоритетыСтатусовСопоставления)
//  - признак того, что организация работает через роуминг (приоритет у локальных организаций)
// Если найдено несколько контрагентов сервиса с одинаковым приоритетом, выбирается один из подобранных.
//
// Параметры:
//  Организация - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
//  ПараметрСтатусыКонтрагентаЭДО - Массив, Строка - Коллекция статусов или одиночный статус контрагента ЭДО (см. Модуль_Ядро.Перечисление_СтатусыКонтрагентов)
//
// Возвращаемое значение:
//  Структура - см. Контрагенты_РезультатГрупповогоСопоставления
//
Функция Контрагенты_ГрупповоеСопоставлениеV2(Организация, ПараметрСтатусыКонтрагентаЭДО = Неопределено) Экспорт
	
	Если ТипЗнч(ПараметрСтатусыКонтрагентаЭДО) = Тип("Строка") Тогда
		
		СтатусыКонтрагентаЭДО = Новый Массив;
		СтатусыКонтрагентаЭДО.Добавить(ПараметрСтатусыКонтрагентаЭДО);
		
	Иначе
		
		СтатусыКонтрагентаЭДО = ПараметрСтатусыКонтрагентаЭДО;	
				
	КонецЕсли;
	
	ОписаниеЗамера = Метрика_НачатьЗамер_ГрупповоеСопоставлениеКонтрагентов();
	
	BoxId = АдресЯщикаВИдентификатор(Организация.ID);
	
	// Получаем несвязанных контрагентов и связываем по ИНН и КПП
	ТаблицаДляСопоставления = ХранениеДанных_НеСопоставленныеКонтрагенты();
	ТаблицаПорция = ТаблицаДляСопоставления.СкопироватьКолонки();
	
	КоличествоСопоставляемых = ТаблицаДляСопоставления.Количество();
	
	ДетальныеДанные = Контрагенты_ДетальныеДанныеГрупповогоСопоставления();
	
	Счетчик = 0;
	РазмерПорции = 100;
	
	Для Каждого СтрокаСопоставления Из ТаблицаДляСопоставления Цикл
		
		Счетчик = Счетчик + 1;
		
		СтрокаПорция = ТаблицаПорция.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПорция, СтрокаСопоставления);
		
		Если ТаблицаПорция.Количество() = РазмерПорции ИЛИ Счетчик = КоличествоСопоставляемых Тогда
			
			КоллекцияИНН = ТаблицаПорция.ВыгрузитьКолонку("ИНН");
			
			ТаблицаКонтрактов = Контрагенты_КонтрагентыСервисаПоИНН(КоллекцияИНН, Организация, СтатусыКонтрагентаЭДО);
			
			Контрагенты_ПодобратьСопоставитьКонтрагентов(ДетальныеДанные, ТаблицаПорция, ТаблицаКонтрактов);
			
			ТаблицаПорция.Очистить();
			
		КонецЕсли;
		
	КонецЦикла;
	
	АдресВХ_ДетальныеДанные = ВременноеХранилище_Поместить(
		ДетальныеДанные,
		Новый УникальныйИдентификатор
	);
	
	Результат = Контрагенты_РезультатГрупповогоСопоставленияV2(
		КоличествоСопоставляемых,
		АдресВХ_ДетальныеДанные,
		ДетальныеДанные
	);
	
	Метрика_ЗавершитьЗамер_ГрупповоеСопоставлениеКонтрагентов(ОписаниеЗамера, Результат, BoxId);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ПриоритетыСтатусовСопоставления()
	
	СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	
	Результат = Новый Соответствие;
		
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ПартнерскиеОтношения + "_ИННКПП", 1);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ПартнерскиеОтношения + "_ИННКПП", 2);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ПриглашаютВас + "_ИННКПП", 3);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ПриглашаютВас + "_ИННКПП", 4);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ОжидаетсяОтвет + "_ИННКПП", 5);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ОжидаетсяОтвет + "_ИННКПП", 6);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ПартнерскиеОтношения + "_ИНН", 7);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ПартнерскиеОтношения + "_ИНН", 8);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ПриглашаютВас + "_ИНН", 9);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ПриглашаютВас + "_ИНН", 10);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.ОжидаетсяОтвет + "_ИНН", 11);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.ОжидаетсяОтвет + "_ИНН", 12);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.РаботаетВДиадок + "_ИННКПП", 13);
	Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.РаботаетВДиадок + "_ИННКПП", 14);
	Результат.Вставить("Диадок_" + СтатусыКонтрагентов.РаботаетВДиадок + "_ИНН", 15);
    Результат.Вставить("Роуминговый_" + СтатусыКонтрагентов.РаботаетВДиадок + "_ИНН", 16);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ПриоритетСтрокиСопоставленияКонтрагента(Роуминговый, Статус, КритерийСопоставления)
	
	ПриоритетыСтатусовСопоставления = Контрагенты_ПриоритетыСтатусовСопоставления();
	
	Если Роуминговый Тогда
		КлючСопоставления = "Роуминговый_" + Статус + "_" + КритерийСопоставления;
	Иначе
		КлючСопоставления = "Диадок_" + Статус + "_" + КритерийСопоставления;
	КонецЕсли;
	
	ПриоритетСопоставления = ПриоритетыСтатусовСопоставления.Получить(КлючСопоставления);
	
	Возврат ПриоритетСопоставления;
	
КонецФункции

Процедура ДобавитьПодходящиеКонтрагенты(ПодходящиеКонтрагенты, НайденнаяЗапись, КритерийОтбора)
	
	СтрокаПодходящиеКонтрагенты = ПодходящиеКонтрагенты.Добавить();
	
	ЗаполнитьЗначенияСвойств(СтрокаПодходящиеКонтрагенты, НайденнаяЗапись);
	
	СтрокаПодходящиеКонтрагенты.Приоритет = Контрагенты_ПриоритетСтрокиСопоставленияКонтрагента(
		НайденнаяЗапись.Роуминговый,
		НайденнаяЗапись.Статус,
		КритерийОтбора
	);
	
КонецПроцедуры

Процедура Контрагенты_СопоставитьКонтрагентов(КонтрагентИБ, ИдентификаторыЭДО) Экспорт
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Модуль_ХранениеДанных.Контрагенты_СопоставитьКонтрагентов(КонтрагентИБ, ИдентификаторыЭДО);
	
КонецПроцедуры

// Получает сведения о контрагентах по заданному списку ИНН.
//
// Параметры:
//  КоллекцияИНН - Массив из Строка - список ИНН для для отбора контрагентов.
//  Организация - Структура - см. Контракт_ОрганизацияЭДО
//  СтатусыКонтрагентаЭДО - Массив - (необязательный) статусы партнерских отношений для отбора контрагентов (см. Перечисление_СтатусыКонтрагентов)
//
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Ссылка - СправочникСсылка.Диадок_ЮрФизЛица
//   * ИНН- Строка - ИНН контрагента
//   * КПП- Строка - КПП контрагента
//   * ID - Строка - идентификатор ящика контрагента
//   * Роуминговый - Булево - Истина, если это роуминговый ящик контрагента
//   * Статус - Строка - статус партнерских отношений (см. Перечисление_СтатусыКонтрагентов)
//
Функция Контрагенты_КонтрагентыСервисаПоИНН(КоллекцияИНН, Организация, СтатусыКонтрагентаЭДО = Неопределено)
	
	КоллекцияПроверенныхИНН = Контрагенты_МассивПроверенныхИНН(КоллекцияИНН);
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		ОрганизацияЭДО = Организация.Ссылка;
		Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
		ВыборкаКонтрагентов = Модуль_ХранениеДанных.Контрагенты_КонтрагентыСервисаПоИНН_Диадок(
				КоллекцияПроверенныхИНН,
				ОрганизацияЭДО
			);
		
	Иначе
		
		КонтрагентыАПИ = Контрагенты_МассивOrganizationsByInn(
				КоллекцияПроверенныхИНН,
				Организация
			);
		ВыборкаКонтрагентов = Контрагенты_ТаблицаКонтрактовПоOrganizationsResponse(КонтрагентыАПИ);
		
	КонецЕсли;
	
	ОтборПоСтатусу = ЗначениеЗаполнено(СтатусыКонтрагентаЭДО);
	
	Перечисление_СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	
	ТребуемыеКолонки = "ID, Ссылка, ИНН, КПП, Роуминговый, Статус";
	Результат = ВыборкаКонтрагентов.СкопироватьКолонки(ТребуемыеКолонки);
	
	Для Каждого ЭлементВыборки Из ВыборкаКонтрагентов Цикл
		
		Если ЗначениеЗаполнено(ЭлементВыборки.ДатаЛиквидации) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭлементВыборки.Статус = Перечисление_СтатусыКонтрагентов.ЗаблокированМной
			ИЛИ ЭлементВыборки.Статус = Перечисление_СтатусыКонтрагентов.ЗаблокировалМеня Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОтборПоСтатусу И СтатусыКонтрагентаЭДО.Найти(ЭлементВыборки.Статус) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаРезультата = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаРезультата, ЭлементВыборки);
		
	КонецЦикла;
	
	Результат.Индексы.Добавить("ИНН,КПП");
	Результат.Индексы.Добавить("ИНН");
	
	Возврат Результат;
	
КонецФункции

// Получает сведения о контрагентах по заданному списку ИНН.
//
// Параметры:
//  ИНН - Строка - ИНН для для поиска контрагентов в сервисе.
//  BoxId - строка - BoxId организации для поиска контрагентов в сервисе
//
// Возвращаемое значение:
//  ТаблицаЗначений - см. Контрагенты_НоваяТаблицаКонтрактов
//
Функция Контрагенты_СписокДляСопоставленияКонтрагентаИБ(ИНН, BoxId) Экспорт
	
	Результат = Неопределено;
	
	КоллекцияИНН = Новый Массив;
	КоллекцияИНН.Добавить(ИНН);
	
	КоллекцияПроверенныхИНН = Контрагенты_МассивПроверенныхИНН(КоллекцияИНН);
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
	Организация = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	КонтрагентыАПИ = Контрагенты_МассивOrganizationsByInn(
		КоллекцияПроверенныхИНН,
		Организация
	);
	
	Результат = Контрагенты_ТаблицаКонтрактовПоOrganizationsResponse(КонтрагентыАПИ);
	ДобавитьРеквизитыКонтрагентовИБ = Истина;
	
	ХранениеДанных_ДополнитьТаблицуКонтрагеновЭДОДаннымиИБ(Результат, Организация, ДобавитьРеквизитыКонтрагентовИБ);
	
	Возврат Результат;
	
КонецФункции

// Обновляет данные контрагента в базе 1С данными с сервера Диадока
//
// Параметры:
//  КонтрагентЭДО - Структура - см. функцию Контракт_КонтрагентЭДО()
//  BoxId - строка - BoxId организации для поиска контрагентов в сервисе
//
Процедура Контрагенты_ОбновитьКонтрагентаЭДО(КонтрагентЭДО, BoxId) Экспорт
	
	Если НЕ ИспользоватьПодсистемуДиадока() Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
	ОрганизацияЭДО = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	ХранениеДанных_ЗаписатьКонтрагента(КонтрагентЭДО);
	ХранениеДанных_ЗаписатьСтатусКонтрагента(КонтрагентЭДО, ОрганизацияЭДО);
	ХранениеДанных_ЗаписатьДатуИзмененияКонтрагента(КонтрагентЭДО, ОрганизацияЭДО);
	
КонецПроцедуры

// Очищает сохраненные в памяти списки контрагентов после сопоставления нового контрагента
//
// Параметры
//  BoxId - строка - BoxId организации для которой выполнено сопоставление контрагента
//
Процедура Контрагенты_ОчиститьКЭШПослеСопоставленияКонтрагента(BoxId) Экспорт
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
	Организация = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаПартнеров(Организация);
	Контрагенты_ОчиститьСписок(ПараметрыСписка);
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаПартнеровДляРазделаКонтрагентов(Организация);
	Контрагенты_ОчиститьСписок(ПараметрыСписка);
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаДляПриглашения(Организация);
	Контрагенты_ОчиститьСписок(ПараметрыСписка);
	
	Кэш_Поместить("УчастникиЭДО_Контрагенты", Неопределено);
	
КонецПроцедуры

Функция Контрагенты_СоответствиеСтатусовКонтрагентовРежимуОтображения()
	
	Результат = Новый Соответствие;
	
	МассивПриглашения = Новый Массив;
	МассивПриглашения.Добавить(Перечисление_СтатусыКонтрагентов().РаботаетВДиадок);
	МассивПриглашения.Добавить(Перечисление_СтатусыКонтрагентов().ЗаблокировалМеня);
	МассивПриглашения.Добавить(Перечисление_СтатусыКонтрагентов().ЗаблокированМной);
	
	МассивВашиКонтрагенты = Новый Массив;
	МассивВашиКонтрагенты.Добавить(Перечисление_СтатусыКонтрагентов().ПартнерскиеОтношения);
	
	МассивПриглашаютВас = Новый Массив;
	МассивПриглашаютВас.Добавить(Перечисление_СтатусыКонтрагентов().ПриглашаютВас);
	
	МассивОжидаетсяОтвет = Новый Массив;
	МассивОжидаетсяОтвет.Добавить(Перечисление_СтатусыКонтрагентов().ОжидаетсяОтвет);
	
	Результат.Вставить("ПоискИПриглашение",	МассивПриглашения);
	Результат.Вставить("ВашиКонтрагенты",	МассивВашиКонтрагенты);
	Результат.Вставить("ПриглашаютВас",		МассивПриглашаютВас);
	Результат.Вставить("ОжидаетсяОтвет",	МассивОжидаетсяОтвет);

	Возврат Результат;
	
КонецФункции	

Процедура Контрагенты_ДополнитьТаблицуКоличествомДокументовЗаПериод(КонтрагентыЭДО, ОрганизацияЭДО)
	
	Если КонтрагентыЭДО.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СопоставленныеКонтрагенты = ХранениеДанных_СопоставитьКонтрагентовПоИННКПП(КонтрагентыЭДО);
	СопоставленныеКонтрагенты.Колонки.Добавить("ДокументовЗаПериод", Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(10)));
	
	КонтрагентыЭДО.Колонки.Добавить("Контрагент1С", Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(10)));
	
	Контрагенты1С = СопоставленныеКонтрагенты.ВыгрузитьКолонку("Контрагент1С");
	Организация1С = ОрганизацияЭДО.СвязанныйСправочник1;
	
	Параметры = Новый Структура;
	Параметры.Вставить("МассивКонтрагентов",	Контрагенты1С);
	Параметры.Вставить("Организация",			ОрганизацияЭДО.СвязанныйСправочник1);
	
	КоличествоДокументовПоКонтрагентам = ПодключаемыйМодуль_ОбработатьСобытие("ПолучитьКоличествоДокументовЗаПериод", Параметры);
	
	Если ЗначениеЗаполнено(КоличествоДокументовПоКонтрагентам) Тогда
		
		КоличествоДокументовПоКонтрагентам.Индексы.Добавить("Связь1");
			
		Для Каждого СтрокаСвязей Из СопоставленныеКонтрагенты Цикл
			
			НайденнаяСтрока = КоличествоДокументовПоКонтрагентам.Найти(СтрокаСвязей.Контрагент1С, "Связь1");
			Если НайденнаяСтрока <> Неопределено Тогда
				СтрокаСвязей.ДокументовЗаПериод = НайденнаяСтрока.ДокументовЗаПериод;
			КонецЕсли;
			
		КонецЦикла;
		
		СопоставленныеКонтрагенты.Свернуть("КонтрагентЭДО", "ДокументовЗаПериод");
		
		СопоставленныеКонтрагенты.Индексы.Добавить("КонтрагентЭДО");
		
	Иначе
		СопоставленныеКонтрагенты.Очистить();
		
	КонецЕсли;
	
	Для Каждого Контрагент Из КонтрагентыЭДО Цикл
		
		НайденнаяСтрока = СопоставленныеКонтрагенты.Найти(Контрагент.ID, "КонтрагентЭДО");
		Если НайденнаяСтрока <> Неопределено Тогда
			Контрагент.ДокументовЗаПериод = НайденнаяСтрока.ДокументовЗаПериод;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Контрагенты_ЗаголовокКолонкиКонтрагента(РежимОтображения) Экспорт
	
	Результат = "Контрагент";
	
	Если РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ВашиКонтрагенты Тогда
		
		Результат = "Наименование";
		
	ИначеЕсли РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ПоискИПриглашение Тогда
		
		Результат = "Контрагент в Диадок";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_СтруктураРежимовОтображения(РежимОтображения) Экспорт
	
	Результат = Новый Структура;
	
	ВашиКА		= РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ВашиКонтрагенты;
	Поиск		= РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ПоискИПриглашение;
	Приглашают	= РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ПриглашаютВас;
	Ожидают		= РежимОтображения = Перечисление_ОтношенияСКонтрагентами().ОжидаетсяОтвет;
	
	Результат.Вставить("ВашиКА",		ВашиКА);
	Результат.Вставить("Поиск",			Поиск);
	Результат.Вставить("Приглашают",	Приглашают);
	Результат.Вставить("Ожидают",		Ожидают);
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаполнитьДеревоРежимов(ДеревоРежимов) Экспорт
	
	ДеревоРежимов.Строки.Очистить();
	
	НовСтрокаДерева = ДеревоРежимов.Строки.Добавить();
	
	НовСтрокаДерева.Имя				= "ПоискИПриглашение";
	НовСтрокаДерева.Представление	= "Поиск и приглашение";
	
	НовСтрокаДерева = ДеревоРежимов.Строки.Добавить();
	
	НовСтрокаДерева.Имя				= "ВашиКонтрагенты";
	НовСтрокаДерева.Представление	= "Ваши контрагенты";
	
	НовСтрокаДерева = ДеревоРежимов.Строки.Добавить();
	
	НовСтрокаДерева.Имя				= "ПриглашаютВас";
	НовСтрокаДерева.Представление	= "Приглашают вас";
	
	НовСтрокаДерева = ДеревоРежимов.Строки.Добавить();
	
	НовСтрокаДерева.Имя				= "ОжидаетсяОтвет";
	НовСтрокаДерева.Представление	= "Ожидается ответ";
	
КонецПроцедуры	

Функция Контрагенты_ТекстПриглашенияДляКонтрагентов(Организация) Экспорт
	
	Результат = "";
	
	BoxId					= Организация.ID;
	НаименованиеОрганизации = Организация.Наименование;
	
	СтрокаКонтекста	= КонтекстСеанса_СтрокаКонтекста(BoxId);
	
	Если ЗначениеЗаполнено(СтрокаКонтекста.ОписаниеПользователя) Тогда 
		Должность	= СтрокаКонтекста.ОписаниеПользователя.Должность;
		ФИО			= СтрокаКонтекста.ОписаниеПользователя.ФИО;
	Иначе
		Должность	= "";
		ФИО			= "";
	КонецЕсли;
	
	Результат = "Уважаемый контрагент!
				| 
				|Сообщаем Вам, что компания " + НаименованиеОрганизации + " перешла на электронный обмен юридически значимыми документами.
				|Мы готовы выставлять и принимать счета-фактуры, акты и накладные, УПД, акты сверок, а также вести переписку с вами в электронном виде без дублирования на бумаге.
				| 
				|Чтобы подтвердить свое согласие и перейти на электронный документооборот, примите данное приглашение.
				| 
				|С уважением, " + Должность + " " + ФИО;
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ОчиститьСписок(ПараметрыПолученияСписка) Экспорт
	
	Кэш_Поместить(ПараметрыПолученияСписка.Ключ, Неопределено);
	
КонецПроцедуры	

Функция Контрагенты_ТребуетсяЗагружатьДокументы(Организация, ИдентификаторЯщикаКонтрагентаЭДО)
	
	Результат = Истина;
	
	ЗагружатьПоСопоставленнымКонтрагентам = ОбщиеНастройки_Прочитать("ЗагружатьДокументыПоСопоставленнымКонтрагентам");
	
	Если ЗагружатьПоСопоставленнымКонтрагентам Тогда
		
		Идентификаторы 	= Новый_ИдентификаторыСправочника(, ИдентификаторЯщикаКонтрагентаЭДО);
		КонтрагентыИБ 	= Контрагенты_СопоставленныеВ1С(Идентификаторы);
		Результат 		= ЗначениеЗаполнено(КонтрагентыИБ);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТребуетсяШифрованиеДокументов(ДанныеОрганизации, ДанныеКонтрагента) Экспорт
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(ДанныеОрганизации.Ссылка, ДанныеОрганизации.ID);
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(ДанныеКонтрагента.Ссылка, ДанныеКонтрагента.ID);
	
	Результат = Документы_ТребуетсяШифрованиеДокументов(ИдентификаторыОрганизации, ИдентификаторыКонтрагента);
	
	Возврат Результат;
	
КонецФункции

// Возвращаем параметры для получения списка контрагентов 
// 
// Возвращаемое значение:
//  Структура - структура параметров для получения списка контрагентов
//		* ДобавитьРеквизитыКонтрагентовИБ 		- Булево - если значение Истина, в таблицу контрактов будет добавлена колонка,
//															содержащая массив структур значений реквизитов контрагентов ИБ
//															см. ХранениеДанных.Контракт_РеквизитыКонтрагентов1С
//		* ДобавитьКоличествоДокументовЗаПериод 	- Булево - если значение Истина, в таблицу контрактов будет добавлена колонка,
//															содержащая количество документов контрагента за 3 месяца
//															Колечество документов за период определяется в ПМ.
//		* Упорядочить 							- Булево - если значение Истина, список контрагентов будет отсортирован по наименованию контрагента
//		* Ключ 									- Строка - используется для сохранения и получения списка контрагентов в кэше
//		* Отбор - Структура - значения отбора списка документов
//			* ОрганизацияЭДО - Структура 	- данные организации ЭДО. см Контракт_ОрганизацияЭДО
//			* Статусы 		 - Массив 		- статусы контрагентов ЭДО. см. Перечисление_СтатусыКонтрагентов
//
Функция Контрагенты_ПараметрыПолученияСписка()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ДобавитьРеквизитыКонтрагентовИБ"		, Истина);
	Результат.Вставить("ДобавитьКоличествоДокументовЗаПериод"	, Ложь);
	Результат.Вставить("Упорядочить"							, Истина);
	
	Результат.Вставить("Ключ", "");
	
	Результат.Вставить("Отбор", Новый Структура);
	
	Результат.Отбор.Вставить("ОрганизацияЭДО"	, Неопределено);
	Результат.Отбор.Вставить("Статусы"			, Новый Массив);
	
	Возврат Результат;
	
КонецФункции

// Возвращаем параметры для получения списка партнеров.
// Контрагенты в статусе "IsMyCounteragent" 
//
// Параметры:
//  ОрганизацияЭДО - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
// 
// Возвращаемое значение:
//  Структура - см. Контрагенты_ПараметрыПолученияСписка
//
Функция Контрагенты_ПараметрыПолученияСпискаПартнеров(ОрганизацияЭДО) Экспорт
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСписка();
	ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ = Истина;
	
	КлючСписка = Контрагенты_КлючСпискаКонтрагентов(ОрганизацияЭДО.ID, "ПартнерыОрганизации");
	ПараметрыСписка.Ключ = КлючСписка;
	
	СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ПартнерскиеОтношения);
	
	ПараметрыСписка.Отбор.ОрганизацияЭДО = ОрганизацияЭДО;
	
	Возврат ПараметрыСписка;
	
КонецФункции

// Возвращаем параметры для получения списка партнеров.
// Контрагенты в статусе "IsMyCounteragent", "IsInviteMe", "isInvitedByMe" 
//
// Параметры:
//  ОрганизацияЭДО - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
// 
// Возвращаемое значение:
//  Структура - см. Контрагенты_ПараметрыПолученияСписка
//
Функция Контрагенты_ПараметрыПолученияСпискаПартнеровДляРазделаКонтрагентов(ОрганизацияЭДО) Экспорт
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСписка();
	ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ = Истина;
	
	КлючСписка = Контрагенты_КлючСпискаКонтрагентов(ОрганизацияЭДО.ID, "РазделРаботыСКонтрагентами");
	ПараметрыСписка.Ключ = КлючСписка;
	
	СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ПартнерскиеОтношения);
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ПриглашаютВас);
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ОжидаетсяОтвет);
	
	ПараметрыСписка.Отбор.ОрганизацияЭДО = ОрганизацияЭДО;
	
	Возврат ПараметрыСписка;
	
КонецФункции

// Возвращаем параметры для получения списка контрагентов, работающих в Диадок, но неявляющихся партнерами.
// Контрагенты в статусах "NotInCounteragentList", "RejectsMe", "IsRejectedByMe" 
//
// Параметры:
//  ОрганизацияЭДО - Структура - данные организации ЭДО (см. Модуль_Ядро.Контракт_ОрганизацияЭДО)
// 
// Возвращаемое значение:
//  Структура - см. Контрагенты_ПараметрыПолученияСписка
//
Функция Контрагенты_ПараметрыПолученияСпискаДляПриглашения(ОрганизацияЭДО) Экспорт
	
	ПараметрыСписка = Контрагенты_ПараметрыПолученияСписка();
	ПараметрыСписка.ДобавитьКоличествоДокументовЗаПериод = Истина;
	
	КлючСписка = Контрагенты_КлючСпискаКонтрагентов(ОрганизацияЭДО.ID, "РаботающиеВДиадок");
	ПараметрыСписка.Ключ = КлючСписка;
	
	СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.РаботаетВДиадок);
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ЗаблокировалМеня);
	ПараметрыСписка.Отбор.Статусы.Добавить(СтатусыКонтрагентов.ЗаблокированМной);
	
	ПараметрыСписка.Отбор.ОрганизацияЭДО = ОрганизацияЭДО;
	
	Возврат ПараметрыСписка;
	
КонецФункции

//
Функция Контрагенты_КлючСпискаКонтрагентов(ЧастьКлюча1, ЧастьКлюча2)
	
	ШаблонКлюча = "СписокКонтрагентов_%1_%2";
	
	Результат = Общее_ПодставитьПараметрыВСтроку(ШаблонКлюча, ЧастьКлюча1, ЧастьКлюча2);
	
	Возврат Результат;	
	
КонецФункции

//	СПИСКИ КОНТРАГЕНТОВ: ДЕЙСТВИЯ АПИ

Функция Контрагенты_КомментарийИДокументПриглашения(Организация, МассивКонтрагентов) Экспорт
	
	Результат = Новый Соответствие;
	
	BoxId_Организации	= Организация.ID;
	OrgId_Организации	= Организация.OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId_Организации);
	
	Для Каждого Контрагент Из МассивКонтрагентов Цикл
		
		BoxId_Контрагента		= Контрагент.ID;
		OrgId_Контрагента		= Контрагент.OrgId;
		
		Комментарий				= Контрагенты_Комментарий(ПараметрыСервиса, OrgId_Организации, OrgId_Контрагента);
		СтруктураФайла			= Контрагенты_ДокументПриглашения(ПараметрыСервиса, BoxId_Организации, OrgId_Организации, OrgId_Контрагента);
		
		СтруктураПриглашения = Новый Структура;
		
		СтруктураПриглашения.Вставить("Контрагент",		Контрагент);
		СтруктураПриглашения.Вставить("Комментарий",	Комментарий);
		СтруктураПриглашения.Вставить("Файл",			СтруктураФайла);
		
		Результат.Вставить(Контрагент.ID, СтруктураПриглашения);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Получает сведения о приглашении (установлении статуса партнерства)
//
// Параметры:
//  myBoxId - Строка - идентификатор ящика организации
//  myOrgId - Строка - идентификатор организации-контрагента
//  CounteragentOrgId - Строка - идентификатор 
// 
// Возвращаемое значение:
//  Структура - содержит поля:
//    * Комментарий - Строка - Текст приглашения
//    * Документ - Контракт_Документ, Неопределено - документ, приложенный к приглашению
//    * ТребуетсяПодпись - Булево - Истина, если требуется подписать вложение
//
Функция Контрагенты_СведенияОПриглашении(myBoxId, myOrgId, CounteragentOrgId) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(myBoxId);
	
	Комментарий = Контрагенты_Комментарий(ПараметрыСервиса, myOrgId, CounteragentOrgId);
	Вложение = Контрагенты_ДокументПриглашения(ПараметрыСервиса, myBoxId, myOrgId, CounteragentOrgId);
	
	Документ = Неопределено;
	
	Если Вложение.ТребуетсяПодпись Тогда
		
		Документ = Документы_ДанныеДокумента(
				myBoxId, 
				Вложение.MessageID, 
				Вложение.EntityID);
		
		Если НЕ ЗначениеЗаполнено(Документ.Идентификаторы.BoxID)
				И ИспользоватьПодсистемуДиадока() Тогда
			
			ДокументAPI = АПИ_GetDocument(
				ПараметрыСервиса, 
				myBoxId, 
				Вложение.MessageID, 
				Вложение.EntityID);
			
			Документ = Документы_ДанныеДокументаАПИ(
				myBoxId, 
				ДокументAPI);
			
			Лента_ЗаписатьДокументЭДО(Документ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТребуетсяПодпись", Вложение.ТребуетсяПодпись);
	Результат.Вставить("Комментарий", Комментарий);
	Результат.Вставить("Документ", Документ);
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ПриглашениеКонтрагента() Экспорт

	Результат = Новый Структура;
	
	Результат.Вставить("Контрагент");
	Результат.Вставить("Комментарий");
	
	СтруктураФайла = Новый Структура;
	СтруктураФайла.Вставить("ИмяФайла");
	СтруктураФайла.Вставить("Данные");
	СтруктураФайла.Вставить("ДанныеПодписи");
	СтруктураФайла.Вставить("MessageId");
	СтруктураФайла.Вставить("EntityId");
	СтруктураФайла.Вставить("ТребуетсяПодпись", Ложь);
	
	Результат.Вставить("Файл",			СтруктураФайла);
	
	Возврат Результат;
	
КонецФункции

// Отправляет контрагенту приглашение к партнерским отношениям.
//
// Параметры:
//  Организация - Структура - Описание организации, от имени которой выполняется отправка приглагшения контрагенту.
//  МассивКонтрагентов - Массив - Коллекция контрагентов, которым будут отправены приглашения.
//  ПараметрыПриглашения - Структура - Текстовое описание приглашения:
//   * ТекстПриглашения - Текст сообщения с приглашением контрагенту.
//   * ИмяФайла - Полное имя файла-вложения к приглашению.
// 
// Возвращаемое значение:
//  Структура - Результат отправки приглашений контрагентам:
//   * ПриглашенныеКонтрагенты - Массив - Коллекция контрагентов, которым были отправлены приглашения.
//   * ДетальныеДанные - Строка - Адрес детальных данных во временном хранилище.
//
Функция Контрагенты_ОтправитьПриглашение(Организация, МассивКонтрагентов, ПараметрыПриглашения = Неопределено) Экспорт
	
	ТекстПриглашения	= СвойствоСтруктуры(ПараметрыПриглашения, "ТекстПриглашения");
	BoxId_Организации	= Организация.ID;
	OrgId_Организации	= Организация.OrgId;
	
	InvitationDocument	 = Контрагенты_ОписаниеВложенияДляОтправкиПриглашения(ПараметрыПриглашения, BoxId_Организации);
	ЕстьВложение		 = ЗначениеЗаполнено(InvitationDocument);
	
	СтатусыОтправкиПриглашения = Контрагенты_СтатусыРезультатовОтправкиПриглашения();
	ДетальныеДанные = Контрагенты_ДетальныеДанныеОтправкиПриглашений();
	
	ПриглашенныеКонтрагенты = Новый Массив;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId_Организации);
	
	Для Каждого Контрагент Из МассивКонтрагентов Цикл
		
		Если ЗначениеЗаполнено(Контрагент.ДатаЛиквидации) Тогда
			Продолжить;
		КонецЕсли;
		
		OrgId_Контрагента	= Контрагент.OrgId;
		ИНН					= Контрагент.ИНН;
		Вложение			= InvitationDocument;
		
		Если ЕстьВложение
			И Контрагент.Роуминговый Тогда
			
			Вложение = Неопределено;
			
			Контрагенты_ЗаписатьОшибкуОтправкиПриглашенияСВложениемВРоуминг(
				Контрагент.Наименование,
				Контрагент.ИНН,
				Контрагент.КПП
			);
			
			Статус = СтатусыОтправкиПриглашения.ОтправленоВРоумингБезВложения;
			
		КонецЕсли;
		
		AcquireCounteragentRequest = АПИ_AcquireCounteragentRequest(OrgId_Контрагента, ТекстПриглашения, Вложение, ИНН);
		
		ОтправкаПриглашения = АПИ_AcquireCounteragent(ПараметрыСервиса, OrgId_Организации, AcquireCounteragentRequest);
		ОтправкаПриглашения_Отправлено = (ОтправкаПриглашения.КодОтвета = 200);
		ОтправкаПриглашения_НетАвтороуминга = (ОтправкаПриглашения.КодОтвета = 409);
		
		Если ОтправкаПриглашения_Отправлено Тогда
			
			Пока Истина Цикл
				
				TaskId = ОтправкаПриглашения.РезультатОтвета;
				
				РезультатОтправки = АПИ_AcquireCounteragentResult(ПараметрыСервиса, TaskId);
				
				Если ЗначениеЗаполнено(РезультатОтправки.ВремяОжидания) Тогда
					Таймаут(РезультатОтправки.ВремяОжидания);
				Иначе
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			ПриглашенныеКонтрагенты.Добавить(Контрагент);
			
			Статус = СтатусыОтправкиПриглашения.ПриглашениеОтправлено;
			
		ИначеЕсли ОтправкаПриглашения_НетАвтороуминга Тогда
			
			Статус = СтатусыОтправкиПриглашения.НетАвтороуминга;
			
		Иначе
			
			Контрагенты_ЗаписатьОшибкуОтправкиПриглашения(
				Контрагент.Наименование,
				Контрагент.ИНН,
				Контрагент.КПП,
				ОтправкаПриглашения
			);
			
			Статус = СтатусыОтправкиПриглашения.ОшибкаОтправки;
			
		КонецЕсли;
		
		ИдентификаторФНС = ИдентификаторФНСИзИдентификаторУчастникаЭДО(Контрагент.ИдентификаторУчастникаЭДО);
		
		ОператорЭДО = ПредставлениеОператораЭДО(
			ИдентификаторФНС,
			BoxId_Организации
		);
		
		НоваяСтрока = ДетальныеДанные.Добавить();
		НоваяСтрока.Наименование = Контрагент.Наименование;
		НоваяСтрока.ИНН = Контрагент.ИНН;
		НоваяСтрока.КПП = Контрагент.КПП;
		НоваяСтрока.Статус = Статус;
		НоваяСтрока.ОператорЭДО = ОператорЭДО;
		
	КонецЦикла;
	
	АдресВХ_ДетальныеДанные = ВременноеХранилище_Поместить(
		ДетальныеДанные,
		Новый УникальныйИдентификатор
	);
	
	Результат = Новый Структура;
	Результат.Вставить("ПриглашенныеКонтрагенты", ПриглашенныеКонтрагенты);
	Результат.Вставить("ДетальныеДанные", АдресВХ_ДетальныеДанные);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ОписаниеВложенияДляОтправкиПриглашения(ПараметрыПриглашения, BoxId_Организации)
	
	Результат = Неопределено; 
	
	ДвоичныеДанныеФайла	 = СвойствоСтруктуры(ПараметрыПриглашения, "ДвоичныеДанныеФайла");
	Если ЗначениеЗаполнено(ДвоичныеДанныеФайла) Тогда
		
		КонтрактМЧД = Неопределено;
		Если НЕ ПараметрыПриглашения.Свойство("КонтрактМЧД", КонтрактМЧД) Тогда
			ДанныеМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(BoxId_Организации);
			Если ДанныеМЧД.ТребуетсяМЧД И ЗначениеЗаполнено(ДанныеМЧД.МЧД) Тогда
				КонтрактМЧД	= ДанныеМЧД.СписокМЧД.Получить(ДанныеМЧД.МЧД);
			КонецЕсли;
		КонецЕсли;
		
		ИмяФайла					 = СвойствоСтруктуры(ПараметрыПриглашения, "ИмяФайла");
		ДвоичныеДанныеПодписи		 = СвойствоСтруктуры(ПараметрыПриглашения, "ДвоичныеДанныеПодписи");
		ЗапрашиватьОтветнуюПодпись	 = СвойствоСтруктуры(ПараметрыПриглашения, "ЗапрашиватьОтветнуюПодпись");
		
		PowerOfAttorney	 			 = АПИ_Новый_PowerOfAttorneyToPost(КонтрактМЧД);
		NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
			BoxId_Организации,
			ДвоичныеДанныеФайла);
			
		SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
			BoxId_Организации,
			ДвоичныеДанныеПодписи);
		
		SignedContent   			 = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorney);
		Результат					 = АПИ_Новый_InvitationDocument(SignedContent, ИмяФайла, ЗапрашиватьОтветнуюПодпись);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаписатьОшибкуОтправкиПриглашенияСВложениемВРоуминг(НаименованиеКонтрагента, ИННКонтрагента, КППКонтрагента)
	
	ВидОперации = НСтр("ru='Приглашение отправлено без вложения, контрагент в роуминге.'");
	
	ШаблонСообщения = НСтр("ru='%1 ИНН-КПП: %2-%3'");
	
	ТекстСообщения = Общее_ПодставитьПараметрыВСтроку(
		ШаблонСообщения,
		НаименованиеКонтрагента,
		ИННКонтрагента,
		КППКонтрагента
	);
	
	СписокОшибок_ДобавитьИнформацию(
		ВидОперации,
		ТекстСообщения
	);
	
КонецПроцедуры

Функция Контрагенты_ПринятьПриглашение(Организация, ПриглашенияКонтрагентов) Экспорт
	
	Результат = Новый Массив;
	
	BoxId = Организация.ID;
	
	ДанныеМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(BoxId);
	
	КонтрагентыБезЗапросаПодписи = Новый Массив;
	
	Для Каждого КлючЗначение Из ПриглашенияКонтрагентов Цикл
		
		Контрагент_ID	 = КлючЗначение.Ключ;
		Приглашение		 = КлючЗначение.Значение;
		
		MessageId			 = СвойствоСтруктуры(Приглашение.Файл,	"MessageId");
		EntityId			 = СвойствоСтруктуры(Приглашение.Файл,	"EntityId");
		Данные				 = СвойствоСтруктуры(Приглашение.Файл,	"Данные");
		ДанныеПодписи		 = СвойствоСтруктуры(Приглашение.Файл,	"ДанныеПодписи");
		ТребуетсяПодпись	 = СвойствоСтруктуры(Приглашение.Файл,	"ТребуетсяПодпись");
		Контрагент			 = СвойствоСтруктуры(Приглашение,		"Контрагент");
		
		Если ТребуетсяПодпись Тогда
			
			Идентификаторы = Новый Структура;
			Идентификаторы.Вставить("BoxId",	 BoxId);
			Идентификаторы.Вставить("LetterId",	 MessageId);
			
			КонтрактМЧД = Неопределено;
			Если ДанныеМЧД.ТребуетсяМЧД И НЕ Приглашение.Файл.Свойство("КонтрактМЧД", КонтрактМЧД) Тогда
				КонтрактМЧД	= ДанныеМЧД.СписокМЧД.Получить(ДанныеМЧД.МЧД);
			КонецЕсли;
			
			PowerOfAttorney	= АПИ_Новый_PowerOfAttorneyToPost(КонтрактМЧД);
			
			ИмяКоллекции	= "Signatures";
			Attachment		= АПИ_Новый_DocumentSignature(EntityId, ДанныеПодписи, , , PowerOfAttorney);
			
			ПодготовленнаяСтруктура = Новый Структура;
			ПодготовленнаяСтруктура.Вставить(ИмяКоллекции, Attachment);
			
			РезультатОтправки = РезультатPostMessagePatch(Идентификаторы, ПодготовленнаяСтруктура);
			
			Результат.Добавить(Контрагент);
			
		Иначе
			
			КонтрагентыБезЗапросаПодписи.Добавить(Контрагент);
			
		КонецЕсли;
		
	КонецЦикла;
	
	РезультатОтправкиПриглашений = Контрагенты_ОтправитьПриглашение(Организация, КонтрагентыБезЗапросаПодписи);
	КонтрагентыБезЗапросаПодписи = РезультатОтправкиПриглашений.ПриглашенныеКонтрагенты;
	
	Для Каждого Контрагент Из КонтрагентыБезЗапросаПодписи Цикл
		Результат.Добавить(Контрагент);
	КонецЦикла;
	
	Контрагенты_ЗаписатьСтатусДляМассиваКонтрагентов(Организация, Результат, Перечисление_СтатусыКонтрагентов().ПартнерскиеОтношения);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_Заблокировать(Организация, МассивКонтрагентов, Комментарий = "") Экспорт
	
	Результат = Новый Массив;
	
	BoxId_Организации	= Организация.ID;
	OrgId_Организации	= Организация.OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId_Организации);
	
	Для Каждого Контрагент Из МассивКонтрагентов Цикл
		
		OrgId_Контрагента = Контрагент.OrgId;
		
		АПИ_BreakWithCounteragent(ПараметрыСервиса, OrgId_Организации, OrgId_Контрагента, Комментарий);
		
		Результат.Добавить(Контрагент);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаписатьСтатусДляМассиваКонтрагентов(Организация, МассивКонтрагентов, Статус) Экспорт
	
	ХранениеДанных_ЗаписатьСтатусДляМассиваКонтрагентов(МассивКонтрагентов, Организация, Статус);
	
КонецПроцедуры	

Функция Контрагенты_Комментарий(ПараметрыСервиса, myOrgId, counteragentOrgId)
	
	Counteragent = АПИ_GetCounteragent(ПараметрыСервиса, myOrgId, counteragentOrgId);
	СтатусКонтрагента = СвойствоСтруктуры(Counteragent, "CurrentStatus", "");
	
	Если СтатусКонтрагента = Перечисление_СтатусыКонтрагентов().ПриглашаютВас Тогда
		ПолеКомментария = "MessageFromCounteragent";
	Иначе
		ПолеКомментария = "MessageToCounteragent";
	КонецЕсли;
	
	Результат = СвойствоСтруктуры(Counteragent, ПолеКомментария, "");
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ДокументПриглашения(ПараметрыСервиса, BoxId, OrgId, counteragentOrgId)
	
	Результат = Новый Структура;
	
	Counteragent = АПИ_GetCounteragent(ПараметрыСервиса, OrgId, counteragentOrgId);
	
	ИмяФайла		 = "";
	Данные			 = "";
	MessageId		 = "";
	EntityId		 = "";
	ТребуетсяПодпись = Ложь;
	
	Если СвойствоСтруктуры(Counteragent, "InvitationDocumentId") <> Неопределено Тогда
		
		MessageId	 = Counteragent.InvitationDocumentId.MessageId;
		EntityId	 = Counteragent.InvitationDocumentId.EntityId;
		
		//получаем данные файла приглашения
		Данные = АПИ_GetEntityContent(ПараметрыСервиса, BoxId, MessageId, EntityId);
		
		Message	 = АПИ_GetMessage(ПараметрыСервиса, BoxId, MessageId, EntityId);
		Entity	 = МассивСтруктур_Найти(Message.Entities, EntityId, "EntityId");
		
		ИмяФайла		 = Entity.FileName;
		ТребуетсяПодпись = СвойствоСтруктуры(Entity, "NeedRecipientSignature", Ложь);
		
	КонецЕсли;
	
	Результат.Вставить("ИмяФайла",			 ИмяФайла);
	Результат.Вставить("Данные",			 Данные);
	Результат.Вставить("ДанныеПодписи",		 Неопределено);
	Результат.Вставить("MessageId",			 MessageId);
	Результат.Вставить("EntityId",			 EntityId);
	Результат.Вставить("ТребуетсяПодпись",	 ТребуетсяПодпись);
	
	Возврат Результат;
	
КонецФункции

