//
Функция Макеты_ДанныеМакета(ИмяМакета)
	
	Результат = Неопределено;
	
	КоллекцияМакетов = Кэш_Прочитать("МакетыОбработки");
	
	Если ЗначениеЗаполнено(КоллекцияМакетов) Тогда
		Результат = СвойствоСтруктуры(КоллекцияМакетов, ИмяМакета);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает двоичные данные обработки по данным из макета
//
// Параметры:
//  ДанныеМакета - ДвоичныеДанные, Строка - см.функцию МакетыОбработки_ДанныеМакета()
// 
// Возвращаемое значение:
//  ДвоичныеДанные
//
Функция Макеты_ДвоичныеДанныеОбработки(ДанныеМакета)
	
	ТипПараметра		 = ТипЗнч(ДанныеМакета);
	ЭтоИмяФайла			 = (ТипПараметра = Тип("Строка"));
	ЭтоДвоичныеДанные	 = (ТипПараметра = Тип("ДвоичныеДанные"));
	
	Если ЭтоИмяФайла Тогда
		
		Результат = Новый ДвоичныеДанные(ДанныеМакета);
		
	ИначеЕсли ЭтоДвоичныеДанные Тогда
		
		Результат = ДанныеМакета;
		
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
		"ru = 'Недопустимый параметр для получения файла обработки
		|Тип параметра: %1
		|Значение параметра: %2'"), ТипПараметра, ДанныеМакета);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

