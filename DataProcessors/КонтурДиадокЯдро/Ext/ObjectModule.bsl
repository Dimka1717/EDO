// Выполняет запись ошибки в журнал регистрации.
//
// Параметры:
//  ТекстОшибки - Строка - подробное описание ошибки, с номером строки кода и т.д.
//
Процедура Ошибка_ДобавитьВЖурналРегистрации(ТекстОшибки)
	
	ЗаписьЖурналаРегистрации("Диадок", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	
КонецПроцедуры

Процедура Ошибка_ДобавитьВФайл(ТекстОшибки) Экспорт
	
	ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
	
	Каталог = ОбщиеНастройки_Прочитать("КаталогЛогирования");
	Если Не ФайлСуществует(Каталог) Тогда
		
		Попытка
			СоздатьКаталог(Каталог);
		Исключение
			ТекстСообщения = Общее_ПодставитьПараметрыВСтроку("Не удалось записать лог: Каталог не существует %1", Каталог);
			Ошибка_СообщитьПользователю(ТекстСообщения, ИдентификаторФормы);
			Возврат;
		КонецПопытки;
		
	КонецЕсли;
	
	ДатаЛога = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd");
	НомерСеанса = НомерСеансаИнформационнойБазы();
	Пользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
	ИмяФайла = Общее_ПодставитьПараметрыВСтроку("pro_service_log_%1_%2_%3.txt", ДатаЛога, НомерСеанса, Пользователь.Имя);
	ПолноеИмяФайла = ОбъединитьПути(Каталог, ИмяФайла);
	
	ШаблонЗаписи = "[%1] %2 %3";
	ДатаЗаписи = Формат(ТекущаяДатаСеанса(), "ДФ='yyyy-MM-dd HH:mm:ss'");
	ТекстЗаписи = Общее_ПодставитьПараметрыВСтроку(ШаблонЗаписи, ДатаЗаписи, ТекстОшибки, Символы.ПС);
	
	Попытка
		Запись = Новый ЗаписьТекста(ПолноеИмяФайла, КодировкаТекста.UTF8, , Истина);
		Запись.ЗаписатьСтроку(ТекстЗаписи);
		Запись.Закрыть();
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		КраткоеПредставление = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Ошибка_СообщитьПользователю(Общее_ПодставитьПараметрыВСтроку("Не удалось записать лог: %1", КраткоеПредставление),
									ИдентификаторФормы);
		
	КонецПопытки;
	
КонецПроцедуры

// Вызывает регистрацию ошибки в журнал регистрации и списке ошибок, а также сообщение пользователю.
//
// Параметры:
//  ВидОперации			 - Строка - вид операции при которой возникла ошибка.
//  Ошибка - Строка, ИнформацияОбОшибке - подробное описание ошибки, с номером строки кода и т.д
//							или объект ИнформацияОбОшибке.
//  ДопИнформация		 - Строка - дополнительная информация об ошибке.
//  ТекстСообщения		 - Строка - текст сообщения пользователю.
//  ИдентификаторФормы	 - УникальныйИдентификатор - см. процедуру Ошибка_СообщитьПользователю
//  ПолеФормы			 - Строка                  - см. процедуру Ошибка_СообщитьПользователю
//  РасшифровкаОшибок	 - Произвольный            - см. процедуру Ошибка_СообщитьПользователю
//
// BSLLS:NumberOfOptionalParams-off
Процедура Ошибка_Обработать(
		Знач ВидОперации,
		Ошибка,
		ДопИнформация = Неопределено,
		ТекстСообщения = Неопределено,
		ИдентификаторФормы = Неопределено,
		ПолеФормы = Неопределено,
		РасшифровкаОшибок = Неопределено) Экспорт
	
	// BSLLS:NumberOfOptionalParams-on
	
	Если ТипЗнч(Ошибка) = Тип("ИнформацияОбОшибке") Тогда
		ПодробныйТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
	Иначе
		ПодробныйТекстОшибки = СокрЛП(Ошибка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		
		Если ЗначениеЗаполнено(ПодробныйТекстОшибки) Тогда
			ТекстСообщенияПользователю = ТекстСообщения + Символы.ПС + НСтр("ru ='Подробности см. в журнале регистрации.'");
		Иначе
			ТекстСообщенияПользователю = ТекстСообщения;
		КонецЕсли;
		
		Ошибка_СообщитьПользователю(ТекстСообщенияПользователю, ИдентификаторФормы, ПолеФормы);
		
	КонецЕсли;
	
	Если Прав(ВидОперации, 1) <> "." Тогда
		ВидОперации = ВидОперации + ".";
	КонецЕсли;
	
	ПредставлениеОперации = Общее_ПодставитьПараметрыВСтроку(НСтр("ru = 'Выполнение операции: %1'"), ВидОперации);
	ПредставлениеДопИнформации = СоединитьСтроку(ЗначениеВМассив(ДопИнформация), Символы.ПС);
	
	Если ЗначениеЗаполнено(ПодробныйТекстОшибки) Тогда
		ТекстОшибкиДляЖурналаРегистрации = ПодробныйТекстОшибки;
	Иначе
		ТекстОшибкиДляЖурналаРегистрации = ТекстСообщения;
	КонецЕсли;
	
	СтрокиОшибки = ПараметрыВМассив(ТекстОшибкиДляЖурналаРегистрации, ПредставлениеДопИнформации);
	ТекстОшибки = СоединитьСтроку(СтрокиОшибки, Символы.ПС);
	
	СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстОшибки, РасшифровкаОшибок);
	
	ТекстОшибки = ПредставлениеОперации + Символы.ПС + ТекстОшибки;
	
	Ошибка_ДобавитьВЛог(ТекстОшибки);
	
КонецПроцедуры

Процедура Ошибка_Добавить(Знач ВидОперации, Ошибка, Контекст)
	
	КраткаяОшибка = Общее_ПодставитьПараметрыВСтроку(
		"%1
		|
		|Ошибка: %2
		|
		|Подробности см. в журнале регистрации.",
		Контекст,
		КраткоеПредставлениеОшибки(Ошибка)
	);
	
	СписокОшибок_ДобавитьОшибку(
		ВидОперации,
		КраткаяОшибка
	);
	
	ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
		"Выполнение операции: %1.
		|Контекст:
		|%2
		|
		|Ошибка:
		|%3",
		ВидОперации,
		Контекст,
		ПодробноеПредставлениеОшибки(Ошибка)
	);
	
	Ошибка_ДобавитьВЛог(ПодробнаяОшибка);
	
КонецПроцедуры

Процедура Ошибка_ДобавитьВЛог(ТекстОшибки) Экспорт
	
	Ошибка_ДобавитьВЖурналРегистрации(ТекстОшибки);
	
	Если РежимЛогированияВключен() И Не ЭтоФоновоеЗадание() Тогда
		Ошибка_ДобавитьВФайл(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

// Формирует и выводит сообщение, которое может быть "привязано" к форме.
//
// Параметры:
//  ТекстСообщения     - Строка                  - текст выводимого сообщения.
//  ИдентификаторФормы - УникальныйИдентификатор - идентификатор формы, к которой должно быть "привязано" сообщение.
//                                                 Если не указан, сообщение привязывается к активному окну.
//  ПолеФормы          - Строка                  - путь к реквизиту формы, для которого нужно вывести сообщение.
//
// Варианты вызова:
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'")) - Сообщение будет "привязано" к активной форме.
//
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'"),
//   ОбщийКонтекстКлиентСервер.ИдентификаторФормы)       - Сообщение будет "привязано" к основной форме.
//
//   СообщитьПользователю(НСтр("ru = 'Сообщение об ошибке.'"),
//   ОбщийКонтекстКлиентСервер.ИдентификаторФормы,
//   "Объект.СписокДокументов[2]")                             - Сообщение выводится в списке документов основной формы
//                                                               рядом со строкой с индексом 2.
//
Процедура Ошибка_СообщитьПользователю(ТекстСообщения, ИдентификаторФормы = Неопределено, ПолеФормы = Неопределено) Экспорт
	
	Сообщение = Новый СообщениеПользователю;
	
	Сообщение.Текст = ТекстСообщения;
	
	Если ЗначениеЗаполнено(ИдентификаторФормы) Тогда
		Сообщение.ИдентификаторНазначения = ИдентификаторФормы;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолеФормы) Тогда
		Сообщение.Поле = ПолеФормы;
	КонецЕсли;
	
	Сообщение.Сообщить();
	
КонецПроцедуры

// Возвращает список накопленных ошибок.
//
// Возвращаемое значение:
//   Массив - содержит структуры, см. функцию СписокОшибок_НоваяСтрока().
//
Функция СписокОшибок() Экспорт
	
	АдресСпискаОшибок = ОбщийКонтекст_Прочитать("АдресСпискаОшибок");
	
	Результат = ВременноеХранилище_Прочитать(АдресСпискаОшибок);
	
	Если Результат = Неопределено Тогда
		
		Результат = Новый Массив;
		
		ВременноеХранилище_Поместить(Результат, АдресСпискаОшибок);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Очищает список накопленных ошибок.
// 
Процедура СписокОшибок_Очистить() Экспорт
	
	АдресСпискаОшибок = ОбщийКонтекст_Прочитать("АдресСпискаОшибок");
	
	ВременноеХранилище_Поместить(Неопределено, АдресСпискаОшибок);
	
КонецПроцедуры

// Добавляет сообщение в список ошибок с видом "Ошибка".
//
// Параметры:
//  ВидОперации        - Строка    - вид операции, при которой возникла ошибка.
//  ТекстСообщения     - Строка    - подробное описание ошибки, с номером строки кода и т.д.
//  Расшифровка        - Массив    - (необязательный) содержит структуры, см. функцию СписокОшибок_НоваяРасшифровка.
//                                   Может использоваться для интеративной навигации по связанным с ошибкой данным.
//                                   Например, структура для отображения карточки пакета.
//  РодительскаяСтрока - Структура - (необязательный) строка раздела, в которую будет добавлена ошибка, см. фукнцию СписокОшибок_НоваяСтрока().
// 
// Возвращаемое значение:
//   Структура - описание добавленного сообщения, см. функцию СписокОшибок_НоваяСтрока().
//
Функция СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстСообщения, Расшифровка = Неопределено, РодительскаяСтрока = Неопределено) Экспорт
	
	ВидыСообщений = СписокОшибок_Перечисление_ВидыСообщенийСпискаОшибок();
	
	Результат = СписокОшибок_ДобавитьСообщение(ВидОперации, ТекстСообщения, ВидыСообщений.Ошибка, Расшифровка, РодительскаяСтрока);
	
	Возврат Результат;

КонецФункции

// Добавляет сообщение в список ошибок с видом "Информация".
//
// Параметры:
//  ВидОперации        - Строка    - вид операции, к которой относится информация.
//  ТекстСообщения     - Строка    - описание информации.
//  Расшифровка        - Массив    - (необязательный) содержит структуры, см. функцию СписокОшибок_НоваяРасшифровка.
//                                   Может использоваться для интеративной навигации по связанным с информацией данным.
//                                   Например, ссылка на контрагента.
//  РодительскаяСтрока - Структура - (необязательный) строка, в которую будет добавлена ошибка, см. фукнцию СписокОшибок_НоваяСтрока.
// 
// Возвращаемое значение:
//   Структура - описание добавленного сообщения, см. функцию СписокОшибок_НоваяСтрока().
//
Функция СписокОшибок_ДобавитьИнформацию(ВидОперации, ТекстСообщения, Расшифровка = Неопределено, РодительскаяСтрока = Неопределено) Экспорт
	
	ВидыСообщений = СписокОшибок_Перечисление_ВидыСообщенийСпискаОшибок();
	
	Результат = СписокОшибок_ДобавитьСообщение(ВидОперации, ТекстСообщения, ВидыСообщений.Информация, Расшифровка, РодительскаяСтрока);
	
	Возврат Результат;

КонецФункции

// Добавляет сообщение в список ошибок с видом "ВажнаяИнформация".
//
// Параметры:
//  ВидОперации        - Строка    - вид операции, к которой относится информация.
//  ТекстСообщения     - Строка    - описание информации.
//  Расшифровка        - Массив    - (необязательный) содержит структуры, см. функцию СписокОшибок_НоваяРасшифровка.
//                                   Может использоваться для интеративной навигации по связанным с информацией данным.
//                                   Например, ссылка на контрагента.
//  РодительскаяСтрока - Структура - (необязательный) строка, в которую будет добавлена ошибка, см. фукнцию СписокОшибок_НоваяСтрока.
// 
// Возвращаемое значение:
//   Структура - описание добавленного сообщения, см. функцию СписокОшибок_НоваяСтрока.
//
Функция СписокОшибок_ДобавитьВажнуюИнформацию(ВидОперации, ТекстСообщения, Расшифровка = Неопределено, РодительскаяСтрока = Неопределено) Экспорт
	
	ВидыСообщений = СписокОшибок_Перечисление_ВидыСообщенийСпискаОшибок();
	
	Результат = СписокОшибок_ДобавитьСообщение(ВидОперации, ТекстСообщения, ВидыСообщений.ВажнаяИнформация, Расшифровка, РодительскаяСтрока);
	
	Возврат Результат;

КонецФункции

// Добавляет сообщение в список ошибок.
//
// Параметры:
//  Раздел             - Строка    - раздел, в который нужно добавить сообщение.
//  ТекстСообщения     - Строка    - описание информации.
//  Расшифровка        - Массив    - содержит структуры, см. функцию СписокОшибок_НоваяРасшифровка.
//                                   Может использоваться для интеративной навигации по связанным с информацией данным.
//                                   Например, ссылка на контрагента.
//  РодительскаяСтрока - Структура - строка раздела, в которую будет добавлена ошибка, см. фукнцию СписокОшибок_НоваяСтрока.
//                                   Если указана то параметр Раздел игнорируется.
// 
// Возвращаемое значение:
//   Структура - описание добавленного сообщения, см. функцию СписокОшибок_НоваяСтрока.
//
Функция СписокОшибок_ДобавитьСообщение(Раздел, ТекстСообщения, ВидСообщения, Расшифровка = Неопределено, РодительскаяСтрока = Неопределено)
	
	Результат		 = СписокОшибок_НоваяСтрока();
	ВидыСообщений	 = СписокОшибок_Перечисление_ВидыСообщенийСпискаОшибок();
	
	Если РодительскаяСтрока = Неопределено Тогда
		
		СписокОшибок	 = СписокОшибок();
		СтрокаРаздела	 = МассивСтруктур_Найти(СписокОшибок, Раздел, "ТекстСообщения");
		
		Если СтрокаРаздела = Неопределено Тогда
			
			СтрокаРаздела = СписокОшибок_НоваяСтрока();
			СтрокаРаздела.ТекстСообщения = Раздел;
			СтрокаРаздела.ВидСообщения	 = ВидыСообщений.Раздел;
			
			СписокОшибок.Добавить(СтрокаРаздела);
			
		КонецЕсли;
		
		СтрокаСообщения = МассивСтруктур_Найти(СтрокаРаздела.Строки, ТекстСообщения, "ТекстСообщения");
		
		Если СтрокаСообщения = Неопределено Тогда
			СтрокаРаздела.Строки.Добавить(Результат);
		Иначе
			СтрокаСообщения.Количество = СтрокаСообщения.Количество + 1;	
		КонецЕсли;
		
	Иначе
		
		РодительскаяСтрока.Строки.Добавить(Результат);
		
	КонецЕсли;
	
	Результат.ТекстСообщения = ТекстСообщения;
	Результат.ВидСообщения	 = ВидСообщения;
	Результат.Расшифровка	 = Расшифровка;
	
	Возврат Результат;
	
КонецФункции

Функция СписокОшибок_НоваяСтрока()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Расшифровка");
	Результат.Вставить("ВидСообщения");
	Результат.Вставить("ТекстСообщения");
	Результат.Вставить("Количество", 1);
	Результат.Вставить("Строки", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

Функция СписокОшибок_НоваяРасшифровка()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Действие");
	Результат.Вставить("Параметры");
	Результат.Вставить("Представление");
	
	Возврат Результат;
	
КонецФункции

Функция СписокОшибок_НовыеПараметрыРасшифровки(Действие)
	
	Результат = Новый Структура;
	
	Результат.Вставить("Действие");
	Результат.Вставить("Параметры");
	Результат.Вставить("Представление");
	
	Возврат Результат;
	
КонецФункции

Функция СписокОшибок_Перечисление_ВидыСообщенийСпискаОшибок() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("Раздел"				, "Раздел");
	Результат.Вставить("Ошибка"				, "Ошибка");
	Результат.Вставить("Информация"			, "Информация");
	Результат.Вставить("ВажнаяИнформация"	, "ВажнаяИнформация");
	
	Возврат Результат;
	
КонецФункции

Функция СписокОшибок_Перечисление_ВидыДействийСпискаОшибок() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("ОткрытьФорму"			, "ОткрытьФорму");
	Результат.Вставить("ПоказатьЗначение"		, "ПоказатьЗначение");
	Результат.Вставить("ВыполнитьОповещение"	, "ВыполнитьОповещение");
	Результат.Вставить("ОткрытьФормуОбработки"	, "ОткрытьФормуОбработки");
	
	Возврат Результат;
	
КонецФункции

// Добавляет расшифровку в массив.
//
// Параметры:
//  МассивРасшифровки    - Массив    - массив, в который нужно добавить расшифровку.
//  ПараметрыРасшифровки - Структура - см. функцию СписокОшибок_НовыеПараметрыРасшифровки.
//  Представление        - Строка    - (необязательный) представление расшифровки в интерактивном списке ошибок.
//                                     Значение по умолчанию "открыть".
//  Действие             - Строка    - (необязательный) действие, которое нужно выполнить для расшифровки,
//                                     см. функцию СписокОшибок_Перечисление_ВидыДействийСпискаОшибок.
//                                     Значение по умолчанию "ПоказатьЗначение".
// 
Процедура СписокОшибок_ДобавитьРасшифровкуВМассив(МассивРасшифровки, ПараметрыРасшифровки
	, Представление	 = Неопределено
	, Действие		 = Неопределено)
	
	ВидыДействий = СписокОшибок_Перечисление_ВидыДействийСпискаОшибок();
	
	Если ЗначениеЗаполнено(Действие) Тогда
		
		Если НЕ ВидыДействий.Свойство(Действие) Тогда
			
			ТекстОшибки = НСтр("ru = 'Неизвестный вид действия в расшифровке списка ошибок ""%1""'");
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Действие);
			
			ВызватьИсключение ТекстОшибки;
			
		КонецЕсли;
		
	Иначе
		Действие = ВидыДействий.ПоказатьЗначение;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Представление = НСтр("ru = 'открыть'");
	КонецЕсли;
	
	НоваяРасшифровка = СписокОшибок_НоваяРасшифровка();
	НоваяРасшифровка.Действие		 = Действие;
	НоваяРасшифровка.Параметры		 = ПараметрыРасшифровки;
	НоваяРасшифровка.Представление	 = Представление;
	
	МассивРасшифровки.Добавить(НоваяРасшифровка);
	
КонецПроцедуры

Функция РежимЛогированияВключен() Экспорт
	
	Результат = ОбщиеНастройки_Прочитать("РежимЛогирования") = Истина;
	Возврат Результат;
	
КонецФункции

