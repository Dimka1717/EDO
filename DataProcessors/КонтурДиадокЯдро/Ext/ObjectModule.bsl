КонецПроцедуры

Функция ДатаПоследнегоПрочитанногоСобытияКонтрагентов(ИдентификаторЯщика)
	
	КлючНастройки = "Диадок_ДатаСобытийКонтрагентов" + ИдентификаторЯщика;
	
	КоличествоСекундДень = 86400;
	
	ДатаПоУмолчанию = ТекущаяДатаСеанса() - КоличествоСекундДень;
	
	Результат = ХранилищеОбщихНастроек_Прочитать(КлючНастройки, ДатаПоУмолчанию);
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаписатьДатуПоследнегоПрочитанногоСобытияКонтрагентов(ИдентификаторЯщика, Дата)
	
	КлючНастройки = "Диадок_ДатаСобытийКонтрагентов" + ИдентификаторЯщика;
	
	ХранилищеОбщихНастроек_Поместить(КлючНастройки, Дата);
	
КонецПроцедуры 

Процедура Контрагенты_ЗаполнениеОсновныхСтатусов(Организация)
	
	МассивCounteragents = Контрагенты_МассивCounteragents(Организация);
	ТаблицаКонтрактов = Контрагенты_ТаблицаКонтрактовПоCounteragents(МассивCounteragents);
	
	Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов);
	Контрагенты_ОбновлениеСтатусов(ТаблицаКонтрактов, Организация);
	Контрагенты_ОбновлениеДатыИзменения(ТаблицаКонтрактов, Организация);
	Контрагенты_ОбновлениеПодразделений(Организация, ТаблицаКонтрактов);
	
КонецПроцедуры
                                                         
Функция Контрагенты_МассивCounteragents(Организация, CounteragentStatus = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	BoxId	= Организация.ID;
	MyOrgId	= Организация.OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	AfterIndexKey		= Неопределено;
	ЕстьЕщеКонтрагенты	= Истина;
	
	Пока ЕстьЕщеКонтрагенты Цикл
		
		CounteragentList	= АПИ_GetCounteragents(ПараметрыСервиса, MyOrgId, CounteragentStatus, AfterIndexKey);
		
		Counteragents = CounteragentList.Counteragents;
		Результат.Добавить(Counteragents);
		
		TotalCount			= CounteragentList.TotalCount;
				
		РазмерCounteragents = Counteragents.Количество();	// Возможна ситуация когда TotalCount = 1, а Counteragents.Количество() = 0, 
		Если РазмерCounteragents = 0 Тогда					// поэтому ориентируемся на размер массива Counteragents
			AfterIndexKey = "";	
		Иначе
			Counteragent	= Counteragents[РазмерCounteragents - 1];
			AfterIndexKey	= Counteragent.IndexKey;
		КонецЕсли;
		
		ЕстьЕщеКонтрагенты	= (TotalCount > 100);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции	

Функция Контрагенты_ТаблицаКонтрактовПоCounteragents(МассивCounteragents) Экспорт
	
	Результат = Контрагенты_НоваяТаблицаКонтрактов();
	
	Для Каждого Counteragents Из МассивCounteragents Цикл
		Для Каждого Counteragent Из Counteragents Цикл
			
			Контрагент = Контрагенты_НовыйКонтрагентИзСтруктуры(Counteragent);
			
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Контрагент);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ПоискИПриглашениеДляОрганизации(Организация) Экспорт
	
	МассивИННДляПриглашения 	= ХранениеДанных_МассивИННДляПриглашения(Организация);
	МассивПроверенныхИНН		= Контрагенты_МассивПроверенныхИНН(МассивИННДляПриглашения);
	МассивOrganizationsResponse	= Контрагенты_МассивOrganizationsByInn(МассивПроверенныхИНН, Организация);
	
	ТаблицаКонтрактов = Контрагенты_ТаблицаКонтрактовПоOrganizationsResponse(МассивOrganizationsResponse);
	
	Отбор = Новый Структура;
	Отбор.Вставить("Статус", Перечисление_СтатусыКонтрагентов().РаботаетВДиадок);
	
	Результат = ТаблицаКонтрактов.Скопировать(Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_МассивПроверенныхИНН(МассивИНН) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого ИНН Из МассивИНН Цикл
		
		ИНН_БезНулей		= Контрагенты_ИННБезЛидирующихНулей(ИНН);
		ИНН_ПрошелПроверку	= Контрагенты_ИННСоответствуетТребованиямФНС(ИНН_БезНулей);
		
		Если ИНН_ПрошелПроверку Тогда
			Результат.Добавить(ИНН_БезНулей);
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ИННБезЛидирующихНулей(ИНН)
	
	Результат = СокрЛП(ИНН);
	
	Если Лев(Результат, 2) = "00" Тогда
		Результат = Сред(Результат, 3);
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции	
	
Функция Контрагенты_ИННСоответствуетТребованиямФНС(ИНН)
	
	Результат	= Ложь;
	
	ИННСтр	 	= СокрЛП(ИНН);
	ДлинаИНН	= СтрДлина(ИННСтр);
	ТолькоЦифры	= СодержитТолькоЦифрыВСтроке(ИННСтр);
	
	НеверныеИНН = 	ИННСтр = "0000000000"
				ИЛИ ИННСтр = "000000000000"
				ИЛИ Лев(ИННСтр, 2) = "00"
				ИЛИ НЕ ТолькоЦифры;
	
	Если НЕ НеверныеИНН Тогда
		
		Если ДлинаИНН = 10 Тогда
			
			КонтрольнаяСумма = 0;
			
			Для Н = 1 По 9 Цикл
				
				Если 	  Н = 1 Тогда
					Множитель = 2;
				ИначеЕсли Н = 2 Тогда
					Множитель = 4;
				ИначеЕсли Н = 3 Тогда
					Множитель = 10;
				ИначеЕсли Н = 4 Тогда
					Множитель = 3;
				ИначеЕсли Н = 5 Тогда
					Множитель = 5;
				ИначеЕсли Н = 6 Тогда
					Множитель = 9;
				ИначеЕсли Н = 7 Тогда
					Множитель = 4;
				ИначеЕсли Н = 8 Тогда
					Множитель = 6;
				ИначеЕсли Н = 9 Тогда
					Множитель = 8;
				КонецЕсли; 
				
				Цифра = Число(Сред(ИННСтр, Н, 1));
				КонтрольнаяСумма = КонтрольнаяСумма + Цифра * Множитель;
				
			КонецЦикла; 
			
			КонтрольныйРазряд = (КонтрольнаяСумма %11) %10;
			
			Если КонтрольныйРазряд = Число(Сред(ИННСтр, 10, 1)) Тогда
				Результат = Истина;
			КонецЕсли; 
			
		ИначеЕсли ДлинаИНН = 12 Тогда
			
			КонтрольнаяСумма11 = 0;
			КонтрольнаяСумма12 = 0;
			
			Для Н = 1 По 11 Цикл
				
				Если Н = 1 Тогда
					Множитель11 = 7;
					Множитель12 = 3;
				ИначеЕсли Н = 2 Тогда
					Множитель11 = 2;
					Множитель12 = 7;
				ИначеЕсли Н = 3 Тогда
					Множитель11 = 4;
					Множитель12 = 2;
				ИначеЕсли Н = 4 Тогда
					Множитель11 = 10;
					Множитель12 = 4;
				ИначеЕсли Н = 5 Тогда
					Множитель11 = 3;
					Множитель12 = 10;
				ИначеЕсли Н = 6 Тогда
					Множитель11 = 5;
					Множитель12 = 3;
				ИначеЕсли Н = 7 Тогда
					Множитель11 = 9;
					Множитель12 = 5;
				ИначеЕсли Н = 8 Тогда
					Множитель11 = 4;
					Множитель12 = 9;
				ИначеЕсли Н = 9 Тогда
					Множитель11 = 6;
					Множитель12 = 4;
				ИначеЕсли Н = 10 Тогда
					Множитель11 = 8;
					Множитель12 = 6;
				ИначеЕсли Н = 11 Тогда
					Множитель11 = 0;
					Множитель12 = 8;
				КонецЕсли; 
				
				Цифра = Число(Сред(ИННСтр, Н, 1));
				КонтрольнаяСумма11 = КонтрольнаяСумма11 + Цифра * Множитель11;
				КонтрольнаяСумма12 = КонтрольнаяСумма12 + Цифра * Множитель12;
				
			КонецЦикла; 
			
			КонтрольныйРазряд11 = (КонтрольнаяСумма11 %11) %10;
			КонтрольныйРазряд12 = (КонтрольнаяСумма12 %11) %10;
			
			Если  КонтрольныйРазряд11 = Число(Сред(ИННСтр, 11, 1))
				И КонтрольныйРазряд12 = Число(Сред(ИННСтр, 12, 1)) Тогда
				Результат = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция Контрагенты_МассивOrganizationsByInn(МассивИНН, Организация)
	
	Результат = Новый Массив;
	
	BoxId	= Организация.ID;
	OrgId	= Организация.OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Счетчик			= 0;
	МассивИНН_Доп	= Новый Массив;
	КоличествоИНН	= МассивИНН.Количество();
	
	Для Каждого ИНН Из МассивИНН Цикл
		
		Счетчик = Счетчик + 1;
		МассивИНН_Доп.Добавить(ИНН);
		
		Если МассивИНН_Доп.Количество() = 100 ИЛИ Счетчик = КоличествоИНН Тогда
			
			GetOrganizationsByInnListResponse = АПИ_GetOrganizationsByInnList(ПараметрыСервиса, МассивИНН_Доп, OrgId);
			
			Результат.Добавить(GetOrganizationsByInnListResponse);
		    МассивИНН_Доп.Очистить();
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТаблицаКонтрактовПоOrganizationsResponse(МассивOrganizationsResponse)
	
	Результат = Контрагенты_НоваяТаблицаКонтрактов();
	
	Для Каждого СтруктураOrganizations Из МассивOrganizationsResponse Цикл
		
		МассивOrganizations = ЗначениеСоответствия(СтруктураOrganizations, "Organizations");
		Если НЕ ЗначениеЗаполнено(МассивOrganizations) Тогда
			Продолжить; 	
		КонецЕсли;
		
		Для Каждого Counteragent Из МассивOrganizations Цикл
		
			Контрагент = Контрагенты_НовыйКонтрагентИзСоответствия(Counteragent);
			
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Контрагент);
		
		КонецЦикла;
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов)
	
	Если Не ЗначениеЗаполнено(ТаблицаКонтрактов) Тогда
		Возврат;
	КонецЕсли;
	
	МассивДляЗаписиОбъектов = ХранениеДанных_МассивКонтрагентовДляОбновленияРеквизитов(ТаблицаКонтрактов);
	
	Для Каждого Контрагент Из МассивДляЗаписиОбъектов Цикл
		ХранениеДанных_ЗаписатьКонтрагента(Контрагент);
	КонецЦикла;
	
КонецПроцедуры

