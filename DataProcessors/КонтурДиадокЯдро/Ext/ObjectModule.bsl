// Возвращает список организаций, в которые пользователь имеет доступ.
// "Имеет доступ" означает, что он зарегистрирован там как сотрудник.
//
// Параметры:
//  Сессия - Структура, ФиксированнаяСтруктура - см. МодельСессияПользователя
// 
// Возвращаемое значение:
//  Массив из Контракт_Организация - список организаций
//
Функция Организации_ДоступныеОрганизации(Сессия) Экспорт
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	ПараметрыСервиса = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	OrganizationList = АПИ_GetMyOrganizations(ПараметрыСервиса);
	
	Результат = Новый Массив;
	
	Для Каждого Organization Из OrganizationList.Organizations Цикл
		
		// Исключаем организации, в которых текущий
		// пользователь не зарегистрирован как сотрудник
		Если Не Organization.IsEmployee Тогда
			Продолжить;
		КонецЕсли;
		
		Организация = Организации_НоваяОрганизация(Organization);
		Результат.Добавить(Организация);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Получает информацию о сертификатах, привязанных к сотруднику в Диадоке.
// Если установлен сертификат по умолчанию, он будет первым в списке.
//
// Параметры:
//  BoxId - Строка - идентификатор ящика
//  Сессия - Структура, ФиксированнаяСтруктура - см. МодельСессияПользователя
// 
// Возвращаемое значение:
//  ФиксированныйМассив из Контракт_СертификатПользователя - коллекция сертификатов
//
Функция Пользователи_МоиСертификаты(Знач BoxId, Знач Сессия) Экспорт
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	ПараметрыКлиентаДД = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	
	BoxId = АдресЯщикаВИдентификатор(BoxId);
	
	Попытка
		Данные = АПИ_GetMyCertificates(ПараметрыКлиентаДД, BoxId);
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		ВидОперации = Общее_ПодставитьПараметрыВСтроку("GetMyCertificates (BoxId = %1)", BoxId);
		
		Ошибка_Обработать(ВидОперации, Ошибка);
		
		Возврат Новый ФиксированныйМассив(Новый Массив);
		
	КонецПопытки;
	
	Ответ = Новый Массив;
	
	Для Каждого Элемент Из Данные.Certificates Цикл
		
		Модель = Контракт_СертификатПользователя();
		Модель.Отпечаток = ВРег(Элемент.Thumbprint);
		Модель.Тип = НРег(Элемент.Type);
		Если Элемент.Свойство("IsDefault") Тогда
			Модель.ПоУмолчанию = Элемент.IsDefault;
		КонецЕсли;
		
		Если Модель.ПоУмолчанию Тогда
			Ответ.Вставить(0, Модель);
		Иначе
			Ответ.Добавить(Модель);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = ФиксированныеДанные(Ответ);
	
	Возврат Результат;
	
КонецФункции

// Модель данных сертификата сотрудника.
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//    * Отпечаток - Строка - Отпечаток сертификата
//    * ПоУмолчанию - Булево - Истина, если сертификат выбран для работы по умолчанию в организации сотрудника
//    * Тип - Строка - тип сертификата, принимает значения из перечисления CertificateType
//
Функция Контракт_СертификатПользователя()
	
	Результат = Новый Структура;
	Результат.Вставить("Отпечаток", "");
	Результат.Вставить("Тип", "");
	Результат.Вставить("ПоУмолчанию", Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_НоваяОрганизация(Organization)
	
	Результат = Контракт_Организация();
	
	Результат.BoxId				 = Organization.Boxes[0].BoxId;
	Результат.OrgId				 = Organization.OrgId;
	Результат.ИНН				 = Organization.Inn;
	Результат.КПП				 = СвойствоСтруктуры(Organization, "Kpp", "");
	Результат.Наименование		 = СвойствоСтруктуры(Organization, "ShortName", Organization.FullName);
	Результат.ОГРН				 = СвойствоСтруктуры(Organization, "Ogrn", "");
	Результат.FnsParticipantId	 = СвойствоСтруктуры(Organization, "FnsParticipantId", "");
	Результат.Пилотная			 = СвойствоСтруктуры(Organization, "IsPilot", Ложь);
	Результат.Активная			 = СвойствоСтруктуры(Organization, "IsActive", Ложь);
	Результат.Тестовая			 = СвойствоСтруктуры(Organization, "IsTest", Ложь);
	Результат.Филиал			 = СвойствоСтруктуры(Organization, "IsBranch", Ложь);
	Результат.Роуминг			 = СвойствоСтруктуры(Organization, "IsRoaming", Ложь);
	Результат.Sociability		 = Organization.Sociability;
	Результат.ДатаЛиквидации	 = ДатаXML_в_Дата1С(СвойствоСтруктуры(Organization, "LiquidationDate", Дата(1, 1, 1)));
	Результат.Иностранная		 = СвойствоСтруктуры(Organization, "IsForeign", Ложь);
	
	Для Каждого Department Из Organization.Departments Цикл
		Подразделение = Организации_НовоеПодразделение(Department);
		Результат.Подразделения.Добавить(Подразделение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

