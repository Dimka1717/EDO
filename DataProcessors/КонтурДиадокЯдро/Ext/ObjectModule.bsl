Процедура СписокДокументов_ДополнитьДанныеСписка(СписокДокументов)
	
	ДокументыУчета = СписокДокументов.ВыгрузитьКолонку("Документ");
	
	ЗначенияРеквизитов = Неопределено;
	Если НЕ ИспользоватьПодсистемуДиадока() Тогда
		ЗначенияРеквизитов = МенеджерИнтеграции_ЗначенияРеквизитовДокументовУчета(ДокументыУчета);
	КонецЕсли;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		
		СтрокаСписка.ПредставлениеДокументаДиадок = СписокДокументов_ПредставлениеДокумента(СтрокаСписка);
		СтрокаСписка.ТребуемоеДействие = СписокДокументов_ТребуемоеДействие(СтрокаСписка);
		
		Если НЕ ЗначениеЗаполнено(ЗначенияРеквизитов) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументУчета = СтрокаСписка.Документ;
		Реквизиты = ЗначенияРеквизитов.Получить(ДокументУчета);
		Если НЕ ЗначениеЗаполнено(Реквизиты) Тогда
			Продолжить;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаСписка, Реквизиты);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СписокДокументов_ИдентификаторыДокументовАПИ(Параметры, Направление) Экспорт
	
	Результат = Новый Массив;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	Направления			= Перечисление_Направления();
	КлассыДокументов 	= Перечисление_КлассыДокументов();
	
	Если Направление = Направления.Исходящее Тогда
		DocumentClass = КлассыДокументов.Исходящие;
	ИначеЕсли Направление = Направления.Входящее Тогда
		DocumentClass = КлассыДокументов.Входящие;
	ИначеЕсли Направление = Направления.Внутреннее Тогда
		DocumentClass = КлассыДокументов.Внутренние;	
	КонецЕсли;
	
	НастройкаТребуетсяЗагружатьДокументыПоBoxIdКонтрагента = Новый Соответствие;
	
	Для Каждого ТекСтрока Из СтрокиКонтекста Цикл
		
		BoxId		= ТекСтрока.Ключ;
		BoxIdGUID	= ТекСтрока.Значение.Box.BoxIdGuid;
		
		ОрганизацияСоответствуетОтбору = СписокДокументов_ОрганизацияСоответствуетОтбору(Параметры, BoxId);
		
		Если НЕ ОрганизацияСоответствуетОтбору Тогда 
			Продолжить; 
		КонецЕсли;
		
		Идентификаторы	= Новый_ИдентификаторыСправочника(, BoxId);
		Организация		= Организации_ЗаполненныеРеквизиты(Идентификаторы);
		
		СчетчикЦиклов = СписокДокументов_СчетчикЦикловПолученияДокументов(Параметры, Направление);
		
		Для Сч = 1 По СчетчикЦиклов Цикл
			
			МассивDocuments = Новый Массив;

			ПропускатьПервыйПоиск = СчетчикЦиклов = 2
									И Параметры.ОтборПоСтатусу = Перечисление_СтатусыДокументов().ТребуетсяПодписатьИОтправить;
	
			Если Сч = 1 И НЕ ПропускатьПервыйПоиск Тогда
				МассивDocuments = СписокДокументов_МассивDocuments(Параметры, DocumentClass, BoxId);
				Если Направление = Направления.Входящее Тогда
					ТрехсторонниеДокументы = СписокДокументов_МассивDocuments(Параметры, КлассыДокументов.Трехсторонние, BoxId);
					ДополнитьМассив(МассивDocuments, ТрехсторонниеДокументы);
				КонецЕсли;
			ИначеЕсли Сч = 2 Тогда
				ПараметрыДляСогласования = СписокДокументов_ПараметрыДокументовНаСогласование(Параметры);
				МассивDocuments = СписокДокументов_МассивDocuments(ПараметрыДляСогласования, DocumentClass, BoxId);
			КонецЕсли;	
		
			Для Каждого ТекDocuments Из МассивDocuments Цикл
				Для Каждого ТекДокумент Из ТекDocuments Цикл
					
					Если Сч = 2 Тогда
						ДокументПодходитПоДате = СписокДокументов_ПодходитПоДатеОтправки(Параметры, ТекДокумент);
					Иначе
						ДокументПодходитПоДате = Истина;
					КонецЕсли; 
					
					Если ДокументПодходитПоДате Тогда
						
						ТребуетсяЗагружатьДокументы = Истина;
						
						Если НЕ ТекДокумент.DocumentDirection = КлассыДокументов.Внутренние Тогда 
							CounteragentBoxId = ТекДокумент.CounteragentBoxId;
							ТребуетсяЗагружатьДокументы = НастройкаТребуетсяЗагружатьДокументыПоBoxIdКонтрагента.Получить(CounteragentBoxId);
							Если ТребуетсяЗагружатьДокументы = Неопределено Тогда
								ТребуетсяЗагружатьДокументы	 = Контрагенты_ТребуетсяЗагружатьДокументы(Организация, CounteragentBoxId);
								НастройкаТребуетсяЗагружатьДокументыПоBoxIdКонтрагента.Вставить(CounteragentBoxId, ТребуетсяЗагружатьДокументы);
							КонецЕсли;
						КонецЕсли;
						
						Если ТребуетсяЗагружатьДокументы Тогда
						
							Идентификаторы = Новый Структура;
							Идентификаторы.Вставить("ДокументАПИ",	ТекДокумент);
							Идентификаторы.Вставить("BoxID",		BoxIdGUID);
							Идентификаторы.Вставить("LetterID",		ТекДокумент.MessageId);
							Идентификаторы.Вставить("DocumentID",	ТекДокумент.EntityId);
							
							Результат.Добавить(Идентификаторы);
						
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;	
			КонецЦикла;	
			
		КонецЦикла;
		
	КонецЦикла;	
	
	НастройкаТребуетсяЗагружатьДокументыПоBoxIdКонтрагента = Неопределено;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_СчетчикЦикловПолученияДокументов(Параметры, Направление)
	
	Результат = 1;
	
	РежимОтбораПоПериоду = СвойствоСтруктуры(Параметры, "РежимОтбораПоПериоду", "");
	
	Если Направление = Перечисление_Направления().Исходящее
		И РежимОтбораПоПериоду <> "ПоДатеДокумента" Тогда
		
		Результат = 2;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция СписокДокументов_ПараметрыДокументовНаСогласование(Параметры)
	
	Результат = Общее_СкопироватьСтруктуру(Параметры);
	
	Результат.РежимОтбораПоПериоду = "ПоДатеДокумента";
	
	Результат.НачалоПериода	= Дата(1, 1, 1);
	Результат.КонецПериода	= Дата(1, 1, 1);
	
	Результат.Вставить("СтатусДокумента", "WaitingForSenderSignature");
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ПодходитПоДатеОтправки(Параметры, ДокументАПИ)
	
	Результат = Ложь;
	
	ДатаНачала		= Параметры.НачалоПериода;
	ДатаОкончания	= Параметры.КонецПериода;
	
	ДатаСоздания = Ticks_2_Date(ДокументАПИ.CreationTimestampTicks);
	
	Если ДатаСоздания >= ДатаНачала
		И ДатаСоздания <= ДатаОкончания Тогда
	
		Результат = Истина;	
	
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции	

Функция СписокДокументов_ПредставлениеДокумента(СтрокаСписка)
	
	Результат = СтрокаСписка.ПредставлениеДокументаДиадок;
	
	Если СтрокаСписка.ТипДокумента <> "Nonformalized" Тогда
		
		НачалоПредставления = Лев(Результат, 3);
		
		Если НачалоПредставления = "ON_" ИЛИ НачалоПредставления = "DP_" Тогда
			
			Результат = Списки_НазваниеДокументаAPI(СтрокаСписка.ТипДокумента);
			Результат = Результат + Документы_ПредставлениеДокумента_НомерДата(СтрокаСписка.НомерДокумента, СтрокаСписка.ДатаДокумента);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ТребуемоеДействие(СтрокаСписка)
	
	Результат = "";
	
	Если СтрокаСписка.Направление = Перечисление_Направления().Входящее Тогда
		
		Если НЕ СтрокаСписка.АнализПроведен Тогда
			Результат = "Выполнить анализ";
		ИначеЕсли СтрокаСписка.ДействиеВ1С <> "" Тогда	
			Результат = СтрокаСписка.ДействиеВ1С;
		ИначеЕсли СтрокаСписка.ДействиеВДД <> "" Тогда
			Результат = СтрокаСписка.ДействиеВДД;
		КонецЕсли;
		
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ДанныеПакетаНаОтправкуПоСтрокеСписка(СтрокаСписка)
	
	Результат = Контракт_Документ();
	
	Направление = СвойствоСтруктуры(СтрокаСписка, "Направление", Перечисление_Направления().Исходящее);
	
	Результат.Направление				= Направление;
	Результат.ИдентификаторВидаПакета	= СтрокаСписка.ВидПакетаID;
	Результат.ДокументУчета				= СтрокаСписка.Документ;
	
	ВидПакета = Списки_ОписаниеВидаПакета(СтрокаСписка.ВидПакетаID);
	Если ЗначениеЗаполнено(ВидПакета) Тогда
		Результат.Шаблон = (ВидПакета.Шаблон = Истина);
	КонецЕсли;
	
	Результат.РезультатАнализа.ТребуемоеДействиеВДД	= "Отправить пакет";
	
	Реквизиты = Результат.Реквизиты;
	Реквизиты.Дата	= СтрокаСписка.ДатаДокумента;
	Реквизиты.Номер	= СтрокаСписка.НомерДокумента;
	Реквизиты.Сумма	= СтрокаСписка.СуммаДокумента;
	
	ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(СтрокаСписка.Организация);
	УчастникДО_Организации		= ХранениеДанных_УчастникДО_Организации(ИдентификаторыОрганизации);
	
	ЗаполнитьЗначенияСвойств(Результат.Отправитель, УчастникДО_Организации, , "Организация");
	Результат.Отправитель.Организация = СтрокаСписка.Организация;
	
	Если СтрокаСписка.Организация = СтрокаСписка.Контрагент Тогда
		
		ЗаполнитьЗначенияСвойств(Результат.Получатель, УчастникДО_Организации, , "Организация");
		Результат.Получатель.Организация = СтрокаСписка.Организация;
		
	Иначе
		
		ИдентификаторыКонтрагента	= Новый_ИдентификаторыСправочника(СтрокаСписка.Контрагент);
		ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(УчастникДО_Организации.ОрганизацияЭДО, УчастникДО_Организации.BoxId);
		УчастникДО_Контрагенты		= ХранениеДанных_УчастникДО_Контрагенты(ИдентификаторыКонтрагента, ИдентификаторыОрганизации);

		ЗаполнитьЗначенияСвойств(Результат.Получатель, УчастникДО_Контрагенты, , "Организация");
		Результат.Получатель.Организация = СтрокаСписка.Контрагент;
		
	КонецЕсли;
	
	Результат.Идентификаторы.BoxId = АдресЯщикаВИдентификатор(УчастникДО_Организации.BoxId);
	
	Для Счетчик = 1 По 5 Цикл
		
		ИмяДопРеквизита = "ДопРеквизит" + Строка(Счетчик);
		
		Если ЗначениеЗаполнено(СтрокаСписка[ИмяДопРеквизита]) Тогда
			Результат.ДопРеквизиты.Вставить(ИмяДопРеквизита, СтрокаСписка[ИмяДопРеквизита]);
		КонецЕсли; 
		
	КонецЦикла;
	
	СлужебнаяИнформацияСтроки = СвойствоСтруктуры(СтрокаСписка, "СлужебнаяИнформация", Новый Структура);
	ДополнитьСтруктуру(Результат.СлужебнаяИнформация, СлужебнаяИнформацияСтроки);
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ОрганизацияСоответствуетОтбору(Параметры, BoxId)
	
	Результат = Истина;
	
	Организация = СвойствоСтруктуры(Параметры, "ОтборПоОрганизации", Неопределено);
	
	Если ЗначениеЗаполнено(Организация) Тогда
		
		ИдентификаторыСправочника = Новый_ИдентификаторыСправочника(Организация);
		ИдентификаторОрганизации = ХранениеДанных_ИдентификаторОрганизации(ИдентификаторыСправочника);
		
		Если ЗначениеЗаполнено(ИдентификаторОрганизации)
			И ИдентификаторОрганизации <> BoxId Тогда
			Результат = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция СписокДокументов_МассивDocuments(Параметры, DocumentClass, BoxId)
	
	Результат = Новый Массив;

	FilterCategory 			= СписокДокументов_FilterCategory(Параметры, DocumentClass);
	CounteragentBoxId   	= СписокДокументов_CounteragentBoxId(Параметры);
	ToDepartmentId			= Неопределено;
	DepartmentId			= Неопределено;
	
	ФильтрыПоДатам			= СписокДокументов_СтруктураФильтровПоДатам(Параметры);
	
	TimestampFromTicks		= ФильтрыПоДатам.TimestampFromTicks;
	TimestampToTicks		= ФильтрыПоДатам.TimestampToTicks;
	FromDocumentDate		= ФильтрыПоДатам.FromDocumentDate;
	ToDocumentDate			= ФильтрыПоДатам.ToDocumentDate;
	
	ExcludeSubdepartments	= Неопределено;
	AfterIndexKey			= Неопределено;
	ЕстьЕщеДокументы		= Истина;
	
	ПараметрыСервиса		= ПараметрыСервиса_Диадок(BoxId);
	
	Пока ЕстьЕщеДокументы Цикл
		
		Попытка
			
			DocumentList = АПИ_GetDocuments(ПараметрыСервиса,
											BoxId,
											FilterCategory,
											CounteragentBoxId,
											ToDepartmentId,
											TimestampFromTicks,
											TimestampToTicks,
											FromDocumentDate,
											ToDocumentDate,
											DepartmentId,
											ExcludeSubdepartments,
											AfterIndexKey);
			
			ЧастьДокументов = DocumentList.Documents;
			Результат.Добавить(ЧастьДокументов);
			
			КоличествоЧастиДокументов	= ЧастьДокументов.Количество();
			TotalCount					= DocumentList.TotalCount;
			
			AfterIndexKey = ?(TotalCount = 0, "", ЧастьДокументов[КоличествоЧастиДокументов - 1].IndexKey);
			
			Если TotalCount > КоличествоЧастиДокументов Тогда
				ЕстьЕщеДокументы = Истина;
			Иначе	
				ЕстьЕщеДокументы = DocumentList.HasMoreResults;
			КонецЕсли;	
			
		Исключение
			ЕстьЕщеДокументы = Ложь;
		КонецПопытки;		 
		
	КонецЦикла;
											
	Возврат Результат;											
	
КонецФункции

Функция СписокДокументов_FilterCategory(Параметры, DocumentClass)
	
	Если Параметры.Свойство("СтатусДокумента") Тогда
		СтатусДокументовAPI = Параметры.СтатусДокумента;
	Иначе
		СтатусДокументовAPI = Перечисление_СтатусыДокументовАПИ().Получить(Параметры.ОтборПоСтатусу);
	КонецЕсли;
	
	DocumentType	= СвойствоСтруктуры(Параметры, "ТипДокумента", "Any");
	DocumentStatus	= СтатусДокументовAPI;
	
	Результат = DocumentType + "." + DocumentClass + DocumentStatus;
	
	Возврат Результат;
	
КонецФункции	

Функция СписокДокументов_CounteragentBoxId(Параметры)
	
	Результат = "";
	
	Контрагент = СвойствоСтруктуры(Параметры, "ОтборПоКонтрагенту", Неопределено);
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		Идентификаторы	= Новый_ИдентификаторыСправочника(Контрагент);
		Результат		= ХранениеДанных_ИдентификаторКонтрагента(Идентификаторы);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_СтруктураФильтровПоДатам(Параметры)
	
	Результат = Новый Структура;
	
	Результат.Вставить("TimestampFromTicks"	, Неопределено);
	Результат.Вставить("TimestampToTicks"	, Неопределено);
	Результат.Вставить("FromDocumentDate"	, Неопределено);
	Результат.Вставить("ToDocumentDate"		, Неопределено);
	
	РежимОтбораПоПериоду	= СвойствоСтруктуры(Параметры, "РежимОтбораПоПериоду"	, "");
	НачалоПериода			= СвойствоСтруктуры(Параметры, "НачалоПериода"			, '00010101');
	КонецПериода			= СвойствоСтруктуры(Параметры, "КонецПериода"			, ТекущаяДата());
	
	Если РежимОтбораПоПериоду = "ПоДатеДокумента" Тогда
		Результат.Вставить("FromDocumentDate"	, Формат(НачалоПериода	, "ДФ=dd.MM.yyyy"));
		Результат.Вставить("ToDocumentDate"		, Формат(КонецПериода	, "ДФ=dd.MM.yyyy"));
	Иначе
		Результат.Вставить("TimestampFromTicks"	, Date_2_Ticks(НачалоПериода));
		Результат.Вставить("TimestampToTicks"	, Date_2_Ticks(КонецПериода));
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ТаблицаКонтрагентовДляОтправки() Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Организация1С", Справочники_ОписаниеТипаПоля("Организации"));
	Результат.Колонки.Добавить("Контрагент1С",	Справочники_ОписаниеТипаПоля("Контрагенты"));
	
	КонтекстСеанса = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого ТекСтрока Из КонтекстСеанса Цикл
		
		Идентификаторы	= Новый_ИдентификаторыСправочника(, ТекСтрока.Ключ);
		Организация		= Организации_ЗаполненныеРеквизиты(Идентификаторы);
				
		СопоставленныеОрганизации = СвойствоСтруктуры(Организация, "СвязанныеСправочники");
		Если СопоставленныеОрганизации = Неопределено Тогда
			СопоставленныеОрганизации = Организации_СопоставленныеВ1С(Идентификаторы);
		КонецЕсли;
		
		Если СопоставленныеОрганизации.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		ПараметрыСписка = Контрагенты_ПараметрыПолученияСпискаПартнеров(Организация);
		ПараметрыСписка.Упорядочить = Ложь;
		
		КонтрагентыЭДО = Контрагенты_ЗаполненныйСписок(ПараметрыСписка);
		
		Для Каждого СопоставленнаяОрганизация1С Из СопоставленныеОрганизации Цикл
			
			Для Каждого КонтрагентЭДО Из КонтрагентыЭДО Цикл
				
				Для Каждого РеквизитыКонтрагентовИБ Из КонтрагентЭДО.РеквизитыСвязанныхСправочников Цикл
					НоваяСтрока = Результат.Добавить();
					НоваяСтрока.Организация1С	= СопоставленнаяОрганизация1С.Ссылка;
					НоваяСтрока.Контрагент1С	= РеквизитыКонтрагентовИБ.Ссылка;
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

