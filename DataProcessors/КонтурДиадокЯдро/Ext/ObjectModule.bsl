КонецПроцедуры

Функция Модуль_Создать(ИмяМодуля) Экспорт
	
	Результат = Неопределено;
	
	Если Не ЭтоВнешняяОбработка() Тогда
		
		Результат = Модуль_СоздатьИзКонфигурации(ИмяМодуля);
		
	Иначе
		
		ДанныеДляПодключения = Макеты_ДанныеМакета(ИмяМодуля);
		
		Если ЗначениеЗаполнено(ДанныеДляПодключения) Тогда
			
			ЭтоИмяФайла = Общее_ЭтоИмяФайла(ДанныеДляПодключения);
			
			Если ЭтоИмяФайла Тогда
				
				Результат = Модуль_СоздатьИзФайлаНаДиске(ИмяМодуля, ДанныеДляПодключения);
				
			Иначе
				
				Результат = Модуль_СоздатьИзДвоичныхДанных(ИмяМодуля, ДанныеДляПодключения);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Результат, Новый Структура("Ядро", ЭтотОбъект));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Модуль_СоздатьИзФайлаНаДиске(ИмяМодуля, ПутьКФайлу)
	
	Если НЕ ФайлСуществует(ПутьКФайлу) Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
					"ru = 'Не найден файл модуля %1
					|Путь к файлу: %2'")
				, ИмяМодуля, ПутьКФайлу);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ОписаниеОбработки = ПодключенныеОбработки_Прочитать(ИмяМодуля);
	ВремяПоследнегоИзменения = СвойствоСтруктуры(ОписаниеОбработки, "ВремяИзменения");
	ФайлМодуляИзменился = ФайлИзменился(ПутьКФайлу, ВремяПоследнегоИзменения);
	
	Если НЕ ФайлМодуляИзменился Тогда
		
		Результат = КэшМодулей_Прочитать(ИмяМодуля);
		
		Если Результат <> Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = ВнешниеОбработки_СоздатьБезПредупреждений(ПутьКФайлу);
	
	КэшМодулей_Поместить(ИмяМодуля, Результат);
	
	ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция Модуль_СоздатьИзДвоичныхДанных(ИмяМодуля, ДвоичныеДанные)
	
	Результат = КэшМодулей_Прочитать(ИмяМодуля);
	
	Если Результат = Неопределено Тогда
		
		Результат = ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанные);
		
		КэшМодулей_Поместить(ИмяМодуля, Результат);
		
		ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Модуль_СоздатьИзКонфигурации(ИмяМодуля)
	
	Результат = КэшМодулей_Прочитать(ИмяМодуля);
	
	Если Результат = Неопределено Тогда
		
		Если НЕ ЗначениеЗаполнено(ИмяМодуля) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Результат = Обработки[ИмяМодуля].Создать();
			
		КэшМодулей_Поместить(ИмяМодуля, Результат);
		
		ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Модуль_Отключить(ИмяМодуля) Экспорт
	
	КэшМодулей_Поместить(ИмяМодуля, Неопределено);
	ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, Неопределено);
	
КонецПроцедуры

