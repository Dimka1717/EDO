Функция ПолномочияПодписанта_Получить(BoxID, ВидТитула, Сторона, Знач ОтпечатокСертификата = Неопределено) Экспорт
	
	// ВидТитула - Строка с вариантами: Utd, Utd820, Ucd, TovTorg551, AccCert552
	// ПокупательПродавец - Строка с вариантами "Покупатель" или "Продавец"
	// ОтпечатокСертификата может быть пустым, в этом случае возьмем отпечаток для текущего пользователя - облачный или локальный, без разницы
	
	Результат = Новый Структура("Данные, Ошибки");
	
	Если ЭтоАктСверкиВзаиморасчетов(ВидТитула) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОтпечатокСертификата) Тогда
		ОтпечатокСертификата = КонтекстСеанса_Прочитать(BoxId, "ОтпечатокСертификата");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОтпечатокСертификата) Тогда
		
		TitleType = АПИ_DocumentTitleType(ВидТитула, Сторона);
		
		КлючКэш = ПолномочияПодписанта_КлючПолномочийПодписанта(BoxId, ОтпечатокСертификата, TitleType);
		
		ПолномочияПодписанта = Кэш_Прочитать(КлючКэш);
		
		Если НЕ ЗначениеЗаполнено(ПолномочияПодписанта) Тогда
			
			ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
			
			ПолномочияПодписанта = АПИ_ExtendedSignerDetails(ПараметрыСервиса, BoxId, ОтпечатокСертификата, TitleType);
			Ошибки = ПолномочияПодписанта_ПроверитьЗаполнение(BoxId, ПолномочияПодписанта);
			
			Если НЕ ЗначениеЗаполнено(Ошибки) Тогда
				Кэш_Поместить(КлючКэш, ПолномочияПодписанта);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.Данные = ПолномочияПодписанта;
	Результат.Ошибки = Ошибки;
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_ПроверитьЗаполнение(BoxId, ПолномочияПодписанта)
	
	Результат = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(ПолномочияПодписанта) Тогда
		
		Результат.Добавить("Не заполнены полномочия.");
		
	Иначе
		
		ЭтоСотрудникОрганизации = Подписант_ЭтоСотрудникОрганизации(BoxId);
		
		Если ЭтоСотрудникОрганизации Тогда
			
			ДолжностьПодписанта = СвойствоСтруктуры(ПолномочияПодписанта, "JobTitle");
			
			Если НЕ ЗначениеЗаполнено(ДолжностьПодписанта) Тогда
				Результат.Добавить("Не заполнена должность.");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_Сохранить(BoxID, ВидТитула, Сторона, ПолномочияПодписанта, Знач ОтпечатокСертификата = Неопределено) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Если ОтпечатокСертификата = Неопределено Тогда
		ОтпечатокСертификата = КонтекстСеанса_Прочитать(BoxId, "ОтпечатокСертификата");
	КонецЕсли;
	
	TitleType = АПИ_DocumentTitleType(ВидТитула, Сторона);
	
	Результат = АПИ_ExtendedSignerDetails(ПараметрыСервиса, BoxId, ОтпечатокСертификата, TitleType, ПолномочияПодписанта);
	
	КлючКэш = ПолномочияПодписанта_КлючПолномочийПодписанта(BoxId, ОтпечатокСертификата, TitleType);
	
	Кэш_Поместить(КлючКэш, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_КлючПолномочийПодписанта(BoxId, ОтпечатокСертификата, TitleType)
	
	ШаблонКлюча = "ПолномочияПодписанта_%1_%2_%3";
	
	Результат = Общее_ПодставитьПараметрыВСтроку(ШаблонКлюча, BoxId, ОтпечатокСертификата, TitleType);
	
	Возврат Результат;	
	
КонецФункции

Функция ПолномочияПодписанта_Покупателя(BoxID, ТипКонтента) Экспорт
	
	Результат = Новый Структура;
	
	ВидТитула = Документы_ВидТитула(ТипКонтента);
	
	ОписаниеПолномочийПодписанта	= ПолномочияПодписанта_Получить(BoxID, ВидТитула, "Покупатель");
	ПолномочияПодписанта			= ОписаниеПолномочийПодписанта.Данные; 
	
	ОписаниеПодписанта = Новый Структура;
	ОписаниеПодписанта.Вставить("Фамилия",		"");
	ОписаниеПодписанта.Вставить("Имя",			"");
	ОписаниеПодписанта.Вставить("Отчество",		"");
	ОписаниеПодписанта.Вставить("Должность",	"");
	ОписаниеПодписанта.Вставить("НаименованиеОрганизации",	"");
	
	Если ПолномочияПодписанта <> Неопределено Тогда
		
		ОписаниеПодписанта.Вставить("Фамилия",		СокрЛП(ПолномочияПодписанта.Surname));
		ОписаниеПодписанта.Вставить("Имя",			СокрЛП(ПолномочияПодписанта.FirstName));
		ОписаниеПодписанта.Вставить("Отчество",		СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "Patronymic")));
		ОписаниеПодписанта.Вставить("Должность",	СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "JobTitle")));
		
	Иначе
		
		ОписаниеПользователя = КонтекстСеанса_СтрокаКонтекста(BoxID).ОписаниеПользователя;
		
		ОписаниеПодписанта.Вставить("Фамилия",		СокрЛП(ОписаниеПользователя.Фамилия));
		ОписаниеПодписанта.Вставить("Имя", 			СокрЛП(ОписаниеПользователя.Имя));
		ОписаниеПодписанта.Вставить("Отчество",		СокрЛП(ОписаниеПользователя.Отчество));
		ОписаниеПодписанта.Вставить("Должность",	ОписаниеПользователя.Должность);
		
	КонецЕсли;
	
	ЭтоСотрудникОрганизации = Подписант_ЭтоСотрудникОрганизации(BoxId);
	
	Если ЭтоСотрудникОрганизации Тогда
		
		НаименованиеОрганизации = КонтекстСеанса_Прочитать(BoxID, "ОрганизацияНаименование");
		
	Иначе

		НаименованиеОрганизации = "ИП " + ОписаниеПодписанта.Фамилия + " " 
										+ ОписаниеПодписанта.Имя 
										+ ?(ЗначениеЗаполнено(ОписаниеПодписанта.Отчество), " " + ОписаниеПодписанта.Отчество, "");
	КонецЕсли;
	
	ОписаниеПодписанта.НаименованиеОрганизации = НаименованиеОрганизации;
	
	Результат.Вставить("ПолномочияПодписанта",	ПолномочияПодписанта);
	Результат.Вставить("ОписаниеПодписанта",	ОписаниеПодписанта);
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_ОбластиПолномочий(Знач ВидТитула, Сторона) Экспорт
	
	Результат = Новый Массив;
	
	ВидТитула = НРег(ВидТитула);
	
	Если Сторона = "Покупатель" Тогда
		
		Если ВидТитула = "ucd" Тогда
			
			Результат.Добавить("PersonDocumentedOperation");
			
		ИначеЕсли ВидТитула = "ucd736" Тогда
			
			Результат.Добавить("InvoiceSigner");
			Результат.Добавить("PersonDocumentedOperation");
			Результат.Добавить("ResponsibleForOperationAndSignerForInvoice");
			Результат.Добавить("PersonOtherPower");
			
		ИначеЕсли ВидТитула = "torg2" Тогда
			
			Результат.Добавить("PersonApprovedDocument");
			Результат.Добавить("PersonConfirmedDocument");
			Результат.Добавить("PersonAgreedOnDocument");
			Результат.Добавить("PersonOtherPower");
			
		Иначе
			
			Результат.Добавить("PersonMadeOperation");
			Результат.Добавить("PersonDocumentedOperation");
			Результат.Добавить("MadeAndSignOperation");
			
		КонецЕсли;
		
	Иначе
		
		Если ВидТитула = "tovtorg551" ИЛИ ВидТитула = "acccert552" Тогда
			
			Результат.Добавить("PersonMadeOperation");
			Результат.Добавить("MadeAndSignOperation");
			Результат.Добавить("PersonDocumentedOperation");
			
		ИначеЕсли ВидТитула = "ucd" ИЛИ ВидТитула = "ucd736" Тогда
			
			Результат.Добавить("InvoiceSigner");
			Результат.Добавить("PersonDocumentedOperation");
			Результат.Добавить("ResponsibleForOperationAndSignerForInvoice");
			
		ИначеЕсли ВидТитула = "torg2" Тогда
			
			Результат.Добавить("PersonMadeOperation");
			Результат.Добавить("MadeAndSignOperation");
			Результат.Добавить("PersonDocumentedOperation");
			Результат.Добавить("ChairmanCommission");
			Результат.Добавить("MemberCommission");
			
		Иначе
			
			Результат.Добавить("InvoiceSigner");
			Результат.Добавить("PersonMadeOperation");
			Результат.Добавить("MadeAndSignOperation");
			Результат.Добавить("PersonDocumentedOperation");
			Результат.Добавить("MadeOperationAndSignedInvoice");
			Результат.Добавить("MadeAndResponsibleForOperationAndSignedInvoice");
			Результат.Добавить("ResponsibleForOperationAndSignerForInvoice");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_ПредставленияПолномочий(Знач ВидТитула) Экспорт
	
	Результат = Новый Соответствие;
	
	ВидТитула = НРег(ВидТитула);
	
	Если ВидТитула = "torg2" Тогда
		
		Результат.Вставить("PersonMadeOperation", "Лицо, принявшее ценности");
		Результат.Вставить("MadeAndSignOperation", "Лицо, принявшее ценности и ответственное за оформление события (операции)");
		Результат.Вставить("PersonDocumentedOperation", "Лицо, ответственное за оформление события (операции)");
		
	Иначе
		
		Результат.Вставить("PersonMadeOperation", "Лицо, совершившее сделку, операцию");
		Результат.Вставить("MadeAndSignOperation", "Лицо, совершившее сделку, операцию и ответственное за её оформление");
		Результат.Вставить("PersonDocumentedOperation", "Лицо, ответственное за оформление свершившегося события");
		
	КонецЕсли;
	
	Результат.Вставить("InvoiceSigner",										"Лицо, ответственное за подписание счетов-фактур"); 
	Результат.Вставить("MadeOperationAndSignedInvoice",						"Лицо, совершившее сделку, операцию и ответственное за подписание счетов-фактур");
	Результат.Вставить("MadeAndResponsibleForOperationAndSignedInvoice",	"Лицо, совершившее сделку, операцию и ответственное за её оформление и за подписание счетов-фактур");
	Результат.Вставить("ResponsibleForOperationAndSignerForInvoice",		"Лицо, ответственное за оформление свершившегося события и за подписание счетов-фактур");
	Результат.Вставить("PersonApprovedDocument",							"Лицо, в полномочия которого входит утверждение документа, оформляющего событие (факт хозяйственной жизни)");
	Результат.Вставить("PersonConfirmedDocument",							"Лицо, в полномочия которого входит подтверждение оформленного события (факта хозяйственной жизни)");
	Результат.Вставить("PersonAgreedOnDocument",							"Лицо, в полномочия которого входит согласование документа, оформляющего событие (факт хозяйственной жизни)");
	Результат.Вставить("PersonOtherPower",									"Лицо с иными полномочиями");
	Результат.Вставить("ChairmanCommission",								"Председатель комиссии");
	Результат.Вставить("MemberCommission",									"Член комиссии");
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_ЗаполненыДляДокументовПакета(Пакет)
	
	Результат = Истина;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ПолномочияЗаполненыДляТекущегоДокумента = ПолномочияПодписанта_ЗаполненыДляДокумента(Документ);
		
		Результат = Результат И ПолномочияЗаполненыДляТекущегоДокумента;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_ЗаполненыДляДокумента(Документ)
	
	Результат = Истина;
	
	BoxId = Документ.Отправитель.BoxId;
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	ВидТитула = Документы_ВидТитула(ТипКонтента);
	
	Если ЗначениеЗаполнено(ВидТитула) Тогда
		
		ОписаниеПолномочийПодписанта = ПолномочияПодписанта_Получить(BoxId, ВидТитула, "Продавец");
		
		Если ЗначениеЗаполнено(ОписаниеПолномочийПодписанта.Ошибки) Тогда
			
			Если Документы_ДокументОтправлен(Документ) Тогда
				ВидОперации = "Отправка отложенного пакета документов"
			Иначе
				ВидОперации = "Отправка пакета документов";
			КонецЕсли;
			
			Представление = Документы_ПредставлениеДокумента(Документ);
			ТекстОшибки = НСтр(
				"ru='Не удалось подписать документ %1 по причине: в модуле не заполнены полномочия подписанта.
				|
				|Необходимо заполнить полномочия и повторить попытку отправки документов.
				|
				|Для заполнения перейдите по ссылке: '"
			);
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Представление);
			
			ПараметрыФормыЗаполненияПолномочийПодписанта = Новый Структура;
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("АдресЯщика", BoxId);
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("ТипКонтента", ТипКонтента);
			ПараметрыФормыЗаполненияПолномочийПодписанта.Вставить("ПокупательПродавец", "Продавец");
			
			ПараметрыСсылки = СписокОшибок_НовыеПараметрыРасшифровки("");
			ПараметрыСсылки.Вставить("ОбработчикОповещения", "ОбработчикОповещения_ОткрытьФормуЗаполненияПолномочийПодписанта");
			ПараметрыСсылки.Вставить("РезультатОповещения", ПараметрыФормыЗаполненияПолномочийПодписанта);
			
			РасшифровкаОшибок = Новый Массив;
			ПредставлениеСсылки = "Заполнить полномочия";
			ДействиеОткрытьФорму = СписокОшибок_Перечисление_ВидыДействийСпискаОшибок().ВыполнитьОповещение;
			
			СписокОшибок_ДобавитьРасшифровкуВМассив(РасшифровкаОшибок, ПараметрыСсылки, ПредставлениеСсылки, ДействиеОткрытьФорму);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, , , , , РасшифровкаОшибок);
			
			Результат = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолномочияПодписанта_СтатусыПодписанта(Знач ВидТитула, Сторона) Экспорт
	
	Результат = Новый Массив;
	
	ВидТитула = НРег(ВидТитула);
	
	Если ВидТитула = "torg2" Тогда
		
		Если Сторона = "Покупатель" Тогда
			
			Результат.Добавить("SellerEmployee");
			Результат.Добавить("OtherOrganizationEmployee");
			Результат.Добавить("AuthorizedPerson");
			Результат.Добавить("BuyerEmployee");
			Результат.Добавить("InformationCreatorBuyerEmployee");
			
		Иначе
			
			Результат.Добавить("OtherOrganizationEmployee");
			Результат.Добавить("AuthorizedPerson");
			Результат.Добавить("BuyerEmployee");
			Результат.Добавить("InformationCreatorBuyerEmployee");
			
		КонецЕсли;
		
	Иначе
		
		ЗаполнятьПоСотрудникуПокупателя = Ложь;
		
		Если Сторона = "Покупатель"
			И (ВидТитула = "utd970"
				ИЛИ ВидТитула = "utd820"
				ИЛИ ВидТитула = "ucd736") Тогда
				
			ЗаполнятьПоСотрудникуПокупателя = Истина;
			
		КонецЕсли;
			
		Если ЗаполнятьПоСотрудникуПокупателя Тогда
			Результат.Добавить("BuyerEmployee");
			Результат.Добавить("InformationCreatorBuyerEmployee");
		Иначе
			Результат.Добавить("SellerEmployee");
			Результат.Добавить("InformationCreatorEmployee");
		КонецЕсли;
		
		Результат.Добавить("OtherOrganizationEmployee");
		Результат.Добавить("AuthorizedPerson");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает представления статусов расширенного подписанта ExtendedSignerDetails.SignerStatus
//
// Параметры:
//  ПокупательПродавец - Строка - "Покупатель", если нужно вернуть представления статусов со стороны покупателя
// 
// Возвращаемое значение:
//  Структура
//
Функция ПолномочияПодписанта_ПредставленияСтатусовПодписанта(Знач ВидТитула, Сторона) Экспорт
	
	Результат = Новый Структура;
	
	ВидТитула = НРег(ВидТитула);
	
	Если Сторона = "Покупатель" И ВидТитула <> "torg2" Тогда
		SellerEmployee = "Работник организации - покупателя товаров (работ, услуг, имущественных прав)"; 
		InformationCreatorEmployee = "Работник организации - составителя файла обмена информации покупателя, если составитель файла обмена информации не является покупателем";
	Иначе
		SellerEmployee = "Работник организации - продавца товаров (работ, услуг, имущественных прав)"; 
		InformationCreatorEmployee = "Работник организации - составителя файла обмена информации продавца, если составитель файла обмена информации не является продавцом";
	КонецЕсли;
	
	Если Сторона = "Продавец" И ВидТитула = "torg2" Тогда
		BuyerEmployee = "Работник организации-покупателя";
		InformationCreatorBuyerEmployee = "Работник организации - составителя файла обмена информации покупателя";
	Иначе
		BuyerEmployee = "Работник организации - покупателя товаров (работ, услуг, имущественных прав)";
		InformationCreatorBuyerEmployee = "Работник организации - составителя файла обмена информации покупателя, если составитель файла обмена информации покупателя не является покупателем";
	КонецЕсли;
	
	Результат.Вставить("SellerEmployee",					SellerEmployee);
	Результат.Вставить("InformationCreatorEmployee",		InformationCreatorEmployee);
	Результат.Вставить("OtherOrganizationEmployee",			"Работник иной уполномоченной организации");
	Результат.Вставить("AuthorizedPerson",					"Уполномоченное физическое лицо (в том числе индивидуальный предприниматель)");
	Результат.Вставить("BuyerEmployee",						BuyerEmployee); 
	Результат.Вставить("InformationCreatorBuyerEmployee",	InformationCreatorBuyerEmployee);
	
	Возврат Результат;
	
КонецФункции

