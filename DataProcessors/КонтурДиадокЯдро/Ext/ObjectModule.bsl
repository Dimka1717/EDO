// Возвращает сводную информацию о перевозочных документах для коллекции учетных документов пакета
//
// Параметры:
//  ДокументыУчета	 - Массив	 - Коллекция ссылок на учетные документы пакета
// 
// Возвращаемое значение:
//  Структура - Сводная информация о перевозочных документах
//
Функция КонтурЛогистика_СостояниеПеревозочныхДокументов(ДокументыУчета) Экспорт
	
	РаботаСЛогистикой = Модуль_РаботаСЛогистикой(ЭтотОбъект);
	
	Результат = РаботаСЛогистикой.СостояниеПеревозочныхДокументов(ДокументыУчета);
	
	Если ЗначениеЗаполнено(Результат.ТекстОшибки) Тогда
		
		Действие = Метрика_НазваниеДействий().СостояниеСвязанныхДокументов;
		КонтурЛогистика_ОбработатьОшибку(Действие, Результат.ТекстОшибки);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет необходимость предложить установить модуль Логистики через Мастер установки.
// Для платформы старше 8.3.9 безусловно не предлагаем установку,
// т.к. это техническое ограничение использования модуля Логистики.
// 
// Возвращаемое значение:
//  Булево - признак необходимости предлагать установку
//
Функция КонтурЛогистика_ПредложитьУстановитьМодуль() Экспорт
	
	Если ПриложениеСтаршеВерсии("8.3.9") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	МодульЛогистикиУстановлен = КонтурЛогистика_МодульУстановлен();
	
	Если МодульЛогистикиУстановлен Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Результат = Ложь;
	
	ЗначенияОпций = ОбщийКонтекст_Прочитать("ФункциональныеОпции");
	ТипБулево = Тип("Булево");
	
	Значение = ЗначенияОпций.Получить("Logistic.Install");
	
	Если ЗначениеЗаполнено(Значение) Тогда
		
		Попытка
			Результат = XMLЗначение(ТипБулево, Значение);
		Исключение
			Результат = Ложь;
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Скачивает из Сервиса обновлений Мастер установки Логистики
// и возвращает имя подключенной внешней обработки.
// 
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект - Объект подключенной внешней обработки
//
Функция КонтурЛогистика_ПодключитьМастерУстановки() Экспорт
	
	РаботаСЛогистикой = Модуль_РаботаСЛогистикой(ЭтотОбъект);
	
	ИмяВнешнейОбработки = "КонтурЛогистика_МастерУстановки";
	
	ИдентификаторПоставки = РаботаСЛогистикой.ИдентификаторМодуляМастераУстановки();
	ТипПоставки = "data-processor";
	
	ДвоичныеДанныеОбработки = АпдейтКлиент_ДвоичныеДанныеПоставки(ИдентификаторПоставки, ТипПоставки);
	
	Результат = ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанныеОбработки, ИмяВнешнейОбработки);
	
	Возврат Результат;
	
КонецФункции

Функция АпдейтКлиент_ДвоичныеДанныеПоставки(ИдентификаторПоставки, ТипПоставки)
	
	АпдейтКлиент = Модуль_АпдейтКлиент();
	
	ИдентификаторИБ = Строка(_ИдентификаторИнформационнойБазыДиадок());
	
	Версия = АпдейтКлиент.КонтекстВерсии();
	Версия.Версия = "0.0.0";
	Версия.ИдБазы = ИдентификаторИБ;
	
	Статус = АпдейтКлиент.ПроверитьОбновление(ИдентификаторПоставки, Версия);
	ФайлПоставки = АпдейтКлиент.СкачатьОбновление(Статус, ТипПоставки);
	
	Если Не ФайлПоставки.Размер() Тогда
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"КонтурДиадокАпдейтКлиент: Файл поставки не содержит данных
			|ИдБазы = %1
			|Продукт = %2
			|ТипКонтента = %3",
			Статус.ИдБазы,
			Статус.Продукт,
			ТипПоставки
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	Возврат ФайлПоставки;
	
КонецФункции

