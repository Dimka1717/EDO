Процедура Документы_ЗаполнитьФормализованныйКонтентXML(Документ, ПроверятьXDTO) Экспорт
	
	ПротоСтруктура = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Новый Структура);
	Документы_ЗаполнитьПротоСтруктуруПодписантом(Документ, ПротоСтруктура);
	Документы_ЗаполнитьПротоСтруктуруИдентификаторамиУчастниковЭДО(Документ);
	
	ДокументXML = Документы_НовыйДокументXML(Документ, ПроверятьXDTO);
	МетаданныеДокументаXML = ГенерацияXML_МетаданныеДокументаXML(ДокументXML);
	ЗаполнитьЗначенияСвойств(Документ.Метаданные, МетаданныеДокументаXML);
	
	ДанныеХранения = Контракт_ДанныеХранения();
	ДанныеХранения.Данные = ГенерацияXML_ОбъектXDTO_В_ДвоичныеДанные(ДокументXML);
	Документ.Метаданные.Свойство("FileName", ДанныеХранения.ИмяФайла);
	Документ.Документооборот.Вставить("ХранилищеКонтента", ДанныеХранения);

	Контракт_СвойстваФайла = Контракт_СлужебнаяИнформация_СвойстваФайла();
	СвойстваФайла = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "СвойстваФайла", Контракт_СвойстваФайла);
	СвойстваФайла.ИмяФайла = ДанныеХранения.ИмяФайла;
	СвойстваФайла.РазмерФайла = ДанныеХранения.Данные.Размер();
	Документ.СлужебнаяИнформация.Вставить("СвойстваФайла", СвойстваФайла);
	
КонецПроцедуры

Функция Документы_НовыйДокументXML(Документ, ПроверятьXDTO)
	
	Попытка
		
		Результат = ГенерацияXML_НовыйДокументXML(Документ, ПроверятьXDTO);
		
	Исключение
		
		ФорматОтправки = ФорматОтправкиПоТипуДокумента(Документ.Тип);
		СсылкаНаОбъект = Документ.ДокументУчета;
		
		Ошибка = ИнформацияОбОшибке();
		
		ШаблонОшибки =
		"Не удалось сформировать файл XML (Тип=%1, Функция=%2, Версия=%3) по причине:
		|%4";
		
		ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ФорматОтправки.ИмяТипа,
			ФорматОтправки.ФункцияДокумента,
			ФорматОтправки.ВерсияФормата,
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ГенерацияXML",
			УровеньЖурналаРегистрации.Ошибка,
			СсылкаНаОбъект.Метаданные(),
			СсылкаНаОбъект,
			ПодробнаяОшибка
		);
		
		ДопКонтекст = Новый Соответствие;
		ДополнитьПеременныеМетрики_ТипЭлектронногоДокумента(ДопКонтекст, ФорматОтправки);
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияОтправкаДокумента(),
			"СформироватьXML",
			Ошибка,
			ДопКонтекст
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ЗаполнитьХранилищеКонтента(Документ) Экспорт
	
	ХранилищеКонтента	= ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, "ХранилищеКонтента");
	ДвоичныеДанные		= ХранилищеКонтента.Данные;
	
	Если ДвоичныеДанные <> Неопределено Тогда
		
		Если Документ.Тип.Формализованный Тогда
			
			ОбъектXDTO = ГенерацияXML_XML_В_ОбъектXDTO(ДвоичныеДанные);
			
			Попытка
				Контент = ГенерацияXML_ОбъектXDTO_В_ProtoСтруктура(ОбъектXDTO);
				Документ.СлужебнаяИнформация.Вставить("Контент", Контент);
			Исключение
				
				ПредставлениеДокумента = Документы_ПредставлениеДокумента(Документ);
				
				ВидОперации		 = "Чтение контента документа";
				ТекстСообщения	 = Общее_ПодставитьПараметрыВСтроку("Не удалось прочитать контент документа: %1", ПредставлениеДокумента);
				ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ДопИнформация = Новый Массив;
				ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Документ: %1", ПредставлениеДокумента));
				
				Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
				
			КонецПопытки;
			
		КонецЕсли;
		
		Документ.Документооборот.Вставить("ХранилищеКонтента", ХранилищеКонтента);
		
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ОпределитьНаличиеРазногласийВФормализованныхАктахСверок(Документы) Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("АктыСРазногласиями", Новый Массив);
	Результат.Вставить("АктыБезРазногласий", Новый Массив);
	
	ВидыИтоговСверки = ВидыИтоговСверки_Значения();
	
	Для Каждого Документ Из Документы Цикл
		
		ТипКонтента = Документ.Тип.ТипКонтента;
		
		Если НЕ ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ Документы_МожноСформироватьОтветныйТитулФормализованногоАктаСверки(Документ) Тогда
			
			Результат.АктыБезРазногласий.Добавить(Документ);
			
			Продолжить;
			
		КонецЕсли;
		
		Документы_ЗаполнитьОтветныйТитулФормализованногоАктаСверки(Документ, Ложь);
		
		КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета");
		
		Если ЗначениеЗаполнено(КонтентОтвета)
			И КонтентОтвета.SignDisagreement = ВидыИтоговСверки.ЕстьРазногласия Тогда
			
			Результат.АктыСРазногласиями.Добавить(Документ);
		Иначе
			Результат.АктыБезРазногласий.Добавить(Документ);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноСформироватьОтветныйТитулФормализованногоАктаСверки(Документ) Экспорт
	
	Результат = Ложь;
	
	Если НЕ ЭтоФормализованныйАктСверки405(Документ.Тип.ТипКонтента) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если КонфигурацияПоддерживаетСверкуВзаиморасчетов() И Документы_МожноПодписатьВходящий(Документ) Тогда
		
		СтатусДокументаТребуетсяПодпись = Перечисление_СтатусыДокументов().ТребуетсяПодпись;
		Статус = Документ.Статусы.Статус;
		Документ1С = Документ.ДокументУчета;
		
		Если Найти(Статус, СтатусДокументаТребуетсяПодпись) > 0
			И ЗначениеЗаполнено(Документ1С)
			И Документ1С.Проведен Тогда
			
			Результат = Истина;
			
		Иначе
			
			Результат = Ложь;
			
		КонецЕсли;
		
	Иначе
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ЗаполнитьОтветныйТитулФормализованногоАктаСверки(Документ, ЗаполнитьТаблицуОтветногоТитулаАктаСверки) Экспорт
	
	Документ1С = Документ.ДокументУчета;
	ТипКонтента = Документ.Тип.ТипКонтента;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЗаполнитьТаблицуОтветногоТитулаАктаСверки", ЗаполнитьТаблицуОтветногоТитулаАктаСверки);
	
	КонтентОтвета = МенеджерИнтеграции_КонтентОтветногоТитула(Документ1С, ТипКонтента, ДополнительныеПараметры);
	
	Документ.СлужебнаяИнформация.Вставить("КонтентОтвета", КонтентОтвета);
	
КонецПроцедуры

// В зависимости от имени и версии конфигурации определяет доступность сверки в 1С
//
// Возвращаемое значение:
//  Булево - Истина - сверка в 1С доступна
//			 Ложь - сверка в 1С не доступна
//
Функция КонфигурацияПоддерживаетСверкуВзаиморасчетов() Экспорт
	
	Результат = Ложь;
	
	ОписаниеКонфигурации = ОписаниеКонфигурации();
	
	ИмяКонфигурации = ОписаниеКонфигурации.Имя;
	ВерсияКонфигурации = ОписаниеКонфигурации.Версия;
	ТаблицаКонфигураций = КонфигурацииСПоддержкойСверкиВзаиморасчетов();
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИмяКонфигурации", ИмяКонфигурации);
	
	СтрокаТаблицы = ТаблицаКонфигураций.Найти(ИмяКонфигурации, "ИмяКонфигурации");
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Результат = (СравнитьВерсии(ВерсияКонфигурации, СтрокаТаблицы.ВерсияКонфигурации) >= 0);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует таблицу конфигураций поддерживающих сверку взаиморасчетов.
//
// Возвращаемое значение:
//  ТаблицаЗначений.
//    * ИмяКонфигурации - Строка- Имя конфигурации;
//    * ВерсияКонфигурации - Строка- Версия конфигурации;
//
Функция КонфигурацииСПоддержкойСверкиВзаиморасчетов()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИмяКонфигурации");
	Результат.Колонки.Добавить("ВерсияКонфигурации");
	
	ДобавитьСтрокуВТаблицуЗначений(Результат, "БухгалтерияПредприятия", "3.0.131");
	ДобавитьСтрокуВТаблицуЗначений(Результат, "БухгалтерияПредприятияКОРП", "3.0.131");
	ДобавитьСтрокуВТаблицуЗначений(Результат, "УправлениеТорговлей", "11.5.11.79");
	ДобавитьСтрокуВТаблицуЗначений(Результат, "КомплекснаяАвтоматизация", "2.5.11.79");
	ДобавитьСтрокуВТаблицуЗначений(Результат, "УправлениеПредприятием", "2.5.11.79");
	ДобавитьСтрокуВТаблицуЗначений(Результат, "УправлениеХолдингомERP", "3.1.11.8");
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ)
	
	КонтрактМЧД = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
	
	Если КонтрактМЧД <> Неопределено Тогда
		
		ПередаватьМЧДФайлом = МЧД_ЗначениеНастройкиПередаватьМЧДФайломПоДокументу(Документ);
		
		Результат = АПИ_Новый_PowerOfAttorneyToPost(КонтрактМЧД, ПередаватьМЧДФайлом);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ЗначениеНастройкиПередаватьМЧДФайломПоДокументу(Документ)
	
	КлючНастроек = НастройкиДокументов_КлючЗначенияВКэшеПередаватьМЧДФайлом();
	
	НастройкиКэш = Кэш_Прочитать(КлючНастроек);
	Если НастройкиКэш = Неопределено Тогда
		НастройкиКэш = Новый Соответствие;
		Кэш_Поместить(КлючНастроек, НастройкиКэш);
	КонецЕсли;
	
	АдресЯщикаОрганизации = Документ.Идентификаторы.BoxId;
	Если Документ.Направление = Перечисление_Направления().Входящее Тогда
		АдресЯщикаКонтрагента = Документ.Отправитель.BoxId;
	Иначе
		АдресЯщикаКонтрагента = Документ.Получатель.BoxId;
	КонецЕсли;

	КлючЗначения = АдресЯщикаОрганизации + АдресЯщикаКонтрагента;
	
	Результат = НастройкиКэш.Получить(КлючЗначения);
	
	Если Результат = Неопределено Тогда
		
		ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(, АдресЯщикаОрганизации);
		ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
		
		ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(, АдресЯщикаКонтрагента);
		ДанныеКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
		
		Результат = НастройкиДокументов_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации, ДанныеКонтрагента);
		
		НастройкиКэш.Вставить(КлючЗначения, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает описание электронного документа по идентификаторам
//
// Параметры:
//  BoxId - Строка - ящик организации
//  MessageId - Строка - идентификатор сообщения
//  EntityId - Строка - идентификатор вложения
// 
// Возвращаемое значение:
//  Структура - см. Контракт_Документ
//
Функция Документы_ДанныеДокумента(BoxId, MessageId, EntityId)
	
	Идентификаторы = Контракт_Идентификаторы();
	Идентификаторы.BoxID = BoxID;
	Идентификаторы.LetterID = MessageId;
	Идентификаторы.DocumentID = EntityId;
	
	Результат = ХранениеДанных_ДанныеДокумента(Идентификаторы);
	
	Возврат Результат;
	
КонецФункции

// Возвращает виды документов из текущей конфигурации для поиска в модуле
// 
// Возвращаемое значение:
//  Структура - Предопределенные виды документов конфигурации для поиска в модуле
//
Функция Документы_ВидыДокументовДляПоискаВМодуле() Экспорт
	
	Результат = Новый СписокЗначений;
	
	Если НЕ ЕстьИнтеграционныйМодуль() Тогда
		Возврат Результат;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	ВидыДокументов = МенеджерИнтеграции.ВидыПредопределенныхДокументовДляПоискаВМодуле();
	
	Для Каждого ОбъектМетаданных Из ВидыДокументов Цикл
		
		ПредставлениеОбъекта = ОбъектМетаданных.ПредставлениеОбъекта;
		
		Если НЕ ЗначениеЗаполнено(ПредставлениеОбъекта) Тогда
			ПредставлениеОбъекта = ОбъектМетаданных.Представление();
		КонецЕсли;
		
		Результат.Добавить(ОбъектМетаданных.ПолноеИмя(), ПредставлениеОбъекта);
		
	КонецЦикла;
	
	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции

// МЕТАДАННЫЕ ДОКУМЕНТА

Функция Документы_МетаданныеПротоСтруктуры(Документ)
	
	ПротоСтруктура	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Новый Структура);
	ТипКонтента		= Документ.Тип.ТипКонтента;
	
	Результат = Новый Структура;
		
	Если ТипЗнч(ПротоСтруктура) = Тип("Структура") Тогда
		
		ТипыКонтентов = Перечисление_ТипыКонтентов();
		
		Если ПротоСтруктура.Свойство("Seller") Тогда
			Результат.Вставить("SellerFnsParticipantId", ПротоСтруктура.Seller.FNSParticipantId);
		КонецЕсли;
		
		Если ПротоСтруктура.Свойство("Buyer") Тогда
			Результат.Вставить("BuyerFnsParticipantId",	ПротоСтруктура.Buyer.FNSParticipantId);
		КонецЕсли;
		
		Если ПротоСтруктура.Свойство("Sellers") И ПротоСтруктура.Sellers.Количество() > 0 Тогда
			Результат.Вставить("SellerFnsParticipantId", ПротоСтруктура.Sellers[0].FNSParticipantId);
		КонецЕсли;
		
		Если ПротоСтруктура.Свойство("Buyers") И ПротоСтруктура.Buyers.Количество() > 0 Тогда
			Результат.Вставить("BuyerFnsParticipantId",	ПротоСтруктура.Buyers[0].FNSParticipantId);
		КонецЕсли;
		
		Для Каждого КлючЗначение Из ПротоСтруктура Цикл
			
			Если НЕ ЗначениеЗаполнено(КлючЗначение.Значение) Тогда
				Продолжить;
			КонецЕсли;
			
			Если (КлючЗначение.Ключ = "Date" ИЛИ КлючЗначение.Ключ = "DocumentDate")
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "DocumentDate")) Тогда
				
				Результат.Вставить("DocumentDate", КлючЗначение.Значение);
				
			ИначеЕсли (КлючЗначение.Ключ = "Number" ИЛИ КлючЗначение.Ключ = "DocumentNumber")
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "DocumentNumber")) Тогда
				
				Результат.Вставить("DocumentNumber", КлючЗначение.Значение);
				
			ИначеЕсли КлючЗначение.Ключ = "Price"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "ContractPrice")) Тогда
				
				Результат.Вставить("ContractPrice", КлючЗначение.Значение);
				
			ИначеЕсли КлючЗначение.Ключ = "Grounds"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "Grounds")) Тогда
				
				Результат.Вставить("Grounds", КлючЗначение.Значение);
				
			ИначеЕсли КлючЗначение.Ключ = "ContractType"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "ContractType")) Тогда
				
				Результат.Вставить("ContractType", КлючЗначение.Значение);
				
			ИначеЕсли КлючЗначение.Ключ = "Currency"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "CurrencyCode")) Тогда
				
				Результат.Вставить("CurrencyCode", КлючЗначение.Значение);
				
			ИначеЕсли КлючЗначение.Ключ = "Vat" И КлючЗначение.Значение <> Неопределено // Неопределено = "Без НДС"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "TotalVat")) Тогда
				
				Результат.Вставить("TotalVat", ЧислоИзСтрокиЛок(КлючЗначение.Значение));	
				
			ИначеЕсли КлючЗначение.Ключ = "Total"
				И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(Результат, "TotalSum")) Тогда
				
				Результат.Вставить("TotalSum", ЧислоИзСтрокиЛок(КлючЗначение.Значение));
				
			ИначеЕсли КлючЗначение.Ключ = "InvoiceTable" Тогда //@155
				
				Результат.Вставить("TotalVat", ЧислоИзСтрокиЛок(КлючЗначение.Значение.Vat));
				Результат.Вставить("TotalSum", ЧислоИзСтрокиЛок(КлючЗначение.Значение.Total));
				
			ИначеЕсли КлючЗначение.Ключ = "Table" Тогда //@551
				
				Если КлючЗначение.Значение.Свойство("Vat") Тогда  //@820
					Результат.Вставить("TotalVat", ЧислоИзСтрокиЛок(КлючЗначение.Значение.Vat));
				ИначеЕсли КлючЗначение.Значение.Свойство("TotalVat") Тогда
					Результат.Вставить("TotalVat", ЧислоИзСтрокиЛок(КлючЗначение.Значение.TotalVat));
				КонецЕсли;
				
				Результат.Вставить("TotalSum", ЧислоИзСтрокиЛок(КлючЗначение.Значение.Total));
				
			ИначеЕсли КлючЗначение.Ключ = "Works" Тогда //@552
				
				TotalVat = 0;
				TotalSum = 0;
				
				Для Каждого Work Из КлючЗначение.Значение Цикл
					TotalVat = TotalVat + ЧислоИзСтрокиЛок(Work.TotalVat);
					TotalSum = TotalSum + ЧислоИзСтрокиЛок(Work.Total);
				КонецЦикла;
				
				Результат.Вставить("TotalVat", TotalVat);
				Результат.Вставить("TotalSum", TotalSum);
				
			ИначеЕсли КлючЗначение.Ключ = "InvoiceCorrectionTable" Тогда //@189
				
				Если КлючЗначение.Значение.Свойство("TotalsDec") Тогда
					Результат.Вставить("CorrectionVatDec"	, ЧислоИзСтрокиЛок(КлючЗначение.Значение.TotalsDec.Vat));
					Результат.Вставить("CorrectionTotalDec"	, ЧислоИзСтрокиЛок(КлючЗначение.Значение.TotalsDec.Total));
				КонецЕсли;
				
				Если КлючЗначение.Значение.Свойство("TotalsInc") Тогда
					Результат.Вставить("CorrectionVatInc"	, ЧислоИзСтрокиЛок(КлючЗначение.Значение.TotalsInc.Vat));
					Результат.Вставить("CorrectionTotalInc"	, ЧислоИзСтрокиЛок(КлючЗначение.Значение.TotalsInc.Total));
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ТипКонтента = ТипыКонтентов.utd ИЛИ ТипКонтента = ТипыКонтентов.ucd Тогда
			
			Если НЕ ЗначениеЗаполнено(ПротоСтруктура.RevisionNumber) Тогда
				Результат.Вставить("DocumentNumber"	, ПротоСтруктура.Number);
				Результат.Вставить("DocumentDate"	, ПротоСтруктура.Date);
			Иначе
				Результат.Вставить("DocumentNumber"			, ПротоСтруктура.RevisionNumber);
				Результат.Вставить("DocumentDate"			, ПротоСтруктура.RevisionDate);
				Результат.Вставить("OriginalDocumentNumber"	, ПротоСтруктура.Number);
				Результат.Вставить("OriginalDocumentDate"	, ПротоСтруктура.Date);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипКонтента = ТипыКонтентов.ucd Тогда
			Результат.Вставить("OriginalDocumentNumber"	, ПротоСтруктура.Invoices[0].InvoiceNumber);
			Результат.Вставить("OriginalDocumentDate"	, ПротоСтруктура.Invoices[0].InvoiceDate);
		КонецЕсли;
		
		Если ТипКонтента = ТипыКонтентов.rezru Тогда
			
			Результат.Вставить("DocumentName"	, ПротоСтруктура.DocumentName);
			Результат.Вставить("DocumentNumber"	, ПротоСтруктура.DocumentNumber);
			Результат.Вставить("DocumentDate"	, ПротоСтруктура.DocumentDate);
			
			Если ЗначениеЗаполнено(ПротоСтруктура.RevisionNumber) Тогда					
				Результат.Вставить("RevisionNumber"	, ПротоСтруктура.RevisionNumber);
				Результат.Вставить("RevisionDate"	, ПротоСтруктура.RevisionDate);
			КонецЕсли;
			
		КонецЕсли;
		
		Если (ТипКонтента = ТипыКонтентов.utd820 Или ТипКонтента = ТипыКонтентов.utd970)
			И ЗначениеЗаполнено(ПротоСтруктура.RevisionNumber) Тогда
			
			Результат.Вставить("DocumentNumber",			ПротоСтруктура.RevisionNumber);
			Результат.Вставить("DocumentDate",				ПротоСтруктура.RevisionDate);
			Результат.Вставить("OriginalDocumentNumber",	ПротоСтруктура.DocumentNumber);
			Результат.Вставить("OriginalDocumentDate",		ПротоСтруктура.DocumentDate);
			
		КонецЕсли;
		
		Если ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
			
			Результат.Вставить("DocumentNumber", ПротоСтруктура.ActNumber);
			Результат.Вставить("BeginDate", ПротоСтруктура.ReconcilationDateFrom);
			Результат.Вставить("EndDate", ПротоСтруктура.ReconcilationDateTo);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет FnsParticipantId отправителя и получателя.
// В XML эти данные заполняются в поля: ИдПол и ИдОтпр, а также используются для формирования имени файла.
Процедура Документы_ЗаполнитьПротоСтруктуруИдентификаторамиУчастниковЭДО(Документ)
		
	ТипКонтента		= Документ.Тип.ТипКонтента;
	ПротоСтруктура	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент");
	
	Если 	ТипКонтента = "utd"
		ИЛИ ТипКонтента = "utd820"
		ИЛИ ТипКонтента = "utd970"
		ИЛИ ТипКонтента = "ucd"
		ИЛИ ТипКонтента = "ucd736"
		ИЛИ ТипКонтента = "tovtorg"
		ИЛИ ТипКонтента = "rezru"
		ИЛИ ТипКонтента = "xmlproformainvoice"
		ИЛИ ТипКонтента = ТипКонтента_proformainvoice29()
		ИЛИ ТипКонтента = ТипКонтента_invoiceoffer29() Тогда
		
		Если ТипКонтента = "utd820" Или ТипКонтента = "utd970" Тогда
			
			Если ПротоСтруктура.Buyers.Количество() > 0 И ПротоСтруктура.Sellers.Количество() > 0 Тогда
				Buyer	= ПротоСтруктура.Buyers[0];
				Seller	= ПротоСтруктура.Sellers[0];
			Иначе
				Возврат;
			КонецЕсли;
			
		Иначе
			Buyer	= ПротоСтруктура.Buyer;
			Seller	= ПротоСтруктура.Seller;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Buyer.FnsParticipantId) Тогда
			Buyer.FnsParticipantId = Документ.Получатель.FnsParticipantId;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Seller.FnsParticipantId) Тогда
			Seller.FnsParticipantId = Документ.Отправитель.FnsParticipantId;
		КонецЕсли;
		
	ИначеЕсли ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
		
		Sender = ПротоСтруктура.ReconciliationAct.AdditionalInfoReconciliationAct.Sender;
		Recipient = ПротоСтруктура.ReconciliationAct.AdditionalInfoReconciliationAct.Recipient;
		
		Recipient.FnsParticipantId = Документ.Получатель.FnsParticipantId;
		Sender.FnsParticipantId = Документ.Отправитель.FnsParticipantId;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Документы_ЗаполнитьРеквизитыПодготовленногоДокумента(Документ)
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "DocumentDate")) Тогда
		Документ.Реквизиты.Дата = Документ.Метаданные.DocumentDate;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "DocumentNumber")) Тогда
		Документ.Реквизиты.Номер = Документ.Метаданные.DocumentNumber;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "TotalSum")) Тогда
		Документ.Реквизиты.Сумма = Документ.Метаданные.TotalSum;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "CorrectionTotalInc"))
		ИЛИ ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "CorrectionTotalDec")) Тогда
		Документ.Реквизиты.Сумма = Документ.Метаданные.CorrectionTotalInc - Документ.Метаданные.CorrectionTotalDec;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "TotalVat")) Тогда
		Документ.Реквизиты.СуммаНДС = Документ.Метаданные.TotalVat;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "CorrectionVatInc"))
		ИЛИ ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "CorrectionVatDec")) Тогда
		Документ.Реквизиты.СуммаНДС = Документ.Метаданные.CorrectionVatInc - Документ.Метаданные.CorrectionVatDec;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "CurrencyCode")) Тогда
		Документ.Реквизиты.КодВалюты = Документ.Метаданные.CurrencyCode;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойствоСтруктуры(Документ.Метаданные, "FileName")) Тогда
		
		ИмяФайла = Документ.Метаданные.FileName;
		 
		Документ.ИмяФайла = ИмяФайла;
		Документ.ИмяФайла = Документы_ПредставлениеДокумента(Документ);
		
		ХранилищеКонтента = Неопределено;
		
		Если Документ.Документооборот.Свойство("ХранилищеКонтента", ХранилищеКонтента) Тогда
			ХранилищеКонтента.ИмяФайла = ИмяФайла;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Применяется для формализованных документов: обновляет подписанта в прото-структуре
//
Процедура Документы_ЗаполнитьПротоСтруктуруПодписантом(Документ, ПротоСтруктура, Сторона = "Продавец") Экспорт
	
	Если Документ.Тип.ТипКонтента = ТипКонтента_utd970()
		Или Документ.Тип.ТипКонтента = ТипКонтента_proformainvoice29()
		Или Документ.Тип.ТипКонтента = ТипКонтента_invoiceoffer29()
		Или Документ.Тип.ТипКонтента = ТипКонтента_torgblr() Тогда
		
		Signer = Подписант_ЗаполненныйПодписантДляУПД970(Документ, Сторона);
		
		Если ТипЗнч(ПротоСтруктура) = Тип("Структура") Тогда
			Signer = ОбъектXDTOВСтруктуру(Signer);
		КонецЕсли;
		
		ПротоСтруктура.Signers.Очистить();
		ПротоСтруктура.Signers.Добавить(Signer);
		
	ИначеЕсли Подписант_ИспользоватьДетальныеДанные(Документ.Тип.ТипКонтента) Тогда                
		
		ExtendedSigner = Подписант_СПолномочиями(Документ, Сторона);
		
		Если ТипЗнч(ПротоСтруктура) = Тип("Структура") Тогда
			ExtendedSigner = ОбъектXDTOВСтруктуру(ExtendedSigner);
		КонецЕсли;
		
		ПротоСтруктура.Signers.Очистить();
		ПротоСтруктура.Signers.Добавить(ExtendedSigner);	
		
	ИначеЕсли ЭтоФормализованныйАктСверки405(Документ.Тип.ТипКонтента) Тогда
		
		Signer_ReconciliationAct = Подписант_АктСверки(Документ);
		
		Если ТипЗнч(ПротоСтруктура) = Тип("Структура") Тогда
			Signer_ReconciliationAct = ОбъектXDTOВСтруктуру(Signer_ReconciliationAct);
		КонецЕсли;
		
		ПротоСтруктура.ReconciliationAct.Signer = Signer_ReconciliationAct;
		
	Иначе
		
		Signer = Подписант(Документ.Идентификаторы.BoxId);
		
		Если ТипЗнч(ПротоСтруктура) = Тип("Структура") Тогда
			Signer = ОбъектXDTOВСтруктуру(Signer);
		КонецЕсли;
		
		ПротоСтруктура.Signer = Signer;
		
	КонецЕсли;
	
КонецПроцедуры

// ПРЕДСТАВЛЕНИЕ ДОКУМЕНТА

Функция Документы_ПредставлениеДокумента(Документ, ВыводитьСумму = Ложь, ВыводитьСтатусы = Ложь) Экспорт
	
	Результат = Документ.ИмяФайла;
	
	Если Документ.Тип.ТипДокумента <> "Nonformalized" Тогда
		
		Если НЕ ЗначениеЗаполнено(Результат) ИЛИ Документ.Тип.Формализованный Тогда
			Результат = Документы_ПредставлениеДокументаИзРеквизитов(Документ);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВыводитьСумму Тогда
		Сумма = Документы_ПредставлениеДокумента_Сумма(Документ);
		Результат = Результат + Сумма;
	КонецЕсли;
	
	Если ВыводитьСтатусы Тогда
		Статусы = Документы_ПредставлениеДокумента_Статусы(Документ);
		Результат = Результат + Статусы;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПредставлениеДокументаИзРеквизитов(Документ)
	
	ТипДокумента		= Документ.Тип.ТипДокумента;
	ТипКонтента			= Документ.Тип.ТипКонтента;
	ФункцияДокумента	= Документ.Тип.ФункцияДокумента;
	
	ОписаниеТипаДокумента	= Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
	
	Результат = ОписаниеТипаДокумента.Title;
	
	Если НРег(ТипДокумента) <> НРег("Torg2") Тогда
		
		ФункцияXML	= Документы_ФункцияДокументаДляXML(ТипДокумента, ФункцияДокумента);
		
		Если ОписаниеТипаДокумента.FormatVersion = ТипКонтента_utd820() Тогда
			Результат = Результат + " (820)";
		КонецЕсли;

		Результат	= Результат + " " + ФункцияXML;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Документ.Метаданные)
		И Документ.СлужебнаяИнформация.Свойство("Контент") Тогда
		МетаданныеПротоСтруктуры = Документы_МетаданныеПротоСтруктуры(Документ);
	Иначе
		МетаданныеПротоСтруктуры = Документ.Метаданные;
	КонецЕсли;	
		
	НомерДокумента	= Документ.Реквизиты.Номер;
	ДатаДокумента	= Документ.Реквизиты.Дата;
	
	ЭтоИсправление			= Найти(Результат, "Исправление") > 0;
	НомерИсходногоДокумента	= СвойствоСтруктуры(МетаданныеПротоСтруктуры, "OriginalDocumentNumber",	"");
	ДатаИсходногоДокумента	= СвойствоСтруктуры(МетаданныеПротоСтруктуры, "OriginalDocumentDate",	"");
	ЭтоАктСверки405			= НРег(ОписаниеТипаДокумента.TypeNamedId) = НРег("ReconciliationAct")
							И НРег(ОписаниеТипаДокумента.Version) = НРег("reconciliationact405_05_01_01");
	
	Если ЭтоИсправление
		И ЗначениеЗаполнено(НомерИсходногоДокумента)
		И ЗначениеЗаполнено(ДатаИсходногоДокумента) Тогда
		
		Результат = СтрЗаменить(Результат, "Исправление", "Исправление" + Документы_ПредставлениеДокумента_НомерДата(НомерДокумента, ДатаДокумента));
		Результат = Результат + Документы_ПредставлениеДокумента_НомерДата(НомерИсходногоДокумента, ДатаИсходногоДокумента);
		
	ИначеЕсли ЭтоАктСверки405 Тогда
		
		Результат = Результат + Документы_ПредставлениеДокумента_Номер(НомерДокумента);
		
	Иначе
		
		Результат = Результат + Документы_ПредставлениеДокумента_НомерДата(НомерДокумента, ДатаДокумента);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПредставлениеДокумента_НомерДата(НомерДокумента, ДатаДокумента)
	
	Результат = "";
	
	Если ЗначениеЗаполнено(НомерДокумента)
		И ЗначениеЗаполнено(ДатаДокумента) Тогда
		
		Результат = " №" + Строка(НомерДокумента) + " от " + Формат(ДатаДокумента, "ДФ=dd.MM.yy");
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ПредставлениеДокумента_Сумма(Документ)
	
	Результат = "";
	
	СуммаДокумента = Документ.Реквизиты.Сумма;
	
	Если ЗначениеЗаполнено(СуммаДокумента) Тогда
		Результат = " на сумму " + Формат(СуммаДокумента, "ЧДЦ=2");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПредставлениеДокумента_Статусы(Документ)
	
	Результат = "";
	
	Статус		= Документ.Статусы.Статус;
	ДопСтатус	= Документ.Статусы.ДополнительныйСтатус;
	
	Если ЗначениеЗаполнено(Статус) Тогда
		Результат = " " + Статус;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДопСтатус) Тогда
		Результат = Результат + "; " + ДопСтатус;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПредставлениеДокумента_Валюта(Документ) Экспорт
	
	Результат = "";
	
	КодВалюты = Строка(Документ.Реквизиты.КодВалюты);
	
	Если ЗначениеЗаполнено(КодВалюты) Тогда
		Результат = Модуль_ГенерацияXML(ЭтотОбъект).НаименованиеВалюты(КодВалюты);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПредставлениеДокумента_Номер(НомерДокумента)
	
	Результат = "";
	
	Если ЗначениеЗаполнено(НомерДокумента) Тогда
		
		Результат = " №" + Строка(НомерДокумента);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ПЕЧАТНАЯ ФОРМА ДОКУМЕНТА

// Возвращает печатную форму электронного документа.
// Если печатная форма не переопределена в ПМ, то формируется стандартная печатная форма.
//
// Параметры:
//    Документ - Структура - описание электронного документа (см. Контракт_Документ())
//
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма электронного документа.
//  Неопределено - если печатная форма не определена в ПМ и документ неформализованный.
//
Функция Документы_ПечатнаяФорма(Документ) Экспорт  
	
	Результат = ПечатнаяФормаДокументаПМ(Документ);

	Если Результат = Неопределено И Документ.Тип.Формализованный
		И НРег(Документ.Тип.ТипДокумента) <> "torg2" Тогда
		
		Результат = ПечатнаяФормаФормализованного(Документ);

	КонецЕсли;

	Возврат Результат;
	
КонецФункции

// Получает печатную форму, переопределенную в подключаемом модуле.
// В случае некорректного переопределения печатной формы генерируется исключение.
//
// Параметры:
//    Документ - Структура - описание электронного документа (см. Контракт_Документ())
//
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма электронного документа.
//  Неопределено - если переопределение не выполнено.
//
Функция ПечатнаяФормаДокументаПМ(Документ)
	
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента");
	
	Если ХранилищеКонтента <> Неопределено Тогда
		
		Если ЭтоАдресИзВременногоХранилища(ХранилищеКонтента.Данные) Тогда
			ХранилищеКонтента.Данные = ПолучитьИзВременногоХранилища(ХранилищеКонтента.Данные);
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Документ", Документ);
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПечатнаяФормаДокумента", ПараметрыПМ);

	Если Результат <> Неопределено И ТипЗнч(Результат) <> Тип("ТабличныйДокумент") Тогда
		
		ТекстОшибки		 = "В подключаемом модуле некорректно сформирована печатная форма документа";
		ВидОперации		 = НСтр("ru = 'Формирование печатной формы'");
		ШаблонДопИнформации = НСтр("ru = 'Событие ""ПечатнаяФормаДокумента"" в подключаемом модуле должно было вернуть Неопределено или ТабличныйДокумент, а вернуло %1'");
		ДопИнформация	 = Общее_ПодставитьПараметрыВСтроку(ШаблонДопИнформации, Строка(ТипЗнч(Результат)));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Получает стандартную печатную форму электронного документа.
//
// Параметры:
//    Документ - Структура - описание электронного документа (см. Контракт_Документ())
//
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма электронного документа.
//
Функция ПечатнаяФормаФормализованного(Документ)
	
	Попытка
		
		Если ЗначениеЗаполнено(Документ.Идентификаторы.DocumentId) Тогда
			
			Действие = "СформироватьПечатнуюФормуЭлектронногоДокумента";
			Результат = Документы_ПечатнаяФормаПоДокументу(Документ);
			
		Иначе
			
			Действие = "СформироватьПечатнуюФормуПрото";
			Результат = Документы_ПечатнаяФормаПоКонтенту(Документ);
			
		КонецЕсли;
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		ФорматОтправки = ФорматОтправкиПоТипуДокумента(Документ.Тип);
		СсылкаНаОбъект = Документ.ДокументУчета;
		Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
			ОбъектМетаданных = СсылкаНаОбъект.Метаданные();
		КонецЕсли;
		
		ШаблонОшибки =
		"Не удалось сформировать печатную форму (Тип=%1, Функция=%2, Версия=%3) по причине:
		|%4";
		
		ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ФорматОтправки.ИмяТипа,
			ФорматОтправки.ФункцияДокумента,
			ФорматОтправки.ВерсияФормата,
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ПечатныеФормы",
			УровеньЖурналаРегистрации.Ошибка,
			ОбъектМетаданных,
			СсылкаНаОбъект,
			ПодробнаяОшибка
		);
		
		ДопКонтекст = Новый Соответствие;
		ДополнитьПеременныеМетрики_ТипЭлектронногоДокумента(ДопКонтекст, ФорматОтправки);
		ДополнитьПеременныеМетрики_ИдентификаторыЭлектронногоДокумента(ДопКонтекст, Документ.Идентификаторы);
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияПечатныеФормы(),
			Действие,
			Ошибка,
			ДопКонтекст
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;

КонецФункции

Функция Документы_ПечатнаяФормаПоКонтенту(Документ) Экспорт
	
	ТипКонтента			= Документ.Тип.ТипКонтента;
	ТипДокумента		= Документ.Тип.ТипДокумента;
	ПротоКонтент		= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Новый Структура);
	
	Если ПротоКонтент.Свойство("FormatVersion") Тогда
		ПротоКонтент.FormatVersion = ТипКонтента;
	КонецЕсли;
	
	ФорматКонтента		= Списки_ОписаниеФорматаКонтента(ТипКонтента);
	XDTO_SellerContent	= ФорматКонтента.XDTO_SellerContent;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ПоказатьДопСведения", Истина);
		
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(Документ.Идентификаторы.BoxId);
	ДопПараметры.Вставить("ВыводитьНаименованиеТовараСКодами", СтрокаКонтекста.ДополнительныеФункции.ВыводитьНаименованиеТовараСКодами);

	ПараметрыГенерацииXMLПоУмолчанию	 = Контракт_ПараметрыГенерацииXML();
	ПараметрыГенерацииXML				 = СвойствоСтруктуры(Документ.СлужебнаяИнформация	, "ПараметрыГенерацииXML"	, ПараметрыГенерацииXMLПоУмолчанию);
	ТочностьКоличества					 = СвойствоСтруктуры(ПараметрыГенерацииXML			, "ТочностьКоличества"		, ПараметрыГенерацииXMLПоУмолчанию.ТочностьКоличества);
	ТочностьЦены						 = СвойствоСтруктуры(ПараметрыГенерацииXML			, "ТочностьЦены"			, ПараметрыГенерацииXMLПоУмолчанию.ТочностьЦены);
	
	ДопПараметры.Вставить("ТочностьКоличества"	, ТочностьКоличества);
	ДопПараметры.Вставить("ТочностьЦены"		, ТочностьЦены);
	
	Результат = ПечатнаяФормаПротоКонтента(ПротоКонтент, XDTO_SellerContent, ТипДокумента, ДопПараметры);
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ПечатнаяФормаПоДокументу(Документ) Экспорт
	
	ДопПараметры = Новый Структура;
		
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
	
	Если ХранилищеКонтента = Неопределено Тогда
		ХранилищеКонтента = ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, "ХранилищеКонтента");
	КонецЕсли;
	
	ТребуетсяРасшифровка = ХранилищеКонтента.ТребуетсяРасшифровка;
	
	Если ТребуетсяРасшифровка Тогда
		ДопПараметры.Вставить("ДокументЗашифрован", Истина);
	Иначе
		
		ПротоКонтент = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Новый Структура);
		
		Если НЕ ЗначениеЗаполнено(ПротоКонтент) И Документ.Тип.Формализованный Тогда
			
			Если ЭтоАдресВременногоХранилища(ХранилищеКонтента.Данные) Тогда
				Данные = ПолучитьИзВременногоХранилища(ХранилищеКонтента.Данные);
			Иначе
				Данные = ХранилищеКонтента.Данные;
			КонецЕсли;
			
			ПротоКонтент = ГенерацияXML_XML_В_ProtoСтруктура(Данные);
			
		КонецЕсли;
		
		ТипКонтента			= Документ.Тип.ТипКонтента;
		ТипДокумента		= Документ.Тип.ТипДокумента;
		ФорматКонтента		= Списки_ОписаниеФорматаКонтента(ТипКонтента);
		XDTO_SellerContent	= ФорматКонтента.XDTO_SellerContent;
		
		ТитулПокупателя = СвойствоСтруктуры(Документ.Документооборот, "ТитулПокупателя", Неопределено);
		
		Если ТитулПокупателя = Неопределено Тогда
			ТитулПокупателя = ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, "ТитулПокупателя");
		КонецЕсли;
		
		Если ТитулПокупателя.Данные <> Неопределено Тогда
			
			ОбъектXDTO		= ГенерацияXML_XML_В_ОбъектXDTO(ТитулПокупателя.Данные);
			ТитулПокупателя	= ГенерацияXML_ОбъектXDTO_В_ProtoСтруктура(ОбъектXDTO);
			ДопПараметры.Вставить("ПротоКонтентОтвета", ТитулПокупателя);
			
		ИначеЕсли ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
			
			КонтентОтвета = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
			Если НЕ КонтентОтвета = Неопределено Тогда
				ДопПараметры.Вставить("ПротоКонтентОтвета", КонтентОтвета);
			КонецЕсли;
			
		КонецЕсли;
		
		ДопПараметры.Вставить("ПоказатьДопСведения", Истина);
		
		СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(Документ.Идентификаторы.BoxId);
    	ДопПараметры.Вставить("ВыводитьНаименованиеТовараСКодами", СтрокаКонтекста.ДополнительныеФункции.ВыводитьНаименованиеТовараСКодами);
		
		ПараметрыГенерацииXMLПоУмолчанию	 = Контракт_ПараметрыГенерацииXML();
		ПараметрыГенерацииXML				 = СвойствоСтруктуры(Документ.СлужебнаяИнформация	, "ПараметрыГенерацииXML"	, ПараметрыГенерацииXMLПоУмолчанию);
		ТочностьКоличества					 = СвойствоСтруктуры(ПараметрыГенерацииXML			, "ТочностьКоличества"		, ПараметрыГенерацииXMLПоУмолчанию.ТочностьКоличества);
		ТочностьЦены						 = СвойствоСтруктуры(ПараметрыГенерацииXML			, "ТочностьЦены"			, ПараметрыГенерацииXMLПоУмолчанию.ТочностьЦены);
		
		ДопПараметры.Вставить("ТочностьКоличества"	, ТочностьКоличества);
		ДопПараметры.Вставить("ТочностьЦены"		, ТочностьЦены);
		
	КонецЕсли;
	
	Результат = ПечатнаяФормаПротоКонтента(ПротоКонтент, XDTO_SellerContent, ТипДокумента, ДопПараметры);
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ПечатнаяФормаСервераДиадок(Идентификаторы) Экспорт
	
	BoxId		= Идентификаторы.BoxId;
	MessageId	= Идентификаторы.LetterId;
	DocumentId	= Идентификаторы.DocumentId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Счетчик = 0;
	
	Пока Счетчик < 10 Цикл
		
		Ответ = АПИ_GeneratePrintForm(ПараметрыСервиса, BoxId, MessageId, DocumentId);
		
		Если ЗначениеЗаполнено(Ответ.ВремяОжидания) Тогда
			
			МаксимальноеВремяОжидания = 1800;
			
			Если Ответ.ВремяОжидания > МаксимальноеВремяОжидания Тогда
				
				ШаблонОшибки = НСтр(
					"ru='Превышено максимальное время ожидания генерации печатной формы документа: %1
					|BoxId: %2
					|MessageId: %3
					|DocumentId: %4'"
				);
				
				ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
					ШаблонОшибки,
					Ответ.ВремяОжидания,
					BoxId,
					MessageId,
					DocumentId
				);
				
				ВызватьИсключение ТекстОшибки;
				
			КонецЕсли;
			
			Таймаут(Ответ.ВремяОжидания);
			Счетчик = Счетчик + 1;
			
		Иначе
			
			Результат = Ответ.ДвоичныеДанныеФайла;
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

Функция Документы_СгенерироватьПечатнуюФормуДиадок(Идентификаторы) Экспорт
	
	BoxId = Идентификаторы.BoxId;
	LetterId = Идентификаторы.LetterId;
	DocumentId = Идентификаторы.DocumentId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Результат = АПИ_GeneratePrintForm(
			ПараметрыСервиса,
			BoxId,
			LetterId,
			DocumentId);
	
	Возврат Результат;
	
КонецФункции

// Возвращает печатную форму ошибок формирования печатной формы.
//
// Параметры:
//    ПредставлениеДокумента - Строка - Представление документа п окоторому формировалась печатная форма
//    ТекстОшибки - Строка - описание ошибки возвращаемой сервером
//
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма.
//
Функция Документы_ПечатнаяФормаОшибкиФормирования(ПредставлениеДокумента, ТекстОшибки) Экспорт
	
	Модуль_ПечатныеФормы = Модуль_ПечатныеФормы(ЭтотОбъект);
	
	Результат = Модуль_ПечатныеФормы.ПечатнаяФорма_ОшибкиФормирования(ПредставлениеДокумента, ТекстОшибки);
	
	Возврат Результат;
	
КонецФункции

// ДОП СВОЙСТВА ДОКУМЕНТА

Функция Документы_ПолучитьДополнительныеСведенияПротоКонтента(ПротоКонтент, ТипКонтента) Экспорт
	
	Если ТипКонтента = ТипКонтента_invoiceoffer29()
		Или ТипКонтента = ТипКонтента_proformainvoice29() Тогда
		
		AdditionalInfoId = Неопределено;
		Если ЗначениеЗаполнено(ПротоКонтент.AdditionalInfoId) Тогда
			AdditionalInfoId = ПротоКонтент.AdditionalInfoId[0];
		КонецЕсли;
		
	Иначе
		
		AdditionalInfoId = СвойствоСтруктуры(ПротоКонтент, "AdditionalInfoId");
		
	КонецЕсли;
	
	Результат = СвойствоСтруктуры(AdditionalInfoId, "StructedAdditionalInfos");
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ЗаполнитьДополнительныеСведенияПротоКонтента(ПротоКонтент, ДопСведения, ТипКонтента) Экспорт
	
	Если ТипКонтента = ТипКонтента_invoiceoffer29()
		Или ТипКонтента = ТипКонтента_proformainvoice29() Тогда
		
		Если ЗначениеЗаполнено(ПротоКонтент.AdditionalInfoId) Тогда
			AdditionalInfoItem = ПротоКонтент.AdditionalInfoId[0];
		Иначе
			AdditionalInfoItem = Новый Структура("StructedAdditionalInfos");
			ПротоКонтент.AdditionalInfoId.Добавить(AdditionalInfoItem);
		КонецЕсли;
		
		AdditionalInfoItem.StructedAdditionalInfos = ДопСведения;
		
	Иначе
		
		AdditionalInfoId = СвойствоСтруктуры(ПротоКонтент, "AdditionalInfoId");
		Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(AdditionalInfoId, "StructedAdditionalInfos") Тогда
			AdditionalInfoId.StructedAdditionalInfos = ДопСведения;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает дополнительное свойство шапки документа из AdditionalInfo, AdditionalInfoId или StructedAdditionalInfos
//
// Параметры:
//  ПротоКонтент	 - ОбъектXDTO	 - документ в прото структуре
//  Идентификатор	 - Строка		 - имя свойства, значение которого необходимо получить
// 
// Возвращаемое значение:
//  Строка - значение свойства
//  Неопределено - свойство не найдено
//
Функция Документы_ПолучитьДопСвойствоШапки(ПротоКонтент, Идентификатор) Экспорт 
	
	Результат = Неопределено;
	
	НРегИдентификатор = НРег(Идентификатор);
	
	StructedAdditionalInfos = Неопределено;
	
	Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(ПротоКонтент, "AdditionalInfo") Тогда
		
		Если ТипЗнч(ПротоКонтент.AdditionalInfo) = Тип("Строка") Тогда
			Результат = Документы_ПолучитьДопСвойствоШапки_СтарыйФормат(ПротоКонтент.AdditionalInfo, НРегИдентификатор);
		Иначе
			Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(ПротоКонтент.AdditionalInfo, "StructedAdditionalInfos") Тогда
				StructedAdditionalInfos = ПротоКонтент.AdditionalInfo.StructedAdditionalInfos;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(ПротоКонтент, "AdditionalInfoId")
		И ЕстьРеквизитИлиСвойствоОбъектаЛокальная(ПротоКонтент.AdditionalInfoId, "StructedAdditionalInfos") Тогда
		StructedAdditionalInfos = ПротоКонтент.AdditionalInfoId.StructedAdditionalInfos;
	КонецЕсли;
	
	Если ЕстьРеквизитИлиСвойствоОбъектаЛокальная(ПротоКонтент, "StructedAdditionalInfos") Тогда
		StructedAdditionalInfos = ПротоКонтент.StructedAdditionalInfos;
	КонецЕсли;
	
	Если Результат = Неопределено
		И StructedAdditionalInfos <> Неопределено Тогда
		
		Для Каждого ЭлементСписка Из StructedAdditionalInfos Цикл
			
			Если НРег(ЭлементСписка.Key) = НРегИдентификатор Тогда
				Результат = ЭлементСписка.Value;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПолучитьДопСвойствоШапки_СтарыйФормат(СтрокаДопИнфо, НаименованиеСвойства)
	
	Результат = Неопределено;
	
	ДопИнфо		= Врег(СтрокаДопИнфо);
	ИмяСвойства	= Врег(НаименованиеСвойства);
	
	Если Найти(ДопИнфо, ИмяСвойства) > 0 Тогда
		
		Результат = Прав(СтрокаДопИнфо, СтрДлина(СтрокаДопИнфо) - Найти(ДопИнфо, ИмяСвойства) - СтрДлина(НаименованиеСвойства) + 1);
		
		Если Лев(Результат, 1) = ":"
		 Или Лев(Результат, 1) = "=" Тогда
			Результат = Прав(Результат, СтрДлина(Результат) - 1);
		КонецЕсли;	
		
		Если Найти(Результат, ";") > 0 Тогда
			Результат = Лев(Результат, Найти(Результат, ";") - 1);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение дополнительного реквизита электронного документа
//
// Параметры:
//	Документ		- Структура	- электронный документ(см. метод "Контракт_Документ")
//	ИмяРеквизита	- Строка	- имя дополнительного реквизита
//
// Возвращаемое значение:
//  Строка - значение свойства
//  Неопределено - свойство не найдено
Функция Документы_ЗначениеДополнительногоРеквизита(Документ, ИмяРеквизита)
	
	ПустаяСтруктура = Новый Структура;
	
	ДополнительныеРеквизиты = СвойствоСтруктуры(Документ, "ДопРеквизиты", ПустаяСтруктура);
	
	Результат = СвойствоСтруктуры(ДополнительныеРеквизиты, ИмяРеквизита);
	
	Если Результат = Неопределено Тогда
		
		// если структура ДопРеквизиты не заполнена - поищем в самом ДокументеЭДО
		
		Идентификаторы = СвойствоСтруктуры(Документ, "Идентификаторы", ПустаяСтруктура);
		
		ДокументЭДО = СвойствоСтруктуры(Идентификаторы, ДокументЭДО);
		
		Если ДокументЭДО <> Неопределено Тогда
			
			СтруктураПоиска = Новый Структура("ИмяРеквизита", ИмяРеквизита);
			
			СтрокиТЧ = ДокументЭДО.ДополнительныеРеквизиты.НайтиСтроки(СтруктураПоиска);
			
			Если СтрокиТЧ.Количество() > 0 Тогда
			
				Результат = СокрЛП(СтрокиТЧ[0].Значение);
			
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ВАЛИДАЦИЯ ДОКУМЕНТА

// Контракт структурированного описания ошибки валидации электроннного документа.
// 
// Возвращаемое значение:
//  Структура:
//    * ТекстОшибки - Строка - шаблон текста ошибки.
//    * Обрамление - Строка - список HTML-тегов через запятую.
//    * СсылкаДляИсправления - Строка, ЛюбаяСсылка - адрес гиперссылки.
//
Функция Контракт_ОшибкаВалидацииДокумента()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ТекстОшибки");
	Результат.Вставить("Обрамление");
	Результат.Вставить("СсылкаДляИсправления");
	
	Возврат Результат;
	
КонецФункции

// Конструктор ошибки валидации электронного документа.
//
// Параметры:
//  Текст - Строка - шаблон текста ошибки.
//  АдресСсылки - Строка, ЛюбаяСсылка - адрес гиперссылки.
//  Теги - Строка - (Необязательный) список HTML-тегов через запятую.
// 
// Возвращаемое значение:
//  Контракт_ОшибкаВалидацииДокумента.
//
Функция Новый_ОшибкаВалидацииДокумента(Текст, АдресСсылки = "", Теги = "")
	
	Результат = Контракт_ОшибкаВалидацииДокумента();
	Результат.ТекстОшибки = Текст;
	Результат.СсылкаДляИсправления = АдресСсылки;
	Результат.Обрамление = Теги;
	
	Возврат Результат;
	
КонецФункции

// Валидирует протоконтент.
//
// Параметры:
//  ПротоКонтент - ОбъектXDTO - контент формализованного документа.
//  ТипПротоКонтента - Строка - идентификатор типа протоструктуры (см. proto.xsd)
//  ТипКонтента - Строка - (Необязательный) идентификатор базового формата (уточняет тип прото).
// 
// Возвращаемое значение:
//  Массив из Контракт_ОшибкаВалидацииДокумента - ошибки в заполнении электронного документа.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция Документы_ВалидацияКонтента(ПротоКонтент, ТипПротоКонтента, ТипКонтента = Неопределено) Экспорт
	
	Модуль_ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	
	Если ТипПротоКонтента = "Utd970SellerContent" Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияUTD970(ПротоКонтент);
		
	ИначеЕсли ТипПротоКонтента = "Utd820SellerContent" Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияUTD820(ПротоКонтент);
		
	ИначеЕсли ТипПротоКонтента = "UtdSellerContent" Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияUTD(ПротоКонтент);
		
	ИначеЕсли ТипПротоКонтента = "UcdSellerContent" Тогда
		
		Если НРег(ТипКонтента) = "ucd736" Тогда
			Результат = Модуль_ГенерацияXML.ВалидацияUCD736(ПротоКонтент);
		Иначе
			Результат = Модуль_ГенерацияXML.ВалидацияUCD(ПротоКонтент);
		КонецЕсли;
		
	ИначеЕсли ТипПротоКонтента = "ReconciliationActSenderTitle" Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияАктСверки405ИнформацияОтправителя(ПротоКонтент);
		
	ИначеЕсли ТипПротоКонтента = "ReconciliationActRecipientTitle" Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияАктСверки405ИнформацияПолучателя(ПротоКонтент);
		
	ИначеЕсли ТипПротоКонтента = ТипПротоКонтента_СчетФНС29() Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияСчетаФНС29(ПротоКонтент);
		
	Иначе
		
		Результат = Новый Массив;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Валидирует содержимое электронного документа. Сначала выполняются стандартные проверки,
// затем вызывается пользовательская диагностика ошибок.
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ
// 
// Возвращаемое значение:
//  Массив из Контракт_ОшибкаВалидацииДокумента - ошибки в заполнении электронного документа.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция Документы_ОшибкиВалидацииДокумента(Документ) Экспорт
	
	Результат = Новый Массив;
	
	ЭтоРедактируемыйШаблон = Документы_ЭтоРедактируемыйШаблон(Документ);
	
	Если ЭтоРедактируемыйШаблон Тогда
		Возврат Результат; // Редактируемые шаблоны не подлежат валидации
	КонецЕсли;
	
	ПротоКонтент = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Неопределено);
	
	Если Документ.СлужебнаяИнформация.Свойство("КонтентОтвета") Тогда
		ПротоКонтент = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	КонецЕсли;
	
	Если ПротоКонтент <> Неопределено Тогда
		
		ТипКонтента			= Документ.Тип.ТипКонтента;
		XDTO_SellerContent	= Списки_ОписаниеФорматаКонтента(ТипКонтента).XDTO_SellerContent;
		Результат			= Документы_ВалидацияКонтента(ПротоКонтент, XDTO_SellerContent, ТипКонтента);
		
		Документы_ДополнитьОшибкиВалидацииОшибкамиИзИнтеграционногоМодуля(Результат, ПротоКонтент);
		
		Документы_ДополнитьОшибкиВалидацииСтавкиНДС(Результат, ПротоКонтент, ТипКонтента);
		
	КонецЕсли;
	
	ОшибкиПМ = ПодключаемыйМодуль_ВалидацияДокумента(Документ);
	
	Для Каждого ОписаниеОшибкиПМ Из ОшибкиПМ Цикл
		
		ОшибкаВалидации = Новый_ОшибкаВалидацииДокумента(
			ОписаниеОшибкиПМ.Текст,
			ОписаниеОшибкиПМ.Ссылка
		);
		
		Если ОписаниеОшибкиПМ.ЭтоГруппа Тогда
			ОшибкаВалидации.Обрамление = "h3";
		КонецЕсли;
		
		Результат.Добавить(ОшибкаВалидации);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Валидирует содержимое ответного титула электронного документа. Сначала выполняются стандартные проверки,
// затем вызывается пользовательская диагностика ошибок.
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ
// 
// Возвращаемое значение:
//  Массив из Контракт_ОшибкаВалидацииДокумента - ошибки в заполнении электронного документа.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция Документы_ОшибкиВалидацииОтветногоТитула(Документ) Экспорт
	
	Результат = Новый Массив;
	
	ПротоКонтент = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентОтвета", Неопределено);
	
	Если ПротоКонтент <> Неопределено Тогда
		
		ТипКонтента = Документ.Тип.ТипКонтента;
		XDTO_AcceptanceContent = Списки_ОписаниеФорматаКонтента(ТипКонтента).XDTO_AcceptanceContent;
		Результат = Документы_ВалидацияКонтента(ПротоКонтент, XDTO_AcceptanceContent);
		
		Документы_ДополнитьОшибкиВалидацииОшибкамиИзИнтеграционногоМодуля(Результат, ПротоКонтент);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Дополним список ошибок валидации контента ЭД описанием ошибок, возникших при сборе контента
// средствами библиотек "КонтурДиадокСтандартОФ", "КонтурДиадокСтандартУФ" или интеграционным модулем
//
// Параметры:
//  КоллекцияОшибок - Массив - см. тело метода "Документы_ОшибкиВалидацииДокумента" 
//  ПротоКонтент	- Структура - протоконтент ЭД
//
Процедура Документы_ДополнитьОшибкиВалидацииОшибкамиИзИнтеграционногоМодуля(КоллекцияОшибок, ПротоКонтент)
	
	ОшибкиВДанных = СвойствоСтруктуры(ПротоКонтент, "ОшибкиВДанных");

	Если ОшибкиВДанных = Неопределено Тогда
		СлужебнаяИнформация = СвойствоСтруктуры(ПротоКонтент, "СлужебнаяИнформация");
		ОшибкиВДанных = СвойствоСтруктуры(СлужебнаяИнформация, "ОшибкиВДанных");
	КонецЕсли;
	
	Если ОшибкиВДанных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ОписаниеОшибкиСтандарт Из ОшибкиВДанных Цикл
		
		ОшибкаВалидации = Контракт_ОшибкаВалидацииДокумента();
		ЗаполнитьЗначенияСвойств(ОшибкаВалидации, ОписаниеОшибкиСтандарт);
		
		Если Не ЗначениеЗаполнено(ОшибкаВалидации.Обрамление) Тогда
			ОшибкаВалидации.Обрамление = "h3";
		КонецЕсли;
		
		КоллекцияОшибок.Добавить(ОшибкаВалидации);
		
	КонецЦикла;
			
КонецПроцедуры

Процедура Документы_ДополнитьОшибкиВалидацииСтавкиНДС(КоллекцияОшибок, ПротоКонтент, ТипКонтента)
	
	Если НЕ ТребуетсяВалидацияСтавокНДС() Тогда
		Возврат;
	КонецЕсли;
	
	Модуль_ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	
	Если ТипКонтента = ТипКонтента_utd970() Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияСтавокНДС_UTD970(ПротоКонтент);
		
	ИначеЕсли ТипКонтента = ТипКонтента_ucd736() Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияСтавокНДС_UCD736(ПротоКонтент);
		
	ИначеЕсли ТипКонтента = ТипКонтента_proformainvoice29()
		ИЛИ ТипКонтента = ТипКонтента_invoiceoffer29() Тогда
		
		Результат = Модуль_ГенерацияXML.ВалидацияСтавокНДC_Invoice29(ПротоКонтент);
		
	Иначе
		
		Результат = Новый Массив;
		
	КонецЕсли;
	
	ДополнитьМассив(КоллекцияОшибок, Результат);
	
КонецПроцедуры

Функция ПодключаемыйМодуль_ВалидацияДокумента(Документ)
	
	Результат = Новый Массив;
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Документ", Документ);
	ПараметрыПМ.Вставить("Ошибки", Результат);
	
	ИмяСобытия = "ВалидацияДокумента";
	
	ПодключаемыйМодуль_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ОшибкиВалидации_HTML(СписокОшибок) Экспорт
	
	Перем Обрамление, СсылкаДляИсправления;
	
	HTMLШаблоны = Документы_ОшибкиВалидации_HTMLШаблоны();
	
	Результат = HTMLШаблоны.Начало;
	Результат = Результат + HTMLШаблоны.ТаблицаСтилей;
	Результат = Результат + HTMLШаблоны.НачалоТела;
	Результат = Результат + HTMLШаблоны.Шапка;
	Результат = Результат + HTMLШаблоны.НачалоСписка;
	
	ТекстОшибки		= "";
	СтрокаЗамены	= "[ТекстОшибки]";
	
	Для Каждого ОписаниеОшибки Из СписокОшибок Цикл
		
		ОписаниеОшибки.Свойство("Обрамление", Обрамление);
		
		Если Обрамление = "h3" 
			И ТекстОшибки <> "" Тогда
				
			НоваяСтрока	= СтрЗаменить(HTMLШаблоны.СтрокаОшибки, СтрокаЗамены, ТекстОшибки);
			Результат	= Результат + НоваяСтрока;
			ТекстОшибки	= "";
				
		КонецЕсли;
		
		ПредставлениеОшибки = ОписаниеОшибки.ТекстОшибки;
		
		ОписаниеОшибки.Свойство("СсылкаДляИсправления", СсылкаДляИсправления);
		
		Если ЗначениеЗаполнено(СсылкаДляИсправления) Тогда
			ПредставлениеОшибки = HTML_ПодставитьГиперссылкуВОшибкуВалидации(ПредставлениеОшибки, СсылкаДляИсправления);
		КонецЕсли;
		
		Разделитель = "<br>";
		
		ПоследнийСимвол = Прав(ПредставлениеОшибки, 1);
		
		Если  ПоследнийСимвол <> ""
			И ПоследнийСимвол <> ":" Тогда
			Разделитель = "." + Разделитель;
		КонецЕсли;
		
		ТекстОшибки = ТекстОшибки + ПредставлениеОшибки + Разделитель;
		
	КонецЦикла;
	
	Если ТекстОшибки <> "" Тогда
		
		НоваяСтрока	= СтрЗаменить(HTMLШаблоны.СтрокаОшибки, СтрокаЗамены, ТекстОшибки);
		Результат	= Результат + НоваяСтрока;
		
	КонецЕсли;
	
	Результат = Результат + HTMLШаблоны.ОкончаниеСписка;
	Результат = Результат + HTMLШаблоны.Окончание;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ОшибкиВалидации_HTMLШаблоны() Экспорт
	
	Картинки				= БиблиотекаКартинок();
	КартинкаИсправитьОшибки	= Картинки.КартинкаИсправитьОшибкиБольшая_Base64;
	
	Начало			= "<html><head>";
	ТаблицаСтилей	= "
					|<style type=text/css>
					|	body {font-family: Arial; font-size: 16px; line-height: 19px; letter-spacing: 0px; text-align: left;}
					|	li {margin-bottom: 10px;}
					|</style>";
	НачалоТела		= "</head><body>";
	Шапка			= "<h3 class=head;><img class=support src=""data:image/png;base64," + КартинкаИсправитьОшибки + """ align=""texttop""><b> Исправьте ошибки</b></h3>";
	НачалоСписка	= "<ul>";
	СтрокаОшибки	= "<li margin-bottom: 10px;>[ТекстОшибки]</li>";
	ОкончаниеСписка	= "</ul>";
	Окончание		= "</body></html>";
	
	Результат = Новый Структура;
	Результат.Вставить("Начало"			, Начало);
	Результат.Вставить("ТаблицаСтилей"	, ТаблицаСтилей);
	Результат.Вставить("НачалоТела"		, НачалоТела);
	Результат.Вставить("Шапка"			, Шапка);
	Результат.Вставить("НачалоСписка"	, НачалоСписка);
	Результат.Вставить("СтрокаОшибки"	, СтрокаОшибки);
	Результат.Вставить("ОкончаниеСписка", ОкончаниеСписка);
	Результат.Вставить("Окончание"		, Окончание);
	
	Возврат Результат;
	
КонецФункции

Функция HTML_ПодставитьГиперссылкуВОшибкуВалидации(Текст, Ссылка)
	
	СодержимоеСсылки = Неопределено;
	
	ПозицияОткрывающейСкобки = Найти(Текст, "<");
	ПозицияЗакрывающейСкобки = Найти(Текст, ">");
	
	Если ПозицияОткрывающейСкобки > 0 И ПозицияЗакрывающейСкобки > 0
		И ПозицияОткрывающейСкобки < ПозицияЗакрывающейСкобки Тогда
		
		Если ТипЗнч(Ссылка) = Тип("Строка") Тогда
			СодержимоеСсылки = Ссылка;
		ИначеЕсли ЭтоСсылкаНаСправочникИлиДокумент(Ссылка) Тогда
			СодержимоеСсылки = ВРЕГ("" + Ссылка.Метаданные().ПолноеИмя() + ":" + Ссылка.УникальныйИдентификатор());
		КонецЕсли;
		
	КонецЕсли;
	
	Если СодержимоеСсылки = Неопределено Тогда
		ВызватьИсключение "Некорректный параметр метода: ПодставитьГиперссылкуВОшибкуВалидации";
	Иначе
	
		Результат = Лев(Текст, ПозицияОткрывающейСкобки - 1)
					+ "<a href="
					+ СодержимоеСсылки
					+ ">" + Сред(Текст, ПозицияОткрывающейСкобки + 1, ПозицияЗакрывающейСкобки - ПозицияОткрывающейСкобки - 1)
					+ "</a>"
					+ Сред(Текст, ПозицияЗакрывающейСкобки + 1);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Значение_В_ЗаписьXML(Значение, ЗаписьXML)

	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Структура") Или ТипЗначения = Тип("Соответствие") Тогда
		
		Для Каждого КлючИЗначение Из Значение Цикл
			
			ЗаписьXML.ЗаписатьНачалоЭлемента(КлючИЗначение.Ключ);
			
			Значение_В_ЗаписьXML(КлючИЗначение.Значение, ЗаписьXML);
			
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		
		Для Каждого ЭлементМассива Из Значение Цикл
			
			Значение_В_ЗаписьXML(ЭлементМассива, ЗаписьXML);
			
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		
		Если Лев(Значение, 1) = "<" Тогда
			ЗаписьXML.ЗаписатьСекциюCDATA(Значение);
		Иначе
			ЗаписьXML.ЗаписатьТекст(Значение);
		КонецЕсли;
		
	Иначе
		
		ЗаписьXML.ЗаписатьТекст(XMLСтрока(Значение));
		
	КонецЕсли;
	
КонецПроцедуры

Функция Логирование_СтруктураВXML(Структура) Экспорт
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Лог");
	
	Значение_В_ЗаписьXML(Структура, ЗаписьXML);
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции

Функция ЭтоСсылкаНаСправочникИлиДокумент(ПроверяемаяСсылка)
	
	Результат = Ложь;
	
	ТипПроверяемойСсылки = ТипЗнч(ПроверяемаяСсылка);
	
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипПроверяемойСсылки)
		ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипПроверяемойСсылки) Тогда
		
		Результат = Истина;
		
		Возврат Результат;
		
	КонецЕсли;
	
	ПлатформаПоддерживаетРасширения = НЕ РежимСовместимостиКонфигурацииНижеВерсии("8.3.6");
	ТипВсеСсылкиСРасширениями = НЕ РежимСовместимостиКонфигурацииНижеВерсии("8.3.20");
	
	Если ПлатформаПоддерживаетРасширения И НЕ ТипВсеСсылкиСРасширениями Тогда
		
		МетаданныеРасширений = МетаданныеРасширений();
		
		Для Каждого МетаданныеРасширения Из МетаданныеРасширений Цикл
			
			МетаданныеТипа = МетаданныеРасширения.НайтиПоТипу(ТипПроверяемойСсылки);
			
			Если МетаданныеТипа = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если МетаданныеРасширения.Справочники.Содержит(МетаданныеТипа)
				ИЛИ МетаданныеРасширения.Документы.Содержит(МетаданныеТипа) Тогда
				
				Результат = Истина;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция МетаданныеРасширений()
	
	КлючКэша = "МетаданныеРасширений";
	
	Результат = Кэш_Прочитать(КлючКэша);
	
	Если Результат = Неопределено Тогда
		
		Результат = Новый Массив;
		
		МассивРасширенийКонфигурации = Вычислить("РасширенияКонфигурации.Получить()");
		
		Для Каждого УстановленноеРасширение Из МассивРасширенийКонфигурации Цикл
			
			Если НЕ УстановленноеРасширение.Активно Тогда
				Продолжить;
			КонецЕсли;
			
			ДвоичныеДанныеРасширения = УстановленноеРасширение.ПолучитьДанные();
			
			Если НЕ ДвоичныеДанныеРасширения = Неопределено Тогда
				
				МетаданныеРасширения = Вычислить("Новый ОбъектМетаданныхКонфигурация(ДвоичныеДанныеРасширения)");
				
				Результат.Добавить(МетаданныеРасширения);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Кэш_Поместить(КлючКэша, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ПОЛУЧЕНИЕ ДОКУМЕНТОВ АПИ

// Возвращает заполненный контракт документа. Также заполняет ссылкой на документ учета 1С
//
// Параметры:
//  см. Документы_КонтрактДокумента()
// 
// Возвращаемое значение:
//  см. Документы_КонтрактДокумента()
//
Функция Документы_ДанныеДокументаАПИ(BoxID, ДокументAPI) Экспорт

	Результат = Документы_КонтрактПоДокументуАПИ(BoxID, ДокументAPI);
	
	Результат.ДокументУчета = ХранениеДанных_СопоставленныйДокументВ1С(Результат.Идентификаторы);
	
	Возврат Результат;
	
КонецФункции	

// Выполняет мэппинг полей контракта модуля и данных из API, а также дополняет данными информационной базы
//
// Параметры:
//  BoxID		 - Строка	 	- идентификатор ящика в виде GUID
//  ДокументAPI	 - Структура	- значения свойств документа из API (см. описание объекта Document в документации Диадок API)
//									https://diadoc-sdk.readthedocs.io/ru/final/proto/Document.html
// 
// Возвращаемое значение:
//  Структура - контракт документа (см. Контракт_Документ())
//
Функция Документы_КонтрактПоДокументуАПИ(BoxID, ДокументAPI) Экспорт
	
	Результат = Контракт_Документ();
	
	Идентификаторы	= Результат.Идентификаторы;
	
	Идентификаторы.BoxId		= BoxId;
	Идентификаторы.LetterId		= ДокументAPI.MessageId;
	Идентификаторы.DocumentId	= ДокументAPI.EntityId;
	
	Если ТипЗнч(ДокументAPI) = Тип("Структура") Тогда
		
		Направление			= ДокументAPI_НаправлениеДокумента(ДокументAPI);
		СтруктураДатаНомер	= ДокументAPI_ДатаНомерДокумента(ДокументAPI);
		СтруктураСуммы		= ДокументAPI_СуммыДокумента(ДокументAPI);
		
		ДатаЭДО = СвойствоСтруктуры(ДокументAPI, "SendTimestampTicks");
		Если ДатаЭДО = Неопределено
			ИЛИ ДатаЭДО = 0 Тогда
			ДатаЭДО = ДокументAPI.CreationTimestampTicks;
		КонецЕсли;
		
		Результат.Направление	= Направление;
		Результат.ДатаЭДО		= Ticks_2_Date(ДатаЭДО);
		
		НеразрывныйПробел = "&#160;";
		Результат.ИмяФайла = СтрЗаменить(ДокументAPI.Title, НеразрывныйПробел, Символы.НПП);
		
		Если ДокументAPI.Свойство("PacketIsLocked") Тогда
			Результат.Заблокирован = ДокументAPI.PacketIsLocked;
		КонецЕсли;
		
		СтруктураРеквизитов = Результат.Реквизиты;
		
		СтруктураРеквизитов.Дата				= СтруктураДатаНомер.ДатаДокумента;
		СтруктураРеквизитов.Номер				= СтруктураДатаНомер.НомерДокумента;
		СтруктураРеквизитов.Сумма				= СтруктураСуммы.СуммаДокумента;
		СтруктураРеквизитов.СуммаНДС			= СтруктураСуммы.СуммаНДС;
		СтруктураРеквизитов.КодВалюты 			= СтруктураСуммы.Валюта;
		
		СтруктураТипа = Результат.Тип;
		
		СтруктураТипа.ТипДокумента				= ДокументAPI.TypeNamedId;
		СтруктураТипа.ТипКонтента				= ДокументAPI_ТипКонтентаДокумента(ДокументAPI);
		СтруктураТипа.ФункцияДокумента			= Документы_ФункцияДокументаДляХранения(ДокументAPI.Function);
		СтруктураТипа.Представление				= СтруктураТипа.ТипДокумента;
		СтруктураТипа.Формализованный			= Списки_ОписаниеФорматаКонтента(СтруктураТипа.ТипКонтента).Формализованный;
		СтруктураТипа.WorkflowId				= ДокументAPI.WorkflowId;
		
		СтруктураОтправителя	= Результат.Отправитель;
		СтруктураПолучателя		= Результат.Получатель;
		
		Если Направление = Перечисление_Направления().Внутреннее Тогда
			
			ИдентификаторОрганизации	= Новый_ИдентификаторыСправочника(, BoxId);
			Организации_Структура		= ХранениеДанных_УчастникДО_Организации(ИдентификаторОрганизации);
			
			ЗаполнитьЗначенияСвойств(СтруктураОтправителя, Организации_Структура);
			ЗаполнитьЗначенияСвойств(СтруктураПолучателя, Организации_Структура);
			
		Иначе
			
			CounteragentBoxId = ДокументAPI.CounteragentBoxId;
			СтруктураУчастниковЭДО	= ДокументAPI_СтруктураОтправителяПолучателя(Направление, BoxId, CounteragentBoxId);
			ЗаполнитьЗначенияСвойств(СтруктураОтправителя	, СвойствоСтруктуры(СтруктураУчастниковЭДО, "Отправитель"));
			ЗаполнитьЗначенияСвойств(СтруктураПолучателя	, СвойствоСтруктуры(СтруктураУчастниковЭДО, "Получатель"));
			
		КонецЕсли;
		
		Если Направление = Перечисление_Направления().Исходящее Тогда
			СтруктураОтправителя.DepartmentId	= ДокументAPI.DepartmentId;
			СтруктураПолучателя.DepartmentId	= ДокументAPI.ToDepartmentId;
		Иначе
			СтруктураОтправителя.DepartmentId	= ДокументAPI.FromDepartmentId;
			СтруктураПолучателя.DepartmentId	= ДокументAPI.DepartmentId;
		КонецЕсли;
		
		СтруктураСвязи = Результат.Связи;
		
		СтруктураСвязи.InitialDocumentIds 		= ДокументAPI.InitialDocumentIds;
		СтруктураСвязи.SubordinateDocumentIds 	= ДокументAPI.SubordinateDocumentIds;
		
		PacketId			= СвойствоСтруктуры(ДокументAPI,	"PacketId");
		CustomDocumentId	= СвойствоСтруктуры(ДокументAPI,	"CustomDocumentId");
		EditingSettingId	= СвойствоСтруктуры(ДокументAPI,	"EditingSettingId");
		LockMode			= СвойствоСтруктуры(ДокументAPI,	"LockMode");
		IsEncryptedContent	= СвойствоСтруктуры(ДокументAPI,	"IsEncryptedContent");
		Origin				= СвойствоСтруктуры(ДокументAPI,	"Origin");
		OriginMessageId		= СвойствоСтруктуры(Origin,	  		"MessageId");
		
		Если ЗначениеЗаполнено(PacketId) Тогда
			СтруктураСвязи.PacketId = PacketId;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(CustomDocumentId) Тогда
			СтруктураСвязи.CustomDocumentId = CustomDocumentId;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(OriginMessageId) Тогда
			СтруктураСвязи.OriginMessageId = OriginMessageId;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(EditingSettingId) Тогда
			Результат.ПараметрыШаблона.EditingSettingId = EditingSettingId;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(LockMode) И LockMode <> "None" Тогда
			Результат.ПараметрыШаблона.LockMode = LockMode;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(IsEncryptedContent) Тогда
			Результат.СлужебнаяИнформация.Вставить("ЗашифрованныйПакет", IsEncryptedContent);
		КонецЕсли;
		
		Для Каждого Элемент Из ДокументAPI.Metadata Цикл
			Ключ = Элемент.Key;
			Значение = _ЗаменитьНедопустимыеСимволыXML(Элемент.Value);
			Результат.Метаданные.Вставить(Ключ, Значение);
		КонецЦикла;
		
		СтатусыДО = ДокументAPI_СтатусыДО(ДокументAPI);
		
		СтруктураСтатусов = Результат.Статусы;
		
		СтруктураСтатусов.Статус = СтатусыДО.PrimaryStatus;
		СтруктураСтатусов.ДополнительныйСтатус = СтатусыДО.SecondaryStatus;
		
		Если ЗначениеЗаполнено(СтатусыДО.ResolutionTarget) Тогда
			СтруктураСтатусов.ОбъектМаршрутизации = ДокументAPI_ОбъектМаршрутизации(СтатусыДО.ResolutionTarget)
		КонецЕсли; 
		
		СтруктураСтатусов.ТребуетсяОбработка = ДокументAPI_ТребуетсяОбработкаДокумента(СтатусыДО);
		СтруктураСтатусов.ВнешниеСтатусы = ДокументAPI_ВнешнийСтатусДокумента(ДокументAPI.LastOuterDocflows, ДокументAPI.CustomData);
		СтруктураСтатусов.СтатусМЧД = СтатусыДО.StatusMCHD;
		СтруктураСтатусов.СтатусМЧДКритичность = СтатусыДО.StatusMCHDSeverity;
		
		СтатусПКФНС = ДокументAPI_СтатусПКФНС(ДокументAPI.LastOuterDocflows);
		
		СтруктураСтатусов.СтатусПКФНС = СтатусПКФНС.Представление;
		СтруктураСтатусов.СтатусПКФНСКритичность = СтатусПКФНС.Тип;
		
		СтатусДТС = ДокументAPI_СтатусДТС(ДокументAPI.LastOuterDocflows);
		СтруктураСтатусов.СтатусДТС = СтатусДТС.Представление;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументAPI_СтатусыДО(ДокументAPI)
	
	Перем ConfirmationMetadata, RecipientReceiptMetadata, AmendmentRequestMetadata;
	Перем SenderReceiptMetadata;
	
	Результат = Новый_СтатусыДокументооборотаAPI();
	
	// 0. Статусы
	
	Лента_ЗаполнитьСтатусыДО(Результат, ДокументAPI.DocflowStatus);
	
	// 1. Титул отправителя
	
	ДокументAPI.Свойство("SenderSignatureStatus", Результат.SenderTitle);
	
	// 2. Ответное действие получателя
	
	ДокументAPI.Свойство("RecipientResponseStatus", Результат.RecipientResponse);
	
	// 3. Документооборт УПД
	
	// Извещение о получении Подтверждения оператора
	Если ДокументAPI.Свойство("ConfirmationMetadata", ConfirmationMetadata) Тогда
		ConfirmationMetadata.Свойство("ReceiptStatus", Результат.ConfirmationReceipt);
	КонецЕсли;
	
	Если ДокументAPI.Свойство("RecipientReceiptMetadata", RecipientReceiptMetadata) Тогда
		
		// Извещение о получении документа
		RecipientReceiptMetadata.Свойство("ReceiptStatus", Результат.RecipientReceipt);
		
		// Извещение о получении Подтверждения оператора
		Если RecipientReceiptMetadata.Свойство("ConfirmationMetadata", ConfirmationMetadata) Тогда
			ConfirmationMetadata.Свойство("ReceiptStatus", Результат.RecipientReceiptConfirmation);
		КонецЕсли;
		
	КонецЕсли;
	
	// Извещение о получении титула получателя
	Если ДокументAPI.Свойство("SenderReceiptMetadata", SenderReceiptMetadata) Тогда
		SenderReceiptMetadata.Свойство("ReceiptStatus", Результат.SenderReceipt);
	КонецЕсли;
		
	// 4. Уточнение
	
	Если ДокументAPI.Свойство("AmendmentRequestMetadata", AmendmentRequestMetadata) Тогда
		
		AmendmentRequestMetadata.Свойство("AmendmentFlags", Результат.Amendment);
		AmendmentRequestMetadata.Свойство("ReceiptStatus ", Результат.AmendmentReceipt);
		
	КонецЕсли;
	
	// 5. Аннулирование
	
	ДокументAPI.Свойство("RevocationStatus", Результат.Revocation);
	
	// 7. Статус доставки в роуминг
	
	ДокументAPI.Свойство("RoamingNotificationStatus", Результат.RoamingNotification);
	
	// 8. Статус согласования документа/аннулировании
	
	Если ДокументAPI.Свойство("ResolutionStatus") Тогда
		Результат.Resolution = ДокументAPI.ResolutionStatus.Type;
		
		// 9. Имя Пользователя или подразделения для согласования
		ДокументAPI.ResolutionStatus.Свойство("Target", Результат.ResolutionTarget)
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументAPI_ОбъектМаршрутизации(Target)
	
	Результат = Контракт_ОбъектМаршрутизации();
	
	Если Не ЗначениеЗаполнено(Target) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Наименование = Неопределено;
	Идентификатор = Неопределено;
	
	Если Target.Свойство("User", Наименование)
		И Target.Свойство("UserID", Идентификатор)
		И ЗначениеЗаполнено(Наименование) 
		И ЗначениеЗаполнено(Идентификатор) Тогда 
		
		Результат.Наименование = Наименование;
		Результат.Идентификатор = Идентификатор;
		
	ИначеЕсли Target.Свойство("Department", Наименование)
		И Target.Свойство("DepartmentID", Идентификатор)
		И ЗначениеЗаполнено(Наименование) 
		И ЗначениеЗаполнено(Идентификатор) Тогда
		
		Результат.Наименование = Наименование;
		Результат.Идентификатор = Идентификатор;
		
	Иначе
		
		Результат = Контракт_ОбъектМаршрутизации();
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция ДокументAPI_СтруктураОтправителяПолучателя(Направление, BoxId, CounteragentBoxId)
	
	Результат = Новый Структура;
	
	ИдентификаторОрганизации	= Новый_ИдентификаторыСправочника(, BoxId);
	ИдентификаторКонтрагента	= Новый_ИдентификаторыСправочника(, CounteragentBoxId);
	
	Организации_Структура		= ХранениеДанных_УчастникДО_Организации(ИдентификаторОрганизации);
	Контрагенты_Структура		= ХранениеДанных_УчастникДО_Контрагенты(ИдентификаторКонтрагента, ИдентификаторОрганизации);
	
	ОрганизацияЭДО = Организации_Структура.ОрганизацияЭДО;
	КонтрагентЭДО = Контрагенты_Структура.ОрганизацияЭДО;
	
	Если Не ЗначениеЗаполнено(КонтрагентЭДО)
		И ЗначениеЗаполнено(ОрганизацияЭДО) Тогда
		
		Контрагент	= Контрагенты_РеквизитыКонтрагента_АПИ(CounteragentBoxId);
		Организация = Организации_ЗаполненныеРеквизиты(ИдентификаторОрганизации);
		
		ХранениеДанных_ЗаписатьКонтрагента(Контрагент);
		
		Контрагенты_Структура = ХранениеДанных_УчастникДО_Контрагенты(ИдентификаторКонтрагента, ИдентификаторОрганизации);
		
	КонецЕсли;
	
	Отправитель	= ?(Направление = Перечисление_Направления().Исходящее, Организации_Структура, Контрагенты_Структура);
	Получатель	= ?(Направление = Перечисление_Направления().Исходящее, Контрагенты_Структура, Организации_Структура);
	
	Результат.Вставить("Отправитель", Отправитель);
	Результат.Вставить("Получатель"	, Получатель);
	
	Возврат Результат;
	
КонецФункции	

Функция ДокументAPI_НаправлениеДокумента(Document)
	
	DocumentDirection = Document.DocumentDirection;
	Направления = Перечисление_Направления();
	Результат = "Неизвестное";
	
	Если DocumentDirection = "Inbound" Тогда
		Результат	= Направления.Входящее;
	ИначеЕсли DocumentDirection = "Outbound" Тогда
		Результат	= Направления.Исходящее;
	ИначеЕсли DocumentDirection = "Internal" Тогда
		Результат	= Направления.Внутреннее;
	КонецЕсли;	

	Возврат Результат;
	
КонецФункции // НаправлениеДокумента()

Функция ДокументAPI_ТипКонтентаДокумента(Document)

	ТипКонтента = Неопределено;
	
	Если Document.Свойство("Version") Тогда
		ТипКонтента = Document.Version;
	ИначеЕсли Document.Свойство("AttachmentVersion") Тогда
		ТипКонтента = Document.AttachmentVersion;
	КонецЕсли;
	
	Результат = Документы_БазовыйТипКонтентаДокумента(ТипКонтента, Document.TypeNamedId);
	
	Возврат Результат;

КонецФункции // ТипКонтентаДокумента()

Функция ДокументAPI_ДатаНомерДокумента(Document)

	Перем DocumentDate;
	
	Результат = Новый Структура("ДатаДокумента, НомерДокумента");
	
	Document.Свойство("DocumentDate", DocumentDate); // DD.MM.YYYY
	
	Если ЗначениеЗаполнено(DocumentDate) Тогда
		Результат.ДатаДокумента = Дата(Сред(DocumentDate, 7, 4) + Сред(DocumentDate, 4, 2) + Сред(DocumentDate, 1, 2));
	КонецЕсли;
	
	Document.Свойство("DocumentNumber", Результат.НомерДокумента);
	
	Возврат Результат;

КонецФункции

Функция ДокументAPI_СуммыДокумента(Document)

	Результат = Новый Структура;
	Результат.Вставить("СуммаДокумента"	, Неопределено);
	Результат.Вставить("СуммаНДС"		, Неопределено);
	Результат.Вставить("Валюта"			, Неопределено);
	
	СуммаДокумента = 0;
	СуммаНДС = 0;
	
	Для Каждого MetadataItem Из Document.Metadata Цикл
		
		Если MetadataItem.Key = "TotalSum" Тогда
			СуммаДокумента = ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "ContractPrice" Тогда
			СуммаДокумента = ЧислоИзСтрокиЛок(MetadataItem.Value);	
		ИначеЕсли MetadataItem.Key = "CorrectionTotalInc" Тогда
			СуммаДокумента = СуммаДокумента + ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "CorrectionTotalDec" Тогда
			СуммаДокумента = СуммаДокумента - ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "TotalVat" Тогда
			СуммаНДС = ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "CorrectionVatInc" Тогда
			СуммаНДС = СуммаНДС + ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "CorrectionVatDec" Тогда
			СуммаНДС = СуммаНДС - ЧислоИзСтрокиЛок(MetadataItem.Value);
		ИначеЕсли MetadataItem.Key = "CurrencyCode" Тогда
			Результат.Валюта = ЧислоИзСтрокиЛок(MetadataItem.Value);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СуммаДокумента) Тогда
		Результат.СуммаДокумента = СуммаДокумента;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СуммаНДС) Тогда
		Результат.СуммаНДС = СуммаНДС;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Возвращает список идентификаторов сущностей, с отбором по типу вложения и родительской сущности.
//
// Параметры:
//  Entities		 - Массив	- массив структур Message.Entities, который был получены методом GetMessage 
//  AttachmentType	 - Строка	- тип вложения искомой сущности - см. АПИ_Перечисление_AttachmentType
//  ParentEntityId	 - Строка	- идентификатор родительской сущности
// 
// Возвращаемое значение:
//   - Массив строковых идентификаторов найденных сущностей
//
Функция ДокументAPI_AttachmentEntityId(Entities, AttachmentType, ParentEntityId)
	
	Результат = Новый Массив;
	
	Для Каждого Entity Из Entities Цикл
		
		Если Entity.AttachmentType = AttachmentType И Entity.ParentEntityId = ParentEntityId Тогда
			
			Результат.Добавить(Entity.EntityId);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_БазовыйТипКонтентаДокумента(Знач ТипКонтента, ТипДокумента = Неопределено)
	
	// Возможно в ТипКонтента содержится AttachmentVersion, который сохранялся в ТипКонтента до редакции 3.0
	// При этом для 93, 172 форматов AttachmentVersion возвращался пустой, тогда получим тип формата по типу документа.
	
	Если НЕ ЗначениеЗаполнено(ТипКонтента) Тогда
		
		ТипКонтента = СокрЛП(ТипДокумента);
		
		// Для исправляющих документов берем основной тип.
		Если Прав(ТипКонтента, 8) = "Revision" Тогда
			ТипКонтента = Лев(ТипКонтента, СтрДлина(ТипКонтента) - 8);
		КонецЕсли;
		
	Иначе
		ТипКонтента = СокрЛП(ТипКонтента);
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТипКонтента) Тогда
		
		ОписаниеФормата = Списки_ОписаниеФорматаКонтента_AttachmentVersion(ТипКонтента);
		
		Если ОписаниеФормата <> Неопределено Тогда
			Результат = ОписаниеФормата.API_FormatVersion;
		Иначе
			// если через API получили AttachmentVersion в виде конкретных версий, например:  "utd_05_01_04" 
			Результат = ТипыДокументовAPI_ПриведенныйТипКонтента(ТипКонтента);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
	// TODO проверить все значения из http://api-docs.diadoc.ru/ru/latest/docflows/AttachmentVersion.html
	
КонецФункции

