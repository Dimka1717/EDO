Функция Документы_ФормироватьОтветныйТитул(Документ) Экспорт
	
	Результат = Ложь;
	
	BoxId			= Документ.Идентификаторы.BoxId;
	WorkflowId		= Документ.Тип.WorkflowId;
	Формализованный	= Документ.Тип.Формализованный;
	
	ОтсутствуетWorkflowId = (WorkflowId = 0);
	
	Если ОтсутствуетWorkflowId И Формализованный Тогда
		Результат = Истина;
	Иначе
		
		ОписаниеВидовДокументооборотаAPI = ПредопределенныеСписки_ОписаниеВидовДокументооборотаAPI(BoxId);
		
		ОписаниеДО = ОписаниеВидовДокументооборотаAPI.Получить(WorkflowId);
		
		Если ОписаниеДО <> Неопределено Тогда
			Результат = ОписаниеДО.ТитулПолучателя;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

