// Формирует описание формата электронного документа.
// Аналог структуры FullVersion (см. https://api-docs.diadoc.ru/ru/latest/proto/FullVersion.html).
//
// Параметры:
//  ИмяТипа - Строка - Идентификатор типа документа (TypeNamedId).
//  ФункцияДоумента - Строка - Идентификатор функции документа (Function).
//  ВерсияФормата - Строка - Идентификатор версии формата вложения (Version).
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. Контракт_ФорматЭлектронногоДокумента.
//
Функция Новый_ФорматЭлектронногоДокумента(Знач ИмяТипа, Знач ФункцияДокумента, Знач ВерсияФормата)
	
	Если Не ЗначениеЗаполнено(ФункцияДокумента) Тогда
		ФункцияДокумента = "default";
	КонецЕсли;
	
	Результат = Контракт_ФорматЭлектронногоДокумента();
	Результат.ИмяТипа = ИмяТипа;
	Результат.ФункцияДокумента = ФункцияДокумента;
	Результат.ВерсияФормата = ВерсияФормата;
	
	Возврат Новый ФиксированнаяСтруктура(Результат);
	
КонецФункции

