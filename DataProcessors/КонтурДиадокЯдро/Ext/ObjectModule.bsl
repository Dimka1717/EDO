// Признак того, что электронный документ(ЭД) это акт сверки, который был отправлен из сервиса Контур.Взаиморасчеты
//
// Параметры:
//	Документ	- Структура	- электронный документ(см. метод "Контракт_Документ")
//
// Возвращаемое значение:
// 	Булево - Истина, если ЭД это акт сверки, отправленный из сервиса Контур.Взаиморасчеты
Функция ЭтоАктСверкиИзСервисаВзаиморасчеты(Документ) Экспорт

	Результат = Ложь;
	
	Если ТипЗнч(Документ) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТипДокумента 	 = СвойствоСтруктуры(Документ.Тип, "ТипДокумента", "");
	CustomDocumentId = Документ.Связи.CustomDocumentId;
	
	Если ЭтоАктСверкиВзаиморасчетов(ТипДокумента)
		И ЕстьИдентификаторСервисаВзаиморасчеты(CustomDocumentId) Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

