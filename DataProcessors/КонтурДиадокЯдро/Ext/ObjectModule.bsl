// Проверяет наличие выставленных онлайн-счетов на портале СКБ Контура
// за использование сервиса Контур-Диадок.
//
// Возвращаемое значение:
//  Булево - Истина, если онлайн-счета выставлены.
//
Функция ОнлайнСчета_НаличиеСчетов() Экспорт
	
	Результат = Ложь;
	
	Возврат Результат; // Временно получение выставленных счетов отключено (Diadoc1c-2231)
	
	Попытка
		
		КонтекстСеанса = ХранилищеКонтекстаСеанса();
		
		Если ЗначениеЗаполнено(КонтекстСеанса) Тогда  
			
			Для Каждого КлючИЗначение Из КонтекстСеанса Цикл
				
				СтрокаКонтекста 		= КлючИЗначение.Значение; 
				BoxId					= СтрокаКонтекста.BoxId;
				ПараметрыСервиса_Контур = ПараметрыСервиса_Контур(BoxId); 
				ПараметрыСервиса_Диадок = ПараметрыСервиса_Диадок(BoxId);
				AccountID 				= АПИ_ИдентификаторЛицевогоСчетаДиадок(ПараметрыСервиса_Диадок, BoxId);
				
				Если Не ЗначениеЗаполнено(AccountID) Тогда
					Продолжить;
				КонецЕсли;
				
				Если ЕстьОнлайнСчетаНаОплату(ПараметрыСервиса_Контур, AccountId) Тогда 
					Результат = Истина;
					Прервать;
				КонецЕсли; 
				
			КонецЦикла;
			
		КонецЕсли; 
		
	Исключение
		
		ВидОперации		 = НСтр("ru = 'Проверка наличия онлайн-счетов Контур.Диадок'");
		ТекстСообщения	 = НСтр("ru = 'Не удалось проверить наличие счетов за использование сервиса Контур.Диадок'");
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции 

// Отвечает на вопрос о том есть ли не оплаченные счета сервиса
//
// Параметры:
//  AccountId			 - Строка - ИД Биллинг аккаунта - 
//  АвторизационныйТокен - Строка - Токен авторизации организации Диадок - 
// 
// Возвращаемое значение:
//   -  Булево - Ответ о присутствии счетов на оплату
Функция ЕстьОнлайнСчетаНаОплату(ПараметрыСервиса, AccountId) Экспорт
	Результат = Ложь;
	ПустойОтвет = "[]";
	
	ОтветСервиса = КонтурАПИ_GetPortalBills(ПараметрыСервиса, AccountId); 
	
	Если НЕ ОтветСервиса = ПустойОтвет Тогда
		Результат = Истина;
	КонецЕсли;

	Возврат Результат;
КонецФункции

