Функция КонтурПлагины_СчетВПакете_ДатаПерехода()
	
	ИмяКэша = "КонтурПлагины_СчетВПакете_ДатаПерехода";
	
	Результат = Кэш_Прочитать(ИмяКэша);
	
	Если Результат = Неопределено Тогда
		
		ИмяНастройкиДатыПерехода = КонтурПлагины_СчетВПакете_ИмяНастройкиДатыПерехода();
		ДатаПерехода = ХранениеДанных_ЗначениеДопРеквизита(Неопределено, ИмяНастройкиДатыПерехода);
		
		Если ТипЗнч(ДатаПерехода) = Тип("Дата") Тогда
			Результат = ДатаПерехода;
		Иначе
			Результат = Дата(1, 1, 1);
		КонецЕсли;
		
		Кэш_Поместить(ИмяКэша, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
