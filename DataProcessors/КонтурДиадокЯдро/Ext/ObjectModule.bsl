Функция ЛичныйКабинет_ОписаниеПредложения(ПредложениеДляПокупки)
	
	Результат = "";
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	ЭтоПодпискаНаМодуль = ПредложенияДляПокупки_ЭтоПодпискаНаМодуль(СценарийПредложения);
	ЭтоПакет = ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения);
	ЭтоМаршрут = ПредложенияДляПокупки_ЭтоПодпискаНаМаршрут(СценарийПредложения);
	ЭтоСертификат = ПредложенияДляПокупки_ЭтоПодпискаНаСертификат(СценарийПредложения);
	ЭтоКоннектор = ПредложенияДляПокупки_ЭтоПодпискаНаКоннекторы(СценарийПредложения);
	ЭтоAPI = ПредложенияДляПокупки_ЭтоПодпискаНаAPI(СценарийПредложения);
	
	Остаток = ПредложениеДляПокупки.ОстатокТрафика;
	ДатаОкончания = ПредложениеДляПокупки.ДатаОкончания;
	
	Если ЗначениеЗаполнено(ДатаОкончания)
		ИЛИ Остаток <> Неопределено Тогда
		
		Если ПредложениеДляПокупки.СрокДействияИстек
			ИЛИ Остаток = 0 Тогда
			
			Если ЭтоПакет ИЛИ ЭтоМаршрут ИЛИ ЭтоСертификат Тогда
				
				Результат = "Закончился";
				
			ИначеЕсли ЭтоКоннектор ИЛИ ЭтоAPI Тогда
				
				Результат = "Закончилась";
				
			Иначе
				Результат = "Подписка закончилась";
			КонецЕсли;
			
		Иначе
			
			Если ЭтоПакет И Остаток <> Неопределено Тогда
				
				Результат = ЛичныйКабинет_ОписаниеТекущегоПакета(Остаток);
				
			ИначеЕсли ЭтоПодпискаНаМодуль Тогда
				
				Результат = "Подписка заканчивается";
				
			Иначе
				Результат = "Заканчивается";
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ОписаниеТекущегоПакета(ОстатокПакета)
	
	Если НЕ ЗначениеЗаполнено(ОстатокПакета) Тогда
		Возврат "";
	КонецЕсли;
	
	ОсталосьПятьДокументов = 5;
	ОсталосьДваДокумента = 2;
	
	Если ОстатокПакета >= ОсталосьПятьДокументов Тогда
		
		ОкончаниеСловаОстался = "ось";
		ОкончаниеСловаДокумент = "ов";
		
	ИначеЕсли ОстатокПакета >= ОсталосьДваДокумента Тогда
		
		ОкончаниеСловаОстался = "ось";
		ОкончаниеСловаДокумент = "а";
		
	Иначе
		
		ОкончаниеСловаОстался = "ся";
		ОкончаниеСловаДокумент = "";
		
	КонецЕсли;
	
	// BSLLS:Typo-off
	Шаблон = "Остал%1 %2 документ%3";
	// BSLLS:Typo-on
	Результат = Общее_ПодставитьПараметрыВСтроку(Шаблон, ОкончаниеСловаОстался, ОстатокПакета, ОкончаниеСловаДокумент);

	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ОписаниеТекущегоМаршрута(Знач КоличествоРесурса)
	
	Если НЕ ЗначениеЗаполнено(КоличествоРесурса) Тогда
		КоличествоРесурса = "Безлимит";
	КонецЕсли;
	
	// BSLLS:Typo-off
	Шаблон = "Доступно маршрутов: %1";
	// BSLLS:Typo-on
	Результат = Общее_ПодставитьПараметрыВСтроку(Шаблон, КоличествоРесурса);

	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ДействиеПредложения(ПредложениеДляПокупки)
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	ЭтоПерваяПодписка = ПредложенияДляПокупки_ЭтоПерваяПодпискаНаМодуль(СценарийПредложения);
	ЭтоПромо = ПредложенияДляПокупки_ЭтоПодпискаНаПромоМодуля(СценарийПредложения);
	
	Если ЭтоПерваяПодписка ИЛИ ЭтоПромо Тогда
		
		Результат = "Получить доступ";
		
	Иначе
		
		ЭтоПакет = ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения);
		ЭтоПромоПакетов = ПредложенияДляПокупки_ЭтоПодпискаНаПромоПакетов(СценарийПредложения);
		ЭтоРекомендацияПакетов = ПредложенияДляПокупки_ЭтоРекомендацияПакетов(СценарийПредложения);
		ЭтоСертификат = ПредложенияДляПокупки_ЭтоПодпискаНаСертификат(СценарийПредложения);
		
		Если ЭтоПакет 
			И ПредложениеДляПокупки.ДатаОкончания = Неопределено
			И ПредложениеДляПокупки.ОстатокТрафика = Неопределено
			ИЛИ ЭтоПромоПакетов
			ИЛИ ЭтоРекомендацияПакетов Тогда
			
			Результат = "Выбрать тариф";
			
		ИначеЕсли ЭтоСертификат Тогда
			
			Результат = "Выпустить сертификат";
			
		Иначе
			
			Результат = "Выставить счет";
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ЭтоВажноеПредложение(ПредложениеДляПокупки)
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	ЭтоПодпискаНаПервыйПакет = ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения)
							И ПредложениеДляПокупки.ДатаОкончания = Неопределено
							И ПредложениеДляПокупки.ОстатокТрафика = Неопределено;
	
	ЭтоПодпискаНаПромоПакетов = ПредложенияДляПокупки_ЭтоПодпискаНаПромоПакетов(СценарийПредложения);
	
	Если ЭтоПодпискаНаПервыйПакет Тогда
		
		Результат = Ложь;
		
	ИначеЕсли ЭтоПодпискаНаПромоПакетов Тогда
		
		Результат = Ложь;
		
	Иначе
		
		ОснованиеПредложения = ПредложениеДляПокупки.ОснованиеПредложения;
		ОснованияПредложения = ПредложенияДляПокупки_ОснованияПредложения();
		
		Результат = (ОснованиеПредложения = ОснованияПредложения.PackageIsOut
				ИЛИ ОснованиеПредложения = ОснованияПредложения.PackagePeriodIsExpired
				ИЛИ ОснованиеПредложения = ОснованияПредложения.PackageAreExhausted
				ИЛИ ОснованиеПредложения = ОснованияПредложения.SubscriptionPeriodIsExpired);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЛичныйКабинет_СкорректироватьВажностьПредложенийПриНаличииПромо(ПредложенияДляПокупки)
	
	ЕстьПредложениеНаПромоМодуля = Ложь;
	
	Для Каждого ПредложениеДляПокупки Из ПредложенияДляПокупки Цикл
		
		Если ПредложениеДляПокупки.ЭтоПредложениеПромо Тогда
			ЕстьПредложениеНаПромоМодуля = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЕстьПредложениеНаПромоМодуля Тогда
		
		Для Каждого ПредложениеДляПокупки Из ПредложенияДляПокупки Цикл
			
			Если ПредложениеДляПокупки.ЭтоМодуль Тогда
				ПредложениеДляПокупки.ЭтоПредложениеВажное = Ложь;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЛичныйКабинет_ДанныеАктивныхПодписок(АктивныеПодпискиДляВсехЛицевыхСчетов)
	
	Результат = Новый Массив;
	
	Для Каждого КлючЗначение Из КонтекстСеанса_СтрокиКонтекста(Истина) Цикл
		
		BoxId = КлючЗначение.Значение.Ящик.Идентификатор;
		
		СтрокаКонтекста = КлючЗначение.Значение;
		НетАктивныхПодписокДляЯщика = Истина;
		
		АктивныеПодписки = АктивныеПодпискиДляВсехЛицевыхСчетов.Получить(BoxId);
		
		Если АктивныеПодписки <> Неопределено Тогда
			
			АктивныеПодписки = ЛичныйКабинет_СкорректированныеАктивныеПодпискиСУчетомМодификаторовМаршрутов(АктивныеПодписки);
			
			Для Каждого АктивнаяПодписка Из АктивныеПодписки Цикл
				
				ЛицевойСчет = АктивнаяПодписка.ЛицевойСчет;
				
				ДанныеАктивнойПодписки = ЛичныйКабинет_ДанныеДляАктивнойПодписки(АктивнаяПодписка, СтрокаКонтекста, ЛицевойСчет);
				Результат.Добавить(ДанныеАктивнойПодписки);
				НетАктивныхПодписокДляЯщика = Ложь;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если НетАктивныхПодписокДляЯщика Тогда
			
			ДанныеБезАктивнойПодписки = ЛичныйКабинет_ДанныеДляАктивнойПодписки(Неопределено, СтрокаКонтекста, Неопределено);
			Результат.Добавить(ДанныеБезАктивнойПодписки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_СкорректированныеАктивныеПодпискиСУчетомМодификаторовМаршрутов(АктивныеПодписки)
	
	Результат = Новый Массив;
	
	ИндексПодписок = Новый Соответствие;
	
	Для Каждого АктивнаяПодписка Из АктивныеПодписки Цикл
		ИндексПодписок.Вставить(АктивнаяПодписка.ИдентификаторПодписки, АктивнаяПодписка);
	КонецЦикла;
	
	Для Каждого АктивнаяПодписка Из АктивныеПодписки Цикл
		
		ЭтоМаршрут = АктивнаяПодписка.Идентификатор = КонтурШлюзАвторизации_ИмяСервисаМаршруты();
		ИдентификаторОсновнойПодписки = АктивнаяПодписка.ИдентификаторОсновнойПодписки;
		ЭтоМодификаторМаршрута = ЭтоМаршрут И ЗначениеЗаполнено(ИдентификаторОсновнойПодписки);
		
		Если НЕ ЭтоМодификаторМаршрута Тогда
			Результат.Добавить(АктивнаяПодписка);
			Продолжить;
		КонецЕсли;
		
		ОсновнаяПодписка = ИндексПодписок.Получить(ИдентификаторОсновнойПодписки);
		
		Если ОсновнаяПодписка <> Неопределено 
			И ЗначениеЗаполнено(ОсновнаяПодписка.Количество) Тогда
			
			Если ЗначениеЗаполнено(АктивнаяПодписка.Количество) Тогда
				ОсновнаяПодписка.Количество = ОсновнаяПодписка.Количество + АктивнаяПодписка.Количество;
			Иначе
				ОсновнаяПодписка.Количество = АктивнаяПодписка.Количество;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ДанныеДляАктивнойПодписки(АктивнаяПодписка, СтрокаКонтекста, ЛицевойСчет)
	   
	Результат = Новый_ДанныеЛичногоКабинета(СтрокаКонтекста, ЛицевойСчет);
	
	Если АктивнаяПодписка <> Неопределено Тогда
		
		Результат.Представление = ЛичныйКабинет_ПредставлениеАктивнойПодписки(АктивнаяПодписка);
		Результат.Описание = ЛичныйКабинет_ОписаниеАктивнойПодписки(АктивнаяПодписка);
		Результат.ДатаНачала = АктивнаяПодписка.ДатаНачала;
		Результат.ДатаОкончания = АктивнаяПодписка.ДатаОкончания;
		Результат.Количество = АктивнаяПодписка.Количество;
		Результат.Использовано = АктивнаяПодписка.Использовано;
		Результат.Действие = Неопределено;
		Результат.Ссылка = Неопределено;
		
		ИмяСервиса = АктивнаяПодписка.Идентификатор;
		
		Результат.ЭтоМодуль = КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(ИмяСервиса);
		Результат.ЭтоПакет = КонтурШлюзАвторизации_ЭтоПодпискаНаПакет(ИмяСервиса);
		Результат.ЭтоПлагин = КонтурШлюзАвторизации_ЭтоПодпискаНаПлагин(ИмяСервиса);
		
		Результат.ИсходныеДанные = АктивнаяПодписка;
		Результат.Приоритет = ЛичныйКабинет_ПриоритетАктивнойПодписки(Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ПредставлениеАктивнойПодписки(АктивнаяПодписка)
	
	ИмяСервиса = АктивнаяПодписка.Идентификатор;
	
	ЭтоПодпискаНаМодуль = КонтурШлюзАвторизации_ЭтоПодпискаНаМодуль(ИмяСервиса);
	ЭтоПодпискаНаПакет = КонтурШлюзАвторизации_ЭтоПодпискаНаПакет(ИмяСервиса);
    
	Если ЭтоПодпискаНаМодуль Тогда
		
		Результат = ЛичныйКабинет_ПредставлениеПодпискиНаМодуль();
	
	ИначеЕсли ЭтоПодпискаНаПакет Тогда
		
        Результат = ЛичныйКабинет_ПредставлениеАктивнойПодпискиНаПакет(АктивнаяПодписка);
	
	Иначе
		Результат = АктивнаяПодписка.Представление;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ПредставлениеАктивнойПодпискиНаПакет(АктивнаяПодписка)
	
	Результат = ЛичныйКабинет_ПредставлениеПодпискиНаПакет();
	
	ТекущееКоличество = АктивнаяПодписка.Количество;
	ИспользованноеКоличество = АктивнаяПодписка.Использовано;
	
	Если ТекущееКоличество <> Неопределено
		И ИспользованноеКоличество <> Неопределено Тогда
		
		ИзначальноеКоличество = ТекущееКоличество + ИспользованноеКоличество;
		Шаблон = "%1 исходящих документов";
		Результат = Общее_ПодставитьПараметрыВСтроку(Шаблон, ИзначальноеКоличество);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ОписаниеАктивнойПодписки(АктивнаяПодписка)
	
	Результат = "";
	
	ИмяСервиса = АктивнаяПодписка.Идентификатор;
	
	ПодпискаПокаНеДействует = (АктивнаяПодписка.ДатаНачала > ТекущаяДатаСеанса());
	
	Если ПодпискаПокаНеДействует Тогда
		
		Результат = "Активируется после предыдущего";
		
	Иначе
		
		ЭтоПодпискаНаПакет = КонтурШлюзАвторизации_ЭтоПодпискаНаПакет(ИмяСервиса);
		ЭтоПодпискаНаМаршрут = КонтурШлюзАвторизации_ЭтоПодпискаНаМаршрут(ИмяСервиса);
		
		Если ЭтоПодпискаНаПакет Тогда
			
			Результат = ЛичныйКабинет_ОписаниеТекущегоПакета(АктивнаяПодписка.Количество);
			
		ИначеЕсли ЭтоПодпискаНаМаршрут Тогда
			
			Результат = ЛичныйКабинет_ОписаниеТекущегоМаршрута(АктивнаяПодписка.Количество);
			
		Иначе
			Результат = "";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛичныйКабинет_ПриоритетАктивнойПодписки(ДанныеДляАктивнойПодписки)
	
	Если ДанныеДляАктивнойПодписки.ЭтоМодуль Тогда
		
		Результат = 1;
		
	ИначеЕсли ДанныеДляАктивнойПодписки.ЭтоПакет Тогда
		
		Результат = 2;
		
	ИначеЕсли ДанныеДляАктивнойПодписки.ЭтоПлагин Тогда
		
		Результат = 3;
		
	Иначе
		Результат = 4;
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Процедура ЛичныйКабинет_ВыполнитьРазметкуГруппировкиДанных(ДанныеПредложенийИПодписок)
	
	РазметкаНачалаГруппы = 1;
	РазметкаСерединыГруппы = 2;
	РазметкаОкончанияГруппы = 3;
	
	КлючТекущейГруппы = Неопределено;
	ИндексНачалаГруппы = Неопределено;
	ИндексКонцаГруппы = Неопределено;
	
	Для Индекс = 0 По ДанныеПредложенийИПодписок.ВГраница() Цикл
		
		ТекущиеДанные = ДанныеПредложенийИПодписок[Индекс]; 
		
		Если ТекущиеДанные.ЭтоПредложение Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТекущиеДанные.ЭтоПакет Тогда
			КлючТекущихДанных = ТекущиеДанные.BoxId;
		Иначе
			КлючТекущихДанных = ТекущиеДанные.BoxId + ТекущиеДанные.Представление;
		КонецЕсли;
		
		Если КлючТекущейГруппы <> КлючТекущихДанных Тогда
			
			Если ИндексНачалаГруппы <> ИндексКонцаГруппы Тогда
				
				ДанныеПредложенийИПодписок[ИндексНачалаГруппы].РазметкаГруппировки = РазметкаНачалаГруппы;
				ДанныеПредложенийИПодписок[ИндексКонцаГруппы].РазметкаГруппировки = РазметкаОкончанияГруппы;
				
			КонецЕсли;
			
			КлючТекущейГруппы = КлючТекущихДанных;
			
			ИндексНачалаГруппы = Индекс;
			ИндексКонцаГруппы = ИндексНачалаГруппы;
			
		Иначе
			
			ИндексКонцаГруппы = Индекс;
			ТекущиеДанные.РазметкаГруппировки = РазметкаСерединыГруппы;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ИндексНачалаГруппы <> ИндексКонцаГруппы Тогда
		
		ДанныеПредложенийИПодписок[ИндексНачалаГруппы].РазметкаГруппировки = РазметкаНачалаГруппы;
		ДанныеПредложенийИПодписок[ИндексКонцаГруппы].РазметкаГруппировки = РазметкаОкончанияГруппы;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЛичныйКабинет_ПроверитьДоступностьПлагинов(ЛицевыеСчета)
	
	Если ЭтоСборкаДляПровайдераСервиса() Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьПлагины() Тогда
		Возврат;
	КонецЕсли;
	
	ДоступныеСервисыПлагинов = Новый Массив;
	
	Для Каждого ДанныеЛицевогоСчета Из ЛицевыеСчета Цикл
		
		Для Каждого СервисПодписки Из ДанныеЛицевогоСчета.ДоступныеСервисы Цикл
			
			ЭтоПодпискаНаПлагин = КонтурШлюзАвторизации_ЭтоПодпискаНаПлагин(СервисПодписки.Идентификатор);
			
			Если ЭтоПодпискаНаПлагин Тогда
				ДоступныеСервисыПлагинов.Добавить(СервисПодписки.Идентификатор);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если ДоступныеСервисыПлагинов.Количество() > 0 Тогда
		
		ИмяНастройки = "ИспользоватьПлагины";		
		ОбщиеНастройки_Поместить(ИмяНастройки, Истина);
		ОбщийКонтекстКлиентСервер.ИспользоватьПлагины = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Метрика_ДобавитьОшибку_ПолучениеДанныхБиллинга(BoxId, ТекстОшибки)
	
	Категория = Метрика_НазваниеКатегории().ДоступныеСервисы;
	Действие = "ОшибкаПолученияДанныхБиллинга";
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID", BoxId);
	Переменные.Вставить("ТекстОшибки", ТекстОшибки);
	
	Метрика_ЗаписатьЛог(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьОшибку_ПолучениеПредложенийДляПокупки(ЛицевойСчет, ТекстОшибки, BoxId)
	
	Категория = Метрика_НазваниеКатегории().ОнлайнПродажи;
	Действие = "ОшибкаПолученияПредложенийДляПокупки";
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID", BoxId);
	Переменные.Вставить("ЛицевойСчет", ЛицевойСчет);
	Переменные.Вставить("ТекстОшибки", ТекстОшибки);
	
	Метрика_ЗаписатьЛог(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_СервисыПодписок(СтрокаКонтекста, ТребуетсяОплатаМодуля, ТребуетсяОплатаАПИ)
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	BoxId = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
	
	КатегорияДоступныеСервисы = Метрика_НазваниеКатегории().ДоступныеСервисы;
	
	Для Каждого ДанныеЛицевогоСчета Из СтрокаКонтекста.ЛицевыеСчета Цикл
		
		Для Каждого СервисПодписки Из ДанныеЛицевогоСчета.ДоступныеСервисы Цикл
			
			Действие = СервисПодписки.Представление;
			
			Переменные = Новый Соответствие;
			
			Переменные.Вставить("BoxID", BoxId);
			Переменные.Вставить("ЛицевойСчет", СервисПодписки.ЛицевойСчет);
			Переменные.Вставить("КодПродукта", СервисПодписки.КодПродукта);
			Переменные.Вставить("Идентификатор", СервисПодписки.Идентификатор);
			Переменные.Вставить("ОплатаПлательщиком", ДанныеЛицевогоСчета.ОплатаПлательщиком);
			
			Метрика_ЗаписатьСтатистику(КатегорияДоступныеСервисы, Действие, , Переменные);
			
		КонецЦикла;
		
	КонецЦикла;
	
	ЭтоРеальнаяОрганизация = Организации_ЭтоРеальнаяОрганизация(СтрокаКонтекста.Box.Organization);
	
	Если ЭтоРеальнаяОрганизация Тогда
		
		СервисПодпискиНаМодуль = СтрокаКонтекста.СервисПодпискиНаМодуль;
		
		КатегорияСервисПодпискиНаМодуль = Метрика_НазваниеКатегории().СервисПодпискиНаМодуль;
		Действие = СервисПодпискиНаМодуль.Представление;
	
		ПеременныеПодпискиНаМодуль = Новый Соответствие;
		
		ПеременныеПодпискиНаМодуль.Вставить("BoxID", BoxId);
		ПеременныеПодпискиНаМодуль.Вставить("ЛицевойСчет", СервисПодпискиНаМодуль.ЛицевойСчет);
		ПеременныеПодпискиНаМодуль.Вставить("КодПродукта", СервисПодпискиНаМодуль.КодПродукта);
		ПеременныеПодпискиНаМодуль.Вставить("Идентификатор", СервисПодпискиНаМодуль.Идентификатор);
		ПеременныеПодпискиНаМодуль.Вставить("ТребуетсяОплатаСервиса", СтрокаКонтекста.ТребуетсяОплатаСервиса);
		ПеременныеПодпискиНаМодуль.Вставить("ТребуетсяОплатаМодуля", ТребуетсяОплатаМодуля);
		ПеременныеПодпискиНаМодуль.Вставить("ТребуетсяОплатаАПИ", ТребуетсяОплатаАПИ);
		
		Метрика_ЗаписатьСтатистику(КатегорияСервисПодпискиНаМодуль, Действие, , ПеременныеПодпискиНаМодуль);
		
	КонецЕсли;
		
КонецПроцедуры

// Отправляет метрики по текущим предложениям для покупки по всем лицевым счетам
//
// Параметры:
//  ПредложенияДляВсехЛицевыхСчетов	 - Соответствие	 - коллекция предложений
//
Процедура Метрика_ДобавитьСтатистику_ПредложенияДляПокупки(ПредложенияДляВсехЛицевыхСчетов) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из КонтекстСеанса_СтрокиКонтекста(Истина) Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		
		BoxId = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		СервисПодпискиНаМодуль = Неопределено;
		
		Для Каждого ДанныеЛицевогоСчета Из СтрокаКонтекста.ЛицевыеСчета Цикл
			
			ЛицевойСчет = ДанныеЛицевогоСчета.ЛицевойСчет;
			ПредложенияДляПокупки = ПредложенияДляВсехЛицевыхСчетов.Получить(ЛицевойСчет);
			
			Если ПредложенияДляПокупки <> Неопределено Тогда
				
				Метрика_ДобавитьСтатистику_ПредложенияПоЛицевомуСчету(BoxId, ЛицевойСчет, ПредложенияДляПокупки);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_ПредложенияПоЛицевомуСчету(BoxId, ЛицевойСчет, ПредложенияДляПокупки)
	
	КатегорияМетрики = Метрика_НазваниеКатегории().ОнлайнПродажи;
	ДействиеМетрики	= "Доступные предложения";
	
	Для Каждого ПредложениеДляПокупки Из ПредложенияДляПокупки Цикл
		
		Переменные = Новый Соответствие;
		
		Переменные.Вставить("BoxId", BoxId);
		Переменные.Вставить("AccountId", ЛицевойСчет);
		Переменные.Вставить("ReasonForOffer", ПредложениеДляПокупки.ОснованиеПредложения);
		Переменные.Вставить("ScenarioId", ПредложениеДляПокупки.Сценарий);
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.Тип) Тогда
			Переменные.Вставить("Activity", ПредложениеДляПокупки.Тип);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.ПодпискаПродления) Тогда
			Переменные.Вставить("EntitytId", ПредложениеДляПокупки.ПодпискаПродления);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПредложениеДляПокупки.Тариф) Тогда
			Переменные.Вставить("TariffId", ПредложениеДляПокупки.Тариф);
		КонецЕсли;
		
		Метрика_ЗаписатьСтатистику(КатегорияМетрики, ДействиеМетрики, , Переменные);
		
	КонецЦикла;

КонецПроцедуры

