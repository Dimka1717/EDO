Функция Лента_ОбработатьНовыеСобытияДокументов(Организация, МаксКоличествоЦиклов = 1, DepartmentId = "") Экспорт
	
	BoxId = Организация.ID;
	AfterIndexKey = Организация.AfterIndexKey;
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(BoxId);
	
	Если СтрДлина(AfterIndexKey) = 8 Тогда //Дата ГГГГММДД
		Ticks = Date_2_Ticks(AfterIndexKey);
		AfterIndexKey = "";
	КонецЕсли;
	
	ПараметрыСервиса = Лента_ПараметрыСервиса(boxId);
	Если ПараметрыСервиса = Неопределено Тогда
		Возврат 0; // не знаем сколько событий
	КонецЕсли;
	
	ЗагружатьПоСопоставленнымКонтрагентам = ОбщиеНастройки_Прочитать("ЗагружатьДокументыПоСопоставленнымКонтрагентам");
	ЗагружатьДокументооборотЦеликом = ОбщиеНастройки_Прочитать("ЗагружатьДокументооборотЦеликом");
	
	КоличествоЦиклов = 0;
	
	Пока Истина Цикл
		
		#Если Клиент Тогда
		ОбработкаПрерыванияПользователя();
		#КонецЕсли
		
		ПорцияСобытий = Лента_СобытияЯщикаОрганизации(boxId, Ticks, , AfterIndexKey, DepartmentId);
		ТаблицаСобытий = Лента_ТаблицаСобытийДляОбработки(boxId, ПорцияСобытий.Events);
		ТаблицаСобытийСвернутая = Лента_СвернутьТаблицуСобытий(ТаблицаСобытий);
		НаличиеДанных1С = ХранениеДанных_НаличиеДанных1С(ТаблицаСобытийСвернутая);
		ЗаписыватьДанные = НаличиеДанных1С.Количество() > 0;
		
		КоличествоСобытий = ТаблицаСобытийСвернутая.Количество();
		Метрика_ДобавитьЗамер_ЧтениеЛентыСобытий(КоличествоСобытий, BoxId);
		
		Для Каждого ДанныеСобытия Из ТаблицаСобытийСвернутая Цикл
			
			LetterId = ДанныеСобытия.LetterId;
			DocumentId = ДанныеСобытия.DocumentId;
			
			Если НаличиеДанных1С.Количество() = 0 Тогда
				НетДокументаЭДО = Истина;
			Иначе
				Данные1С = НаличиеДанных1С[ДанныеСобытия.ID];
				НетДокументаЭДО = НЕ ЗначениеЗаполнено(Данные1С.ДокументЭДО);
			КонецЕсли;
			
			Если НЕ Лента_ТребуетсяОбработатьСобытие(Организация, ДанныеСобытия, НетДокументаЭДО) Тогда
				Продолжить;
			КонецЕсли;
			
			DocumentInfo = ДанныеСобытия.Event.Document.DocumentInfo;
			ЭтоДокумент = (DocumentInfo.MessageType = "Letter");
			ЭтоШаблон = (DocumentInfo.MessageType = "Template");
			ТребуетсяРасшифровка = (ЭтоДокумент И НетДокументаЭДО И DocumentInfo.LetterInfo.IsEncrypted);
			
			Если НетДокументаЭДО Тогда
				
				Если ЭтоШаблон Тогда
					// GetDocument пока не умеет работать с шаблонами
					Сообщение = АПИ_GetMessage(ПараметрыСервиса, BoxId, LetterId, DocumentId);
					ДокументAPI = Сообщение.Entities[0].DocumentInfo;
				Иначе
					
					ДокументAPI = АПИ_GetDocument(ПараметрыСервиса, BoxId, LetterId, DocumentId);
					
					Если СвойствоСтруктуры(ДокументAPI, "IsDeleted", Ложь) Тогда
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;
				
				Документ = Документы_ДанныеДокументаАПИ(ИдентификаторЯщика, ДокументAPI);
				
				// Корректный статус входящего документа у промежуточного пользователя
				// можем получить только из ленты.
				Документ.Статусы = Лента_СтатусыДокумента(ДанныеСобытия, BoxId);
				
				Идентификаторы = Документ.Идентификаторы;
				ДанныеКонтента = СвойствоСтруктуры(ДокументAPI.Content, "Data");
				
				Если Документ.Направление = Перечисление_Направления().Исходящее Тогда
					Документ.Состояние = Перечисление_СтатусыПакетов().ЗагруженИзДиадок;
				КонецЕсли;
				
				Если ЭтоШаблон Тогда
					Лента_ЗаполнитьДанныеШаблона(Документ, DocumentInfo);
				КонецЕсли;
				
				Если ЗаписыватьДанные Тогда
					Данные1С.ДокументЭДО = Лента_ЗаписатьДокументЭДО(Документ);
				КонецЕсли;
				
				ДанныеСобытия.Документ = Документ;
				
			Иначе
				
				ДанныеКонтента = Неопределено;
				Идентификаторы = Контракт_Идентификаторы();
				
				ЗаполнитьЗначенияСвойств(Идентификаторы, Данные1С);
				
				Если ЭтоШаблон Тогда
					Лента_ОбновитьДанныеШаблона(ДанныеСобытия, Идентификаторы);
				Иначе
					Лента_ОбновитьДанныеДокумента(ДанныеСобытия, Данные1С, Идентификаторы, BoxId);
				КонецЕсли;
				
			КонецЕсли;
			
			Если ЗаписыватьДанные Тогда
				
				ДанныеСобытия.ДокументЭДО = Данные1С.ДокументЭДО;
				
				СохраняемыйКонтентДО = Лента_ДанныеДО(ДанныеСобытия, ЗагружатьДокументооборотЦеликом);
				ПараметрыХранилищДокумента = Лента_ПараметрыХранилищДокумента(Идентификаторы, СохраняемыйКонтентДО, ДанныеКонтента, ТребуетсяРасшифровка);
				
				Лента_ЗаписатьДанныеХранилищДокумента(Идентификаторы, ПараметрыХранилищДокумента);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗагружатьДокументооборотЦеликом И ЗаписыватьДанные Тогда
			Лента_ЗаписатьИсториюСобытий(ТаблицаСобытий, НаличиеДанных1С, BoxId);
		КонецЕсли;
		
		Если ТаблицаСобытий.Количество() > 0 Тогда
			
			ПоследнееСобытие = ТаблицаСобытий[ТаблицаСобытий.Количество() - 1];
			
			AfterIndexKey = ПоследнееСобытие.Event.IndexKey;
			Ticks = ПоследнееСобытие.Event.Timestamp.Ticks;
			ДатаГраницыСинхронизации = Ticks_2_Date(Ticks);
			
			РеквизитыДляОбновления = Новый Структура(
					"AfterIndexKey, 
					|ДатаГраницыСинхронизации",
					AfterIndexKey,
					ДатаГраницыСинхронизации);
			
			Попытка
				
				Организации_ОбновлениеРеквизитов(Организация, РеквизитыДляОбновления);
				
			Исключение
				
				ИнформацияОбОшибке = ИнформацияОбОшибке();
				ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
				
				// BSLLS:UsageWriteLogEvent-off
				ЗаписьЖурналаРегистрации(
					"Диадок.ЗаписьГраницыСинхронизацииЛенты",
					УровеньЖурналаРегистрации.Предупреждение,
					Метаданные(),
					BoxId,
					ПодробноеПредставлениеОшибки
				);
				// BSLLS:UsageWriteLogEvent-on
				
			КонецПопытки;
			
			Лента_ПослеОбработкиСобытий(ПараметрыСервиса, ТаблицаСобытийСвернутая);
			
		КонецЕсли;
		
		Метрика_ДобавитьЗамер_ЧтениеЛентыСобытий(КоличествоСобытий, BoxId, Ложь);
		
		ОсталосьСобытий = ПорцияСобытий.TotalCount - ТаблицаСобытий.Количество();
		КоличествоЦиклов = КоличествоЦиклов + 1;
		
		Если ОсталосьСобытий = 0 ИЛИ КоличествоЦиклов >= МаксКоличествоЦиклов Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОсталосьСобытий;
	
КонецФункции

Функция Лента_ПараметрыСервиса(boxId)
	
	ИспользоватьСлужебнуюУчетнуюЗапись = ОбщийКонтекст_Прочитать("ИспользоватьСлужебнуюУчетнуюЗапись");
	
	Если ИспользоватьСлужебнуюУчетнуюЗапись Тогда
		
		СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста("", Ложь);
		
		Если СтрокаКонтекста = Неопределено Тогда
			
			Логин	= ОбщиеНастройки_Прочитать("СлужебнаяУчетнаяЗаписьЛогин");
			Пароль	= ОбщиеНастройки_Прочитать("СлужебнаяУчетнаяЗаписьПароль");
			Токен	= Авторизация_ПоПаролю(Логин, Пароль);
			Если Не ЗначениеЗаполнено(Токен) Тогда
				Возврат Токен;
			КонецЕсли;
			
		КонецЕсли;
		
		Результат = ПараметрыСервиса_Диадок(, Истина);
		
	Иначе
		Результат = ПараметрыСервиса_Диадок(BoxId);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_СобытияЯщикаОрганизации(boxId, tick_start = "", tick_final = "", AfterIndexKey = "", DepartmentId = "")
	
	ПараметрыСервиса = Лента_ПараметрыСервиса(boxId);
	
	DocflowEventsRequest = АПИ_Новый_GetDocflowEventsRequest(tick_start, tick_final, AfterIndexKey, Истина, , , DepartmentId);
	
	Попытка
		Результат = АПИ_GetDocflowEvents_v4(ПараметрыСервиса, boxId, DocflowEventsRequest);
	Исключение
		
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
		Метрика_ДобавитьОшибку_ЧтениеЛентыСобытий(ТекстОшибки, boxId);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ТаблицаСобытийДляОбработки(BoxId, Events)
	
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(BoxId);
	
	Результат = Новый ТаблицаЗначений; 
	
	ОписаниеСтроки = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	
	Результат.Колонки.Добавить("Event");
	Результат.Колонки.Добавить("ДокументЭДО");
	Результат.Колонки.Добавить("Документ");
	Результат.Колонки.Добавить("ID",				ОписаниеСтроки);
	Результат.Колонки.Добавить("LetterId",			ОписаниеСтроки);
	Результат.Колонки.Добавить("BoxId",				ОписаниеСтроки);
	Результат.Колонки.Добавить("DocumentId",		ОписаниеСтроки);
	Результат.Колонки.Добавить("DocumentDirection",	ОписаниеСтроки);
	
	Для Каждого Event Из Events Цикл
		
		Если Event.Свойство("Document") И Event.Свойство("DocumentID") Тогда
			
			СтрокаСобытия = Результат.Добавить();
			
			СтрокаСобытия.BoxId 			= ИдентификаторЯщика;
			СтрокаСобытия.LetterId 			= Event.DocumentId.MessageId;
			СтрокаСобытия.DocumentId 		= Event.DocumentId.EntityId;
			СтрокаСобытия.ID                = Новый_КлючИдентификатораДокумента(СтрокаСобытия.LetterId, СтрокаСобытия.DocumentId);
			СтрокаСобытия.DocumentDirection	= Event.Document.DocumentInfo.DocumentDirection;
			СтрокаСобытия.Event				= Event;			
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_СвернутьТаблицуСобытий(ТаблицаСобытий)
	
	Результат = ТаблицаСобытий.СкопироватьКолонки(); // создадим новую ТЗ
	
	ИменаКолонокСвертки = "BoxId,LetterId,DocumentId";
	ТаблицаСобытий.Индексы.Добавить(ИменаКолонокСвертки);
	
	ТаблицаСвернутая = ТаблицаСобытий.Скопировать(, ИменаКолонокСвертки);
	ТаблицаСвернутая.Свернуть(ИменаКолонокСвертки);
	СтруктураПоиска = Новый Структура(ИменаКолонокСвертки);
	
	Для Каждого СтрокаКлючей Из ТаблицаСвернутая Цикл
		
		ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаКлючей);
		СтрокиИсходнойТаблицы = ТаблицаСобытий.НайтиСтроки(СтруктураПоиска);
		НовСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокиИсходнойТаблицы[СтрокиИсходнойТаблицы.Количество() - 1]);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ТребуетсяОбработатьСобытие(Организация, ДанныеСобытия, НетДокументаЭДО)
	
	Результат = Истина;
	
	ЭтоВнутреннийДО = (ДанныеСобытия.DocumentDirection = "Internal");
	Если ЭтоВнутреннийДО Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЭтоИсходящийДО = (ДанныеСобытия.DocumentDirection = "Outbound");
	ЭтоВходящийДО = (ДанныеСобытия.DocumentDirection = "Inbound");
	
	DocumentInfo = ДанныеСобытия.Event.Document.DocumentInfo;
	ЭтоЧерновикДО = (DocumentInfo.MessageType = "Draft");
	
	ЗагружатьИсходящиеДокументы = ОбщиеНастройки_Прочитать("ЗагружатьИсходящиеДокументы");
	ЗагружатьВходящиеДокументы = ОбщиеНастройки_Прочитать("ЗагружатьВходящиеДокументы");
	
	ПропускатьИсходящий = НЕ ЗагружатьИсходящиеДокументы И НетДокументаЭДО;
	
	Если ЭтоЧерновикДО
		ИЛИ ЭтоИсходящийДО И ПропускатьИсходящий
		ИЛИ ЭтоВходящийДО И НЕ ЗагружатьВходящиеДокументы Тогда
		
		Результат = Ложь;
		
	Иначе
		
		Participants = ДанныеСобытия.Event.Document.DocumentInfo.Participants;
		
		Если ЭтоИсходящийДО Тогда
			CounteragentBoxId = Participants.Recipient.BoxId;
		ИначеЕсли ЭтоВходящийДО Тогда
			CounteragentBoxId = Participants.Sender.BoxId;
		КонецЕсли;
		
		Результат = Контрагенты_ТребуетсяЗагружатьДокументы(Организация, CounteragentBoxId);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ЗаписатьДокументЭДО(Документ)
	
	НачатьТранзакцию();
	
	ХранениеДанных_ЗаписатьДокумент(Документ);
	ДублиДокумента = ХранениеДанных_ДублиДокумента(Документ.Идентификаторы);
	
	Если ДублиДокумента.Количество() > 0 Тогда
		ОтменитьТранзакцию();
		Документ.Идентификаторы.ДокументЭДО = ДублиДокумента[0];
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	Результат = Документ.Идентификаторы.ДокументЭДО;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ДанныеДО(ДанныеСобытия, ЗагружатьДокументооборотЦеликом)
	
	Перем SenderTitle, Title, RecipientResponse, Attachment, Signature, Rejection, SignatureRejection;
	Перем Confirmation, Receipt, RecipientReceipt, AmendmentRequest;
	Перем Revocation, RevocationRequest, RevocationResponse, Resolution, ProxyResponse;
	
	Результат = Новый Структура;
	
	ТипыТранзакцийДО = Перечисление_ТипыТранзакцийДО();
	Docflow = ДанныеСобытия.Event.Document.Docflow;
	
	// 1. Титул отправителя
	Если Docflow.Свойство("SenderTitle", SenderTitle) И Docflow.SenderTitle.Свойство("Attachment", Attachment) Тогда
		
		ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
		Результат.Вставить(ТипыТранзакцийДО.ХранилищеКонтента, ПараметрыДанных);
		
	КонецЕсли;
	
	Если НЕ ЗагружатьДокументооборотЦеликом Тогда
		Возврат Результат;
	КонецЕсли;
	
	// 2. Ответное действие получателя
	Если Docflow.Свойство("RecipientResponse", RecipientResponse) Тогда
		
		// 2.1 Титул получателя
		Если RecipientResponse.Свойство("Title", Title) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Title);
			Результат.Вставить(ТипыТранзакцийДО.ТитулПокупателя, ПараметрыДанных);
			
		// 2.2 Подпись получателя без ответного титула
		ИначеЕсли RecipientResponse.Свойство("Signature", Signature) Тогда
			
			Attachment = ?(Title = Неопределено, SenderTitle.Attachment.Attachment, Title.Attachment);
			ПараметрыДанных = Новый Структура("Attachment, Signature", Attachment, Signature);
			Результат.Вставить(ТипыТранзакцийДО.ПодписьПокупателя, ПараметрыДанных);
			
		// 2.3 Отказ в подписании получателя
		ИначеЕсли RecipientResponse.Свойство("Rejection", Rejection) И Rejection.Свойство("SignatureRejection", SignatureRejection) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(SignatureRejection);
			Результат.Вставить(ТипыТранзакцийДО.ОтказВПодписанииДокумента, ПараметрыДанных);
			
		КонецЕсли;
		
	КонецЕсли;
	
	// 3. Документооборот УПД (http://api-docs.diadoc.ru/ru/latest/docflows/UtdDocflow.html)
	
	Если Docflow.Свойство("Confirmation", Confirmation) Тогда
		
		// 3.1  Подтверждение даты отправки/получения
		Если Confirmation.Свойство("ConfirmationAttachment", Attachment) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО.Подтверждение, ПараметрыДанных);
			
		КонецЕсли;
		
		// 3.2  Извещение о получении Подтверждения оператора
		Если Confirmation.Свойство("Receipt", Receipt) И Receipt.Свойство("ReceiptAttachment", Attachment) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО.ИзвещениеОПолученииПодтверждения, ПараметрыДанных);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Docflow.Свойство("RecipientReceipt", RecipientReceipt) Тогда
		
		// 3.3  Извещение о получении документа
		Если RecipientReceipt.Свойство("ReceiptAttachment", Attachment) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО.ИзвещениеОПолучении, ПараметрыДанных);
			
		КонецЕсли;
		
		Если RecipientReceipt.Свойство("Confirmation", Confirmation) Тогда
			
			// 3.4 Подтверждение оператора
			Если Confirmation.Свойство("ConfirmationAttachment", Attachment) Тогда
				
				ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
				Результат.Вставить(ТипыТранзакцийДО.ПодтверждениеОтправкиИзвещения, ПараметрыДанных);
				
			КонецЕсли;
			
			// 3.5 Извещение о получении Подтверждения оператора
			Если Confirmation.Свойство("Receipt", Receipt) И Receipt.Свойство("ReceiptAttachment", Attachment) Тогда
				
				ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
				Результат.Вставить(ТипыТранзакцийДО.ИзвещениеОПолученииПодтвержденияОтправкиИзвещения, ПараметрыДанных);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// 4. Уточнение
	
	Если Docflow.Свойство("AmendmentRequest", AmendmentRequest) Тогда
		
		// 4.1  Уведомление об уточнении
		Если AmendmentRequest.Свойство("AmendmentRequest", Attachment) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО.УведомлениеОбУточнении, ПараметрыДанных);
			
		КонецЕсли;
		
		// 4.2 Извещение о получении Уведомления об уточнении
		Если AmendmentRequest.Свойство("Receipt", Receipt) И Receipt.Свойство("ReceiptAttachment", Attachment) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО.ИзвещениеОПолученииУведомленияОбУточнении, ПараметрыДанных);
			
		КонецЕсли;
		
	КонецЕсли;
	
	// 5. Аннулирование
	
	Если Docflow.Свойство("Revocation", Revocation) Тогда
		
		Если Revocation.InitiatorBoxId = ДанныеСобытия.Event.Document.DocumentInfo.Participants.Sender.BoxId Тогда
			ИнициативаАннулирования = "Продавца";
		Иначе
			ИнициативаАннулирования = "Покупателя";
		КонецЕсли;
		
		// 5.1 Предложение об аннулировании
		Если Revocation.Свойство("RevocationRequest", RevocationRequest) И RevocationRequest.Свойство("RevocationRequest", Attachment) Тогда			
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Attachment);
			Результат.Вставить(ТипыТранзакцийДО["ПредложениеОбАннулировании" + ИнициативаАннулирования], ПараметрыДанных);
			
		КонецЕсли;
		
		Если Revocation.Свойство("RevocationResponse", RevocationResponse) Тогда
			
			// 5.2 Подпись предложения об аннулировании
			Если RevocationResponse.Свойство("RecipientSignature", Signature) Тогда
				
				ПараметрыДанных = Новый Структура("Attachment, Signature", Attachment.Attachment, Signature);
				Результат.Вставить(ТипыТранзакцийДО["ПодписьАннулирования" + ИнициативаАннулирования], ПараметрыДанных);
				
			КонецЕсли;			
			
			// 5.3 Отказ в подписи предложения об аннулировании
			Если RevocationResponse.Свойство("SignatureRejection", Rejection) Тогда
				
				ПараметрыДанных = Лента_ПараметрыДанныхДО(Rejection.SignatureRejection);
				Результат.Вставить(ТипыТранзакцийДО["ОтказВПодписанииАннулирования" + ИнициативаАннулирования], ПараметрыДанных);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// 6. Действия промежуточного получателя
	Если Docflow.Свойство("ProxyResponse", ProxyResponse) Тогда
		
		// 6.1. Отказ в подписании промежуточным получателем
		Если ProxyResponse.Свойство("Rejection", Rejection)
			И ProxyResponse.Rejection.Свойство("SignatureRejection", Rejection) Тогда
			
			ПараметрыДанных = Лента_ПараметрыДанныхДО(Rejection);
			Результат.Вставить(ТипыТранзакцийДО.ОтказВПодписанииДокумента, ПараметрыДанных);
			
		КонецЕсли;
		
		// 6.2. Подпись промежуточного получателя
		Если ProxyResponse.Свойство("Signature", Signature) Тогда
			
			Attachment = SenderTitle.Attachment.Attachment;
			ПараметрыДанных = Новый Структура("Attachment, Signature", Attachment, Signature);
			Результат.Вставить(ТипыТранзакцийДО.ПодписьПромежуточногоПолучателя, ПараметрыДанных);
			
		КонецЕсли;
			
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_СтатусыДокумента(ДанныеСобытия, BoxId)
	
	Результат = Контракт_СтатусыДокумента();
	
	СтатусыДО = Лента_СтатусыСобытия(ДанныеСобытия, BoxId);
	
	Результат.Статус = СтатусыДО.PrimaryStatus;
	Результат.ДополнительныйСтатус = СтатусыДО.SecondaryStatus;
	Результат.ТребуетсяОбработка = ДокументAPI_ТребуетсяОбработкаДокумента(СтатусыДО);
	Результат.ОбъектМаршрутизации = ДокументAPI_ОбъектМаршрутизации(СтатусыДО.ResolutionTarget);
	Результат.СтатусМЧД = СтатусыДО.StatusMCHD;
	Результат.СтатусМЧДКритичность = СтатусыДО.StatusMCHDSeverity;
	
	ВнешниеСтатусы = Лента_ВнешниеСтатусы(ДанныеСобытия.Event.Document.Docflow.OuterDocflowEntities);
	
	ВнешниеСтатусы_ДобавитьСтатусКонтурЛогистика(ВнешниеСтатусы, ДанныеСобытия.Event.Document.DocumentInfo.CustomData);
	
	Результат.ВнешниеСтатусы = ВнешниеСтатусы;
	
	СтатусПКФНС = Лента_СтатусПКФНС(ДанныеСобытия.Event.Document.Docflow.OuterDocflowEntities);
	
	Результат.СтатусПКФНС = СтатусПКФНС.Представление;
	Результат.СтатусПКФНСКритичность = СтатусПКФНС.Тип;
	
	СтатусДТС = Лента_СтатусДТС(ДанныеСобытия.Event.Document.Docflow.OuterDocflowEntities);
	Результат.СтатусДТС = СтатусДТС.Представление;
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ВнешниеСтатусы(OuterDocflowEntities)
	
	Результат = Новый Структура;
	
	Для Каждого OuterDocflowInfo Из OuterDocflowEntities Цикл
		
		DocflowNamedId = OuterDocflowInfo.DocflowNamedId;
		
		Если DocflowNamedId <> ИдентификаторВнешнегоДО_ГИСМТ() Тогда
			Продолжить;
		КонецЕсли;
		
		ДатаБуфер = '00010101000000';
		
		Для каждого StatusEntities Из OuterDocflowInfo.StatusEntities Цикл
			
			ДатаСтатуса = Ticks_2_Date(StatusEntities.Attachment.Attachment.Entity.CreationTimestamp.Ticks);
			
			Если ДатаБуфер > ДатаСтатуса Тогда
				Продолжить;
			КонецЕсли;
			
			ДатаБуфер = ДатаСтатуса;
			
			Status = StatusEntities.Status;
			
			Результат.Вставить(DocflowNamedId, Status.FriendlyName);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// BSLLS:NestedStateents-off
//
// Параметры:
//  OuterDocflowEntities - Массив - Коллекция внешних событий и статусов 
// 
// Возвращаемое значение:
//  Структура - Представление и тип события ПКФНС
//
Функция Лента_СтатусПКФНС(OuterDocflowEntities)
	
	Результат = Новый Структура("Представление, Тип");
	
	Для Каждого OuterDocflowInfo Из OuterDocflowEntities Цикл
		
		DocflowNamedId = OuterDocflowInfo.DocflowNamedId;
		
		Если DocflowNamedId <> ИдентификаторВнешнегоДО_ПКФНС() Тогда
			Продолжить;
		КонецЕсли;
		
		ДатаБуфер = '00010101000000';
		
		Для Каждого StatusEntities Из OuterDocflowInfo.StatusEntities Цикл
			
			ДатаСтатуса = Ticks_2_Date(StatusEntities.Attachment.Attachment.Entity.CreationTimestamp.Ticks);
			
			Если ДатаБуфер > ДатаСтатуса Тогда
				Продолжить;
			КонецЕсли;
			
			ДатаБуфер = ДатаСтатуса;
			
			Status = StatusEntities.Status;
			
			Результат.Представление = Status.FriendlyName;
			Результат.Тип = Status.Type;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции
// BSLLS:NestedStateents-on

Функция Лента_СтатусДТС(OuterDocflowEntities)
	
	Результат = Новый Структура("Представление, Тип");
	
	Для Каждого OuterDocflowInfo Из OuterDocflowEntities Цикл
		
