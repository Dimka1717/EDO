// Получает список правил обработки (идентификаторов операций) электронных документов указанного типа.
//
// Параметры:
//  ТипЭД - Структура - описание типа электронного документа (см. Контракт_ТипЭлектронногоДокумента).
// 
// Возвращаемое значение:
//  СписокЗначений:
//    * Значение - Строка - идентификатор правила обработки электронного документа.
//    * Представление - Строка - пользовательское представление операции.
//
Функция МенеджерИнтеграции_ПравилаСозданияДокументовУчета(ТипЭД) Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() 
		ИЛИ НЕ ТипЭД.Формализованный Тогда
		Возврат Новый СписокЗначений;
	КонецЕсли;
	
	ФорматЭД = ФорматОтправкиПоТипуДокумента(ТипЭД);
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	Результат = МенеджерИнтеграции.СозданиеДокументов_ПравилаСозданияДокументовУчета(ФорматЭД);
	
	Возврат Результат;
	
КонецФункции

// Создает и заполняет учетные документы.
//
// Параметры:
//  Содержимое - ДвоичныеДанные, Структура - XML-файл или протоструктура с его содержимым.
//  ИдентификаторОперации - Строка - Идентификатор правила создания учетного документа.
//  ПараметрыЗаполнения - Структура - значения заполнения учетного документа (см. ПараметрыЗаполненияДокументаИнформационнойБазы)
//  ФорматЭД - Структура - описание формата электронного документа (см. Контракт_ФорматЭлектронногоДокумента)
// 
// Возвращаемое значение:
//  ДокументОбъект, СправочникОбъект - заполненный объект информационной базы.
//  Неопределено - если типовой модуль не подключен.
//
Функция МенеджерИнтеграции_НовыйДокументИнформационнойБазы(Содержимое, ИдентификаторОперации, ПараметрыЗаполнения, ФорматЭД)
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	Результат = МенеджерИнтеграции.СозданиеДокументов_НовыйДокументИнформационнойБазы(
		Содержимое,
		ИдентификаторОперации,
		ПараметрыЗаполнения,
		ФорматЭД
	);
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыЗаполненияДокументаИнформационнойБазы()
	
	Результат = Новый Структура;
	Результат.Вставить("Контрагент");
	Результат.Вставить("Организация");
	Результат.Вставить("ЦенаВключаетНДС", Ложь);
	Результат.Вставить("ДокументОснование");
	
	Возврат Результат;
	
КонецФункции

// Возвращает признак необходимости отладки ТиповогоМодуля
// Анализируется значение функции РежимОтладкиВключен()
//
// Возвращаемое значение:
//  Булево - Истина, если режим отладки включен
//
Функция ТиповойМодуль_РежимОтладки()
	
	Результат = РежимОтладкиВключен();
	Возврат Результат;
	
КонецФункции

// Возвращает каталог отладки для выгрузки типового модуля
//
// Возвращаемое значение:
//  Строка
//
Функция ТиповойМодуль_КаталогОтладки()
	
	Результат = "";
	
	КаталогТекущейОбработки = КаталогОбработки();
	
	Если ЗначениеЗаполнено(КаталогТекущейОбработки) Тогда
		
		Если ЭтоУправляемоеПриложение() Тогда
			ИмяПапкиОтладкиСтандарта = "includeUF";
		Иначе
			ИмяПапкиОтладкиСтандарта = "includeOF";
		КонецЕсли;
		
		Файл = Новый Файл(КаталогТекущейОбработки);
		КаталогОбработки = Файл.Путь;
		Результат = ОбъединитьПути(КаталогОбработки, ИмяПапкиОтладкиСтандарта);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет что запущено управляемое приложение
//
// Возвращаемое значение:
//  Булево
//
Функция ЭтоУправляемоеПриложение()

	Результат = (ТекущийРежимЗапуска() = РежимЗапускаКлиентскогоПриложения.УправляемоеПриложение);
	Возврат Результат;

КонецФункции

Функция МенеджерИнтеграции_КонтентОтветногоТитула(СсылкаНаОбъект, ТипКонтента, ДополнительныеПараметры)
	
	Результат = Новый Структура;
	
	Если ЕстьИнтеграционныйМодуль() Тогда
		
		Модуль_МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
		Результат = Модуль_МенеджерИнтеграции.КонтентОтветногоТитула(СсылкаНаОбъект, ТипКонтента, ДополнительныеПараметры);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

