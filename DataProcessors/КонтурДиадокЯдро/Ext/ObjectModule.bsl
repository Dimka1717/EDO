Функция УправлениеПМ_СделатьБэкапФайлаПМ(ОписаниеПМ)
	
	Результат = Неопределено;
	
	Попытка
		Результат = ПолучитьИмяВременногоФайла("epf.bak");
		КопироватьФайл(ОписаниеПМ.ПутьКФайлу, Результат);
	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		ШаблонТекстаОшибки ="Произошла ошибка при создании бэкапа файла ПМ.
		|Путь к файлу: %1
		|Описание ошибки: %2";
		
		УправлениеПМ_ЗафиксироватьОшибкуОбновленияФайлаПМ(ШаблонТекстаОшибки, ОписаниеОшибки, ОписаниеПМ);

	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция УправлениеПМ_ПодключитьНовыйФайлПМ(ОписаниеПМ)
	
	Успешно = Истина;
	
	Попытка
		
		Модуль_ПМ_Отключить();
		Модуль_ПМ(ЭтотОбъект);
		
	Исключение
		
		Успешно = Ложь;
		
		ОписаниеОшибки = ОписаниеОшибки();
		
		ШаблонТекстаОшибки ="Произошла ошибка при подключении ПМ из файла.
		|Путь к файлу: %1
		|Описание ошибки: %2";
		
		УправлениеПМ_ЗафиксироватьОшибкуОбновленияФайлаПМ(ШаблонТекстаОшибки, ОписаниеОшибки, ОписаниеПМ);
	
	КонецПопытки;
	
	Возврат Успешно;
	
КонецФункции

Функция УправлениеПМ_ЗаменитьФайлПМ(НовыйФайлПМ, ОписаниеПМ)
	
	Успешно = Истина;
	
	Попытка
		НовыйФайлПМ.Записать(ОписаниеПМ.ПутьКФайлу);
	Исключение
		
		Успешно = Ложь;
		
		ОписаниеОшибки = ОписаниеОшибки();
		
		ШаблонТекстаОшибки ="Произошла ошибка при обновлении файла ПМ.
		|Путь к файлу: %1
		|Описание ошибки: %2";
		
		УправлениеПМ_ЗафиксироватьОшибкуОбновленияФайлаПМ(ШаблонТекстаОшибки, ОписаниеОшибки, ОписаниеПМ);
		
	КонецПопытки;
	
	Возврат Успешно;
	
КонецФункции

Функция УправлениеПМ_ВосстановитьПМнаДискеИзБэкапа(ПутьКФайлуБэкапа, ОписаниеПМ)
	
	Успешно = Истина;
	
	Попытка
		
		Модуль_ПМ_Отключить();
		
		КопироватьФайл(ПутьКФайлуБэкапа, ОписаниеПМ.ПутьКФайлу);
				
		Модуль_ПМ(ЭтотОбъект);
		
	Исключение
		
		Успешно = Ложь;

		ОписаниеОшибки = ОписаниеОшибки();
		ШаблонТекстаОшибки ="Произошла ошибка при восстановлении ПМ из бэкапа.
		|Путь к файлу: %1
		|Описание ошибки: %2";
		
		УправлениеПМ_ЗафиксироватьОшибкуОбновленияФайлаПМ(ШаблонТекстаОшибки, ОписаниеОшибки, ОписаниеПМ);

	КонецПопытки;
	
	Возврат Успешно;
	
КонецФункции

Процедура УправлениеПМ_ЗафиксироватьОшибкуОбновленияФайлаПМ(ОписаниеОшибки, ШаблонТекстаОшибки, ОписаниеПМ)
	
	ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонТекстаОшибки, ОписаниеПМ.ПутьКФайлу, ОписаниеОшибки);
	
	Ошибка_ДобавитьВЛог(ТекстОшибки);
	
	Метрика_ДобавитьОшибку_ПриОбновленииФайлаПМ(ТекстОшибки, ОписаниеПМ);
	
КонецПроцедуры

// Возвращает признак того, что хэш-сумма текущего ПМ модуля отличается от хэш-суммы файла в сервисе
//
// Параметры:
//  ОписаниеПМ	 - Структура - сведения о выгружаемом подключаемом модуле
//		* см. Контракт_ОписаниеПМ
// 
// Возвращаемое значение:
//  Булево - Истина, если хэш-сумма текущего ПМ модуля отличается от хэш-суммы файла в сервисе
//
Функция УправлениеПМ_ХэшСуммаФайлаИзменилась(ОписаниеПМ)

	Результат = Истина;
	
	Если ЗначениеЗаполнено(ОписаниеПМ.ХэшСуммаФайла)
		И ОписаниеПМ.ХэшСуммаФайла = ОписаниеПМ.ХэшСуммаФайлаВСервисе Тогда
		
		Результат = Ложь;		
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Общее_ЭтоКопияИнформационнойБазы()
	
	Результат = Ложь;
	
	ЕстьПараметрыБлокировкиРаботыСВнешнимиРесурсами = ПроверитьНаличиеОбъектаМетаданных("Константы.ПараметрыБлокировкиРаботыСВнешнимиРесурсами");
	
	Если ЕстьПараметрыБлокировкиРаботыСВнешнимиРесурсами Тогда
		
		Попытка
			
			// BSLLS:SetPrivilegedMode-off
			УстановитьПривилегированныйРежим(Истина);
			// BSLLS:SetPrivilegedMode-on
			
			СохраненныеПараметры = Вычислить("Константы.ПараметрыБлокировкиРаботыСВнешнимиРесурсами.Получить().Получить()");
			УстановитьПривилегированныйРежим(Ложь);
			
		Исключение
			СохраненныеПараметры = Неопределено;
		КонецПопытки;
		
		Результат = СвойствоСтруктуры(СохраненныеПараметры, "РаботаСВнешнимиРесурсамиЗаблокирована", Ложь);
		
		Если Результат = Неопределено Тогда
			Результат = Ложь;
		КонецЕсли;
		
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

