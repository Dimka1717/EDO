Функция ДесериализоватьПараметрыГиперссылки(СериализованныеПараметрыГиперссылки) Экспорт
	
	ДвоичныеДанныеПараметрыГиперссылки = Base64Значение(СериализованныеПараметрыГиперссылки);
	JSONПараметрыГиперссылки = СтрокаИзДвоичныхДанных(ДвоичныеДанныеПараметрыГиперссылки);
	
	Результат = ПарсерJSON_Прочитать(JSONПараметрыГиперссылки);
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьСсылкуНаСтраницуПроверкиДоверенностиНаСайтеФНС(ИнформацияОДоверенности) Экспорт
	
	ИдентификаторДоверенности = СвойствоСтруктуры(ИнформацияОДоверенности, "Идентификатор", """");
	ДоверительИНН = СвойствоСтруктуры(ИнформацияОДоверенности.Доверитель, "ИНН", """");
	ПредставительИНН = СвойствоСтруктуры(ИнформацияОДоверенности.Представитель, "ИНН", """");
	
	МЧДСтраницаПроверкиНаСайтеФНСАдрес = Перечисление_АдресаИнтернетРесурсов().МЧДСтраницаПроверкиНаСайтеФНС;
	ПараметрыПроверкиМДЧ = "?guid=%1&innP=%2&innR=%3";
	
	ПараметрыПроверкиМДЧСтрокой = Общее_ПодставитьПараметрыВСтроку(ПараметрыПроверкиМДЧ,
																ИдентификаторДоверенности,
																ДоверительИНН,
																ПредставительИНН);
	
	Результат = МЧДСтраницаПроверкиНаСайтеФНСАдрес + ПараметрыПроверкиМДЧСтрокой;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СобытияМЧД_ФайлыДоверенности(ПараметрыГиперссылки) Экспорт
	
	Если ТипЗнч(ПараметрыГиперссылки) = Тип("Строка") Тогда
		Идентификаторы = ДесериализоватьПараметрыГиперссылки(ПараметрыГиперссылки);
	Иначе
		Идентификаторы = ПараметрыГиперссылки;
	КонецЕсли;
	
	Результат = МЧД_ДанныеФайловДоверенности(Идентификаторы.BoxId, Идентификаторы.MessageId, Идентификаторы.EntityId);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СобытияМЧД_ПредставлениеГиперссылкиДляСкачивания(ЕстьЦепочкаМЧД)
	
	Если ЕстьЦепочкаМЧД Тогда
		Результат = "Скачать цепочку доверенностей (xml  и подписи к ним)";
	Иначе
		Результат = "Скачать доверенность (xml  и подпись к ней)";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ДОСТУПНЫЕ ДЕЙСТВИЯ С ДОКУМЕНТАМИ

Функция Документы_ДоступныеДействия(Документ) Экспорт
	
	Результат = Новый Структура;
	
	ДействияЭДО				= Перечисление_ДействияЭДО();
	НаправленияДокументов	= Перечисление_Направления();
	
	Для Каждого КлючЗначение Из ДействияЭДО Цикл
		Результат.Вставить(КлючЗначение.Ключ, Ложь);
	КонецЦикла;
	
	BoxId					= Документ.Идентификаторы.BoxId;
	СтрокаКонтекста 		= КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	ЗаполненыУчастникиДО	= ЗначениеЗаполнено(Документ.Отправитель.BoxId)
							И ЗначениеЗаполнено(Документ.Получатель.BoxId);
	
	Если ЗначениеЗаполнено(СтрокаКонтекста)
		И ЗаполненыУчастникиДО Тогда
		
		Если Документ.Шаблон Тогда
			
			Результат.ОтправитьШаблон			= Документы_МожноОтправитьШаблон(Документ);
			Результат.АннулироватьШаблон		= Документы_МожноАннулироватьШаблон(Документ);
			
		Иначе
			
			ДоступноПодписаниеСертификатом = Документы_ДоступноПодписаниеСертификатом(Документ);
			
			Если ДоступноПодписаниеСертификатом Тогда
				
				ДоступноПодписаниеБезОтправки = Документы_ДоступноПодписаниеБезОтправки();
				
				Результат.ПодписатьИсходящий = Документы_МожноПодписатьИсходящий(Документ) И ДоступноПодписаниеБезОтправки;
				Результат.ПодписатьИОтправить = Документы_МожноПодписатьИОтправитьИсходящий(Документ);
				Результат.НастроитьПараметрыПодписания = Документы_МожноНастроитьПараметрыПодписания(Документ);
				Результат.Аннулировать = Документы_МожноАннулировать(Документ);
				
			КонецЕсли;
			
			МожноПодписатьВходящий = Документы_МожноПодписатьВходящий(Документ);
			
			Результат.ПодписатьВходящий = МожноПодписатьВходящий И ДоступноПодписаниеСертификатом;
			Результат.ОтказатьВПодписи = МожноПодписатьВходящий;
			Результат.ОтказатьВАннулировании = Документы_МожноОтказатьВАннулировании(Документ);
			Результат.ЗапроситьУточнение = Документы_МожноЗапроситьУточнениеВходящегоДокумента(Документ);
			
			ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
			
			Если ФормироватьУС = Неопределено Тогда
				
				Результат.ОтказатьВПодписи = Результат.ОтказатьВПодписи И ДоступноПодписаниеСертификатом;
				Результат.ОтказатьВАннулировании = Результат.ОтказатьВАннулировании И ДоступноПодписаниеСертификатом;
				Результат.ЗапроситьУточнение = Результат.ЗапроситьУточнение И ДоступноПодписаниеСертификатом;
				
			Иначе
				
				Результат.ОтказатьВПодписи = Результат.ОтказатьВПодписи И ФормироватьУС;
				Результат.ОтказатьВАннулировании = Результат.ОтказатьВАннулировании И ФормироватьУС;
				Результат.ЗапроситьУточнение = Результат.ЗапроситьУточнение И ФормироватьУС;
				
			КонецЕсли;
			
			Результат.ЗаполнитьДопСведения		= Документы_МожноЗаполнитьДопСведения(Документ);
			Результат.ЗаполнитьСведенияОбАвансах = Документы_МожноЗаполнитьСведенияОбАвансах(Документ);
			Результат.Отправить					= Документы_МожноОтправитьИсходящий(Документ);
			Результат.ПередатьВПодразделение	= Документы_ДокументОтправлен(Документ);
			Результат.ПометитьКакЗавершенный	= (Документ.Направление = НаправленияДокументов.Входящее);
			
			Результат.ПередатьНаСогласование	= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.ПередатьНаСогласование);
			Результат.ПередатьНаПодпись			= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.ПередатьНаПодпись);
			Результат.ПередатьПоМаршруту		= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.ПередатьПоМаршруту);
			Результат.ОтказВЗапросеПодписи		= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.ОтказВЗапросеПодписи);
			Результат.Согласование				= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.Согласование);
			Результат.ОтказВСогласовании		= Документы_ДоступноДействиеМаршрутизации(Документ, ДействияЭДО.ОтказВСогласовании);
			
			ДоступноПодписаниеГосключ = ДоступноПодписаниеГосключ();
			Если ДоступноПодписаниеГосключ Тогда
				Результат.ПодписатьИОтправитьГосключ = Документы_МожноПодписатьИОтправитьИсходящий(Документ);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


Функция ПраваПользователяЯщикаОрганизации(BoxId)
	
	СтрокаКонтекста	= КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	Если ЗначениеЗаполнено(СтрокаКонтекста) Тогда
		Результат = СтрокаКонтекста.ПраваПользователя;
	Иначе
		Результат = Контракт_ПраваПользователя();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


Функция Документы_ДоступноПодписаниеСертификатом(Документ)
	
	Результат = Ложь;
	
	Если Документ.Шаблон Тогда
		Возврат Результат;
	КонецЕсли;
	
	BoxId = Документ.Идентификаторы.BoxId;
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	Если ЗначениеЗаполнено(СтрокаКонтекста)
		И ЗначениеЗаполнено(СтрокаКонтекста.Сертификат) Тогда
		
		Результат = СтрокаКонтекста.ПраваПользователя.CanSignDocuments;
		
	КонецЕсли;

	Результат = Результат И ЗначениеНастройки_ПодписаниеСертификат();
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДоступноДействиеМаршрутизации(Документ, Действие) 

	Результат = Ложь;
	
	ПараметрыОтправки = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПараметрыОтправки");
	ОтправкаЗашифрованногоПакета = СвойствоСтруктуры(ПараметрыОтправки, "ЗашифрованныйПакет", Ложь);
	
	Если ОтправкаЗашифрованногоПакета Тогда
		Возврат Результат;
	КонецЕсли;
	
	BoxId				= Документ.Идентификаторы.BoxId;
	ПраваПользователя	= ПраваПользователяЯщикаОрганизации(BoxId);
	ДействияЭДО			= Перечисление_ДействияЭДО();
	
	Если Действие = ДействияЭДО.Согласование
		ИЛИ Действие = ДействияЭДО.ОтказВСогласовании Тогда
		
		Результат = ПраваПользователя.CanAddResolutions
					И Документы_МожноСогласовать(Документ);
		
	ИначеЕсли Действие = ДействияЭДО.ОтказВЗапросеПодписи Тогда
		
		Результат = ПраваПользователя.CanSignDocuments
					И Документы_МожноОтказатьВЗапросеПодписи(Документ);
		
	ИначеЕсли Действие = ДействияЭДО.ПередатьНаСогласование Тогда
		
		Результат = ПраваПользователя.CanRequestResolutions 
					И Документы_ДоступенДляМаршрутизации(Документ);
		
	ИначеЕсли Действие = ДействияЭДО.ПередатьНаПодпись Тогда
		
		Результат = ПраваПользователя.CanRequestResolutions 
					И Документы_МожноПередатьНаПодпись(Документ);
		
	ИначеЕсли Действие = ДействияЭДО.ПередатьПоМаршруту Тогда
		
		Результат = ПраваПользователя.CanRequestResolutions
					И Документы_МожноПередатьПоМаршруту(Документ);
	Иначе
		ВызватьИсключение "Попытка выполнить неизвестное действие маршрутизации: " + Действие;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДоступенДляМаршрутизации(Документ)
	
	Результат = НЕ Документ.Шаблон
				И НЕ Документы_НаЭтапеАннулирования(Документ)
				И НЕ Документы_НаМаршрутизации(Документ)
				И НЕ ЭтоАктСверкиИзСервисаВзаиморасчеты(Документ);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_НаЭтапеАннулирования(Документ)
	
	Статус = Документ.Статусы.Статус;
	
	Результат = (Статус = Перечисление_СтатусыДокументов().ТребуетсяАннулирование
				 ИЛИ Статус = Перечисление_СтатусыДокументов().ОжидаетсяАннулирование
				 ИЛИ Найти(Статус, "Аннулирован") > 0);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_НаМаршрутизации(Документ)
	
	ДополнительныйСтатус = Документ.Статусы.ДополнительныйСтатус;
	
	Результат = (ДополнительныйСтатус = Перечисление_ДополнительныеСтатусыДокументов().НаСогласовании
			 ИЛИ ДополнительныйСтатус = Перечисление_ДополнительныеСтатусыДокументов().НаПодписании);
		 
	Возврат Результат;
	
КонецФункции


Функция Документы_МожноОтправитьИсходящий(Документ)
	
	Результат = Ложь;
	
	НаправленияДокументов	= Перечисление_Направления();
	ДокументОтправлен		= Документы_ДокументОтправлен(Документ);
		
	Если Документ.Направление = НаправленияДокументов.Исходящее
		И НЕ Документ.Шаблон
		И НЕ ДокументОтправлен Тогда
		
		ХранилищеКонтента	= СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
		ДокументПодписан	= ЗначениеЗаполнено(ХранилищеКонтента.Подпись.ДанныеПодписи);
		
		BoxId				= Документ.Идентификаторы.BoxId;
		ПраваПользователя	= ПраваПользователяЯщикаОрганизации(BoxId);
		
		Результат = ДокументПодписан 
					И ПраваПользователя.CanCreateDocuments;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноОтправитьШаблон(Документ)
	
	Результат = Ложь;
	
	НаправленияДокументов	= Перечисление_Направления();
	ДокументОтправлен		= Документы_ДокументОтправлен(Документ);
		
	Если Документ.Направление = НаправленияДокументов.Исходящее
		И Документ.Шаблон
		И НЕ ДокументОтправлен Тогда
		
		BoxId				= Документ.Идентификаторы.BoxId;
		ПраваПользователя	= ПраваПользователяЯщикаОрганизации(BoxId);
		
		Результат = ПраваПользователя.CanCreateDocuments;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноПодписатьИсходящий(Документ)
	
	Результат = Ложь;
	
	НаправленияДокументов = Перечисление_Направления();
	
	Если (Документ.Направление = НаправленияДокументов.Исходящее 
			ИЛИ Документ.Направление = НаправленияДокументов.Внутреннее)
		И НЕ Документ.Шаблон Тогда
	
		ЭтоПроизвольныйПакет	= Не ЗначениеЗаполнено(Документ.ИдентификаторВидаПакета);
		ДокументОтправлен		= Документы_ДокументОтправлен(Документ);
		
		Результат = НЕ ДокументОтправлен 
					И НЕ ЭтоПроизвольныйПакет;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноПодписатьИОтправитьИсходящий(Документ)
	
	Результат = Ложь;
	
	НаправленияДокументов	= Перечисление_Направления();
	СтатусыДокументовЭДО	= Перечисление_СтатусыДокументов();
	ДопСтатусыДокументовЭДО	= Перечисление_ДополнительныеСтатусыДокументов();
	
	Статус					= Документ.Статусы.Статус;
	ДополнительныйСтатус	= Документ.Статусы.ДополнительныйСтатус;
	ДокументОтправлен		= Документы_ДокументОтправлен(Документ);
	
	Если (Документ.Направление = НаправленияДокументов.Исходящее 
			ИЛИ Документ.Направление = НаправленияДокументов.Внутреннее)
		И НЕ Документ.Шаблон 
		И (НЕ ДокументОтправлен
			ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить
				И ДополнительныйСтатус <> ДопСтатусыДокументовЭДО.НаСогласовании) Тогда
		
			BoxId				= Документ.Идентификаторы.BoxId;
			ПраваПользователя	= ПраваПользователяЯщикаОрганизации(BoxId);
			
			Результат = ПраваПользователя.CanCreateDocuments;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноНастроитьПараметрыПодписания(Документ)
	
	Результат = Ложь;
	
	МожноПодписатьИОтправитьИсходящий = Документы_МожноПодписатьИОтправитьИсходящий(Документ);
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	
	ТребуютсяПолномочияПодписания = НЕ ЭтоФормализованныйАктСверки405(ТипКонтента);
	
	Если МожноПодписатьИОтправитьИсходящий
		И ТребуютсяПолномочияПодписания
		И НЕ Документ.Шаблон Тогда
		
		ВидТитула	= Документы_ВидТитула(ТипКонтента);
		
		Результат = ЗначениеЗаполнено(ВидТитула);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноСогласовать(Документ)
	
	ДополнительныйСтатус = Документ.Статусы.ДополнительныйСтатус;
	
	Результат = НЕ Документ.Шаблон
				И ДополнительныйСтатус <> Перечисление_ДополнительныеСтатусыДокументов().НаПодписании
				И ДополнительныйСтатус <> Перечисление_ДополнительныеСтатусыДокументов().Согласован
				И ДополнительныйСтатус <> Перечисление_ДополнительныеСтатусыДокументов().ОтказаноВСогласовании
				И НЕ Документы_НаЭтапеАннулирования(Документ);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноОтказатьВЗапросеПодписи(Документ)
	
	Статус 					= Документ.Статусы.Статус;
	ДополнительныйСтатус 	= Документ.Статусы.ДополнительныйСтатус;
	
	Результат = НЕ Документ.Шаблон
				И НЕ Документы_НаЭтапеАннулирования(Документ)
				И ДополнительныйСтатус = Перечисление_ДополнительныеСтатусыДокументов().НаПодписании
				И ЗначениеЗаполнено(Статус);
				
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноПередатьНаПодпись(Документ)
	
	ДокументМожноПодписать = Документы_ДокументИсходящийМожноПередатьНаПодпись(Документ)
						 	ИЛИ Документы_МожноПодписатьВходящий(Документ);
						 
	Результат = Документы_ДоступенДляМаршрутизации(Документ) 
				И ДокументМожноПодписать;
						
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноПередатьПоМаршруту(Документ)
	
	СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();

	Статус = Документ.Статусы.Статус;
	
	Результат = НЕ Документ.Заблокирован
				И Документы_ДоступенДляМаршрутизации(Документ)
				И (Статус = СтатусыДокументовЭДО.ДокументооборотЗавершен
				ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить
				ИЛИ Документы_МожноПодписатьИсходящий(Документ)
				ИЛИ Документы_МожноПодписатьВходящий(Документ)
				ИЛИ Документы_ЭтоСФ(Документ, Истина));
						
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноПодписатьВходящий(Документ)
	
	Результат = Ложь;
	
	НаправленияДокументов	= Перечисление_Направления();
	СтатусыДокументовЭДО	= Перечисление_СтатусыДокументов();
	ДопСтатусыДокументовЭДО	= Перечисление_ДополнительныеСтатусыДокументов();
	
	Если (Документ.Направление = НаправленияДокументов.Входящее 
			ИЛИ Документ.Направление = НаправленияДокументов.Внутреннее)
		И НЕ Документ.Шаблон
		И НЕ ЭтоАктСверкиИзСервисаВзаиморасчеты(Документ) Тогда
	
		Статус					= Документ.Статусы.Статус;
		ДополнительныйСтатус	= Документ.Статусы.ДополнительныйСтатус;
		
		Результат = Найти(Статус, СтатусыДокументовЭДО.ТребуетсяПодпись) > 0
					И ДополнительныйСтатус <> ДопСтатусыДокументовЭДО.НаСогласовании;
		
		Если НЕ Результат
			И ДополнительныйСтатус <> ДопСтатусыДокументовЭДО.НаСогласовании
			И (Найти(Статус, СтатусыДокументовЭДО.ОжидаетсяУточнение) > 0
				Или Найти(Статус, СтатусыДокументовЭДО.Откорректирован) > 0) Тогда
			
			ЭтоСФ = Документы_ЭтоСФ(Документ, Истина);
			
			Если НЕ ЭтоСФ Тогда
				
				ТитулПокупателя = СвойствоСтруктуры(Документ.Документооборот, "ТитулПокупателя");
				
				Если ТитулПокупателя = Неопределено Тогда
					ТитулПокупателя	= ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, "ТитулПокупателя");
				КонецЕсли;
				
				Результат = НЕ ЗначениеЗаполнено(ТитулПокупателя.Данные);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноЗапроситьУточнениеВходящегоДокумента(Документ) Экспорт
	
	Результат = Ложь;
	
	НаправленияДокументов	= Перечисление_Направления();
	СтатусыДокументовЭДО	= Перечисление_СтатусыДокументов();
	
	Если Документ.Направление = НаправленияДокументов.Входящее
		И НЕ Документ.Шаблон Тогда
		
		ФорматКонтента = Списки_ОписаниеФорматаКонтента(Документ.Тип.ТипКонтента);
		
		Если ЗначениеЗаполнено(ФорматКонтента.XDTO_CorrectionRequestContent) Тогда
			
			Статус	= Документ.Статусы.Статус;
			ЭтоСФ	= Документы_ЭтоСФ(Документ);
			
			Если ЭтоСФ
				И (Статус = СтатусыДокументовЭДО.ДокументооборотЗавершен
					ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить
					ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИзвещение
					ИЛИ Найти(Статус, "Требуется подпись") > 0
					ИЛИ Найти(Статус, "Подписан") > 0) Тогда
				
				Результат = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция Документы_МожноАннулировать(Документ)
	
	Результат = Истина;
	
	Если Документ.Шаблон Тогда
		
		Результат = Ложь;
		
	Иначе
		
		СтатусыДокументовЭДО	= Перечисление_СтатусыДокументов();
		НаправленияДокументов	= Перечисление_Направления();
		
		Статус = Документ.Статусы.Статус;
		Направление = Документ.Направление;
		ЭтоСФ = Документы_ЭтоСФ(Документ, Истина);
		
		ТитулПокупателя = СвойствоСтруктуры(Документ.Документооборот, "ТитулПокупателя");
		
		Если ТитулПокупателя = Неопределено Тогда
			ТитулПокупателя = ХранениеДанных_ДанныеХранилища(Документ.Идентификаторы, "ТитулПокупателя");
		КонецЕсли;
			
		СостояниеДокументаЗапрещаетАннулирование = (СтрНайтиЛок(Статус, СтатусыДокументовЭДО.Аннулирован) > 0
			Или Статус = СтатусыДокументовЭДО.ОжидаетсяАннулирование
			Или Статус = СтатусыДокументовЭДО.ОтказаноВПодписи
			Или Статус = СтатусыДокументовЭДО.КонтрагентОтказалВПодписи
			Или Статус = СтатусыДокументовЭДО.ОтказаноВПодписиКонтрагенту);
		
		СостояниеИсходящегоДокументаЗапрещаетАннулирование = (Направление = НаправленияДокументов.Исходящее
			И (Статус = СтатусыДокументовЭДО.КонтрагентОтказалВПодписи
				Или Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить
				Или Статус = СтатусыДокументовЭДО.ОшибкаДоставкиЧерезРоуминг));
		
		СостояниеВходящегоДокументаЗапрещаетАннулирование = (Направление = НаправленияДокументов.Входящее
			И (СтрНайтиЛок(Статус, СтатусыДокументовЭДО.ТребуетсяПодписатьИзвещение) > 0
				Или СтрНайтиЛок(Статус, СтатусыДокументовЭДО.ТребуетсяПодпись) > 0
				Или ((СтрНайтиЛок(Статус, СтатусыДокументовЭДО.ОжидаетсяУточнение) > 0
					И НЕ ЗначениеЗаполнено(ТитулПокупателя.Данные))
					И НЕ ЭтоСФ)
				Или Статус = "В подписи отказано" // устаревший статус, для совместимости
				Или Статус = СтатусыДокументовЭДО.ОтказаноВПодписиКонтрагенту));
		
		СостояниеВнутреннегоДокументаЗапрещаетАннулирование = (Направление = НаправленияДокументов.Внутреннее
			И (Статус = СтатусыДокументовЭДО.ТребуетсяПодписьПолучателя
				Или Статус = СтатусыДокументовЭДО.ПолучательОтказалВПодписи
				Или Статус = СтатусыДокументовЭДО.ТребуетсяПодписатьИОтправить));
		
		АннулированиеДокументаЗапрещено = НЕ ЗначениеЗаполнено(Статус)
			Или СостояниеДокументаЗапрещаетАннулирование
			Или СостояниеИсходящегоДокументаЗапрещаетАннулирование
			Или СостояниеВходящегоДокументаЗапрещаетАннулирование
			Или СостояниеВнутреннегоДокументаЗапрещаетАннулирование;
		
		Результат = НЕ АннулированиеДокументаЗапрещено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноОтказатьВАннулировании(Документ)
	
	СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();
	
	Статус = Документ.Статусы.Статус;
	
	Результат = НЕ Документ.Шаблон 
				И Статус = СтатусыДокументовЭДО.ТребуетсяАннулирование;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноАннулироватьШаблон(Документ)
	
	СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();
	
	Статус = Документ.Статусы.Статус;
	
	Результат = Документ.Шаблон
				И (Статус = СтатусыДокументовЭДО.Обработан
					ИЛИ Статус = СтатусыДокументовЭДО.ТребуетсяСоздатьДокумент);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноЗаполнитьДопСведения(Документ)
	
	Результат = Ложь;
	
	ДокументОтправлен = Документы_ДокументОтправлен(Документ);
	
	Если НЕ ДокументОтправлен Тогда
		
		ТипыКонтентов = Перечисление_ТипыКонтентов();
		ТипКонтента	= Документ.Тип.ТипКонтента;
		
		Результат = (ТипКонтента = ТипыКонтентов.utd970
			ИЛИ ТипКонтента = ТипыКонтентов.utd820
			ИЛИ ТипКонтента = ТипыКонтентов.ucd736
			ИЛИ ТипКонтента = ТипКонтента_proformainvoice29()
			ИЛИ ТипКонтента = ТипКонтента_invoiceoffer29());

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МожноЗаполнитьСведенияОбАвансах(Документ)
	
	Результат = Ложь;
	
	ДокументОтправлен = Документы_ДокументОтправлен(Документ);
	
	Если НЕ ДокументОтправлен Тогда
		
		ТипыКонтентов = Перечисление_ТипыКонтентов();
		ТипКонтента = Документ.Тип.ТипКонтента;
		
		Результат = (ТипКонтента = ТипыКонтентов.utd970);

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтатусОшибочногоДействия(Документ) Экспорт
	
	Результат = Ложь;
	
	Статус = НРег(Документ.Статусы.Статус);
	
	Если Статус = "аннулирован" Тогда
		Результат = Истина;
	Иначе
		
		МаркерыСтатуса = Новый Массив;
		МаркерыСтатуса.Добавить("ошибка");
		МаркерыСтатуса.Добавить("отказ");
		МаркерыСтатуса.Добавить("отклонен");
		МаркерыСтатуса.Добавить("отозван");
		
		Для Каждого Маркер Из МаркерыСтатуса Цикл
			
			Если Найти(Статус, Маркер) > 0 Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтатусТребуетДействия(Документ) Экспорт
	
	Результат = Ложь;
	
	Статус					= НРег(Документ.Статусы.Статус);
	ДополнительныйСтатус	= НРег(Документ.Статусы.ДополнительныйСтатус);

	МаркерыСтатуса = Новый Массив;
	МаркерыСтатуса.Добавить("требуется");
	МаркерыСтатуса.Добавить("на согласовании");
	МаркерыСтатуса.Добавить("на подписании");
	МаркерыСтатуса.Добавить("на аннулировании");
	
	Для Каждого Маркер Из МаркерыСтатуса Цикл
		
		Если Найти(Статус, Маркер) > 0 
			ИЛИ Найти(ДополнительныйСтатус, Маркер) > 0 Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтатусОжидаетДействия(Документ) Экспорт
	
	Результат = Ложь;
	
	Статус = НРег(Документ.Статусы.Статус);
	
	МаркерыСтатуса = Новый Массив;
	МаркерыСтатуса.Добавить("ожидается");
	МаркерыСтатуса.Добавить("завершен");
	
	Для Каждого Маркер Из МаркерыСтатуса Цикл
		
		Если Найти(Статус, Маркер) > 0 Тогда 
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


Функция Документы_ДоступноПодписаниеБезОтправки()

	РазрешитьПодписаниеБезОтправки = ОбщиеНастройки_Прочитать("РазрешитьПодписаниеБезОтправки");
	
	Результат = (РазрешитьПодписаниеБезОтправки = Истина);
	
	Возврат Результат; 
	
КонецФункции

// ДОСТУПНЫЕ ДОКУМЕНТЫ ДЛЯ ВЫПОЛНЕНИЯ ДЕЙСТВИЯ

Функция Документы_ДоступныеДляСогласованияДокументы(МассивДокументов, Действие) Экспорт 
	
	Результат = Новый Массив;
	
	Для Каждого Документ Из МассивДокументов Цикл
		
		Если НЕ Документ.Шаблон Тогда
			
			ДействиеМожноВыполнить = Документы_ДоступноДействиеМаршрутизации(Документ, Действие);
			
			Если ДействиеМожноВыполнить Тогда
				Результат.Добавить(Документ);
			Иначе
				
				ПредставленияДействийЭДО	= Перечисление_ПредставленияДействийЭДО();
				ВидОперации					= ПредставленияДействийЭДО[Действие];
				ПредставлениеДокумента		= Документы_ПредставлениеДокумента(Документ);
				ТекстСообщения				= "Для документа " + ПредставлениеДокумента + " нельзя выполнить действие: " + НРег(ВидОперации) + ".";
				
				СписокОшибок_ДобавитьОшибку("Согласование", ТекстСообщения);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДоступныеДляАннулированияДокументы(МассивДокументов, Действие) Экспорт 
	
	Результат				= Новый Массив;
	ЗакрытыеПакетыКУдалению = Новый Массив;
	
	ВариантыДействий = Перечисление_ВариантыОтветаПоДокументу();
	
	Для Каждого Документ Из МассивДокументов Цикл
		
		BoxId = Документ.Идентификаторы.BoxId;
		LetterId = Документ.Идентификаторы.LetterId;
		
		ЗаблокированныйПакет = Документ.Заблокирован;
		
		ДоступноПодписаниеСертификатом = Документы_ДоступноПодписаниеСертификатом(Документ);
		
		Если Действие = ВариантыДействий.АннулироватьШаблон Тогда
			
			МожноВыполнитьДействие = Документы_МожноАннулироватьШаблон(Документ);
		
		ИначеЕсли Действие = ВариантыДействий.Аннулировать Тогда
			
			МожноВыполнитьДействие = Документы_МожноАннулировать(Документ)
									И ДоступноПодписаниеСертификатом;
					
		ИначеЕсли Действие = ВариантыДействий.ОтказатьВАннулировании Тогда
			
			МожноВыполнитьДействие = Документы_МожноОтказатьВАннулировании(Документ);
			
			ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
			
			Если ФормироватьУС = Неопределено Тогда
				МожноВыполнитьДействие = МожноВыполнитьДействие И ДоступноПодписаниеСертификатом;
			Иначе
				МожноВыполнитьДействие = МожноВыполнитьДействие И ФормироватьУС;
			КонецЕсли;
			
		Иначе
			
			ПредставлениеДокумента	= Документы_ПредставлениеДокумента(Документ);
			ТекстИсключения			= "Не удалось выполнить действие ""%1"" для документа %2";
			ТекстИсключения			= Общее_ПодставитьПараметрыВСтроку(ТекстИсключения, Действие, ПредставлениеДокумента);
			
			ВызватьИсключение ТекстИсключения;
			
		КонецЕсли;
		
		Если МожноВыполнитьДействие Тогда
			
			Результат.Добавить(Документ);
			
		ИначеЕсли ЗаблокированныйПакет И ЗакрытыеПакетыКУдалению.Найти(LetterId) = Неопределено Тогда
			
			ЗакрытыеПакетыКУдалению.Добавить(LetterId);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗакрытыеПакетыКУдалению.Количество() > 0 Тогда
		
		Для ИндексДокумента = -Результат.ВГраница() По 0 Цикл
			
			LetterId = Результат[-ИндексДокумента].Идентификаторы.LetterId;
			
			Если ЗакрытыеПакетыКУдалению.Найти(LetterId) <> Неопределено Тогда 
				Результат.Удалить(-ИндексДокумента);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДоступныеДляПерезаполненияИОтправки(СтрокиСписка) Экспорт 
	
	Результат = Новый Массив;
	
	Для Каждого СтрокаСписка Из СтрокиСписка Цикл
		
		Если ЗначениеЗаполнено(СтрокаСписка.Статус)
			И ЗначениеЗаполнено(СтрокаСписка.ВидПакетаID)
			И СтрокаСписка.Статус <> Перечисление_СтатусыДокументов().ТребуетсяПодписатьИОтправить
			И СтрокаСписка.Метка <> Перечисление_СтатусыПакетов().Переотправлен
			И СтрокаСписка.Метка <> Перечисление_СтатусыПакетов().ЗагруженИзДиадок Тогда
			
			Результат.Добавить(СтрокаСписка);
			
		Иначе
			
			ШаблонСообщения				= "Для документа %1 нельзя выполнить действие: %2. ";
			
			ПредставленияДействийЭДО	= Перечисление_ПредставленияДействийЭДО();
			ВидОперации					= ПредставленияДействийЭДО.ПерезаполнитьИОтправить;
			ПредставлениеДокумента		= СтрокаСписка.ПредставлениеДокументаДиадок;
			ТекстСообщения				= Общее_ПодставитьПараметрыВСтроку(ШаблонСообщения, ПредставлениеДокумента, НРег(ВидОперации));
			
			ДокументОтправленЧерезМодульСтандарт = (
				ЗначениеЗаполнено(СтрокаСписка.Документ)
				И НЕ ЗначениеЗаполнено(СтрокаСписка.ВидПакетаID)
			);
			
			Если НЕ ЗначениеЗаполнено(СтрокаСписка.Статус) Тогда
				ТекстСообщения = ТекстСообщения + "Неизвестный статус. Выполните обмен с сервером и повторите попытку.";
			ИначеЕсли ДокументОтправленЧерезМодульСтандарт Тогда
				ТекстСообщения = ТекстСообщения + "Воспользуйтесь кнопкой ""Отвязать"" в карточке документа.";
			КонецЕсли;
			
			СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстСообщения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДоступныеДляПодписанияВходящие(Документы, Действие) Экспорт 
	
	Результат = Новый Массив;
	
	Для Каждого Документ Из Документы Цикл
		
		МожноПодписать = Документы_МожноПодписатьВходящий(Документ);
		
		Если МожноПодписать Тогда
			Результат.Добавить(Документ);
		Иначе
				
			ПредставленияДействийЭДО	= Перечисление_ПредставленияДействийЭДО();
			ВидОперации					= ПредставленияДействийЭДО[Действие];
			ПредставлениеДокумента		= Документы_ПредставлениеДокумента(Документ);
			ТекстСообщения				= "Для документа " + ПредставлениеДокумента + " нельзя выполнить действие: " + НРег(ВидОперации) + ".";
			
			СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстСообщения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// СОЗДАНИЕ/СОПОСТАВЛЕНИЕ ДОКУМЕНТОВ

// Устарела. Следует использовать Документы_СоздатьДокументыПоПравилу
//
Функция Документы_СоздатьДокументы(ДокументыДляОбработки,
								   ИдентификаторОперации,
								   ДополнительныеПараметры = Неопределено,
								   АдресНоменклатурыДляСопоставления = Неопределено) Экспорт 
	
	Перем НоменклатураДляСопоставления;
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		
		Документы_СоздатьДокумент(
			Документ,
			ИдентификаторОперации,
			НоменклатураДляСопоставления,
			ДополнительныеПараметры
		);
		
	КонецЦикла;
	
	Если АдресНоменклатурыДляСопоставления = Неопределено Тогда
		
		Результат = НоменклатураДляСопоставления;
		
	Иначе
		
		НоменклатураДляСопоставленияИзХранилища = ПолучитьИзВременногоХранилища(АдресНоменклатурыДляСопоставления);
		Документы_ДобавитьНоменклатуруДляСопоставления(НоменклатураДляСопоставленияИзХранилища, НоменклатураДляСопоставления);
		ПоместитьВоВременноеХранилище(НоменклатураДляСопоставленияИзХранилища, АдресНоменклатурыДляСопоставления);
		
		Результат = АдресНоменклатурыДляСопоставления;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Конструктор дополнительных параметров для создания учетных документов.
// 
// @СлужебныйПрограммныйИнтерфейс
// 
// Возвращаемое значение:
//  Структура.
//
Функция ДополнительныеПараметрыСозданияДокумента() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ЦенаВключаетНДС", Ложь);
	Результат.Вставить("Контрагент");
	
	Возврат Результат;
	
КонецФункции

// Возвращает параметры создания из Документа 
//
// Параметры:
//  ДокументУчета - Структура - описание электронного документа см. Контракт_Документ.
// 
// Возвращаемое значение:
//  Структура - содержит параметры для использования в методе Ядро.Документы_СоздатьДокументыПоПравилу:
//    * ИдентификаторОперации - Строка - Идентификатор операции создания документов.
//    * ДополнительныеПараметры - Структура - См. Ядро.ДополнительныеПараметрыСозданияДокумента.
//
Функция ПараметрыСозданияИзДокумента(ДокументУчета)
	
	ПараметрыСозданияИзДокумента = СвойствоСтруктуры(ДокументУчета.СлужебнаяИнформация, "ПараметрыСоздания", Новый Структура);
	
	ДополнительныеПараметры				 = ДополнительныеПараметрыСозданияДокумента(); 
	ДополнительныеПараметрыИзДокумента	 = СвойствоСтруктуры(ПараметрыСозданияИзДокумента, "ДополнительныеПараметры", Новый Структура);
	ЗаполнитьЗначенияСвойств(ДополнительныеПараметры, ДополнительныеПараметрыИзДокумента);
	
	ИдентификаторОперации = СвойствоСтруктуры(ПараметрыСозданияИзДокумента, "ИдентификаторОперации", "");
	
	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторОперации", ИдентификаторОперации);
	Результат.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	
	Возврат Результат;
	
КонецФункции

// На основании электронных документов создает учетные документы по указанному правилу.
// 
// @СлужебныйПрограммныйИнтерфейс
//
// Параметры:
//  ДокументИлиМассив - Структура, Массив из Структура - Электронные документы (см. Контракт_Документ).
// 
Функция Документы_СоздатьДокументыПоПравилу(ДокументИлиМассив) Экспорт
	
	Если ТипЗнч(ДокументИлиМассив) = Тип("Массив") Тогда
		КоллекцияДокументов = ДокументИлиМассив;
	Иначе
		КоллекцияДокументов = Новый Массив;
		КоллекцияДокументов.Добавить(ДокументИлиМассив);
	КонецЕсли;
	
	НастройкаСоздаватьПередаточныеДокументы	 = ЗначениеНастройки_СоздаватьПередаточныеДокументы();
	НастройкаСоздаватьСчетаФактуры			 = ЗначениеНастройки_СоздаватьСчетаФактуры();
	
	Для Каждого ТекущийДокумент Из КоллекцияДокументов Цикл
		
		ПараметрыСоздания = ПараметрыСозданияИзДокумента(ТекущийДокумент);
		ДополнительныеПараметры = ПараметрыСоздания.ДополнительныеПараметры;
		
		БазовыеПроверки = Новый Массив;
		
		Если ЗначениеЗаполнено(ТекущийДокумент.ДокументУчета) Тогда
			БазовыеПроверки.Добавить("Документ уже создан.");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекущийДокумент.Отправитель.Организация) Тогда
			БазовыеПроверки.Добавить("Не сопоставлен контрагент.");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекущийДокумент.Получатель.Организация) Тогда
			БазовыеПроверки.Добавить("Не сопоставлена организация.");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(БазовыеПроверки) Тогда
			Документы_ОшибкаПриСоздании(ТекущийДокумент, БазовыеПроверки);
			Продолжить;
		КонецЕсли;
		
		Если НастройкаСоздаватьСчетаФактуры 
			И НЕ НастройкаСоздаватьПередаточныеДокументы Тогда
		
			РеквизитыДокументаИзБазы = ХранениеДанных_ДанныеДокумента(ТекущийДокумент.Идентификаторы);
			Если ЗначениеЗаполнено(РеквизитыДокументаИзБазы.ДокументУчета) Тогда
				// Это раздельный пакет и СФ уже созданна при создании накладной
				Продолжить;
			КонецЕсли; 
		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДополнительныеПараметры.Контрагент) Тогда
			// Пользователь переопределил контрагента в форме создания документов
			ТекущийДокумент.Отправитель.Организация = ДополнительныеПараметры.Контрагент;
		КонецЕсли;
		
		ИдентификаторОперации = ПараметрыСоздания.ИдентификаторОперации;
		
		РезультатСоздания = ОбработкаСозданияДокументаУчетаПМ(ТекущийДокумент, ИдентификаторОперации, ДополнительныеПараметры);
		
		Если РезультатСоздания.Отказ Тогда
			Документы_ОшибкаПриСоздании(ТекущийДокумент, РезультатСоздания.Ошибки);
			Продолжить;
		КонецЕсли;
		
		ЗаполненныйОбъект = РезультатСоздания.ЗаполненныйОбъект;
		
		НачатьТранзакцию();
		
		Попытка
			
			ТипЗначения			= ТипЗнч(ЗаполненныйОбъект);
			ОбъектМетаданных	= Метаданные.НайтиПоТипу(ТипЗначения);
			
			ЭтоДокумент		= Метаданные.Документы.Содержит(ОбъектМетаданных);
			ЭтоСправочник	= Метаданные.Справочники.Содержит(ОбъектМетаданных);
			ЭтоПВХ			= Метаданные.ПланыВидовХарактеристик.Содержит(ОбъектМетаданных);
			
			Если ЭтоДокумент Тогда
				
				Если Не ЗначениеЗаполнено(ЗаполненныйОбъект.Номер) Тогда
					ЗаполненныйОбъект.УстановитьНовыйНомер();
				КонецЕсли;
				
			ИначеЕсли ЭтоСправочник ИЛИ ЭтоПВХ Тогда
				
				Если Не ЗначениеЗаполнено(ЗаполненныйОбъект.Код) Тогда
					ЗаполненныйОбъект.УстановитьНовыйКод();
				КонецЕсли;
				
			КонецЕсли;
			
			Если ЗаполненныйОбъект.Модифицированность() Тогда
				ЗаполненныйОбъект.Записать();
			КонецЕсли;
			
			Документы_УстановитьСвязьСДокументом(ТекущийДокумент.Идентификаторы, ЗаполненныйОбъект.Ссылка);	
			
			ТекущийДокумент.ДокументУчета = ЗаполненныйОбъект.Ссылка;
			
			Документы_ОбновитьКомментарийДокументаУчета(ТекущийДокумент, ЗаполненныйОбъект);
			
			МетрикиКонтур_ЗаписатьСобытие_СозданиеДокумента1С(ТекущийДокумент.Получатель.BoxId);
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ИнформацияОбОшибке = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Документы_ОшибкаПриСоздании(ТекущийДокумент, ИнформацияОбОшибке);
			
			ВызватьИсключение;
			
		КонецПопытки;
		
		Метрика_ДобавитьСтатистику_СозданиеДокументов(ТекущийДокумент, ИдентификаторОперации, ДополнительныеПараметры);
		
	КонецЦикла;
	
	Возврат Неопределено; // Функция используется как процедура, результат не важен.
	
КонецФункции

// На основании электронных документов создает учетные документы по указанному правилу.
// 
// @СлужебныйПрограммныйИнтерфейс
//
// Параметры:
//  ПакетИлиМассив - Структура, Массив из Структура - Электронные документы (см. Контракт_Пакет).
// 
Функция Пакеты_СоздатьДокументыПоПравилу(ПакетИлиМассив) Экспорт
	
	Если ТипЗнч(ПакетИлиМассив) = Тип("Массив") Тогда
		КоллекцияПакетов = ПакетИлиМассив;
	Иначе
		КоллекцияПакетов = Новый Массив;
		КоллекцияПакетов.Добавить(ПакетИлиМассив);
	КонецЕсли;
	
	Для Каждого ТекущийПакет Из ПакетИлиМассив Цикл
		
		ДокументыДляСоздания = ТекущийПакет.Документы; 
		
		СортироватьДокументыПакетаПередСозданием(ДокументыДляСоздания);
		
		Документы_СоздатьДокументыПоПравилу(ДокументыДляСоздания);
		
	КонецЦикла;
	
	Возврат Неопределено; // Функция используется как процедура, результат не важен.
	
КонецФункции

// СФ при создании раздельного пакета должна создаваться в последнюю очередь
//
// Параметры:
//  ДокументыПакета - Массив из Структура - Электронные документы (см. Контракт_Документ).
// 
Процедура СортироватьДокументыПакетаПередСозданием(ДокументыПакета)
	
	Если ДокументыПакета.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаСортировки = Новый ТаблицаЗначений;
	ТаблицаСортировки.Колонки.Добавить("Документ");
	ТаблицаСортировки.Колонки.Добавить("Приоритет");
	
	Для каждого ДокументПакета Из ДокументыПакета Цикл
		
		ФункцияДокумента = ДокументПакета.Тип.ФункцияДокумента;
		ТипДокумента	 = ДокументПакета.Тип.ТипДокумента;
		
		НоваяСтрока = ТаблицаСортировки.Добавить();
		НоваяСтрока.Документ = ДокументПакета;
		НоваяСтрока.Приоритет = 1;
		
		Если ТипДокумента = Тип_СФ()
			ИЛИ ФункцияДокумента = Функция_СЧФ() Тогда
			
			НоваяСтрока.Приоритет = 9;
			
		КонецЕсли;
		
	КонецЦикла; 
	
	ТаблицаСортировки.Сортировать("Приоритет Возр");
	
	ДокументыПакета = ТаблицаСортировки.ВыгрузитьКолонку("Документ");
	
КонецПроцедуры

Функция ОбработкаСозданияДокументаУчетаПМ(
		ТекущийДокумент,
		ИдентификаторОперации,
		ПараметрыСоздания,
		ДополнительныеПараметрыПМ = Неопределено
	)
	
	Если ДополнительныеПараметрыПМ = Неопределено Тогда
		ДополнительныеПараметрыПМ = Новый Структура;
	КонецЕсли;
	
	ДополнительныеПараметрыПМ.Вставить("ЦенаВключаетНДС", ПараметрыСоздания.ЦенаВключаетНДС);
	
	Если ЗначениеЗаполнено(ИдентификаторОперации) Тогда // Для совместимости с ПМ предыдущих версий
		ДополнительныеПараметрыПМ.Вставить("ВыбранныйВид", ИдентификаторОперации);
	КонецЕсли;
	
	Отказ = Ложь;
	Ошибки = Новый Массив;
	
	Попытка
	
		РезультатОбработчика = Интеграция_ПолучитьЗаполненныйОбъектДокумента1С(
				ТекущийДокумент,
				ИдентификаторОперации,
				ДополнительныеПараметрыПМ
		);
		
	Исключение
		
		Отказ = Истина;
		НеФормализованнаяОшибка = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации("Диадок.СозданиеДокумента", УровеньЖурналаРегистрации.Ошибка, , , ПодробноеПредставлениеОшибки(НеФормализованнаяОшибка));
		
		Ошибки.Добавить(КраткоеПредставлениеОшибки((НеФормализованнаяОшибка))); 
		
	КонецПопытки;
	
	Если ТипЗнч(РезультатОбработчика) = Тип("Структура") Тогда
		
		ОписаниеОшибкиПМ = СвойствоСтруктуры(РезультатОбработчика, "ОписаниеОшибки");
		ЗаполненныйОбъект = СвойствоСтруктуры(РезультатОбработчика, "ОсновнойОбъект");
		НоваяНоменклатура = СвойствоСтруктуры(РезультатОбработчика, "ТаблицаНоменклатурыДляСопоставления");
		
	Иначе
		
		ЗаполненныйОбъект = РезультатОбработчика;
		НоваяНоменклатура = Неопределено;
		
	КонецЕсли;
	
	Если ЗаполненныйОбъект = Неопределено Тогда
		
		Отказ = Истина;
		Если ЗначениеЗаполнено(ОписаниеОшибкиПМ) Тогда
			Ошибки.Добавить(ОписаниеОшибкиПМ);
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Отказ", Отказ);
	Результат.Вставить("Ошибки", Ошибки);
	Результат.Вставить("ЗаполненныйОбъект", ЗаполненныйОбъект);
	Результат.Вставить("ТаблицаСопоставленияНоменклатуры", НоваяНоменклатура);
	
	Возврат Результат;
	
КонецФункции

// Устарела. Следует использовать Документы_СоздатьДокументыПоПравилу
//
Процедура Документы_СоздатьДокумент(Документ, ИдентификаторОперации, НоменклатураДляСопоставления, ДополнительныеПараметрыПМ = Неопределено)
	
	ОписаниеОшибки		= "";
	ОписаниеОшибкиПМ	= "";
	ДокументНеСоздан	= Ложь;
	
	Если ЗначениеЗаполнено(Документ.ДокументУчета) Тогда
		
		ОписаниеОшибки = "Документ уже создан.";
		
	ИначеЕсли НЕ ЗначениеЗаполнено(Документ.Отправитель.Организация) Тогда
		
		ОписаниеОшибки = "Не сопоставлен контрагент.";
		
	ИначеЕсли НЕ ЗначениеЗаполнено(Документ.Получатель.Организация) Тогда
		
		ОписаниеОшибки = "Не сопоставлена организация.";
		
	Иначе
		
		ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
		
		Если ХранилищеКонтента = Неопределено Тогда
			
			ХранилищеКонтента = Документы_Расшифровать(Документ.Идентификаторы);
			Документ.Документооборот.Вставить("ХранилищеКонтента", ХранилищеКонтента);
			
		КонецЕсли;
		
		ПараметрыСоздания = ДополнительныеПараметрыСозданияДокумента();
		
		РезультатСоздания = ОбработкаСозданияДокументаУчетаПМ(
			Документ,
			ИдентификаторОперации,
			ПараметрыСоздания,
			ДополнительныеПараметрыПМ
		);
		
		ОписаниеОшибкиПМ = РезультатСоздания.Ошибки;
		Документ1СОбъект = РезультатСоздания.ЗаполненныйОбъект;
		НоваяНоменклатура = РезультатСоздания.ТаблицаСопоставленияНоменклатуры;
		
		Если ЗначениеЗаполнено(НоваяНоменклатура) Тогда
			Документы_ДобавитьНоменклатуруДляСопоставления(НоменклатураДляСопоставления, НоваяНоменклатура);
		Иначе
			ОписаниеОшибки = ОписаниеОшибкиПМ;
			ДокументНеСоздан = (Документ1СОбъект = Неопределено);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки)
		ИЛИ ДокументНеСоздан Тогда
		
		Документы_ОшибкаПриСоздании(Документ, ОписаниеОшибки);
		
	Иначе
		
		Если Документ1СОбъект <> Неопределено
			И НЕ ЗначениеЗаполнено(ОписаниеОшибкиПМ) Тогда
			
			
			НачатьТранзакцию();
			
			Попытка
				
				Если Документ1СОбъект.Модифицированность() Тогда
					Документ1СОбъект.Записать();
				КонецЕсли;
				
				Документы_УстановитьСвязьСДокументом(Документ.Идентификаторы, Документ1СОбъект.Ссылка); 
				
				Документ.ДокументУчета = Документ1СОбъект.Ссылка;
				
				Документы_ОбновитьКомментарийДокументаУчета(Документ, Документ1СОбъект);
				
				МетрикиКонтур_ЗаписатьСобытие_СозданиеДокумента1С(Документ.Получатель.BoxId);
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ИнформацияОбОшибке = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				Документы_ОшибкаПриСоздании(Документ, ИнформацияОбОшибке);
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				ВызватьИсключение;
				
			КонецПопытки;
			
			Метрика_ДобавитьСтатистику_СозданиеДокументов(Документ, ИдентификаторОперации, ПараметрыСоздания);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Логирует ошибки при создании учетных документов.
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ.
//  ОшибкаИлиМассив - Строка, Массив из Строка - сведения об ошибках.
//
Процедура Документы_ОшибкаПриСоздании(Документ, ОшибкаИлиМассив = "") Экспорт
	
	ВидОперации		 	= "Создание входящих документов учета";
	Представление		= Документы_ПредставлениеДокумента(Документ);
	ДопИнформация		= "Документ: " + Представление;
	ТекстОшибки			= "Не удалось создать входящий документ учета %1";
	ТекстОшибки			= Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Представление);
	
	Если ТипЗнч(ОшибкаИлиМассив) = Тип("Массив") Тогда
		Ошибки = ОшибкаИлиМассив;
	Иначе
		Ошибки = Новый Массив;
		Ошибки.Добавить(ОшибкаИлиМассив);
	КонецЕсли;
	
	ИнформацияОбОшибке = СоединитьСтроку(Ошибки, Символы.ПС);
	
	Ошибка_Обработать(ВидОперации, ИнформацияОбОшибке, ДопИнформация, ТекстОшибки);
	
КонецПроцедуры	

Функция Документы_СопоставитьДокумент(Документ) Экспорт
	
	ОписаниеОшибки	= "";
	
	Документ1С	= Документ.ДокументУчета;
	ДокументЭДО	= Документ.Идентификаторы.ДокументЭДО;
	
	Если ЗначениеЗаполнено(Документ1С) Тогда
		
		ОписаниеОшибки = "Документ уже сопоставлен.";
		
	ИначеЕсли НЕ ЗначениеЗаполнено(Документ.Отправитель.Организация) Тогда
		
		ОписаниеОшибки = "Не сопоставлен контрагент.";
		
	ИначеЕсли НЕ ЗначениеЗаполнено(Документ.Получатель.Организация) Тогда
		
		ОписаниеОшибки = "Не сопоставлена организация.";
		
	Иначе
		
		ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
		
		Если ХранилищеКонтента = Неопределено Тогда
			
			ХранилищеКонтента = Документы_Расшифровать(Документ.Идентификаторы);
			Документ.Документооборот.Вставить("ХранилищеКонтента", ХранилищеКонтента);
			
		КонецЕсли;
				
		РезультатПМ = Интеграция_НайтиСопоставлениеДокумента(Документ);
						
		Если НЕ ЗначениеЗаполнено(РезультатПМ) Тогда
			
			ОписаниеОшибки = "Автоматически не нашли подходящий документ.";
			
		ИначеЕсли ТипЗнч(РезультатПМ) = Тип("Массив") Тогда
			
			Если РезультатПМ.Количество() = 1 Тогда
				
				Документ1С = РезультатПМ[0];
				
			Иначе
				
				// В этом случае дадим пользователю выбор - но уже в какой-нибудь интерактивной форме, когда будет ручное сопоставление
				ОписаниеОшибки = "Найдено более одного документа для сопоставления.";
				
			КонецЕсли;
			
		Иначе
			
			Документ1С = РезультатПМ;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Документ1С)
			И НЕ Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Документ1С))
			И НЕ Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Документ1С)) Тогда
			
			ОписаниеОшибки = НСтр("ru = 'Неверный тип возврата в событии подключаемого модуля ""НайтиСопоставлениеДокумента""'");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ВидОперации		= "Сопоставление документов";
		Представление	= Документы_ПредставлениеДокумента(Документ);
		ДопИнформация	= "Документ: " + Представление;
		ТекстОшибки		= "Не сопоставлен по причине: %1 Воспользуйтесь ручным сопоставлением в карточке документа.";
		ТекстОшибки		= Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, ОписаниеОшибки);
		
		Ошибка_Обработать(ВидОперации, , ДопИнформация, ТекстОшибки);
		
	Иначе 
		
		Попытка
			
			Документы_УстановитьСвязьСДокументом(Документ.Идентификаторы, Документ1С); 
			
			Документ.ДокументУчета = Документ1С;
			
			Документы_ОбновитьКомментарийДокументаУчета(Документ);
			
		Исключение
			
			ВидОперации		 = НСтр("ru = 'Сопоставление электронного документа с документом учета'");
			ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ДопИнформация	 = Общее_ПодставитьПараметрыВСтроку(НСтр("ru = 'Электронный документ: %1'"), ДокументЭДО);
			ТекстСообщения	 = НСтр("ru = 'Не удалось сопоставить электронный документ с документом учета'");
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
			ВызватьИсключение;
			
		КонецПопытки;
		
		Метрика_ДобавитьСтатистику_СопоставлениеДокументов(Документ, "Сопоставить");
		
	КонецЕсли;
	
	Возврат Документ1С;
	
КонецФункции

// Сопоставляет переданные документы с документом 1С
//
// Параметры:
//  ДокументыДляСопоставления - Массив из Структура - Массив контрактов электронных документов (см. Контракт_Документ).
//
Функция Документы_СопоставитьДокументы(ДокументыДляСопоставления) Экспорт
	
	Для каждого ДокументДляСопоставления Из ДокументыДляСопоставления Цикл
	
		Результат = Документы_СопоставитьДокумент(ДокументДляСопоставления);
	
	КонецЦикла;
	
	Возврат Неопределено; // Функция используется как процедура, результат не важен.
	
КонецФункции

// Возвращает значение реквизитов номер и дата документа учета
//
// Параметры:
//  Документ		 - Структура - см. Контракт_Документ
//  СсылкаНаОбъект	 - ДокументСсылка - Ссылка на документ учета
// 
// Возвращаемое значение:
// РеквизитыДокументаУчета - Структура - Коллекция в которой находятся реквизиты и их соответствия в случае отсутствия ИМ возвращает Неопределено
// 	- Номер - Строка - номер учетного документа
// 	- Дата - Дата - дата учетного документа
//
Функция Документы_Сопоставление_ПолучитьРеквизитыДляПроверки(СсылкаНаОбъект) Экспорт
	
	Результат = Неопределено;
	
	Если ЕстьИнтеграционныйМодуль() Тогда
		Результат = МенеджерИнтеграции_ПолучитьРеквизитыДокументаУчета_НомерДата(СсылкаНаОбъект);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет значение реквизитов номер и дата документа учета
//
// Параметры:
//  СсылкаНаОбъект	 	- ДокументСсылка - Ссылка на документ учета
//  Номер	 			- Строка - Номер документа учета для заполнения
//  Дата	 			- Дата - Дата документа учета для заполнения
//
Процедура Документы_Сопоставление_ОбновитьРеквизитыУчетногоДокумента(СсылкаНаОбъект, Номер, Дата) Экспорт
	
	Попытка
		
		ОбъектОбработки = СсылкаНаОбъект.ПолучитьОбъект();
		
		МенеджерИнтеграции_ЗаполнитьРеквизитыДокументаУчета_НомерДата(ОбъектОбработки, Номер, Дата);
		
		ОбъектОбработки.Записать();
		
	Исключение
		
		ВидОперации		 = "Обновление реквизитов учетного документа";
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения	 = "Не удалось обновить реквизиты";
		ДопИнформация	 = "Документ: " + СокрЛП(СсылкаНаОбъект);
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура Документы_ДобавитьНоменклатуруДляСопоставления(НоменклатураДляСопоставления, НоваяНоменклатура)
	
	Если НЕ ЗначениеЗаполнено(НоваяНоменклатура) Тогда
		Возврат;
	КонецЕсли;
	
	Если НоменклатураДляСопоставления = Неопределено Тогда
		
		НоменклатураДляСопоставления = НоваяНоменклатура.СкопироватьКолонки();
		
		Если НоменклатураДляСопоставления.Индексы.Количество() = 0 Тогда
			
			КолонкиИндекса	= "";
			Разделитель		= "";
			
			Для Каждого Колонка Из НоменклатураДляСопоставления.Колонки Цикл
				КолонкиИндекса	= КолонкиИндекса + Разделитель + Колонка.Имя;
				Разделитель		= ", ";
			КонецЦикла;
			
			НоменклатураДляСопоставления.Индексы.Добавить(КолонкиИндекса);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Отбор = Новый Структура;
	
	Для Каждого Колонка Из НоменклатураДляСопоставления.Колонки Цикл
		Отбор.Вставить(Колонка.Имя);
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из НоваяНоменклатура Цикл
		
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаТЗ);
		
		ТакаяСтрокаУжеЕсть = ЗначениеЗаполнено(НоменклатураДляСопоставления.НайтиСтроки(Отбор));
		
		Если НЕ ТакаяСтрокаУжеЕсть Тогда
			НоваяСтрока = НоменклатураДляСопоставления.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЕсли;
		
	КонецЦикла;
	
	Документы_ДополнитьКолонкиТаблицыСопоставленияНоменклатуры(НоменклатураДляСопоставления);
	
КонецПроцедуры

//Дополниет таблицу сопоставления номенклатуры колонкой НоменклатураКонтрагента при ее отсутствии. 
//Необходимо для совместимости с ПМ ниже 4 версии
//
Процедура Документы_ДополнитьКолонкиТаблицыСопоставленияНоменклатуры(НоменклатураДляСопоставления)
	
	Если НоменклатураДляСопоставления.Колонки.Найти("НоменклатураКонтрагента") = Неопределено Тогда
		
		НоменклатураДляСопоставления.Колонки.Добавить("НоменклатураКонтрагента", Новый ОписаниеТипов()); 
		
		Для каждого СтрокаТЗ Из НоменклатураДляСопоставления Цикл
			СтрокаТЗ.НоменклатураКонтрагента = Новый_НоменклатураКонтрагента();
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ПолучитьТабличнуюЧастьИзКонтентаXML(Контент) Экспорт
	
	Результат = ГенерацияXML_ПолучитьТабличнуюЧастьИзКонтентаXML(Контент);
	
	Для Каждого СтрокаТЧ Из Результат Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТЧ.ИдентификаторНоменклатуры) Тогда
			СтрокаТЧ.ИдентификаторНоменклатуры = Номенклатура_СформироватьИдентификаторНоменклатурыКонтрагента(СтрокаТЧ.НоменклатураДокумента);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ОтвязатьДокумент(Идентификаторы) Экспорт
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("ДокументУчета", Неопределено);
	СтруктураРеквизитов.Вставить("Контрагент", Неопределено);
	СтруктураРеквизитов.Вставить("Организация", Неопределено);
	
	ХранениеДанных_ОбновлениеРеквизитовДокумента(Идентификаторы, СтруктураРеквизитов);
	
КонецПроцедуры

Процедура Документы_УстановитьСвязьСДокументом(Идентификаторы, СсылкаНаОбъект) Экспорт
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("ДокументУчета", СсылкаНаОбъект);
	
	УчетныеДокументы = Новый Массив;
	УчетныеДокументы.Добавить(СсылкаНаОбъект);
	
	ЗначенияРеквизитовДокументов = МенеджерИнтеграции_ЗначенияРеквизитовДокументовУчета(УчетныеДокументы);
	ЗначенияРеквизитов = ЗначенияРеквизитовДокументов.Получить(СсылкаНаОбъект);
	
	Если ЗначениеЗаполнено(ЗначенияРеквизитов) Тогда
		
		Если ЗначенияРеквизитов.Свойство("Контрагент") Тогда 
			СтруктураРеквизитов.Вставить("Контрагент",  ЗначенияРеквизитов.Контрагент);
		КонецЕсли; 
		Если ЗначенияРеквизитов.Свойство("Организация") Тогда 
			СтруктураРеквизитов.Вставить("Организация",  ЗначенияРеквизитов.Организация);
		КонецЕсли;
		
	КонецЕсли;
	
	ХранениеДанных_ОбновлениеРеквизитовДокумента(Идентификаторы, СтруктураРеквизитов);
	
	МетрикиКонтур_ЗаписатьСобытие_СопоставлениеДокумента1С(Идентификаторы.BoxId);
	
КонецПроцедуры

// СОПОСТАВЛЕНИЕ НОМЕНКЛАТУРЫ

// Получает номенклатуру информационной базы, сопоставленную с номенклатурой электронного документа.
//
// Параметры:
//  ВладелецНоменклатуры - СправочникСсылка - Владелец номенклатуры (контрагент/партнер).
//  ИдентификаторыНоменклатуры - Строка, Массив из Строка - идентификаторы номенклатуры контрагента.
// 
// Возвращаемое значение:
//  Соответствие - содержит:
//    * Ключ - Строка - идентификатор номенклатуры контрагента.
//    * Значение - Структура - номенклатура информационной базы (см. Контракт_НоменклатураИнформационнойБазы)
//
Функция МенеджерИнтеграции_СопоставлениеНоменклатурыПрочитать(ВладелецНоменклатуры, ИдентификаторыНоменклатуры)
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Новый Соответствие;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	Результат = МенеджерИнтеграции.Номенклатура_СопоставлениеПрочитать(
		ВладелецНоменклатуры,
		ИдентификаторыНоменклатуры
	);
	
	Возврат Результат;
	
КонецФункции

// Записывает сопоставление номенклатуры электронного документа с номенклатурой информационной базы.
//
// Параметры:
//  НоменклатураКонтрагента - Структура - см. Контракт_НоменклатураКонтрагента
//  НоменклатураИБ - Структура - см. Контракт_НоменклатураИнформационнойБазы
//
Процедура МенеджерИнтеграции_СопоставлениеНоменклатурыЗаписать(НоменклатураКонтрагента, НоменклатураИБ) Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	МенеджерИнтеграции.Номенклатура_СопоставлениеЗаписать(
		НоменклатураКонтрагента,
		НоменклатураИБ
	);
	
КонецПроцедуры

// Формирует таблицу номенклатуры электронных документов и выполняет поиск
// сопоставленной номенклатуры информационной базы.
//
// @СлужебныйПрограммныйИнтерфейс: для вызова из формы создания учетных документов.
//
// Параметры:
//  ДокументИлиМассив - Структура, Массив из Структура - электронные документы (см. Контракт_Документ).
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
Функция Номенклатура_ТаблицаСопоставленияНоменклатуры(ДокументИлиМассив) Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументИлиМассив) Тогда
		ПервыйДокумент = Неопределено;
	ИначеЕсли ТипЗнч(ДокументИлиМассив) = Тип("Массив") Тогда
		ПервыйДокумент = ДокументИлиМассив[0];
	Иначе
		ПервыйДокумент = ДокументИлиМассив;
	КонецЕсли;
	
	КонтрагентИБ = Неопределено;
	Если ЗначениеЗаполнено(ПервыйДокумент) Тогда
		КонтрагентИБ = ПервыйДокумент.Отправитель.Организация;
	КонецЕсли;
	
	Результат = Новый_ТаблицаСопоставленияНоменклатуры(КонтрагентИБ);
	
	ПромежуточнаяТаблица = Номенклатура_ТаблицаНоменклатурыКонтрагентов(ДокументИлиМассив);
	
	Номенклатура_ЗагрузитьНоменклатуруКонтрагентовВТаблицуСопоставления(Результат, ПромежуточнаяТаблица);
	
	Номенклатура_ПрочитатьСопоставлениеНоменклатуры(Результат);
	
	Возврат Результат;
	
КонецФункции

// Метаданные сопоставления номенклатуры для настройки формы сопсотавления
// 
// Возвращаемое значение:
//  - Структура - типы полей и связи параметров выбора основных реквизитов номенклатуры и связанных справочников.
//  - Неопределено - если типовой ИМ не подключен.
//
Функция МенеджерИнтеграции_МетаданныеСопоставленияНоменклатуры() Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	Результат = МенеджерИнтеграции.Номенклатура_МетаданныеСопоставленияНоменклатуры();
	
	Возврат Результат;
	
КонецФункции

// Возвращает свойства набора номенклатур информационной базы.
// Определяет обязательность использования характеристики и упаковки.
//
// Параметры:
//  СсылкаИлиМассив - Массив из ОпределяемыйТип.НоменклатураБЭД, ОпределяемыйТип.НоменклатураБЭД
//    - ссылки на номенклатуру ИБ, для которой требуется определить свойства. Если передается ссылка, преобразуется в массив.
//
// Возвращаемое значение:
// Соответствие, Неопределено - в случае незаполненного набора номенклатуры возвращается Неопределено. Соответствие содержит:
//  * Ключ     - ОпределяемыйТип.НоменклатураБЭД - ссылка на номенклатуру ИБ.
//  * Значение - Структура                       - содержит свойства номенклатуры ИБ. См. НовыеСвойстваНоменклатурыИБ.
// 
// Возвращаемое значение:
//  Структура - типы полей и связи параметров выбора основных реквизитов номенклатуры и связанных справочников 
//
Функция МенеджерИнтеграции_СвойстваНоменклатурыИнформационнойБазы(СсылкаИлиМассив) Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	Результат = МенеджерИнтеграции.Номенклатура_СвойстваНоменклатурыИнформационнойБазы(СсылкаИлиМассив);
	
	Возврат Результат;
	
КонецФункции

// Варианты сопоставления номенклатуры
//
// Параметры:
//  ДокументИлиМассив	 - Структура/Массив	- Документ котент или массив контентов документа см. Контракт_Документ() 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица с вариантами сопоставления номенклатуры
//
Функция Номенклатура_ВариантыСопоставленияНоменклатуры(ДокументИлиМассив) Экспорт
	
	Результат = Новый Соответствие;
	
	Если ТипЗнч(ДокументИлиМассив) = Тип("Массив") Тогда
		
		КоллекцияДокументов = ДокументИлиМассив;
		
	Иначе
		
		КоллекцияДокументов = Новый Массив;
		КоллекцияДокументов.Добавить(ДокументИлиМассив);
		
	КонецЕсли;
	
	ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	
	ТаблицаВариантов = Новый ТаблицаЗначений;
	ТаблицаВариантов.Колонки.Добавить("Владелец");
	ТаблицаВариантов.Колонки.Добавить("Идентификатор");
	ТаблицаВариантов.Колонки.Добавить("Номенклатура");
	ТаблицаВариантов.Колонки.Добавить("Характеристика");
	ТаблицаВариантов.Колонки.Добавить("Упаковка");
	ТаблицаВариантов.Индексы.Добавить("Владелец, Идентификатор");
	
	ТаблицаСопоставленнойНоменклатуры = Номенклатура_ТаблицаСопоставленияНоменклатуры(ДокументИлиМассив);
	
	ДобавитьПоляПоискаНоменклатурыВТаблицуСопоставления(ТаблицаСопоставленнойНоменклатуры);
	
	Для Каждого Документ Из КоллекцияДокументов Цикл
		
		Если НЕ Документ.Тип.Формализованный
			ИЛИ ЭтоАктСверкиВзаиморасчетов(Документ.Тип.ТипДокумента) Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеДокумента = Документ.Документооборот.ХранилищеКонтента.Данные;
		ТабличнаяЧасть = Документы_ПолучитьТабличнуюЧастьИзКонтентаXML(ДанныеДокумента);
		
		ВладелецНоменклатуры = Номенклатура_ВладелецНоменклатуры(Документ.Отправитель.Организация); 
		
		Для Каждого СтрокаТЧ Из ТабличнаяЧасть Цикл 
			
			Идентификатор = СтрокаТЧ.ИдентификаторНоменклатуры;
			ДополнительныеПоля = СтрокаТЧ.ДополнительнаяИнформация; 
			НоменклатураДокумента = СтрокаТЧ.НоменклатураДокумента;
			
			Если НоменклатураСопоставлена(ТаблицаСопоставленнойНоменклатуры, ВладелецНоменклатуры, Идентификатор) Тогда
				Продолжить;
			КонецЕсли;
			
			НайденныеВарианты = Интеграция_НайтиСопоставлениеНоменклатуры(
				ВладелецНоменклатуры,
				НоменклатураДокумента,
				ДополнительныеПоля
			);
			
			ДополнитьТаблицуВариантовСопоставленияНоменклатуры(
				ТаблицаВариантов,
				ВладелецНоменклатуры,
				Идентификатор,
				НайденныеВарианты
			);
			
		КонецЦикла;
		
	КонецЦикла;
	
	ТаблицаВариантов.Свернуть("Владелец,Идентификатор,Номенклатура,Характеристика,Упаковка");
	
	Возврат ТаблицаВариантов;
	
КонецФункции

Процедура ДополнитьТаблицуВариантовСопоставленияНоменклатуры(ТаблицаВариантов, Владелец, Идентификатор, НовыеВарианты)
	
	Если Не ЗначениеЗаполнено(НовыеВарианты) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого НоменклатураИБ Из НовыеВарианты Цикл 
		
		СтрокаВарианта = ТаблицаВариантов.Добавить();
		
		СтрокаВарианта.Владелец = Владелец;
		СтрокаВарианта.Идентификатор = Идентификатор;
		
		СтрокаВарианта.Номенклатура = НоменклатураИБ.Номенклатура;
		СтрокаВарианта.Характеристика = НоменклатураИБ.Характеристика; 
		СтрокаВарианта.Упаковка = НоменклатураИБ.Упаковка;  
		
	КонецЦикла;
	
КонецПроцедуры

Функция Новый_КлючевыеПоляНоменклатурыКонтрагента(Владелец = Неопределено, Идентификатор = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Владелец", Владелец);
	Результат.Вставить("Идентификатор", Идентификатор);
	
	Возврат Результат;
	
КонецФункции

// Добавить поля поиска номенклатуры в таблицу сопоставления (Идентификатор, Владелец)
//
// Параметры:
//  Таблица	 - ТаблицаЗначений - см Новый_ТаблицаСопоставленияНоменклатуры
//
Процедура ДобавитьПоляПоискаНоменклатурыВТаблицуСопоставления(Таблица)
	
	КлючевыеПоляНоменклатурыКонтрагента = Новый_КлючевыеПоляНоменклатурыКонтрагента();
	
	ПоляНоменклатурыКонтрагентаСтрокой = "";
	РазделительПолей = "";

	Для Каждого Поле Из КлючевыеПоляНоменклатурыКонтрагента Цикл
		
		ПоляНоменклатурыКонтрагентаСтрокой = ПоляНоменклатурыКонтрагентаСтрокой + РазделительПолей + Поле.Ключ;
		
		РазделительПолей = ",";

		ПолеТаблицы = Таблица.Колонки.Найти(Поле.Ключ);
		Если ПолеТаблицы = Неопределено Тогда
			Таблица.Колонки.Добавить(Поле.Ключ);	
		КонецЕсли; 
		
	КонецЦикла; 
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаТаблицы.НоменклатураКонтрагента, ПоляНоменклатурыКонтрагентаСтрокой);	
	КонецЦикла;

КонецПроцедуры

// Функция - Проверяет надичие сопоставление номенклатуры контрагента в ИБ
//
// Параметры:
//  ТаблицаСопоставленнойНоменклатуры	 - ТаблицаЗначений -  
//  НоменклатураКонтрагента			 	 - Струткура - см. Контракт_НовыйНоменклатураКонтрагента 
// 
// Возвращаемое значение:
//   - 
//
Функция НоменклатураСопоставлена(ТаблицаСопоставленнойНоменклатуры, ВладелецНоменклатуры, Идентификатор)
	
	Результат = Ложь;
	
	КлючевыеПоля = Новый_КлючевыеПоляНоменклатурыКонтрагента(ВладелецНоменклатуры, Идентификатор);
	
	СтрокиПоискаНоменклатуры = ТаблицаСопоставленнойНоменклатуры.НайтиСтроки(КлючевыеПоля); 
	
	Для Каждого СтрокаПоиска Из СтрокиПоискаНоменклатуры Цикл 
		Результат = ЗначениеЗаполнено(СтрокаПоиска.Номенклатура);
		Прервать;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Формирует таблицу сопоставления номенклатуры только позициями, требующих сопоставления.
//
// Параметры:
//  ДокументИлиМассив - Структура, Массив из Структура - электронные документы (см. Контракт_Документ).
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
Функция Номенклатура_НесопоставленнаяНоменклатура(ДокументИлиМассив)
	
	ТаблицаСопоставления = Номенклатура_ТаблицаСопоставленияНоменклатуры(ДокументИлиМассив);
	
	ОбратныйИндекс = ТаблицаСопоставления.Количество() - 1;
	
	Пока ОбратныйИндекс >= 0 Цикл
		
		Запись = ТаблицаСопоставления[ОбратныйИндекс];
		
		НоменклатураСопоставлена = ЗначениеЗаполнено(Запись.Номенклатура);
		
		Если НоменклатураСопоставлена Тогда
			ТаблицаСопоставления.Удалить(ОбратныйИндекс);
		КонецЕсли;
		
		ОбратныйИндекс = ОбратныйИндекс - 1;
		
	КонецЦикла;
	
	Возврат ТаблицаСопоставления;
	
КонецФункции

// Загружает сведения о номенклатуре контрагентов в таблицу сопоставления номенклатуры.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//  ТаблицаНоменклатурыКонтрагентов - ТаблицаЗначений - см. Новый_ТаблицаНоменклатурыКонтрагентов.
//
Процедура Номенклатура_ЗагрузитьНоменклатуруКонтрагентовВТаблицуСопоставления(ТаблицаСопоставления, ТаблицаНоменклатурыКонтрагентов)
	
	Для Каждого СтрокаНоменклатураКонтрагента Из ТаблицаНоменклатурыКонтрагентов Цикл
		
		// Подготовить таблицу, чтобы не инициализировать её при каждом вызове ПМ.
		ПустаяТаблицаПМ = ТаблицаСопоставления.СкопироватьКолонки();
		
		КонтрагентИБ = СтрокаНоменклатураКонтрагента.Контрагент;
		
		НоменклатураКонтрагента = Новый_НоменклатураКонтрагента();
		ЗаполнитьЗначенияСвойств(НоменклатураКонтрагента, СтрокаНоменклатураКонтрагента);
		
		// ПМ вызывается для каждой строки, т.к. в общем случае нет гарантии
		ТаблицаПМ = ПодключаемыйМодуль_ЗаполнитьТаблицуСопоставленияНоменклатуры(КонтрагентИБ, НоменклатураКонтрагента, ПустаяТаблицаПМ);
		
		Для Каждого СтрокаТаблицыПМ Из ТаблицаПМ Цикл
			
			НоваяЗапись = ТаблицаСопоставления.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТаблицыПМ);
			НоваяЗапись.Контрагент = НоменклатураКонтрагента.Владелец;
			НоваяЗапись.НоменклатураКонтрагента = НоменклатураКонтрагента;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Инициализирует таблицу для интерактивного сопоставления
// номенклатуры контрагента с номенклатурой информационной базы.
// Для получения таблицы используется вызов подключаемого модуля.
//
// Параметры:
//  КонтрагентИБ - ЛюбаяСсылка - (Необязательный) Контрагент информационной базы. Для совместимости
//                               с ПМ_УТ_11 для версии модуля 4.5 или ниже.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - структура таблицы определяется в ПМ.
//
Функция Новый_ТаблицаСопоставленияНоменклатуры(КонтрагентИБ = Неопределено)
	
	ПустаяНоменклатураКонтрагента = Новый_НоменклатураКонтрагента();
	
	Результат = ПодключаемыйМодуль_ЗаполнитьТаблицуСопоставленияНоменклатуры(КонтрагентИБ, ПустаяНоменклатураКонтрагента);
	
	Результат.Очистить();
	
	Возврат Результат;
	
КонецФункции

// Помещает номенклатуру электронного документа в таблицу, которая затем используется для интерактивного
// сопоставления с номенклатурой информационной базы. Заполнение таблицы данными номенклатуры поставщика
// производится в событии ПМ "ЗаполнитьТаблицуСопоставленияНоменклатуры". Если в ПМ не передавать
// таблицу сопоставления, то она будет проинициализирована при первом вызове функции.
//
// Параметры:
//  Контрагент - Произвольный - Контрагент-владелец номенклатуры.
//  НоменклатураДокумента - Структура, Массив из Структура - номенклатура из электронного документа (см. Контракт_НоменклатураКонтрагента).
//  ТаблицаСопоставления - ТаблицаЗначений - (Необязательный) заполняемая таблица. Если параметр не указан, результирующая
//                                           таблица будет проиниализирована в подключаемом модуле.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. ПодключаемыйМодуль.НоваяТаблицаНоменклатурыДляСопоставления.
//
Функция ПодключаемыйМодуль_ЗаполнитьТаблицуСопоставленияНоменклатуры(Контрагент, НоменклатураДокумента, ТаблицаСопоставления = Неопределено)
	
	РезультатФункцииПМ = Новый Структура;
	РезультатФункцииПМ.Вставить("ОписаниеОшибки", "");
	РезультатФункцииПМ.Вставить("ОсновнойОбъект", Неопределено);
	
	Если ТипЗнч(ТаблицаСопоставления) = Тип("ТаблицаЗначений") Тогда
		РезультатФункцииПМ.Вставить("ТаблицаНоменклатурыДляСопоставления", ТаблицаСопоставления);
	КонецЕсли;
	
	МассивНоменклатуры = ЗначениеВМассив(НоменклатураДокумента);
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("РезультатСозданияДокумента", РезультатФункцииПМ);
	ПараметрыПМ.Вставить("Контрагент", Контрагент);
	ПараметрыПМ.Вставить("МассивНоменклатуры", МассивНоменклатуры);
	
	ПодключаемыйМодуль_ОбработатьСобытие("ЗаполнитьТаблицуСопоставленияНоменклатуры", ПараметрыПМ);
	
	Результат = РезультатФункцииПМ.ТаблицаНоменклатурыДляСопоставления;
	
	Возврат Результат;
	
КонецФункции

// Конструктор описания номенклатуры информационной базы.
// 
// Возвращаемое значение:
//  Структура - данные, представляющие номенклатуру ИБ:
//   * Номенклатура - ЛюбаяСсылка, Неопределено.
//   * Характеристика - ЛюбаяСсылка, Неопределено.
//   * Упаковка - ЛюбаяСсылка, Неопределено.
//
Функция Контракт_НоменклатураИнформационнойБазы()
	
	Результат = Новый Структура;
	Результат.Вставить("Номенклатура");
	Результат.Вставить("Характеристика");
	Результат.Вставить("Упаковка");
	
	Возврат Результат;
	
КонецФункции

// Формирует описание номенклатуры информационной базы.
//
// Параметры:
//  Номенклатура	 - ЛюбаяСсылка - (Необязательный) Ссылка на номенклатуру.
//  Характеристика	 - ЛюбаяСсылка - (Необязательный) Ссылка на характеристику номенклатуры.
//  Упаковка		 - ЛюбаяСсылка - (Необязательный) Ссылка на упаковку номенклатуры.
// 
// Возвращаемое значение:
//  Структура - см. Контракт_НоменклатураИнформационнойБазы.
//
Функция Новый_НоменклатураИнформационнойБазы(Номенклатура = Неопределено, Характеристика = Неопределено, Упаковка = Неопределено)
	
	Результат = Контракт_НоменклатураИнформационнойБазы();
	Результат.Номенклатура = Номенклатура;
	
	Если ЗначениеЗаполнено(Характеристика) Тогда
		Результат.Характеристика = Характеристика;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Упаковка) Тогда
		Результат.Упаковка = Упаковка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Конструктор описания номенклатуры контрагента.
// 
// Возвращаемое значение:
//  Структура - данные, представляющие номенклатуру контрагента:
//   * Владелец				 - ЛюбаяСсылка, Неопределено - владелец номенклатуры. Неопределено, если не инициализировано.
//   * Идентификатор		 - Строка - идентификатор записи по комбинации: номенклатура#характеристика#упаковка.
//   * Наименование			 - Строка - наименование номенклатуры.
//   * Характеристика		 - Строка - наименование характеристики номенклатуры.
//   * ЕдиницаИзмерения		 - Строка - единица измерения номенклатуры.
//   * ЕдиницаИзмеренияКод	 - Строка - код единицы измерения номенклатуры.
//   * Код					 - Строка - код номенклатуры.
//   * Артикул				 - Строка - артикул номенклатуры.
//   * Сорт					 - Строка - сорт номенклатуры.
//   * Описание				 - Строка - описание работы, услуги.
//   * СтавкаНДС			 - Строка - ставка НДС номенклатуры.
//
Функция Контракт_НоменклатураКонтрагента()
	
	Результат = Новый Структура;
	Результат.Вставить("Владелец");
	Результат.Вставить("Идентификатор");
	Результат.Вставить("Код");
	Результат.Вставить("Артикул");
	Результат.Вставить("Сорт");
	Результат.Вставить("Наименование");
	Результат.Вставить("Характеристика");
	Результат.Вставить("Описание");
	Результат.Вставить("СтавкаНДС");
	Результат.Вставить("ЕдиницаИзмерения");
	Результат.Вставить("ЕдиницаИзмеренияКод");
	
	Возврат Результат;
	
КонецФункции

// Формирует описание номенклатуры контрагента
//
// Параметры:
//  Владелец - ЛюбаяСсылка - (Необязательный) Владелец номенклатуры.
//  Идентификатор - Строка - (Необязательный) Идентификатор номенклатуры контрагента.
// 
// Возвращаемое значение:
//  Структура - см. Контракт_НоменклатураКонтрагента.
//
// @СлужебныйПрограммныйИнтерфейс
//
Функция Новый_НоменклатураКонтрагента(Владелец = Неопределено, Идентификатор = Неопределено) Экспорт
	
	Результат = Контракт_НоменклатураКонтрагента();
	
	Если ЗначениеЗаполнено(Владелец) Тогда
		Результат.Владелец = Владелец;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		Результат.Идентификатор = Идентификатор;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует идентификатор номенклатуры контрагента, который будет использован
// для сопоставления с номенклатурой информационной базы. Идентификатор создается
// путем конкатенации наименования, характеристики, кода и артикула. Окончания
// слишком длинных идентификаторов заменяются на хеш-функцию.
//
// Параметры:
//  СтрокаЭД - СтрокаТаблицыЗначений - см. функцию Документы_ПолучитьТабличнуюЧастьИзКонтентаXML.
// 
// Возвращаемое значение:
//  Строка.
//
Функция Номенклатура_СформироватьИдентификаторНоменклатурыКонтрагента(НоменклатураДокумента)
	
	ФрагментыПредставления = Новый Массив;
	ФрагментыПредставления.Добавить(НоменклатураДокумента.Наименование);
	ФрагментыПредставления.Добавить(НоменклатураДокумента.Характеристика);
	ФрагментыПредставления.Добавить(НоменклатураДокумента.Код);
	ФрагментыПредставления.Добавить(НоменклатураДокумента.Артикул);
	
	Представление = "";
	ВсеПоляПустые = Истина;
	Разделитель = "";
	
	Для Каждого Фрагмент Из ФрагментыПредставления Цикл
		
		Если ЗначениеЗаполнено(Фрагмент) Тогда
			ВсеПоляПустые = Ложь;
		КонецЕсли;
		
		Представление = Представление + Разделитель + СокрЛП(Фрагмент);
		Разделитель = "#";
		
	КонецЦикла;
	
	Если ВсеПоляПустые Тогда
		Представление = "";
	КонецЕсли;
	
	МаксимальнаяДлинаИдентификатора = 110; // Длина поля Идентификатор справочника НоменклатураПоставщиков в старых версиях типовых конфигураций
	Результат = Номенклатура_ИдентификаторПоСтроке(Представление, МаксимальнаяДлинаИдентификатора);
	
	Возврат Результат;
	
КонецФункции

// Генерирует уникальный строковый идентификатор с ограниченной длиной.
// Входная строка приводится к верхнему регистру, из нее удаляются все пробелы.
// Если длина нормализованной строки превышает заданное ограничение,
// её "хвост" заменяется на хеш-строку, вычисленную по алгоритму MD5.
//
// Параметры:
//  ВходнаяСтрока - Строка - произвольная строка.
//  МаксимальнаяДлина - Число - (Необязательный) максимальная длина формируемого идентификатора.
// 
// Возвращаемое значение:
//  Строка - идентификатор входной строки.
//
Функция Номенклатура_ИдентификаторПоСтроке(Знач ВходнаяСтрока, Знач МаксимальнаяДлина = Неопределено)
	
	Если Не ЗначениеЗаполнено(МаксимальнаяДлина) Тогда 
		МаксимальнаяДлина = 110;
	КонецЕсли;
	
	НормализованнаяСтрока = СокрЛП(ВходнаяСтрока);
	НормализованнаяСтрока = ВРег(НормализованнаяСтрока);
	НормализованнаяСтрока = СтрЗаменить(НормализованнаяСтрока, " ", "");
	
	Результат = Общее_СократитьСтрокуКонтрольнойСуммой(НормализованнаяСтрока, МаксимальнаяДлина);
	
	Возврат Результат;
	
КонецФункции

// Получает владельца номенклатуры по ссылке на контрагента.
//
// Параметры:
//  Контрагент - ЛюбаяСсылка - контрагент информационной базы.
// 
// Возвращаемое значение:
//  ЛюбаяСсылка - владелец номенклатуры контрагента.
//
Функция Номенклатура_ВладелецНоменклатуры(Контрагент)
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		ОбъектМетаданных = Контрагент.Метаданные();
		
		Если ОбъектМетаданных.Реквизиты.Найти("Партнер") <> Неопределено Тогда
			Результат = Контрагент.Партнер;
		Иначе
			Результат = Контрагент;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает уникальные записи номенклатуры контрагента из табличной части электронного документа.
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ.
// 
// Возвращаемое значение:
//  Массив - из см. Контракт_НоменклатураКонтрагента.
//
Функция Документы_НоменклатураЭлектронногоДокумента(Документ)
	
	Результат = Новый Массив;
	
	МожноОбработатьКонтентXML = Документ.Тип.Формализованный
							И НЕ ЭтоАктСверкиВзаиморасчетов(Документ.Тип.ТипДокумента);
	
	Если МожноОбработатьКонтентXML Тогда
		
		Документы_ПроверитьЗаполнитьХранилищеКонтента(Документ);
		СодержимоеДокумента = Документ.Документооборот.ХранилищеКонтента.Данные;
		
	Иначе
		
		Документы_ЗаполнитьКонтентOCR(Документ);
		СодержимоеДокумента = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентOCR");
		
		Если НЕ ЗначениеЗаполнено(СодержимоеДокумента) Тогда
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	ТабличнаяЧасть = Документы_ПолучитьТабличнуюЧастьИзКонтентаXML(СодержимоеДокумента);
	
	КонтрагентИБ = Документ.Отправитель.Организация;
	ВладелецНоменклатуры = Номенклатура_ВладелецНоменклатуры(КонтрагентИБ);
	
	ОбработанныеИдентификаторы = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ТабличнаяЧасть Цикл
		
		ИдентификаторНоменклатуры = СтрокаТЧ.ИдентификаторНоменклатуры;
		НоменклатураДокумента = СтрокаТЧ.НоменклатураДокумента;
		
		НоменклатураКонтрагента = Новый_НоменклатураКонтрагента(ВладелецНоменклатуры, ИдентификаторНоменклатуры);
		НоменклатураКонтрагента.Код = НоменклатураДокумента.Код;
		НоменклатураКонтрагента.Артикул = НоменклатураДокумента.Артикул;
		НоменклатураКонтрагента.Наименование = НоменклатураДокумента.Наименование;
		НоменклатураКонтрагента.Характеристика = НоменклатураДокумента.Характеристика;
		НоменклатураКонтрагента.СтавкаНДС = НоменклатураДокумента.СтавкаНДС;
		НоменклатураКонтрагента.ЕдиницаИзмерения = НоменклатураДокумента.ЕдиницаИзмерения;
		НоменклатураКонтрагента.ЕдиницаИзмеренияКод = НоменклатураДокумента.ЕдиницаИзмеренияКод;
		
		Если ОбработанныеИдентификаторы.Найти(НоменклатураКонтрагента.Идентификатор) = Неопределено Тогда
			Результат.Добавить(НоменклатураКонтрагента);
			ОбработанныеИдентификаторы.Добавить(НоменклатураКонтрагента.Идентификатор);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ЗаполнитьКонтентOCR(Документ)
	
	Если НЕ ИспользоватьПлагины()
		ИЛИ Документ.Тип.Формализованный
		ИЛИ Документ.СлужебнаяИнформация.Свойство("КонтентOCR") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ИдентификаторПлагинаOCR = "Plugin_OCR";
	ПлагинOCR = КонтурПлагины_УстановленныйПлагин(ИдентификаторПлагинаOCR);
	ВключенПлагинOCR = (ПлагинOCR.Состояние = КонтурПлагины_СостояниеПлагинаВключен());
	
	Если ВключенПлагинOCR Тогда
		
		Документы_ПроверитьЗаполнитьХранилищеКонтента(Документ);
		
		ИмяСобытия = "ЗаполнитьКонтентOCR";
		
		ПараметрыСобытия = Новый Структура;
		ПараметрыСобытия.Вставить("Документ", Документ);
		
		Результат = Неопределено;
		КонтурПлагины_ОбработатьСобытие(ИмяСобытия, ПараметрыСобытия, Результат);
		
		Если ЗначениеЗаполнено(Результат) Тогда
			Документ.СлужебнаяИнформация.Вставить("КонтентOCR", Результат);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Помещает в поле Документ.Документооборот.ХранилищеКонтента
// расшифрованное содержимое электронного документа.
//
// Параметры:
//  Документ - Структура - см. Контракт_Документ.
//
Процедура Документы_ПроверитьЗаполнитьХранилищеКонтента(Документ)
	
	ХранилищеКонтента = Неопределено;
	ИмяХранилища = "ХранилищеКонтента";
	
	Если Документ.Документооборот.Свойство(ИмяХранилища, ХранилищеКонтента)
		И ЗначениеЗаполнено(ХранилищеКонтента) Тогда
		Возврат;
	КонецЕсли;
	
	ОтправлятьРезультатПроверкиПодписи = Ложь;
	ХранилищеКонтента = Документы_Расшифровать(Документ.Идентификаторы, Ложь);
	
	Документ.Документооборот.Вставить(ИмяХранилища, ХранилищеКонтента);
	
КонецПроцедуры

// Имена полей, однозначно идентифицирующих номенклатуру контрагента.
// 
// Возвращаемое значение:
//  Строка - имена полей через запятую.
//
Функция Номенклатура_ИменаКлючевыхПолейНоменклатурыКонтрагента()
	Возврат "Владелец, Идентификатор";
КонецФункции

// Инициализирует таблицу, состав колонок которой соответствует
// ключам структуры Контракт_НоменклатураКонтрагента.
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//    * <Все поля Контракт_НоменклатураКонтрагента> - описание номенклатуры контрагента.
//    * Контрагент - контрагент информационной базы (для совместимости с ПМ).
//
Функция Новый_ТаблицаНоменклатурыКонтрагентов()
	
	ШаблонНоменклатурыКонтрагента = Новый_НоменклатураКонтрагента();
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Контрагент");
	
	Для Каждого Элемент Из ШаблонНоменклатурыКонтрагента Цикл
		ИмяПоля = Элемент.Ключ;
		Результат.Колонки.Добавить(ИмяПоля);
	КонецЦикла;
	
	ИменаКлючевыхПолей = Номенклатура_ИменаКлючевыхПолейНоменклатурыКонтрагента();
	Результат.Индексы.Добавить(ИменаКлючевыхПолей);
	
	Возврат Результат;
	
КонецФункции

// Разбирает содержимое табличных частей электронных документов и формирует
// итоговую таблицу с уникальными записями номенклатуры контрагентов.
//
// Параметры:
//  ДокументИлиМассив - Структура, Массив из Структура - см. Контракт_Документ.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. Новый_ТаблицаНоменклатурыКонтрагентов.
//
Функция Номенклатура_ТаблицаНоменклатурыКонтрагентов(ДокументИлиМассив)
	
	Если ТипЗнч(ДокументИлиМассив) = Тип("Массив") Тогда
		КоллекцияДокументов = ДокументИлиМассив;
	Иначе
		КоллекцияДокументов = Новый Массив;
		КоллекцияДокументов.Добавить(ДокументИлиМассив);
	КонецЕсли;
	
	Результат = Новый_ТаблицаНоменклатурыКонтрагентов();
	
	Для Каждого Документ Из КоллекцияДокументов Цикл
		
		НоменклатураДокумента = Документы_НоменклатураЭлектронногоДокумента(Документ);
		
		Если ЗначениеЗаполнено(НоменклатураДокумента) Тогда
			
			КонтрагентИБ = Документ.Отправитель.Организация;
			Номенклатура_ДополнитьТаблицуНоменклатурыКонтрагентов(Результат, НоменклатураДокумента, КонтрагентИБ);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Загружает сведения о номенклатуре контрагента в общую таблицу.
// При этом каждая позиция проверяется на уникальность по ключевым полям.
//
// Параметры:
//  ТаблицаНоменклатурыКонтрагентов - ТаблицаЗначений - см. Новый_ТаблицаНоменклатурыКонтрагентов.
//  НоменклатураДокумента - Массив из Структура - см. Контракт_НоменклатураКонтрагента.
//  КонтрагентИБ - ЛюбаяСсылка - контрагент информационной базы.
//
Процедура Номенклатура_ДополнитьТаблицуНоменклатурыКонтрагентов(ТаблицаНоменклатурыКонтрагентов, НоменклатураДокумента, КонтрагентИБ)
	
	ИменаКлючевыхПолей = Номенклатура_ИменаКлючевыхПолейНоменклатурыКонтрагента();
	КлючевыеПоля = Новый Структура(ИменаКлючевыхПолей);
	
	Для Каждого НоменклатураКонтрагента Из НоменклатураДокумента Цикл
		
		ЗаполнитьЗначенияСвойств(КлючевыеПоля, НоменклатураКонтрагента, ИменаКлючевыхПолей);
		
		НайденныеСтроки = ТаблицаНоменклатурыКонтрагентов.НайтиСтроки(КлючевыеПоля);
		ЗаписьДобавлена = ЗначениеЗаполнено(НайденныеСтроки);
		
		Если ЗаписьДобавлена Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаНоменклатурыКонтрагентов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, НоменклатураКонтрагента);
		НоваяСтрока.Контрагент = КонтрагентИБ;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет сведения о номенклатуре информационной базы, сопоставленной с номенклатурой контрагентов.
// Реализация алгоритма содержится в подключаемом модуле.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
Процедура Номенклатура_ПрочитатьСопоставлениеНоменклатуры(ТаблицаСопоставления)
	
	СобытиеПМ = "ПрочитатьСопоставлениеНоменклатуры";
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("ТаблицаСопоставления", ТаблицаСопоставления);
	
	ПодключаемыйМодуль_ОбработатьСобытие(СобытиеПМ, ПараметрыПМ);
	
КонецПроцедуры

// Находит варианты сопоставления номенклатуры.
// Алгоритмы поиска выполняются в следующей последовательности:
//  - Подключаемый модуль
//  - Плагины
//  - Интеграционный модуль (если стандартный алгоритм не отключили в ПМ)
//
// Параметры:
//  ВладелецНоменклатуры - ЛюбаяСсылка - Владелец номенклатуры (контрагент или партнер)
//  НоменклатураДокумента - Структура - Поля номенклатуры из электронного документа (см. Контракт_НоменклатураЭлектронногоДокумента).
//  ДополнительныеПоля - Массив из КлючЗначение - Инфополя строки табличной части электронного документа.
// 
// Возвращаемое значение:
//  Массив из Контракт_НоменклатураИнформационнойБазы.
//
Функция Интеграция_НайтиСопоставлениеНоменклатуры(ВладелецНоменклатуры, НоменклатураДокумента, ДополнительныеПоля)
	
	ИмяСобытия = "НайтиСопоставлениеНоменклатуры";
	
	ВариантыСопоставления = Новый Массив;
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("ВариантыСопоставления", ВариантыСопоставления);
	ПараметрыПМ.Вставить("Владелец", ВладелецНоменклатуры);
	ПараметрыПМ.Вставить("НоменклатураДокумента", ФиксированныеДанные(НоменклатураДокумента));
	ПараметрыПМ.Вставить("ДополнительныеПоля", ФиксированныеДанные(ДополнительныеПоля));
	
	РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		РезультатПМ
	);
	
	СтандартнаяОбработка = (РезультатПМ <> Истина);
	
	Если СтандартнаяОбработка Тогда
		
		ТиповыеВариантыСопоставления = МенеджерИнтеграции_ВариантыСопоставленияНоменклатуры(НоменклатураДокумента);
		
		Если ЗначениеЗаполнено(ТиповыеВариантыСопоставления) Тогда
		
			ДополнитьМассив(ВариантыСопоставления, ТиповыеВариантыСопоставления);
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВариантыСопоставления;
	
КонецФункции

// Записывает соответствие между номенклатурой контрагента и номенклатурой информационной базы и 
// обрабатывает возникающие ошибки. Алгоритм записи реализуется в интеграционном или подключаемом модуле.
//
// @СлужебныйПрограммныйИнтерфейс: для вызова из формы сопоставления номенклатуры.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
// 
// Возвращаемое значение:
//  Булево - Истина, если запись выполнена успешно.
//
Функция Интеграция_ЗаписатьСопоставлениеНоменклатуры(ТаблицаСопоставления) Экспорт
	
	ИмяСобытия = "СопоставитьНоменклатуруПоставщика";
	
	ПараметрыПМ = ТаблицаСопоставления;
	
	РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(РезультатПМ) Тогда
		
		РезультатИМ = МенеджерИнтеграции_СопоставитьНоменклатуруПоставщика(ТаблицаСопоставления);
		
		ПараметрыПМ = Новый Структура;
		ПараметрыПМ.Вставить("ДанныеДляОбработки", ТаблицаСопоставления);
		
		РезультатПМ = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
			ИмяСобытия,
			ПараметрыПМ,
			РезультатИМ
		);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		РезультатПМ
	);
	
	ОписаниеОшибки = СвойствоСтруктуры(РезультатПМ, "ОписаниеОшибки");
	
	ЗаписьВыполнена = Истина;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ЗаписьВыполнена = Ложь;
		ВидОперации = "Ошибка сопоставления номенклатуры";
		
		Ошибка_Обработать(
			ВидОперации,
			ОписаниеОшибки,
			Неопределено,
			ОписаниеОшибки
		);
		
	КонецЕсли;
	
	Возврат ЗаписьВыполнена;
	
КонецФункции

// Возвращаемое значение:
//  Массив - Коллекция найденных документов 1С
//
Функция Интеграция_НайтиСопоставлениеДокумента(Документ) Экспорт
	
	ИмяСобытия = "НайтиСопоставлениеДокумента";
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Документ", Документ);
	
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
	
	ПараметрыПМ.Вставить("Контент", ХранилищеКонтента);
	ПараметрыПМ.Вставить("ПакетДД", Документ.Идентификаторы.ПакетЭДО);
	ПараметрыПМ.Вставить("ДокументДД", Документ.Идентификаторы.ДокументЭДО);
	
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
			ИмяСобытия,
			ПараметрыПМ);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(Результат) Тогда
		
		РезультатИМ = МенеджерИнтеграции_НайтиСопоставлениеДокумента(Документ);
		
		Результат = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
				ИмяСобытия,
				ПараметрыПМ,
				РезультатИМ);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		Результат);
	
	Возврат Результат;
	
КонецФункции

// Типовой обработчик события "СопоставитьНоменклатуруПоставщика"
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
// Возвращаемое значение:
//  Структура:
//    * ОсновнойОбъект - Неопределено - для совместимости
//    * ОписаниеОшибки - Строка - текст ошибки создания объекта
//
Функция МенеджерИнтеграции_СопоставитьНоменклатуруПоставщика(ТаблицаСопоставления)
	
	КраткоеОписаниеОшибки = "";
	
	Попытка
		
		ТиповойМодуль_ЗаписатьСопоставлениеНоменклатуры(ТаблицаСопоставления);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		КраткоеОписаниеОшибки = КраткоеПредставлениеОшибки(Ошибка);
		
	КонецПопытки;
	
	Результат = Новый Структура;
	Результат.Вставить("ОписаниеОшибки", КраткоеОписаниеОшибки);
	Результат.Вставить("ОсновнойОбъект", Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Ставка НДС значение обьекта ИБ из представления
//
// Параметры:
//  ПредставлениеСтавкиНДС	 - Строка/Число -  Преставление ставки НДС в элетронном документе
// 
// Возвращаемое значение:
//  Перечисление.СтавкиНДС , Справочник.СтавкиНДС, Неопределно -  Значение Ставки НДС, если не удалось Определить СтавкуНДС возвращается неопределено
//
Функция СтавкиНДС_ЗначениеИзПредставления(ПредставлениеСтавкиНДС) Экспорт
	
	Если НЕ Метаданные.Перечисления.Найти("СтавкиНДС") = Неопределено Тогда
		Результат = СтавкиНДС_ПеречислениеИзПредставления(ПредставлениеСтавкиНДС);
	ИначеЕсли НЕ Метаданные.Справочники.Найти("СтавкиНДС") = Неопределено Тогда
		Результат = СтавкиНДС_СправочникИзПредставления(ПредставлениеСтавкиНДС);
	Иначе
		Результат = Неопределено;
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции 

Функция СтавкиНДС_СправочникИзПредставления(СтавкаНДС) 
	
	Результат = Неопределено;
	
	СправочникМенеджер = Вычислить("Справочники.СтавкиНДС");
	
	ЗначениеСправочника = СправочникМенеджер.НайтиПоНаименованию(СтавкаНДС); 
	
	Если ЗначениеЗаполнено(ЗначениеСправочника) Тогда 
		
		 Результат = ЗначениеСправочника;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СтавкиНДС_ПеречислениеИзПредставления(СтавкаНДС)
	
	ЗначениеНДС = Неопределено;
	
	ПеречислениеМенеджер = Вычислить("Перечисления.СтавкиНДС");
	
	Если ТипЗнч(СтавкаНДС) = Тип("Строка") Тогда
		ПредставлениеСтавкиНДС = СтавкаНДС;
	ИначеЕсли ТипЗнч(СтавкаНДС) = Тип("Число") Тогда
		ПредставлениеСтавкиНДС = Строка(СтавкаНДС);
	Иначе // неправильный тип
		ПредставлениеСтавкиНДС = Неопределено;
	КонецЕсли;
	
	Если ПредставлениеСтавкиНДС = Неопределено ИЛИ ВРЕГ(ПредставлениеСтавкиНДС) = "БЕЗ НДС" Тогда
		ЗначениеНДС = ПеречислениеМенеджер.БезНДС;
		
	ИначеЕсли ПредставлениеСтавкиНДС = "0" ИЛИ ПредставлениеСтавкиНДС = "0%" Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС0;
		
	ИначеЕсли Найти("10#0.1#0,1#0.10#0,10#10%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС10;
		
	ИначеЕсли Найти("20#0.2#0,2#0.20#0,20#20%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС20;
		
	ИначеЕсли Найти("18#0.18#0,18#0.18#0,18#18%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС18;
		
	ИначеЕсли Найти("10/110#10% / 110%#10%/110%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС10_110;
		
	ИначеЕсли Найти("20/120#20% / 120%#20%/120%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС20_120;
		
	ИначеЕсли Найти("18/118#18% / 118%#18%/118%", ПредставлениеСтавкиНДС) > 0 Тогда
		ЗначениеНДС = ПеречислениеМенеджер.НДС18_118;
		
	КонецЕсли;
	
	Возврат ЗначениеНДС;
	
КонецФункции

// АНАЛИЗ ДОКУМЕНТОВ

Функция Новый_РезультатАнализаВходящегоДокумента() Экспорт
	
	Результат = Новый Структура(
	"Ошибки, 
	//  Массив строк с описаниями ошибок
	
	|ДокументДляСопоставления,
	//  Ссылка на документ/справочник 1С, сооответствующий данному документу
	
	|ДействиеВ1С,
	//  Действие, которое необходимо выполнить с данным документом в 1С (Строка). Например, "СоздатьСчетФактуру", "ПометитьНаУдаление" и т.д.
	
	|ДействиеВДД,
	//  Действие, которое необходимо выполнить с данным документом в ядре сервиса (Строка). Допустимые варианты - "Подписать", "ОтказатьВПодписи", "ЗапроситьУточнение"
	
	|ТипОшибкиВалидации,
	//  Произвольный текст, отображаемый в списке. Просто для классификации ошибок
	
	|КонтентОтвета"
	//  ОбъектXDTO, соответствующий титулу покупателя (для формализованных документов) или отказу в подписи. Именно такой ответ будет отправлен в ядро, если заполнено поле "ДействиеВДД".
	
	);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПровестиАнализВходящегоДокумента(Документ) Экспорт
	
	Результат = Неопределено;
	
	Попытка
		
		Идентификаторы		= Документ.Идентификаторы;
		АнализПроведен		= Документ.РезультатАнализа.АнализПроведен;
		РезультатАнализа	= Новый_РезультатАнализаВходящегоДокумента();
		
		Если АнализПроведен Тогда
			ХранениеДанных_СброситьРезультатАнализаДокумента(Идентификаторы);
		КонецЕсли;
		
		ПараметрыПМ = Новый Структура;
		ПараметрыПМ.Вставить("РезультатАнализа",	РезультатАнализа);
		ПараметрыПМ.Вставить("Документ",			Документ);
		
		Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПровестиАнализДокумента", ПараметрыПМ);
		
		Если Результат <> Неопределено Тогда
			Документы_СохранитьРезультатАнализа(Идентификаторы, Результат);
		КонецЕсли;
				
	Исключение
		
		ВидОперации	 	= НСтр("ru = 'Проведение анализа документа'");
		ТекстОшибки	 	= ОписаниеОшибки();
		ТекстСообщения	= НСтр("ru = 'Не удалось провести анализ документа'");
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
		
	КонецПопытки;
	
	Возврат Результат;
		
КонецФункции

Функция Документы_ПровестиАнализВходящихДокументов(ДокументыСписок) Экспорт
	
	Результат = Новый Массив;
	Для каждого Документ Из ДокументыСписок Цикл
	
		РезультатПоДокументу = Документы_ПровестиАнализВходящегоДокумента(Документ);	
		Результат.Добавить(РезультатПоДокументу);
		
	КонецЦикла;
	
