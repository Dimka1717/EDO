// Конвертирует функцию документа, которая записана в подсистеме хранения, в
// значение для XML. Необходима из-за ограничения в 15 символов у реквизита "ФункцияДокумента"
//
// Параметры:
//  ФункцияДокумента - Строка - значение функции документа, записанное в подсистеме хранения
// 
// Возвращаемое значение:
//  Строка - сконвертированное значение функции документа для XML
//
Функция ФункцияТорг2ДляXML(ФункцияДокумента)
	
	КонвертируемыеЗначения = Новый Соответствие;
	КонвертируемыеЗначения.Вставить("NoInfo", "NoAdditionalInfo");
	КонвертируемыеЗначения.Вставить("WithInfo", "WithAdditionalInfo");
	
	Результат = КонвертируемыеЗначения.Получить(ФункцияДокумента);
	Если Результат = Неопределено Тогда
		Результат = ФункцияДокумента;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтатусШаблона(DocumentInfo)
	
	СтатусыДокументовЭДО = Перечисление_СтатусыДокументов();
	
	TemplateInfo			 = DocumentInfo.TemplateInfo;
	Participants			 = DocumentInfo.Participants;
	DocumentDirection		 = DocumentInfo.DocumentDirection;
	LetterParticipants		 = TemplateInfo.LetterParticipants;
	TransformedToLetterIds	 = TemplateInfo.TransformedToLetterIds;
	
	SenderBoxId		 = Participants.Sender.BoxId;
	RecipientBoxId	 = Participants.Recipient.BoxId;
	MessageFromBoxId = LetterParticipants.Sender.BoxId;
	
	TemplateRefusalInfo = СвойствоСтруктуры(TemplateInfo, "TemplateRefusalInfo");
	RefusalBoxId		= СвойствоСтруктуры(TemplateRefusalInfo, "BoxId", "");
	
	SenderBoxId		 = ИдентификаторВАдресЯщика(SenderBoxId);
	RecipientBoxId	 = ИдентификаторВАдресЯщика(RecipientBoxId);
	MessageFromBoxId = ИдентификаторВАдресЯщика(MessageFromBoxId);
	RefusalBoxId	 = ИдентификаторВАдресЯщика(RefusalBoxId);
	
	ГотовитДокументПолучательШаблона	 = (MessageFromBoxId = RecipientBoxId);
	ГотовитДокументОтправительШаблона	 = (MessageFromBoxId = SenderBoxId);
	
	ОтозвалОтправительШаблона = (RefusalBoxId = SenderBoxId);
	ОтклонилПолучательШаблона = (RefusalBoxId = RecipientBoxId);
	
	ЭтоВходящийШаблон	 = (DocumentDirection = "Inbound");
	ЭтоИсходящийШаблон	 = (DocumentDirection = "Outbound");
	
	ЕстьДокументПоШаблону = ЗначениеЗаполнено(TransformedToLetterIds);
	
	Если ОтозвалОтправительШаблона Тогда
		
		Результат = СтатусыДокументовЭДО.Отозван;
		
	ИначеЕсли ОтклонилПолучательШаблона Тогда
		
		Результат = СтатусыДокументовЭДО.Отклонен;
		
	ИначеЕсли ЕстьДокументПоШаблону Тогда
		
		Результат = СтатусыДокументовЭДО.Обработан;
		
	Иначе
		
		Если ГотовитДокументПолучательШаблона И ЭтоВходящийШаблон
			ИЛИ ГотовитДокументОтправительШаблона И ЭтоИсходящийШаблон Тогда
			
			Результат = СтатусыДокументовЭДО.ТребуетсяСоздатьДокумент;
			
		Иначе
			
			Результат = СтатусыДокументовЭДО.ОжидаетсяСозданиеДокумента;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ДАННЫЕ ХРАНЕНИЯ ДОКУМЕНТА АПИ

Функция Документы_ДанныхХранения_АПИ(Идентификаторы, ИмяХранилища, МассивEntities = Неопределено) Экспорт
	
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");

	Если МассивEntities = Неопределено Тогда
		МассивEntities = Документы_МассивEntities(BoxId, LetterId, DocumentId, Истина);
	КонецЕсли;
	
	EntityДанныхХранения			= Документы_EntityДанныхХранения(МассивEntities, ИмяХранилища, DocumentId);
	EntityСДвоичнымиДанными			= Документы_ЗаполнениеEntityData(BoxId, LetterId, EntityДанныхХранения);
	Результат				 		= Документы_ДанныеХраненияПоEntity(EntityСДвоичнымиДанными);
	
	EntityId						= СвойствоСтруктуры(EntityДанныхХранения, "EntityId", DocumentId);
	
	EntityДанныхПодписи     		= Документы_EntityПодписи(МассивEntities, ИмяХранилища, EntityId, BoxId);
	EntityСДвоичнымиДаннымиПодписи	= Документы_ЗаполнениеEntityData(BoxId, LetterId, EntityДанныхПодписи);
	СтруктураДанныхПодписи			= Документы_ДанныеПодписиПоEntity(EntityСДвоичнымиДаннымиПодписи, EntityДанныхХранения);
	
	ЗаполнитьЗначенияСвойств(Результат.Подпись, СтруктураДанныхПодписи);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МассивEntities(BoxId, LetterId, DocumentId, originalSignature = Неопределено, injectEntityContent = Неопределено)
	
	Результат = Новый Массив;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	Если СтрокаКонтекста <> Неопределено Тогда
		
		ПараметрыСервиса	= ПараметрыСервиса_Диадок(BoxId);
		Message				= АПИ_GetMessage(ПараметрыСервиса, BoxId, LetterId, DocumentId, originalSignature, injectEntityContent);
		
		Если ТипЗнч(Message) = Тип("Структура") Тогда
			Результат = Message.Entities;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_EntityДанныхХранения(МассивEntities, ИмяХранилища, DocumentId)
	
	Результат = Неопределено;

	Для Каждого Entity Из МассивEntities Цикл
		
		Если Entity.Свойство("AttachmentType") Тогда
			
			Если Ложь
				ИЛИ ИмяХранилища = "ХранилищеКонтента" 
					И Entity.EntityId = DocumentId
					
				ИЛИ ИмяХранилища = "ТитулПокупателя" 
					И Найти(ВРЕГ(Entity.AttachmentType), "BUYERTITLE") > 0
					И Entity.ParentEntityId = DocumentId
					
				ИЛИ ИмяХранилища = "ТитулПокупателя"
					И Entity.AttachmentType = "Title"
					И Entity.ParentEntityId = DocumentId
					
				ИЛИ Найти(ИмяХранилища, "ПредложениеОбАннулировании") > 0
					И Entity.AttachmentType = "RevocationRequest"
					И Entity.ParentEntityId = DocumentId
					
				ИЛИ ИмяХранилища = "Подтверждение" 
					И Entity.AttachmentType = "InvoiceConfirmation" 
					И Entity.ParentEntityId = DocumentId
					
				ИЛИ ИмяХранилища = "ИзвещениеОПолучении" 
					И Entity.AttachmentType = "InvoiceReceipt" 
					И Entity.ParentEntityId = DocumentId
				
				Тогда
				
				Результат = Entity;
				Прервать;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ЗаполнениеEntityData(BoxId, LetterId, Entity)
	
	Результат = Неопределено;
	
	Если ТипЗнч(Entity) = Тип("Структура") Тогда
		
		ДанныеBase64 = СвойствоСтруктуры(Entity.Content, "Data", Неопределено);
		
		Если ЗначениеЗаполнено(ДанныеBase64) Тогда
			ДанныеКонтента = Base64Значение(ДанныеBase64);
		Иначе
			ДанныеКонтента = Документы_ДвоичныеДанныеEntity(BoxId, LetterId, Entity.EntityId);
		КонецЕсли;
		
		Entity.Content.Вставить("Data", ДанныеКонтента);
		
		Результат = Entity;
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеХраненияПоEntity(СтруктураEntity)
	
	Результат = Контракт_ДанныеХранения();
	
	Если ТипЗнч(СтруктураEntity) = Тип("Структура") Тогда
		
		ДанныеКонтента = СтруктураEntity.Content.Data;
		
		Если СтруктураEntity.IsEncryptedContent Тогда
			Результат.ЗашифрованныеДанные = ДанныеКонтента;
		Иначе
			Результат.Данные = ДанныеКонтента;
		КонецЕсли;	
		
		Результат.ДатаСоздания			= Ticks_2_Date(СтруктураEntity.RawCreationDate);
		Результат.ИмяФайла				= СтруктураEntity.FileName;
		Результат.Описание				= СтруктураEntity.EntityId;
		Результат.Размер				= СтруктураEntity.Content.Size;
		Результат.ТребуетсяРасшифровка	= СтруктураEntity.IsEncryptedContent;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


// ДАННЫЕ ПОДПИСИ ДОКУМЕНТА АПИ

Функция Документы_ДанныеПодписи_АПИ(Идентификаторы, ИмяХранилища) Экспорт
	
	Результат = Контракт_Подпись();
	
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");

	МассивEntities					= Документы_МассивEntities(BoxId, LetterId, DocumentId, Истина);
	EntityДанныхХранения			= Документы_EntityДанныхХранения(МассивEntities, ИмяХранилища, DocumentId);
	EntityId						= СвойствоСтруктуры(EntityДанныхХранения, "EntityId", "");
	
	EntityДанныхПодписи     		= Документы_EntityПодписи(МассивEntities, ИмяХранилища, EntityId, BoxId);
	EntityСДвоичнымиДаннымиПодписи	= Документы_ЗаполнениеEntityData(BoxId, LetterId, EntityДанныхПодписи);
	СтруктураДанныхПодписи			= Документы_ДанныеПодписиПоEntity(EntityСДвоичнымиДаннымиПодписи, EntityДанныхХранения);
	
	ЗаполнитьЗначенияСвойств(Результат, СтруктураДанныхПодписи);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_EntityПодписи(МассивEntities, ИмяХранилища, EntityId, BoxId) Экспорт
	
	Результат = Неопределено;
	
	Для Каждого Entity Из МассивEntities Цикл
		
		Если Истина
			И Entity.Свойство("EntityType")
			И ВРЕГ(Entity.EntityType) = "SIGNATURE"
			И Entity.ParentEntityId = EntityId
			Тогда
			
			Если Ложь
				ИЛИ ИмяХранилища <> "ПредложениеОбАннулированииПокупателя" 
					И ИмяХранилища <> "ПредложениеОбАннулированииПродавца" 
					
				ИЛИ ИмяХранилища = "ПредложениеОбАннулированииПокупателя" 
					И АдресЯщикаВИдентификатор(Entity.SignerBoxId) <> BoxId
					
				ИЛИ ИмяХранилища = "ПредложениеОбАннулированииПродавца" 
					И АдресЯщикаВИдентификатор(Entity.SignerBoxId) = BoxId
					
				Тогда
				
				Результат = Entity;
				Прервать;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДвоичныеДанныеEntity(BoxId, LetterId, EntityId) Экспорт
	
	Результат = Неопределено;
	
	ПараметрыСервиса= ПараметрыСервиса_Диадок(BoxId);
	Результат		= АПИ_GetEntityContent(ПараметрыСервиса, BoxId, LetterId, EntityId);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеПодписиПоEntity(СтруктураEntity, EntityДанныхХранения)
	
	Результат = Контракт_Подпись();
	
	Если ТипЗнч(СтруктураEntity) = Тип("Структура") Тогда
		
		Результат.ДанныеПодписи		= СтруктураEntity.Content.Data;
		Результат.ДатаПодписи		= Ticks_2_Date(СтруктураEntity.RawCreationDate);
		
		DocumentInfo				= СвойствоСтруктуры(EntityДанныхХранения, "DocumentInfo");
		СтатусПодписиОтправителя	= СвойствоСтруктуры(DocumentInfo, "SenderSignatureStatus");
		ПодписьОтправителяВалидна	= СтатусПодписиОтправителя = "SenderSignatureCheckedAndValid";
		
		Результат.ПодписьВерна		= ПодписьОтправителяВалидна ИЛИ DocumentInfo = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


// ПРАВИЛА СОПОСТАВЛЕНИЯ 

Функция Документы_ПравилаСопоставления(Документ) Экспорт
	
	РеквизитыДокумента = ПодключаемыйМодуль_РеквизитыДокумента(Документ);
	
	Параметры = Новый Структура;
	Параметры.Вставить("РеквизитыДокумента", РеквизитыДокумента);
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПравилаСопоставленияДокумента", Параметры);
	
	Возврат Результат;
	
КонецФункции

// Получает список доступных операций для создания учетных документов на основании электронного документа.
//
// Параметры:
//  Документ - Структура - описание электронного документа (см. Контракт_Документ)
// 
// Возвращаемое значение:
//  СписокЗначений - доступные операции для создания документов.
//  Неопределено - если используется устаревший ПМ.
//
Функция Документы_СписокТиповДокументовДляСоздания(Документ) Экспорт
	
	РезультатПМ = Интеграция_СписокТиповДокументовДляСоздания(Документ);
	
	Если ЗначениеЗаполнено(РезультатПМ) Тогда
		
		Результат = РезультатПМ;
		
		ДополнитьСписокТиповДокументовДляСоздания(Результат, Документ);
		
	ИначеЕсли ПодключаемыйМодуль_ИспользоватьФормуСозданияДокументов() Тогда
		
		Результат = Новый СписокЗначений;
		Результат.Добавить("", НСтр("ru = '<По умолчанию>'"));
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДополнитьСписокТиповДокументовДляСоздания(Результат, Документ)
	
	ТипЭлектронногоДокумента = Документ.Тип;
	СоздаватьПередаточныеДокументы = ЗначениеНастройки_СоздаватьПередаточныеДокументы();
	
	Если НЕ СоздаватьПередаточныеДокументы
		ИЛИ НЕ Документы_ЭтоСчетФактура(ТипЭлектронногоДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеВарианты = ПравилаСозданияДокументовУчетаУПДСЧФДОП(ТипЭлектронногоДокумента.ТипКонтента);
	
	Для Каждого Элемент Из ДополнительныеВарианты Цикл
		
		Если Результат.НайтиПоЗначению(Элемент.Значение) = Неопределено Тогда
			
			Результат.Добавить(Элемент.Значение, Элемент.Представление);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПравилаСозданияДокументовУчетаУПДСЧФДОП(ТипКонтента)
	
	Перем ДополнительныеВарианты, ТипУПДДОП;
	
	ТипУПДДОП = Контракт_ТипЭлектронногоДокумента();
	ТипУПДДОП.ТипДокумента = Тип_УПД();
	ТипУПДДОП.ФункцияДокумента = Функция_СЧФДОП();
	ТипУПДДОП.Формализованный = Истина;
	
	ТипыКонтентов = Перечисление_ТипыКонтентов();
	
	Если ТипКонтента = ТипКонтента_utd970() Тогда
		ТипУПДДОП.ТипКонтента = ТипыКонтентов.utd970;	
	Иначе
		ТипУПДДОП.ТипКонтента = ТипыКонтентов.utd820;
	КонецЕсли;
	
	ДополнительныеВарианты = МенеджерИнтеграции_ПравилаСозданияДокументовУчета(ТипУПДДОП);
	
	Возврат ДополнительныеВарианты;
	
КонецФункции

Функция Документы_ПравилаСопоставленияПоВидуМетаданных(ВидМетаданных) Экспорт
	
	Результат = Новый Структура;
	
	Для Каждого ОбъектМетаданных Из Метаданные[ВидМетаданных] Цикл
		Документы_ДобавитьПравилоСопоставленияДляОбъектаМетаданных(Результат, ОбъектМетаданных);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает перечень видов электронных документов, которые соответствуют
// типу документа в терминах API сервиса.
//
// Параметры:
//  ТипДокумента	 - Строка - имя типа документа в терминах сервиса (typeNameId);
//  ФункцияДокумента - Строка, Неопределено - принимает значения: "InvoiceAndBasic", "Invoice", "Basic" или Неопределено;
// 
// Возвращаемое значение:
//  Массив - содержит элементы перечисления ЭДО_Перечисление_ВидыЭД.
//
Функция Документы_ВидыЭлектронныхДокументовПоФорматуЭДО(Знач ТипДокумента, Знач ФункцияДокумента) Экспорт
	
	Результат = Новый Массив;
	
	ВидыЭДО = Перечисление_ВидыЭДО();
	
	ТипДокумента = ВРег(ТипДокумента);
	ФункцияЭД	 = ВРег(ФункцияДокумента);
	
	ЕстьФункцияСФ = Документы_ЕстьФункцияСчетаФактуры(ФункцияЭД);
	ЕстьФункцияПД = Документы_ЕстьФункцияПервичногоДокумента(ФункцияЭД);
	
	// Счет-фактура
	Если ТипДокумента = ВРег("UniversalTransferDocument") И ЕстьФункцияСФ
		Или ТипДокумента = ВРег("UniversalTransferDocumentRevision") И ЕстьФункцияСФ
		Или ТипДокумента = ВРег("Invoice")
		Или ТипДокумента = ВРег("InvoiceRevision") Тогда 
		Результат.Добавить(ВидыЭДО.СчетФактура);
	КонецЕсли;
	
	// Корректировочный счет-фактура
	Если ТипДокумента = ВРег("UniversalCorrectionDocument") И ЕстьФункцияСФ
		Или ТипДокумента = ВРег("UniversalCorrectionDocumentRevision") И ЕстьФункцияСФ
		Или ТипДокумента = ВРег("InvoiceCorrection")
		Или ТипДокумента = ВРег("InvoiceCorrectionRevision") Тогда 
		Результат.Добавить(ВидыЭДО.КорректировочныйСчетФактура);
	КонецЕсли;
	
	// Акт или накладная
	Если ТипДокумента = ВРег("UniversalTransferDocument") И ЕстьФункцияПД
		Или ТипДокумента = ВРег("UniversalTransferDocumentRevision") И ЕстьФункцияПД Тогда 
		
		Результат.Добавить(ВидыЭДО.Накладная);
		Результат.Добавить(ВидыЭДО.Акт);
		
	ИначеЕсли ТипДокумента = ВРег("XmlTorg12")
		Или ТипДокумента = ВРег("Torg12") Тогда 
		
		Результат.Добавить(ВидыЭДО.Накладная);
		
	ИначеЕсли ТипДокумента = ВРег("XmlAcceptanceCertificate")
		Или ТипДокумента = ВРег("AcceptanceCertificate") Тогда 
		
		Результат.Добавить(ВидыЭДО.Акт);
		
	КонецЕсли;
	
	// Соглашение об изменении стоимости
	Если ТипДокумента = ВРег("UniversalCorrectionDocument") И ЕстьФункцияПД
		Или ТипДокумента = ВРег("UniversalCorrectionDocumentRevision") И ЕстьФункцияПД Тогда
		Результат.Добавить(ВидыЭДО.КорректировочнаяНакладная);
	КонецЕсли;
	
	// Счет на оплату
	Если ТипДокумента = ВРег(Тип_СчетНаОплату())
		Или ТипДокумента = ВРег(Тип_СчетНаОплатуФормализованный())
		Или ТипДокумента = ВРег(Тип_СчетОфертаНаОплатуФормализованный()) Тогда
		Результат.Добавить(ВидыЭДО.Счет);
	КонецЕсли;
	
	// Акт сверки
	Если ТипДокумента = ВРег("ReconciliationAct") Тогда
		Результат.Добавить(ВидыЭДО.АктСверки);
	КонецЕсли; 
	
	// Внутреннее перемещение
	Если ТипДокумента = ВРег("UniversalTransferDocumentInternal") Тогда
		Результат.Добавить(ВидыЭДО.Накладная);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что электронный документ имеет функцию счета-фактуры.
//
// Параметры:
//  ФункцияЭД - Строка - функция электронного документа.
// 
// Возвращаемое значение:
//  Булево - Истина, если электронный документ имеет функцию счета-фактуры.
//
Функция Документы_ЕстьФункцияСчетаФактуры(Знач ФункцияЭД)
	
	Результат = Ложь;
	
	ФункцияЭД = ВРег(ФункцияЭД);
	
	Если Не ЗначениеЗаполнено(ФункцияЭД)
		Или ФункцияЭД = ВРег("Default") Тогда 
		Возврат Результат;
	КонецЕсли;
	
	ПодстрокиПоиска = Новый Массив;
	ПодстрокиПоиска.Добавить("Invoice");
	ПодстрокиПоиска.Добавить("СЧФ");
	ПодстрокиПоиска.Добавить("КСЧФ");
	
	Для Каждого Подстрока Из ПодстрокиПоиска Цикл 
		
		Если Найти(ФункцияЭД, ВРег(Подстрока)) > 0 Тогда 
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что электронный документ имеет функцию первичного документа.
//
// Параметры:
//  ФункцияЭД - Строка - функция электронного документа.
// 
// Возвращаемое значение:
//  Булево - Истина, если электронный документ имеет функцию первичного документа.
//
Функция Документы_ЕстьФункцияПервичногоДокумента(Знач ФункцияЭД)
	
	Результат = Ложь;
	
	ФункцияЭД = ВРег(ФункцияЭД);
	
	Если Не ЗначениеЗаполнено(ФункцияЭД)
		Или ФункцияЭД = ВРег("Default") Тогда 
		Возврат Результат;
	КонецЕсли;
	
	ПодстрокиПоиска = Новый Массив;
	ПодстрокиПоиска.Добавить("Basic");
	ПодстрокиПоиска.Добавить("ДОП");
	ПодстрокиПоиска.Добавить("ДИС");
	
	Для Каждого Подстрока Из ПодстрокиПоиска Цикл 
		
		Если Найти(ФункцияЭД, ВРег(Подстрока)) > 0 Тогда 
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ДобавитьПравилоСопоставления(НаборПравил, ВидМетаданных, ИмяМетаданных, Отбор = Неопределено) Экспорт

	ОбъектМетаданных = Метаданные[ВидМетаданных].Найти(ИмяМетаданных);
	
	Если ОбъектМетаданных <> Неопределено Тогда
		
		Правило = Документы_ПравилоСопоставленияДокумента(ОбъектМетаданных.ПолноеИмя(), ОбъектМетаданных.Синоним, Отбор);
		НаборПравил.Вставить(ОбъектМетаданных.Имя, Правило);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Документы_ДобавитьПравилоСопоставленияДляОбъектаМетаданных(НаборПравил, ОбъектМетаданных, Отбор = Неопределено)
	
	Правило = Документы_ПравилоСопоставленияДокумента(ОбъектМетаданных.ПолноеИмя(), ОбъектМетаданных.Синоним, Отбор);
	НаборПравил.Вставить(ОбъектМетаданных.Имя, Правило);
	
КонецПроцедуры

Функция Документы_ПравилоСопоставленияДокумента(ИмяМетаданных, СинонимМетаданных, Отбор = Неопределено)
	
	Если Отбор = Неопределено Тогда
		Отбор = Новый Структура;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяМетаданных"		, ИмяМетаданных);
	Результат.Вставить("СинонимМетаданных"	, СинонимМетаданных);
	Результат.Вставить("Отбор"				, Отбор);
	
	Возврат Результат;
	
КонецФункции


// ШИФРОВАНИЕ ДОКУМЕНТА

Функция Документы_Расшифровать(Идентификаторы, ОтправлятьРезультатПроверкиПодписи = Истина) Экспорт
	
	Результат = ХранениеДанных_ДанныеХранилища(Идентификаторы, "ХранилищеКонтента");
	
	ТребуетсяРасшифровка = Результат.ТребуетсяРасшифровка;
	
	Если ТребуетсяРасшифровка Тогда
		
		РасшифрованныеДанные	= РасшифроватьДанные(Результат.ЗашифрованныеДанные);
		Результат.Данные		= РасшифрованныеДанные;
		
		ПодписьВерна = Документы_ПроверитьПодпись(Результат);
		
		Результат.Подпись.ПодписьВерна	= ПодписьВерна;
		Результат.ТребуетсяРасшифровка	= Ложь;
		
		Если ОтправлятьРезультатПроверкиПодписи Тогда
			
			Попытка
				Документы_ОтправитьРезультатПроверкиПодписи(Идентификаторы, ПодписьВерна);
			Исключение
				
				ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
				
				Если Найти(НРег(ТекстОшибки), НРег("InvalidDocumentState")) > 0
					ИЛИ Найти(НРег(ТекстОшибки), НРег("Состояние документа не позволяет выполнить действие")) > 0 Тогда
					// Отметка о проверке подписи уже установлена.
				Иначе
					ВызватьИсключение;
				КонецЕсли;
				
			КонецПопытки;
			
		КонецЕсли;
		
		ХранениеДанных_ЗаписатьДанныеХранилища(Результат, "ХранилищеКонтента", Идентификаторы.ДокументЭДО);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ОтправитьРезультатПроверкиПодписи(Идентификаторы, ПодписьВерна) Экспорт 
	
	BoxId		 = Идентификаторы.BoxId;
	MessageId	 = Идентификаторы.LetterId;
	DocumentId	 = Идентификаторы.DocumentId;
	
	ПодготовленнаяСтруктура = Новый Структура;
	
	ИмяКоллекции = "SignatureVerifications";
	
	Attachment = Новый Структура;
	Attachment.Вставить("InitialDocumentId"	, DocumentId);
	Attachment.Вставить("IsValid"			, ПодписьВерна);
	
	ПодготовленнаяСтруктура.Вставить(ИмяКоллекции, Attachment);
	
	РезультатОтправки = РезультатPostMessagePatch(Идентификаторы, ПодготовленнаяСтруктура);
	
	Результат = РезультатОтправки.MessagePatch;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СертификатыДляШифрованияИзДиадока(BoxId, CounteragentBoxId) Экспорт 
	
	Результат = Новый Массив;
	
	OrgId = КонтекстСеанса_СтрокаКонтекста(BoxId).OrgId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	Counteragent = АПИ_GetOrganization(ПараметрыСервиса, boxId);
	
	CounteragentOrgId = Counteragent.OrgId;
	
	Ответ = АПИ_GetCounteragentCertificates(ПараметрыСервиса, OrgId, OrgId);
	
	Для Каждого Certificate Из Ответ.Certificates Цикл
		Результат.Добавить(Base64Значение(Certificate.RawCertificateData));
	КонецЦикла;
	
	Ответ = АПИ_GetCounteragentCertificates(ПараметрыСервиса, OrgId, CounteragentOrgId);
	
	Для Каждого Certificate Из Ответ.Certificates Цикл
		Результат.Добавить(Base64Значение(Certificate.RawCertificateData));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ПроверитьПодпись(ДанныеХранения)
	
	ДвоичныеДанные			= ДанныеХранения.Данные;
	ДвоичныеДанныеПодписи	= ДанныеХранения.Подпись.ДанныеПодписи;
	
	Результат = ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТребуетсяШифрованиеДокументов(ИдентификаторыОрганизации, ИдентификаторыКонтрагента) Экспорт
	
	Результат = Ложь;
	
	Организация			= Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	РазрешеноШифрование = КонтекстСеанса_СтрокаКонтекста(Организация.ID).ДополнительныеФункции.РазрешеноШифрование;
	
	Если РазрешеноШифрование Тогда
		
		ШифроватьДокументыВЭтойПаре = ХранениеДанных_ЗначениеШифрованияДокумента(ИдентификаторыОрганизации, ИдентификаторыКонтрагента);
		
		Если ТипЗнч(ШифроватьДокументыВЭтойПаре) = Тип("Булево") Тогда
			Результат = ШифроватьДокументыВЭтойПаре;
		Иначе
			Результат = Организация.ШифроватьДокументы;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


