Функция ДополнительныеОтчетыИОбработки_НайтиПоИмени(ИмяОбработки)
	
	МенеджерХранилища = Справочники.ДополнительныеОтчетыИОбработки;
	Результат = МенеджерХранилища.ПустаяСсылка();
	
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ХранилищеОбработок.Ссылка КАК Ссылка,
	|	ХранилищеОбработок.Версия КАК Версия
	|ИЗ
	|	Справочник.ДополнительныеОтчетыИОбработки КАК ХранилищеОбработок
	|ГДЕ
	|	НЕ ХранилищеОбработок.ПометкаУдаления
	|	И НЕ ХранилищеОбработок.ЭтоГруппа
	|	И ХранилищеОбработок.ИмяОбъекта = &ИмяОбработки
	|	И ХранилищеОбработок.Публикация = &Публикация
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ИмяОбработки", ИмяОбработки);
	Запрос.УстановитьПараметр("Публикация", Перечисления.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

