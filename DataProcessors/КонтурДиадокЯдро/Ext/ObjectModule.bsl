Функция РезультатPostMessagePatch(Идентификаторы, ПодготовленныеСтруктуры, OperationId = Неопределено) Экспорт
	
	Результат = Неопределено;
	
	BoxId		= Идентификаторы.BoxId;
	LetterId	= Идентификаторы.LetterId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	MessagePatchToPost = АПИ_Новый_MessagePatchToPost(BoxId, LetterId);
	
	ДействияПатчинга = Новый Массив;
	
	Для Каждого СтруктураНаОтправку Из ПодготовленныеСтруктуры Цикл
		
		ИмяКоллекции	= СтруктураНаОтправку.Ключ;
		Attachment		= СтруктураНаОтправку.Значение;
		
		Если ЗначениеЗаполнено(Attachment) Тогда
			
			MessagePatchToPost.Вставить(ИмяКоллекции, ЗначениеВМассив(Attachment));
			ДействияПатчинга.Добавить(ИмяКоллекции);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = АПИ_PostMessagePatch(ПараметрыСервиса, MessagePatchToPost, OperationId);
	
	МетрикиКонтур_ЗаписатьСобытие_ОбработкаДокумента(BoxId, ДействияПатчинга);
	
	Возврат Результат;
	
КонецФункции

