Функция АПИ_ЗагрузитьКонтентНаПолку(
		Знач BoxId,
		Знач Content) Экспорт
	
	Результат = "";
	
	Если НЕ ЗначениеЗаполнено(Content) Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	isLastPart = Ложь;
	fileExtension = "";
	РазмерКонтента = 512 * 1024;
	МассивДанных = РазделитьДвоичныеДанныеЛок(Content, РазмерКонтента);
	ГраницаМассива = МассивДанных.Вграница();
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Для PartIndex = 0 По ГраницаМассива Цикл
		
		Data = МассивДанных[PartIndex];
		
		Если PartIndex = ГраницаМассива Тогда
			
			isLastPart = Истина;
			
		КонецЕсли;
		
		Если PartIndex = 0 Тогда
			
			Результат = Модуль_МетодыAPI.DD_API_ShelfUploadPartInit(
					ПараметрыСервиса,
					Data,
					fileExtension,
					isLastPart);
			
			Продолжить;
			
		КонецЕсли;
		
		МассивОшибочныхФайлов = Модуль_МетодыAPI.DD_API_ShelfUploadPart(
				ПараметрыСервиса,
				Data,
				Результат,
				PartIndex,
				isLastPart);
		
		Если ЗначениеЗаполнено(МассивОшибочныхФайлов) Тогда
			
			ВызватьИсключение "Не удалось загрузить файл на полку документов";
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция РазделитьДвоичныеДанныеЛок(ДвоичныеДанные, РазмерВБайтах) Экспорт
	
	Результат = Новый Массив;
	
	Если ПриложениеСтаршеВерсии("8.3.10") Тогда
		
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("data.tmp");
		ДвоичныеДанные.Записать(ИмяВременногоФайла);
		ИменаФайлов = РазделитьФайл(ИмяВременногоФайла, РазмерВБайтах);
		РазделительПути = РазделительПути();
		Для Индекс = 0 По ИменаФайлов.Количество() - 1 Цикл
			ПолноеИмяФайла = ИменаФайлов[Индекс];
			ПолноеИмяФайла = СтрЗаменить(ПолноеИмяФайла, "/", РазделительПути);
			ПолноеИмяФайла = СтрЗаменить(ПолноеИмяФайла, "\", РазделительПути);
			ДвоичныеДанныеЧасти = Новый ДвоичныеДанные(ПолноеИмяФайла);
			Результат.Добавить(ДвоичныеДанныеЧасти);
			// BSLLS:UsingSynchronousCalls-off
			УдалитьФайлы(ПолноеИмяФайла);
			// BSLLS:UsingSynchronousCalls-on
		КонецЦикла;
		// BSLLS:UsingSynchronousCalls-off
		УдалитьФайлы(ИмяВременногоФайла);
		// BSLLS:UsingSynchronousCalls-on
		
	Иначе
		
		Результат = Вычислить("РазделитьДвоичныеДанные(ДвоичныеДанные, РазмерВБайтах)");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

