Функция РасшифроватьДанные(ЗашифрованныеДанные) Экспорт
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ЗашифрованныеДвоичныеДанные", ЗашифрованныеДанные);
	Результат = ПодключаемыйМодуль_ОбработатьСобытие("РасшифроватьДанные", ПараметрыСобытия);
	
	Если Результат = Неопределено Тогда
		
		Если ИспользоватьВнешнююКриптографию() Тогда
			
			Результат = ВнешниеСервисы_РасшифроватьДанные(ЗашифрованныеДанные);
			
		Иначе
			
			Результат = МенеджерКриптографии_РасшифроватьДанные(ЗашифрованныеДанные);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата, ПарольКонтейнера = Неопределено) Экспорт
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ДвоичныеДанные",			ДвоичныеДанные);
	ПараметрыСобытия.Вставить("ОтпечатокСертификата",	ОтпечатокСертификата);
	ПараметрыСобытия.Вставить("ПарольКонтейнера",		ПарольКонтейнера);
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПодписатьДанные", ПараметрыСобытия);
	
	Если Результат = Неопределено Тогда 
		
		Если ИспользоватьВнешнююКриптографию() Тогда
			
			Результат = ВнешниеСервисы_ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата, ПарольКонтейнера);
			
		Иначе
			
			Результат = МенеджерКриптографии_ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПодписьДанных(BoxId, ДвоичныеДанные, Знач ОтпечатокСертификата = "") Экспорт
	
	Если Не ЗначениеЗаполнено(ОтпечатокСертификата) Тогда
		ОтпечатокСертификата = КонтекстСеанса_Прочитать(BoxId, "ОтпечатокСертификата");
	КонецЕсли;
	
	Если ОтпечатокСертификата = "" Тогда 
		ВызватьИсключение "Подписание доступно только при авторизации по сертификату";	
	КонецЕсли;
	
	Результат = ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата);
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи) Экспорт
	
	ПараметрыСобытия = Новый Структура;
	ПараметрыСобытия.Вставить("ДвоичныеДанные"		 , ДвоичныеДанные);
	ПараметрыСобытия.Вставить("ДвоичныеДанныеПодписи", ДвоичныеДанныеПодписи);
	
	ПодписьВерна = ПодключаемыйМодуль_ОбработатьСобытие("ПроверитьПодпись", ПараметрыСобытия);
	
	Если ПодписьВерна = Неопределено Тогда
		
		Попытка
			
			Если ИспользоватьВнешнююКриптографию() Тогда
				
				ОписаниеСертификата = ВнешниеСервисы_ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
				
			Иначе
				
				ОписаниеСертификата = МенеджерКриптографии_ПроверитьПодпись(ДвоичныеДанные, ДвоичныеДанныеПодписи);
				
			КонецЕсли;
			
			Результат			= ЗначениеЗаполнено(ОписаниеСертификата);
		Исключение
			
			ВидОперации		 = "Проверка подписи";
			ТекстСообщения	 = "Не удалось проверить подпись";
			ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
			
			Результат = Ложь;
			
		КонецПопытки;
		
	Иначе
		Результат = ПодписьВерна;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

