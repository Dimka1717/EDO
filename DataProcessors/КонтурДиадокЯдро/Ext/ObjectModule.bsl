// Получает файл из хранилища внешней обработки
//
// Параметры:
//  ДопОбработкаСсылка - СправочникСсылка - ссылка на элемент справочника внешних обработок.
// 
// Возвращаемое значение:
//  ДвоичныеДанные - содержимое хранилища обработки.
//
Функция Обработка_ДвоичныеДанныеВнешнейОбработки(ДопОбработкаСсылка) Экспорт
	
	МетаданныеСсылки = ДопОбработкаСсылка.Метаданные();
	
	ИмяОбъекта = МетаданныеСсылки.ПолноеИмя();
	ИмяОбъектаНРег = НРег(ИмяОбъекта);
	
	Если ИмяОбъектаНРег = НРег("Справочник.ДополнительныеОтчетыИОбработки") Тогда
		ИмяРеквизита = "ХранилищеОбработки";
	ИначеЕсли ИмяОбъектаНРег = НРег("Справочник.ВнешниеОбработки") Тогда
		ИмяРеквизита = "ХранилищеВнешнейОбработки";
	ИначеЕсли ИмяОбъектаНРег = НРег("Справочник.ВнешниеПечатныеФормы") Тогда
		ИмяРеквизита = "Хранилище";
	Иначе
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"Неожиданное имя справочника внешних обработок (%1)",
			ИмяОбъекта
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	Результат = ДопОбработкаСсылка[ИмяРеквизита].Получить();
	
	Возврат Результат;
	
КонецФункции

Функция Обработка_СоздатьИзВнешнейОбработки(ДопОбработкаСсылка)
	
	Если Не ЗначениеЗаполнено(ДопОбработкаСсылка) Тогда
		Ошибка = "Не указана ссылка на доп. обработку";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ДвоичныеДанные = Обработка_ДвоичныеДанныеВнешнейОбработки(ДопОбработкаСсылка);
	
	Если Не ДвоичныеДанные.Размер() Тогда
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"Не загружен файл внешней обработки (%1)",
			Строка(ДопОбработкаСсылка)
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	Результат = ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанные);
	
	Возврат Результат;
	
КонецФункции

Функция Обработка_СоздатьИзФайла(ПутьКОбработке)
	
	Если Не ФайлСуществует(ПутьКОбработке) Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
		"ru = 'Не найден файл обработки.
		|Путь к файлу: %1'")
		, ПутьКОбработке);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = ВнешниеОбработки_СоздатьБезПредупреждений(ПутьКОбработке);	
	
	Возврат Результат;
	
КонецФункции

// Создаёт экземпляр обработки
//
//Параметры:
// ПутьКОбработке - Строка, ЛюбаяСсылка - путь к файлу, имя обработки или ссылка на справочник внешних обработок
// РасположениеОбработки - Строка - Месторасположеление обработки (Конфигурация, Диск, Внешняяобработка)
//
//Возвращаемое значение:
// ОбработкаОбъект - объект созданной внешней обработки.
//
Функция Обработка_Создать(ПутьКОбработке, РасположениеОбработки) Экспорт
	
	Если РасположениеОбработки = ВариантРасположенияОбработкиКонфигурация() Тогда
		
		Результат = Обработка_СоздатьИзКонфигурации(ПутьКОбработке);
		
	ИначеЕсли РасположениеОбработки = ВариантРасположенияОбработкиСправочник() Тогда
		
		Результат = Обработка_СоздатьИзВнешнейОбработки(ПутьКОбработке);
		
	ИначеЕсли РасположениеОбработки = ВариантРасположенияОбработкиФайл() Тогда
		
		Результат = Обработка_СоздатьИзФайла(ПутьКОбработке);
		
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Непредвиденное значение параметра (РасположениеОбработки = %1)'"),
			РасположениеОбработки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

