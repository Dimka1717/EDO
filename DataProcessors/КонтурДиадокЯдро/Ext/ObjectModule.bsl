// Получает номер версии установленного модуля продуктовой аналитики.
// 
// Возвращаемое значение:
//  Строка - номер версии текущей установки. Если не установлено, вернет значение "0.0.0"
//
Функция ПродуктоваяАналитика_УстановленнаяВерсия()
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	ИмяОбработки = ПродуктоваяАналитика_ИмяОбработки();
	ДопОбработка = ДополнительныеОтчетыИОбработки_НайтиПоИмени(ИмяОбработки);
	
	Результат = "0.0.0";
	
	Если ЗначениеЗаполнено(ДопОбработка) Тогда
		Результат = ДополнительныеОтчетыИОбработки_ВерсияОбработки(ДопОбработка);
	КонецЕсли;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает параметры команды сбора данных модулем продуктовой аналитики.
// 
// Возвращаемое значение:
//  Структура - Содержит параметры для передачи в модуль продуктовой аналитики
//   * ИспользуетсяПодсистемаДиадок - Булево - Истина, если используется подсистема Диадок
//   * ИмяИнтегационногоМодуля - Строка - Маркер текущего интеграционного модуля
//
Функция ПродуктоваяАналитикаСлужебный_ПараметрыКоманды()
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользуетсяПодсистемаДиадок", ОбщийКонтекстКлиентСервер.ИспользуетсяПодсистемаДиадок);
	Результат.Вставить("ИмяИнтеграционногоМодуля", ИнтеграционныйМодуль_Получить());
	
	Возврат Результат;
	
КонецФункции

// Инсталлирует модуль продуктовой аналитики.
//
// Параметры:
//  ФайлПоставки - ДвоичныеДанные - файл поставки модуля.
//
Процедура ПродуктоваяАналитика_УстановитьМодуль(ФайлПоставки)
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	ИмяОбработки = ПродуктоваяАналитика_ИмяОбработки();
	ДопОбработка = ДополнительныеОтчетыИОбработки_НайтиПоИмени(ИмяОбработки);
	ГруппаОбработок = ДополнительныеОтчетыИОбработки_НайтиСоздатьГруппу("Контур.Диадок");
	
	ДополнительныеОтчетыИОбработки_СоздатьОбновить(
		ДопОбработка,
		ФайлПоставки,
		ИмяОбработки,
		ГруппаОбработок
	);
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПродуктоваяАналитика_ДобавитьСобытиеМетрики(TopicKey, СтекСобытий, Событие)
	
	Метрика_Логирование(TopicKey, Событие);
	
	Если МетрикиОтключены() Тогда
		Возврат;
	КонецЕсли;
	
	СтекСобытий.Топики[TopicKey].Добавить(Событие);
	
КонецПроцедуры

Процедура ПродуктоваяАналитика_ОтправитьМетрики(СтекСобытий)
	
	МетрикиОтправлены = ОтправитьСтекСобытийМетрики(СтекСобытий);
	
	Если НЕ МетрикиОтправлены Тогда
		ОтключитьМетрики();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПродуктоваяАналитика_ЗаписатьМетрикуОшибкаПодготовкиДанных(ВерсияДанных)
	
	Категория = "ПродуктоваяАналитика";
	Действие = "ОтправкаДанныхПродуктовойАналитики";
	
	ШаблонОшибки = НСтр("ru='Неожиданное значение версии модуля продуктовой аналитики: %1'");
	ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонОшибки, ВерсияДанных);
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("ТекстОшибки", ТекстОшибки);
	
	Метрика_ЗаписатьЛог(Категория, Действие, , Переменные);
	
КонецПроцедуры

