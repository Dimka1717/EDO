// Проверяет необходимость конвертации точности цены
// если ранее использовался модуль Diadoc.StandartUF
// и в нем была установлена настройка "Точность цены"
// 
// Возвращаемое значение:
//  Булево - Истина - конвертация необходима,
//           Ложь - конвертация не требуется
//
Функция ОбщиеНастройки_НеобходимаКонвертацияТочностиЦены() Экспорт 
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Результат = Ложь;
	
	СохраненноеЗначение = Модуль_ХранениеДанных.НастройкаМодуляСтандарт_ТочностьЦены();
	Если СохраненноеЗначение <> Неопределено Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Конвертирует настройку модуля Diadoc.StandartUF "Точность цены"
//
Процедура ОбщиеНастройки_КонвертироватьТочностьЦены() Экспорт 
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	Модуль_ХранениеДанных.КонвертацияНастроек_ТочностьЦены();
	
КонецПроцедуры

// Возвращает сохраненное значение настройки "Использовать сервис Контур.Маркировка"
// 
// Возвращаемое значение:
//  Булево - Истина, если включена интеграция с сервисом Контур.Маркировка.
//
Функция ЗначениеНастройки_ИспользоватьСервисКонтурМаркировка()
	
	СохраненноеЗначение = ОбщиеНастройки_Прочитать("ИспользоватьСервисКонтурМаркировка");
