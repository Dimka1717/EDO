Функция Организации_НоваяОрганизацияЭДО(СтруктураOrganization)
	
	Результат		= Контракт_ОрганизацияЭДО();
	Organization	= СтруктураOrganization.Organization;
	
	КраткоеНаименование	= СвойствоСтруктуры(Organization, "ShortName"	, "");
	ПолноеНаименование	= СвойствоСтруктуры(Organization, "FullName"	, "");
	
	Результат.ID						= Organization.Boxes[0].BoxId;
	Результат.ИНН				 		= СвойствоСтруктуры(Organization, "Inn"					, "");
	Результат.КПП						= СвойствоСтруктуры(Organization, "Kpp"					, "");
	Результат.ИдентификаторУчастникаЭДО	= СвойствоСтруктуры(Organization, "FnsParticipantId"	, "");
	Результат.OrgId				 		= СвойствоСтруктуры(Organization, "OrgId"				, "");
	Результат.Наименование				= ?(КраткоеНаименование = ""	, ПолноеНаименование	, КраткоеНаименование);
	
	Возврат Результат;
	
