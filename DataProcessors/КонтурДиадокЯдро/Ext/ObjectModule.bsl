	Переменные.Вставить("ЗапретитьВыгрузкуПМвСервисДиадок", СвойствоСтруктуры(ОбщиеНастройки, "ЗапретитьВыгрузкуПМвСервисДиадок"));
	Переменные.Вставить("ЗапретитьОбновлениеПМизСервисаДиадок", СвойствоСтруктуры(ОбщиеНастройки, "ЗапретитьОбновлениеПМизСервисаДиадок"));
	
	// Общие настройки: списки документов
	Переменные.Вставить("Загружать исходящие", СвойствоСтруктуры(ОбщиеНастройки, "ЗагружатьИсходящиеДокументы"));
	Переменные.Вставить("Загружать входящие", СвойствоСтруктуры(ОбщиеНастройки, "ЗагружатьВходящиеДокументы"));
	Переменные.Вставить("Загружать по сопоставленным", СвойствоСтруктуры(ОбщиеНастройки, "ЗагружатьДокументыПоСопоставленнымКонтрагентам"));
	Переменные.Вставить("Разворачивать пакеты по документам", СвойствоСтруктуры(ОбщиеНастройки, "РазворачиватьПакетыНаОтправкуПоДокументам"));
	Переменные.Вставить("Показывать количество документов", СвойствоСтруктуры(ОбщиеНастройки, "ПоказыватьКоличествоДокументовВСписке"));
	Переменные.Вставить("Использовать сопоставление подразделений", СвойствоСтруктуры(ОбщиеНастройки, "ИспользоватьСопоставлениеПодразделений"));
	
	// Общие настройки: входящие документы
	Переменные.Вставить("СоздаватьСчетаФактуры", СвойствоСтруктуры(ОбщиеНастройки, "СоздаватьСчетаФактуры"));
	Переменные.Вставить("СоздаватьПередаточныеДокументы", СвойствоСтруктуры(ОбщиеНастройки, "СоздаватьПередаточныеДокументы"));
	Переменные.Вставить("СозданиеДокументов_ИспользоватьДатуЭД", СвойствоСтруктуры(ОбщиеНастройки, "СозданиеДокументов_ИспользоватьДатуЭД"));
	Переменные.Вставить("РежимПроверкиСопоставленияНоменклатуры", СвойствоСтруктуры(ОбщиеНастройки, "РежимПроверкиСопоставленияНоменклатуры"));
	Переменные.Вставить("Отключить анализ входящих", СвойствоСтруктуры(ОбщиеНастройки, "ОтключитьАнализДляВходящихДокументов"));
	
	// Общие настройки: хранение документов
	Переменные.Вставить("Хранить файлы документов и подписей на диске", СвойствоСтруктуры(ОбщиеНастройки, "ХранитьДокументыНаДиске"));
	Переменные.Вставить("Сценарий скачивания документов", СвойствоСтруктуры(ОбщиеНастройки, "СохранениеДокументовСценарий"));
	Переменные.Вставить("Группировать по пакетам", СвойствоСтруктуры(ОбщиеНастройки, "СохранениеДокументовГруппироватьПоПакетам"));
	
