Процедура Модуль_ГенерацияXML_ИнициализироватьФабрикиXDTO(Модуль)
	
	Если Модуль.Кэш = Неопределено Тогда
		
		ИмяКэша = "ФабрикиXDTO";
		
		XML_ФабрикиXDTO = Кэш_Прочитать(ИмяКэша);
		
		Если XML_ФабрикиXDTO = Неопределено Тогда
			
			XML_ФабрикиXDTO = Новый Соответствие;
			ИменаФабрикXDTO = Модуль_ГенерацияXML_ИменаФабрикXDTO(Модуль);
			
			Для Каждого ИмяФабрикиXDTO Из ИменаФабрикXDTO Цикл
				
				XML_ФабрикаXDTO = Модуль.XML_ФабрикаXDTO(ИмяФабрикиXDTO);
				XML_ФабрикиXDTO.Вставить("ФабрикаXDTO_" + ИмяФабрикиXDTO, XML_ФабрикаXDTO);
				
			КонецЦикла;
			
			Кэш_Поместить(ИмяКэша, XML_ФабрикиXDTO);
			
		КонецЕсли;
		
		Модуль.Кэш = Новый Соответствие;
		
		Для Каждого ДанныеФабрикиXDTO Из XML_ФабрикиXDTO Цикл
			Модуль.Кэш.Вставить(ДанныеФабрикиXDTO.Ключ, ДанныеФабрикиXDTO.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Модуль_ГенерацияXML_ИменаФабрикXDTO(Модуль)
	
	Результат = Новый Массив;
	
	Для Каждого Макет Из Модуль.Метаданные().Макеты Цикл
		
		ИмяМакета = Макет.Имя;
		
		Если Прав(ИмяМакета, 4) = "_xsd" Тогда
			ИмяМакета = Лев(ИмяМакета, СтрДлина(ИмяМакета) - 4);
			Результат.Добавить(ИмяМакета);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

