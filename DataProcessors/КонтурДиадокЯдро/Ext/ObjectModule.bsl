Процедура ПредложенияДляПокупки_ЗаполнитьОснованиеПредложения(ПредложениеДляПокупки)
	
	СценарийПредложения = ПредложениеДляПокупки.Сценарий;
	
	Если ПредложенияДляПокупки_ЭтоПодпискаНаПромоМодуля(СценарийПредложения) Тогда
		
		ОснованиеПредложения = ПредложенияДляПокупки_ОснованиеПредложенияДляПромо();
		
	ИначеЕсли ПредложенияДляПокупки_ЭтоРекомендацияПлагинов(СценарийПредложения) Тогда
		
		ОснованиеПредложения = ПредложенияДляПокупки_ОснованиеПредложенияДляПлагинов();
		
	ИначеЕсли ПредложенияДляПокупки_ЭтоПодпискаНаПакет(СценарийПредложения) Тогда
		
		ОснованиеПредложения = ПредложенияДляПокупки_ОснованиеПредложенияДляПакета(ПредложениеДляПокупки);
		
	Иначе
		
		ОснованиеПредложения = ПредложенияДляПокупки_ОснованиеПредложенияДляПодписки(ПредложениеДляПокупки);
		
	КонецЕсли;
	
	ПредложениеДляПокупки.ОснованиеПредложения = ОснованиеПредложения;
	
КонецПроцедуры

