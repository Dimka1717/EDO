//**********************************************
//{		ДЛИТЕЛЬНЫЕ ОПЕРАЦИИ И ФОНОВЫЕ ЗАДАНИЯ

// Запускает фоновое задание для выполнения метода длительной операции,
// или синхронно выполняет метод, если фоновые задания использовать нельзя.
//
// Параметры:
//  ИмяМетода       - Строка - см. функцию ВыполнитьМетод().
//  ПараметрыМетода - Массив - (необязательный) см. функцию ВыполнитьМетод().
//
// Возвращаемое значение:
//   Структура - описание операции, см. функцию НовоеОписаниеДлительныеОперации().
//
Функция ДлительныеОперации_ВыполнитьОперацию(ИмяМетода, ПараметрыМетода = Неопределено) Экспорт
	
	ПараметрыДлительныхОпераций = ОбщийКонтекст_Прочитать("ПараметрыДлительныхОпераций");
	ИспользоватьФоновыеЗадания = СвойствоСтруктуры(ПараметрыДлительныхОпераций, "ИспользоватьФоновыеЗадания", Ложь);
	
	Если ИспользоватьФоновыеЗадания Тогда
		
		Результат = НачатьВыполнениеДлительнойОперации(ИмяМетода, ПараметрыМетода);
		
		ДлительнаяОперация_ПроверитьРезультат(Результат);
		
	Иначе
		
		Результат = НовоеОписаниеДлительныеОперации();
		
		Результат.ИмяМетода = ИмяМетода;
		Результат.Завершено = Истина;
		Результат.Результат = ВыполнитьМетод(ИмяМетода, ПараметрыМетода);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Обновляет признак Завершено и поле Результат в описании операции.
// После получения результата, данные из временного хранилища удаляются.
//
// Параметры:
//   ОписаниеОперации  - Структура    - см. функцию НовоеОписаниеДлительныеОперации();
//   ОжидатьЗавершения - Булево       - Истина, если нужно подождать завершения операции;
//
Процедура ДлительнаяОперация_ПроверитьРезультат(ОписаниеОперации, ОжидатьЗавершения = Ложь) Экспорт
	
	Если НЕ ОписаниеОперации.Завершено Тогда
		ОписаниеОперации.Завершено = ФоновоеЗадание_Завершено(ОписаниеОперации.ИдентификаторЗадания, ОжидатьЗавершения);
	КонецЕсли;
	
	Если ОписаниеОперации.Завершено Тогда
			
		АдресРезультата = ОписаниеОперации.АдресРезультата;
		
		Если ЗначениеЗаполнено(АдресРезультата) Тогда
			
			РезультатВыполнения = ВременноеХранилище_Прочитать(АдресРезультата);
			
			Если РезультатВыполнения = Неопределено Тогда
				
				ВидОперации				= "Выполнение фонового задания";
				ТекстСообщения			= "Произошла исключительная ситуация. Рекомендуется повторить действие.";
				ПодробныйТекстОшибки	= "Результат выполнения фонового задания не найден по адресу: " + АдресРезультата;
				
				СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстСообщения);
				Ошибка_ДобавитьВЖурналРегистрации(ПодробныйТекстОшибки);
				
				ОписаниеОперации.ТекстОшибки = ПодробныйТекстОшибки;
				
			Иначе
				
				ОписаниеОперации.Результат	= СвойствоСтруктуры(РезультатВыполнения, "РезультатОперацииДиадок");
				СписокОшибокОперации		= СвойствоСтруктуры(РезультатВыполнения, "СписокОшибокДиадок");
				
				ДлительнаяОперация_ОбработатьСписокОшибок(СписокОшибокОперации);
				
			КонецЕсли;
			
			ВременноеХранилище_Удалить(АдресРезультата);
			ОписаниеОперации.АдресРезультата = Неопределено;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДлительнаяОперация_ОбработатьСписокОшибок(СписокОшибокОперации)
	
	ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
	
	Для Каждого РазделСообщений Из СписокОшибокОперации Цикл
		Для Каждого СообщениеРаздела Из РазделСообщений.Строки Цикл
			
			ВидОперации		= РазделСообщений.ТекстСообщения;
			ТекстСообщения	= СообщениеРаздела.ТекстСообщения;
			Расшифровка		= СообщениеРаздела.Расшифровка;
			
			СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстСообщения, Расшифровка);
			
			Если РежимЛогированияВключен() Тогда
				Ошибка_ДобавитьВФайл(ТекстСообщения);
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Запускает фоновое задание для выполнения длительной операции.
//
// Параметры:
//  ИмяМетода       - Строка - см. функцию ВыполнитьМетод().
//  ПараметрыМетода - Массив - (необязательный) см. функцию ВыполнитьМетод().
//
// Возвращаемое значение:
//   Структура - см. функцию НовоеОписаниеДлительныеОперации().
//
Функция НачатьВыполнениеДлительнойОперации(ИмяМетода, ПараметрыМетода = Неопределено)

	НаименованиеЗадания	 = "Диадок.ФоновоеЗадание." + ИмяМетода;
	
	ПараметрыОперации = НовыеПараметрыДлительнойОперации(ИмяМетода, ПараметрыМетода);
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ПараметрыОперации", ПараметрыОперации);
	
	ПараметрыДлительныхОпераций = ОбщийКонтекст_Прочитать("ПараметрыДлительныхОпераций");
	ИспользоватьБСП = СвойствоСтруктуры(ПараметрыДлительныхОпераций, "ИспользоватьБСП", Ложь);
	ИдентификаторКоманды = "ВыполнитьДлительнуюОперацию";
	
	Если ИспользоватьБСП Тогда
		
		ОписаниеЗадания = ЗапуститьФоновоеЗаданиеЧерезБСП(ИдентификаторКоманды, ПараметрыКоманды, НаименованиеЗадания);
		
	Иначе
		
		ОписаниеЗадания = ЗапуститьФоновоеЗадание(ИдентификаторКоманды, ПараметрыКоманды, НаименованиеЗадания);
		
	КонецЕсли;
	
	Результат = НовоеОписаниеДлительныеОперации();
	
	Результат.ИмяМетода				 = ИмяМетода;
	Результат.АдресРезультата		 = ОписаниеЗадания.АдресРезультата;
	Результат.ИдентификаторЗадания	 = ОписаниеЗадания.ИдентификаторЗадания;
	
	Возврат Результат;
	
КонецФункции

// Инициализирует контест и выполняет метод длительной операции в фоновом задании.
//
// Параметры:
//  ПараметрыОперации - Структура - см. функцию НовыеПараметрыДлительнойОперации().
//
// Возвращаемое значение:
//   Произвольный - результат выполнения операции.
//
Функция ВыполнитьДлительнуюОперацию(ПараметрыОперации)
	
	ИмяМетода		 = ПараметрыОперации.ИмяМетода;
	ПараметрыМетода	 = ПараметрыОперации.ПараметрыМетода;
	
	ИнициализироватьКонтекстФоновогоЗадания(ПараметрыОперации);
	
	Результат = ВыполнитьМетод(ИмяМетода, ПараметрыМетода);
	
	Возврат Результат;
	
КонецФункции

// Определяет параметры для запуска длительных операций.
//
// Возвращаемое значение:
//  Структура - содержит поля:
//    * ИспользоватьФоновыеЗадания - Булево - Истина, если механизм фоновых заданий использовать можно.
//    * ИспользоватьБСП            - Булево - Истина, если длительные операции будут выполняться
//                                            с помощью стандартного механизма фонового выполнения
//                                            длительных операций через команду внешней обработки,
//                                            из справочника дополнительных обработок.
//    * ВнешняяОбработкаМодуля - СправочникСсылка - (необязательный) ссылка на внешнюю обработку модуля
//                                                в справочнике дополнительных обработок.
//                                                Обязателен, если ИспользоватьБСП = Истина.
//
Функция ПараметрыДлительныхОпераций()
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьБСП"			, Ложь);
	Результат.Вставить("ИспользоватьФоновыеЗадания"	, Ложь);
	Результат.Вставить("ВнешняяОбработкаМодуля"		, Неопределено);
	
	ФайловыйРежимРаботы				= ФайловыйРежимРаботы();
	ФоновыеОперацииРазрешены		= ФоновыеОперацииРазрешены();
	
	Если НЕ ФайловыйРежимРаботы И ФоновыеОперацииРазрешены Тогда
		
		ИспользоватьТиповуюПодсистему1С = ОбщиеНастройки_Прочитать("ИспользоватьТиповуюПодсистему1С");
		
		Если ИспользоватьТиповуюПодсистему1С Тогда
			
			ВнешняяОбработкаМодуляДляБСП = СсылкаНаДопОбработкуОсновногоМодуля();
			
			МожноПередаватьПараметрыВКомандуОбработки = (СравнитьВерсии(ТекущаяВерсияБСП(), "1.2.1.4") >= 0);
			
			ЕстьМеханизмДлительныхОпераций = ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули.ДлительныеОперации")
			И ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули.ДополнительныеОтчетыИОбработки");
			
			Если ЕстьМеханизмДлительныхОпераций
				И МожноПередаватьПараметрыВКомандуОбработки
				И ЗначениеЗаполнено(ВнешняяОбработкаМодуляДляБСП) Тогда
				
				Результат.ИспользоватьБСП			 = Истина;
				Результат.ИспользоватьФоновыеЗадания = Истина;
				Результат.ВнешняяОбработкаМодуля	 = ВнешняяОбработкаМодуляДляБСП;
				
			КонецЕсли;
			
		ИначеЕсли ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули.Диадок_ФоновыеЗадания") Тогда
			
			Результат.ИспользоватьФоновыеЗадания = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СсылкаНаДопОбработкуОсновногоМодуля()
	
	Результат = Неопределено;
	
	ОсновнойМодуль = ПодключенныеОбработки_Прочитать("ОсновнойМодуль");
	Если ОсновнойМодуль <> Неопределено Тогда
		
		ИмяФайлаОсновногоМодуля	 = ОсновнойМодуль.ИспользуемоеИмяФайла;
		МестоположенияМодуля	 = Перечисление_МестоположенияМодуля();
		Местоположение			 = МестоположениеМодуляПоИспользуемомуИмениФайла(ИмяФайлаОсновногоМодуля, МестоположенияМодуля);
		
		Если Местоположение = МестоположенияМодуля.ЭлементСправочника Тогда
			
			ВнешняяОбработкаМодуля = ОбновленияМодуля_ПодходящаяВнешняяОбработка(ОсновнойМодуль.Версия);
			
			Если ЗначениеЗаполнено(ВнешняяОбработкаМодуля) Тогда
				
				Результат = ВнешняяОбработкаМодуля;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 

// Возвращает структуру для описания состояния выполняемой операции.
//
// Возвращаемое значение:
//  Структура - содержит свойства:
//     * Завершено            - Булево       - Истина, если задание завершено.
//     * Результат            - Произвольный - Результат выполнения операции.
//     * АдресРезультата      - Строка       - Адрес временного хранилища,по которому можно получить
//                                             результат асинхронной операции.
//     * ИдентификаторЗадания - УникальныйИдентификатор - см. функцию НовоеОписаниеФоновогоЗадания().
//
Функция НовоеОписаниеДлительныеОперации()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ИмяМетода");
	Результат.Вставить("Завершено", Ложь);
	Результат.Вставить("ИдентификаторЗадания");
	Результат.Вставить("АдресРезультата");
	Результат.Вставить("Результат");
	Результат.Вставить("ТекстОшибки");
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру параметров для инициализации контекста
// и запуска длительной операции в фоновом задании.
//
// Параметры:
//  ИмяМетода       - Строка - см. функцию ВыполнитьМетод().
//  ПараметрыМетода - Массив - (необязательный) см. функцию ВыполнитьМетод().
//
// Возвращаемое значение:
//   Структура - содержит свойства:
//      * ИмяМетода           - Строка       - значение входящего параметра.
//      * ПараметрыМетода     - Массив       - значение входящего параметра.
//      * ВерсияОбработки     - Строка       - текущая версия обработки.
//      * КонтекстСеанса      - Соответствие - см. функцию КонтекстСеанса_СтрокиКонтекста().
//      * МакетыОбработки     - Структура    - см. функцию МакетыОбработки_ДляФоновогоЗадания().
//
Функция НовыеПараметрыДлительнойОперации(ИмяМетода, ПараметрыМетода = Неопределено)
	
	Результат = Новый Структура;
	
	Результат.Вставить("ИмяМетода", ИмяМетода);
	Результат.Вставить("ПараметрыМетода", ПараметрыМетода);
	Результат.Вставить("РежимОтладки", РежимОтладкиВключен());
	Результат.Вставить("МакетыОбработки", Макеты_ДляФоновогоЗадания());
	Результат.Вставить("КонтекстСеанса", КонтекстСеанса_СтрокиКонтекста());
	Результат.Вставить("ВерсияОбработки", ВерсияОбработки());
	Результат.Вставить("ОбщиеНастройки", ХранениеДанных_ОбщиеНастройки());
	Результат.Вставить("ВерсияМодуля", ОбщийКонтекст_Прочитать("ВерсияМодуля"));
	Результат.Вставить("КлючРазработчика", ОбщийКонтекст_Прочитать("КлючРазработчика"));
	Результат.Вставить("АдресDiadocAPI", ОбщийКонтекст_Прочитать("АдресDiadocAPI"));
	Результат.Вставить("АдресKonturAPI", ОбщийКонтекст_Прочитать("АдресKonturAPI"));
	Результат.Вставить("ЗапускИзРасширения", ИспользуетсяРасширениеКонтурДиадок());
	Результат.Вставить("ПровайдерСервиса", ОбщийКонтекст_Прочитать("ПровайдерСервиса"));
	Результат.Вставить("ФункциональныеОпции", ОбщийКонтекст_Прочитать("ФункциональныеОпции"));
	Результат.Вставить("Зависимости", ОбщийКонтекст_Прочитать("__Зависимости"));
	
	ОбщийКэшДлительнойОперации = ОбщийКэшДлительнойОперации(ИмяМетода);
	Результат.Вставить("ОбщийКэшДлительнойОперации", ОбщийКэшДлительнойОперации);
	
	Возврат Результат;
	
КонецФункции

// Проверяет возможность работы фонового задания,
// вызывает исключение в случае ошибки.
//
Процедура ПроверитьВозможностьЗапускаФоновогоЗадания() Экспорт
	
	ТекущиеЗначение_РазрешитьДлительныеОперацииВФоне	 = ОбщиеНастройки_Прочитать("РазрешитьДлительныеОперацииВФоне");
	ТекущиеЗначение_ПараметрыДлительныхОпераций			 = ОбщийКонтекст_Прочитать("ПараметрыДлительныхОпераций");
	
	ОбщиеНастройки_Поместить("РазрешитьДлительныеОперацииВФоне", Истина);
	НовыеПараметрыДлительныхОпераций = ПараметрыДлительныхОпераций();
	ОбщийКонтекст_Поместить("ПараметрыДлительныхОпераций", НовыеПараметрыДлительныхОпераций);
	
	ОписаниеОперации = НачатьВыполнениеДлительнойОперации("ТестФоновогоЗадания");
	
	ОбщиеНастройки_Поместить("РазрешитьДлительныеОперацииВФоне", ТекущиеЗначение_РазрешитьДлительныеОперацииВФоне);
	ОбщийКонтекст_Поместить("ПараметрыДлительныхОпераций", ТекущиеЗначение_ПараметрыДлительныхОпераций);
	
	ДлительнаяОперация_ПроверитьРезультат(ОписаниеОперации, Истина);
	
	Результат = ОписаниеОперации.Результат;
	
	Если Результат <> Истина Тогда
		
		Если НЕ ЗначениеЗаполнено(Результат) Тогда
			РезультатТеста = ТипЗнч(Результат);
		КонецЕсли;
		
		ТекстОшибки = "Неправильный результат тестирования фонового задания: " + Результат;
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

// Проверяет наличие интеграционного и подключаемого модулей
// в контексте фонового задания.
//
// Возвращаемое значение:
//   Булево - Истина, если интеграционный и подключаемый модули есть в контексте.
//
Функция ТестФоновогоЗадания()

	Результат = Ложь;
	
	ЭтоФоновоеЗадание = ЭтоФоновоеЗадание();
	Если ЭтоФоновоеЗадание Тогда
	
		Модуль_Проверить_ИМ_ПМ();
		
		Результат = Истина;
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Запускает фоновое задание через общий модуль "Диадок_ФоновыеЗадания"
// для выполнения команды внешней обработки ядра.
//
// Параметры:
//	ИдентификаторКоманды - Строка - Идентификатор запускаемой команды
//	ПараметрыКоманды - Структура - Структура параметров запускаемой команды
//	НаименованиеЗадания - Строка - Наименование запускаемого фонового задания
//
// Возвращаемое значение:
// 	Структура - см. функцию НовоеОписаниеФоновогоЗадания()
//
Функция ЗапуститьФоновоеЗадание(ИдентификаторКоманды, ПараметрыКоманды, НаименованиеЗадания)
	
	Если Не ЭтоВнешняяОбработка() Тогда
		ФайлОбработки = "КонтурДиадокЯдро";
	Иначе
		ФайлОбработки = Макеты_ФайлЯдра();
	КонецЕсли;
	
	ИмяПроцедуры = "Диадок_ФоновыеЗадания.ВыполнитьКоманду";
	ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
	АдресРезультата = ВременноеХранилище_Поместить(Неопределено, ИдентификаторФормы);
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("ПараметрыКоманды", ПараметрыКоманды);
	ПараметрыПроцедуры.Вставить("ИдентификаторКоманды", ИдентификаторКоманды);
	
	МассивПараметров = ПараметрыВМассив(ФайлОбработки, ПараметрыПроцедуры, АдресРезультата);
	
	Задание = ФоновыеЗадания.Выполнить(ИмяПроцедуры, МассивПараметров, , НаименованиеЗадания);
	
	Результат = НовоеОписаниеФоновогоЗадания();
	Результат.АдресРезультата = АдресРезультата;
	Результат.ИдентификаторЗадания = Задание.УникальныйИдентификатор;
	
	Возврат Результат;
	
КонецФункции

// Запускает фоновое задание с помощью стандартной подсистемы длительных операций,
// для выполнения команды внешней обработки ядра.
//
// Возвращаемое значение:
//   Структура - см. функцию НовоеОписаниеФоновогоЗадания()
//
Функция ЗапуститьФоновоеЗаданиеЧерезБСП(ИдентификаторКоманды, ПараметрыКоманды, НаименованиеЗадания)
	
	ОбщийМодульДлительныеОперации = ОбщийМодуль_ПолучитьБезопасно("ДлительныеОперации");
	
	ИмяПроцедуры		 = "ДополнительныеОтчетыИОбработки.ВыполнитьКоманду";
	ИдентификаторФормы	 = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
	
	ПараметрыДлительныхОпераций	 = ОбщийКонтекст_Прочитать("ПараметрыДлительныхОпераций");
	ВнешняяОбработкаМодуля		 = ПараметрыДлительныхОпераций.ВнешняяОбработкаМодуля;
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("ПараметрыКоманды",				 ПараметрыКоманды);
	ПараметрыПроцедуры.Вставить("ИдентификаторКоманды",			 ИдентификаторКоманды);
	ПараметрыПроцедуры.Вставить("ДополнительнаяОбработкаСсылка", ВнешняяОбработкаМодуля);
	
	ПараметрыВыполнения = ОбщийМодульДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания	 = НаименованиеЗадания;
	ПараметрыВыполнения.ОжидатьЗавершение			 = 0;
	ПараметрыВыполнения.КлючФоновогоЗадания			 = "ИдентификаторКоманды_" + XMLСтрока(Новый УникальныйИдентификатор);
	
	ОписаниеЗаданияБСП = ОбщийМодульДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыПроцедуры, ПараметрыВыполнения);
	
	Если ОписаниеЗаданияБСП.Статус = "Ошибка" Тогда
		
		ТекстОшибки = ОписаниеЗаданияБСП.ПодробноеПредставлениеОшибки;
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = НовоеОписаниеФоновогоЗадания();
	Результат.АдресРезультата		 = ОписаниеЗаданияБСП.АдресРезультата;
	
	Если ОписаниеЗаданияБСП.Свойство("УникальныйИдентификатор") Тогда
		Результат.ИдентификаторЗадания	 = ОписаниеЗаданияБСП.УникальныйИдентификатор;
	ИначеЕсли ОписаниеЗаданияБСП.Свойство("ИдентификаторЗадания") Тогда
		Результат.ИдентификаторЗадания	 = ОписаниеЗаданияБСП.ИдентификаторЗадания;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет статус фонового задания
//
// Параметры:
//  ИдентификаторЗадания  - УникальныйИдентификатор - см. функцию НовоеОписаниеДлительныеОперации();
//  ОжидатьЗавершения     - Булево                  - Истина, если нужно подождать завершения задания;
//
// Возвращаемое значение:
//  Булево - Истина, если задание завершено
//
Функция ФоновоеЗадание_Завершено(ИдентификаторЗадания, ОжидатьЗавершения = Ложь)
	
	Результат = Ложь;
	
	Если ОжидатьЗавершения Тогда
		ФоновоеЗадание_ПодождатьЗавершения(ИдентификаторЗадания);
	КонецЕсли;
	
	Задание = ФоновоеЗадание_НайтиПоИдентификатору(ИдентификаторЗадания);
	
	Если Задание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
		
		Результат = Истина;
		
	ИначеЕсли Задание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
		
		ТекстОшибки = "Фоновое задание отменено администратором " + ИдентификаторЗадания;
		
		ВызватьИсключение ТекстОшибки;
		
	ИначеЕсли Задание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
		
		ТекстОшибки = ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Ожидает завершения хотябы одного из перечисленных фоновых заданий
//
// Параметры:
//  ИдентификаторыЗаданий - Массив - содержит уникальные идентификаторы фоновых заданий
//
Процедура ФоновоеЗадание_ПодождатьЗавершенияЛюбогоЗадания(Знач ИдентификаторыЗаданий) Экспорт
	
	НачалоОбработки = Истина;
	ЕстьЗавершенныеЗадания = Ложь;
	
	Пока Не ЕстьЗавершенныеЗадания Цикл
		
		Если Не НачалоОбработки Тогда
			ФоновоеЗадание_ПодождатьЗавершения(ИдентификаторыЗаданий[0], 1);
		КонецЕсли;
		
		Для Каждого ИдентификаторЗадания Из ИдентификаторыЗаданий Цикл
			
			Задание = ФоновоеЗадание_НайтиПоИдентификатору(ИдентификаторЗадания);
			
			Если Задание.Состояние <> СостояниеФоновогоЗадания.Активно Тогда
				ЕстьЗавершенныеЗадания = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		НачалоОбработки = Ложь;
		
	КонецЦикла;
	
КонецПроцедуры

// Ожидает завершения фонового задания
//
// Параметры:
//  ИдентификаторЗадания      - УникальныйИдентификатор - см. функцию НовоеОписаниеДлительныеОперации();
//  МаксимальноеВремяОжидания - Число                   - (необязательный) максимальное время ожидания в секундах;
//
Процедура ФоновоеЗадание_ПодождатьЗавершения(ИдентификаторЗадания, МаксимальноеВремяОжидания = Неопределено)
	
	Задание = ФоновоеЗадание_НайтиПоИдентификатору(ИдентификаторЗадания);
	
	Если Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		
		Попытка
			Задание.ОжидатьЗавершения(МаксимальноеВремяОжидания);
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает по идентификатору объект фонового задания.
// Вызывает исключение, если фоновое задание найти не удалось.
//
// Возвращаемое значение:
//   ФоновоеЗадание - найденное задание.
//
Функция ФоновоеЗадание_НайтиПоИдентификатору(ИдентификаторЗадания)
	
	Результат = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);
	
	Если Результат = Неопределено Тогда
		
		ТекстОшибки = "Фоновое задание не найдено по идентификатору " + ИдентификаторЗадания;
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру для описания запущенного фонового задания.
//
// Возвращаемое значение:
//   Структура - содержит свойства:
//     * АдресРезультата      - Строка - Адрес временного хранилища,по которому можно получить
//                                       результат асинхронной операции по завершению фонового задания.
//     * ИдентификаторЗадания - УникальныйИдентификатор - Уникальный идентификатор фонового задания,
//                                                        при выполнении операции асинхронно.
//
Функция НовоеОписаниеФоновогоЗадания()
	
	Результат = Новый Структура;
	Результат.Вставить("АдресРезультата");
	Результат.Вставить("ИдентификаторЗадания");
	
	Возврат Результат;
	
КонецФункции

// Инициализирует контест в фоновом задании.
//
// Параметры:
//   ПараметрыОперации - Структура - см. функцию НовыеПараметрыДлительнойОперации().
//
Процедура ИнициализироватьКонтекстФоновогоЗадания(ПараметрыОперации)
	
	ПроверитьВерсиюОбработкиФоновогоЗадания(ПараметрыОперации.ВерсияОбработки);
	ПараметрыКонтекста = ПараметрыИнициализацииОбщегоКонтекста();
	ПараметрыКонтекста.РежимОтладки = ПараметрыОперации.РежимОтладки;
	ПараметрыКонтекста.ВерсияМодуля = ПараметрыОперации.ВерсияМодуля;
	ПараметрыКонтекста.Зависимости = ПараметрыОперации.Зависимости;
	ПараметрыКонтекста.МакетыОбработки = ПараметрыОперации.МакетыОбработки;
	ПараметрыКонтекста.ОбщиеНастройки = ПараметрыОперации.ОбщиеНастройки;
	ПараметрыКонтекста.КлючРазработчика = ПараметрыОперации.КлючРазработчика;
	ПараметрыКонтекста.АдресDiadocAPI = ПараметрыОперации.АдресDiadocAPI;
	ПараметрыКонтекста.АдресKonturAPI = ПараметрыОперации.АдресKonturAPI;
	ПараметрыКонтекста.ЗапускИзРасширения = ПараметрыОперации.ЗапускИзРасширения;
	ПараметрыКонтекста.ПровайдерСервиса = ПараметрыОперации.ПровайдерСервиса;
	ПараметрыКонтекста.ЭтоДлительнаяОперация = Истина;
	
	ХранилищеКэш_Установить(ПараметрыОперации.ОбщийКэшДлительнойОперации);
	
	Макеты_Установить(ПараметрыОперации.МакетыОбработки);
	ФоновыеЗадания_ПодключитьЗависимости(ПараметрыОперации.Зависимости);
	
	ИнициализироватьОбщийКонтекст(ПараметрыКонтекста);
	ХранилищеКонтекстаСеанса_Установить(ПараметрыОперации.КонтекстСеанса);
	ОбщийКонтекст_Поместить("ФункциональныеОпции", ПараметрыОперации.ФункциональныеОпции);
	
КонецПроцедуры

Процедура ФоновыеЗадания_ПодключитьЗависимости(Зависимости)
	
	Для Каждого Зависимость Из Зависимости Цикл
		
		ТипОбъекта = Зависимость.Тип + "." + Зависимость.Имя;
		Если ТипОпределен(ТипОбъекта) Тогда
			Продолжить;
		КонецЕсли;
		
		ФайлИлиПуть = Макеты_ДанныеМакета(Зависимость.Имя);
		
		Если Не ЗначениеЗаполнено(ФайлИлиПуть) И Зависимость.ВызыватьИсключение Тогда
			Ошибка = Общее_ПодставитьПараметрыВСтроку("Отсутствует файл зависимости (%1)", Зависимость.Имя);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		ЭтоИмяФайла = Общее_ЭтоИмяФайла(ФайлИлиПуть);
		
		// BSLLS:UnusedLocalVariable-off
		Попытка
			Если ЭтоИмяФайла Тогда
				Модуль = Модуль_СоздатьИзФайлаНаДиске(Зависимость.Имя, ФайлИлиПуть);
			Иначе
				Модуль = Модуль_СоздатьИзДвоичныхДанных(Зависимость.Имя, ФайлИлиПуть);
			КонецЕсли;
		Исключение
		// BSLLS:UnusedLocalVariable-on
			
			Если Зависимость.ВызыватьИсключение Тогда
				ВызватьИсключение;
			КонецЕсли;
			
			ОшибкаИнфо = ИнформацияОбОшибке();
			
			// BSLLS:UsageWriteLogEvent-off
			ЗаписьЖурналаРегистрации(
				"Диадок.ИнициализацияФоновогоЗадания",
				УровеньЖурналаРегистрации.Предупреждение,
				Метаданные(),
				ТипОбъекта,
				ПодробноеПредставлениеОшибки(ОшибкаИнфо)
			);
			// BSLLS:UsageWriteLogEvent-on
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// Проверяет, определен ли в контексте текущего сеанса указанный тип
//
// Параметры:
//  ИмяТипа - Строка - имя проверяемого типа (например, "ОбработкаОбъект.КонтурДиадокСтд")
// 
// Возвращаемое значение:
//  Булево - Истина, если тип определен.
//
Функция ТипОпределен(ИмяТипа)
	
	Попытка
		Тип = Тип(ИмяТипа);
	Исключение
		Тип = Тип("Неопределено");
	КонецПопытки;
	
	Результат = (Тип <> Тип("Неопределено"));
	
	Возврат Результат;
	
КонецФункции

Функция ОбщийКэшДлительнойОперации(ИмяМетода)

	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ТаблицаПерекодировки = ХранениеДанных.ТаблицаПерекодировки();
	
	ТипыДокументовAPI_ПроверитьНаличие();
	
	Если ИмяМетода = "Пакеты_ПодготовитьПакетыДляОтправки"
		ИЛИ ИмяМетода = "Пакеты_ПерезаполнитьПакетыПоСтрокамСписка" Тогда
		СписокДокументов_ПолучитьИзЛокальногоКэша();	
	КонецЕсли;
	
	Кэш = ХранилищеКэш();
	
	КэшСтрокой = ЗначениеВСтрокуВнутр(Кэш);
	
	Результат = ЗначениеИзСтрокиВнутр(КэшСтрокой);
	
	Возврат Результат;
	
КонецФункции 

// Проверяет что требуемая версия равна версии текущей обработки,
// в противном случае вызывается исключение.
//
// Параметры:
//   ТребуемаяВерсия - Строка - требуемая версия обработки.
//
Процедура ПроверитьВерсиюОбработкиФоновогоЗадания(ТребуемаяВерсия)
	
	ТекущаяВерсия = ВерсияОбработки();
	
	Если ТекущаяВерсия <> ТребуемаяВерсия Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку("Текущая версия обработки ""%1"" не соответствует требуемой ""%2""!", ТекущаяВерсия, ТребуемаяВерсия);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли; 
	
КонецПроцедуры

// Выполняет небезопасно произвольный метод.
//
// Параметры:
//  ИмяМетода        - Строка - Имя функции, которую нужно выполнить.
//  МассивПараметров - Массив - (необязательный) параметры функции
//                              в порядке их расположения в сигнатуре фукнции,
//                              см. функцию ПараметрыВМассив().
//
// Возвращаемое значение:
//   Произвольный - Результат выполнения метода.
//
Функция ВыполнитьМетод(ИмяМетода, ПараметрыМетода = Неопределено)
	
	СтрокаПараметров = СтрокаИзМассиваПараметров(ПараметрыМетода, "ПараметрыМетода");
	
	Результат = Вычислить(ИмяМетода + "(" + СтрокаПараметров + ")");
	
	Возврат Результат;
	
КонецФункции

Функция ФоновоеЗадание_МаксимальноеКоличество()
	
	Результат = 10;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ОписаниеЗадачиВФоне(ИмяМетода, ПараметрыМетода = Неопределено)
	
	Результат = Новый Структура;
	
	Результат.Вставить("ИмяМетода",			ИмяМетода);
	Результат.Вставить("ПараметрыМетода",	ПараметрыМетода);
	Результат.Вставить("Результат",			Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Обрабатывает в несколько потоков очередь задач
//
// Параметры:
//  ОчередьЗадач - Массив - содержит структуры см. функцию Новый_ОписаниеЗадачиВФоне()
//
Процедура ОчередьЗадач_Обработать(ОчередьЗадач)
	
	КоличествоПотоков = ФоновоеЗадание_МаксимальноеКоличество();
	
	ИндексСледующейЗадачи = 0;
	ИндексПоследнейЗадачи = ОчередьЗадач.ВГраница();
	
	ТекущиеЗадачи = Новый Массив;
	ЗадачиИзменились = Ложь;
	
	Пока ЗначениеЗаполнено(ТекущиеЗадачи) Или ИндексСледующейЗадачи <= ИндексПоследнейЗадачи Цикл
		
		Пока ИндексСледующейЗадачи <= ИндексПоследнейЗадачи Цикл
			
			Если ТекущиеЗадачи.Количество() >= КоличествоПотоков Тогда
				Прервать; // Достигнут предел допустимого количества фоновых заданий
			КонецЕсли;
			
			Задача			 = ОчередьЗадач[ИндексСледующейЗадачи];
			ОписаниеОперации = ДлительныеОперации_ВыполнитьОперацию(Задача.ИмяМетода, Задача.ПараметрыМетода);
			
			ОписаниеЗадачи = Новый Структура;
			ОписаниеЗадачи.Вставить("Задача"			, Задача);
			ОписаниеЗадачи.Вставить("ОписаниеОперации"	, ОписаниеОперации);
			
			ТекущиеЗадачи.Вставить(0, ОписаниеЗадачи);
			
			ЗадачиИзменились = Истина;
			
			ИндексСледующейЗадачи = ИндексСледующейЗадачи + 1;
			
		КонецЦикла;
		
		Если Не ЗадачиИзменились Тогда
			ОчередьЗадач_ПодождатьЗавершенияЛюбойЗадачи(ТекущиеЗадачи);
		КонецЕсли;
		
		ЗадачиИзменились = Ложь;
		
		Для Сч = -ТекущиеЗадачи.ВГраница() По 0 Цикл
			
			ИндексЗадачи = -Сч;
			
			ОписаниеЗадачи	 = ТекущиеЗадачи[ИндексЗадачи];
			Задача			 = ОписаниеЗадачи.Задача;
			ОписаниеОперации = ОписаниеЗадачи.ОписаниеОперации;
			
			ДлительнаяОперация_ПроверитьРезультат(ОписаниеОперации);
			
			Если ОписаниеОперации.Завершено Тогда
				
				Задача.Результат = ОписаниеОперации.Результат;
				
				ТекущиеЗадачи.Удалить(ИндексЗадачи);
				
				ЗадачиИзменились = Истина;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Ожидает завершения хотябы одного из перечисленных фоновых заданий
//
// Параметры:
//  МассивЗадач - Массив - содержит структуры, с полями:
//                 * Задача           - см. функцию Новый_ОписаниеЗадачиВФоне();
//                 * ОписаниеОперации - см. функцию НовоеОписаниеДлительныеОперации();
//
Процедура ОчередьЗадач_ПодождатьЗавершенияЛюбойЗадачи(МассивЗадач)
	
	ИдентификаторыЗаданий = Новый Массив;
	
	Для каждого ОписаниеЗадачи Из МассивЗадач Цикл
		
		ИдентификаторЗадания = ОписаниеЗадачи.ОписаниеОперации.ИдентификаторЗадания;
		
		ИдентификаторыЗаданий.Добавить(ИдентификаторЗадания);
		
	КонецЦикла;
	
	ФоновоеЗадание_ПодождатьЗавершенияЛюбогоЗадания(ИдентификаторыЗаданий);
	
КонецПроцедуры

