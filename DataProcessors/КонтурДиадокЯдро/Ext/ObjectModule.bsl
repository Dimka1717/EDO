//Служебный. Транспорт HTTP из модуля "Центр поддержки"
Функция ЦП_ОтправитьЗапрос(Запрос) Экспорт
	
	ВнешниеСервисы								 = Модуль_ВнешниеСервисы(ЭтотОбъект);
	ПараметрыСервиса							 = ПараметрыСервиса_Контур();
	ПараметрыСервиса.АдресВебСервиса			 = Запрос.Хост;
	ПараметрыСервиса.ИспользоватьНовоеСоединение = Истина;
	
	ПараметрыЗапроса = ВнешниеСервисы.ПараметрыHTTPЗапроса();
	ПараметрыЗапроса.Заголовки   = Запрос.Заголовки;
	ПараметрыЗапроса.Метод		 = Запрос.Метод;
	ПараметрыЗапроса.АдресМетода = Запрос.Ресурс;
	ПараметрыЗапроса.ТелоЗапроса = Запрос.Тело;
	ПараметрыЗапроса.ТелоОтветаКакДвоичныеДанные = Истина;
	
	ЭтоОтправкаВложения		 = Найти(ПараметрыЗапроса.АдресМетода, "/csi/attachments/v1/upload?integrationId") > 0;
	ИспользоватьВнешнийHTTP	 = ВнешниеСервисы.ИспользоватьВнешнийHTTP();
	Если ЭтоОтправкаВложения Тогда
		ПараметрыЗапроса.ПринудительноИспользоватьNative = Истина;
	ИначеЕсли ИспользоватьВнешнийHTTP Тогда
		ПараметрыЗапроса.ТелоЗапроса = СтрокаИзДвоичныхДанных(Запрос.Тело);
	КонецЕсли;
	
	ПараметрыЗапроса.ДопустимыеКодыОтвета.Добавить(200);
	ПараметрыЗапроса.ДопустимыеКодыОтвета.Добавить(201);
	ПараметрыЗапроса.ДопустимыеКодыОтвета.Добавить(204);
	
	Ответ = ВнешниеСервисы.ВыполнитьHTTPЗапрос(ПараметрыСервиса, ПараметрыЗапроса);
	
	Результат = Новый Структура("КодСостояния, Тело");
	Результат.КодСостояния	 = Ответ.КодОтвета;
	Результат.Тело			 = Ответ.ТелоОтвета;
	
	Возврат Результат;
	
КонецФункции

