Функция ПараметрыПМ_ПолучитьЗаполненныйОбъектДокумента1С(Знач Документ, Знач ДополнительныеПараметры, Знач ИдентификаторОперации)
	
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Неопределено);
	НастройкаСоздаватьСФ = ЗначениеНастройки_СоздаватьСчетаФактуры();
	
	Результат = Новый Структура;
	Результат.Вставить("Документ", Документ);
	Результат.Вставить("ИдентификаторОперации", ИдентификаторОперации);
	Результат.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	Результат.Вставить("Контент", ХранилищеКонтента);
	Результат.Вставить("ПакетДД", Документ.Идентификаторы.ПакетЭДО);
	Результат.Вставить("ДокументДД", Документ.Идентификаторы.ДокументЭДО);
	Результат.Вставить("СоздаватьСчетаФактуры", НастройкаСоздаватьСФ);
	
	КонтентOCR = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтентOCR");
	
	Если ЗначениеЗаполнено(КонтентOCR) Тогда
		Результат.Контент = Контракт_ДанныеХранения();
		Результат.Контент.Данные = КонтентOCR;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Типовой обработчик события "ПолучитьЗаполненныйОбъектДокумента1С"
//
// Параметры:
//  Документ - Структура - электронный документ (см. Контракт_Документ)
//  ИдентификаторОперации - Строка, Неопределено - идентификатор операции по созданию учетного документа
//													(см. Документы_СписокТиповДокументовДляСоздания)
//  ДополнительныеПараметры - Структура - дополнительные параметры обработчика события
//
// Возвращаемое значение:
//  Структура:
//    * ОсновнойОбъект - ДокументОбъект, СправочникОбъект, Неопределено - заполненный объект ИБ
//																		(Неопределено, если есть ошибки)
//    * ОписаниеОшибки - Строка - текст ошибки создания объекта
//
Функция МенеджерИнтеграции_ПолучитьЗаполненныйОбъектДокумента1С(
		Документ,
		ИдентификаторОперации,
		ДополнительныеПараметры
	)
	
	Если НЕ ЕстьИнтеграционныйМодуль() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	ПараметрыСоздания = МенеджерИнтеграции.ДополнительныеПараметрыСозданияУчетногоДокумента();
	ПараметрыСоздания.СоздаватьСчетаФактуры = ЗначениеНастройки_СоздаватьСчетаФактуры();
	ПараметрыСоздания.ИспользоватьДатуЭлектронногоДокумента = ЗначениеНастройки_ИспользоватьДатуЭлектронногоДокумента();
	ПараметрыСоздания.ОтключитьПроверкуСопоставленияНоменклатуры =
		ЗначениеНастройки_РежимПроверкиСопоставленияНоменклатуры() = СозданиеДокументов_ЗаполнитьРежимыПроверкиСопоставленияНоменклатуры_СоздаватьДокументБезНоменклатуры();
		
	Результат = МенеджерИнтеграции.ПолучитьЗаполненныйОбъектДокумента1С(
			Документ,
			ИдентификаторОперации,
			ДополнительныеПараметры,
			ПараметрыСоздания
		);
	
	Возврат Результат;
	
КонецФункции

