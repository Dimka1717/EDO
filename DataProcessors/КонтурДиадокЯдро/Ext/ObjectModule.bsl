// Функция - Проверить значение настройки транспорт HTTP
// Проверяет и возвращает корректные настройки транспорта
// Если ИспользоватьВнешнийHTTP = Истина, тогда устанавливает WinHTTP
// Если есть значение функ опции - берет его
// Если в настройках некорректное значение - приводит к Встроенный
// Измененная настройка записывается
// 
// Возвращаемое значение:
//  Строка - см. Перечисление_ТранспортHTTP()
//
Функция ПроверитьЗначениеНастройки_ТранспортHTTP()
	
	ЗаписатьНастройку = Ложь;
	ТранспортHTTP = ЗначениеНастройки_ТранспортHTTP();
	
	ИспользоватьВнешнийHTTP = ЗначениеНастройки_ИспользоватьВнешнийHTTP();
	
	Если ИспользоватьВнешнийHTTP Тогда
		Если ТранспортHTTP <> Перечисление_ТранспортHTTP().WinHTTP Тогда
			
			ТранспортHTTP = Перечисление_ТранспортHTTP().WinHTTP;
			ЗаписатьНастройку = Истина;
			
		КонецЕсли;
	Иначе
		ТранспортHTTP_ФО = ТранспортФункциональнойОпции();
		
		Если ТранспортHTTP_ФО <> Неопределено Тогда
			Если ТранспортHTTP_ФО <> ТранспортHTTP Тогда
				
				ТранспортHTTP = ТранспортHTTP_ФО;
				ЗаписатьНастройку = Истина;
				
			КонецЕсли;
		КонецЕсли;
		
		Если ПустаяСтрока(ТранспортHTTP) Тогда
			
			ТранспортHTTP = Перечисление_ТранспортHTTP().Встроенный;
			ЗаписатьНастройку = Истина;
			
		Иначе
			Попытка
				
				Перечисление_ТранспортHTTP().Свойство(ТранспортHTTP, ТранспортHTTP);
				
			Исключение
				
				ТранспортHTTP = Перечисление_ТранспортHTTP().Встроенный;
				ЗаписатьНастройку = Истина;
				
			КонецПопытки;
			
			Если ТранспортHTTP = Неопределено Тогда
				
				ТранспортHTTP = Перечисление_ТранспортHTTP().Встроенный;
				ЗаписатьНастройку = Истина;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	// Нужно использовать для автотестов или локальных запусков
	ПараметрыКонфигурационногоФайла = КонфигурационныйФайл_ЗначенияПараметров();
	ИспользоватьКоннекторHTTP = ПараметрыКонфигурационногоФайла.Получить("ИспользоватьКоннекторHTTP");
	Если ИспользоватьКоннекторHTTP = Истина Тогда
		
		ТранспортHTTP = Перечисление_ТранспортHTTP().КоннекторHTTP;
		Возврат ТранспортHTTP;
		
	КонецЕсли;
	
	Если ЗаписатьНастройку Тогда
		
		ОбщиеНастройки_Поместить("ТранспортHTTP", ТранспортHTTP);
		
	КонецЕсли;
	
	Возврат ТранспортHTTP;

КонецФункции

