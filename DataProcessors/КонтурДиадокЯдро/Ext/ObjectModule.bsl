//#Область Регистрация_ошибок

// Добавляет запись в DD_Log с заданными категорией и действием:
// - Имя интеграционного модуля записывается в поле Label (значение "null", если ИМ не подключен)
// - Краткое представление ошибки записывается в поле View
// - Подробное представление ошибки добавляется в переменную "Подробности"
// - Дополнительно в переменные метрики безусловно добавляются ключи:
//     * BaseId - Строка - идентификатор текущей информационной базы
//     * ТиповойМодуль - Строка - результат проверки контрольной суммы (см. Метрика_ЗначениеПеременнойТиповойМодуль)
//
// Параметры:
//  Категория - Строка - идентификатор категории ошибки
//  Действие - Строка - идентификатор действия
//  Ошибка - ИнформацияОбОшибке, Строка - информация об ошибке
//  ДопПеременные - Структура, Соответствие - (Необязательный) значения дополнительных переменных
//
Процедура Метрика_ДобавитьОшибку(Знач Категория, Знач Действие, Ошибка, ДопПеременные = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	TraceID = TraceId();
	
	Метка = ИнтеграционныйМодуль_Получить();
	Если Не ЗначениеЗаполнено(Метка) Тогда
		Метка = "null";
	КонецЕсли;
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		Представление = СокрЛП(Ошибка);
		Подробности = "";
	Иначе
		Представление = КраткоеПредставлениеОшибки(Ошибка);
		Подробности = ПодробноеПредставлениеОшибки(Ошибка);
	КонецЕсли;
	
	ПеременныеМетрики = Новый Соответствие;
	Если ЗначениеЗаполнено(Подробности) Тогда
		ПеременныеМетрики.Вставить("Подробности", Подробности);
	КонецЕсли;
	
	ДополнитьПеременныеМетрики_ТиповойМодуль(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ПроизвольныеПараметры(ПеременныеМетрики, ДопПеременные);
	
	ДобавитьСисИнфо = Истина;
	
	СобытиеМетрики = НовоеСобытиеМетрики(
		Категория,
		Действие,
		Метка,
		Представление
	);
	
	ЗарегистрироватьСобытиеМетрики(
		ТопикиМетрики_Log(),
		СобытиеМетрики,
		TraceID,
		ПеременныеМетрики,
		ДобавитьСисИнфо
	);
	
КонецПроцедуры

Процедура Метрика_ДобавитьОшибку_ЧтениеЛентыСобытий(ТекстОшибки, BoxId) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория	 = "Обмен с сервером";
	Действие	 = "Чтение ленты";
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID",	АдресЯщикаВИдентификатор(BoxId));
	Переменные.Вставить("Причина",	ТекстОшибки);
	
