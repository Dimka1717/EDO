//#Область Описание_окружения

Функция ПараметрыСессии()
	
	Результат = Кэш_Прочитать("ПараметрыСессииДляМетрики");
	
	Если Результат = Неопределено Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Session"			, НоваяСессияМетрики());
		Результат.Вставить("ClientInstanceId"	, Строка(_ИдентификаторПользователяИБ()));
		
		Кэш_Поместить("ПараметрыСессииДляМетрики", Новый ФиксированнаяСтруктура(Результат));
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеПриложения()
	
	Результат = Кэш_Прочитать("ОписаниеПриложенияДляМетрики");
	
	Если Результат = Неопределено Тогда
		
		ВерсияМодуля		 = ОбщийКонтекст_Прочитать("ВерсияМодуля");
		ОписаниеОС			 = ОписаниеОС();
		ОписаниеБраузера	 = ОписаниеБраузера();
		ОписаниеПрограммы	 = ОписаниеПрограммы();
		ОписаниеАппаратногоОбеспечения = ОписаниеАппаратногоОбеспечения();
		
		Результат = НовоеОписаниеПриложения(ВерсияМодуля
		, ОписаниеОС
		, ОписаниеБраузера
		, ОписаниеПрограммы
		, ОписаниеАппаратногоОбеспечения);
		
		Кэш_Поместить("ОписаниеПриложенияДляМетрики", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеОС()
	
	СтрокаТипПлатформы = НРег(ОписаниеСистемнойИнформации().ТипПлатформы);
	
	Если Найти(СтрокаТипПлатформы, "64") > 0 Тогда
		BitSet = "x64";
	Иначе
		BitSet = "x86";
	КонецЕсли;
	
	Если Найти(СтрокаТипПлатформы, НРег("Linux")) <> 0 Тогда
		Name = "Linux";
	ИначеЕсли Найти(СтрокаТипПлатформы, НРег("MacOS")) <> 0 Тогда
		Name = "MacOS";
	ИначеЕсли Найти(СтрокаТипПлатформы, НРег("Windows")) <> 0 Тогда
		Name = "Windows";
	Иначе
		Name = Неопределено;
	КонецЕсли;
	
	Version = "0.0.0";
	
	Результат = Новый Структура;
	Результат.Вставить("BitSet"	, BitSet);
	Результат.Вставить("Name"	, Name);
	Результат.Вставить("Version", Version);
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеПрограммы() Экспорт
	
	ОписаниеКонфигурации = ОписаниеКонфигурации();
	
	Name = "1С:Предприятие 8";
	RunMode = ТекущийРежимЗапускаПриложения();
	Version = ВерсияВСемантикДляМетрики(ОписаниеСистемнойИнформации().ВерсияПриложения);
	
	Configuration = ОписаниеКонфигурации.Имя;
	ConfigurationVersion = ВерсияВСемантикДляМетрики(ОписаниеКонфигурации.Версия);
	ConfigurationVersion = СтрЗаменить(ConfigurationVersion, "/", "-"); // метрики не принимают символ "/"
	
	Результат = Новый Структура;
	Результат.Вставить("Name", Name);
	Результат.Вставить("RunMode", RunMode);
	Результат.Вставить("Version", Version);
	
	Результат.Вставить("Configuration", Configuration);
	Результат.Вставить("ConfigurationVersion", ConfigurationVersion);
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеБраузера()
	
	Результат = Новый Структура;
	
	UserAgent = "";
	
	Если ЗначениеЗаполнено(UserAgent) Тогда
		Результат.Вставить("UserAgent", UserAgent);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеАппаратногоОбеспечения()
	
	TotalMemoryGb = Окр(ОписаниеСистемнойИнформации().ОперативнаяПамять / 1000);
	
	Результат = Новый Структура;
	Результат.Вставить("TotalMemoryGb", TotalMemoryGb);
	
	Возврат Результат; 
	
КонецФункции

