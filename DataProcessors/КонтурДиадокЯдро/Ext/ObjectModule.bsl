// Возвращает массив организаций 1С, совпадающих с организацией Диадок по ИНН.
//
// Параметры:
//	ИНН - Строка - ИНН организации
//
// Возвращаемое значение:
//	Массив
//
Функция Организации_ПодходящиеОрганизации1СПоИНН(ИНН) Экспорт
	
	Результат = Новый Массив;
	
	ИмяСправочника = Справочники_ТипЗначенияОбъекта("Организации", "ДляЗапроса");
	
	РеквизитИНН = ИмяСправочника + ".Реквизиты.ИНН";
	РеквизитИНН = СтрЗаменить(РеквизитИНН, "Справочник", "Справочники");
	
	Если НЕ ПроверитьНаличиеОбъектаМетаданных(РеквизитИНН) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗапросОрганизации = Новый Запрос;
	ЗапросОрганизации.Текст = Организации_ТекстЗапроса_ПодходящиеОрганизации1СПоИНН(ИмяСправочника);
	
	ЗапросОрганизации.УстановитьПараметр("ИНН", ИНН);
	
	ВыборкаОрганизации = ЗапросОрганизации.Выполнить().Выбрать();
	
	Пока ВыборкаОрганизации.Следующий() Цикл
		Результат.Добавить(ВыборкаОрганизации.Организация);		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапроса_ПодходящиеОрганизации1СПоИНН(ИмяСправочника)
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Организация
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ИНН = &ИНН
	|	И НЕ Организации.ПометкаУдаления";
	
	Если ИмяСправочника <> "Справочник.Организации" Тогда
		Результат = СтрЗаменить(Результат, "Справочник.Организации", ИмяСправочника);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

