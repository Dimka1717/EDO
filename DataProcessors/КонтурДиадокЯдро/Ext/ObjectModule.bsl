Функция КонтурЛогистика_ПредставлениеСтатусаДокумента(Статус)
	
	Если Не ЗначениеЗаполнено(Статус) Тогда
		Возврат "";
	КонецЕсли;
	
	ПредставленияСтатусов = Новый Соответствие;
	
	ПредставленияСтатусов.Вставить(
		КонтурЛогистика_СтатусОжидаетПодписания(),
		НСтр("ru = 'r-wait-sign'; en = 'r-wait-sign'")
	);
	
	ПредставленияСтатусов.Вставить(
		КонтурЛогистика_СтатусОжидаетПодписанияПеревозчиком(),
		НСтр("ru = 'r-wait-carrier-sign'; en = 'r-wait-carrier-sign'")
	);
	
	ПредставленияСтатусов.Вставить(
		КонтурЛогистика_СтатусПодписан(),
		НСтр("ru = 'r-signed'; en = 'r-signed'")
	);
	
	ПредставленияСтатусов.Вставить(
		КонтурЛогистика_СтатусВПути(),
		НСтр("ru = 'on-the-way'; en = 'on-the-way'")
	);
	
	Представление = ПредставленияСтатусов.Получить(Статус);
	
	Если Не ЗначениеЗаполнено(Представление) Тогда
		Представление = СокрЛП(Статус);
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

