// Генерирует двоичные данные xml-файла универсального сообщения
//
// Параметры:
//  BoxId			 - Строка	 - Иденификатор ящика
//  MessageId		 - Строка	 - Иденификатор сообщения
//  EntityId		 - Строка	 - Иденификатор сущности для формирования УС
//  ДанныеСообщения	 - Строка	 - см. функцию Контракт_ДанныеУниверсальногоСообщения()
// 
// Возвращаемое значение:
//   - ДвоичныеДанные
//
Функция УС_УниверсальноеСообщение(BoxId, MessageId, EntityId, ДанныеСообщения) Экспорт
	
	ОбъектСообщения = ГенерацияXML_ДанныеУниверсальногоСообщения(ДанныеСообщения);
	
	ТипКодировки = "UTF-8";
	ДвоичныеДанныеXML = ГенерацияXML_ОбъектXDTO_В_ДвоичныеДанные(ОбъектСообщения, ТипКодировки);
	UniversalMessageGenerationRequest = ДвоичныеДанные_В_Текст(ДвоичныеДанныеXML, ТипКодировки);
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Результат = АПИ_GenerateUniversalMessage(ПараметрыСервиса, BoxId, MessageId, EntityId,
													UniversalMessageGenerationRequest);
	
	Возврат Результат;
	
КонецФункции

