//   - Булево
//
Функция УС_ДоступноФормированиеУниверсальныхСообщений(BoxId) Экспорт
	
	ФормироватьУС = ОбщийКонтекст_Прочитать("ФормироватьУС");
	
	Если ФормироватьУС = Ложь Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПраваПользователя = ПраваПользователяЯщикаОрганизации(BoxId);
	
	Результат = СвойствоСтруктуры(ПраваПользователя, "CanAttachUniversalMessages");
	
