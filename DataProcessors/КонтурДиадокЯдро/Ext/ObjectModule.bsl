// Получает описание пользователя Диадока
//
// Параметры:
//  ТокенДоступа - Строка - авторизационный токен
//  ТипТокена - Строка - тип токена (см. Перечисление_ТипыТокенов)
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельПользовательСервиса
//
Функция АПИ_ПользовательСервиса(ТокенДоступа, ТипТокена)
	
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	НастройкиКлиента = НастройкиКлиентаAPI(АдресСервиса, ТокенДоступа, ТипТокена);
	
	Ответ = Модуль_МетодыAPI.DD_API_GetMyUserV2(НастройкиКлиента);
	
	Данные = МодельПользовательСервиса();
	Данные.Идентификатор = НРег(Ответ.UserId);
	Данные.Зарегистрирован = Ответ.IsRegistered;
	Данные.Логин = СвойствоСтруктуры(Ответ, "Login", "");
	
	Если Ответ.Свойство("FullName") Тогда
		Данные.Фамилия = Ответ.FullName.LastName;
		Данные.Имя = Ответ.FullName.FirstName;
		Данные.Отчество = СвойствоСтруктуры(Ответ.FullName, "MiddleName", "");
	КонецЕсли;
	
	Данные.Представление = ПользователиСлужебный_ВычислитьПредставление(Данные);
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

Функция ПользователиСлужебный_ВычислитьПредставление(Данные)
	
	Если ЗначениеЗаполнено(Данные.Фамилия)
		И ЗначениеЗаполнено(Данные.Отчество) Тогда
		
		// Фамилия И.О.
		Результат = Общее_ПодставитьПараметрыВСтроку(
			"%1 %2.%3.",
			Данные.Фамилия,
			Лев(Данные.Имя, 1),
			Лев(Данные.Отчество, 1)
		);
		
	ИначеЕсли ЗначениеЗаполнено(Данные.Фамилия) Тогда
		
		// Фамилия Имя
		Результат = Общее_ПодставитьПараметрыВСтроку(
			"%1 %2",
			Данные.Фамилия,
			Данные.Имя
		);
		
	ИначеЕсли ЗначениеЗаполнено(Данные.Логин) Тогда
		
		Результат = Данные.Логин;
		
	ИначеЕсли ЗначениеЗаполнено(Данные.Идентификатор) Тогда
		
		Результат = Данные.Идентификатор;
		
	Иначе
		Результат = "<Информация отсутствует>";
	КонецЕсли;
	
	Если Не Данные.Зарегистрирован Тогда
		Результат = Результат + " (не зарегистрирован)";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

