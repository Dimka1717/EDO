// Признак того, что организация 1С сопоставлена с организацией Диадок
//
// Параметры:
//  ОрганизацияИБ - СправочникСсылка - Ссылка на элемент справочника 1С
//
// Возвращаемое значение:
//  Булево - Истина, если организация 1С сопоставлена с организацией Диадок
//
Функция Организации_ОрганизацияСопоставленаСЯщикомДиадок(ОрганизацияИБ) Экспорт
	
	Идентификаторы = Новый_ИдентификаторыСправочника(ОрганизацияИБ);
	BoxID = ХранениеДанных_ИдентификаторОрганизации(Идентификаторы);
	
	Результат = ЗначениеЗаполнено(BoxID);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ЗаписатьЭлемент(Организация) Экспорт
	
	Результат = Неопределено;
	
	BoxId						= СвойствоСтруктуры(Организация, "ID");
	AfterIndexKey				= СвойствоСтруктуры(Организация, "AfterIndexKey", "");
	ДатаГраницыСинхронизации	= СвойствоСтруктуры(Организация, "ДатаГраницыСинхронизации", Дата(1, 1, 1));
	
	СуществующаяОрганизация = Организации_СсылкаПоИдентификатору(BoxId);
	Организация.Ссылка		= СуществующаяОрганизация;
	
	Если НЕ ЗначениеЗаполнено(AfterIndexKey)  Тогда
		Организация.AfterIndexKey = Формат(ТекущаяДата(), "ДФ=yyyyMMdd");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаГраницыСинхронизации)  Тогда
		Организация.ДатаГраницыСинхронизации = НачалоДня(ТекущаяДата());
	КонецЕсли;
	
	Результат = ХранениеДанных_ЗаписатьОрганизацию(Организация);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_НайтиСоздатьЭлемент(Box)
	
	ОрганизацияДиадокСсылка = Организации_СсылкаПоИдентификатору(Box.BoxId);
	
	Если Не ЗначениеЗаполнено(ОрганизацияДиадокСсылка) Тогда
		
		Модель = Контракт_ОрганизацияЭДО();
		
		Модель.ID = Box.BoxId;
		Модель.OrgID = Box.Organization.OrgId;
		Модель.ИНН = Box.Organization.Inn;
		Модель.КПП = Box.Organization.Kpp;
		Модель.Наименование = Box.Title;
		Модель.ИдентификаторУчастникаЭДО = Box.Organization.FnsParticipantId;
		
		ОрганизацияДиадокСсылка = Организации_ЗаписатьЭлемент(Модель);
		
	КонецЕсли;
	
	Возврат ОрганизацияДиадокСсылка;
	
КонецФункции

