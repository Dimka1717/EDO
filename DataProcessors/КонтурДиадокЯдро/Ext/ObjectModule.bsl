// Обрабатывает облачные настройки текущей информационной базы
//
Процедура ОблачныеНастройки_ОбработатьНастройки() Экспорт
	
	НовыеНастройки = ОбщийКонтекст_Прочитать("ОблачныеНастройки");
	
	Если ЗначениеЗаполнено(НовыеНастройки) Тогда
		
		Для Каждого Элемент Из НовыеНастройки Цикл
			
			ОблачныеНастройки_ПрименитьНастройку(Элемент.Ключ, Элемент.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОблачныеНастройки_ПрименитьНастройку(ИмяНастройки, ЗначениеНастройки)
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		ОблачныеНастройкиСлужебный_ПрименитьНастройку(ИмяНастройки, ЗначениеНастройки);
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияОбработкаОблачнойНастройки(),
			ИмяНастройки,
			НачалоЗамера
		);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияОбработкаОблачнойНастройки(),
			ИмяНастройки,
			Ошибка
		);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОблачныеНастройкиСлужебный_ПрименитьНастройку(ИмяНастройки, ЗначениеНастройки)
	
	КлючиНастроек = ОблачныеНастройки_КлючиНастроек();
	
	Если ИмяНастройки = КлючиНастроек.ИспользоватьПМ_МодульСтандарт Тогда
		
		ОблачныеНастройки_ИспользоватьПМСтандарта(ЗначениеНастройки);
		
	ИначеЕсли ИмяНастройки = КлючиНастроек.УстановитьРежимСовместимости_820_970 Тогда
		
		ОблачныеНастройки_УстановитьРежимСовместимости_820_970(ЗначениеНастройки);
		
	ИначеЕсли ИмяНастройки = КлючиНастроек.УстановитьФорматОтправки_УПД_Организации Тогда
		
		ОблачныеНастройки_УстановитьФорматОтправкиПервичныхДокументовОрганизации(ЗначениеНастройки);
		
	ИначеЕсли ИмяНастройки = КлючиНастроек.УстановитьФорматОтправки_УПД_Контрагенты Тогда
		
		ОблачныеНастройки_УстановитьФорматОтправкиПервичныхДокументовКонтрагенты(ЗначениеНастройки);
		
	ИначеЕсли ИмяНастройки = КлючиНастроек.УстановитьФорматОтправки_УКД_Организации Тогда
		
		ОблачныеНастройки_УстановитьФорматОтправкиКорректировочныхДокументовОрганизации(ЗначениеНастройки);
		
	ИначеЕсли ИмяНастройки = КлючиНастроек.УстановитьФорматОтправки_УКД_Контрагенты Тогда
		
		ОблачныеНастройки_УстановитьФорматОтправкиКорректировочныхДокументовКонтрагенты(ЗначениеНастройки);
		
	Иначе
		
		ШаблонОшибки = "Неожиданное имя настройки: %1";
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ИмяНастройки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ОблачныеНастройки_УдалитьНастройку(ИмяНастройки);
	
КонецПроцедуры

Процедура ОблачныеНастройки_ИспользоватьПМСтандарта(Знач ЗначениеНастройки)
	
	Если ЭтоОбычноеПриложение() Тогда
		ЗначениеНастройки = Строка(ЗначениеНастройки);
	КонецЕсли;
	
	ВариантыРасположенияПМ = ЗначенияНастроек_РасположениеПМСтандарта();
	
	НеожиданноеЗначениеНастройки = (ЭтоУправляемоеПриложение() И (ТипЗнч(ЗначениеНастройки) <> Тип("Булево")))
		ИЛИ (ЭтоОбычноеПриложение() И (ВариантыРасположенияПМ.Найти(ЗначениеНастройки) = Неопределено));
	
	Если НеожиданноеЗначениеНастройки Тогда
		
		КлючиНастроек = ОблачныеНастройки_КлючиНастроек();
		
		ШаблонОшибки = "Неожиданное значение настройки ""%1"": %2 (%3)
		|Режим запуска: %4";
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			КлючиНастроек.ИспользоватьПМ_МодульСтандарт,
			Строка(ЗначениеНастройки),
			Строка(ТипЗнч(ЗначениеНастройки)),
			ТекущийРежимЗапуска()
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ХранениеДанных.УстановитьНастройкуИспользоватьПМСтандарта(ЗначениеНастройки);
	
КонецПроцедуры

Процедура ОблачныеНастройки_УстановитьРежимСовместимости_820_970(ЗначениеНастройки)
	
	Если ТипЗнч(ЗначениеНастройки) <> Тип("Булево") Тогда
		
		КлючиНастроек = ОблачныеНастройки_КлючиНастроек();
		
		ШаблонОшибки = "Неожиданное значение настройки %1: %2 (%3)";
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			КлючиНастроек.УстановитьРежимСовместимости_820_970,
			Строка(ЗначениеНастройки),
			Строка(ТипЗнч(ЗначениеНастройки))
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ХранениеДанных.УстановитьНастройкуРежимСовместимости_820_970(ЗначениеНастройки);
	
КонецПроцедуры

Процедура ОблачныеНастройки_УстановитьФорматОтправкиПервичныхДокументовОрганизации(ЗначениеНастройки)
	
	ЗначенияФорматов = ЗначенияНастроек_ФорматОтправкиПервичныхДокументов();
	
	Если ТипЗнч(ЗначениеНастройки) <> Тип("Строка")
		ИЛИ ЗначенияФорматов.Найти(ЗначениеНастройки) = Неопределено Тогда
		
		КлючиНастроек = ОблачныеНастройки_КлючиНастроек();
		
		ШаблонОшибки = "Неожиданное значение настройки %1: %2 (%3)";
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			КлючиНастроек.УстановитьФорматОтправки_УПД_Организации,
			Строка(ЗначениеНастройки),
			Строка(ТипЗнч(ЗначениеНастройки))
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ВидыДокументов = ВидыПервичныхДокументов();
	
	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	НастройкиПоОрганизациям = ХранениеДанных.НастройкиДокументовНаОтправкуПоСопоставленнымОрганизациям(ВидыДокументов);
	
	Для Каждого ТекущаяНастройка Из НастройкиПоОрганизациям Цикл
		
		Если ЗначенияФорматов.Найти(ТекущаяНастройка.Значение) <> Неопределено
			И ТекущаяНастройка.Значение <> ЗначениеНастройки Тогда
			
			ХранениеДанных.ЗаписатьНастройкуУчастникаДО(
				ТекущаяНастройка.Свойство,
				ЗначениеНастройки,
				ТекущаяНастройка.Организация
			);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

