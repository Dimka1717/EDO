//{		ОБЩИЙ КОНТЕКСТ

// Возвращает значение из общего контекста.
//
Функция ОбщийКонтекст_Прочитать(ИмяПараметра) Экспорт
	
	Результат = СвойствоСтруктуры(ОбщийКонтекстКлиентСервер, ИмяПараметра);
	
	Возврат Результат;
	
КонецФункции

// Помещает в общий контекст новое значение
//
Процедура ОбщийКонтекст_Поместить(Ключ, Значение) Экспорт
	
	Если ОбщийКонтекстКлиентСервер = Неопределено Тогда
		ОбщийКонтекстКлиентСервер = Новый Структура;
	КонецЕсли;
	
	ОбщийКонтекстКлиентСервер.Вставить(Ключ, Значение);
	
КонецПроцедуры

// Устанавливает в качестве общего контекста новый существующий контекст
//
Процедура УстановитьОбщийКонтекст(НовыйКонтекст) Экспорт
	
	ОбщийКонтекстКлиентСервер = НовыйКонтекст;
	
КонецПроцедуры

// Добавляет в общий контекст параметры, которые не зависят от общих настроек.
//
// Параметры:
//  ПараметрыКонтекста - Структура - см. функцию ПараметрыИнициализацииОбщегоКонтекста()
//
Процедура ОбщийКонтекст_ДобавитьБазовыеПараметры(ПараметрыКонтекста)
	
	УИД = ПараметрыКонтекста.ИдентификаторФормы;
	
	СтрокаСоединения = СтрокаСоединенияИнформационнойБазы();
	ФайловыйРежимРаботы = (ВРег(Лев(СтрокаСоединения, 5)) = "FILE=");
	
	ОбщийКонтекст_Поместить("ВерсияМодуля", ПараметрыКонтекста.ВерсияМодуля);
	ОбщийКонтекст_Поместить("ПолнаяВерсияМодуля", ПараметрыКонтекста.ПолнаяВерсияМодуля);
	ОбщийКонтекст_Поместить("ФайловыйРежимРаботы", ФайловыйРежимРаботы);
	ОбщийКонтекст_Поместить("КлючРазработчика", ПараметрыКонтекста.КлючРазработчика);
	ОбщийКонтекст_Поместить("РежимОтладки", ПараметрыКонтекста.РежимОтладки);
	ОбщийКонтекст_Поместить("ИдентификаторФормы", УИД);
	ОбщийКонтекст_Поместить("АдресDiadocAPI", ПараметрыКонтекста.АдресDiadocAPI);
	ОбщийКонтекст_Поместить("АдресKonturAPI", ПараметрыКонтекста.АдресKonturAPI);
	ОбщийКонтекст_Поместить("АдресUpdateServiceAPI", ПараметрыКонтекста.АдресUpdateServiceAPI);
	ОбщийКонтекст_Поместить("АдресSubscriptionsGateway", ПараметрыКонтекста.АдресSubscriptionsGateway);
	ОбщийКонтекст_Поместить("АдресаСКД", Новый Структура);
	ОбщийКонтекст_Поместить("АдресаНастроекСКД", Новый Структура);
	ОбщийКонтекст_Поместить("РасположениеМодуля", ПараметрыКонтекста.РасположениеМодуля);
	ОбщийКонтекст_Поместить("ЗапускИзРасширения", ПараметрыКонтекста.ЗапускИзРасширения);
