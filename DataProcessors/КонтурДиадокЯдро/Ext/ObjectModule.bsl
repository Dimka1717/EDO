Функция Новый_СервисПодписки(ДанныеПодписки, ДанныеСервиса, ЛицевойСчет, КодПродукта)
	
	Результат = Контракт_СервисПодписки();
	
	Результат.Идентификатор = ДанныеСервиса.Имя;
	
	Если ЗначениеЗаполнено(ДанныеСервиса.Представление) Тогда
		Результат.Представление = ДанныеСервиса.Представление;
	Иначе
		Результат.Представление = ДанныеСервиса.Имя;
	КонецЕсли;
	
	Результат.ИдентификаторПодписки = ДанныеПодписки.Идентификатор;
	Результат.ИдентификаторОсновнойПодписки = ДанныеПодписки.ИдентификаторОсновнойПодписки;
	Результат.ДатаНачала = ДанныеПодписки.ДатаНачала;
	Результат.ДатаОкончания = ДанныеПодписки.ДатаОкончания;
	
	Если ЗначениеЗаполнено(ДанныеСервиса.Ресурсы) Тогда
		Результат.Количество = ДанныеСервиса.Ресурсы[0].Количество;
		Результат.Использовано = ДанныеСервиса.Ресурсы[0].Использовано;
	КонецЕсли;
	
	Результат.ЛицевойСчет = ЛицевойСчет;
	
	Если ЗначениеЗаполнено(КодПродукта) Тогда
		Результат.КодПродукта = КодПродукта;
	Иначе
		Результат.КодПродукта = КонтурШлюзАвторизации_КодПродукта();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

