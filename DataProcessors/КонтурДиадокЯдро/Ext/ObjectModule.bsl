Функция ПодключаемыйМодуль_СовместимыеПараметры(ИмяСобытия, Параметры)
	
	Результат = Параметры;
	
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		
		Если ИмяСобытия = "ПодготовитьПакет" Тогда
			
			Пакет = ПодключаемыйМодуль_УстаревшийПакет(Параметры.Пакет);
						
			Результат.Пакет.Вставить("ДополнительныеРеквизиты",	Результат.Пакет.ДопРеквизиты);
			Результат.Пакет.Вставить("Данные1С",				Пакет.Данные1С);
			Результат.Пакет.Вставить("ДанныеДД",				Пакет.ДанныеДД);
			Результат.Пакет.Вставить("ПараметрыСогласования",	Пакет.ПараметрыСогласования);
			
			Результат.Вставить("ВидПакетаРазвернутый", Пакет.Данные1С.ВидПакета);
			
		ИначеЕсли ИмяСобытия = "ПослеПодготовкиПакета"
			ИЛИ ИмяСобытия = "ПослеОтправкиПакета" Тогда
			
			Результат = Новый Структура;
			Пакет = ПодключаемыйМодуль_УстаревшийПакет(Параметры.Пакет);	
			Результат.Вставить("Пакет", Пакет);
			
		ИначеЕсли ИмяСобытия = "ПолучитьСертификатыДляШифрования" Тогда
			
			Пакет = ПодключаемыйМодуль_УстаревшийПакет(Параметры.Пакет);
			
			Результат.Вставить("Данные1С", Пакет.Данные1С);
			Результат.Вставить("ДанныеДД", Пакет.ДанныеДД);
			
		ИначеЕсли ИмяСобытия = "ВыполнитьТребуемоеДействие"
			ИЛИ ИмяСобытия = "ПровестиАнализДокумента" Тогда
			
			Документ = Параметры.Документ;
			
			Результат.Вставить("ПакетДД",		Документ.Идентификаторы.ПакетЭДО);
			Результат.Вставить("ДокументДД",	Документ.Идентификаторы.ДокументЭДО);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_УстаревшийПакет(Пакет) Экспорт
	
	Результат = Новый Структура;
	
	Если Пакет.Направление = Перечисление_Направления().Исходящее Тогда
		УчастникЭДО_Организация = Пакет.Отправитель;
		УчастникЭДО_Контрагент	= Пакет.Получатель;
	Иначе
		УчастникЭДО_Организация = Пакет.Получатель;
		УчастникЭДО_Контрагент	= Пакет.Отправитель;
	КонецЕсли;
	
	Организация			= УчастникЭДО_Организация.Организация;
	ОрганизацияДиадок	= УчастникЭДО_Организация.ОрганизацияЭДО;
	
	Контрагент			= УчастникЭДО_Контрагент.Организация;
	КонтрагентДиадок	= УчастникЭДО_Контрагент.ОрганизацияЭДО;
	
	DepartmentIdОрганизации	= УчастникЭДО_Организация.DepartmentId;
	DepartmentIdКонтрагента = УчастникЭДО_Контрагент.DepartmentId;
	
	ПодразделениеКонтрагента = Подразделения_СсылкаПоИдентификатору(DepartmentIdКонтрагента, Ложь);
	ПодразделениеОрганизации = Подразделения_СсылкаПоИдентификатору(DepartmentIdОрганизации);
	
	ОтложеннаяОтправка		= СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОтложеннаяОтправка", Ложь);
	ЗашифрованныйПакет		= СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ЗашифрованныйПакет", Ложь);
	ПараметрыПереотправки	= СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ПараметрыПереотправки");
	
	Если ПараметрыПереотправки <> Неопределено Тогда
		ПереотправляемыйПакетЭДО	= ПараметрыПереотправки.ПереотправляемыйПакет.ПакетЭДО;
		УдалениеНеактуальных 		= ПараметрыПереотправки.ВыполнитьУдалениеНеактуальныхДокументовПакета;
	Иначе
		ПереотправляемыйПакетЭДО	= Неопределено;
		УдалениеНеактуальных		= Ложь;
	КонецЕсли;
	
	Данные1С = Новый Структура;
	Данные1С.Вставить("Ссылка",							Пакет.Идентификаторы.ПакетЭДО);
	Данные1С.Вставить("ВидПакета",						Списки_ОписаниеВидаПакета(Пакет.ИдентификаторВида));
	Данные1С.Вставить("ВидПакетаID",					Пакет.ИдентификаторВида);
	Данные1С.Вставить("ДатаДокумента",					Пакет.Реквизиты.Дата);
	Данные1С.Вставить("НомерДокумента",					Пакет.Реквизиты.Номер);
	Данные1С.Вставить("СуммаДокумента",					Пакет.Реквизиты.Сумма);
	Данные1С.Вставить("Документ",						Пакет.ДокументУчета);
	Данные1С.Вставить("Контрагент",						Контрагент);
	Данные1С.Вставить("КонтрагентДиадок",				КонтрагентДиадок);
	Данные1С.Вставить("Организация",					Организация);
	Данные1С.Вставить("ОрганизацияДиадок",				ОрганизацияДиадок);
	Данные1С.Вставить("ПереотправляемыйПакетСсылка",	ПереотправляемыйПакетЭДО);
	Данные1С.Вставить("ПодразделениеКонтрагента",		ПодразделениеКонтрагента);
	Данные1С.Вставить("ПодразделениеОрганизации",		ПодразделениеОрганизации);
	Данные1С.Вставить("ЭтоВнутреннийДокумент",			Ложь);
	Данные1С.Вставить("ВыполнитьУдалениеНеактуальныхДокументовПакета",	УдалениеНеактуальных);
	
	ДанныеДД = Новый Структура;
	ДанныеДД.Вставить("BoxId",				Пакет.Идентификаторы.BoxId);
	ДанныеДД.Вставить("LetterId",			Пакет.Идентификаторы.LetterId);
	ДанныеДД.Вставить("OrganizationId",		УчастникЭДО_Организация.BoxId);
	ДанныеДД.Вставить("CounterAgentId",		УчастникЭДО_Контрагент.BoxId);
	ДанныеДД.Вставить("DelaySend",			ОтложеннаяОтправка);
	ДанныеДД.Вставить("Encrypted",			ЗашифрованныйПакет);
	ДанныеДД.Вставить("FromDepartmentId",	Пакет.Отправитель.DepartmentId);
	ДанныеДД.Вставить("ToDepartmentId",		Пакет.Получатель.DepartmentId);
	ДанныеДД.Вставить("LockPackage",		Пакет.Заблокирован);
	ДанныеДД.Вставить("TimestampTicks",		Пакет.ДатаЭДО);
	ДанныеДД.Вставить("IsDraft",			Ложь);
	ДанныеДД.Вставить("IsInternal",			Ложь);
	ДанныеДД.Вставить("ProxyBoxId",			"");
	ДанныеДД.Вставить("ProxyDepartmentId",	"");

	ПараметрыСогласования = Новый Структура;
	ПараметрыСогласования.Вставить("Действие",						"");
	ПараметрыСогласования.Вставить("ИдентификаторСотрудника",		"");
	ПараметрыСогласования.Вставить("ИдентификаторПодразделения",	"");
	ПараметрыСогласования.Вставить("ИдентификаторМаршрута",			"");
	ПараметрыСогласования.Вставить("Комментарий",					"");
	ПараметрыСогласования.Вставить("Документы",						Новый Массив);
		
	Результат.Вставить("Данные1С",	Данные1С);
	Результат.Вставить("ДанныеДД",	ДанныеДД);
	Результат.Вставить("Документы", Новый Массив);
	Результат.Вставить("ПараметрыСогласования",		ПараметрыСогласования);
	Результат.Вставить("ДополнительныеРеквизиты",	Пакет.ДопРеквизиты);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		ДокументУстаревшегоФормата = ПодключаемыйМодуль_УстаревшийДокумент(Документ);
		Результат.Документы.Добавить(ДокументУстаревшегоФормата);
	КонецЦикла;	
	
	Результат.Вставить("ПараметрыШаблона", Пакет.ПараметрыШаблона);
	
	Возврат Результат;
		
КонецФункции

Функция ПодключаемыйМодуль_УстаревшийДокумент(Документ)
	
	Результат = Новый Структура;
	
	ОписаниеВидаДокумента = Списки_ОписаниеВидаДокумента(Документ.ИдентификаторВида);
	Если ЗначениеЗаполнено(ОписаниеВидаДокумента) Тогда
		ОписаниеВидаДокумента.ТипКонтентаAPI = Документ.Тип.ТипКонтента;
	КонецЕсли;
	
	Результат.Вставить("Вид", 							ОписаниеВидаДокумента);
	Результат.Вставить("ВидID",							Документ.ИдентификаторВида);
	Результат.Вставить("Ключ",							Документ.Ключ);
	Результат.Вставить("ИмяФайла",						Документ.ИмяФайла);
	Результат.Вставить("Метаданные",					Документ.Метаданные);
	Результат.Вставить("Документ1С",					Документ.ДокументУчета);
	Результат.Вставить("Комментарий",					Документ.Комментарий);
	
	Результат.Вставить("РеквизитыДокумента",			Документ.Реквизиты);
	Результат.Вставить("ДатаДокумента",					Документ.Реквизиты.Дата);
	Результат.Вставить("НомерДокумента",				Документ.Реквизиты.Номер);
	Результат.Вставить("Сумма",							Документ.Реквизиты.Сумма);
	Результат.Вставить("СуммаНДС",						Документ.Реквизиты.СуммаНДС);
	
	Результат.Вставить("Тип", 							Документ.Тип.ТипДокумента);
	Результат.Вставить("ТипКонтента",					Документ.Тип.ТипКонтента);
	Результат.Вставить("Функция",						Документ.Тип.ФункцияДокумента);
	
	Результат.Вставить("ОписаниеФорматаКонтента",		Списки_ОписаниеФорматаКонтента(Результат.ТипКонтента));
	Результат.Вставить("ОписаниеТипаДокумента",			Списки_ОписаниеТипаДокументаAPI(Результат.Тип, Результат.ТипКонтента, Результат.Функция));	
	
	Результат.Вставить("ДатаСоздания",					Документ.Документооборот.ХранилищеКонтента.ДатаСоздания);
	Результат.Вставить("ДвоичныеДанные",				Документ.Документооборот.ХранилищеКонтента.Данные);
	Результат.Вставить("ЗашифрованныеДвоичныеДанные",	Документ.Документооборот.ХранилищеКонтента.ЗашифрованныеДанные);
	Результат.Вставить("ДвоичныеДанныеПодписи",			Документ.Документооборот.ХранилищеКонтента.Подпись.ДанныеПодписи);
	
	Результат.Вставить("BoxID",							Документ.Идентификаторы.BoxId);
	Результат.Вставить("LetterID",						Документ.Идентификаторы.LetterId);
	Результат.Вставить("DocumentID",					Документ.Идентификаторы.DocumentId);
	Результат.Вставить("Ссылка",						Документ.Идентификаторы.ДокументЭДО);
	
	ПараметрыОтправки = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПараметрыОтправки");
	
	Результат.Вставить("ЗапрашиватьИзвещение",			СвойствоСтруктуры(ПараметрыОтправки, "ЗапрашиватьИзвещение", Ложь));
	Результат.Вставить("ЗапрашиватьОтветнуюПодпись",	СвойствоСтруктуры(ПараметрыОтправки, "ЗапрашиватьОтветнуюПодпись", Ложь));
	Результат.Вставить("ДокументыОснования",			СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ДокументыОснования", Новый Массив));
	
	Если НЕ Документ.Тип.Формализованный Тогда
		КонтентНеформализованного = Новый Структура("NeedRecipientSignature, Date, Number, Grounds, Total, Vat, Price, ContractType", Ложь);
		Документ.СлужебнаяИнформация.Вставить("Контент", КонтентНеформализованного);
	КонецЕсли;
	
	Результат.Вставить("Content", СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент"));
	
	ПараметрыГенерацииXML = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ПараметрыГенерацииXML");
	Результат.Вставить("ТочностьЦены",		 СвойствоСтруктуры(ПараметрыГенерацииXML, "ТочностьЦены"));
	Результат.Вставить("ТочностьКоличества", СвойствоСтруктуры(ПараметрыГенерацииXML, "ТочностьКоличества"));
	
	Результат.Вставить("PatchedContentId",				Неопределено);
	Результат.Вставить("InitialDocumentIds",			Новый Массив);
	Результат.Вставить("ПараметрыСогласования");
	Результат.Вставить("Заголовок");
	Результат.Вставить("СуммаДоговора");
	Результат.Вставить("ТипДоговора");
	Результат.Вставить("Основание");
	
	Результат.Вставить("ПараметрыШаблона", Документ.ПараметрыШаблона);
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_УстаревшийВидДокумента(Документ)
	
	XDTO_SellerContent = Документ.ОписаниеФорматаКонтента.XDTO_SellerContent;
	XDTO_SellerContent = ПодключаемыйМодуль_УстаревшийSellerContent(XDTO_SellerContent, Документ.Вид.ТипДокументаAPI);
	
	Результат = Новый Структура;
	
	Результат.Вставить("ТипКонтента",	XDTO_SellerContent);
	Результат.Вставить("ID",			Документ.Вид.ID);
	Результат.Вставить("Наименование",	Документ.Вид.Наименование);
	Результат.Вставить("TypeNamedId",	Документ.Вид.ТипДокументаAPI);
	Результат.Вставить("FormatVersion",	Документ.Вид.ТипКонтентаAPI);
	Результат.Вставить("FunctionName",	Документ.Вид.ФункцияДокументаAPI);
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_УстаревшийSellerContent(XDTO_SellerContent, ТипДокументаAPI)
	
	Результат = XDTO_SellerContent;
	
	Если Результат = Неопределено Тогда
		
		Если ТипДокументаAPI = "ProformaInvoice" Тогда
			
			Результат = "ProformaInvoiceContent";
			
		ИначеЕсли ТипДокументаAPI = "Torg12" Тогда
			
			Результат = "Torg12Content";
			
		ИначеЕсли ТипДокументаAPI = "AcceptanceCertificate" Тогда
			
			Результат = "AcceptanceCertificateContent";
			
		ИначеЕсли ТипДокументаAPI = "Contract" Тогда
			
			Результат = "ContractContent";
			
		Иначе
			Результат = "NonformilizedContent";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПодключаемыйМодуль_СконвертироватьРезультат(ИмяСобытия, Параметры, ИсходныеПараметры, Результат)
	
	Если ИмяСобытия = "ПодготовитьПакет" Тогда
		
		Параметры.Пакет.Удалить("Данные1С");
		Параметры.Пакет.Удалить("ДанныеДД");
		Параметры.Пакет.Удалить("ПараметрыСогласования");
		Параметры.Пакет.Удалить("ДополнительныеРеквизиты");
		
	ИначеЕсли ИмяСобытия = "ПослеПодготовкиПакета" Тогда
		
		Пакет		= ИсходныеПараметры.Пакет;
		ДанныеДД	= Параметры.Пакет.ДанныеДД;
		
		ПромежуточныйПолучатель = Пакет.СлужебнаяИнформация.ПараметрыОтправки.ПромежуточныйПолучатель;
		ПромежуточныйПолучатель.BoxId 			= ДанныеДД.ProxyBoxId;
		ПромежуточныйПолучатель.DepartmentId 	= ДанныеДД.ProxyDepartmentId;
		
		ИзменилсяBoxIdОтправителя		 = Пакет.Отправитель.BoxId <> ДанныеДД.OrganizationId;
		ИзменилсяDepartmentIdОтправителя = Пакет.Отправитель.DepartmentId <> ДанныеДД.FromDepartmentId;
		ИзменилсяBoxIdПолучателя		 = Пакет.Получатель.BoxId <> ДанныеДД.CounterAgentId;
		ИзменилсяDepartmentIdПолучателя	 = Пакет.Получатель.DepartmentId <> ДанныеДД.ToDepartmentId;
		
		Пакет.Идентификаторы.BoxId		= ДанныеДД.BoxId;
		Пакет.Отправитель.BoxId			= ДанныеДД.OrganizationId;
		Пакет.Получатель.BoxId			= ДанныеДД.CounterAgentId;
		Пакет.Отправитель.DepartmentId	= ДанныеДД.FromDepartmentId;
		Пакет.Получатель.DepartmentId	= ДанныеДД.ToDepartmentId;
		Пакет.Заблокирован				= ДанныеДД.LockPackage;
		
		Организация = Неопределено;
		Если ИзменилсяBoxIdОтправителя Тогда
			
			Организация = Организации_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Отправитель.BoxId));
			Пакет.Отправитель.FNSParticipantId	 = Организация.ИдентификаторУчастникаЭДО;
			Пакет.Отправитель.Организация		 = Организация.СвязанныйСправочник1;
			Пакет.Отправитель.ОрганизацияЭДО	 = Организация.Ссылка;
			
		КонецЕсли;
		
		Если ИзменилсяDepartmentIdОтправителя Тогда
			
			Если Организация = Неопределено Тогда
				Организация = Организации_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Отправитель.BoxId));
			КонецЕсли;
			
			ПодразделениеОтправителя = Подразделения_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Отправитель.DepartmentId), Организация);
			Пакет.Отправитель.Подразделение = ПодразделениеОтправителя.Ссылка;
			
		КонецЕсли;
		
		Контрагент = Неопределено;
		Если ИзменилсяBoxIdПолучателя Тогда
			
			Контрагент = Контрагенты_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Получатель.BoxId));
			Пакет.Получатель.FNSParticipantId	 = Контрагент.ИдентификаторУчастникаЭДО;
			Пакет.Получатель.Организация		 = Контрагент.СвязанныйСправочник1;
			Пакет.Получатель.ОрганизацияЭДО		 = Контрагент.Ссылка;
			
		КонецЕсли;
		
		Если ИзменилсяDepartmentIdПолучателя Тогда
			
			Если Контрагент = Неопределено Тогда
				Контрагент = Контрагенты_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Получатель.BoxId));
			КонецЕсли;
			
			ПодразделениеПолучателя = Подразделения_ЗаполненныеРеквизиты(Новый_ИдентификаторыСправочника(, Пакет.Получатель.DepartmentId), Контрагент, Ложь);
			Пакет.Получатель.Подразделение = ПодразделениеПолучателя.Ссылка;
			
		КонецЕсли;
		
		Пакет.СлужебнаяИнформация.Вставить("ОтложеннаяОтправка", ДанныеДД.DelaySend);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодключаемыйМодуль_ЗаполнитьМетаданныеУстаревшегоДокумента(Документ)
	
	// До редакции 3.0 часть полей меты могла заполняться в ПМ в структуре Документ
	// Теперь все данные меты должны содержаться в Документ.Метаданные
	// Заполняем только те значения меты, которые не заполнены по данным контента или напрямую в ПМ.
	
	МетаданныеДокумента = Документ.Метаданные;
	
	Если ЗначениеЗаполнено(Документ.СуммаНДС) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "TotalVat")) Тогда
		МетаданныеДокумента.Вставить("TotalVat", Документ.СуммаНДС);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.Сумма) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "TotalSum")) Тогда
		МетаданныеДокумента.Вставить("TotalSum", Документ.Сумма);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.ИмяФайла) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "FileName")) Тогда
		МетаданныеДокумента.Вставить("FileName", Документ.ИмяФайла);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.СуммаДоговора) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "ContractPrice")) Тогда
		МетаданныеДокумента.Вставить("ContractPrice", Документ.СуммаДоговора);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.ТипДоговора) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "ContractType")) Тогда
		МетаданныеДокумента.Вставить("ContractType", Документ.ТипДоговора);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.Основание) 
		И НЕ ЗначениеЗаполнено(СвойствоСтруктуры(МетаданныеДокумента, "Grounds")) Тогда
		МетаданныеДокумента.Вставить("Grounds", Документ.Основание);
	КонецЕсли;
	
КонецПроцедуры

// Получает версию API подключаемого модуля.
// Если ПМ не подключен, возвращается версия  API поставляемого интеграционного модуля.
// 0 - если не удалось определить версию API ПМ.
// 
// Возвращаемое значение:
//  Число - номер версии API.
//
Функция ПодключаемыйМодуль_ВерсияПрограммногоИнтерфейса() Экспорт
	
	ПМ = Модуль_ПМ(ЭтотОбъект);
	
	Если ПМ = Неопределено Тогда
		
		// Вместо ПМ используется поставляемый ИМ
		Результат = ПодключаемыйМодуль_АктуальнаяВерсияAPI();
		
	Иначе
		
		Попытка
			Результат = ПМ.ЭДО_ВерсияAPIПодключаемогоМодуля();
		Исключение
			Ошибка = ИнформацияОбОшибке();
			Результат = 0;
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_АктуальнаяВерсияAPI()
	Возврат 4;
КонецФункции

Функция ПодключаемыйМодуль_ТребуемаяВерсияAPIПодключаемогоМодуля()
	
	Результат = Новый Массив;
	Результат.Добавить(ПодключаемыйМодуль_АктуальнаяВерсияAPI());
	Результат.Добавить(3);
	Результат.Добавить(2);
	Результат.Добавить(1);
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_РеквизитыДокумента(Документ) Экспорт
	
	Результат = Новый Структура;
	
	ТипДокумента		= Документ.Тип.ТипДокумента;
	ТипКонтента			= Документ.Тип.ТипКонтента;
	ФункцияДокумента	= Документ.Тип.ФункцияДокумента;
	ФункцияДокументаXML = Документы_ФункцияДокументаДляXML(ТипДокумента, ФункцияДокумента);
	
	Результат.Вставить("Метаданные",            Документ.Метаданные);
	Результат.Вставить("Ссылка",				Документ.Идентификаторы.ДокументЭДО);
	Результат.Вставить("ДатаДокумента",			Документ.Реквизиты.Дата);
	Результат.Вставить("НомерДокумента",		Документ.Реквизиты.Номер);	
	Результат.Вставить("СуммаДокумента",		Документ.Реквизиты.Сумма);
	Результат.Вставить("СуммаНДС",				Документ.Реквизиты.СуммаНДС);
	Результат.Вставить("Валюта",				Документ.Реквизиты.КодВалюты);
	Результат.Вставить("Направление",			Документ.Направление);
	
	Результат.Вставить("ТипДокумента",			ТипДокумента);
	Результат.Вставить("ТипКонтента",			ТипКонтента);
	Результат.Вставить("ФункцияДокумента",		ФункцияДокумента);
	Результат.Вставить("ФункцияДокументаXML",	ФункцияДокументаXML);
	
	Результат.Вставить("ВидДокумента",			Документ.ИдентификаторВида);
	Результат.Вставить("ДокументВ1С",			Документ.ДокументУчета);
	Результат.Вставить("Статус",				Документ.Статусы.Статус);
	Результат.Вставить("ДополнительныйСтатус",	Документ.Статусы.ДополнительныйСтатус);
	
	Результат.Вставить("АнализПроведен",		Документ.РезультатАнализа.АнализПроведен);
	Результат.Вставить("ТребуемоеДействиеВ1С",	Документ.РезультатАнализа.ТребуемоеДействиеВ1С);
	Результат.Вставить("ТребуемоеДействиеВДД",	Документ.РезультатАнализа.ТребуемоеДействиеВДД);
	Результат.Вставить("ТекстОшибки",			Документ.РезультатАнализа.ТекстОшибки);
	Результат.Вставить("ИмяФайла",				Документ.ИмяФайла);
	
	Результат.Вставить("ЗаблокированныйПакет",	Документ.Заблокирован);
	
	Результат.Вставить("BoxId",					Документ.Идентификаторы.BoxId);
	Результат.Вставить("LetterId",				Документ.Идентификаторы.LetterId);
	Результат.Вставить("DocumentId",			Документ.Идентификаторы.DocumentId);
	
	ВходящийДокумент = Результат.Направление = Перечисление_Направления().Входящее;
	
	СтруктураОрганизация	= ?(ВходящийДокумент, Документ.Получатель, Документ.Отправитель);
	СтруктураКонтрагент		= ?(ВходящийДокумент, Документ.Отправитель, Документ.Получатель);
	
	Результат.Вставить("Контрагент",			СтруктураКонтрагент.Организация);
	Результат.Вставить("Организация",			СтруктураОрганизация.Организация);
	
	Результат.Вставить("КонтрагентДиадок",		СтруктураКонтрагент.ОрганизацияЭДО);
	Результат.Вставить("ОрганизацияДиадок",		СтруктураОрганизация.ОрганизацияЭДО);
	
	Результат.Вставить("ОрганизацияДиадокID",	СтруктураОрганизация.BoxId);
	Результат.Вставить("КонтрагентДиадокID",	СтруктураКонтрагент.BoxId);
	
	Результат.Вставить("DepartmentId",			СтруктураОрганизация.DepartmentId);
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что версия программного интерфейса подключаемого модуля
// позволяет использовать форму создания документов.
//
// Возвращаемое значение:
//  Булево - Истина, если используется ПМ с подходящей версией API.
//
Функция ПодключаемыйМодуль_ИспользоватьФормуСозданияДокументов() Экспорт
	
	МинимальнаяВерсияИнтерфейсаПМ = 4;
	ТекущаяВерсияИнтерфейсаПМ = ПодключаемыйМодуль_ВерсияПрограммногоИнтерфейса();
	
	Результат = (ТекущаяВерсияИнтерфейсаПМ >= МинимальнаяВерсияИнтерфейсаПМ);
	
	Возврат Результат;
	
КонецФункции

