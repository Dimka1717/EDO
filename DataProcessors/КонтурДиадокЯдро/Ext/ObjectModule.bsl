	);
	
	ОбработатьРезультатПодготовкиЭлектронногоДокумента(Документ, ДокументУстаревший);
	
КонецПроцедуры

Процедура УПД970_ПодготовитьЭлектронныйДокументВРежимеСовместимости(Документ, ДанныеСотрудника, ДополнительныеПараметры)
	
	ИмяСобытия = "ПодготовитьЭлектронныйДокумент";
	
	ДокументУстаревший = ПодключаемыйМодуль_УстаревшийДокумент(Документ);
	ВидДокумента = ПодключаемыйМодуль_УстаревшийВидДокумента(ДокументУстаревший);
	
	Документ.СлужебнаяИнформация.Вставить("ОшибкиКонвертации", Новый Массив);
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Результат", ДокументУстаревший);
	ПараметрыПМ.Вставить("ДанныеСотрудника", ДанныеСотрудника);
	ПараметрыПМ.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	ПараметрыПМ.Вставить("ВидДокументаРазвернутый", ВидДокумента);
	
	Конвертация970_ЗаполнитьПараметрыДляПодготовкиЭлектронногоДокумента_в820(ПараметрыПМ, Документ);
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(Результат) Тогда
		
		РезультатИМ = Истина;
		
		Конвертация970_ЗаполнитьПараметрыДляПодготовкиЭлектронногоДокумента_в970(ПараметрыПМ, Документ);
		
		МенеджерИнтеграции_ПодготовитьЭлектронныйДокумент(
			ДокументУстаревший,
			ДанныеСотрудника,
			ВидДокумента,
			ДополнительныеПараметры
		);
		
		Конвертация970_ЗаполнитьПараметрыДляПодготовкиЭлектронногоДокумента_в820(ПараметрыПМ, Документ);
		
		НастройкиМодуляСтандарт = ХранениеДанных_НастройкиМодуляСтандарт();
		Если НастройкиМодуляСтандарт.ИспользоватьПодключаемыйМодуль Тогда
			
			Конвертация970_СобытияПМСтандарта_ПослеЗаполненияКонтента(
				ПараметрыПМ,
				Документ.ДокументУчета,
				НастройкиМодуляСтандарт.РежимСовместимостиФорматов155и820);
			
		КонецЕсли;
		
		Результат = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
			ИмяСобытия,
			ПараметрыПМ,
			РезультатИМ
		);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		Результат
	);
	
	ОбработатьРезультатПодготовкиЭлектронногоДокумента(Документ, ДокументУстаревший);
	
	Content970 = УПД820_Конвертировать_в970(
		ПараметрыПМ.Результат.Content,
		Документ.СлужебнаяИнформация.ОшибкиКонвертации);
		
	УПД970_ВосстановитьДанныеПослеКонвертации_из820(Content970, Документ.СлужебнаяИнформация.Контент);
	
	Документ.СлужебнаяИнформация.Контент = Content970;
	
КонецПроцедуры

Процедура ОбработатьРезультатПодготовкиЭлектронногоДокумента(Документ, ДокументУстаревший)
	
	Документ.Ключ = ДокументУстаревший.Ключ;
	Документ.Комментарий = ДокументУстаревший.Комментарий;

	ХранилищеКонтента	= Документ.Документооборот.ХранилищеКонтента;
	СлужебнаяИнформация	= Документ.СлужебнаяИнформация;
	
	ПодключаемыйМодуль_ЗаполнитьМетаданныеУстаревшегоДокумента(ДокументУстаревший);
	Документ.Метаданные = ДокументУстаревший.Метаданные;
	
	ХранилищеКонтента.Данные	= ДокументУстаревший.ДвоичныеДанные;
	ХранилищеКонтента.ИмяФайла	= ДокументУстаревший.ИмяФайла;
	
	ХранилищеКонтента.Подпись.ДанныеПодписи = ДокументУстаревший.ДвоичныеДанныеПодписи;
	
	СлужебнаяИнформация.ДокументыОснования								= ДокументУстаревший.ДокументыОснования;
	СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьИзвещение			= ДокументУстаревший.ЗапрашиватьИзвещение;
	СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись	= ДокументУстаревший.ЗапрашиватьОтветнуюПодпись;
	СлужебнаяИнформация.ПараметрыГенерацииXML.ТочностьКоличества		= ДокументУстаревший.ТочностьКоличества;
	СлужебнаяИнформация.ПараметрыГенерацииXML.ТочностьЦены				= ДокументУстаревший.ТочностьЦены;
	
	Если НЕ Документ.Тип.Формализованный Тогда
		// для совместимости с ранними версиями ПМ
		ЗапрашиватьОтветнуюПодпись = СвойствоСтруктуры(ДокументУстаревший.Content, "NeedRecipientSignature", Ложь);
		СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись = (ДокументУстаревший.ЗапрашиватьОтветнуюПодпись = Истина) 
																			Или ЗапрашиватьОтветнуюПодпись;
	КонецЕсли;
	
КонецПроцедуры

