Процедура Метрика_ДобавитьСтатистику_СкачиваниеДокументов(
	Действие,
	Документ,
	ЗаписатьМетрикиСценария = Ложь,
	ДопПеременные = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "Скачивание документов";
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	DocumentId	= Документ.Идентификаторы.DocumentId;
	
	Статус		= Документ.Статусы.Статус;
	Направление = Документ.Направление;
	
	Переменные = Новый Соответствие;
	
	Переменные.Вставить("BoxID"		, BoxId);
	Переменные.Вставить("LetterId"	, LetterId);
	Переменные.Вставить("DocumentId", DocumentId);
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	Переменные.Вставить("BaseID", ИдентификаторБазы1С);

	Переменные.Вставить("Статус"		, Статус);
	Переменные.Вставить("Направление"	, Направление);
	
	Если ЗаписатьМетрикиСценария Тогда
		
		СценарийСохранения				= ОбщиеНастройки_Прочитать("СохранениеДокументовСценарий");
		ГруппироватьДокументыПоПакетам	= ОбщиеНастройки_Прочитать("СохранениеДокументовГруппироватьПоПакетам");
	
		Переменные.Вставить("Сценарий сохранения"				, СценарийСохранения);
		Переменные.Вставить("Группировать документы по пакетам"	, ГруппироватьДокументыПоПакетам);
		
	КонецЕсли;
	
	Если ДопПеременные <> Неопределено Тогда
		Для каждого Переменная Из ДопПеременные Цикл
			Переменные.Вставить(Переменная.Ключ, Переменная.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_МассовоеДействиеПоДокументам(
	Категория,
	Действие,
	ДокументыДляОбработки,
	ИсточникОткрытия = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеДокументов = Новый Соответствие;
	
	СоответствиеОрганизаций1С = Новый Соответствие;
	
	Для Каждого Документ Из ДокументыДляОбработки Цикл
		
		// может прийти как массив строк списка, так и массив документов
		Если Документ.Свойство("Идентификаторы") Тогда
			BoxId		= Документ.Идентификаторы.BoxId;
			КонтрактМЧД	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
			РегНомерМЧД	= СвойствоСтруктуры(КонтрактМЧД, "Идентификатор", "");
			Документ1С	= СвойствоСтруктуры(Документ, "ДокументУчета");
		Иначе
			
			Организация1С	= Документ.Организация;
			BoxId			= СоответствиеОрганизаций1С[Организация1С];
			Документ1С		= СвойствоСтруктуры(Документ, "Документ");
			
			Если BoxId = Неопределено Тогда
				
				Идентификаторы			= Новый_ИдентификаторыСправочника(Организация1С);
				УчастникДО_Организации	= Организации_ЗаполнитьУчастникаДО(Идентификаторы);
				
				BoxId = УчастникДО_Организации.BoxId;
				
				СоответствиеОрганизаций1С.Вставить(Организация1С, BoxId);
				
			КонецЕсли;
			
		КонецЕсли;	
		
		ЗначениеСоответствия = СоответствиеДокументов[BoxId];
		Если ЗначениеСоответствия = Неопределено Тогда
			
			ЗначениеСоответствия = Новый Структура();
			ЗначениеСоответствия.Вставить("КоличествоДокументов", 1);
			ЗначениеСоответствия.Вставить("РегНомерМЧД"			, РегНомерМЧД);
			ЗначениеСоответствия.Вставить("Документ1С"			, Документ1С);
			
		Иначе
			
			ЗначениеСоответствия.КоличествоДокументов = ЗначениеСоответствия.КоличествоДокументов + 1;
			
			Если НЕ ЗначениеЗаполнено(ЗначениеСоответствия.Документ1С) Тогда
				ЗначениеСоответствия.Документ1С = Документ1С;
			КонецЕсли;
			
		КонецЕсли;
		
		СоответствиеДокументов.Вставить(BoxId, ЗначениеСоответствия);
		
	КонецЦикла;
	
	Для Каждого Элемент Из СоответствиеДокументов Цикл
		
		ЗначениеСоответствия = Элемент.Значение;
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID",					АдресЯщикаВИдентификатор(Элемент.Ключ));
		Переменные.Вставить("Количество документов",	ЗначениеСоответствия.КоличествоДокументов);
		Переменные.Вставить("Рег.номер МЧД",			ЗначениеСоответствия.РегНомерМЧД);
		
		Если ЗначениеЗаполнено(ЗначениеСоответствия.Документ1С) Тогда
			Переменные.Вставить("doc1CId", СокрЛП(ЗначениеСоответствия.Документ1С.УникальныйИдентификатор()));
		КонецЕсли;
		
		ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
		Переменные.Вставить("BaseID", ИдентификаторБазы1С);
		
		Если ЗначениеЗаполнено(ИсточникОткрытия) Тогда
			Переменные.Вставить("Источник", СокрЛП(ТипЗнч(ИсточникОткрытия)));
		КонецЕсли;
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_ДействиеДокументаАПИ(Категория, Действие, Документ)
	
	Если Не ИспользоватьМетрики()
		ИЛИ Не ЗначениеЗаполнено(Категория) Тогда
		Возврат;
	КонецЕсли;
	
	BoxId		= Документ.Идентификаторы.BoxId;
	LetterId	= Документ.Идентификаторы.LetterId;
	DocumentId	= Документ.Идентификаторы.DocumentId;
	
	ТипДокумента	 = Документ.Тип.ТипДокумента;
	ФункцияДокумента = Документ.Тип.ФункцияДокумента;
	ТипКонтента		 = Документ.Тип.ТипКонтента;
	
	Переменные = Новый Соответствие;
	
	Переменные.Вставить("BoxID",		АдресЯщикаВИдентификатор(BoxId));
	Переменные.Вставить("LetterId",		LetterId);
	Переменные.Вставить("DocumentId",	DocumentId);
	
	Переменные.Вставить("Тип документа",		ТипДокумента);
	Переменные.Вставить("Функция документа",	ФункцияДокумента);
	Переменные.Вставить("Версия документа",		ТипКонтента);
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	Переменные.Вставить("BaseID", ИдентификаторБазы1С);
	
	СлужебнаяИнформация	 = Документ.СлужебнаяИнформация;
	КонтрактМЧД			 = СвойствоСтруктуры(СлужебнаяИнформация, "КонтрактМЧД");
	Если ЗначениеЗаполнено(КонтрактМЧД) Тогда
		Переменные.Вставить("Рег.номер МЧД"		, КонтрактМЧД.Идентификатор);
		Переменные.Вставить("МЧД по умолчанию"	, КонтрактМЧД.ПоУмолчанию);
	КонецЕсли;
	
	Переменные.Вставить("FromDepartmentId"	, Документ.Отправитель.DepartmentId);
	Переменные.Вставить("ToDepartmentId"	, Документ.Получатель.DepartmentId);
	
	Если Категория = Метрики_КатегорияОтправкаДокумента() Тогда
		
		ДополнитьПеременныеМетрики_ОписаниеУчетногоДокумента(Переменные, Документ.ДокументУчета);
		
	КонецЕсли;
	
	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_НастройкиОрганизацияПриАвторизации() Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Контекст = КонтекстСеанса_СтрокиКонтекста();
	Если Не ЗначениеЗаполнено(Контекст) Тогда
		Возврат;
	КонецЕсли;
	
	Категория	= Метрика_НазваниеКатегории().НастройкиОрганизации;
	Действие	= Метрика_НазваниеДействий().Авторизация;
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Для Каждого Элемент Из Контекст Цикл
		
		BoxId = Элемент.Ключ;
		
		ИдентификаторОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
		ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторОрганизации);
		
		НастройкиПакетов = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(ДанныеОрганизации);
		
		ПередаватьМЧДФайлом = ХранениеДанных_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации);
		ПередаватьМЧДФайлом = ЗначениеНастройки(ПередаватьМЧДФайлом, Тип("Булево"), Ложь);
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID",	АдресЯщикаВИдентификатор(BoxId));
		Переменные.Вставить("BaseID",	ИдентификаторБазы1С);
		
		Переменные.Вставить("Записывать комментарии в документах",	ДанныеОрганизации.ЗаписыватьКомментарииВДокументы1С);
		Переменные.Вставить("Комментарий при отправке",				ДанныеОрганизации.ТекстКомментарияОтправка);
		Переменные.Вставить("Комментарий при создании",				ДанныеОрганизации.ТекстКомментарияПолучение);
		Переменные.Вставить("Отправлять непроведенные документы",	ДанныеОрганизации.ОтправлятьНепроведенныеДокументы);
		Переменные.Вставить("Указывать отсутствие основания УПД",	ДанныеОрганизации.УказыватьОтсутствиеОснованияУПД);
		Переменные.Вставить("Шифровать документы перед отправкой",	ДанныеОрганизации.ШифроватьДокументы);
		Переменные.Вставить("Передача МЧД файлом",					ПередаватьМЧДФайлом);
		
		МассивВидовПакетов = Новый Массив;
		
		Для Каждого ОписаниеПакета Из НастройкиПакетов Цикл
			Если ОписаниеПакета.ОтправлятьПакет Тогда
				МассивВидовПакетов.Добавить(ОписаниеПакета.ВидПакета);
			КонецЕсли;
		КонецЦикла;
		
		Переменные.Вставить("Виды пакетов",	МассивВидовПакетов);
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
				                   
	КонецЦикла;
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_ВидыДокументовПриАвторизации() Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Контекст = КонтекстСеанса_СтрокиКонтекста();
	Если Не ЗначениеЗаполнено(Контекст) Тогда
		Возврат;
	КонецЕсли;
	
	Категория	= "Настройки организации";
	Действие	= "Виды документов";
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	ВидыПакетов			= СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
	
	Для Каждого Элемент Из Контекст Цикл
		
		BoxId = Элемент.Ключ;
		Идентификатор = АдресЯщикаВИдентификатор(BoxId);
		
		ИдентификаторОрганизации = Новый_ИдентификаторыСправочника(, BoxId);
		ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторОрганизации);
		
		НастройкиПакетов = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(ДанныеОрганизации, , ВидыПакетов);
		НастройкиДокументовНаОтправку = НастройкиДокументов_НастройкиДокументовНаОтправку(ДанныеОрганизации);
		ДобавлятьСчетВПакет = НастройкиДокументов_ЗначениеНастройкиДобавлятьСчетВПакет(ДанныеОрганизации);
		
		МассивВидовДокументов = Новый Массив;
		
		Для Каждого Настройка Из НастройкиПакетов Цикл
			
			Если Не Настройка.ОтправлятьПакет Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеВидаПакета = ВидыПакетов.Найти(Настройка.ВидПакета, "ID");
			
			Если ДанныеВидаПакета <> Неопределено Тогда
				
				Если ЗначениеЗаполнено(ДанныеВидаПакета.СоставПакета) Тогда
					СоставПакета = РазделитьСтрокуЛок(ДанныеВидаПакета.СоставПакета);
					ДополнитьМассив(МассивВидовДокументов, СоставПакета);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого ОписаниеВидаДокумента Из НастройкиДокументовНаОтправку Цикл
			
			ID_ВидДокумента = ОписаниеВидаДокумента.ВидДокумента;
			
			НайденныйВидДокумента = МассивВидовДокументов.Найти(ID_ВидДокумента);
			
			Если НайденныйВидДокумента <> Неопределено Тогда
				
				КоличествоПечатныхФорм	= ОписаниеВидаДокумента.НастройкиПечатныхФорм.ДополнительныеПечатныеФормы.Количество();
				
				ФорматКонтента = ОписаниеВидаДокумента.ФорматКонтента;
				
				НайденныйФорматОтправки = ОписаниеВидаДокумента.ФорматыКонтента.НайтиПоЗначению(ФорматКонтента);
				
				Если НайденныйФорматОтправки <> Неопределено Тогда
					ФорматОтправки = НайденныйФорматОтправки.Представление;
				КонецЕсли;	
				
				Переменные = Новый Соответствие;
				Переменные.Вставить("BoxID", Идентификатор);
				Переменные.Вставить("BaseID", ИдентификаторБазы1С);
				
				Переменные.Вставить("Значение формата отправки", ФорматОтправки);
				Переменные.Вставить("Количество доп.печатных форм", КоличествоПечатныхФорм);
				
				Если ЭтоВидДокументаСчет(ID_ВидДокумента) Тогда
					Переменные.Вставить("ОснованиеДляСчета", ОписаниеВидаДокумента.ФормироватьНаОсновании);
					Если ЗначениеЗаполнено(ДобавлятьСчетВПакет) Тогда
						Переменные.Вставить("ДобавлятьСчетВПакет", ДобавлятьСчетВПакет);
					Иначе
						Переменные.Вставить("ДобавлятьСчетВПакет", Ложь);
					КонецЕсли;
				КонецЕсли;
				
				Метрика_ЗаписатьСтатистику(Категория, Действие, ID_ВидДокумента, Переменные);
				
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЦикла;	
	
КонецПроцедуры

Функция ЭтоВидДокументаСчет(Знач ID_ВидДокумента)
	
	Результат = Ложь;
	
	ЕстьИМ = ЕстьИнтеграционныйМодуль();
	Если ЕстьИМ Тогда
	
		Модуль_МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
		Результат = Модуль_МенеджерИнтеграции.ЭтоИдентификаторВидаФормализованныйСчет(ID_ВидДокумента)
			Или Модуль_МенеджерИнтеграции.ЭтоИдентификаторВидаНеформализованныйСчет(ID_ВидДокумента);
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Фиксирует массив уникальных событий, которые переопределены в подключаемом модуле
// 
Процедура Метрика_ДобавитьСтатистику_ИспользованиеПМ() Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория	 = Метрика_НазваниеКатегории().ИспользованиеПМ;
	Действие	 = Метрика_НазваниеДействий().Переопределить;
	
	СобытияПМ = Кэш_Прочитать("СобытияПодключаемогоМодуля");
	
	Если ЗначениеЗаполнено(СобытияПМ) Тогда
		МассивУникальныхСобытийПМ = Новый Массив;
		
		Для Каждого Элемент Из СобытияПМ Цикл
			МассивУникальныхСобытийПМ.Добавить(Элемент.Ключ);
		КонецЦикла;
	КонецЕсли;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("Действия", МассивУникальныхСобытийПМ);
	
	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_УспешноеАвтообновлениеМодуля(ДанныеДляОбновленияМодуля) Экспорт
	
	РезультатОбновления = "Success";
		
	Топик = ТопикиМетрики().Statistics;
	Категория = Метрика_НазваниеКатегории().АвтообновлениеМодуляУМ;
	Действие = Метрика_НазваниеДействий().АвтоматическоеОбновление;
	Переменные = Метрика_ОбщиеПеременныеАвтообновленияМодуля(РезультатОбновления, ДанныеДляОбновленияМодуля);
	
	Метрика_ЗаписатьПроизвольноеСобытие_Принудительно(Топик, Категория, Действие, , , Переменные);		
	
	Метрики_Отправить_Принудительно();	
	
КонецПроцедуры

Функция Метрика_ОбщиеПеременныеАвтообновленияМодуля(РезультатОбновления, ДанныеДляОбновленияМодуля)
	
	Результат = Новый Соответствие;
	
	ОписаниеРасположения = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	ОписаниеОбновления = ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля;
	ОписаниеОкружения = ДанныеДляОбновленияМодуля.ОписаниеОкруженияМодуля;
				
	ТекущаяВерсия = ОбщийКонтекстКлиентСервер.ВерсияМодуля;
	НоваяВерсия	= ОписаниеОбновления.Версия;
	
	Результат.Вставить("Результат"				, РезультатОбновления);
	Результат.Вставить("НоваяВерсия" 			, НоваяВерсия);
	Результат.Вставить("ТекущаяВерсия" 			, ТекущаяВерсия);
	
	Для Каждого Элемент Из ОписаниеРасположения Цикл
		Результат.Вставить(Элемент.Ключ, Строка(Элемент.Значение));	
	КонецЦикла;
	
	Для Каждого Элемент Из ОписаниеОкружения Цикл
		Результат.Вставить(Элемент.Ключ, Элемент.Значение);	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Метрика_ДобавитьСтатистику_РезультатРегистрацииМЧД(ПараметрыРегистрацииМЧД, РезультатРегистрации)
	
	КатегорияМетрики		= Метрика_НазваниеКатегории().ДобавлениеМЧД;
	ДействиеМетрики			= Метрика_НазваниеДействий().Добавить;
	ПредставлениеМетрики	= КатегорияМетрики;
	
	УспешноеДобавление		 = РезультатРегистрации.ПодробноеОписаниеОшибки = "";
	ПредставлениеРезультата	 = ?(УспешноеДобавление, "Успешно", "Ошибка");
	ВариантРегистрации		 = ?(ПараметрыРегистрацииМЧД.РегистрацияПоФайлу, "По рег. номеру", "По файлу");
	
	ДопПеременные			= Новый Соответствие;
	ДопПеременные.Вставить("Результат"		, ПредставлениеРезультата);
	ДопПеременные.Вставить("Вариант"		, ВариантРегистрации);
	ДопПеременные.Вставить("Рег.номер МЧД"	, ПараметрыРегистрацииМЧД.РегистрационныйНомер);
	
	Если НЕ УспешноеДобавление Тогда
		
		Метрика_СписокОшибок = РезультатРегистрации.СписокОшибок; 
		Если Метрика_СписокОшибок.Количество() = 0 Тогда
			
			Метрика_СписокОшибок = Новый Массив;
			МЧД_ДополнитьСписокОшибокРегистрации(Метрика_СписокОшибок, РезультатРегистрации.КодОшибки, РезультатРегистрации.ПодробноеОписаниеОшибки);
		
		КонецЕсли;
		
		ДопПеременные.Вставить("Описание ошибки", Метрика_СписокОшибок);
		
	КонецЕсли;
	
	Метрика_ДобавитьСтатистику_ДляОрганизации(ПараметрыРегистрацииМЧД.boxId, КатегорияМетрики, ДействиеМетрики, , ДопПеременные, ПредставлениеМетрики);
	
КонецПроцедуры

