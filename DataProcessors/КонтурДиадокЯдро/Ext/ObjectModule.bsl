// Возвращает параметры приложения, определенные в конфигурационном файле.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельАутхКонфигурацияПриложения.
//  Неопределено - если в конфиг-файле отсутствует хотя бы один из параметров клиента OAuth
//
Функция АутхКонфигурацияПриложенияКонфигФайл() Экспорт
	
	ВсеПараметрыУказаны = Истина;
	КонфигФайл = КонфигурационныйФайл_ЗначенияПараметров();
	
	Модель = МодельАутхКонфигурацияПриложения();
	Модель.Имя = КонфигФайл.Получить("auth_client_id");
	Модель.Ключ = КонфигФайл.Получить("auth_client_secret");
	Модель.Разрешения = КонфигФайл.Получить("auth_scope");
	
	ВсеПараметрыУказаны = ВсеПараметрыУказаны И ЗначениеЗаполнено(Модель.Имя);
	ВсеПараметрыУказаны = ВсеПараметрыУказаны И ЗначениеЗаполнено(Модель.Ключ);
	ВсеПараметрыУказаны = ВсеПараметрыУказаны И ЗначениеЗаполнено(Модель.Разрешения);
	
	Результат = Неопределено;
	Если ВсеПараметрыУказаны Тогда
		Результат = ФиксированныеДанные(Модель);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает параметры приложения, определенные в настройках информационной базы.
// Вызывающий код должен самостоятельно устанавливать привилегированный режим.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельАутхПользовательскиеНастройкиПриложения.
//
Функция АутхКонфигурацияПриложенияНастройки() Экспорт
	
	Результат = Неопределено;
	
	Контейнер = ХранилищеНастроекПриложения_Прочитать(КлючНастройкиАутхКонфигурацияПриложения());
	
	Данные = Неопределено;
	Если ТипЗнч(Контейнер) = Тип("ХранилищеЗначения") Тогда
		Данные = Контейнер.Получить();
	КонецЕсли;
	
	Модель = МодельАутхПользовательскиеНастройкиПриложения();
	
	Если Данные <> Неопределено Тогда
		
		Модель.Использовать = Данные.Использовать;
		Модель.Имя = Данные.Имя;
		Модель.Ключ = Данные.Ключ;
		
	КонецЕсли;
	
	Результат = ФиксированныеДанные(Модель);
	
	Возврат Результат;
	
КонецФункции

// Записывает настройки приложения в информационную базу. При записи выполняется
// проверка прав пользователя. Если прав недостаточно, будет вызвано исключение.
// Вызывающий код должен самостоятельно устанавливать привилегированный режим.
//
// Параметры:
//  ИмяПриложения - Строка - имя приложения (client_id)
//  КлючПриложения - Строка - ключ приложения (client_secret)
//  Включить - Булево - Истина, если настройки включены
//
Процедура АутхКонфигурацияПриложенияНастройкиУстановить(Знач ИмяПриложения, Знач КлючПриложения, Знач Включить) Экспорт
	
	Если ТипЗнч(Включить) <> Тип("Булево") Тогда
		Ошибка = "TypeError: Параметр 'Включить' должен иметь тип 'Булево'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если ТипЗнч(ИмяПриложения) <> Тип("Строка") Тогда
		Ошибка = "TypeError: Параметр 'ИмяПриложения' должен иметь тип 'Строка'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если ТипЗнч(КлючПриложения) <> Тип("Строка") Тогда
		Ошибка = "TypeError: Параметр 'КлючПриложения' должен иметь тип 'Строка'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если Включить Тогда
		
		Если ПустаяСтрока(ИмяПриложения) Тогда
			Ошибка = "ValueError: Параметр 'ИмяПриложения' должен быть заполнен";
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		Если ПустаяСтрока(КлючПриложения) Тогда
			Ошибка = "ValueError: Параметр 'КлючПриложения' должен быть заполнен";
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
	КонецЕсли;
	
	Данные = МодельАутхПользовательскиеНастройкиПриложения();
	Данные.Имя = ИмяПриложения;
	Данные.Ключ = КлючПриложения;
	Данные.Использовать = Включить;
	
	Контейнер = Новый ХранилищеЗначения(ФиксированныеДанные(Данные));
	ХранилищеНастроекПриложения_Записать(КлючНастройкиАутхКонфигурацияПриложения(), Контейнер);
	
КонецПроцедуры

// Формирует список разрешений, необходимых приложению для работы с API Диадока.
// 
// Возвращаемое значение:
//  Строка - идентификаторы скоупов, разделенные пробелом.
//
Функция АутхРазрешенияПриложения()
	
	СписокРазрешений = Новый Массив;
	СписокРазрешений.Добавить("openid");
	СписокРазрешений.Добавить("profile");
	СписокРазрешений.Добавить("email");
	СписокРазрешений.Добавить("offline_access");
	СписокРазрешений.Добавить("Diadoc.PublicAPI");
	
	Результат = СоединитьСтроку(СписокРазрешений, " ");
	
	Возврат Результат;
	
КонецФункции

