Функция УС_ТребуетсяФормироватьУниверсальныеСообщения()
	
	Результат = Ложь;
	
	КонтекстСеанса = ХранилищеКонтекстаСеанса();
	
	Для Каждого СтрокаКонтекста Из КонтекстСеанса Цикл
		
		ЗначениеПрава = УС_ДоступноФормированиеУниверсальныхСообщений(СтрокаКонтекста.Ключ);
		Результат = (ЗначениеПрава <> Неопределено);
		Прервать;
		
	КонецЦикла;
	
	Возврат Результат;
	
