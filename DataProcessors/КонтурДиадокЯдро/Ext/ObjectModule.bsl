Функция Контрагенты_РеквизитыКонтрагента_АПИ(BoxId) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	
	Counteragent = АПИ_GetBox(ПараметрыСервиса, BoxId);
	
	Результат = Контрагенты_НовыйКонтрагентИзСтруктуры(Counteragent);
	
	Возврат Результат;
	
КонецФункции

// Формирует внутренний контракт КонтрагентЭДО по описанию организации в Диадоке
//
// Параметры:
//   Counteragent - Структура - описание организации в Диадоке.
//                              см. https://developer.kontur.ru/docs/diadoc-api/proto/Organization.html
//
// Возвращаемое значение:
//  Структура - см. Контракт_КонтрагентЭДО
//
Функция Контрагенты_НовыйКонтрагентИзСтруктуры(Counteragent)
	
	Результат = Контракт_КонтрагентЭДО();

	ПустаяСтрока = "";

	СтатусCurrent		= СвойствоСтруктуры(Counteragent, "CurrentStatus"		, ПустаяСтрока);
	СтатусCounteragent	= СвойствоСтруктуры(Counteragent, "CounteragentStatus"	, ПустаяСтрока);

	Organization 	= Counteragent.Organization;
	Boxes 			= Organization.Boxes;          
	
	ПолноеНаименование	= Organization.FullName;
	КраткоеНаименование	= СвойствоСтруктуры(Organization, "ShortName"			, ПустаяСтрока);
	ДатаЛиквидации 		= СвойствоСтруктуры(Organization, "LiquidationDate"		, Дата(1, 1, 1));
	ДатаИзменения		= СвойствоСтруктуры(Counteragent, "LastEventTimestampTicks"	, 0);
	
	Результат.ID				 		= Boxes[0].BoxId;
	Результат.ИНН				 		= Organization.Inn;
	Результат.КПП						= СвойствоСтруктуры(Organization, "Kpp"					, ПустаяСтрока);
	Результат.ИдентификаторУчастникаЭДО	= СвойствоСтруктуры(Organization, "FnsParticipantId"	, ПустаяСтрока);
	Результат.OrgId				 		= Organization.OrgId;	
	Результат.Наименование				= ?(КраткоеНаименование = ПустаяСтрока	, ПолноеНаименование	, КраткоеНаименование);
	Результат.Статус	 				= ?(СтатусCurrent = ПустаяСтрока		, СтатусCounteragent	, СтатусCurrent);
	Результат.ДатаЛиквидации	 		= ДатаXML_в_Дата1С(ДатаЛиквидации);
	Результат.Роуминговый		 		= ЭтоРоуминговыйИдентификаторУчастникаЭДО(Результат.ИдентификаторУчастникаЭДО);
	Результат.ДатаИзменения	 			= Ticks_2_Date(ДатаИзменения);
	
	Возврат Результат;
	
КонецФункции

// Формирует внутренний контракт КонтрагентЭДО по описанию организации в Диадоке
//
// Параметры:
//   Counteragent - Соответствие- описание организации в Диадоке.
//                                см. https://developer.kontur.ru/docs/diadoc-api/proto/Organization.html
//
// Возвращаемое значение:
//  Структура - см. Контракт_КонтрагентЭДО
//
Функция Контрагенты_НовыйКонтрагентИзСоответствия(Counteragent)
	
	Результат = Контракт_КонтрагентЭДО();
	
	ПустаяСтрока = "";
	
	СтатусCurrent		= ЗначениеСоответствия(Counteragent, "CurrentStatus"		, ПустаяСтрока);
	СтатусCounteragent	= ЗначениеСоответствия(Counteragent, "CounteragentStatus"	, ПустаяСтрока);

	Organization 	= Counteragent["Organization"];
	Boxes 			= Organization["Boxes"];          
	
	ПолноеНаименование	= Organization["FullName"];
	КраткоеНаименование	= ЗначениеСоответствия(Organization, "ShortName"		, ПустаяСтрока);
	ДатаЛиквидации 		= ЗначениеСоответствия(Organization, "LiquidationDate"	, Дата(1, 1, 1));
	
	Результат.ID				 		= Boxes[0]["BoxId"];
	Результат.ИНН				 		= Organization["Inn"];
	Результат.КПП						= ЗначениеСоответствия(Organization, "Kpp"				, ПустаяСтрока);
	Результат.ИдентификаторУчастникаЭДО	= ЗначениеСоответствия(Organization, "FnsParticipantId"	, ПустаяСтрока);
	Результат.OrgId				 		= Organization["OrgId"];	
	
	Результат.Наименование				= ?(КраткоеНаименование = ПустаяСтрока	, ПолноеНаименование	, КраткоеНаименование);
	Результат.Статус	 				= ?(СтатусCurrent = ПустаяСтрока		, СтатусCounteragent	, СтатусCurrent);
	Результат.ДатаЛиквидации	 		= ДатаXML_в_Дата1С(ДатаЛиквидации);
	Результат.Роуминговый		 		= ЭтоРоуминговыйИдентификаторУчастникаЭДО(Результат.ИдентификаторУчастникаЭДО);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_НоваяТаблицаКонтрактов() Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ID"							, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("OrgId"						, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36)));         
	Результат.Колонки.Добавить("ИНН"						, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(12)));
	Результат.Колонки.Добавить("КПП"						, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(9)));
	Результат.Колонки.Добавить("Наименование"				, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	Результат.Колонки.Добавить("ИдентификаторУчастникаЭДО"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(47)));
	Результат.Колонки.Добавить("Роуминговый"				, Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("ДатаЛиквидации"				, Новый ОписаниеТипов("Дата", 	, Новый КвалификаторыДаты));
	Результат.Колонки.Добавить("Статус"						, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(25)));
	Результат.Колонки.Добавить("Ссылка"						, Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник1"		, Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник2"		, Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник3"		, Неопределено);
	Результат.Колонки.Добавить("ID_ОсновноеПодразделение"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("ДатаИзменения"				, Новый ОписаниеТипов("Дата", 	, Новый КвалификаторыДаты));
	
	Возврат Результат;
	
КонецФункции

