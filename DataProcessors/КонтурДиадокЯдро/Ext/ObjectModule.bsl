// Определяет формат отправки электронного документа на основе
// типа контента и функции УПД/УКД.
//
// Параметры:
//  ТипКонтента				- Строка 	- Идентификатор типа контента
//  ФункцияУПД				- Строка 	- Функция документа для XML. Например, "СЧФДОП" или "КСЧФ".
//	ДополнительныеПараметры	- Структура - см. ДополнительныеПараметрыПолученияКонтента
// 
// Возвращаемое значение:
//  Структура - см. Контракт_ФорматЭлектронногоДокумента.
//
Функция ФорматОтправкиПоТипуКонтента(ТипКонтента, ФункцияУПД, ДополнительныеПараметры = Неопределено)
	
	ТипКонтентаНРег = НРег(ТипКонтента);
	
	Если ТипКонтентаНРег = НРег("Utd970SellerContent") Тогда
		
		// Если контент собираем для акта, накладной или СФ, то УПД все равно нам подходит
		Результат = ФорматОтправкиУПД970(ФункцияУПД);
		
	ИначеЕсли ТипКонтентаНРег = НРег("Utd820SellerContent") Тогда
		
		// Если контент собираем для акта, накладной или СФ, то УПД все равно нам подходит
		Результат = ФорматОтправкиУПД820(ФункцияУПД);
		
	ИначеЕсли ТипКонтентаНРег = НРег("UtdSellerContent") Тогда
		
		Результат = ФорматОтправкиУПД155(ФункцияУПД);
		
	ИначеЕсли ТипКонтентаНРег = НРег("UcdSellerContent") Тогда
		
		FormatVersion = СвойствоСтруктуры(ДополнительныеПараметры, "FormatVersion", "ucd");
		
		Если FormatVersion = "ucd736" Тогда 
			Результат = ФорматОтправкиУКД736(ФункцияУПД);
		Иначе
			// УКД подходит и для КСФ
			Результат = ФорматОтправкиУКД189(ФункцияУПД);
		КонецЕсли;
		
	ИначеЕсли ТипКонтентаНРег = НРег("ProformaInvoice29SellerContent") Тогда
		
		Результат = ФорматОтправкиСчетНаОплатуФНС29();
		
	ИначеЕсли ТипКонтентаНРег = НРег("ProformaInvoiceSellerContent") Тогда
		
		Результат = ФорматОтправкиСчетНаОплату();
		
	ИначеЕсли ТипКонтентаНРег = НРег("ReconciliationActSenderTitle") Тогда
		
		Результат = ФорматОтправкиАктСверки();
		
	Иначе
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку("Неожиданный тип контента (%1)", ТипКонтента);
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Конвертирует тип электронного документа в описание формата, которое используется в стандартных модулях.
//
// Параметры:
//  ТипЭД - Структура - тип электронного документа (см. Контракт_ТипЭлектронногоДокумента).
// 
// Возвращаемое значение:
//  Структура - см. Контракт_ФорматЭлектронногоДокумента.
//
Функция ФорматОтправкиПоТипуДокумента(ТипЭД)
	
	ИмяТипа = ТипЭД.ТипДокумента;
	БазовыйФормат = ТипЭД.ТипКонтента;
	ФункцияДокумента = ТипЭД.ФункцияДокумента;
	
	ИмяФункции = Документы_ФункцияДокументаДляXML(ИмяТипа, ФункцияДокумента);
	Если Не ЗначениеЗаполнено(ИмяФункции) Тогда
		ИмяФункции = "default";
	КонецЕсли;
	
	ОписаниеТипаДокумента = Списки_ОписаниеТипаДокументаAPI(ИмяТипа, БазовыйФормат, ФункцияДокумента);
	
	ВерсияФормата = ОписаниеТипаДокумента.Version;
	
	Результат = Новый_ФорматЭлектронногоДокумента(
		ИмяТипа,
		ИмяФункции,
		ВерсияФормата
	);
	
	Возврат Результат;
	
КонецФункции

// Инициализирует структуру дополнительных параметров для методов сбора контента.
// 
// Возвращаемое значение:
//  Структура - содержит поля:
//    * ФИОПодписанта - Строка - Фамилия, имя и отчество  подписанта.
//    * ДанныеСотрудника - Структура, Неопределено - Сведения о работнике организации продавца (РабОргПрод):
//       ** Фамилия - Строка - фамилия сотрудника.
//       ** Имя - Строка - имя сотрудника.
//       ** Отчество - Строка - отчество сотрудника.
//       ** Должность - Строка - должность сотрудника.
//    * ПараметрыСогласования - Структура, Неопределено - Заполняется при передаче документа на согласование/подпись:
//       ** ФИОПодписанта - Строка - Фамилия, имя и отчетство подписанта;
//       ** ДолжностьПодписанта - Строка - должность подписанта;
//       ** ФИОПолучателя - Строка - Фамилия, имя и отчество получателя;
//       ** ДолжностьПолучателя - Строка - должность получателя;
//    * ДополнительныеСведенияСтрокой - Строка - Список доп. полей в формате "ИмяПоля = Значение".
//                                               Доп. поля указываются через точку с запятой.
//    * УказыватьОтсутствиеОснованияУПД - Булево - Истина, если при незаполненном основании передачи
//                                                 товаров (услуг, работ) в поле GroundName следует
//                                                 в указывать строку, определенную форматом для пустого
//                                                 основания передачи (например, "Отсутствует" для 155@
//                                                 или "Без документа-основания" для 820@).
//    * ИспользоватьСервисКонтурМаркировка - Булево - Истина, если для получения сведений о маркировке следует
//                                                    использовать данные подсистемы Контур.Маркировка.
//    * СчетФактура - ссылка на счет-фактуру на отчет комитента о закупках (товары и услуги)
//
Функция ДополнительныеПараметрыПолученияКонтента() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ФИОПодписанта");
	Результат.Вставить("ДанныеСотрудника");
	Результат.Вставить("ПараметрыСогласования");
	Результат.Вставить("ДополнительныеСведенияСтрокой");
	Результат.Вставить("УказыватьОтсутствиеОснованияУПД", Ложь);
	Результат.Вставить("ИспользоватьСервисКонтурМаркировка", ЗначениеНастройки_ИспользоватьСервисКонтурМаркировка());
	Результат.Вставить("ТочностьЦены");
	Результат.Вставить("ТочностьКоличества");
	Результат.Вставить("СчетФактура");
	Результат.Вставить("ПолучатьИзКМДляУКДТолькоРазницу", ПолучатьИзКонтурМаркировкиТолькоИзмененияКодовДляУКД());
	
	Возврат Результат;
	
КонецФункции

// Заполняет дополнительные параметры получения контента по структуре
// дополнительных параметров, полученных из подключаемого модуля.
//
// Параметры:
//  ДопПараметры - Структура - см. ДополнительныеПараметрыПолученияКонтента;
//  ПараметрыПМ	 - Структура, Неопределено - параметры, определенные в ПМ.
//
Процедура ЗаполнитьПараметрыПолученияКонтента(ДопПараметры, ПараметрыПМ)
	
	Если Не ЗначениеЗаполнено(ПараметрыПМ) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДопПараметры, ПараметрыПМ);
	
	Если ПараметрыПМ.Свойство("ДопСведения") Тогда
		ДопПараметры.ДополнительныеСведенияСтрокой = ПараметрыПМ.ДопСведения;
	КонецЕсли;
	
	ДопПараметры.ТочностьЦены = ЗначениеНастройки_ТочностьЦены();
	ДопПараметры.ТочностьКоличества = ЗначениеНастройки_ТочностьКоличества();
	
КонецПроцедуры

// Получает протоконтент для формирования электронного документа.
// Сбор контента производится средствами стандартного модуля.
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - ссылка на источник данных для получения контента.
//  ФорматОтправки - Структура - формат для отправки электронного документа (см. Контракт_ФорматЭлектронногоДокумента).
//  ДополнительныеПараметры - Структура - см. ДополнительныеПараметрыПолученияКонтента.
// 
// Возвращаемое значение:
//  Структура.
//
// Пример:
//  ФорматОтправки = ФорматЭлектронногоДокумента("UniversalTransferDocument", "СЧФДОП", "utd820_05_01_01_hyphen");
//  ДопПараметры = ДополнительныеПараметрыПолученияКонтента();
//  ДопПараметры.УказыватьОтсутствиеОснованияУПД = Истина;
//  Контент = ТиповойМодуль_КонтентФормализованногоДокумента(СчетФактура, ФорматОтправки, ДопПараметры);
//
Функция МенеджерИнтеграции_КонтентТитулаОтправителя(СсылкаНаОбъект, ФорматОтправки, ДополнительныеПараметры)
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Новый Структура;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	Попытка
		
		Результат = МенеджерИнтеграции.КонтентТитулаОтправителя(
			СсылкаНаОбъект,
			ФорматОтправки,
			ДополнительныеПараметры
		);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ШаблонОшибки =
		"Не удалось сформировать титул отправителя (Тип=%1, Функция=%2, Версия=%3) по причине:
		|%4";
		
		ПодробнаяОшибка = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			ФорматОтправки.ИмяТипа,
			ФорматОтправки.ФункцияДокумента,
			ФорматОтправки.ВерсияФормата,
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.ФормированиеЭлектронногоДокумента",
			УровеньЖурналаРегистрации.Ошибка,
			СсылкаНаОбъект.Метаданные(),
			СсылкаНаОбъект,
			ПодробнаяОшибка
		);
		
		ДопКонтекст = Новый Соответствие;
		ДополнитьПеременныеМетрики_ОписаниеУчетногоДокумента(ДопКонтекст, СсылкаНаОбъект);
		ДополнитьПеременныеМетрики_ТипЭлектронногоДокумента(ДопКонтекст, ФорматОтправки);
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияОтправкаДокумента(),
			"ПолучитьКонтент",
			Ошибка,
			ДопКонтекст
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Устарела. Рекомендуется использовать следующие методы:
// Для формирования печатной формы счета на оплату - СчетаНаОплату_ПечатнаяФорма
//
Функция МенеджерИнтеграции_НеформализованныйКонтент(СсылкаНаОбъект, ТипКонтента, ДополнительныеПараметры)
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	Результат = МенеджерИнтеграции.НеформализованныйКонтент(
		СсылкаНаОбъект,
		ТипКонтента,
		ДополнительныеПараметры
	);
	
	Возврат Результат;
	
КонецФункции

Функция ТиповойМодуль_ПолучитьКонтент(Документ1С, ТипКонтента, ДополнительныеПараметры) Экспорт
	
	ФункцияУПД = СвойствоСтруктуры(ДополнительныеПараметры, "ФункцияУПД");
	
	ФорматОтправки = ФорматОтправкиПоТипуКонтента(ТипКонтента, ФункцияУПД, ДополнительныеПараметры);
	
	ПараметрыПолученияКонтента = ДополнительныеПараметрыПолученияКонтента();
	ЗаполнитьПараметрыПолученияКонтента(ПараметрыПолученияКонтента, ДополнительныеПараметры);
	
	Результат = МенеджерИнтеграции_КонтентТитулаОтправителя(
		Документ1С,
		ФорматОтправки,
		ПараметрыПолученияКонтента
	);
	
	ТиповойМодуль_ПослеПолученияКонтента(Результат, ТипКонтента);
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение настройки стандартного модуля "ДиадокСтандартнаяФормаСчетаНаОплату".
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - учетный документ, для которого проверяется работа настройки
// 
// Возвращаемое значение:
//  Булево - Истина, настройка стандарта существует и применима для документов указанного типа.
//
Функция НастройкиТиповогоМодуля_ДиадокСтандартнаяФормаСчетаНаОплату(СсылкаНаОбъект)
	
	Результат = Ложь;
	
	ТипСсылки = ТипЗнч(СсылкаНаОбъект);
	Если НЕ НастройкиТиповогоМодуля_ПрименяетсяНастройкаСтандартнаяФормаСчетаНаОплату(ТипСсылки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СвойствоСтандартнаяФормаСчетаНаОплату = СвойствоДиадокСтандартнаяФормаСчетаНаОплату();
	
	Если СвойствоСтандартнаяФормаСчетаНаОплату <> Неопределено Тогда
		
		Организация1С = СсылкаНаОбъект.Организация;
		
		ЗначениеНастройки = ЗначениеСвойстваПланаВидовХарактеристик(
			Организация1С,
			СвойствоСтандартнаяФормаСчетаНаОплату
		);
		
		Если ТипЗнч(ЗначениеНастройки) = Тип("Булево") Тогда
			Результат = ЗначениеНастройки;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Для проверки совместимости с настройками типового модуля.
// Важно: метод МенеджерИнтеграции.ЭтоДокументКонфигурацииСчетНаОплату
// не используется, т.к. требуется обеспечить точно такое же поведение,
// какое было реализовано в функции ТиповойМодуль.МодульИнтеграции.ЭтоСчетНаОплату
//
// Параметры:
//  ТипСсылки - Тип - тип объекта, для которого проверяется работа настройки
// 
// Возвращаемое значение:
//  Булево - Истина, если для указанного типа объектов применима настройка "ДиадокСтандартнаяФормаСчетаНаОплату"
//
Функция НастройкиТиповогоМодуля_ПрименяетсяНастройкаСтандартнаяФормаСчетаНаОплату(ТипСсылки)
	
	ИМ = ИнтеграционныйМодуль_Получить();
	
	ПодходящиеТипы = Новый Массив;
	
	Если ИМ = ИмяИМ_УТ11() Тогда
		
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплатуКлиенту"));
		
	ИначеЕсли ИМ = ИмяИМ_БП30() Тогда
		
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплатуПокупателю"));
		
	ИначеЕсли ИМ = ИмяИМ_БГУ20() Тогда
		
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплату"));
		
	ИначеЕсли ИМ = ИмяИМ_УНФ16() Тогда
		
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплату"));
		
	ИначеЕсли ИМ = ИмяИМ_АльфаАвто6() Тогда
		
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплату"));
		ПодходящиеТипы.Добавить(Тип("ДокументСсылка.СчетНаОплатуЗаАвтомобили"));
		
	КонецЕсли;
	
	Результат = (ПодходящиеТипы.Найти(ТипСсылки) <> Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция СвойствоДиадокСтандартнаяФормаСчетаНаОплату()
	
	ИдентификаторНастройки = "ДиадокСтандартнаяФормаСчетаНаОплату";
	
	Результат = СвойствоПланаВидовХарактеристик(ИдентификаторНастройки);
	
	Возврат Результат;
	
КонецФункции

Функция СвойствоПланаВидовХарактеристик(НаименованиеСвойства)
	
	Результат = Неопределено;
	
	ИмяПВХ = "ДополнительныеРеквизитыИСведения";
	
	Если Метаданные.ПланыВидовХарактеристик.Найти(ИмяПВХ) = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 2
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК Ссылка
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", НаименованиеСвойства);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Количество() = 2 Тогда
			
			ШаблонОшибки = НСтр(
				"ru='В плане видов характеристик ""Дополнительные реквизиты и сведения"" обнаружено несколько свойств с одинаковым наименованием ""%1""!'"
			);
			
			ТекстОшибки = ПараметрыВСтроку(
				ШаблонОшибки,
				НаименованиеСвойства
			);
			
			ВызватьИсключение ТекстОшибки;
			
		КонецЕсли;
		
		Выборка.Следующий();
		Результат = Выборка.Ссылка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеСвойстваПланаВидовХарактеристик(ОбъектСвойства, Свойство)
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ДополнительныеСведения.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	ДополнительныеСведения.Объект = &Объект
	|	И ДополнительныеСведения.Свойство = &Свойство";
	
	Запрос.УстановитьПараметр("Объект", ОбъектСвойства);
	Запрос.УстановитьПараметр("Свойство", Свойство);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Выборка.Следующий();
		Результат = Выборка.Значение;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует печатную форму электронного счета на оплату.
// Для обратной совместимости со стандратным модулем проверяется
// значение настройки "ДиадокСтандартнаяФормаСчетаНаОплату". Если
// в Стандарте эта настройка была включена, формируется типовая
// печатная форма конфигурации. В противном случае формируется
// диадочная печатная форма счета на оплату.
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - учетный документ (основание электронного счета на оплату)
// 
// Возвращаемое значение:
//  ТабличныйДокумент - печатная форма счета на оплату.
//
Функция СчетаНаОплату_ПечатнаяФорма(СсылкаНаОбъект) Экспорт
	
	Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		
		ТекстОшибки = НСтр(
			"ru='Не указан документ-основание для формирования электронного счета на оплату'"
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.СчетаНаОплату_ПечатнаяФорма",
			УровеньЖурналаРегистрации.Ошибка, , ,
			ТекстОшибки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		
		ТекстОшибки = НСтр(
			"ru='Не подключен типовой интеграционный модуль'"
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.СчетаНаОплату_ПечатнаяФорма",
			УровеньЖурналаРегистрации.Ошибка,
			СсылкаНаОбъект.Метаданные(),
			СсылкаНаОбъект,
			ТекстОшибки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	ИспользоватьПечатнуюФорму1С = НастройкиТиповогоМодуля_ДиадокСтандартнаяФормаСчетаНаОплату(СсылкаНаОбъект);
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
	Попытка
		
		Если ИспользоватьПечатнуюФорму1С Тогда
			Результат = МенеджерИнтеграции.СчетаНаОплату_ПечатнаяФорма1С(СсылкаНаОбъект);
		Иначе
			
			ПечатныеФормы = Модуль_ПечатныеФормы(ЭтотОбъект);
			
			Данные = МенеджерИнтеграции.СчетаНаОплату_Данные(СсылкаНаОбъект);
			Результат = ПечатныеФормы.ПФ_СчетНаОплатуДиадок(Данные);

		КонецЕсли;
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации(
			"Диадок.СчетаНаОплату_ПечатнаяФорма",
			УровеньЖурналаРегистрации.Ошибка,
			СсылкаНаОбъект.Метаданные(),
			СсылкаНаОбъект,
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Формирует сведения для заполнения меты электронного счета на оплату.
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - учетный документ (основание электронного счета на оплату)
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МенеджерИнтеграции.СчетаНаОплату_Метаданные
//
Функция СчетаНаОплату_Метаданные(СсылкаНаОбъект) Экспорт
	
	Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		
		ТекстОшибки = НСтр(
			"ru='Не указан документ-основание для формирования электронного счета на оплату'"
		);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.СчетаНаОплату_Метаданные",
			УровеньЖурналаРегистрации.Ошибка, , ,
			ТекстОшибки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		
		ТекстОшибки = НСтр(
