Функция Новый_ОрганизацияСервиса(Organization)
	
	Данные = МодельОрганизацияСервиса();
	Данные.Идентификатор = НРег(Organization.OrgId);
	Данные.ИНН = Organization.Inn;
	Данные.КПП = СвойствоСтруктуры(Organization, "Kpp", "");
	Данные.ОГРН = СвойствоСтруктуры(Organization, "Ogrn", "");
	Данные.НаименованиеПолное = Organization.FullName;
	Данные.Наименование = СвойствоСтруктуры(Organization, "ShortName", "");
	Данные.ИдентификаторУчастникаЭДО = СвойствоСтруктуры(Organization, "FnsParticipantId", "");
	Данные.Тестовая = Organization.IsTest;
	Данные.Реальная = Не Organization.IsTest;
	Данные.Роуминговая = Organization.IsRoaming;
	
	Если Не ЗначениеЗаполнено(Данные.Наименование) Тогда
		Данные.Наименование = Данные.НаименованиеПолное;
	КонецЕсли;
	
	Результат = Новый ФиксированнаяСтруктура(Данные);
	
	Возврат Результат;
	
