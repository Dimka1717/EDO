// РАБОТА С ФАЙЛАМИ С ДИСКА ДЛЯ ПАКЕТОВ

Процедура Пакеты_ДокументыСДискаПоместитьВКэш(ДокументыСДиска, КлючиПакетов) Экспорт
	
	КлючКэша = КлючКэшаПакетыСДокументамиСДиска();
	КлючиВКэшеДокументовСДиска = ПоместитьВКэшДокументыСДиска(ДокументыСДиска);
	КэшированныеДанные = Кэш_Прочитать(КлючКэша);
	
	Если НЕ ЗначениеЗаполнено(КэшированныеДанные) Тогда
		КэшированныеДанные = Новый Соответствие;
	КонецЕсли;
	
	Для Каждого КлючПакета Из КлючиПакетов Цикл
		
		ДокументыПакета = КэшированныеДанные.Получить(КлючПакета);
		
		Если ДокументыПакета = Неопределено Тогда
			ДокументыПакета = Общее_СкопироватьМассив(КлючиВКэшеДокументовСДиска);
		Иначе
			ДополнитьМассив(ДокументыПакета, КлючиВКэшеДокументовСДиска);
		КонецЕсли;
		
		КэшированныеДанные.Вставить(КлючПакета, ДокументыПакета);
		
	КонецЦикла;
	
	Кэш_Поместить(КлючКэша, КэшированныеДанные);
	
КонецПроцедуры

Функция Пакеты_ДокументыСДискаПрочитатьИзКэша(КлючПакета) Экспорт
	
	Результат = Новый Массив;
	
	КлючКэша = КлючКэшаПакетыСДокументамиСДиска();
	
	ПакетыСДокументамиСДиска = Кэш_Прочитать(КлючКэша);
	
	Если ЗначениеЗаполнено(ПакетыСДокументамиСДиска) Тогда
		
		КлючиВКэшеДокументовСДиска = ПакетыСДокументамиСДиска.Получить(КлючПакета);
		
		Если ЗначениеЗаполнено(КлючиВКэшеДокументовСДиска) Тогда
			Результат = ДокументыСДискаПрочитатьИзКэша(КлючиВКэшеДокументовСДиска);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ДокументыСДискаУдалитьИзКэша() Экспорт
	
	КлючКэша = КлючКэшаДокументыСДиска();
	Кэш_Поместить(КлючКэша, Неопределено);
	
	КлючКэша = КлючКэшаПакетыСДокументамиСДиска();
	Кэш_Поместить(КлючКэша, Неопределено);
	
КонецПроцедуры

Функция ПоместитьВКэшДокументыСДиска(ДокументыСДиска)
	
	Результат = Новый Массив;
	
	КлючКэша = КлючКэшаДокументыСДиска();
	КэшированныеДокументыСДиска = Кэш_Прочитать(КлючКэша);
	
	Если КэшированныеДокументыСДиска = Неопределено Тогда
		КэшированныеДокументыСДиска = Новый Соответствие;
	КонецЕсли;
	
	Для Каждого ДокументСДиска Из ДокументыСДиска Цикл
		
		КлючДокументаСДиска = ДокументСДиска.Ключ;
		
		КэшированныеДокументыСДиска.Вставить(КлючДокументаСДиска, ДокументСДиска);
		
		Результат.Добавить(КлючДокументаСДиска);
		
	КонецЦикла;
	
	Кэш_Поместить(КлючКэша, КэшированныеДокументыСДиска);
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыСДискаПрочитатьИзКэша(КлючиДокументов)
	
	Результат = Новый Массив;
	
	КлючКэша = КлючКэшаДокументыСДиска();
	КэшированныеДокументы = Кэш_Прочитать(КлючКэша);
	
	Если КэшированныеДокументы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого КлючДокумента Из КлючиДокументов Цикл
		
		КэшированныйДокумент = КэшированныеДокументы.Получить(КлючДокумента);
		
		Если ЗначениеЗаполнено(КэшированныйДокумент) Тогда
			Результат.Добавить(КэшированныйДокумент);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КлючКэшаДокументыСДиска()
	Возврат "ХранилищеДокументовСДиска";
КонецФункции

Функция КлючКэшаПакетыСДокументамиСДиска()
	Возврат "ХранилищеПакетовСДокументамиСДиска";
КонецФункции

