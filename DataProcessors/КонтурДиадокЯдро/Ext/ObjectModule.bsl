Функция ПараметрыСервиса_Диадок(Знач BoxId = Неопределено, Знач ИспользоватьСлужебнуюУчетнуюЗапись = Ложь) Экспорт
	
	Ошибка = "";
	
	Если ИспользоватьСлужебнуюУчетнуюЗапись Тогда
		
		Сессия = КонтекстСеанса_ТокенДоступа("");
		Если Не ЗначениеЗаполнено(Сессия) Тогда
			Ошибка = "Сессия не найдена (служебная учетная запись)";
		КонецЕсли;
		
	ИначеЕсли BoxId <> Неопределено Тогда
		
		Сессия = КонтекстСеанса_ТокенДоступа(BoxId);
		Если Не ЗначениеЗаполнено(Сессия) Тогда
			Ошибка = "Сессия не найдена (BoxID = [" + АдресЯщикаВИдентификатор(BoxId) + "])";
		КонецЕсли;
		
	Иначе
		
		Сессия = МодельСессияПользователя();
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	Результат = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыСервиса_Контур(BoxId = Неопределено, ИспользоватьСлужебнуюУчетнуюЗапись = Ложь) Экспорт
	
	Если ИспользоватьСлужебнуюУчетнуюЗапись Тогда
		Сессия = КонтекстСеанса_ТокенДоступа("");
	ИначеЕсли BoxId <> Неопределено Тогда
		Сессия = КонтекстСеанса_ТокенДоступа(BoxId);
	Иначе
		Сессия = МодельСессияПользователя();
	КонецЕсли;
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресKonturAPI");
	Результат = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	
	Возврат Результат;
	
КонецФункции

Функция НастройкиКлиентаAPI(АдресСервиса, ТокенДоступа, ТипТокена)
	
	URL_Структура = URL_Структура(АдресСервиса);
	
	Результат = ПараметрыСервиса();
	Результат.АдресВебСервиса = URL_Структура.Хост;
	Результат.Схема = URL_Структура.Схема;
	Результат.Порт = URL_Структура.Порт;
	Результат.ИспользоватьПротоколOIDC = (ТипТокена = ТипТокенаПортал());
	Результат.Токен = ТокенДоступа;
	
	Если Не Результат.ИспользоватьПротоколOIDC Тогда
		Результат.КлючРазработчика = ОбщийКонтекст_Прочитать("КлючРазработчика");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыСервиса_СервисОбновлений()
	
	АдресСервиса = АдресСервисаОбновлений();
	URL_Структура = URL_Структура(АдресСервиса);
	
	Результат = ПараметрыСервиса();
	Результат.Схема = URL_Структура.Схема;
	Результат.АдресВебСервиса = URL_Структура.Хост;
	Результат.Порт = URL_Структура.Порт;
	
	Возврат Результат;
	
КонецФункции

