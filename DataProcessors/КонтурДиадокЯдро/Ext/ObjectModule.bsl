// Возвращает коллекцию макетов необходимых для запуска фонового задания
//
// Возвращаемое значение:
//  Структура - содержит элементы, в которых:
//     * Ключ - Строка - имя макета
//     * Значение - ДвоичныеДанные, Строка - данные макета или путь к файлу с его данными
//
Функция Макеты_ДляФоновогоЗадания()
	
	Результат = Новый Структура;
	
	Если ЭтоВнешняяОбработка() Тогда
		
		Результат.Вставить("КонтурДиадокПечатныеФормы", Макеты_ДанныеМакета("КонтурДиадокПечатныеФормы"));
		Результат.Вставить("КонтурДиадокВнешниеСервисы", Макеты_ДанныеМакета("КонтурДиадокВнешниеСервисы"));
		Результат.Вставить("КонтурДиадокВызовыПМ", Макеты_ДанныеМакета("КонтурДиадокВызовыПМ"));
		Результат.Вставить("КонтурДиадокМетодыAPI", Макеты_ДанныеМакета("КонтурДиадокМетодыAPI"));
		Результат.Вставить("КонтурДиадокГенерацияXML", Макеты_ДанныеМакета("КонтурДиадокГенерацияXML"));
		Результат.Вставить("КонтурДиадокПарсерJSON", Макеты_ДанныеМакета("КонтурДиадокПарсерJSON"));
		Результат.Вставить("КонтурДиадокХранениеДанных", Макеты_ДанныеМакета("КонтурДиадокХранениеДанных"));
		Результат.Вставить("КонтурДиадокПлагин1С", Макеты_ДанныеМакета("КонтурДиадокПлагин1С"));
		Результат.Вставить("КонтурДиадокЭмуляторТабДокумента", Макеты_ДанныеМакета("КонтурДиадокЭмуляторТабДокумента"));
		Результат.Вставить("КонтурДиадокПлагины", Макеты_ДанныеМакета("КонтурДиадокПлагины"));
		Результат.Вставить("КонтурДиадокРаботаСЛогистикой", Макеты_ДанныеМакета("КонтурДиадокРаботаСЛогистикой"));
		Результат.Вставить("КонтурДиадокРаботаСМаркировкой", Макеты_ДанныеМакета("КонтурДиадокРаботаСМаркировкой"));
		Результат.Вставить("КонтурДиадокМетрики", Макеты_ДанныеМакета("КонтурДиадокМетрики"));
		
		Зависимости = ОбщийКонтекст_Прочитать("__Зависимости");
		Для Каждого Зависимость Из Зависимости Цикл
			Результат.Вставить(Зависимость.Имя, Макеты_ДанныеМакета(Зависимость.Имя));
		КонецЦикла;
		
	КонецЕсли;
	
	ИмяМакетаИнтеграционногоМодуля = ИнтеграционныйМодуль_ПолучитьИмяМакета();
	ИмяМакетаТиповогоМодуля = ИмяТиповогоМодуля();
	
	МакетИнтеграционногоМодуля = Макеты_ДанныеМакета(ИмяМакетаИнтеграционногоМодуля);
	МакетТиповойМодуль = Макеты_ДанныеМакета(ИмяМакетаТиповогоМодуля);
	МенеджерИнтеграции = Макеты_ДанныеМакета("КонтурДиадокМенеджерИнтеграции");
	
	Если ЗначениеЗаполнено(ИмяМакетаИнтеграционногоМодуля) Тогда
		
		Результат.Вставить(ИмяМакетаИнтеграционногоМодуля, МакетИнтеграционногоМодуля);
		
	КонецЕсли;

	Результат.Вставить(ИмяМакетаТиповогоМодуля, МакетТиповойМодуль);
	Результат.Вставить("КонтурДиадокМенеджерИнтеграции", МенеджерИнтеграции);
	
	Возврат Результат;
	
КонецФункции

