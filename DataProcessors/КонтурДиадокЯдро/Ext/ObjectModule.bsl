	ИначеЕсли ТипКонтента = ТипыКонтента.act Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_Акт_172(ПротоКонтентXDTO, ФайлТитулаПродавца, ПараметрыФормированияФайла);
		
	ИначеЕсли ТипКонтента = ТипыКонтента.tovtorg Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_Торг_551(ПротоКонтентXDTO, ФайлТитулаПродавца, ФайлПодписиПродавца, ПараметрыФормированияФайла);
		
	ИначеЕсли ТипКонтента = ТипыКонтента.torg12 Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_Торг_172(ПротоКонтентXDTO, ФайлТитулаПродавца, ПараметрыФормированияФайла);
		
	ИначеЕсли ТипКонтента = ТипыКонтента.torg2 Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_Торг2(ПротоКонтентXDTO, ФайлТитулаПродавца, ФайлПодписиПродавца, ПараметрыФормированияФайла);
		
