// Получает файл подключаемого модуля. Вызывает исключение, если файл ПМ получить нельзя.
//
// Параметры:
//  ТехИнфоПМ - ФиксированнаяСтруктура - см. ТехИнфо_ПодключаемыйМодуль
// 
// Возвращаемое значение:
//  ДвоичныеДанные - файл ПМ.
//
Функция ФайлПодключаемогоМодуля(Знач ТехИнфоПМ) Экспорт
	
	РасположениеПМ = ТехИнфоПМ.Расположение;
	
	Если РасположениеПМ = ВариантРасположенияОбработкиСправочник() Тогда
		
		Путь = ТехИнфоПМ.Путь;
		
		Ключ1 = "e1cib/data/";
		ДлинаКлюча1 = СтрДлина(Ключ1);
		ПозицияКлюча1 = Найти(Путь, Ключ1);
		
		Ключ2 = "?ref=";
		ДлинаКлюча2 = СтрДлина(Ключ2);
		ПозицияКлюча2 = Найти(Путь, Ключ2);
		
		Если ПозицияКлюча1 = 0 
			Или ПозицияКлюча2 = 0 
			Или ПозицияКлюча1 > ПозицияКлюча2 Тогда
			Ошибка = Общее_ПодставитьПараметрыВСтроку("Неожиданный формат навигационной ссылки (%1)", Путь);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		ПолноеИмяМетаданных = Сред(Путь, ПозицияКлюча1 + ДлинаКлюча1, ПозицияКлюча2 - ПозицияКлюча1 - ДлинаКлюча1);
		ИдентификаторСсылки = Сред(Путь, ПозицияКлюча2 + ДлинаКлюча2);
		
		ПустаяСсылка = ПредопределенноеЗначение(ПолноеИмяМетаданных + ".ПустаяСсылка");
		ШаблонЗначения = ЗначениеВСтрокуВнутр(ПустаяСсылка);
		ПустойИдентификатор = СтрЗаменить(ПустойИдентификатор(), "-", "");
		
		ВнутреннееПредставлениеСсылки = СтрЗаменить(ШаблонЗначения, ПустойИдентификатор, ИдентификаторСсылки);
		Ссылка = ЗначениеИзСтрокиВнутр(ВнутреннееПредставлениеСсылки);
		
		Результат = Обработка_ДвоичныеДанныеВнешнейОбработки(Ссылка);
		
	ИначеЕсли РасположениеПМ = ВариантРасположенияОбработкиФайл() Тогда
		
		Файл = Новый Файл(ТехИнфоПМ.Путь);
		
		Если Не Файл.Существует() Тогда
			Ошибка = Общее_ПодставитьПараметрыВСтроку("Файл не существует или к нему нет доступа (%1)", Файл.ПолноеИмя);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		Если Не Файл.ЭтоФайл() Тогда
			Ошибка = Общее_ПодставитьПараметрыВСтроку("Указанный объект не является файлом (%1)", Файл.ПолноеИмя);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		Результат = Новый ДвоичныеДанные(Файл.ПолноеИмя);
		
	ИначеЕсли РасположениеПМ = ВариантРасположенияОбработкиКонфигурация() Тогда
		
		Ошибка = "Невозможно получить файл подключаемого модуля, т.к. он встроен в конфигурацию";
		ВызватьИсключение Ошибка;
		
	Иначе
		Ошибка = Общее_ПодставитьПараметрыВСтроку("Неожиданное расположение подключаемого модуля (%1)", РасположениеПМ);
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует представление подключаемого модуля
//
// Параметры:
//	Настройки - Структура - Структура настроек
//
// Возвращаемое значение:
// Строка
//
Функция ПредставлениеПодключаемогоМодуля(Настройки) Экспорт
	
	Результат = "";
	
	Если Настройки.ИспользоватьПодключаемыйМодуль Тогда
		
		Если Настройки.МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиСправочник() Тогда
			
			ПодключаемыйМодульСсылка = Настройки.ПодключаемыйМодульСсылка;
			
			Если ПодключаемыйМодульСсылка = Неопределено Тогда 
				ИмяСправочникаИОбработки = " не удалось определить";
			Иначе
				
				СинонимСправочника			= ПодключаемыйМодульСсылка.Метаданные().Синоним;
				ИмяОбработкиВСправочнике	= ПодключаемыйМодульСсылка.Наименование;
				
				ИмяСправочникаИОбработки = СинонимСправочника + """: " + ИмяОбработкиВСправочнике;
				
			КонецЕсли;
			
			Результат = "в справочнике: """	+ ИмяСправочникаИОбработки;
		
		ИначеЕсли Настройки.МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиФайл() Тогда
			Результат = "на диске: " + Настройки.ПодключаемыйМодульПуть;
		Иначе	
			Результат = "в конфигурации: " + Настройки.ПодключаемыйМодульИмяОбработки;
		КонецЕсли;
		
	Иначе
		Результат = ": отсутствует";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

