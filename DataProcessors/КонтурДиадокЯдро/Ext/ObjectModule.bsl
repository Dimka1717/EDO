	Возврат "Log";
КонецФункции

Функция ТопикиМетрики_Health()
	Возврат "Health";
КонецФункции

Функция ТопикиМетрики_ПродуктоваяАналитика()
	Возврат "ProductAnalytics";
КонецФункции

Функция ВерсияВСемантикДляМетрики(Версия)
	
	Результат = "";

	Если Не ЗначениеЗаполнено(Версия) Тогда
		Результат = "0.0.0";
	Иначе
		
		МассивРазрядов = РазделитьСтрокуЛок(СокрЛП(Версия), "./");
		
		Для Сч = 1 По 3 - МассивРазрядов.Количество() Цикл
			МассивРазрядов.Добавить("0");
		КонецЦикла;
		
		ТекРазряд	 = "";
		Разделитель	 = "";
		
		Для Сч = 1 По МассивРазрядов.Количество() Цикл
			
			Разряд = СокрЛП(МассивРазрядов[Сч - 1]);
			
			Если Сч < 4 Тогда
				ТекРазряд = ?(ВСтрокеТолькоЦифры(Разряд), Разряд, "0");
			Иначе
				ТекРазряд = СтрЗаменить(Разряд, " ", "");
			КонецЕсли;
			
			Результат = Результат + Разделитель + ТекРазряд;
			
			Если Сч < 3 Тогда
				Разделитель = ".";
			ИначеЕсли Сч = 3 Тогда
				Разделитель = "-";
			Иначе
				Разделитель = "";
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СтекСобытийМетрики()
	
	Результат = Кэш_Прочитать("СтекСобытийМетрики");
	
	Если Результат = Неопределено Тогда
		
		Результат = НовыйСтекСобытийМетрики();
		
		Кэш_Поместить("СтекСобытийМетрики", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ОчиститьСтекСобытийМетрики()
	
	СтекСобытий = СтекСобытийМетрики();
	
	Для Каждого Элемент Из СтекСобытий.Топики Цикл
		
		МассивСобытий = Элемент.Значение;
		
		МассивСобытий.Очистить();
		
	КонецЦикла;
	
	СтекСобытий.РазмерСтека = 0;
	
КонецПроцедуры

Функция ОписаниеПеременныхДляМетрики(Переменные)
	
	Результат = Новый Соответствие;
	
	Для Каждого Элемент Из Переменные Цикл
		
		Если ЗначениеЗаполнено(Элемент.Значение) Тогда
			
			ОписаниеЗначения = ОписаниеЗначенияДляМетрики(Элемент.Значение);
			
			Результат.Вставить(Элемент.Ключ, ОписаниеЗначения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеЗначенияДляМетрики(Значение)
	
	ТипЗначения = ТипЗнч(Значение);
	
	Результат = Новый Структура("value, type");
	
	Если ТипЗначения = Тип("Число") Тогда
		
		Результат.type	 = "number";
		Результат.value	 = XMLСтрока(Значение);
		
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		
		Результат.type	 = "string";
		Результат.value	 = Значение;
		
	ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		
		Результат.type	 = "uuid";
		Результат.value	 = XMLСтрока(Значение);
		
	ИначеЕсли ТипЗначения = Тип("ДвоичныеДанные") Тогда
		
		Результат.type	 = "base64";
		Результат.value	 = Base64Строка(Значение);
		
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		
		Результат.type	 = "string";
		Результат.value	 = Формат(Значение, "БЛ=False; БИ=True");
		
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		
		Результат.type	 = "string";
		Результат.value	 = XMLСтрока(Значение);
		
	Иначе
		
		Попытка
			
			ПарсерJSON_Записать(Значение);
			Результат.value = Значение;
			Результат.type= "json";
			
		Исключение
			Результат.value = "convert_error";
			Результат.type	= "string";
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Адрес, на который надо отправлять данные
//  для фиксации событий в сервисе Контур.Метрика.
//
// Параметры:
//  Топик - Строка - Имя топика метрики
// 
// Возвращаемое значение:
//  Строка - адрес метода
//
Функция АдресМетодаМетрики(Знач Топик)
	
	Если ЭтоМетрикаДиадок(Топик) Тогда
		Топик = "DD_" + Топик;
	КонецЕсли;
	
	Результат = Общее_ПодставитьПараметрыВСтроку("/metrika-pipe/v1/sources/1CModule/topics/%1/events", Топик);
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоМетрикаДиадок(Топик)
	
	Результат = (Топик <> МетрикиКонтурСлужебный_CommonStatistics());
	
	Возврат Результат;
	
КонецФункции

Функция Метрика_НазваниеДействияМаршрутизации(Действие) Экспорт
	
	ДействияЭДО = Перечисление_ДействияЭДО();
	ВозможныеДействияМетрики = Метрика_НазваниеДействий();
	
	Если Действие = ДействияЭДО.ПередатьНаСогласование Тогда
		Результат = ВозможныеДействияМетрики.ПередатьНаСогласование;
	ИначеЕсли Действие = ДействияЭДО.ПередатьНаПодпись Тогда
		Результат = ВозможныеДействияМетрики.ПередатьНаПодпись;
	ИначеЕсли Действие = ДействияЭДО.ПередатьПоМаршруту Тогда
		Результат = ВозможныеДействияМетрики.ПередатьПоМаршруту;
	ИначеЕсли Действие = ДействияЭДО.Согласование Тогда
		Результат = ВозможныеДействияМетрики.Согласовать;
	ИначеЕсли Действие = ДействияЭДО.ОтказВСогласовании Тогда
		Результат = ВозможныеДействияМетрики.ОтказатьВСогласовании;
	ИначеЕсли Действие = ДействияЭДО.ОтказВЗапросеПодписи Тогда
		Результат = ВозможныеДействияМетрики.ОтказВЗапросеПодписи;
	Иначе
		Результат = ВозможныеДействияМетрики.not_defined;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Метрика_НазваниеДействияОтветныеДействия(Действие)
	
	ВариантыОтвета = Перечисление_ВариантыОтветаПоДокументу();
	ВозможныеДействияМетрики = Метрика_НазваниеДействий();
	
	Если Действие = ВариантыОтвета.Подписать Тогда
		Результат = ВозможныеДействияМетрики.Подписать;
	ИначеЕсли Действие = ВариантыОтвета.ОтказатьВПодписи Тогда
		Результат = ВозможныеДействияМетрики.ОтказатьВПодписи;
	ИначеЕсли Действие = ВариантыОтвета.ЗапроситьУточнение Тогда
		Результат = ВозможныеДействияМетрики.ЗапроситьУточнение;
	ИначеЕсли Действие = ВариантыОтвета.Аннулировать Тогда
		Результат = ВозможныеДействияМетрики.Аннулировать;
	ИначеЕсли Действие = ВариантыОтвета.ОтказатьВАннулировании Тогда
		Результат = ВозможныеДействияМетрики.ОтказатьВАннулировании;
	ИначеЕсли Действие = ВариантыОтвета.ПодписатьПромежуточнойПодписью Тогда
		Результат = ВозможныеДействияМетрики.ПодписатьПромежуточнойПодписью;
	Иначе
		Результат = ВозможныеДействияМетрики.not_defined;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Список возможных категорий для записи метрик
