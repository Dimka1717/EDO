КонецФункции

Функция Лента_СтатусыСобытия(ДанныеСобытия, BoxId)
	
	Перем SenderTitle, Response, Confirmation, Receipt, RecipientReceipt;
	Перем AmendmentRequest, Revocation;
	Перем SenderReceipt;
	
	Результат = Новый_СтатусыДокументооборотаAPI();
	
	Docflow = ДанныеСобытия.Event.Document.Docflow;
	
	// 0. Статусы
	
	Лента_ЗаполнитьСтатусыДО(Результат, Docflow.DocflowStatus);
	
	// 1. Титул отправителя
	
	Если Docflow.Свойство("SenderTitle", SenderTitle) Тогда
		Результат.SenderTitle				= SenderTitle.SenderSignatureStatus;
		Результат.SenderTitle_IsFinished	= SenderTitle.IsFinished;
	КонецЕсли;
	
	// 2. Ответное действие получателя
	
	Если Docflow.Свойство("RecipientResponse", Response) Тогда
		Результат.RecipientResponse				= Response.ResponseStatus;
		Результат.RecipientResponse_IsFinished	= Response.IsFinished;
	КонецЕсли;
	
	// 3. Документооборот УПД (http://api-docs.diadoc.ru/ru/latest/docflows/UtdDocflow.html)
	
	Если Docflow.Свойство("Confirmation", Confirmation) Тогда
		
		// Извещение о получении Подтверждения оператора
		Если Confirmation.Свойство("Receipt", Receipt) Тогда
			Результат.ConfirmationReceipt				= Receipt.Status;
			Результат.ConfirmationReceipt_IsFinished	= Receipt.IsFinished;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Docflow.Свойство("RecipientReceipt", RecipientReceipt) Тогда
		
		// Извещение о получении документа
		Результат.RecipientReceipt				= RecipientReceipt.Status;
		Результат.RecipientReceipt_IsFinished	= RecipientReceipt.IsFinished;
		
		Если RecipientReceipt.Свойство("Confirmation", Confirmation) Тогда
			
			// Извещение о получении Подтверждения оператора
			Если Confirmation.Свойство("Receipt", Receipt) Тогда
				Результат.RecipientReceiptConfirmation				= Receipt.Status;
				Результат.RecipientReceiptConfirmation_IsFinished	= Receipt.IsFinished;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Извещение о получении титула получателя
	Если Docflow.Свойство("SenderReceipt", SenderReceipt) Тогда
		
		// Извещение о получении документа
		Результат.SenderReceipt				= SenderReceipt.Status;
		Результат.SenderReceipt_IsFinished	= SenderReceipt.IsFinished;
		
	КонецЕсли;
	
	// 4. Уточнение
	
	Если Docflow.Свойство("AmendmentRequest", AmendmentRequest) Тогда
		
		Результат.Amendment				= AmendmentRequest.AmendmentFlags;
		Результат.Amendment_IsFinished	= AmendmentRequest.IsFinished;
		
		Если AmendmentRequest.Свойство("Receipt", Receipt) Тогда
			Результат.AmendmentReceipt				= Receipt.Status;
			Результат.AmendmentReceipt_IsFinished	= Receipt.IsFinished;
		КонецЕсли;
		
	КонецЕсли;
	
	// 5. Аннулирование
	
	Если Docflow.Свойство("Revocation", Revocation) Тогда
		Результат.Revocation			= Revocation.RevocationStatus;
		Результат.Revocation_IsFinished	= Revocation.IsFinished;
	КонецЕсли;
	
	// 6. Ответное действие промежуточного получателя
	
	RecipientBoxId = ДанныеСобытия.Event.Document.DocumentInfo.Participants.Recipient.BoxId;
	
	Если Docflow.Свойство("ProxyResponse", Response) И RecipientBoxId <> BoxId Тогда
		Результат.ProxyResponse				= Response.ResponseStatus;
		Результат.ProxyResponse_IsFinished	= Response.IsFinished;
	КонецЕсли;
	
	// 7. Статус доставки в роуминг
	
	Если SenderTitle <> Неопределено И SenderTitle.Свойство("RoamingNotification") Тогда
		
		УспешнаяДоставка = СвойствоСтруктуры(SenderTitle.RoamingNotification, "Success", Ложь)
					   ИЛИ СвойствоСтруктуры(SenderTitle.RoamingNotification, "IsSuccess", Ложь);
		
		Если НЕ УспешнаяДоставка Тогда
			Результат.RoamingNotification = "RoamingNotificationStatusError";
		КонецЕсли;
		
	КонецЕсли;
	
	// 8. Статус согласования документа/аннулировании
	
	Лента_СтатусыСобытия_СогласованиеАннулирование(Docflow, Результат);
	
	Возврат Результат;
	
КонецФункции

Процедура Лента_СтатусыСобытия_СогласованиеАннулирование(Docflow, Результат)
	
	Resolution = Неопределено;
	
	Если Docflow.Свойство("Resolution", Resolution) Тогда
		
		Результат.Resolution			= Resolution.ResolutionStatus;
		Результат.Resolution_IsFinished	= Resolution.IsFinished;
		
		Если Resolution.IsFinished Тогда
			Возврат;
		КонецЕсли;
		
		// Объект маршрутизации (подразделение или сотрудник)
		Лента_СтатусыСобытия_ОбъектМаршрутизации(Docflow, Результат);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Лента_СтатусыСобытия_ОбъектМаршрутизации(Docflow, Результат)
	
	ResolutionEntities = Неопределено;
	Requests = Неопределено;
	
	Если Docflow.Свойство("ResolutionEntities", ResolutionEntities) Тогда
		
		Если ResolutionEntities.Свойство("Requests", Requests) 
			И ЗначениеЗаполнено(Requests) Тогда
			СтрокаЗапроса = Requests[Requests.ВГраница()];
			СтрокаЗапроса.Свойство("Target", Результат.ResolutionTarget);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Лента_ПараметрыДанныхДО(AttachmentSignature)
	
	Результат = Новый Структура("Attachment, Signature");
	
	AttachmentSignature.Свойство("Attachment", Результат.Attachment);
	AttachmentSignature.Свойство("Signature", Результат.Signature);
	
	Возврат Результат;
	
КонецФункции

Функция Лента_ПараметрыХранилищДокумента(Идентификаторы, КонтентДО, ДанныеДокумента, ТребуетсяРасшифровка)
	
	Перем Attachment, Signature;
	
	Результат = Новый Структура;
	
	BoxId 		= Идентификаторы.BoxId;
	LetterId 	= Идентификаторы.LetterId;
	
	ПараметрыСервиса = Лента_ПараметрыСервиса(boxId);
	ХранилищаДокумента = ХранениеДанных_ОписаниеДанныхХранилища(Идентификаторы);
	
	Для Каждого ТекущийДО Из КонтентДО Цикл
		
		ИмяХранилища = ТекущийДО.Ключ;
		
		Attachment = ТекущийДО.Значение.Attachment;
		EntityAttachment = Attachment.Entity;
		
		Signature = ТекущийДО.Значение.Signature;
		EntitySignature = ?(Signature = Неопределено, Неопределено, Signature.Cms);
		
		ДатаСоздания = Ticks_2_Date(EntityAttachment.CreationTimestamp.Ticks);
		
		Если ХранилищаДокумента.Свойство(ИмяХранилища) Тогда
			ОписаниеХранилища = ХранилищаДокумента[ИмяХранилища];
		Иначе
			ОписаниеХранилища = Новый Структура("ДанныеЗагружены, ПодписьЗагружена, Id, ДатаСоздания", Ложь, Ложь);
		КонецЕсли;
		
		ОтдельноеХранениеДанных	= (ИмяХранилища = "ПодписьПокупателя"
								ИЛИ Лев(ИмяХранилища, 20) = "ПодписьАннулирования" 
								ИЛИ ИмяХранилища = "ПодписьПромежуточногоПолучателя");
		ПолучитьДанные			= (НЕ ОписаниеХранилища.ДанныеЗагружены И НЕ ОтдельноеХранениеДанных);
		ОбновитьEntityId 		= (EntityAttachment.EntityId <> ОписаниеХранилища.Id И НЕ ОтдельноеХранениеДанных);
		ПолучитьПодпись			= (EntitySignature <> Неопределено И НЕ ОписаниеХранилища.ПодписьЗагружена);
		ОбновитьДатуСоздания	= (ИмяХранилища = "ХранилищеКонтента" И ОписаниеХранилища.ДатаСоздания <> ДатаСоздания);
		
		Если ИмяХранилища = "ХранилищеКонтента" И ПолучитьПодпись И Не ПолучитьДанные Тогда
			
			Документ = ХранениеДанных_ДанныеДокумента(Идентификаторы);
			
			Если ЗначениеЗаполнено(Документ.ПараметрыШаблона.EditingSettingId) Тогда
				ПолучитьДанные = Истина; // Нужно скачать финальную версию документа
			КонецЕсли;
			
		КонецЕсли;
		
		Если ПолучитьДанные
			ИЛИ ПолучитьПодпись
			ИЛИ ОбновитьДатуСоздания
			ИЛИ ОбновитьEntityId Тогда
			
			ХранилищеДанных = Контракт_ДанныеХранения();
			
			Если ПолучитьДанные Тогда
				
				Если ИмяХранилища = "ХранилищеКонтента" И ДанныеДокумента <> Неопределено Тогда
					Данные = ДанныеДокумента;
				Иначе
					Данные = АПИ_GetEntityContent(ПараметрыСервиса, BoxId, LetterId, EntityAttachment.EntityId);
				КонецЕсли;
				
				Если ИмяХранилища = "ХранилищеКонтента" И ТребуетсяРасшифровка Тогда
					ХранилищеДанных.ЗашифрованныеДанные	= Данные;
				Иначе
					ХранилищеДанных.Данные = Данные;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ПолучитьПодпись Тогда			
				
				ДанныеПодписи = АПИ_GetEntityContent(ПараметрыСервиса, BoxId, LetterId, EntitySignature.EntityId);
				
				Если ЗначениеЗаполнено(ДанныеПодписи) Тогда
					ХранилищеДанных.Подпись.ДанныеПодписи	= ДанныеПодписи;
					ХранилищеДанных.Подпись.ДатаПодписи		= Ticks_2_Date(EntitySignature.CreationTimestamp.Ticks);
					ХранилищеДанных.Подпись.ПодписьВерна	= Signature.IsValid;
				КонецЕсли;
				
			КонецЕсли;
			
			ХранилищеДанных.ДатаСоздания	= ДатаСоздания;
			ХранилищеДанных.Описание		= EntityAttachment.EntityId;
			ХранилищеДанных.Размер			= EntityAttachment.Content.Size;
			
			Если ИмяХранилища = "ХранилищеКонтента" И ТребуетсяРасшифровка Тогда
				ХранилищеДанных.ТребуетсяРасшифровка = ТребуетсяРасшифровка;
			КонецЕсли;
			
			Если Attachment.Свойство("AttachmentFilename") Тогда	
				ХранилищеДанных.ИмяФайла = Attachment.AttachmentFilename;
			ИначеЕсли Attachment.Свойство("DisplayFilename") Тогда	
				ХранилищеДанных.ИмяФайла = Attachment.DisplayFilename;
			КонецЕсли;
			
			Результат.Вставить(ИмяХранилища, ХранилищеДанных);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Лента_ЗаписатьДанныеХранилищДокумента(Идентификаторы, ПараметрыХранилищДокумента)

	// При повторном предложении об аннулировании, необходимо пометить предыдущее с его отказом.
	Если ПараметрыХранилищДокумента.Свойство("ПредложениеОбАннулированииПродавца") 
		ИЛИ ПараметрыХранилищДокумента.Свойство("ПредложениеОбАннулированииПокупателя") Тогда
		
		ХранениеДанных_ПометитьНедействительныеДанныеХранилища(Идентификаторы, "ПредложениеОбАннулированииПокупателя");
		ХранениеДанных_ПометитьНедействительныеДанныеХранилища(Идентификаторы, "ПредложениеОбАннулированииПродавца");
		ХранениеДанных_ПометитьНедействительныеДанныеХранилища(Идентификаторы, "ОтказВПодписанииАннулированияПокупателя");
		ХранениеДанных_ПометитьНедействительныеДанныеХранилища(Идентификаторы, "ОтказВПодписанииАннулированияПродавца");
		
	КонецЕсли;
	
	Для Каждого ТекХранилище Из ПараметрыХранилищДокумента Цикл
		
		ИмяХранилища	= ТекХранилище.Ключ;
		ДанныеХранения	= ТекХранилище.Значение;
		ХранениеДанных_ЗаписатьДанныеХранилища(ДанныеХранения, ИмяХранилища, Идентификаторы.ДокументЭДО);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Лента_ОбновитьДанныеДокумента(ДанныеСобытия, Данные1С, Идентификаторы, BoxId)
	
	DocumentInfo		 = ДанныеСобытия.Event.Document.DocumentInfo;
	DocumentDirection	 = ДанныеСобытия.DocumentDirection;
	
	ИменаОбновляемыхРеквизитов = 
		"DepartmentId, 
		|PacketId, 
		|Статус, 
		|ДополнительныйСтатус, 
		|ТребуетсяОбработка, 
		|ВнешниеСтатусы, 
		|СтатусМЧД, 
		|СтатусМЧДКритичность,
		|СтатусПКФНС, 
		|СтатусПКФНСКритичность,
		|СтатусДТС,
		|ОбъектМаршрутизации,
		|FromDepartmentId,
		|ToDepartmentId";
	
	ЗначенияИзБазы		 = Новый Структура(ИменаОбновляемыхРеквизитов);
	ЗначенияИзСервиса	 = Новый Структура(ИменаОбновляемыхРеквизитов);
	
	ЗаполнитьЗначенияСвойств(ЗначенияИзБазы, Данные1С);
	
	Статусы = Лента_СтатусыДокумента(ДанныеСобытия, BoxId);
	ЗаполнитьЗначенияСвойств(ЗначенияИзСервиса, Статусы);
	
	ЗначенияИзСервиса.DepartmentId = DocumentInfo.DepartmentId;
	ЗначенияИзСервиса.PacketId = СокрЛП(СвойствоСтруктуры(DocumentInfo.PacketInfo, "PacketId", ""));
	ЗначенияИзСервиса.FromDepartmentId = DocumentInfo.Participants.Sender.DepartmentId;
	ЗначенияИзСервиса.ToDepartmentId = DocumentInfo.Participants.Recipient.DepartmentId;
	
	НовыеЗначения = ОтличияСтруктур(ЗначенияИзБазы, ЗначенияИзСервиса);
	
	Если ЗначениеЗаполнено(НовыеЗначения) Тогда
		
		ХранениеДанных_ОбновлениеРеквизитовДокумента(Идентификаторы, НовыеЗначения);
		
		Если НовыеЗначения.Свойство("Статус") Тогда
			Документы_ПослеУстановкиСтатуса(Данные1С.ДокументЭДО, НовыеЗначения.Статус);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Лента_ОбновитьДанныеШаблона(ДанныеСобытия, Идентификаторы)
	
	DocumentInfo = ДанныеСобытия.Event.Document.DocumentInfo;
	
	Документ = ХранениеДанных_ДанныеДокумента(Идентификаторы);
	
	Лента_ЗаполнитьСписокСообщенийСозданныхПоШаблону(Документ, DocumentInfo);
	
	Документ.Статусы.Статус = Документы_СтатусШаблона(DocumentInfo);
	
	ХранениеДанных_ЗаписатьДокумент(Документ);
	
КонецПроцедуры

Процедура Лента_ЗаполнитьДанныеШаблона(Документ, DocumentInfo)
	
	Лента_ЗаполнитьВШаблонеУчастниковЭДО(Документ, DocumentInfo);
	Лента_ЗаполнитьСписокСообщенийСозданныхПоШаблону(Документ, DocumentInfo);
	
	Документ.Шаблон			 = Истина;
	Документ.Статусы.Статус	 = Документы_СтатусШаблона(DocumentInfo);
	
КонецПроцедуры

Процедура Лента_ЗаполнитьВШаблонеУчастниковЭДО(Документ, DocumentInfo)
	
	LetterParticipants		 = DocumentInfo.TemplateInfo.LetterParticipants;
	
	Sender		= СвойствоСтруктуры(LetterParticipants, "Sender");
	Proxy		= СвойствоСтруктуры(LetterParticipants, "Proxy");
	Recipient	= СвойствоСтруктуры(LetterParticipants, "Recipient");
	
	MessageFromBoxId		 = СвойствоСтруктуры(Sender,	"BoxId");
	MessageToBoxId			 = СвойствоСтруктуры(Recipient,	"BoxId");
	MessageToDepartmentId	 = СвойствоСтруктуры(Recipient,	"DepartmentId");
	MessageProxyBoxId		 = СвойствоСтруктуры(Proxy,		"BoxId");
	MessageProxyDepartmentId = СвойствоСтруктуры(Proxy,		"DepartmentId");
	
	Документ.ПараметрыШаблона.MessageFromBoxId	 = АдресЯщикаВИдентификатор(MessageFromBoxId);
	Документ.ПараметрыШаблона.MessageToBoxId	 = АдресЯщикаВИдентификатор(MessageToBoxId);
	
	Если ИдентификаторЗаполнен(MessageToDepartmentId) Тогда
		Документ.ПараметрыШаблона.MessageToDepartmentId = MessageToDepartmentId;
	КонецЕсли;
	
	Если ИдентификаторЗаполнен(MessageProxyBoxId) Тогда
		Документ.ПараметрыШаблона.MessageProxyBoxId = MessageProxyBoxId;
	КонецЕсли;
	
	Если ИдентификаторЗаполнен(MessageProxyDepartmentId) Тогда
		Документ.ПараметрыШаблона.MessageProxyDepartmentId = MessageProxyDepartmentId;
	КонецЕсли;
	
КонецПроцедуры

Процедура Лента_ЗаполнитьСписокСообщенийСозданныхПоШаблону(Документ, DocumentInfo)
	
	Документ.Связи.TransformedToLetterIds.Очистить();
	
	TemplateTransformationInfos = DocumentInfo.TemplateInfo.TemplateTransformationInfos;
	
	Если Не ЗначениеЗаполнено(TemplateTransformationInfos) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого Элемент Из TemplateTransformationInfos Цикл
		
		TransformedToLetterId = СвойствоСтруктуры(Элемент, "TransformedToLetterId");
		
		MessageId	= СвойствоСтруктуры(TransformedToLetterId,	"MessageId");
		EntityId	= СвойствоСтруктуры(TransformedToLetterId,	"EntityId");
		
		Если ЗначениеЗаполнено(MessageId) И ЗначениеЗаполнено(EntityId) Тогда
			
			НовыйЭлемент = Новый Структура;
			НовыйЭлемент.Вставить("MessageId", MessageId);
			НовыйЭлемент.Вставить("EntityId", EntityId);
			
			Документ.Связи.TransformedToLetterIds.Добавить(НовыйЭлемент);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Лента_ПослеОбработкиСобытий(ПараметрыСервиса, ТаблицаДокументов)
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("ПараметрыСервиса",		 ПараметрыСервиса);
	ПараметрыПМ.Вставить("ИдентификаторыДокументов", ТаблицаЗначенийВМассивСтруктур(ТаблицаДокументов));
	
	ПодключаемыйМодуль_ОбработатьСобытие("ПослеОбработкиЛентыСобытий", ПараметрыПМ);
	
КонецПроцедуры

Процедура Лента_ЗаписатьИсториюСобытий(ТаблицаСобытий, НаличиеДанных1С, BoxId)
	
	Для Каждого ДанныеСобытия Из ТаблицаСобытий Цикл
		
		Данные1С = НаличиеДанных1С[ДанныеСобытия.ID];
		
		Если ЗначениеЗаполнено(Данные1С.ДокументЭДО) Тогда
			
			Статусы = Лента_СтатусыДокумента(ДанныеСобытия, BoxId);
			
			Запись = РегистрыСведений.Диадок_СтатусыДокументов.СоздатьМенеджерЗаписи();
			
			Запись.Документ 			= Данные1С.ДокументЭДО;
			Запись.Ticks 				= ДанныеСобытия.Event.Timestamp.Ticks;
			Запись.ДатаСтатуса			= Ticks_2_Date(Запись.Ticks);
			Запись.StatusText			= Статусы.Статус;
			Запись.SecondaryStatusText 	= Статусы.ДополнительныйСтатус;
			Запись.IsFinished			= НЕ Статусы.ТребуетсяОбработка;
			
			Запись.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет основной и дополнительный статусы в структуре СтатусыДокументооборотаAPI
//
// Параметры:
//  СтатусыДокументооборотаAPI - Структура - см. функцию Новый_СтатусыДокументооборотаAPI()
//  DocflowStatusV3 - Структура - информация по текущему статусу
//   * PrimaryStatus - Структура - основной статус (обязательный)
//       ** Severity - Строка - уровень критичности
//       ** StatusText - Строка - текстовое описание статуса
//   * SecondaryStatus - Структура - дополнительный статус (необязательный)
//       ** Severity - Строка - уровень критичности
//       ** StatusText - Строка - текстовое описание статуса
//   * PowerOfAttorneyGeneralStatus - Структура - сводный статус по всем МЧД для всех сущностей документа
//       ** Severity - Строка - уровень критичности
//       ** StatusText - Строка - текстовое описание статуса
//       ** StatusNamedId - Строка - текстовый идентификатор статуса
//
Процедура Лента_ЗаполнитьСтатусыДО(СтатусыДокументооборотаAPI, DocflowStatusV3)
	
	Перем SecondaryStatus, PowerOfAttorneyGeneralStatus, GeneralRoamingSendingStatus;
	
	Если DocflowStatusV3.PrimaryStatus.Свойство("StatusText") Тогда
		СтатусыДокументооборотаAPI.PrimaryStatus = DocflowStatusV3.PrimaryStatus.StatusText;
	КонецЕсли;
	
	Если DocflowStatusV3.Свойство("SecondaryStatus", SecondaryStatus) Тогда
		
		Если SecondaryStatus.Свойство("StatusText") Тогда
			СтатусыДокументооборотаAPI.SecondaryStatus = SecondaryStatus.StatusText;
		КонецЕсли;
		
	КонецЕсли;
	
	Если DocflowStatusV3.Свойство("PowerOfAttorneyGeneralStatus", PowerOfAttorneyGeneralStatus) Тогда
		
		Если PowerOfAttorneyGeneralStatus.Свойство("StatusText") Тогда
			СтатусыДокументооборотаAPI.StatusMCHD = PowerOfAttorneyGeneralStatus.StatusText;
		КонецЕсли;
		
		Если PowerOfAttorneyGeneralStatus.Свойство("Severity") Тогда
			СтатусыДокументооборотаAPI.StatusMCHDSeverity = PowerOfAttorneyGeneralStatus.Severity;
		КонецЕсли;
		
	КонецЕсли; 
	
	Если DocflowStatusV3.Свойство("GeneralRoamingSendingStatus", GeneralRoamingSendingStatus)
		И GeneralRoamingSendingStatus.Свойство("Severity") Тогда
		
		RoamingSeverity = GeneralRoamingSendingStatus.Severity;
		УровниКритичности = Контракт_УровниКритичностиСтатусаДокумента();
		
		Если RoamingSeverity = УровниКритичности.Error Тогда
			
			СтатусыДокументооборотаAPI.StatusMCHDSeverity = RoamingSeverity;
			
			Если GeneralRoamingSendingStatus.Свойство("StatusText") Тогда
				СтатусыДокументооборотаAPI.StatusMCHD = GeneralRoamingSendingStatus.StatusText;
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли; 
	
КонецПроцедуры

