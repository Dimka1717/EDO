Функция Подписант_ПолучитьИзКэша(КлючЗначения)
	
	Перем Результат;
	
	СведенияОПодписантах = Кэш_Прочитать("СведенияОУниверсальныхПодписантах");
	
	Если СведенияОПодписантах <> Неопределено Тогда
		Результат = СведенияОПодписантах.Получить(КлючЗначения);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Подписант_ПоместитьВКэш(КлючЗначения, Значение)

	СведенияОПодписантах = Кэш_Прочитать("СведенияОУниверсальныхПодписантах");
	
	Если СведенияОПодписантах = Неопределено Тогда
		СведенияОПодписантах = Новый Соответствие;
	КонецЕсли;
	
	СведенияОПодписантах.Вставить(КлючЗначения, Значение);
	
	Кэш_Поместить("СведенияОУниверсальныхПодписантах", СведенияОПодписантах);
	
КонецПроцедуры

// Формирует сведения о подписанте (универсальный подписант) для ИоП 
//
// Параметры:
//  BoxId - Строка - адрес ящика организации
// 
// Возвращаемое значение:
//  Строка - строка в формате Base64 (см. АПИ_Новый_SignerContent)
//
Функция Подписант_ЗаполненныйSignerContentДляИоП(BoxId)
	
	КонтрактМЧД = Неопределено;
	
	ДанныеМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(BoxId);
	
	Если ДанныеМЧД.ТребуетсяМЧД И ЗначениеЗаполнено(ДанныеМЧД.МЧД) Тогда
		КонтрактМЧД = ДанныеМЧД.СписокМЧД.Получить(ДанныеМЧД.МЧД);
	КонецЕсли;
	РегНомерМЧД = СвойствоСтруктуры(КонтрактМЧД, "Идентификатор", "");
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	Сертификат = СтрокаКонтекста.Сертификат;
	
	ПередаватьМЧДФайлом = Ложь;

	КлючЗначенияВКэше = Подписант_НовыйКлючЗначенияВКэше("", BoxId, РегНомерМЧД, ПередаватьМЧДФайлом);
		
	Результат = Кэш_Прочитать(КлючЗначенияВКэше);
	
	Если Результат = Неопределено Тогда
		
		ПараметрыФормирования = ГенерацияXML_Новый_ПараметрыФормированияУниверсальногоПодписанта(
			BoxId,
			СтрокаКонтекста.ИНН,
			ПередаватьМЧДФайлом);
			
		SignerContent = ГенерацияXML_УниверсальныйПодписант(СтрокаКонтекста.Сертификат, КонтрактМЧД, ПараметрыФормирования);
		
		Результат = ДвоичныеДанныеBase64ИзXDTO(SignerContent);
		
		Кэш_Поместить(КлючЗначенияВКэше, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_НовыйКлючЗначенияВКэше(ТипКонтента, АдресЯщика, РегНомерМЧД, ПередаватьФайлом)
	
	ЧастиКлюча = Новый Массив;
	ЧастиКлюча.Добавить(ТипКонтента);
	ЧастиКлюча.Добавить(АдресЯщика);
	ЧастиКлюча.Добавить(РегНомерМЧД);
	ЧастиКлюча.Добавить(ПередаватьФайлом);
	
	Результат = СоединитьСтроку(ЧастиКлюча, "");
	
	Возврат Результат;
	
КонецФункции

