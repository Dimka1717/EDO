Функция ИспользоватьПлагины()
	
	Результат = ОбщийКонтекстКлиентСервер.ИспользоватьПлагины;
	Возврат Результат;
	
КонецФункции

// Передает вызов из форм библиотеки плагинов в серверный контекст.
//
// Параметры:
//  ИмяКоманды - Строка - идентификатор служебной команды.
//  ПараметрыКоманды - Структура - параметры служебной команды.
//
Процедура КонтурПлагины_ОбработатьСлужебнуюКоманду(ИмяКоманды, ПараметрыКоманды) Экспорт
	
	Контекст = КонтурПлагины_КонтекстВызова();
	
	МодульКП = Модуль_КонтурПлагины(ЭтотОбъект);
	МодульКП.ОбработатьСлужебнуюКоманду(ИмяКоманды, ПараметрыКоманды, Контекст);

КонецПроцедуры

Процедура КонтурПлагины_ОткрытьФорму(ФормаВладелец) Экспорт
	
	Контекст = КонтурПлагины_КонтекстВызова();
	
	МодульКП = Модуль_КонтурПлагины(ЭтотОбъект);
	МодульКП.ОткрытьОсновнуюФорму(Контекст, ФормаВладелец);
	
КонецПроцедуры

Процедура КонтурПлагины_ЗаписатьОшибкуИнициализацииБиблиотеки()
	
	Ошибка = "Модуль не инициализирован (КонтурПлагины)!";
	Операция = "Диадок.Плагины";
	
	Ошибка_Обработать(Операция, Ошибка);
	
КонецПроцедуры

Процедура КонтурПлагины_ОбработатьСобытие(ИмяСобытия, Параметры, Результат)
	
	Если Не ИспользоватьПлагины() Тогда
		Возврат;
	КонецЕсли;
	
	МодульКП = Модуль_КонтурПлагины(ЭтотОбъект);
	
	Если МодульКП = Неопределено Тогда
		КонтурПлагины_ЗаписатьОшибкуИнициализацииБиблиотеки();
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		ВходящиеПараметры = Параметры;
	Иначе
		ВходящиеПараметры = Новый Структура;
		ВходящиеПараметры.Вставить("ДанныеДляОбработки", Параметры);
	КонецЕсли;
	
	ВходящиеПараметры.Вставить("РезультатОбработки", Результат);
	
	Контекст = КонтурПлагины_КонтекстВызова();
	МодульКП.ОбработатьСобытие(ИмяСобытия, ВходящиеПараметры, Контекст);
	
	ВходящиеПараметры.Свойство("РезультатОбработки", Результат);
	
КонецПроцедуры

Функция КонтурПлагины_КонтекстВызова()
	
	Результат = Новый Структура;
	Результат.Вставить("ВызывающийМодуль", Модуль_ВызовыПМ(ЭтотОбъект));
	Результат.Вставить("РежимОтладки", РежимОтладкиВключен());
	Результат.Вставить("КаталогОтладки", КонтурПлагины_КаталогОтладки());
	
	Возврат Результат;

КонецФункции

Функция КонтурПлагины_КаталогОтладки()
	
	Результат = ОбъединитьПути(
		КаталогОбработки(),
		"nosync",
		"plugins"
	);
	
	Возврат Результат;
	
КонецФункции

Функция Контракт_КонтурПлагин()
	
	Результат = Новый Структура;
	Результат.Вставить("Идентификатор");
	Результат.Вставить("Состояние");
	Результат.Вставить("Версия");
	
	Возврат Результат;
	
КонецФункции

// Возвращает список установленных плагинов (загруженных в информационную базу).
// 
// Возвращаемое значение:
//  Массив из Контракт_КонтурПлагин.
//
Функция КонтурПлагины_УстановленныеПлагины()
	
	Результат = Новый Массив;
	
	МодульКП = Модуль_КонтурПлагины(ЭтотОбъект);
	
	Если МодульКП = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Контекст = КонтурПлагины_КонтекстВызова();
	Ответ = МодульКП.УстановленныеПлагины(Контекст);
	
	Если ЗначениеЗаполнено(Ответ) Тогда
		
		Для Каждого Элемент Из Ответ Цикл
			
			Плагин = Контракт_КонтурПлагин();
			ЗаполнитьЗначенияСвойств(Плагин, Элемент);
			Результат.Добавить(Плагин);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонтурПлагины_ТехническаяИнформация()
	
	НастройкаВключена = ИспользоватьПлагины();
	СписокПлагинов = Неопределено;
	
	Если НастройкаВключена Тогда
		СписокПлагинов = КонтурПлагины_УстановленныеПлагины();
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьПлагины", НастройкаВключена);
	Результат.Вставить("Плагины", СписокПлагинов);
	
	Возврат Результат;
	
КонецФункции

