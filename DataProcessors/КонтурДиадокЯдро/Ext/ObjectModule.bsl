// Обновляет сведения о ранее выгруженном ПМ в сервис
//
// Параметры:
//  ОписаниеПМ	 	- Структура  - заполненный контракт со сведениями о ПМ (контракт см. Контракт_ОписаниеПМ) 
//  ИдентификаторИБ	- Строка	 - идентификатор текущей базы
// 
// Возвращаемое значение:
//  Структура - сведения о ПМ из сервиса (описание поле см. МодульAPI.Plugins_ПолучитьСведения)
//
Функция АПИ_УправлениеПМ_ОбновитьВСервисе(ОписаниеПМ, ИдентификаторИБ)

	ПараметрыСервиса = ПараметрыСервиса_СервисУправленияПМ();
	
	МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	КонтентДляПостинга 	= МетодыAPI.Plugins_API_DS_ContentToPost(
		ОписаниеПМ.ДвоичныеДанные,
		ОписаниеПМ.ТипМодуляAPI,
		ОписаниеПМ.ИмяФайла,
		ОписаниеПМ.Описание);
	
	ТелоЗапроса = ПарсерJSON_Записать(КонтентДляПостинга);
	
	ТелоОтвета = МетодыAPI.Plugins_ОбновитьВСервисе(ПараметрыСервиса, ТелоЗапроса, ИдентификаторИБ, ОписаниеПМ.Идентификатор);
	
	Результат = ПарсерJSON_Прочитать(ТелоОтвета);
	
	Возврат Результат;
	
КонецФункции

Функция АПИ_УправлениеПМ_ОбновлениеЗаблокировано(ИдентификаторИБ)
	
	Результат = Ложь;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	
	МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Попытка
		ТелоОтвета = МетодыAPI.DD_API_NonUpgradableClientPM(ПараметрыСервиса);
		СписокИдентификаторов = ПарсерJSON_Прочитать(ТелоОтвета);
	Исключение
		Результат = Истина;	
	КонецПопытки;

	Если Результат = Ложь И СписокИдентификаторов <> Неопределено Тогда
		Результат = (СписокИдентификаторов.Найти(ИдентификаторИБ) <> Неопределено);		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура АПИ_УправлениеПМ_ПреобразоватьСтроковыеЗначенияДаты(ОписаниеПМ)

	Если ОписаниеПМ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СписокПолей = "created,updated";
	
	Для Каждого ИмяПоля Из РазделитьСтрокуЛок(СписокПолей, ",") Цикл
		ДатаСтрокой = СвойствоСтруктуры(ОписаниеПМ, ИмяПоля, "0001-01-01");
		Если ЗначениеЗаполнено(ДатаСтрокой) Тогда
			ОписаниеПМ.Вставить(ИмяПоля, XMLЗначение(Тип("Дата"), ДатаСтрокой));
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

