Функция МЧД_ДанныеПоИспользованиюДоверенностей(BoxId, ВыполнитьПроверкуМЧДпоУмолчанию = Ложь) Экспорт
	
	Результат = Контракт_КонтекстМЧД();
	
	Если ЗначениеЗаполнено(BoxId) Тогда
		
		Результат.ТребуетсяМЧД = МЧД_ТребуетсяДоверенность(BoxId);
		
		Если Результат.ТребуетсяМЧД Тогда
			
			Результат.СписокМЧД = МЧД_СписокДоверенностей(BoxId);
			
			Для Каждого МЧД Из Результат.СписокМЧД Цикл
				
				ОписаниеМЧД = МЧД.Значение;
				
				Если ОписаниеМЧД.ПоУмолчанию Тогда
					
					Результат.МЧД = ОписаниеМЧД.Идентификатор;
					
					Если ВыполнитьПроверкуМЧДпоУмолчанию Тогда
						Результат.РезультатПроверкиМЧД = МЧД_БыстраяПроверка(ОписаниеМЧД, BoxId); 
					КонецЕсли;
					
					Прервать;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция Контракт_КонтекстМЧД()

	Результат = Новый Структура;
	
	Результат.Вставить("ТребуетсяМЧД"			, Ложь);
	Результат.Вставить("СписокМЧД"				, Новый ФиксированноеСоответствие(Новый Соответствие));
	Результат.Вставить("МЧД"					, "");
	Результат.Вставить("РезультатПроверкиМЧД"	, Неопределено);
	
	Возврат Результат;
	
КонецФункции 

