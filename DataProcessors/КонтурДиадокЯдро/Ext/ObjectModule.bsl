Функция ХранениеДанных_ДанныеОрганизации(Идентификаторы) Экспорт
	
	ДанныеОрганизации = Кэш_Прочитать("ДанныеОрганизации");
	
	Если ДанныеОрганизации = Неопределено Тогда
		
		ДанныеОрганизации = Новый Соответствие;
		Кэш_Поместить("ДанныеОрганизации", ДанныеОрганизации);
		
	КонецЕсли;
	
	Ключ = Новый_КлючИдентификаторовСправочника(Идентификаторы);
	
	Результат = ДанныеОрганизации.Получить(Ключ);
	
	Если Результат = Неопределено Тогда
		
		Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
		
		Результат = Модуль_ХранениеДанных.Организации_ДанныеОрганизации(Идентификаторы);
		
		Если ЗначениеЗаполнено(Результат.Наименование) Тогда
			ДанныеОрганизации.Вставить(Ключ, Результат);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
