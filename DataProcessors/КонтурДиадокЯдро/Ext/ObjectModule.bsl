Функция Модуль_ПМ(ВызывающийМодуль) Экспорт
	
	НастройкиПМ = ПодключаемыйМодуль_ПрочитатьНастройки();
	
	Если Не НастройкиПМ.ИспользоватьПодключаемыйМодуль 
		Или НастройкиПМ.ОбнаруженаОшибкаПодключенияПМ Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяМодуля = "ПМ";
	
	Результат = КэшМодулей_Прочитать(ИмяМодуля);
	
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПутьКПМ = НастройкиПМ.ПутьКПМ;
	Расположение = НастройкиПМ.МестонахождениеПодключаемогоМодуля;
	
	Попытка
	
		Результат = Обработка_Создать(
			ПутьКПМ,
			Расположение
		);
		
		Результат.ОсновнойМодуль = Модуль_ВызовыПМ(ЭтотОбъект);
		
	Исключение
		
		ВидОперации = "Подключение ПМ";
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения = "Не удалось подключить ПМ.";
		
		ДопИнформация = Новый Массив;
		ДопИнформация.Добавить("Путь = " + Строка(ПутьКПМ) + ";");
		ДопИнформация.Добавить("Местонахождение = " + Строка(Расположение) + ";");
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		ОбщийКонтекст_Поместить("ОбнаруженаОшибкаПодключенияПМ", Истина);
		
	КонецПопытки;
	
	Если ПодключаемыйМодуль_Проверить(Результат) Тогда
		
		ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, Результат);
		
	Иначе
		
		Результат = Неопределено;
		
		ОбщийКонтекст_Поместить("ОбнаруженаОшибкаПодключенияПМ", Истина);
		
		ВидОперации = "Подключение ПМ";
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения = ПодключаемыйМодуль_ТекстОшибкиНеЯвляетсяПМ();
		ДопИнформация = Новый Массив;
		ДопИнформация.Добавить("Обработка не содержит код подключаемого модуля.");
		ДопИнформация.Добавить("Путь = " + Строка(ПутьКПМ) + ";");
		ДопИнформация.Добавить("Местонахождение = " + Строка(Расположение) + ";");
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	КонецЕсли;
	
	КэшМодулей_Поместить(ИмяМодуля, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_Проверить(ЭкземплярОбработки)
	
	Если ЭкземплярОбработки = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Результат = Истина;
	
	Попытка
		
		ЕстьУказательНаОсновнойМодуль = (ЭкземплярОбработки.ОсновнойМодуль <> Неопределено);
		ВерсияAPIПодключаемогоМодуля = ЭкземплярОбработки.ЭДО_ВерсияAPIПодключаемогоМодуля();
		
		ВерсииСовместимы = (ПодключаемыйМодуль_ТребуемаяВерсияAPIПодключаемогоМодуля().Найти(ВерсияAPIПодключаемогоМодуля) <> Неопределено);
		
		Если НЕ ВерсииСовместимы Тогда
		
			ВерсияAPIОсновногоМодуля = ПодключаемыйМодуль_ТребуемаяВерсияAPIПодключаемогоМодуля()[0];
		
			ШаблонТекстаСообщения = "Подключаемый модуль не совместим с основным модулем!
			|Версия API основного модуля: %1
			|Версия API подключаемого модуля: %2";
		
			ТекстСообщения 	= Общее_ПодставитьПараметрыВСтроку(ШаблонТекстаСообщения, ВерсияAPIОсновногоМодуля, ВерсияAPIПодключаемогоМодуля); 
			
			ВидОперации     = "Проверка совместимости версии ПМ";  
		
			Ошибка_Обработать(ВидОперации, , , ТекстСообщения);
		
			Результат = Ложь;
		
		КонецЕсли;
		
	Исключение
		
		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция Модуль_ИМ(ВызывающийМодуль) Экспорт
	
	ИмяМодуля = ИнтеграционныйМодуль_ПолучитьИмяМакета();
	
	Результат = Модуль_Создать(ИмяМодуля);
		
	Если Результат <> Неопределено Тогда
		
		Модуль_ВызовыПМ = Модуль_ВызовыПМ(ЭтотОбъект);
		Модуль_ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
		Модуль_ПечатныеФормы = Модуль_ПечатныеФормы(ЭтотОбъект);
		Модуль_РаботаСМаркировкой = Модуль_РаботаСМаркировкой();
		Результат.ИнициализироватьМодуль(
			ЭтотОбъект,
			Модуль_ВызовыПМ,
			Модуль_ГенерацияXML,
			Модуль_ПечатныеФормы,
			Модуль_РаботаСМаркировкой);
			
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

