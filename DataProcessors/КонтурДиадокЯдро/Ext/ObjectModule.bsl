//{		МЧД

// Контракт МЧД
// 
// Возвращаемое значение:
//  Структура - содержит сведения о реквизитах, полномочиях и делигированных МЧД
// 		Полномочия - Структура - массив (коллекция) структур с описанием полномочий (см. Контракт_МЧД_Полномочия())
// 		СовместныеПолномочия - Булево - признак того, что у доверенности несколько представителей. Полномочия являются совместными.
// 		УтратаПолномочийПриПередоверии - Булево, Неопределено - признак утраты полномочий при передоверии. Признак может отсутствовать, тогда Неопределено
//
Функция Контракт_МЧД()

	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор"		, "");
	Результат.Вставить("ПредставлениеМЧД"	, "");
	Результат.Вставить("ДатаНачалаДействия"	, '00010101');
	Результат.Вставить("СрокДействия"		, '00010101');
	Результат.Вставить("ПоУмолчанию"		, Ложь);
	Результат.Вставить("ДелегированныеМЧД"	, Новый Массив);
	
	Доверитель = Новый Структура; 
	
	Доверитель.Вставить("Наименование",	"");
	Доверитель.Вставить("ИНН",			"");
	Доверитель.Вставить("КПП",			"");
	Доверитель.Вставить("ОГРН",			"");
	
	Результат.Вставить("Доверитель", Доверитель);
	
	Представитель = Новый Структура;
	
	Представитель.Вставить("Наименование",	"");
	Представитель.Вставить("ИНН",			"");
	Представитель.Вставить("КПП",			"");
	Представитель.Вставить("ОГРН",			"");
	Представитель.Вставить("Тип", Неопределено);
	
	Результат.Вставить("Представитель", Представитель);
	
	СтатусПроверки = Новый Структура;
	СтатусПроверки.Вставить("Статус"		, "");
	СтатусПроверки.Вставить("ДатаПроверки"	, '00010101');
	СтатусПроверки.Вставить("СтруктураОшибок", Новый Структура);
	
	Результат.Вставить("СтатусПроверки", СтатусПроверки);
	
	Полномочия = Новый Структура;
	Полномочия.Вставить("Полномочия", Новый Массив);
	Полномочия.Вставить("СовместныеПолномочия", Ложь);
	Полномочия.Вставить("УтратаПолномочийПриПередоверии", Неопределено);
	
	Результат.Вставить("СведенияОПолномочиях", Полномочия);
	
	Возврат Результат;
	
КонецФункции

