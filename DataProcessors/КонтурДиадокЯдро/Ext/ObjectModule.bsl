Функция ТехИнфо_Плагины()
	
	Данные = КонтурПлагины_ТехническаяИнформация();
	
	Результат = Новый Структура;
	Результат.Вставить("Использовать", Данные.ИспользоватьПлагины);
	Результат.Вставить("ЗагруженныеПлагины", Новый Массив);
	
	Если ЗначениеЗаполнено(Данные.Плагины) Тогда
		
		Для Каждого ПлагинИнфо Из Данные.Плагины Цикл
			
			ПлагинПредставление = Общее_ПодставитьПараметрыВСтроку(
				"%1 вер. %2 (%3)",
				ПлагинИнфо.Идентификатор,
				ПлагинИнфо.Версия,
				ПлагинИнфо.Состояние
			);
			Результат.ЗагруженныеПлагины.Добавить(ПлагинПредставление);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

