		ИсключаемыеИМ.Добавить(ИмяИМ_Розница2());
		
		ИмяИМ = ИнтеграционныйМодуль_Получить();
		
		Результат = (ИсключаемыеИМ.Найти(ИмяИМ) = Неопределено);
		
