// Определяет расположение файла, из которого был загружен текущий модуль
//  и заполняет описание расположения модуля для последующего анализа
//
// Параметры:
//  ДанныеДляОбновленияМодуля - Структура - см. функциию НовыеДанныеДляОбновленияМодуля()
//
Процедура ЗаполнитьОписаниеРасположенияМодуля(ДанныеДляОбновленияМодуля)
	
	Описание = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	МестоположенияМодуля = ДанныеДляОбновленияМодуля.Перечисления.МестоположенияМодуля;
	
	Имя = ОбщийКонтекстКлиентСервер.СвойстваМодуля.Имя;
	ПолноеИмя = ОбщийКонтекстКлиентСервер.СвойстваМодуля.ПолноеИмя;
	ЗначениеИспользуемоеИмяФайла = ОбщийКонтекстКлиентСервер.СвойстваМодуля.ИспользуемоеИмяФайла;
	
	ОписаниеРасположениеМодуля = ОбщийКонтекст_Прочитать("РасположениеМодуля");
	Местоположение = СвойствоСтруктуры(ОписаниеРасположениеМодуля, "РасположениеМодуля", МестоположенияМодуля.Неопределено);
	
	Описание.Имя = Имя;
	Описание.ПолноеИмя = ПолноеИмя;
	Описание.Местоположение = Местоположение;
	Описание.ИспользуемоеИмяФайла = ЗначениеИспользуемоеИмяФайла;
	
	Если Местоположение = МестоположенияМодуля.ФайлНаДиске Тогда
		
		Описание.ПутьКФайлу = ЗначениеИспользуемоеИмяФайла;
	
	ИначеЕсли Местоположение = МестоположенияМодуля.ЭлементСправочника Тогда
		
		Если ЗначениеЗаполнено(ОбщийКонтекстКлиентСервер.РасположениеМодуля) Тогда
			СсылкаНаМодуль = ОбщийКонтекстКлиентСервер.РасположениеМодуля.СсылкаНаМодуль;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СсылкаНаМодуль) Тогда
			Описание.Ссылка = СсылкаНаМодуль;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция МестоположениеМодуляПоИспользуемомуИмениФайла(ИмяФайла, МестоположенияМодуля) Экспорт
	
	Результат = "";
	                             
	ИмяФайлаОбъектаОтсутствует = ПустаяСтрока(ИмяФайла);
	ИмяФайлаОбъектаСодержитРасширениеEpf = ( Прав(НРег(ИмяФайла), 4) = ".epf" );
	ИмяФайлаОбъектаСодержитКаталогВременныхФайлов = ( Найти(ИмяФайла, КаталогВременныхФайлов()) > 0 );
	ИмяФайлаОбъектаСодержитАдресВременногоХранилища = СтрокаСодержитАдресВременногоХранилища(ИмяФайла);
													  
	Если ИмяФайлаОбъектаОтсутствует Тогда
		
		Результат = МестоположенияМодуля.ОбработкаКонфигурации;
		
	ИначеЕсли ИмяФайлаОбъектаСодержитАдресВременногоХранилища или
			  ИмяФайлаОбъектаСодержитКаталогВременныхФайлов Тогда
			  
		Результат = МестоположенияМодуля.ЭлементСправочника;
		
	ИначеЕсли ИмяФайлаОбъектаСодержитРасширениеEpf Тогда
		
		Результат = МестоположенияМодуля.ФайлНаДиске;
		
	Иначе
		
		Результат = МестоположенияМодуля.Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет строку на соответствие формату адреса временного хранилища
//	 Метод ЭтоАдресВременногоХранилища() срабатывает не корректно,
//	 если в этот момент файла уже нет во временном хранилище
//
//	Параметры:
//   Строка - Строка - проверяемая строка;
//
//	Возвращаемое значение:
//   Булево - результат проверки
//
Функция СтрокаСодержитАдресВременногоХранилища(Строка)
	
	Результат = Ложь;
	
	ПрефиксыАдресовВХ = Новый Массив;
	ПрефиксыАдресовВХ.Добавить("e1cib\tempstorage\"); // windows
	ПрефиксыАдресовВХ.Добавить("e1cib\data\");
	ПрефиксыАдресовВХ.Добавить("e1cib/tempstorage/"); // linux
	ПрефиксыАдресовВХ.Добавить("e1cib/data/");
	
	Для Каждого Префикс Из ПрефиксыАдресовВХ Цикл
		Если Найти(Строка, Префикс) = 1 Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МодульБылОбновлен()
	
	Результат = Ложь;
	
	ТекущаяВерсия = ОбщийКонтекстКлиентСервер.ВерсияМодуля;
	СохраненнаяВерсия = ЗначениеНастройки_СохраненнаяВерсияМодуля();
	
	ЕстьСохраненнаяВерсия = ЗначениеЗаполнено(СохраненнаяВерсия) И ( СохраненнаяВерсия <> "0.0.0" );
	
	Если ЕстьСохраненнаяВерсия Тогда
		ТекущаяВерсияНовееСохраненной = ( СравнитьВерсии(ТекущаяВерсия, СохраненнаяВерсия) > 0 );
		Результат = ТекущаяВерсияНовееСохраненной;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОтключеноАвтоматическоеОбновлениеМодуля()
	
	Результат = Не ЗначениеНастройки_АвтоматическиОбновлятьМодуль();
	Возврат Результат;
	
КонецФункции

// Проверяет возможность записи элемента справочника внешних обработок
// с правами текущего пользователя
//
// Параметры:
//  ВнешняяОбработка - СправочникСсылка - элемент в справочнике внешних обработок,
//                                        в котором хранится модуль;
// 
// Возвращаемое значение:
//  Строка - описание ошибки
//
Функция ПроверитьВозможностьОбновленияЭлементаСправочникаМодуля(ВнешняяОбработка)
	
	Результат = "";
	
	Если ВнешняяОбработка = Неопределено Тогда
		Результат = "ДополнительныеОбработки.НеНайденЭлемент";
		Возврат Результат;
	КонецЕсли;
		
	Попытка
		
		// BSLLS:SetPrivilegedMode-off
		УстановитьПривилегированныйРежим(Истина);
		// BSLLS:SetPrivilegedMode-on
		
		ОбъектСправочника = ВнешняяОбработка.ПолучитьОбъект();
		ОбъектСправочника.ОбменДанными.Загрузка = Истина;
		ОбъектСправочника.Записать();
		
	Исключение
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
								
		Результат = "ДополнительныеОбработки.ОшибкаПриЗаписи" + " " + ОписаниеОшибки();
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Проверяет возможность обновления расширения конфигурации Диадок
// с правами текущего пользователя
//
// Возвращаемое значение:
//  Строка - описание ошибки
//
Функция ПроверитьВозможностьОбновленияРасширенияКонфигурации()
	
	Результат = "";
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Если НЕ ПравоДоступа("Администрирование", Метаданные)
		И НЕ ПривилегированныйРежим() Тогда
		Результат = "РасширениеКонфигурации.НарушениеПравДоступа У пользователя нет прав на изменение расширения конфигурации.";
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

// Записывает в журнал регистрации описания ошибок, происходящих
// 	в процессе автообновления модуля
//
// Параметры:
//  ОписаниеОшибки - Строка - см. функцию ПодробноеПредставлениеОшибки();
//
Процедура ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки) Экспорт
	
	ИмяСобытия = "Диадок.Автообновление";
	Уровень = УровеньЖурналаРегистрации.Ошибка;
		
	ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, , , ОписаниеОшибки);
	
КонецПроцедуры

// сбор данных (2 часть)

Процедура ДополнитьДанныеДляОбновленияМодуля(ДанныеДляОбновленияМодуля) Экспорт
	
	ТестовыйЗапуск = ОбновлениеМодуля_ЭтоТестовыйЗапуск();
	
	ЗаполнитьОписанияОкруженияИОбновленияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск);	
	
	Если Не ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Тогда
		Возврат;
	КонецЕсли;
		
	ОписаниеРасположения = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	МестоположенияМодуля = ДанныеДляОбновленияМодуля.Перечисления.МестоположенияМодуля;
	
	Если ОписаниеРасположения.Местоположение = МестоположенияМодуля.ФайлНаДиске Тогда
		ТекстОшибки = ПроверитьВозможностьОбновленияФайлаМодуля(ОписаниеРасположения.ПутьКФайлу);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			ДанныеДляОбновленияМодуля.МожноОбновитьМодуль = Ложь;
			ДанныеДляОбновленияМодуля.КомментарийМодуля = ТекстОшибки;
			Возврат;		
		КонецЕсли;		
	КонецЕсли;	
	
	Если МодульДоработан(ДанныеДляОбновленияМодуля) Тогда
		ДанныеДляОбновленияМодуля.МожноОбновитьМодуль = Ложь;
		ДанныеДляОбновленияМодуля.КомментарийМодуля = "МодульДоработан";
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

Функция ОбновлениеМодуля_ЭтоТестовыйЗапуск()
	
	Результат = Ложь;
	
	Если РежимАвтотест() 
		Или ДоменПользователяКонтур() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет принадлежность пользователя к домену kontur
//
Функция ДоменПользователяКонтур()
	
	ДоменПользователя = ЗначениеПеременнойОкружения("UserDomain");
	
	Результат = (НРег(ДоменПользователя) = НРег("Kontur"));
	
	Возврат Результат;		
	
КонецФункции

Функция ЗначениеПеременнойОкружения(Имя)
	
	Результат = "";
	
	Попытка
		WSH = Новый COMobject("wscript.shell");
		Результат = WSH.ExpandEnvironmentStrings("%" + Имя + "%");
	Исключение
		_ОписаниеОшибки = ОписаниеОшибки();
		Метрика_ДобавитьОшибку_ОпределениеЗначенияПеременнойОкружения(Имя, _ОписаниеОшибки);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьОписанияОкруженияИОбновленияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск)
	
	ЗаполнитьОписаниеОкруженияМодуля(ДанныеДляОбновленияМодуля, ТестовыйЗапуск);
	
	ЗаполнитьОписаниеОбновленияМодуля(ДанныеДляОбновленияМодуля);
	
КонецПроцедуры

Процедура ЗаполнитьОписаниеОкруженияМодуля(ДанныеДляОбновленияМодуля, Тестовый) Экспорт
	
	Если ДанныеДляОбновленияМодуля.МодульЗапущенВпервые Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОкружения = ДанныеДляОбновленияМодуля.ОписаниеОкруженияМодуля;
	
	СистемнаяИнформация	= Новый СистемнаяИнформация;
	ВерсияПлатформы = СистемнаяИнформация.ВерсияПриложения;
	
	BoxID = ИдентификаторыЯщиковСопоставленныхОрганизаций();
	BaseID = ОбщийКонтекст_ИдентификаторБазы1С();
	РежимЗапускаПриложения = ТекущийРежимЗапускаПриложения();
	ИмяИнтеграционногоМодуля = ИнтеграционныйМодуль_Получить();
	ВерсияAPIПодключаемогоМодуля = Строка(ПодключаемыйМодуль_ВерсияПрограммногоИнтерфейса());
	
	// client
	ОписаниеОкружения.BoxID = BoxID;
	ОписаниеОкружения.BaseID = BaseID;
	ОписаниеОкружения.Тестовый = Тестовый;
	
	// plug-in module     
	ОписаниеОкружения.ВерсияAPIПодключаемогоМодуля = ВерсияAPIПодключаемогоМодуля;
	
	// platform
	ОписаниеОкружения.ВерсияПлатформы = ВерсияПлатформы;
		
	// configuration
	ОписаниеОкружения.ИмяКонфигурации = Метаданные.Имя;
	ОписаниеОкружения.ВерсияКонфигурации = Метаданные.Версия;
	ОписаниеОкружения.ПодсистемаХранения = ПодсистемаХранения();
	ОписаниеОкружения.РежимЗапускаПриложения = РежимЗапускаПриложения;
	ОписаниеОкружения.ИмяИнтеграционногоМодуля = ИмяИнтеграционногоМодуля;
	
КонецПроцедуры

Функция ИдентификаторыЯщиковСопоставленныхОрганизаций() Экспорт
	
	Результат = Новый Массив;
	
	ДанныеОрганизаций = Организации_ТаблицаСопоставленныхОрганизаций();
	Если ДанныеОрганизаций.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяКолонки = "BoxId";
	ДанныеОрганизаций.Свернуть(ИмяКолонки);
	
	Результат = ДанныеОрганизаций.ВыгрузитьКолонку(ИмяКолонки);
	
	ПривестиАдресаЯщиковКИдентификаторам(Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПодсистемаХранения()
	
	ИспользуетсяПодсистемаДиадок = ОбщийКонтекстКлиентСервер.ИспользуетсяПодсистемаДиадок;
	
	Если ИспользуетсяПодсистемаДиадок Тогда	
		Результат = "ПодсистемаДиадок";
	Иначе
		Результат = "ТиповаяПодсистема1С";
	КонецЕсли;	
	
	Возврат Результат;	
	
КонецФункции

// Проверяет наличие новой версии модуля в сервисе обновлений
// и заполняет ее данные для дальнейшей загрузки
//
// Параметры:
//  ДанныеДляОбновленияМодуля - Структура - см. функциию НовыеДанныеДляОбновленияМодуля()
//
Процедура ЗаполнитьОписаниеОбновленияМодуля(ДанныеДляОбновленияМодуля) Экспорт
	
	ОписаниеОкружения = ДанныеДляОбновленияМодуля.ОписаниеОкруженияМодуля;
	ОписаниеОбновления = ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля;
	
	ТипКонтента = ОбновлениеМодуля_ТипКонтентаAPIпоМестоположениюМодуля(
			ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля.Местоположение);
	
	Попытка
		
		ОписаниеНовойВерсии = ОписаниеНовойВерсииИзСервисаОбновлений(
				ОписаниеОкружения,
				ТипКонтента);
		
	Исключение
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
		
		ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ЗапросНаличияНовойВерсии" + " " + ОписаниеОшибки();
		
		Возврат;
		
	КонецПопытки;
	
	НоваяВерсияМодуля = ОписаниеНовойВерсии.Версия;
	ОписаниеОбновления.Версия = НоваяВерсияМодуля;
	ОписаниеОбновления.СсылкаНаФайл = ОписаниеНовойВерсии.СсылкаНаФайл;
	
	ЕстьНоваяВерсия = Ложь;
	
	Если ЗначениеЗаполнено(ОписаниеОбновления.СсылкаНаФайл) 
		И ЗначениеЗаполнено(НоваяВерсияМодуля) Тогда
		
		ЧастиВерсииМодуля = РазделитьСтрокуЛок(НоваяВерсияМодуля, ".");
		Если ЧастиВерсииМодуля.Количество() = 4 Тогда
			ЧастиВерсииМодуля.Удалить(3);
			НоваяВерсияМодуля = СоединитьСтроку(ЧастиВерсииМодуля, ".");
		КонецЕсли;
		
		ТекущаяВерсия = ОбщийКонтекстКлиентСервер.ВерсияМодуля;
		ЕстьНоваяВерсия = (СравнитьВерсии(НоваяВерсияМодуля, ТекущаяВерсия) > 0);
		
	КонецЕсли;
	
	ОписаниеОбновления.ЕстьНоваяВерсия = ЕстьНоваяВерсия;
	
	Если НЕ ЗначениеЗаполнено(ОписаниеОбновления.СсылкаНаФайл)
		И ЗначениеЗаполнено(ОписаниеНовойВерсии.Комментарий) Тогда
		ДанныеДляОбновленияМодуля.КомментарийСервиса = ОписаниеНовойВерсии.Комментарий;
	КонецЕсли;
	
КонецПроцедуры

// Проверяет наличие новой версии модуля в сервисе обновлений
// и заполняет ее данные для дальнейшей загрузки
//
// Параметры:
//  ДанныеДляОбновленияМодуля - Структура - см. функциию НовыеДанныеДляОбновленияМодуля()
//
Процедура ЗаполнитьОписаниеАктуальнойВерсииМодуля(ДанныеДляОбновленияМодуля) Экспорт
	
	ОписаниеОкружения = ДанныеДляОбновленияМодуля.ОписаниеОкруженияМодуля;
	ОписаниеОбновления = ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля;
	
	ТипКонтента = ОбновлениеМодуля_ТипКонтентаAPIпоМестоположениюМодуля(
			ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля.Местоположение);
	
	Попытка
		
		ОписаниеНовойВерсии = ОписаниеАктуальнойВерсииИзСервисаОбновлений(
				ОписаниеОкружения,
				ТипКонтента);
		
	Исключение
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
		
		ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ЗапросНаличияАктуальнойВерсии" + " " + ОписаниеОшибки();
		
		Возврат;
		
	КонецПопытки;
	
	ОписаниеОбновления.Версия = ОписаниеНовойВерсии.Версия;
	ОписаниеОбновления.СсылкаНаФайл = ОписаниеНовойВерсии.СсылкаНаФайл;
	
	Если НЕ ЗначениеЗаполнено(ОписаниеОбновления.СсылкаНаФайл)
		И ЗначениеЗаполнено(ОписаниеНовойВерсии.Комментарий) Тогда
		ДанныеДляОбновленияМодуля.КомментарийСервиса = ОписаниеНовойВерсии.Комментарий;
	КонецЕсли;
	
КонецПроцедуры

// Получает описание новой версии модуля из сервиса обновлений
//
// Параметры:
//  ОписаниеОкруженияМодуля	- Структура	- см. функциию ОписаниеОкруженияМодуля()
//  ТипКонтента - Строка - тип контента, возвращаемого из сервиса обновлений. Например, data-processor или extension
//							(см. Модуль_МетодаAPI.UpdateServiсe_API_ENUM_ContentsType)
// 
// Возвращаемое значение:
//	Структура - содержит свойства:
//   * status		- Число		- код выполнения запроса;
//   * links		- Массив	- ссылки на новую версию модуля и другой контент;
//	 * description	- Строка	- описание новой версии;
//
Функция ОписаниеНовойВерсииИзСервисаОбновлений(ОписаниеОкруженияМодуля, ТипКонтента)
	
	Результат = НовоеОписаниеВерсииИзСервисаОбновлений();
	
	ВерсияМодуля = ОбщийКонтекстКлиентСервер.ВерсияМодуля;
	ПараметрыОкруженияМодуля = ПараметрыОкруженияМодуля(ВерсияМодуля, ОписаниеОкруженияМодуля);
	
	АПИ_ОписаниеВерсии = АПИ_СервисОбновлений_Check(ПараметрыОкруженияМодуля);
	
	Результат.Версия 		= СвойствоСтруктуры(АПИ_ОписаниеВерсии, "name", "");
	Результат.Комментарий 	= СвойствоСтруктуры(АПИ_ОписаниеВерсии, "description", "");
	
	ОбновлениеМодуля_ЗаполнитьСсылкуНаФайл(Результат, ТипКонтента, АПИ_ОписаниеВерсии);
	
	Возврат Результат;
	
КонецФункции

// Получает описание новой версии модуля из сервиса обновлений
//
// Параметры:
//  ОписаниеОкруженияМодуля	- Структура	- см. функциию ОписаниеОкруженияМодуля()
//  ТипКонтента - Строка - тип контента, возвращаемого из сервиса обновлений. Например, data-processor или extension
//							(см. Модуль_МетодаAPI.UpdateServiсe_API_ENUM_ContentsType)
//
// Возвращаемое значение:
//	Структура - содержит свойства:
//   * status		- Число		- код выполнения запроса;
//   * links		- Массив	- ссылки на новую версию модуля и другой контент;
//	 * description	- Строка	- описание новой версии;
//
Функция ОписаниеАктуальнойВерсииИзСервисаОбновлений(ОписаниеОкруженияМодуля, ТипКонтента)
	
	Результат = НовоеОписаниеВерсииИзСервисаОбновлений();
	
	НулеваяВерсияМодуля = "0.0.0";
	ПараметрыОкруженияМодуля = ПараметрыОкруженияМодуля(НулеваяВерсияМодуля, ОписаниеОкруженияМодуля);
	
	АПИ_ОписаниеВерсии = АПИ_СервисОбновлений_Check(ПараметрыОкруженияМодуля);
	
	Результат.Версия = СвойствоСтруктуры(АПИ_ОписаниеВерсии, "name", "");
	Результат.Комментарий = СвойствоСтруктуры(АПИ_ОписаниеВерсии, "description", "");
	
	ОбновлениеМодуля_ЗаполнитьСсылкуНаФайл(Результат, ТипКонтента, АПИ_ОписаниеВерсии);
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновлениеМодуля_ЗаполнитьСсылкуНаФайл(Результат, ТипКонтента, АПИ_ОписаниеВерсии)
	
	Результат.СсылкаНаФайл 	= СсылкаНаФайлИзОписанияНовойВерсии(АПИ_ОписаниеВерсии, ТипКонтента);	
	Если ЗначениеЗаполнено(Результат.Версия)
		И НЕ ЗначениеЗаполнено(Результат.СсылкаНаФайл) Тогда
		
		ОписаниеКонтентаПолное = АПИ_СервисОбновлений_ОписаниеКонтентаМодуля(Результат.Версия, ТипКонтента);
		Результат.СсылкаНаФайл = СвойствоСтруктуры(ОписаниеКонтентаПолное, "drive_public_link", "");
		
	КонецЕсли;

КонецПроцедуры

Функция НовоеОписаниеВерсииИзСервисаОбновлений()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Версия", 		"");
	Результат.Вставить("СсылкаНаФайл", 	"");
	Результат.Вставить("Комментарий",  	"");
	
	Возврат Результат;
	
КонецФункции

// Формирует структуру параметров для проверки наличия новой версии 
//  на основании версии модуля и параметров его окружения
//
// Возвращаемое значение:
//	Структура
//
Функция ПараметрыОкруженияМодуля(ВерсияМодуля, ОписаниеОкруженияМодуля)
	
	Результат = Новый Структура;
	
	Описание = ОписаниеОкруженияМодуля;
	
	// module     
	Результат.Вставить("version", ВерсияМодуля);
	
	// client
	Результат.Вставить("client_id", Описание.BaseId);
	Результат.Вставить("client_is_test", Описание.Тестовый);
	
	// plug-in module
	Результат.Вставить("pm_api_version", Описание.ВерсияAPIПодключаемогоМодуля);
	
	// platform
	Результат.Вставить("platform_version", Описание.ВерсияПлатформы);
		
	// configuration
	Результат.Вставить("conf_name", Описание.ИмяКонфигурации);
	Результат.Вставить("conf_version", Описание.ВерсияКонфигурации);
	Результат.Вставить("storage_subsystem", Описание.ПодсистемаХранения);
	Результат.Вставить("application_launch_mode", Описание.РежимЗапускаПриложения);
	Результат.Вставить("integration_module_name", Описание.ИмяИнтеграционногоМодуля);
	
	Возврат Результат;
	
КонецФункции

// Извлекает ссылку на файл из описания новой версии сервиса обновлений
//
// Параметры:
//  ОписаниеНовойВерсии - Структура - см. функцию ОписаниеНовойВерсииИзСервисаОбновлений()
//  ТипКонтента 		- Строка - тип контента, возвращаемого из сервиса обновлений. Например, data-processor или extension
//							(см. Модуль_МетодаAPI.UpdateServiсe_API_ENUM_ContentsType)
// 
// Возвращаемое значение:
//  Строка - ссылка для скачивания файла новой версии модуля
//
Функция СсылкаНаФайлИзОписанияНовойВерсии(ОписаниеНовойВерсии, ТипКонтента)
	
	Результат = "";
	
	links = Неопределено;
	Если Не ОписаниеНовойВерсии.Свойство("links", links)
		 Или ТипЗнч(links) <> Тип ("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого link Из links Цикл
		Если link.rel = "content" И link.content_type = ТипКонтента Тогда
			Результат = link.href;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля)
	
	Результат = Истина;
	
	Если ДанныеДляОбновленияМодуля.МодульЗапущенВпервые 
		 Или ДанныеДляОбновленияМодуля.МодульБылОбновлен
		 Или Не ДанныеДляОбновленияМодуля.МожноОбновитьМодуль
		 Или Не ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля.ЕстьНоваяВерсия Тогда
		 
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет наличие файла модуля и возможность записи в его каталог
//
// Параметры:
//  ПутьКФайлу - Строка - путь к файлу модуля
// 
// Возвращаемое значение:
//  Строка - описание ошибки
//
Функция ПроверитьВозможностьОбновленияФайлаМодуля(ПутьКФайлу)
	
	Результат = "";
	
	Файл = Новый Файл(ПутьКФайлу);
	Каталог	 = Файл.Путь;
	ИмяФайла = Файл.Имя;
	
	Если Не Файл.Существует() Тогда
		Результат = "КаталогФайлаМодуля.НеНайденФайл";
		Возврат Результат;
	КонецЕсли;
	
	Префикс = "Diadoc_WriteTest_";
	Расширение = ".txt";
	УникальнаяЧасть = Строка(Новый УникальныйИдентификатор);
	
	ИмяТестовогоФайла = Префикс + УникальнаяЧасть + Расширение;
	ПутьКТестовомуФайлу = ОбъединитьПути(Каталог, ИмяТестовогоФайла);
	
	Попытка
		Запись = Новый ЗаписьТекста(ПутьКТестовомуФайлу);
		Запись.Записать("Тест записи файла перед обновлением " + ИмяФайла);
		Запись.Закрыть();
	Исключение
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
		
		Результат = "КаталогФайлаМодуля.ОшибкаПриЗаписи" + " " + ОписаниеОшибки();
		
	КонецПопытки;
	
	Попытка
		УдалитьФайлы(ПутьКТестовомуФайлу);
	Исключение
		Ошибка = ИнформацияОбОшибке();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция МодульДоработан(ДанныеДляОбновленияМодуля)
	
	Результат = Ложь;
	
	Если ЭтоТиповойМодуль() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = Истина;
		
	РезультатПроверки = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммы();
	ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ПроверкаХешСуммыМодуля " + РезультатПроверки;
	
	Возврат Результат;
	
КонецФункции

// обновление

Функция ОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Экспорт  
	
	Результат = "";
	
	МоментНачалаЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Если Не ВозможноОбновитьМодульАвтоматически(ДанныеДляОбновленияМодуля) Тогда
		
		Если НужноЗарегистрироватьОшибкуАвтообновленияМодуля(ДанныеДляОбновленияМодуля) Тогда 
			
			Результат = "CriticalRejection";
			Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
			
			Метрика_ДобавитьОшибку_ОшибкаАвтообновленияМодуля(ДанныеДляОбновленияМодуля);
			
		Иначе
			
			Результат = "NormalRejection";
			Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);		
			
		КонецЕсли;
		
		Возврат Результат;
		
	КонецЕсли;
	
	Попытка
		
		ВыполнитьОбновлениеМодуля(ДанныеДляОбновленияМодуля);
		
		Результат = "Success";	
		Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
		
		Метрика_ДобавитьСтатистику_УспешноеАвтообновлениеМодуля(ДанныеДляОбновленияМодуля);
		
	Исключение  
		
		Результат = "Error";
		Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, Результат, ДанныеДляОбновленияМодуля);
		
		ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗарегистрироватьОшибкуАвтообновленияМодуляВЖурналеРегистрации(ОписаниеОшибки);
				
		ДанныеДляОбновленияМодуля.ОписаниеОшибки = "ОбновлениеМодуля" + " " + ОписаниеОшибки();
		Метрика_ДобавитьОшибку_ОшибкаАвтообновленияМодуля(ДанныеДляОбновленияМодуля);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция НужноЗарегистрироватьОшибкуАвтообновленияМодуля(ДанныеДляОбновленияМодуля)
	
	Результат = Ложь;
	
	Если ДанныеДляОбновленияМодуля.МодульЗапущенВпервые 
		 Или ДанныеДляОбновленияМодуля.МодульБылОбновлен Тогда
		Возврат Результат; // не должно быть процесса обновления -> значит нет ошибок
	КонецЕсли;
	
	НетНовойВерсии = Не ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля.ЕстьНоваяВерсия;
	Если НетНовойВерсии Тогда
		СервисВернулПричинуОтказа = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.КомментарийСервиса);
		ПроизошлаОшибкаПриСбореДанныхДляОбновления = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.ОписаниеОшибки);
		Если СервисВернулПричинуОтказа Или ПроизошлаОшибкаПриСбореДанныхДляОбновления Тогда
			Результат = Истина;		
		КонецЕсли;
		Возврат Результат; // если НетНовойВерсии -> значит нет процесса обновления -> значит уже не важно, что НельзяОбновитьМодуль
	КонецЕсли;
	
	НельзяОбновитьМодуль = Не ДанныеДляОбновленияМодуля.МожноОбновитьМодуль;
	Если НельзяОбновитьМодуль Тогда
		МодульНашелПричинуОтказа = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.КомментарийМодуля);
		ПроизошлаОшибкаПриСбореДанныхДляОбновления = ЗначениеЗаполнено(ДанныеДляОбновленияМодуля.ОписаниеОшибки);
		Если МодульНашелПричинуОтказа Или ПроизошлаОшибкаПриСбореДанныхДляОбновления Тогда
			Результат = Истина;
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;

КонецФункции

Процедура ВыполнитьОбновлениеМодуля(ДанныеДляОбновленияМодуля)
	
	МестоположенияМодуля = ДанныеДляОбновленияМодуля.Перечисления.МестоположенияМодуля;
	РасположениеМодуля   = ДанныеДляОбновленияМодуля.ОписаниеРасположенияМодуля;
	ОписаниеОбновления   = ДанныеДляОбновленияМодуля.ОписаниеОбновленияМодуля;
		
	ПутьКФайлу		 = РасположениеМодуля.ПутьКФайлу;
	СсылкаНаФайл 	 = ОписаниеОбновления.СсылкаНаФайл;
	Местоположение	 = РасположениеМодуля.Местоположение;
	ВнешняяОбработка = РасположениеМодуля.Ссылка;
	
	Если Местоположение = МестоположенияМодуля.ФайлНаДиске Тогда
		
		ВыполнитьОбновлениеМодуляВФайлеНаДиске(ПутьКФайлу, СсылкаНаФайл);
		
	ИначеЕсли Местоположение = МестоположенияМодуля.ЭлементСправочника Тогда
		
		ВыполнитьОбновлениеМодуляВСправочнике(ВнешняяОбработка, СсылкаНаФайл);
		
	ИначеЕсли Местоположение = МестоположенияМодуля.РасширениеКонфигурации Тогда
		
		ВыполнитьОбновлениеРасширенияКонфигурацииДиадок(СсылкаНаФайл);
		
	Иначе // этого сценария не должно быть
		
		ВызватьИсключение "НекорректноеРасположениеМодуля: " + Местоположение;
		
	КонецЕсли;
	
КонецПроцедуры

// Получает новую версию модуля из сервиса обновлений
// 	и записывает его файл на диске
//
// Параметры:
//  ПутьКФайлу		- Строка    - путь к файлу на диске, в который нужно записать новую версию модуля;
//  СсылкаНаФайл    - Строка 	- ссылка на файл в сервисе обновлений;
//
Процедура ВыполнитьОбновлениеМодуляВФайлеНаДиске(ПутьКФайлу, СсылкаНаФайл)
	
	ФайлНовойВерсии = ФайлНовойВерсииМодуля(СсылкаНаФайл);
	
	ОбновлениеМодуля_ВыполнитьТестовоеПодключениеМодуля(ФайлНовойВерсии);
		                        
	ФайлНовойВерсии.Записать(ПутьКФайлу);
		
КонецПроцедуры

Функция ФайлНовойВерсииМодуля(СсылкаНаФайл) Экспорт

	Попытка
		ДвоичныеДанные = АПИ_СервисОбновлений_СкачатьФайл(СсылкаНаФайл);
	Исключение
		ВызватьИсключение "ОшибкаЗагрузкиНовойВерсии " + ОписаниеОшибки();
	КонецПопытки;
	
	Если ТипЗнч(ДвоичныеДанные) <> Тип("ДвоичныеДанные") Тогда
		ВызватьИсключение "ОшибкаЗагрузкиНовойВерсии: сервер не вернул двоичные данные";
	КонецЕсли;
	
	Результат = ДвоичныеДанные;
	
	Возврат Результат;

КонецФункции

Процедура ВыполнитьОбновлениеРасширенияКонфигурацииДиадок(СсылкаНаФайл) Экспорт
	
	ФайлНовойВерсии = ФайлНовойВерсииМодуля(СсылкаНаФайл);

	РасширениеКонфигурации = РасширениеКонфигурацииКонтурДиадок();
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	РезультатПроверки = РасширениеКонфигурации.ПроверитьВозможностьПрименения(ФайлНовойВерсии, Ложь);
	Если РезультатПроверки.Количество() >  0 Тогда
		ИнформацияОПроблеме = РезультатПроверки[0];
		ВызватьИсключение "ОшибкаПроверкиНовойВерсииРасширения: "  + ИнформацияОПроблеме.Описание;	
	КонецЕсли;
	
	РасширениеКонфигурации.Записать(ФайлНовойВерсии);
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

// Получает менеджер расширения конфигурации Диадок
// Вариант через метаданные объекта выдает ошибку при попытке обновить расширение:
// 		Метаданные().РасширениеКонфигурации();
// 
Функция РасширениеКонфигурацииКонтурДиадок()
	
	Результат = Неопределено;
	
	ИмяРасширения = ОбщийКонтекст_Прочитать("ИмяРасширенияКонтурДиадок");
	Если ЗначениеЗаполнено(ИмяРасширения) Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("Имя", ИмяРасширения);
		
		МенеджерРасширений = Вычислить("РасширенияКонфигурации");
		
		// BSLLS:SetPrivilegedMode-off
		УстановитьПривилегированныйРежим(Истина);
		// BSLLS:SetPrivilegedMode-on
		
		РасширениеДиадок = МенеджерРасширений.Получить(Отбор);
		Если РасширениеДиадок.Количество() > 0 Тогда
			Результат = РасширениеДиадок[0];
		КонецЕсли;
		
		Если ПривилегированныйРежим() Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ВыполнитьОбновлениеМодуляВСправочнике(ВнешняяОбработка, СсылкаНаФайл) Экспорт
	
	ФайлНовойВерсии = ФайлНовойВерсииМодуля(СсылкаНаФайл);
	
	ОбновлениеМодуля_ВыполнитьТестовоеПодключениеМодуля(ФайлНовойВерсии);
	
	ОбновитьМодульВСправочникеДополнительныхОбработок(ВнешняяОбработка, ФайлНовойВерсии);
	
КонецПроцедуры

Процедура ОбновитьМодульВСправочникеДополнительныхОбработок(ВнешняяОбработка, ДвоичныеДанные)
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.ДополнительныеОтчетыИОбработки") Тогда
		
		ОбновитьОбработкуВСправочнике_УФ(ВнешняяОбработка, ДвоичныеДанные);
		
	ИначеЕсли ПроверитьНаличиеОбъектаМетаданных("Справочники.ВнешниеОбработки") Тогда
		
		ОбновитьОбработкуВСправочнике_ОФ(ВнешняяОбработка, ДвоичныеДанные);
		
	Иначе
		
		ВызватьИсключение "Не найден справочник дополнительных обработок";
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьОбработкуВСправочнике_УФ(ВнешняяОбработка, ДвоичныеДанные)
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	СведенияОбОбработке = ОбновленияМодуля_СведенияОВнешнейОбработкеИзФайла(ДвоичныеДанные);
		
	ОбработкаОбъект = ВнешняяОбработка.ПолучитьОбъект();
	ОбработкаОбъект.Версия = СведенияОбОбработке.Версия;
	ОбработкаОбъект.Наименование = СведенияОбОбработке.Наименование;	
	ОбработкаОбъект.ХранилищеОбработки = Новый ХранилищеЗначения(ДвоичныеДанные);
	ОбновитьКомандыОбработкиВСправочнике(ОбработкаОбъект, СведенияОбОбработке);
	ОбработкаОбъект.ОбменДанными.Загрузка = Истина;
	ОбработкаОбъект.Записать();	
	
КонецПроцедуры

Процедура ОбновитьОбработкуВСправочнике_ОФ(ВнешняяОбработка, ДвоичныеДанные)
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	СведенияОбОбработке = ОбновленияМодуля_СведенияОВнешнейОбработкеИзФайла(ДвоичныеДанные);
	
	ИмяФайла = "Diadoc" + "_" + СведенияОбОбработке.Версия + ".epf";
	КомментарийКФайлу = ИмяФайла + "; сохранен в ИБ: " + ТекущаяДата();
	Наименование = ОбщийКонтекстКлиентСервер.СвойстваМодуля.Синоним;
	
	ОбъектСправочника = ВнешняяОбработка.ПолучитьОбъект();
	ОбъектСправочника.Наименование = Наименование;
	ОбъектСправочника.ХранилищеВнешнейОбработки = Новый ХранилищеЗначения(ДвоичныеДанные);
	ОбъектСправочника.КомментарийКФайлуИсточнику = КомментарийКФайлу;
	ОбъектСправочника.ОбменДанными.Загрузка = Истина;
	ОбъектСправочника.Записать();
	
КонецПроцедуры

Процедура ОбновитьКомандыОбработкиВСправочнике(ОбработкаОбъект, СведенияОбОбработке)
	
	НовыеКоманды = СведенияОбОбработке.Команды;
	ТекущиеКоманды = ОбработкаОбъект.Команды;
	
	Для Каждого ОписаниеНовойКоманды Из НовыеКоманды Цикл
		
		Идентификатор = ОписаниеНовойКоманды.Идентификатор;
		
		СтрокаТекущейКоманды = ТекущиеКоманды.Найти(Идентификатор, "Идентификатор"); 
		
		Если СтрокаТекущейКоманды = Неопределено Тогда
		    ДобавитьНовуюКомандуОбработкиВСправочнике(ОбработкаОбъект, ОписаниеНовойКоманды);
		Иначе
			ОбновитьТекущуюКомандуОбработкиВСправочнике(ОбработкаОбъект, СтрокаТекущейКоманды, ОписаниеНовойКоманды);	
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьНовуюКомандуОбработкиВСправочнике(ОбработкаОбъект, ОписаниеНовойКоманды)
	
	Использование = ОписаниеНовойКоманды.Использование;
	ВариантЗапуска = Вычислить("Перечисления.СпособыВызоваДополнительныхОбработок[Использование]");
			
	НоваяКоманда = ОбработкаОбъект.Команды.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяКоманда, ОписаниеНовойКоманды);
	НоваяКоманда.ВариантЗапуска = ВариантЗапуска;
	
КонецПроцедуры

Процедура ОбновитьТекущуюКомандуОбработкиВСправочнике(ОбработкаОбъект, ТекущаяКоманда, ОписаниеНовойКоманды)
	
	ТекущаяКоманда.Представление = ОписаниеНовойКоманды.Представление;
	
	ИмяКолонки = "Скрыть";
	Если ОписаниеНовойКоманды.Владелец().Колонки.Найти(ИмяКолонки) <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ТекущаяКоманда, ОписаниеНовойКоманды, ИмяКолонки);	
	КонецЕсли;
	
КонецПроцедуры

