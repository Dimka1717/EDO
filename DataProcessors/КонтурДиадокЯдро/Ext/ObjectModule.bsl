// Инициализирует клиент сервиса обновлений.
//
// Параметры:
//  ЗаголовокАвторизации - Строка - см. функцию Модуль_МетодыAPI.ЗаголовокАвторизацииДиадок(ПараметрыСервиса);
//  КлючИБ - Строка - Токен авторизации информационной базы см. ЗначениеНастройки_ОблачныеНастройкиКлюч()
//
// Возвращаемое значение:
//  ОбработкаОбъект.КонтурДиадокАпдейтКлиент
//
Функция Модуль_АпдейтКлиент(ЗаголовокАвторизации = Неопределено, КлючИБ = Неопределено) Экспорт
	
	ПолноеИмяТипа = "DataProcessorObject.КонтурДиадокАпдейтКлиент";
	Если ЭтоВнешняяОбработка() Тогда
		ПолноеИмяТипа = "ExternalDataProcessorObject.КонтурДиадокАпдейтКлиент";
	КонецЕсли;
	
	Клиент = Новый(ПолноеИмяТипа);
	
	ПараметрыКлиента = Клиент.АпдейтКлиентПараметры();
	ПараметрыКлиента.Локация = АдресСервисаОбновлений() + "/1c";
	
	Если ЗначениеЗаполнено(ЗаголовокАвторизации) Тогда
		ПараметрыКлиента.Токен = ЗаголовокАвторизации;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючИБ) Тогда
		ПараметрыКлиента.КлючИБ = КлючИБ;
	КонецЕсли;
	
	Клиент.АпдейтКлиент(ПараметрыКлиента);
	
	НастройкиПрокси = ОбщиеНастройки_НастройкиПрокси();
	СессияЛок = Клиент.Сессия();
	СессияЛок.Прокси = НовыйИнтернетПрокси(НастройкиПрокси);
	ДополнитьСоответствие(СессияЛок.Заголовки, ДополнительныеЗаголовкиЗапросовHTTP());
	
	Возврат Клиент;
	
КонецФункции

