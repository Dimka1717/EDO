// Получает данные для заполнения меты неформализованных документов.
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - учетный документ, на основании которого формируется электронный документ
//  ТипЭД - Структура - описание типа электронного документа (см. Контракт_ТипЭлектронногоДокумента)
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - сведения об учетном документе:
//    * Дата - Дата - дата документа
//    * Номер - Строка - номер документа
//    * <дополнительные поля> - список полей зависит от типа ЭД
//
Функция Документы_МетаданныеНеформализованного(СсылкаНаОбъект, ТипЭД)
	
	Если Документы_ЭтоНеформализованныйСчетНаОплату(ТипЭД) Тогда
		
		Данные = СчетаНаОплату_Метаданные(СсылкаНаОбъект);
		
	ИначеЕсли Документы_ЭтоНеформализованныйАктСверки(ТипЭД) Тогда
		
		Данные = АктыСверок_Метаданные(СсылкаНаОбъект);
		
	ИначеЕсли Документы_ЭтоНеформализованныйАкт(ТипЭД)
		Или Документы_ЭтоНеформализованнаяНакладная(ТипЭД) Тогда
		
		Данные = ПередаточныеДокументы_Метаданные(СсылкаНаОбъект);
		
	Иначе // TypeNamedId = Nonformalized
		
		Данные = Новый Структура;
		Данные.Вставить("Номер", "");
		Данные.Вставить("Дата", Дата(1, 1, 1));
		ЗаполнитьЗначенияСвойств(Данные, СсылкаНаОбъект);
		
	КонецЕсли;
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_МетаданныеНеформализованногоБезопасно(СсылкаНаОбъект, ТипЭД)
	
	ЕстьОшибки = Ложь;
	
	Попытка
		
		Результат = Документы_МетаданныеНеформализованного(СсылкаНаОбъект, ТипЭД);
		
	Исключение
		
		ЕстьОшибки = Истина;
		Ошибка = ИнформацияОбОшибке();
		
	КонецПопытки;
	
	Если ЕстьОшибки Тогда
		
		Категория = Метрики_КатегорияОтправкаДокумента();
		Действие = "ПолучитьМету";
		
		ФорматОтправки = ФорматОтправкиПоТипуДокумента(ТипЭД);
		
		ДопКонтекст = Новый Соответствие;
		ДополнитьПеременныеМетрики_ОписаниеУчетногоДокумента(ДопКонтекст, СсылкаНаОбъект);
		ДополнитьПеременныеМетрики_ТипЭлектронногоДокумента(ДопКонтекст, ФорматОтправки);
		
		Метрика_ДобавитьОшибку(
			Категория,
			Действие,
			Ошибка,
			ДопКонтекст
		);
		
		Данные = Новый Структура;
		Данные.Вставить("Номер", "");
		Данные.Вставить("Дата", Дата(1, 1, 1));
		ЗаполнитьЗначенияСвойств(Данные, СсылкаНаОбъект);
		
		Результат = ФиксированныеДанные(Данные);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Устарела. Рекомендуется использовать следующие методы:
// * Для счетов на оплату - СчетаНаОплату_ПечатнаяФорма и СчетаНаОплату_Метаданные
// * Для актов сверок - АктыСверок_ПечатнаяФорма и АктыСверок_Метаданные
//
Функция ТиповойМодуль_СформироватьПечатнуюФорму(СсылкаНаОбъект, ИмяПечатнойФормы, ДополнительныеПараметры) Экспорт
	
	// Структура ДополнительныеПараметры должна иметь ключи: ПараметрыСогласования, ФИОПодписанта
	
	ДанныеПечатнойФормы = МенеджерИнтеграции_НеформализованныйКонтент(
		СсылкаНаОбъект,
		ИмяПечатнойФормы,
		ДополнительныеПараметры
	);
	
	Если Не ЗначениеЗаполнено(ДанныеПечатнойФормы) Тогда
		
		Ошибка = ПараметрыВСтроку(
			"Не удалось получить данные печатной формы (Ссылка = %1, ИмяПечатнойФормы = %2)",
			Строка(СсылкаНаОбъект),
			ИмяПечатнойФормы
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	// Структура результата должна иметь ключи: ИмяВременногоФайла, ИмяФайла
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
	ДанныеПечатнойФормы.Таблица.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
	ДанныеПечатнойФормы.Вставить("ИмяВременногоФайла", ИмяВременногоФайла);
	
	Возврат ДанныеПечатнойФормы;
	
КонецФункции

Функция ТиповойМодуль_СоздатьДокумент(Параметры) Экспорт
	
	ДополнительныеПараметрыПМ = Параметры.ДополнительныеПараметры;
	
	Результат = Новый Структура;
	Результат.Вставить("ОписаниеОшибки");
	Результат.Вставить("ОсновнойОбъект");
	
	ИдентификаторОперации = СвойствоСтруктуры(Параметры, "ИдентификаторОперации");
	Если Не ЗначениеЗаполнено(ИдентификаторОперации) Тогда
		// Для совместимости со старыми ПМ
		ИдентификаторОперации = СвойствоСтруктуры(ДополнительныеПараметрыПМ, "ВыбранныйВид");
	КонецЕсли;
	
	Документ = Параметры.Документ;
	
	Если Не ЗначениеЗаполнено(ИдентификаторОперации) Тогда
		
		ДокументФормализованный = Документ.Тип.Формализованный;
		Результат.ОписаниеОшибки = ТекстОшибки_НеУказаноПравилоСозданияДокументаУчета(ДокументФормализованный);
		
		Возврат Результат;
		
	КонецЕсли;
	
	Если Не ПодключаемыйМодуль_ИспользоватьФормуСозданияДокументов() Тогда
		
		НесопоставленнаяНоменклатура = Номенклатура_НесопоставленнаяНоменклатура(Документ);
		Если ЗначениеЗаполнено(НесопоставленнаяНоменклатура) Тогда
			Результат.Вставить("ТаблицаНоменклатурыДляСопоставления", НесопоставленнаяНоменклатура);
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	ФайлXML = Неопределено;
	
	Если НЕ Документ.СлужебнаяИнформация.Свойство("КонтентOCR", ФайлXML) Тогда
		
		Документы_ПроверитьЗаполнитьХранилищеКонтента(Документ);
		
		Контент = Документ.Документооборот.ХранилищеКонтента;
		ФайлXML = Контент.Данные;	
		
	КонецЕсли;
	
	ФорматЭД = ФорматОтправкиПоТипуДокумента(Документ.Тип);
	
	ПараметрыЗаполнения = ПараметрыЗаполненияДокументаИнформационнойБазы();
	ПараметрыЗаполнения.Контрагент = Документ.Отправитель.Организация;
	ПараметрыЗаполнения.Организация = Документ.Получатель.Организация;
	ПараметрыЗаполнения.ДокументОснование = СвойствоСтруктуры(ДополнительныеПараметрыПМ, "ДокументОснование");
	ПараметрыЗаполнения.ЦенаВключаетНДС = СвойствоСтруктуры(ДополнительныеПараметрыПМ, "ЦенаВключаетНДС", Ложь);
	
	Попытка
		
		Результат.ОсновнойОбъект = МенеджерИнтеграции_НовыйДокументИнформационнойБазы(
			ФайлXML,
			ИдентификаторОперации,
			ПараметрыЗаполнения,
			ФорматЭД
		);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ШаблонТекста = "Не удалось создать документ по выбранному правилу (%1): %2";
		
		Результат.ОписаниеОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонТекста,
			ИдентификаторОперации,
			КраткоеПредставлениеОшибки(Ошибка)
		);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстОшибки_НеУказаноПравилоСозданияДокументаУчета(ЭтоФормализованныйДокумент = Истина)
	
	ТекстУточнения = НСтр(
		"ru = 'Документ неформализованный.';
		|en = 'Документ неформализованный.'"
	);
	
	ТекстОшибки = НСтр(
		"ru = 'Для этого формата или типа документа нельзя создать документ.';
		|en = 'Для этого формата или типа документа нельзя создать документ.'"
	);
	
	ТекстРешения = НСтр(
		"ru = 'Сопоставьте документ вручную из карточки документа.';
		|en = 'Сопоставьте документ вручную из карточки документа.'"
	);
	
	Подстроки = Новый Массив;
	
	Если Не ЭтоФормализованныйДокумент Тогда
		Подстроки.Добавить(ТекстУточнения);
	КонецЕсли;
	
	Подстроки.Добавить(ТекстОшибки);
	Подстроки.Добавить(ТекстРешения);
	
	Разделитель = " ";
	Результат = СоединитьСтроку(Подстроки, Разделитель);
	
	Возврат Результат;
	
КонецФункции

// Группирует идентификаторы номенклатуры по владельцам.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - таблица сопоставления номенклатуры (см. Новый_ТаблицаСопоставленияНоменклатуры).
// 
// Возвращаемое значение:
//  Соответствие:
//    * Ключ - ЛюбаяСсылка- владелец номенклатуры.
//    * Значение - Массив - коллекция идентификаторов номенклатуры.
//
Функция ИдентификаторыНоменклатурыПоВладельцам(ТаблицаСопоставления)
	
	Результат = Новый Соответствие;
	
	Для Каждого Запись Из ТаблицаСопоставления Цикл
		
		НоменклатураКонтрагента = Запись.НоменклатураКонтрагента;
		ВладелецНоменклатуры = НоменклатураКонтрагента.Владелец;
		Идентификаторы = Результат.Получить(ВладелецНоменклатуры);
		
		Если Идентификаторы = Неопределено Тогда
			Идентификаторы = Новый Массив;
			Результат.Вставить(ВладелецНоменклатуры, Идентификаторы);
		КонецЕсли;
		
		Идентификаторы.Добавить(НоменклатураКонтрагента.Идентификатор);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Добавляет в таблицу сопоставления номенклатуры колонки со значениями ключевых полей.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
Процедура ДобавитьКлючевыеПоляНоменклатурыКонтрагентов(ТаблицаСопоставления)
	
	ТаблицаСопоставления.Колонки.Добавить("Владелец");
	ТаблицаСопоставления.Колонки.Добавить("Идентификатор");
	
	ИменаКлючевыхПолей = Номенклатура_ИменаКлючевыхПолейНоменклатурыКонтрагента();
	
	Для Каждого Запись Из ТаблицаСопоставления Цикл
		
		НоменклатураКонтрагента = Запись.НоменклатураКонтрагента;
		ЗаполнитьЗначенияСвойств(Запись, НоменклатураКонтрагента, ИменаКлючевыхПолей);
		
	КонецЦикла;
	
	ТаблицаСопоставления.Индексы.Добавить(ИменаКлючевыхПолей);
	
КонецПроцедуры

// Удаляет из таблицы сопоставления номенклатуры колонки со значениями ключевых полей.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - см. Новый_ТаблицаСопоставленияНоменклатуры.
//
Процедура УдалитьКлючевыеПоляНоменклатурыКонтрагентов(ТаблицаСопоставления)
	
	ТаблицаСопоставления.Колонки.Удалить("Владелец");
	ТаблицаСопоставления.Колонки.Удалить("Идентификатор");
	
КонецПроцедуры

// Получает сведения и сопоставлении номенклатуры контрагентов и номенклатуры информационной базы
// и заполняет в таблице сопоставления колонки "Номенклатура", "Характеристика" и "Упаковка".
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - таблица сопоставления номенклатуры (см. Новый_ТаблицаСопоставленияНоменклатуры).
//
Процедура ТиповойМодуль_ПрочитатьСопоставлениеНоменклатуры(ТаблицаСопоставления) Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьКлючевыеПоляНоменклатурыКонтрагентов(ТаблицаСопоставления);
	
	ИдентификаторыНоменклатуры = ИдентификаторыНоменклатурыПоВладельцам(ТаблицаСопоставления);
	
	ИменаКлючевыхПолей = Номенклатура_ИменаКлючевыхПолейНоменклатурыКонтрагента();
	ЕстьХарактеристика = ТаблицаСопоставления.Колонки.Найти("Характеристика") <> Неопределено;
	ЕстьУпаковка = ТаблицаСопоставления.Колонки.Найти("Упаковка") <> Неопределено;
	
	Для Каждого Элемент Из ИдентификаторыНоменклатуры Цикл
		
		ВладелецНоменклатуры = Элемент.Ключ;
		Идентификаторы = Элемент.Значение;
		
		СопоставленнаяНоменклатура = МенеджерИнтеграции_СопоставлениеНоменклатурыПрочитать(
			ВладелецНоменклатуры,
			Идентификаторы
		);
		
		Для Каждого СоответствиеНоменклатуры Из СопоставленнаяНоменклатура Цикл
			
			ТекущийИдентификатор = СоответствиеНоменклатуры.Ключ;
			НоменклатураИБ = СоответствиеНоменклатуры.Значение;
			
			Если Не ЗначениеЗаполнено(НоменклатураИБ) Тогда
				Продолжить;
			КонецЕсли;
			
			ПоляПоиска = Новый Структура(ИменаКлючевыхПолей);
			ПоляПоиска.Владелец = ВладелецНоменклатуры;
			ПоляПоиска.Идентификатор = ТекущийИдентификатор;
			
			НайденныеЗаписи = ТаблицаСопоставления.НайтиСтроки(ПоляПоиска);
			
			Для Каждого Запись Из НайденныеЗаписи Цикл
				
				Запись.Номенклатура = НоменклатураИБ.Номенклатура;
				
				Если ЕстьХарактеристика Тогда
					Запись.Характеристика = НоменклатураИБ.Характеристика;
				КонецЕсли;
				
				Если ЕстьУпаковка Тогда
					Запись.Упаковка = НоменклатураИБ.Упаковка;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	УдалитьКлючевыеПоляНоменклатурыКонтрагентов(ТаблицаСопоставления);
	
КонецПроцедуры

// Записывает соответствие между номенклатурой информационной базы и номенклатурой контрагента.
//
// Параметры:
//  ТаблицаСопоставления - ТаблицаЗначений - таблица сопоставления номенклатуры (см. Новый_ТаблицаСопоставленияНоменклатуры).
//
Процедура ТиповойМодуль_ЗаписатьСопоставлениеНоменклатуры(ТаблицаСопоставления) Экспорт
	
	Если Не ЕстьИнтеграционныйМодуль() Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьХарактеристика = ТаблицаСопоставления.Колонки.Найти("Характеристика") <> Неопределено;
	ЕстьУпаковка = ТаблицаСопоставления.Колонки.Найти("Упаковка") <> Неопределено;
	
	Характеристика = Неопределено;
	Упаковка = Неопределено;
	
	Для каждого Запись Из ТаблицаСопоставления Цикл
		
		Номенклатура = Запись.Номенклатура;
		
		Если ЕстьХарактеристика Тогда
			Характеристика = Запись.Характеристика;
		КонецЕсли;
		
		Если ЕстьУпаковка Тогда
			Упаковка = Запись.Упаковка;
		КонецЕсли;
		
		НоменклатураИБ = Новый_НоменклатураИнформационнойБазы(Номенклатура, Характеристика, Упаковка);
		
		МенеджерИнтеграции_СопоставлениеНоменклатурыЗаписать(
			Запись.НоменклатураКонтрагента,
			НоменклатураИБ
		);
		
	КонецЦикла; 
	
КонецПроцедуры

