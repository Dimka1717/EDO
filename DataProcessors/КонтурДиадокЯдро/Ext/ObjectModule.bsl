Функция Подписант_ИспользоватьДетальныеДанные(ТипКонтента)
	
	Результат = Ложь;
	
	Если НРег(ТипКонтента) = "utd"
		Или НРег(ТипКонтента) = "utd820"
		Или НРег(ТипКонтента) = "ucd"
		Или НРег(ТипКонтента) = "ucd736"
		Или НРег(ТипКонтента) = "rezru"
		Или НРег(ТипКонтента) = "tovtorg"
		Или НРег(ТипКонтента) = "torg2" Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ПредставлениеПодписанта(BoxId) Экспорт
	
	Сертификат	= КонтекстСеанса_Прочитать(BoxId, "Сертификат");
	Результат	= Сертификаты_ПредставлениеПодписанта(Сертификат);
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ЭтоСотрудникОрганизации(BoxId) Экспорт
	
	Результат = Ложь;
	
	Сертификат = КонтекстСеанса_Прочитать(BoxId, "Сертификат");
	
	Если Сертификат <> Неопределено Тогда
		
		ТипыСертификатовКЭП = Перечисление_ТипыСертификатовКЭП();
		
		Результат = Сертификат.Тип <> ТипыСертификатовКЭП.ИП;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_СПолномочиями(Документ, Сторона = "Продавец")
	
	BoxID = Документ.Идентификаторы.BoxID;
	
	ПолномочияПодписанта = Подписант_ОписаниеПолномочий(Документ, Сторона);
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	
	Если НРег(ТипКонтента) = "torg2" Тогда
		
		Результат = ГенерацияXML_ПолучитьПустуюПротоСтруктуру("Signer_Torg2");
		
		Если ПолномочияПодписанта <> Неопределено Тогда
			ЗаполнитьSignerTorg2(Результат.SignerDetails, ПолномочияПодписанта);
		КонецЕсли;
		
	Иначе
		
		Результат = ГенерацияXML_ПолучитьПустуюПротоСтруктуру("ExtendedSigner");
		
		Результат.BoxId = BoxID;
		
		ОтпечатокСертификата = КонтекстСеанса_Прочитать(BoxID, "ОтпечатокСертификата");
		Если ОтпечатокСертификата <> Неопределено Тогда
			Результат.CertificateThumbprint = ОтпечатокСертификата;
		КонецЕсли;
		
		ЗаполнитьExtendedSigner(BoxID, Результат.SignerDetails, ПолномочияПодписанта);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ЗаполненныйПодписантДляУПД970(Документ, Сторона = "Продавец")
	
	BoxId = Документ.Идентификаторы.BoxID;
	
	ПолномочияПодписанта = Подписант_ОписаниеПолномочий(Документ, Сторона);
	КонтрактМЧД = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	
	Сертификат = СтрокаКонтекста.Сертификат;
	ИННЯщика = СтрокаКонтекста.ИНН;
	
	ПередаватьМЧДФайлом = МЧД_ЗначениеНастройкиПередаватьМЧДФайломПоДокументу(Документ);
	
	ПараметрыФормирования = ГенерацияXML_Новый_ПараметрыФормированияSigner970(ПередаватьМЧДФайлом, ИННЯщика);
	
	Результат = ГенерацияXML_УПД970_ЗаполненныйSigner(ПолномочияПодписанта, Сертификат, КонтрактМЧД, ПараметрыФормирования);
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ОписаниеПолномочий(Документ, Сторона = "Продавец")
	
	Перем Результат;
	
	BoxID		= Документ.Идентификаторы.BoxID;
	ВидТитула	= Документы_ВидТитула(Документ.Тип.ТипКонтента);
	
	Перечисление_SignerType = АПИ_Перечисление_SignerType();
	
	ОписаниеПолномочийПодписанта = ПолномочияПодписанта_Получить(BoxID, ВидТитула, Сторона);
	
	Если ЗначениеЗаполнено(ОписаниеПолномочийПодписанта.Ошибки) Тогда
		Результат = Неопределено;
	Иначе
		Результат = ОписаниеПолномочийПодписанта.Данные;
	КонецЕсли;
	
	Если Результат <> Неопределено Тогда
		
		ТипыСертификатовКЭП		 = Перечисление_ТипыСертификатовКЭП();
		Сертификат				 = КонтекстСеанса_Прочитать(BoxId, "Сертификат");
		ТипСертификата			 = СвойствоСтруктуры(Сертификат, "Тип", ТипыСертификатовКЭП.ФЛ);
		SignerOrganizationName	 = СвойствоСтруктуры(Сертификат, "Организация", "");
		
		Если ТипСертификата = ТипыСертификатовКЭП.ФЛ Тогда
			
			ИННИзОрганизации = КонтекстСеанса_Прочитать(BoxID, "ИНН", "");
			ЭтоОрганизацияЮЛ = СтрДлина(ИННИзОрганизации) <> 12;
			
			Если ЭтоОрганизацияЮЛ Тогда
				SignerType	 = Перечисление_SignerType.LegalEntity;
			Иначе
				SignerType	 = Перечисление_SignerType.IndividualEntity;
			КонецЕсли;	
			
			SignerOrganizationName = КонтекстСеанса_Прочитать(BoxID, "ОрганизацияНаименование");
			
			Результат.Вставить("Inn", ИННИзОрганизации);
			
		ИначеЕсли ТипСертификата = ТипыСертификатовКЭП.ИП Тогда
			
			SignerType	 = Перечисление_SignerType.IndividualEntity;
			
		ИначеЕсли ТипСертификата = ТипыСертификатовКЭП.ЮЛ Тогда
			
			SignerType	 = Перечисление_SignerType.LegalEntity;
			
		Иначе
			
			SignerType	 = Перечисление_SignerType.IndividualEntity;
			
		КонецЕсли;
		
		Результат.SignerType = SignerType;
		Результат.Вставить("SignerOrganizationName", SignerOrganizationName);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение типа подписанта ExtendedSignerDetails.SignerType для ящика,
// при сохранении полномочий подписанта методом ExtendedSignerDetailsToPost
//
// Параметры:
//  BoxId - Строка - идентификатор ящика
// 
// Возвращаемое значение:
//  Строка - значение SignerType  
Функция ПолномочияПодписанта_SignerType(BoxId) Экспорт
	
	SignerType = АПИ_Перечисление_SignerType();
	
	Сертификат = КонтекстСеанса_Прочитать(BoxId, "Сертификат");
	
	Если Сертификат <> Неопределено Тогда
		
		ТипыСертификатовКЭП = Перечисление_ТипыСертификатовКЭП();
		
		Если Сертификат.Тип = ТипыСертификатовКЭП.ЮЛ Тогда
			Результат = SignerType.LegalEntity;
		ИначеЕсли Сертификат.Тип = ТипыСертификатовКЭП.ИП Тогда
			Результат = SignerType.IndividualEntity;
		ИначеЕсли Сертификат.Тип = ТипыСертификатовКЭП.ФЛ Тогда
			Результат = SignerType.PhysicalPerson;
		Иначе
			Результат = Неопределено;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьExtendedSigner(BoxID, SignerDetails, ПолномочияПодписанта)

	Если ПолномочияПодписанта = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	SignerDetails.Status			= ПолномочияПодписанта.SignerStatus;
	SignerDetails.SignerType		= ПолномочияПодписанта.SignerType;
	SignerDetails.Powers			= ПолномочияПодписанта.SignerPowers;
	SignerDetails.Surname 			= ПолномочияПодписанта.Surname;
	SignerDetails.FirstName			= ПолномочияПодписанта.FirstName;
	SignerDetails.Patronymic		= СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "Patronymic"));
	SignerDetails.Inn				= СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "Inn"));
	SignerDetails.JobTitle			= СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "JobTitle"));
	SignerDetails.PowersBase		= СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "SignerPowersBase"));
	SignerDetails.OrganizationName	= СокрЛП(СвойствоСтруктуры(ПолномочияПодписанта, "SignerOrganizationName"));
	
	Если НЕ ЗначениеЗаполнено(SignerDetails.OrganizationName) Тогда
		SignerDetails.OrganizationName = КонтекстСеанса_Прочитать(BoxID, "ОрганизацияНаименование");
	КонецЕсли;
	
	Если ПолномочияПодписанта.Свойство("SignerOrgPowersBase") 
		И ЗначениеЗаполнено(ПолномочияПодписанта.SignerOrgPowersBase) Тогда
		SignerDetails.OrganizationPowersBase = ПолномочияПодписанта.SignerOrgPowersBase;
	КонецЕсли;
	
	RegistrationCertificate = СвойствоСтруктуры(ПолномочияПодписанта, "RegistrationCertificate");
	Если RegistrationCertificate <> Неопределено Тогда
		SignerDetails.RegistrationCertificate = СокрЛП(RegistrationCertificate);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьSignerTorg2(SignerDetails, ПолномочияПодписанта)
	
	СоответствиеПолей = Новый Соответствие;
	СоответствиеПолей.Вставить("SignerStatus", "SignerStatus");
	СоответствиеПолей.Вставить("SignerType", "SignerType");
	СоответствиеПолей.Вставить("SignerPowers", "SignerPowers");
	СоответствиеПолей.Вставить("Surname", "LastName");
	СоответствиеПолей.Вставить("FirstName", "FirstName");
	СоответствиеПолей.Вставить("Patronymic", "MiddleName");
	СоответствиеПолей.Вставить("Inn", "Inn");
	СоответствиеПолей.Вставить("JobTitle", "Position");
	СоответствиеПолей.Вставить("SignerInfo", "SignerInfo");
	СоответствиеПолей.Вставить("SignerPowersBase", "SignerPowersBase");
	СоответствиеПолей.Вставить("SignerOrganizationName", "SignerOrganizationName");
	СоответствиеПолей.Вставить("RegistrationCertificate", "RegistrationCertificate");
	СоответствиеПолей.Вставить("SignerOrgPowersBase", "SignerOrgPowersBase");
	
	Для Каждого Элемент Из СоответствиеПолей Цикл
		
		Значение = Неопределено;
		Если ПолномочияПодписанта.Свойство(Элемент.Ключ, Значение) И ЗначениеЗаполнено(Значение) Тогда
			ИмяПоля = Элемент.Значение;
			SignerDetails[ИмяПоля] = Значение;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Подписант(BoxId)
	
	Результат = ГенерацияXML_ПолучитьПустуюПротоСтруктуру("Signer");
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	ОписаниеПользователя = СтрокаКонтекста.ОписаниеПользователя;
	ОрганизацияИНН = СтрокаКонтекста.Ящик.Организация.ИНН;
	ДлинаИННФЛ = 12;
	ЭтоЯщикИП = (СтрДлина(ОрганизацияИНН) = ДлинаИННФЛ);
	
	Результат.Surname = СокрЛП(ОписаниеПользователя.Фамилия);
	Результат.FirstName = СокрЛП(ОписаниеПользователя.Имя);
	Результат.Patronymic = СокрЛП(ОписаниеПользователя.Отчество);
	Результат.JobTitle = СокрЛП(ОписаниеПользователя.Должность);
	
	Результат.Inn = ОрганизацияИНН;
	Результат.IsSoleProprietor = ЭтоЯщикИП;
	Если ЭтоЯщикИП Тогда
		Результат.SoleProprietorRegistrationCertificate = СтрокаКонтекста.Ящик.Организация.ОГРН;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_АктСверки(Документ)
	
	Результат = ГенерацияXML_ПолучитьПустуюПротоСтруктуру("Signer_ReconciliationAct");
	
	BoxId = Документ.Идентификаторы.BoxId;
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	ОписаниеПользователя = СтрокаКонтекста.ОписаниеПользователя;
	
	Результат.JobTitle				= ОписаниеПользователя.Должность;
	Результат.Official.Surname		= ОписаниеПользователя.Фамилия;
	Результат.Official.FirstName	= ОписаниеПользователя.Имя;
	Результат.Official.Patronymic	= ОписаниеПользователя.Отчество;
	
	Сертификат = СтрокаКонтекста.Сертификат;
	Если ЗначениеЗаполнено(Сертификат)
		И Сертификат.ЭтоКЭП Тогда
		Результат.SignatureType = "EnhancedQualifiedSignature";
	КонецЕсли;
	
	Результат.IdSystemStorage = "1"; // Так как все наши доверки хранятся в Контур.Доверенности то значение всегда = "1"
	
	ДанныеДоверенности = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
	
	Если ЗначениеЗаполнено(ДанныеДоверенности) Тогда
		
		Результат.DigitalAttorneyInfo.Number = ДанныеДоверенности.Идентификатор;
		Результат.DigitalAttorneyInfo.Date = ДанныеДоверенности.ДатаНачалаДействия;
		Результат.DigitalAttorneyInfo.CancelAdditionalInfo = "1"; // Так как все наши доверки хранятся в Контур.Доверенности то значение всегда = "1"
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

