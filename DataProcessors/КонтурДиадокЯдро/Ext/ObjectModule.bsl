// Возвращает из истории по документу события с МЧД
//
// Параметры:
//  ИдентификаторыДокумента	 - Структура - идентификаторы документа
//		BoxId - Строка - идентификатор ящика
//		LetterId - Строка - идентификатор сообщения (пакета)
//		DocumentId - Строка - идентификатор документа
// 
// Возвращаемое значение:
//  Массив - массив структур событиий с данными МЧД
//
Функция Документы_СобытияМЧД(Идентификаторы) Экспорт
	
	ТипВложения			 = АПИ_Перечисление_AttachmentType();
	УровниКритичности	 = Контракт_УровниКритичностиСтатусаДокумента();
	
	BoxId		= Идентификаторы.BoxId;
	LetterId	= Идентификаторы.LetterId;
	DocumentId	= Идентификаторы.DocumentId;
	
	ПараметрыСервиса= ПараметрыСервиса_Диадок(BoxId);
	Message			= АПИ_GetMessage(ПараметрыСервиса, BoxId, LetterId, DocumentId, , Истина);
	MessageId		= СвойствоСтруктуры(Message, "MessageId");
	SortedEntities	= МассивСтруктур_Сортировать(Message.Entities, "RawCreationDate, EntityType");
	
	Результат = Новый_ТаблицаСобытийМЧД();
	
	Для Каждого Entity Из SortedEntities Цикл
		
		AttachmentType = СвойствоСтруктуры(Entity, "AttachmentType");
		
		Если AttachmentType = ТипВложения.PowerOfAttorney Тогда
			
			Событие = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(Событие, Entity);
			Событие.Дата			 = МестноеВремя(Ticks_2_Date(Событие.RawCreationDate));
			Событие.BoxId		 	 = BoxId;
			Событие.MessageId		 = MessageId;
			
			Если ЗначениеЗаполнено(Событие.ParentEntityId) Тогда
				
				ПодписьEntityId = МассивСтруктур_Найти(SortedEntities, Событие.ParentEntityId, "EntityId");
				
				Если ПодписьEntityId <> Неопределено И ЗначениеЗаполнено(ПодписьEntityId.ParentEntityId) Тогда
					
					ДокументEntityId = МассивСтруктур_Найти(SortedEntities, ПодписьEntityId.ParentEntityId, "EntityId");
					
					Если ДокументEntityId <> Неопределено Тогда
						
						Если ЗначениеЗаполнено(ДокументEntityId.ParentEntityId) Тогда
							ДокументParent = МассивСтруктур_Найти(SortedEntities, ДокументEntityId.ParentEntityId, "EntityId");
							ParentAttachmentType = СвойствоСтруктуры(ДокументParent, "AttachmentType");
						Иначе
							ParentAttachmentType = Неопределено;
						КонецЕсли;
						
						Событие.Описание = ОписаниеСобытияМЧД(ДокументEntityId.AttachmentType, ParentAttachmentType);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
			ИнформацияОДоверенности	= АПИ_GetPowerOfAttorneyInfo(ПараметрыСервиса, BoxId, MessageId, Entity.EntityId);
			
			Если НЕ ЗначениеЗаполнено(ИнформацияОДоверенности.Идентификатор) Тогда
				PowerOfAttorneyInfo = СвойствоСтруктуры(Entity, "PowerOfAttorneyInfo");
				Если НЕ PowerOfAttorneyInfo = Неопределено Тогда
					Идентификатор = "";
					ИНН = "";
					
					FullId = СвойствоСтруктуры(PowerOfAttorneyInfo, "FullId");
					Если НЕ FullId = Неопределено Тогда
						Идентификатор = СвойствоСтруктуры(FullId, "RegistrationNumber");
						ИНН = СвойствоСтруктуры(FullId, "issuerInn"); 
					КонецЕсли;
					
					ИнформацияОДоверенности.Идентификатор = Идентификатор;
					ИнформацияОДоверенности.Доверитель.ИНН = ИНН;
				КонецЕсли;
			КонецЕсли;
			
			Событие.ИнформацияОДоверенности	= ИнформацияОДоверенности;
			Событие.ЕстьДелегированныеМЧД = ИнформацияОДоверенности.ДелегированныеМЧД.Количество() > 0;
			
		ИначеЕсли AttachmentType = ТипВложения.PowerOfAttorneyStatus Тогда
			
			МЧДEntityId = СвойствоСтруктуры(Entity, "ParentEntityId");
			
			Событие = Результат.Найти(МЧДEntityId, "EntityId");
			Если Событие <> Неопределено Тогда
				
				ИнформацияМЧД = СвойствоСтруктуры(Entity, "PowerOfAttorneyInfo");
				Если ИнформацияМЧД <> Неопределено Тогда
					
					СпособПередачиМЧД = СвойствоСтруктуры(ИнформацияМЧД, "SendingType");
					
					Событие.МЧДПереданаФайлом = (НРег(СпособПередачиМЧД) = "file"); 
					
					СтатусМЧД = СвойствоСтруктуры(ИнформацияМЧД, "Status");
					Если СтатусМЧД = Неопределено Тогда
						СтатусМЧД = СвойствоСтруктуры(ИнформацияМЧД, "SendingStatus");
					КонецЕсли;
					
					Если СтатусМЧД <> Неопределено Тогда
						
						ОписанияПроверокМЧД				 = Новый Массив;
						Событие.ЕстьОшибкаПроверкиМЧД	 = СвойствоСтруктуры(СтатусМЧД, "Severity", "") = УровниКритичности.Error;
						
						Если Событие.ЕстьОшибкаПроверкиМЧД Тогда
							
							ДетализацияСтатуса	 = СвойствоСтруктуры(СтатусМЧД, "Errors ", Новый Массив); 
							Если ЗначениеЗаполнено(ДетализацияСтатуса) Тогда
								ОписанияПроверокМЧД = ВыгрузитьКолонку(ДетализацияСтатуса, "Text", Истина);
							КонецЕсли;
							
						КонецЕсли;
						
						Событие.ОписанияПроверокМЧД = СписокОшибокВалидацииМЧД(СтатусМЧД);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Сортировать("RawCreationDate");
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеСобытияМЧД(AttachmentType, ParentAttachmentType)
	
	ТипВложения = АПИ_Перечисление_AttachmentType();
	
	Результат = "";
	
	Если AttachmentType = ТипВложения.RevocationRequest Тогда
		
		Результат = "Использовалась при аннулировании";
		
	ИначеЕсли AttachmentType = ТипВложения.InvoiceCorrectionRequest Тогда
		
		Результат = "Использовалась при запросе уточнения";
		
	ИначеЕсли AttachmentType = ТипВложения.InvoiceReceipt 
		ИЛИ AttachmentType = ТипВложения.Receipt Тогда
		
		Результат = "Использовалась при подписании извещения о получении";
		
	ИначеЕсли AttachmentType = ТипВложения.XmlSignatureRejection 
		И ParentAttachmentType = ТипВложения.RevocationRequest Тогда
		
		Результат = "Использовалась при отказе в аннулировании";
		
	ИначеЕсли AttachmentType = ТипВложения.XmlSignatureRejection
		ИЛИ AttachmentType = ТипВложения.SignatureRequestRejection
		ИЛИ AttachmentType = ТипВложения.ResolutionRequestDenial Тогда
		
		Результат = "Использовалась при отказе в подписи";		
		
	Иначе
		
		Результат = "Использовалась при подписании документа";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеСобытияПодписи(AttachmentType, ParentAttachmentType)
	
	ТипВложения = АПИ_Перечисление_AttachmentType();
	
	Результат = "";
	
	Если AttachmentType = ТипВложения.RevocationRequest Тогда
		
		Результат = "Аннулирование";
		
	ИначеЕсли AttachmentType = ТипВложения.InvoiceCorrectionRequest Тогда
		
		Результат = "Запрос уточнения";
		
	ИначеЕсли AttachmentType = ТипВложения.InvoiceReceipt
		ИЛИ AttachmentType = ТипВложения.Receipt Тогда
		
		Результат = "Подписание извещения о получении";
		
	ИначеЕсли AttachmentType = ТипВложения.XmlSignatureRejection
		И ParentAttachmentType = ТипВложения.RevocationRequest Тогда
		
		Результат = "Отказ в аннулировании";
		
	ИначеЕсли AttachmentType = ТипВложения.XmlSignatureRejection
		ИЛИ AttachmentType = ТипВложения.SignatureRequestRejection
		ИЛИ AttachmentType = ТипВложения.ResolutionRequestDenial Тогда
		
		Результат = "Отказ в подписи";
		
	Иначе
		
		Результат = "Подписание документа";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ТаблицаСобытийМЧД()
	
	ОписаниеТипаСтрока = Новый ОписаниеТипов("Строка");
	ОписаниеТипаДата = Новый ОписаниеТипов("Дата");
	ОписаниеТипаБулево = Новый ОписаниеТипов("Булево");
	ОписаниеТипаМассив = Новый ОписаниеТипов("Массив");
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("EntityId", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("ParentEntityId", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("MessageId", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("RawCreationDate", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("AttachmentType", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("Дата", ОписаниеТипаДата);
	Результат.Колонки.Добавить("BoxId", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("Описание", ОписаниеТипаСтрока);

	Результат.Колонки.Добавить("ИнформацияОДоверенности");
	Результат.Колонки.Добавить("ЕстьОшибкаПроверкиМЧД", ОписаниеТипаБулево);
	Результат.Колонки.Добавить("ОписанияПроверокМЧД", ОписаниеТипаМассив);
	Результат.Колонки.Добавить("МЧДПереданаФайлом", ОписаниеТипаБулево);
	Результат.Колонки.Добавить("ЕстьДелегированныеМЧД", ОписаниеТипаБулево);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СобытияМЧД_ДоверительПредставитель(ИнформацияОДоверенности)
	
	ПредставительИНН = СвойствоСтруктуры(ИнформацияОДоверенности.Представитель, "ИНН", """");
	ДоверительИНН = СвойствоСтруктуры(ИнформацияОДоверенности.Доверитель, "ИНН", """");
	ПредставительНаименование = ИнформацияОДоверенности.Представитель.Наименование;
	Идентификатор = ИнформацияОДоверенности.Идентификатор;
	ДоверительНаименование = ИнформацияОДоверенности.Доверитель.Наименование;
	
	ПредставлениеИННПредставителя = "";
	Если ЗначениеЗаполнено(ПредставительИНН) Тогда
		ПредставлениеИННПредставителя = " (" + ПредставительИНН + ")";
	КонецЕсли;
	
	ПредставлениеИННДоверителя = "";
	Если ЗначениеЗаполнено(ДоверительИНН) Тогда
		ПредставлениеИННДоверителя = " (" + ДоверительИНН + ")";
	КонецЕсли;
	
	СтрокиДоверенности = Новый Массив;
	СтрокиДоверенности.Добавить("Доверенность " + Идентификатор);
	СтрокиДоверенности.Добавить(ПредставительНаименование + ПредставлениеИННПредставителя);
	СтрокиДоверенности.Добавить(ДоверительНаименование + ПредставлениеИННДоверителя);
	
	Результат = СоединитьСтроку(СтрокиДоверенности, ", ");
	
	Возврат Результат;
	
КонецФункции

