Процедура КонтурЛогистика_УдалитьИзСпискаПеревозочныеДокументы(СписокДокументов)
	
	// Временная логика
	
	СтрокиДляУдаления = Новый Массив;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		
		ТипДокумента = НРег(СтрокаСписка.ТипДокумента);
		
		ПрефиксДокументовЛогистики = "logistics";
		ДлинаПрефикса = СтрДлина(ПрефиксДокументовЛогистики);
		
		Если Лев(ТипДокумента, ДлинаПрефикса) = ПрефиксДокументовЛогистики
			ИЛИ ТипДокумента = НРег("XmlForwardingReceipt") Тогда
			
			СтрокиДляУдаления.Добавить(СтрокаСписка);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокаСписка Из СтрокиДляУдаления Цикл
		СписокДокументов.Удалить(СтрокаСписка);
	КонецЦикла;
	
КонецПроцедуры

// Возвращает коллекцию учетных документов пакета с найденными для них документами-основаниями
//
// Параметры:
//  Пакет	 - Структура	 - см. фукнцию Контракт_Пакет() 
// 
// Возвращаемое значение:
//  Массив - Коллекция учетных документов пакета с документами-основаниями
//
Функция Пакеты_УчетныеДокументыСОснованиями(Пакет) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДокументУчета = Документ.ДокументУчета;
		
		Если ЗначениеЗаполнено(ДокументУчета) Тогда
			
			Результат.Добавить(ДокументУчета);
			ДокументыОснований = МенеджерИнтеграции_ОснованияДокументаУчета(ДокументУчета);
			ДополнитьМассив(Результат, ДокументыОснований, Истина);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

