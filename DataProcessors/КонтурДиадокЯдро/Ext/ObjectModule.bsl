Функция ТипыДокументовAPI_ГруппировкаДляТипа(TypeNamedId)
	
	Если Найти(TypeNamedId, "Acceptance") > 0 Тогда
		Результат = "Акты";
	ИначеЕсли Найти(TypeNamedId, "Torg") > 0 Тогда
		Результат = "Накладные";
	ИначеЕсли Найти(TypeNamedId, "ProformaInvoice") > 0 Тогда
		Результат = "Счета на оплату";
	ИначеЕсли Найти(TypeNamedId, "Invoice") > 0 Тогда
		Результат = "Счета-фактуры";
	ИначеЕсли Найти(TypeNamedId, "Universal") > 0 Тогда
		Результат = "УПД / УКД";
	ИначеЕсли Найти(TypeNamedId, "ReconciliationAct") > 0 Тогда
		Результат = "Акты сверки";
	Иначе
		Результат = "Прочее";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

