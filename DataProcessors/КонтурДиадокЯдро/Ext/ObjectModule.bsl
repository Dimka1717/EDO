// Возвращает версию режима совместимости конфигурации в формате "РР.ПП.ВВ",
// где РР - номер редакции, ПП - номер подредакции, ВВ - номер версии
// 
// Возвращаемое значение:
//  Строка - режим совместимости конфигурации.
// 
// Пример:
//  ВерсияРежимаСовместимостиЛок() = "8.3.27"
//
Функция ВерсияРежимаСовместимостиЛок()
	
	МаксИндекс = 2;
	
	Если Метаданные.РежимСовместимости = Метаданные.СвойстваОбъектов.РежимСовместимости.НеИспользовать Тогда
		
		Инфо = Новый СистемнаяИнформация;
		Подстроки = РазделитьСтрокуЛок(Инфо.ВерсияПриложения, ".");
		Пока Подстроки.ВГраница() > МаксИндекс Цикл
			Подстроки.Удалить(Подстроки.ВГраница());
		КонецЦикла;
		
	Иначе
		
		НомерРедакции = "8";
		РежимСовместимостиСтрокой = Строка(Метаданные.РежимСовместимости); // строка вида "Версия8_3_25" или "Version8_3_25"
		Подстроки = РазделитьСтрокуЛок(РежимСовместимостиСтрокой, "_");
		Подстроки[0] = НомерРедакции;
		
		Пока Подстроки.ВГраница() < МаксИндекс Цикл
			Подстроки.Добавить("0");
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СоединитьСтроку(Подстроки, ".");
	
КонецФункции

