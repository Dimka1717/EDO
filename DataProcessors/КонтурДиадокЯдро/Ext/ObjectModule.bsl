КонецФункции

Функция Документы_ПровестиАнализВходящегоПакета(ПакетЭДО) Экспорт
	
	Результат = Истина;
	
	ДокументыПакета = Новый ТаблицаЗначений;
	ДокументыПакета.Колонки.Добавить("Ссылка");
	ДокументыПакета.Колонки.Добавить("ТипДокумента");
	ДокументыПакета.Колонки.Добавить("ДатаДокумента");
	ДокументыПакета.Колонки.Добавить("НомерДокумента");
	
	Пакет = Пакеты_СохраненныйПакет(ПакетЭДО);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		РезультатАнализа = Документы_ПровестиАнализВходящегоДокумента(Документ);
		Результат = Результат И ЗначениеЗаполнено(РезультатАнализа);
		
		НоваяСтрока = ДокументыПакета.Добавить();
		НоваяСтрока.Ссылка			= Документ.Идентификаторы.ДокументЭДО;
		НоваяСтрока.ТипДокумента	= Документ.Тип.ТипДокумента;
		НоваяСтрока.ДатаДокумента	= Документ.Реквизиты.Дата;
		НоваяСтрока.НомерДокумента	= Документ.Реквизиты.Номер;
		
	КонецЦикла;
	
	Если Результат Тогда
		
		Попытка
			
			ПараметрыПМ = Новый Структура;
			ПараметрыПМ.Вставить("Пакет",			ПакетЭДО);
			ПараметрыПМ.Вставить("ДокументыПакета",	ДокументыПакета);
			
			ПодключаемыйМодуль_ОбработатьСобытие("ПослеАнализаПакета", ПараметрыПМ);
			
		Исключение
			
			ВидОперации	 	= НСтр("ru = 'Проведение анализа пакета'");
			ТекстОшибки	 	= ОписаниеОшибки();
			ТекстСообщения	= НСтр("ru = 'Не удалось провести анализ пакета с кодом '") + Строка(ПакетЭДО);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, , ТекстСообщения);
			
			Результат = Ложь;

		КонецПопытки;
		
	КонецЕсли;
	
	КатегорияМетрики	= Метрика_НазваниеКатегории().ДействиеВоВходящих;
	ДействиеМетрики		= "Выполнить анализ";
	
	МассивПакетаМетрики = Новый Массив;
	МассивПакетаМетрики.Добавить(Пакет);

	Метрика_ДобавитьСтатистику_МассовоеДействиеПоДокументам(КатегорияМетрики, ДействиеМетрики, МассивПакетаМетрики);
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПровестиАнализВходящихПакетов(ПакетыЭДО) Экспорт
	
	Результат = Новый Массив;
	Для каждого ПакетЭДО Из ПакетыЭДО Цикл
	
		РезультатПоПакетЭДО = Документы_ПровестиАнализВходящегоПакета(ПакетЭДО);
		Результат.Добавить(РезультатПоПакетЭДО);
		
	КонецЦикла;
	
