// Возможные значения результатов проверки контрольной суммы файла модуля.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура.
//
Функция Перечисление_РезультатПроверкиКонтрольнойСуммыФайлаМодуля()
	
	ВозможныеЗначения = Новый Структура;
	ВозможныеЗначения.Вставить(ЗначениеКонтрольнаяСуммаВалидна(), ЗначениеКонтрольнаяСуммаВалидна());
	ВозможныеЗначения.Вставить(ЗначениеКонтрольнаяСуммаНевалидна(), ЗначениеКонтрольнаяСуммаНевалидна());
	ВозможныеЗначения.Вставить(ЗначениеКонтрольнаяСуммаОшибкаПроверки(), ЗначениеКонтрольнаяСуммаОшибкаПроверки());
	ВозможныеЗначения.Вставить(ЗначениеКонтрольнаяСуммаОшибкаПолучения(), ЗначениеКонтрольнаяСуммаОшибкаПолучения());
	
	Результат = Новый ФиксированнаяСтруктура(ВозможныеЗначения);
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыУстановить(Значение)
	
	КлючКэш = "РезультатПроверкиКонтрольнойСуммы";
	Кэш_Поместить(КлючКэш, Значение);
	
КонецПроцедуры

// Возвращает результат проверки контрольной суммы файла модуля.
// 
// Возвращаемое значение:
//  Строка - результат проверки (см. Перечисление_РезультатПроверкиКонтрольнойСуммыФайлаМодуля)
//
Функция ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммы() Экспорт
	
	КлючКэш = "РезультатПроверкиКонтрольнойСуммы";
	Результат = Кэш_Прочитать(КлючКэш);
	
	Возврат Результат;
	
КонецФункции

// Вычисляет контрольную сумму файла модуля и проверяет её наличие в списке опубликованных версий.
// Результат проверки помещается в кэш (см. Перечисление_РезультатПроверкиКонтрольнойСуммыФайлаМодуля).
//
// Параметры:
//  ДвоичныеДанныеИлиАдрес - ДвоичныеДанные - файл внешней обработки;
//                         - Строка - адрес файла внешней обработки во временном хранилище;
//                         - Неопределено - если не удалось получить файл внешней обработки.
//
// @СлужебныйПрограммныйИнтерфейс
//
Процедура ОбновлениеМодуля_ПроверитьУстановитьПризнакМодульДоработан(ДвоичныеДанныеИлиАдрес, МестоположениеМодуля) Экспорт
	
	КэшированноеЗначение = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммы();
	
	Если ЗначениеЗаполнено(КэшированноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыМестоположений = Перечисление_МестоположенияМодуля();
	Если МестоположениеМодуля = ВариантыМестоположений.РасширениеКонфигурации Тогда
		РезультатПроверки = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыРасширенияКонфигурации();	
	Иначе
		РезультатПроверки = ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыФайлаВнешнейОбработки(ДвоичныеДанныеИлиАдрес);
	КонецЕсли;
	
	ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыУстановить(РезультатПроверки);
	
КонецПроцедуры

Функция ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыРасширенияКонфигурации()
		
	ХэшИсходный = ОбновлениеМодуля_ХэшСуммаРасширенияВСервисеОбновлений();
	
	РасширениеКонфигурации = РасширениеКонфигурацииКонтурДиадок();
 		
	ХэшРасширения = Base64Строка(РасширениеКонфигурации.ХешСумма);
	
	Результат = ОбновлениеМодуля_ПроверитьКонтрольнуюСумму(ХэшРасширения, ХэшИсходный);
	
	Возврат Результат;
	
КонецФункции

Функция ОбновлениеМодуля_РезультатПроверкиКонтрольнойСуммыФайлаВнешнейОбработки(ДвоичныеДанныеИлиАдрес)
	
	Если ТипЗнч(ДвоичныеДанныеИлиАдрес) = Тип("ДвоичныеДанные") Тогда
		ДвоичныеДанныеФайла = ДвоичныеДанныеИлиАдрес;
	ИначеЕсли ЭтоАдресИзВременногоХранилища(ДвоичныеДанныеИлиАдрес) Тогда
		ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(ДвоичныеДанныеИлиАдрес);
	Иначе
		ДвоичныеДанныеФайла = Неопределено;
	КонецЕсли;
	
	Если ДвоичныеДанныеФайла = Неопределено Тогда
		
		Результат = ЗначениеКонтрольнаяСуммаОшибкаПолучения();
		
	Иначе
		
		ХэшИсходный = ОбновлениеМодуля_ХэшСуммаВнешниеОбработкиВСервисеОбновлений();
		
		ХэшМодуля = Хэш_Рассчитать(ДвоичныеДанныеФайла, "MD5");
		
		Результат = ОбновлениеМодуля_ПроверитьКонтрольнуюСумму(ХэшМодуля, ХэшИсходный);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновлениеМодуля_ПроверитьКонтрольнуюСумму(ХэшМодуля, ХэшИсходный)

	Если Не ЗначениеЗаполнено(ХэшМодуля) Тогда
		Результат = ЗначениеКонтрольнаяСуммаОшибкаПолучения();
	ИначеЕсли Не ЗначениеЗаполнено(ХэшИсходный) Тогда
		Результат = ЗначениеКонтрольнаяСуммаОшибкаПроверки();
	ИначеЕсли ХэшМодуля = ХэшИсходный Тогда
		Результат = ЗначениеКонтрольнаяСуммаВалидна();
	Иначе
		Результат = ЗначениеКонтрольнаяСуммаНевалидна();
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция ОбновлениеМодуля_ХэшСуммаВнешниеОбработкиВСервисеОбновлений()
	
	Результат = "";
	
	ВерсияМодуля = ОбщийКонтекст_Прочитать("ВерсияМодуля");
	
	ТипыКонтентаАПИ = АПИ_СервисОбновлений_ТипыКонтентов();
	
	Попытка
		ОписаниеКонтентаАПИ = АПИ_СервисОбновлений_ОписаниеКонтентаМодуля(ВерсияМодуля, ТипыКонтентаАПИ.epf);
	Исключение
		Ошибка_Обработать("ОбновлениеМодуля", ОписаниеОшибки());
		ОписаниеКонтентаАПИ = Неопределено;
	КонецПопытки;
		
	Если ОписаниеКонтентаАПИ <> Неопределено Тогда
		Результат = ВРЕГ(ОписаниеКонтентаАПИ.md5hash);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновлениеМодуля_ХэшСуммаРасширенияВСервисеОбновлений()
	
	Результат = "";
	
	ВерсияМодуля = ОбщийКонтекст_Прочитать("ВерсияМодуля");
	
	ТипыКонтентаАПИ = АПИ_СервисОбновлений_ТипыКонтентов();
	
	Попытка
		ОписаниеКонтентаАПИ = АПИ_СервисОбновлений_ОписаниеКонтентаМодуля(ВерсияМодуля, ТипыКонтентаАПИ.cfe);
	Исключение
		Ошибка_Обработать("ОбновлениеМодуля", ОписаниеОшибки());
		ОписаниеКонтентаАПИ = Неопределено;
	КонецПопытки;
		
	Если ОписаниеКонтентаАПИ <> Неопределено Тогда
		Результат = ОписаниеКонтентаАПИ.src_checksum;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция ОбновлениеМодуля_СписокТиповыхВерсий()
	
	Результат = Неопределено;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	
	Попытка
		
		ДанныеФайла = КонтурАПИ_АктуальнойВерсииМодуля(ПараметрыСервиса);
		ДанныеФайлаXDTO = ГенерацияXML_XML_В_ОбъектXDTO(ДанныеФайла);
		Результат = ДанныеФайлаXDTO.Old.ProS["Pro"];
		
	Исключение
		
		Ошибка_Обработать("ОшибкаПолученияФайла", ОписаниеОшибки());
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновлениеМодуля_НаличиеОбновления(ТекущаяВерсияМодуля) Экспорт
	
	Результат = Ложь;
	
	АктуальнаяВерсияМодуля = ОбновленияМодуля_АктуальнаяВерсия();
	
	Если АктуальнаяВерсияМодуля <> "0.0.0" Тогда 
		
		Если СравнитьВерсии(АктуальнаяВерсияМодуля, ТекущаяВерсияМодуля) > 0 Тогда 
			Результат = Истина;
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_АктуальнаяВерсия(ПроверятьНаличиеНезаблокированныхОрганизаций = Истина) Экспорт
	
	Результат = "0.0.0";
	
	Если ПроверятьНаличиеНезаблокированныхОрганизаций Тогда
		ЕстьНезаблокированныеОрганизации = ЗаблокированныеОрганизации_Наличие(Ложь);
	Иначе
		ЕстьНезаблокированныеОрганизации = Истина;
	КонецЕсли;
	
	Если ЕстьНезаблокированныеОрганизации Тогда 
		АктуальнаяВерсия	= ОбновленияМодуля_ПрочитатьВерсию();
		Результат			= СтрЗаменить(АктуальнаяВерсия, "_", ".");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_ПрочитатьВерсию()
	
	Результат = 0;
	
	Попытка
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок();

		ДанныеФайла		= КонтурАПИ_АктуальнойВерсииМодуля(ПараметрыСервиса);
		ДанныеФайлаXDTO	= ГенерацияXML_XML_В_ОбъектXDTO(ДанныеФайла);
		
		Результат = ДанныеФайлаXDTO.Active["Pro"].version;
		
	Исключение
		Ошибка_Обработать("ОшибкаПолученияФайла", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_Файл(ИмяФайлаОбновления) Экспорт

	Результат = Неопределено;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок();
	
	Результат = КонтурАПИ_ФайлАктуальнойВерсииМодуля(ПараметрыСервиса, ИмяФайлаОбновления);
		
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_ПодходящаяВнешняяОбработка(ТекущаяВерсия) Экспорт
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Результат = "";
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.ДополнительныеОтчетыИОбработки") 
		И ПроверитьНаличиеОбъектаМетаданных("Справочники.ДополнительныеОтчетыИОбработки.Реквизиты.ИмяОбъекта") Тогда 
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВнешниеОбработки.Ссылка КАК ПодходящаяВерсияМодуля
		|ИЗ
		|	Справочник.ДополнительныеОтчетыИОбработки КАК ВнешниеОбработки
		|ГДЕ
		|	ВнешниеОбработки.Публикация = ЗНАЧЕНИЕ(Перечисление.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется)
		|	И ВнешниеОбработки.ИмяОбъекта ПОДОБНО ""КонтурЭДО""
		|	И ВнешниеОбработки.Версия = &Версия
		|	И НЕ ВнешниеОбработки.ПометкаУдаления");
		
		Запрос.УстановитьПараметр("Версия", ТекущаяВерсия);
		
	ИначеЕсли ПроверитьНаличиеОбъектаМетаданных("Справочники.ВнешниеОбработки") Тогда 
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВнешниеОбработки.Ссылка КАК ПодходящаяВерсияМодуля
		|ИЗ
		|	Справочник.ВнешниеОбработки КАК ВнешниеОбработки
		|ГДЕ
		|	ВнешниеОбработки.ВидОбработки = ЗНАЧЕНИЕ(Перечисление.ВидыДополнительныхВнешнихОбработок.Обработка)
		|	И (ВнешниеОбработки.Наименование В (&СинонимыМодуля)
		|			ИЛИ ВнешниеОбработки.КомментарийКФайлуИсточнику ПОДОБНО ""%Diadoc%"")
		|	И НЕ ВнешниеОбработки.ПометкаУдаления");
		
		Запрос.УстановитьПараметр("СинонимыМодуля", ОбновленияМодуля_СинонимыМодуля());
		
	Иначе
		
		Возврат Результат;	
		
	КонецЕсли;	
	
	ПодходящиеВерсии = Новый Массив;
	
	НаименованияМодуля = ОбновленияМодуля_НаименованияМодуля();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ДвоичныеДанные		 	= ОбновленияМодуля_ДвоичныеДанныеВнешнейОбработки(Выборка.ПодходящаяВерсияМодуля);
			СведенияОбОбработке	 	= ОбновленияМодуля_СведенияОВнешнейОбработкеИзФайла(ДвоичныеДанные);
			НаименованиеОбработки 	= СведенияОбОбработке.Наименование;
			ВерсияОбработки		 	= СведенияОбОбработке.Версия;
		Исключение
			Ошибка_Обработать("ОшибкаПолученияФайла", ОписаниеОшибки());
			Продолжить;
		КонецПопытки;
		
		СовпадаютВерсии = ( ВерсияОбработки = ТекущаяВерсия );
		СовпадаютНаименования = ( НаименованияМодуля.Найти(НаименованиеОбработки) <> Неопределено );
		
		Если СовпадаютВерсии И СовпадаютНаименования Тогда
			ПодходящиеВерсии.Добавить(Выборка.ПодходящаяВерсияМодуля);
		КонецЕсли;
		
	КонецЦикла;
	
	КоличествоОбработок = ПодходящиеВерсии.Количество();
	
	Если КоличествоОбработок = 1 Тогда
		Результат = ПодходящиеВерсии[0];
	ИначеЕсли КоличествоОбработок > 1 Тогда
		Метрика_ДобавитьОшибку_ПоискПодходящейВнешнейОбработки(КоличествоОбработок);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_СинонимыМодуля()
	
	Результат = Новый Массив;
	
	Результат.Добавить("Диадок Про");
	Результат.Добавить("Контур.Диадок"); //текущий синоним
	
	Возврат Результат;	
	
КонецФункции

Функция ОбновленияМодуля_НаименованияМодуля()
	
	Результат = Новый Массив;
	
	Результат.Добавить("Диадок (СКБ Контур)");
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_ТипВнешнейОбработки() Экспорт

	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.ДополнительныеОтчетыИОбработки") Тогда
		
		ТипОбработки = Новый ОписаниеТипов("СправочникСсылка.ДополнительныеОтчетыИОбработки");
		
	ИначеЕсли ПроверитьНаличиеОбъектаМетаданных("Справочники.ВнешниеОбработки") Тогда	
		
		ТипОбработки = Новый ОписаниеТипов("СправочникСсылка.ВнешниеОбработки");
		
	Иначе
		
		ТипОбработки = Новый ОписаниеТипов(Неопределено);
		
	КонецЕсли; 
	
	Возврат ТипОбработки;

КонецФункции

Процедура ОбновлениеМодуля_ОбработатьОшибку(ТекстОшибки)
	
	Если РежимОтладкиВключен() Тогда
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Ошибка_Обработать("ОбновлениеМодуля", , , ТекстОшибки);
	
КонецПроцедуры

Функция ОбновленияМодуля_ДвоичныеДанныеВнешнейОбработки(ВнешняяОбработка)
	
	Результат = Неопределено;
	
	Если Не ЗначениеЗаполнено(ВнешняяОбработка) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РеквизитыОбработки = ВнешняяОбработка.Метаданные().Реквизиты;
	
	Если РеквизитыОбработки.Найти("ХранилищеОбработки") <> Неопределено Тогда
		Результат = ВнешняяОбработка.ХранилищеОбработки.Получить();
	ИначеЕсли РеквизитыОбработки.Найти("ХранилищеВнешнейОбработки") <> Неопределено Тогда
		Результат = ВнешняяОбработка.ХранилищеВнешнейОбработки.Получить();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_СведенияОВнешнейОбработкеИзФайла(ДвоичныеДанные)
	
	ОбъектОбработки = ВнешниеОбработки_СоздатьБезПредупреждений(ДвоичныеДанные, "ДиадокПРО_ДляЧтенияСведений");
	
	Результат = ОбъектОбработки.СведенияОВнешнейОбработке();
	
	Возврат Результат;
	
КонецФункции

// Выполняем попытку подключения создания внешней обработки из переданных данных и вызов метода объекта СведенияОВнешнейОбработке
// В случае ошибки создания внешней обработки или ошибки при вызове метода СведенияОВнешнейОбработке вызывается исключение
//
// Параметры:
//  ДвоичныеДанные	 - ДвоичныеДанные	 - данные внешней обработки
//
Процедура ОбновлениеМодуля_ВыполнитьТестовоеПодключениеМодуля(ДвоичныеДанные) Экспорт

	Попытка
		СведенияОВнешнейОбработке = ОбновленияМодуля_СведенияОВнешнейОбработкеИзФайла(ДвоичныеДанные);
	Исключение
		ВызватьИсключение "ОшибкаЗагрузкиНовойВерсии: не удалось прочитать сведения о внешней обработке " + ОписаниеОшибки();		
	КонецПопытки;
	
КонецПроцедуры

Функция ОбновлениеМодуля_ТипКонтентаAPIпоМестоположениюМодуля(МестоположениеМодуля)
	
	ВариантыМестоположений = Перечисление_МестоположенияМодуля();
	ТипыКонтентаAPI = АПИ_СервисОбновлений_ТипыКонтентов();
	
	Если МестоположениеМодуля = ВариантыМестоположений.РасширениеКонфигурации Тогда
		
		Результат = ТипыКонтентаAPI.cfe;
		
	ИначеЕсли МестоположениеМодуля = ВариантыМестоположений.ФайлНаДиске
		Или МестоположениеМодуля = ВариантыМестоположений.ЭлементСправочника Тогда
		
		Результат = ТипыКонтентаAPI.epf;
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДвоичныеДанныеФайла(ПолноеИмяФайла) Экспорт
	
	Результат = Неопределено;
	
	Файл = Новый Файл(ПолноеИмяФайла);
	
	Если Файл.Существует()
		И Файл.ЭтоФайл() Тогда
		
		Результат = Новый ДвоичныеДанные(ПолноеИмяФайла);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновленияМодуля_ОписаниеОбновлений(ТекущаяВерсияМодуля) Экспорт
	
	АПИ_ОписаниеВерсий = АПИ_СервисОбновлений_ВерсииПродукта();
	
	Результат = Новый Массив;
	
	Для Каждого Элемент Из АПИ_ОписаниеВерсий.versions Цикл
		
		Если СравнитьВерсии(Элемент.version, ТекущаяВерсияМодуля) = 0 Тогда
			
			Прервать;
			
		КонецЕсли;
		
		Результат.Добавить(Элемент.description);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ИдентификаторПродукта()
	
	Результат = "diadoc_um";
	
	Возврат Результат;
	
КонецФункции

//}		ОБНОВЛЕНИЕ МОДУЛЯ

//{		АВТООБНОВЛЕНИЕ МОДУЛЯ

// сбор данных (1 часть)

// Инициализирует, заполняет и возвращает коллекцию данных, которая обслуживает автообновление модуля.
//	Заполняет данные об окружении и расположении модуля. Проверяет возможность автообновления
//	модуля. Заполняет поясняющие комментарии о невозможности автообновления.
//
// Возвращаемое значение:
//  Структура - см. функцию НовыеДанныеДляОбновленияМодуля()
//
Функция ДанныеДляОбновленияМодуля() Экспорт
	
	Результат = НовыеДанныеДляОбновленияМодуля();
	ЗаполнитьОписаниеРасположенияМодуля(Результат);
	ОписаниеРасположения = Результат.ОписаниеРасположенияМодуля;
	МестоположенияМодуля = Результат.Перечисления.МестоположенияМодуля;
	
	Если ЭтоСборкаДляПровайдераСервиса() Тогда
		Результат.МожноОбновитьМодуль = Ложь;
		Результат.КомментарийМодуля = "МодульВОблачной1С";
	ИначеЕсли ЭтоПервыйЗапуск() Тогда
		Результат.МодульЗапущенВпервые = Истина;
		
	ИначеЕсли МодульБылОбновлен() Тогда
		
		Результат.МодульБылОбновлен = Истина;
 
	ИначеЕсли РежимОтладкиВключен() Тогда
		
		Результат.КомментарийМодуля = "МодульВРежимеОтладки";
		Результат.МожноОбновитьМодуль = Ложь;
		
	ИначеЕсли ОтключеноАвтоматическоеОбновлениеМодуля() Тогда
		
		Результат.КомментарийМодуля = "ОтключеноАвтообновление";
		Результат.МожноОбновитьМодуль = Ложь;
		
	ИначеЕсли ОписаниеРасположения.Местоположение = МестоположенияМодуля.Неопределено Тогда
		
		Результат.КомментарийМодуля = "РасположениеМодуляНеОпределено";
		Результат.МожноОбновитьМодуль = Ложь;
		
	ИначеЕсли ОписаниеРасположения.Местоположение = МестоположенияМодуля.ОбработкаКонфигурации Тогда
		
		Результат.КомментарийМодуля = "МодульВСоставеКонфигурации";
		Результат.МожноОбновитьМодуль = Ложь;
		
	ИначеЕсли ОписаниеРасположения.Местоположение = МестоположенияМодуля.ЭлементСправочника Тогда
		
		ТекстОшибки = ПроверитьВозможностьОбновленияЭлементаСправочникаМодуля(ОписаниеРасположения.Ссылка);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Результат.КомментарийМодуля = ТекстОшибки;
			Результат.МожноОбновитьМодуль = Ложь;
		КонецЕсли;
		
	ИначеЕсли ОписаниеРасположения.Местоположение = МестоположенияМодуля.РасширениеКонфигурации Тогда
		
		ТекстОшибки = ПроверитьВозможностьОбновленияРасширенияКонфигурации();
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Результат.КомментарийМодуля = ТекстОшибки;
			Результат.МожноОбновитьМодуль = Ложь;
		КонецЕсли;
		
	КонецЕсли; 

	Возврат Результат;
	
КонецФункции

// Конструктор коллекции данных, которая обслуживает процесс автообновление модуля.
//  Содержит данные о расположении и окружении модуля, новой версии модуля, 
//	состоянии процесса автообновления и служебные перечисления.
// 
// Возвращаемое значение:
//  Структура - содержит свойства:
//   * Перечисления	          		- Структура	- набор служебных перечислений, см. функцию ПеречисленияДляОбновленияМодуля();
//	 * ОписаниеОкруженияМодуля		- Структура	- основные параметры окружения модуля, используются при запросе
//												  новой версии в сервисе обновлений, отправляются в метрики,
//												  см. функцию НовоеОписаниеОкруженияМодуля();
//	 * ОписаниеРасположенияМодуля	- Структура	- набор значений, описывающий место запуска модуля, используется
//												  при замене текущей версии модуля на новую, отправляются в метрики,
//												  см. функцию НовоеОписаниеРасположенияМодуля();
//   * ОписаниеОбновленияМодуля     - Структура	- информация о новой версии модуля: показывает её наличие и номер версии,
//												  содержит ссылку на скачивание, см. функцию НовоеОписаниеОбновленияМодуля();
//   * МожноОбновитьМодуль          - Булево 	- флаг, разрешающий или запрещающий автообновление модуля;
//   * МодульЗапущенВпервые         - Булево    - флаг, указывающий на первый запуск модуля в текущей ИБ;
//	 * МодульБылОбновлен			- Булево	- флаг, указывающий, что запускается новая версия модуля;
//	 * ОписаниеОшибки	  			- Строка	- текст ошибки, которая может возникнуть на этапе сбора данных для обновления
//												  или в процессе автообновления модуля;
//   * КомментарийМодуля            - Строка	- комментарий, содержащий причину невозможности автообновления,
//												  которая была выявлена на этапе сбора данных для обновления;
//	 * КомментарийСервиса			- Строка	- комментарий, содержащий причину невозможности автообновления,
//												  которую может вернуть сервис обновлений в результате анализа
//												  параметров окружения модуля;
//
Функция НовыеДанныеДляОбновленияМодуля()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Перечисления", ПеречисленияДляОбновленияМодуля());
	
	Результат.Вставить("ОписаниеОкруженияМодуля", НовоеОписаниеОкруженияМодуля());
	Результат.Вставить("ОписаниеРасположенияМодуля", НовоеОписаниеРасположенияМодуля());
	Результат.Вставить("ОписаниеОбновленияМодуля", НовоеОписаниеОбновленияМодуля());
	
	Результат.Вставить("МожноОбновитьМодуль", Истина);
	Результат.Вставить("МодульЗапущенВпервые", Ложь);
	Результат.Вставить("МодульБылОбновлен", Ложь);
	
	Результат.Вставить("ОписаниеОшибки", "");
	Результат.Вставить("КомментарийМодуля", "");
	Результат.Вставить("КомментарийСервиса", "");
		
	Возврат Результат;
	
КонецФункции

Функция ПеречисленияДляОбновленияМодуля()
	
	Результат = Новый Структура;
	
