// Записывает в настройки указанный интеграционный модуль.
//
// Параметры:
//  ИмяИнтеграционногоМодуля - Строка - Идентификатор ИМ.
//
Процедура ОбщиеНастройки_ИнтеграционныйМодульЗаписать(ИмяИнтеграционногоМодуля) Экспорт
	
	ОбщиеНастройки_Поместить(
		"ИмяИнтеграционногоМодуля",
		ИмяИнтеграционногоМодуля
	);
	
КонецПроцедуры

// Очищает настройки подключаемого модуля
//
Процедура ОбщиеНастройки_ПодключаемыйМодульОтключить() Экспорт
	
	Настройки = ОбщиеНастройки_ЗначенияНастроек();
	
	Настройки.Вставить("ИспользоватьПодключаемыйМодуль", Ложь);
	
	ОбщиеНастройки_ЗаписатьНастройки(Настройки);
	
КонецПроцедуры

// Записывает параметры подключаемого модуля в настройки
//
// Параметры:
//  МестонахождениеПМ - Строка - тип адреса, принимает значения "1С", "Файл", "Конфигурация"
//  АдресМодуля - Произвольный - Внешняя обработка, путь к файлу или имя встроенной обработки
//
Процедура ОбщиеНастройки_ПодключаемыйМодульЗаписать(Знач МестонахождениеПМ, Знач АдресМодуля) Экспорт
	
	Если ВРег(МестонахождениеПМ) = ВРег("1С") Тогда
		
		КлючНастройки = "ПодключаемыйМодульСсылка";
		
	ИначеЕсли ВРег(МестонахождениеПМ) = ВРег("Диск") Тогда
		
		КлючНастройки = "ПодключаемыйМодульПуть";
		
	ИначеЕсли ВРег(МестонахождениеПМ) = ВРег("Конфигурация") Тогда
		
		КлючНастройки = "ПодключаемыйМодульИмяОбработки";
		
	Иначе
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"ОбщиеНастройки_ПодключаемыйМодульЗаписать: Неожиданное значение параметра ""МестонахождениеПМ"" (%1)",
			МестонахождениеПМ
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	Настройки = ОбщиеНастройки_ЗначенияНастроек();
	
	Настройки.Вставить("ИспользоватьПодключаемыйМодуль", Истина);
	Настройки.Вставить("МестонахождениеПодключаемогоМодуля", МестонахождениеПМ);
	Настройки.Вставить(КлючНастройки, АдресМодуля);
	
	ОбщиеНастройки_ЗаписатьНастройки(Настройки);
	
КонецПроцедуры

Функция ОбщиеНастройки_ЗначенияНастроек() Экспорт
	
	Результат = ХранениеДанных_ОбщиеНастройки();
	
	Если Не ЗначениеЗаполнено(Результат.СохранениеДокументовИмяКаталогаПакетаПоУмолчанию) Тогда
		ПриоритетыИменКаталогаПакетаПоУмолчанию = ОбщиеНастройки_ПриоритетыИменКаталогаПакетаПоУмолчанию();
		Результат.СохранениеДокументовИмяКаталогаПакетаПоУмолчанию = ПриоритетыИменКаталогаПакетаПоУмолчанию;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбщиеНастройки_ЗаписатьНастройки(Знач СтруктураНастроек) Экспорт
	
	СтруктураНастроек = ОбщиеНастройки_ОбработанныеЗначенияПередЗаписью(СтруктураНастроек);
	
	Результат = ХранениеДанных_ЗаписатьОбщиеНастройки(СтруктураНастроек);
	
	Кэш_Поместить("ВидыПакетов",				Неопределено);
	Кэш_Поместить("ВидыДокументов",				Неопределено);
	Кэш_Поместить("ПриоритетыДокументовПакета", Неопределено);
	
	Кэш_Поместить("ТаблицаВидовСправочникаВидыПакетов",		Неопределено);
	Кэш_Поместить("ТаблицаВидовСправочникаВидыДокументов",	Неопределено);
	
	Модуль_ТиповойМодуль_Отключить();
	Модуль_ИМ_Отключить();
	Модуль_ПМ_Отключить();
	
	Возврат Результат;
	
КонецФункции

Функция ОбщиеНастройки_ОбработанныеЗначенияПередЗаписью(СтруктураНастроек)
	
	Результат = СтруктураНастроек;
	
	Если СтруктураНастроек.Свойство("ХранитьДокументыНаДиске") И НЕ СтруктураНастроек.ХранитьДокументыНаДиске Тогда
		СтруктураНастроек.УдалятьСодержимоеУстаревшихДокументов	= Ложь;		
	КонецЕсли;

	СохранениеДокументовИмяКаталогаПакета = "";
	
	Если СтруктураНастроек.Свойство("СохранениеДокументовИмяКаталогаПакета") И ЗначениеЗаполнено(СтруктураНастроек.СохранениеДокументовИмяКаталогаПакета) Тогда
		
		Для Каждого Имя Из СтруктураНастроек.СохранениеДокументовИмяКаталогаПакета Цикл
			СохранениеДокументовИмяКаталогаПакета = СохранениеДокументовИмяКаталогаПакета + Имя.Значение + ";";
		КонецЦикла;
		
	КонецЕсли;
	
	СтруктураНастроек.СохранениеДокументовИмяКаталогаПакета = СохранениеДокументовИмяКаталогаПакета;
	
	Возврат Результат;
	
КонецФункции

Функция ОбщиеНастройки_ПриоритетыИменКаталогаПакетаПоУмолчанию()
	
	Результат = Новый СписокЗначений;
	
	ТипыДокументовAPI = ПредопределенныеСписки_ТипыДокументовAPI();
	
	ГруппировкиДокументов = ТипыДокументовAPI.Скопировать();
	ГруппировкиДокументов.Свернуть("ГруппировкаДокументов");
	ГруппировкиДокументов.Сортировать("ГруппировкаДокументов");
	
	Для Каждого СтрокаТЗ Из ГруппировкиДокументов Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЗ.ГруппировкаДокументов)
			И СтрокаТЗ.ГруппировкаДокументов <> "Прочее" 
			И СтрокаТЗ.ГруппировкаДокументов <> "Запросы на ЭДО" Тогда
			
			Результат.Добавить(СтрокаТЗ.ГруппировкаДокументов);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

