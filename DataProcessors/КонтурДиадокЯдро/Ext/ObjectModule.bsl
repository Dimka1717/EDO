Функция НастройкиДокументов_НастройкиПакетовДляКонтрагентаОтличаются(ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Результат = Ложь;
			
	Если ДанныеКонтрагента <> Неопределено Тогда
						
		НастройкаОрганизацииПередаватьМЧДФайлом = НастройкиДокументов_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации);
		
		СохраненныеНастройкиДокументовНаОтправку = НастройкиДокументов_НастройкиДокументовНаОтправку(ДанныеОрганизации, ДанныеКонтрагента);
		
		НастройкиДокументовНаОтправкуСтрокой	= ЗначениеВСтрокуВнутр(СохраненныеНастройкиДокументовНаОтправку);

		ШифроватьДокументы = Контрагенты_ТребуетсяШифрованиеДокументов(ДанныеОрганизации, ДанныеКонтрагента);
	
		ПередаватьМЧДФайлом = НастройкиДокументов_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации, ДанныеКонтрагента);
		
		НастройкиПакетовНаОтправку = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(ДанныеОрганизации, ДанныеКонтрагента);		
		
		НастройкиПакетовДляОрганизации = НастройкиДокументов_НастройкиКатегорийПакетовНаОтправку(ДанныеОрганизации);
		НастройкиДокументовДляОрганизации = НастройкиДокументов_НастройкиДокументовНаОтправку(ДанныеОрганизации);
		
		НастройкиПакетовНаОтправкуСтрокой = ЗначениеВСтрокуВнутр(НастройкиПакетовНаОтправку);
		НастройкиПакетовДляОрганизацииСтрокой = ЗначениеВСтрокуВнутр(НастройкиПакетовДляОрганизации);
		НастройкиДокументовДляОрганизацииСтрокой = ЗначениеВСтрокуВнутр(НастройкиДокументовДляОрганизации);
		
		ОтличаютсяНастройкиДокументовДляКонтрагента = НастройкиДокументовНаОтправкуСтрокой <> НастройкиДокументовДляОрганизацииСтрокой;
		ОтличаютсяНастройкиПакетовДляКонтрагента = НастройкиПакетовНаОтправкуСтрокой <> НастройкиПакетовДляОрганизацииСтрокой; 
		
		Результат = ОтличаютсяНастройкиПакетовДляКонтрагента
					ИЛИ ОтличаютсяНастройкиДокументовДляКонтрагента
					ИЛИ ШифроватьДокументы <> ДанныеОрганизации.ШифроватьДокументы
					ИЛИ ПередаватьМЧДФайлом <> НастройкаОрганизацииПередаватьМЧДФайлом;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция НастройкиДокументов_ВидПакетаКатегории(КатегорияПакета, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	Результат = ХранениеДанных_НастройкиЗначениеСвойства(КатегорияПакета, ДанныеОрганизации, ДанныеКонтрагента);
	
	Если Результат = Неопределено И ДанныеКонтрагента <> Неопределено Тогда
		Результат = ХранениеДанных_НастройкиЗначениеСвойства(КатегорияПакета, ДанныеОрганизации);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		ВидыПакетовПоУмолчанию = ПредопределенныеСписки_ВидыПакетовПоУмолчанию();
		ОписаниеВидаПакета = ВидыПакетовПоУмолчанию.Получить(КатегорияПакета);
		
		Результат = ОписаниеВидаПакета.ID;
		
	Иначе
		
		Если ТипЗнч(Результат) <> Тип("Строка") Тогда
			Результат = ХранениеДанных_ЗначениеДопРеквизита(Результат, "ID");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура НастройкиДокументов_ЗаписатьКатегорииПакетов(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Модуль_ХранениеДанных.Настройки_ЗаписатьКатегорииПакетов(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
	
КонецПроцедуры

// Возвращает значение установленного формата для вида документа на отправку в разрезе организации и/или контрагента (если для него вкл. индивидуальные настройки)
//
// Параметры:
//  ВидДокумента		 - Строка	 - идентификатор вида документа (например: ID_УПД, ID_УКД, ID_ТОРГ12, ID_СчетФактура и др). 
//  ДанныеОрганизации	 - Структура - см. функцию Контракт_ОрганизацияЭДО()
//  ДанныеКонтрагента	 - Структура - см. функцию Контракт_КонтрагентЭДО()
// 
// Возвращаемое значение:
//  Строка, Неопределено - значение формата документа или Неопределено
//
Функция НастройкиДокументов_ФорматВидаДокумента(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Результат = Неопределено;
	
	КэшируемыеЗначенияФорматов = НастройкиДокументов_ПолучитьИзКэшаФорматыВидовДокументов();

	Если КэшируемыеЗначенияФорматов = Неопределено Тогда
		КэшируемыеЗначенияФорматов = Новый Соответствие;
		НастройкиДокументов_ПоместитьВКэшФорматыВидовДокументов(КэшируемыеЗначенияФорматов);
	Иначе
		Ключ = НастройкиПечатныхФорм_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
		Результат = КэшируемыеЗначенияФорматов.Получить(Ключ);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		ИдентификаторыВидовДокументов = Новый Массив;
		ИдентификаторыВидовДокументов.Добавить(ВидДокумента);
		
		ФорматыВидовДокументов = ХранениеДанных_ФорматыВидовДокументов(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
		
		Результат = ФорматыВидовДокументов.Получить(ВидДокумента);
		
		Ключ = НастройкиПечатныхФорм_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
		КэшируемыеЗначенияФорматов.Вставить(Ключ, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура НастройкиДокументов_ЗаписатьФорматыВидовДокументов(ФорматыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	КоллекцияСвойств = Новый Соответствие;
	
	Для Каждого Элемент Из ФорматыВидовДокументов Цикл
		КоллекцияСвойств.Вставить("Формат_" + Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Модуль_ХранениеДанных.Настройки_ЗаписатьЗначенияСвойств(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	
	НастройкиДокументов_ПоместитьВКэшФорматыВидовДокументов(Неопределено);
	
КонецПроцедуры

Процедура НастройкиДокументов_ПоместитьВКэшФорматыВидовДокументов(Значение)
	
	Кэш_Поместить("ФорматыВидовДокументов", Значение);
	
КонецПроцедуры

Функция НастройкиДокументов_ПолучитьИзКэшаФорматыВидовДокументов()
	
	Результат = Кэш_Прочитать("ФорматыВидовДокументов");
	Возврат Результат;
	
КонецФункции

Функция НастройкиДокументов_ФорматыКонтента(ОписаниеВидаДокумента) Экспорт
	
	Результат = Новый СписокЗначений;
	
	ВидыЭДО							= Перечисление_ВидыЭДО();
	ФорматыОтправки					= Перечисление_ФорматыОтправкиДокументов();
	НаименованиеФорматовОтправки	= Перечисление_НаименованияФорматовОтправкиДокументов();
	
	ТипКонтентаAPI		= ОписаниеВидаДокумента.ТипКонтентаAPI;
	ТипДокументаAPI		= ОписаниеВидаДокумента.ТипДокументаAPI;
	ФункцияДокументаAPI	= ОписаниеВидаДокумента.ФункцияДокументаAPI;
	
	ЭтоФормализованныйКонтент = ЗначениеЗаполнено(ТипКонтентаAPI);
	
	ВидыЭлектронныхДокументов = Документы_ВидыЭлектронныхДокументовПоФорматуЭДО(ТипДокументаAPI, ФункцияДокументаAPI);
	
	ЭтоСчет = НастройкиДокументов_ЭтоСчет(ВидыЭлектронныхДокументов);
	
	Если ЭтоФормализованныйКонтент Тогда
		
		ЭтоПервичныйДокумент = НастройкиДокументов_ЭтоПервичныйДокумент(ВидыЭлектронныхДокументов);
		ЭтоАктСверки = НастройкиДокументов_ЭтоАктСверки(ВидыЭлектронныхДокументов);
		ВключенРежимСовместимости = Конвертация970_УстановленаНастройкаРежимаСовместимостиФорматовАвто();
		
		Если ЭтоПервичныйДокумент Тогда
			
			ЕстьПодключаемыйМодуль = ЕстьПодключаемыйМодуль();
			
			Если ЕстьПодключаемыйМодуль И ТипКонтентаAPI = "tovtorg" Тогда
				Результат.Добавить("tovtorg", "ФНС 551");
			ИначеЕсли ЕстьПодключаемыйМодуль И ТипКонтентаAPI = "rezru" Тогда
				Результат.Добавить("rezru", "ФНС 552");
			ИначеЕсли ВРЕГ(ТипДокументаAPI) = ВРЕГ("UniversalTransferDocumentInternal") Тогда
				Результат.Добавить("utd970", "ФНС 970");
			Иначе
				
				Результат.Добавить("utd820", "ФНС 820");
				Результат.Добавить("utd970", "ФНС 970");
				Если ЕстьПодключаемыйМодуль Тогда
					Результат.Добавить(НастройкаОтправки_utd970_820(), "ФНС 820 (режим совместимости с ФНС 970)");
				КонецЕсли;
				Если ВключенРежимСовместимости Тогда
					Результат.Добавить(НастройкаОтправки_utd820_970(), "ФНС 970 (режим совместимости с ФНС 820)");
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ЭтоАктСверки Тогда
			
			Если ТипКонтентаAPI = "reconciliationact405" Тогда
				Результат.Добавить("reconciliationact405", "ФНС 405");
			КонецЕсли;
			
		ИначеЕсли ЭтоСчет Тогда
			
			Если ТипКонтентаAPI = ТипКонтента_xmlproformainvoice() Тогда
				Результат.Добавить(ФорматыОтправки.pf_diadoc, НаименованиеФорматовОтправки.pf_diadoc);
				Результат.Добавить(ФорматыОтправки.pf_1c, НаименованиеФорматовОтправки.pf_1c);
				Результат.Добавить(ФорматыОтправки.epf,	НаименованиеФорматовОтправки.epf);
			ИначеЕсли ТипКонтентаAPI = ТипКонтента_proformainvoice29() Тогда
				Результат.Добавить(ТипКонтента_proformainvoice29(), "ФНС 29");
			ИначеЕсли ТипКонтентаAPI = ТипКонтента_invoiceoffer29() Тогда
				Результат.Добавить(ТипКонтента_invoiceoffer29(), "ФНС 29");
			КонецЕсли;
			
		Иначе
			
			ЭтоКорректировочныйДокумент = НастройкиДокументов_ЭтоКорректировочныйДокумент(ВидыЭлектронныхДокументов);
			
			Если ЭтоКорректировочныйДокумент Тогда
			
				Результат.Добавить("ucd736",	"ФНС 736");
				
			ИначеЕсли ВключенРежимСовместимости
				И Конвертация970_ВозможнаКонвертацияВидаДокумента_из820(ОписаниеВидаДокумента) Тогда
				
				Результат.Добавить(ТипКонтента_utd820(), "ФНС 820");
				Результат.Добавить(НастройкаОтправки_utd820_970(), "ФНС 970 (режим совместимости с ФНС 820)");
				
			КонецЕсли;
			
		КонецЕсли;
		
		МожноЗаменитьНаВПФ = НастройкиДокументов_МожноЗаменитьНаВПФ(ТипДокументаAPI);
		
		Если МожноЗаменитьНаВПФ Тогда
			Результат.Добавить(ФорматыОтправки.epf, НаименованиеФорматовОтправки.epf);
		КонецЕсли;
		
	Иначе
		Результат.Добавить(ФорматыОтправки.pf_diadoc, НаименованиеФорматовОтправки.pf_diadoc);
		
		Если ЭтоСчет Тогда
			Результат.Добавить(ФорматыОтправки.pf_1c, НаименованиеФорматовОтправки.pf_1c);
		КонецЕсли;
		
		Результат.Добавить(ФорматыОтправки.epf, НаименованиеФорматовОтправки.epf);
	КонецЕсли;
	
	Если Результат.Количество() = 0 Тогда
		Результат.Добавить(ФорматыОтправки.pf_diadoc, НаименованиеФорматовОтправки.pf_diadoc);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НастройкиДокументов_ЭтоПервичныйДокумент(ВидыЭлектронныхДокументов)
	
	ВидыЭДО = Перечисление_ВидыЭДО();
	
	Результат = ВидыЭлектронныхДокументов.Найти(ВидыЭДО.СчетФактура) <> Неопределено
			ИЛИ ВидыЭлектронныхДокументов.Найти(ВидыЭДО.Накладная) <> Неопределено
			ИЛИ ВидыЭлектронныхДокументов.Найти(ВидыЭДО.Акт) <> Неопределено;
							
	Возврат Результат;						
							
КонецФункции

Функция НастройкиДокументов_ЭтоКорректировочныйДокумент(ВидыЭлектронныхДокументов)
	
	ВидыЭДО = Перечисление_ВидыЭДО();
	
	Результат = ВидыЭлектронныхДокументов.Найти(ВидыЭДО.КорректировочныйСчетФактура) <> Неопределено
			ИЛИ ВидыЭлектронныхДокументов.Найти(ВидыЭДО.КорректировочнаяНакладная) <> Неопределено;
							
	Возврат Результат;						
							
КонецФункции

Функция НастройкиДокументов_ЭтоСчет(ВидыЭлектронныхДокументов)
	
	ВидыЭДО = Перечисление_ВидыЭДО();
	
	Результат = ВидыЭлектронныхДокументов.Найти(ВидыЭДО.Счет) <> Неопределено;
	
	Возврат Результат;
	
КонецФункции

Функция НастройкиДокументов_ЭтоАктСверки(ВидыЭлектронныхДокументов)
	
	ВидыЭДО = Перечисление_ВидыЭДО();
	
	Результат = ВидыЭлектронныхДокументов.Найти(ВидыЭДО.АктСверки) <> Неопределено;
							
	Возврат Результат;						
							
КонецФункции

Функция НастройкиДокументов_МожноЗаменитьНаВПФ(ТипДокументаAPI)
	
	Результат = ВРег(ТипДокументаAPI) = ВРег("XmlAcceptanceCertificate")
				ИЛИ ВРег(ТипДокументаAPI) = ВРег("XmlTorg12");
				
	Возврат Результат;
	
КонецФункции

Процедура НастройкиДокументов_УдалитьНастройкиДокументов(ДанныеОрганизации, ДанныеКонтрагента) Экспорт
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	СвойстваДляУдаления = Новый Соответствие;
	
	ВидыПакетов = СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
	
	Для Каждого СтрокаТЗ Из ВидыПакетов Цикл
		
		КатегорияПакета = СтрокаТЗ.КатегорияПакета;
		
		Если ЗначениеЗаполнено(КатегорияПакета) Тогда
			СвойстваДляУдаления.Вставить(КатегорияПакета);
		КонецЕсли;
		
	КонецЦикла;
	
	ВидыДокументов = СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыДокументов");
	
	Для Каждого ОписаниеВидаДокумента Из ВидыДокументов Цикл
		
		ВидДокумента = ОписаниеВидаДокумента.ID;
		
		СвойстваДляУдаления.Вставить("Формат_" + ВидДокумента);
		Модуль_ХранениеДанных.НастройкиПечатныхФорм_Удалить(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
		
		ЭтоИдентификаторВидаДокументаСчет = ЭтоИдентификаторВидаСчет(ВидДокумента);
		
		Если ЭтоИдентификаторВидаДокументаСчет Тогда
			
			Модуль_ХранениеДанных.НастройкиДокументов_ОснованияВидовДокументов_Удалить(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ИмяСвойстваШифроватьДокументы = Модуль_ХранениеДанных.Перечисление_ИмяСвойстваНастройки("ШифроватьДокументы");
	СвойстваДляУдаления.Вставить(ИмяСвойстваШифроватьДокументы);
	
	ИмяСвойстваДобавлятьСчетВПакет = ХранениеДанных_ИмяСвойстваНастройки_ДобавлятьСчетВПакет();
	СвойстваДляУдаления.Вставить(ИмяСвойстваДобавлятьСчетВПакет);
	
	ИмяСвойстваПередаватьМЧДФайлом = ХранениеДанных_ИмяСвойстваНастройки_ПередаватьМЧДФайлом();
	СвойстваДляУдаления.Вставить(ИмяСвойстваПередаватьМЧДФайлом);
	
	Для Каждого Элемент Из СвойстваДляУдаления Цикл
		
		ИмяСвойства = Элемент.Ключ;
		Модуль_ХранениеДанных.Настройки_УдалитьЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);
		
	КонецЦикла;
	
	НастройкиДокументов_ПоместитьВКэшФорматыВидовДокументов(Неопределено);
	Кэш_Поместить("НастройкиПечатныхФорм", Неопределено);
	
	ОснованияВидовДокументов_ОчиститьКэш();
	
КонецПроцедуры

Процедура НастройкиДокументов_ЗаписатьШифрованиеДокумента(ДанныеОрганизации, ДанныеКонтрагента, Значение) Экспорт
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника(ДанныеОрганизации.Ссылка, ДанныеОрганизации.ID);
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(ДанныеКонтрагента.Ссылка, ДанныеКонтрагента.ID);
	
	ХранениеДанных_ЗаписатьШифрованиеДокумента(ИдентификаторыОрганизации, ИдентификаторыКонтрагента, Значение);
	
КонецПроцедуры

// Устанавливает для организации значения всех категорий пакетов на отправку в соответствии с указанным типом отправки.
// 
// Параметры:
//	ДанныеОрганизации - Структура - см. Контракт_ОрганизацияЭДО()
//	ТипОтправки - Строка - допустимые значения: "УПД" - отправка УПД СЧФ ДОП
//												"СФ_НАКЛАДНАЯ_АКТ" - отправка СФ + ТОРГ12/Акт
//
Процедура НастройкиДокументов_УстановитьКатегорииПакетовНаОтправку(ДанныеОрганизации, ТипОтправки) Экспорт
	
	КатегорииПакетов = Новый Соответствие;
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		КатегорияОсновнойПакет = "Основной пакет";
	Иначе
		КатегорияОсновнойПакет = "ОсновнойПакет";
	КонецЕсли;
	
	Если ТипОтправки = "УПД" Тогда
		ВидПакетаОсновной			= "ID_УПД";
		ВидПакетаКорректировочный 	= "ID_УКД";
	ИначеЕсли ТипОтправки = "СФ_НАКЛАДНАЯ_АКТ" Тогда
		ВидПакетаОсновной 			= "ID_ОсновнойПакет";
		ВидПакетаКорректировочный 	= "ID_КСФ";
	Иначе
		
		ШаблонОшибки = "Неожиданное значение типа отправки (%1)";
		Ошибка = Общее_ПодставитьПараметрыВСтроку(ШаблонОшибки, ТипОтправки);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	КатегорииПакетов.Вставить(КатегорияОсновнойПакет	, ВидПакетаОсновной);
	КатегорииПакетов.Вставить("КорректировочныйПакет"	, ВидПакетаКорректировочный);
	КатегорииПакетов.Вставить("СчетФактураНаАванс"		, "ID_СФ_НаАванс");
	КатегорииПакетов.Вставить("СчетНаОплату"			, "ID_Счет");
	КатегорииПакетов.Вставить("АктCверки"				, "ID_АктСверки");
	КатегорииПакетов.Вставить("ВнутренниеПеремещения"	, "ID_УПД_ВНУТР");
	
	НастройкиДокументов_ЗаписатьКатегорииПакетов(КатегорииПакетов, ДанныеОрганизации);
	
КонецПроцедуры

// Очищает для организации значения всех категорий пакетов на отправку.
// 
// Параметры:
//	ДанныеОрганизации - Структура - см. Контракт_ОрганизацияЭДО()
//
Процедура НастройкиДокументов_ОчиститьКатегорииПакетовНаОтправку(ДанныеОрганизации) Экспорт
	
	КатегорииПакетов = Новый Соответствие;
	
	ВидыПакетов = СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
	
	Для Каждого СтрокаТЗ Из ВидыПакетов Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.КатегорияПакета) Тогда
			Продолжить;
		КонецЕсли;
		
		КатегорииПакетов.Вставить(СтрокаТЗ.КатегорияПакета, "");
		
	КонецЦикла;
	
	НастройкиДокументов_ЗаписатьКатегорииПакетов(КатегорииПакетов, ДанныеОрганизации);
	
КонецПроцедуры

// Определяет доступность настройки использования типовой ПФ 1С
//
// Параметры:
//	ВидДокумента - Строка - идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//	ТипОснования - Строка - значение настройки Типоснования для заданного вида электронного документа
//
// Возвращаемое значение:
//	Булево - Истина, если можно использовать типовую ПФ 1С
//
Функция НастройкиДокументов_ПоказатьНастройку_ТиповаяПФ1С(ВидДокумента, ТипОснования) Экспорт
	
	Результат = Ложь;
	
	Если ЕстьИнтеграционныйМодуль() Тогда
		
		МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
		Результат = МенеджерИнтеграции.ДоступнаТиповаяПечатнаяФорма(ВидДокумента, ТипОснования);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает список доступных оснований для заданного вида электронного документа в рамках используемой конфигурации.
//
// Параметры:
//	ВидДокумента - Строка - идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//
// Возвращаемое значение:
// 	СписокЗначений
Функция МенеджерИнтеграции_СписокОснованийВидаЭлектронногоДокумента(ВидДокумента) Экспорт
	
	Результат = Новый СписокЗначений;
	
	ЕстьИМ = ЕстьИнтеграционныйМодуль();
	
	Если ЕстьИМ Тогда
	
		Модуль_МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	
		Результат = Модуль_МенеджерИнтеграции.СписокОснованийВидаЭлектронногоДокумента(ВидДокумента);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает из БД значение настройки "ТипОснования" для заданного вида электронного документа
//
// Параметры:
//	ВидДокумента		- Строка					- идентификатор вида документа
//  ДанныеОрганизации	- Структура 				- данные организации, в разрезе которой хранится настройка
//	ДанныеКонтрагента	- Структура, Неопределено	- данные контрагента, в разрезе которого хранится настройка
//
// Возвращаемое значение:
//	Строка - значение настройки
Функция НастройкиДокументов_ОснованияВидовДокументов_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
			
	Результат = ОснованияВидовДокументов_ДанныеКэша(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	Результат = Модуль_ХранениеДанных.НастройкиДокументов_ОснованияВидовДокументов_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
			
	ОснованияВидовДокументов_УстановитьКэш(Результат, ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	
	Возврат Результат;
	
КонецФункции

Функция ОснованияВидовДокументов_КлючКэша()
	
	Возврат "ОснованияВидаДокумента";
	
КонецФункции

Функция ОснованияВидовДокументов_ДанныеКэша(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	Результат = Неопределено;
	
	КлючКэша = ОснованияВидовДокументов_КлючКэша();
	
	Кэш = Кэш_Прочитать(КлючКэша);
	Если Кэш = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Ключ = ОснованияВидовДокументов_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Результат = Кэш.Получить(Ключ);
	
	Возврат Результат;
			
КонецФункции

Процедура ОснованияВидовДокументов_УстановитьКэш(ОснованиеВидаДокумента, ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	КлючКэша = ОснованияВидовДокументов_КлючКэша();
	
	Кэш = Кэш_Прочитать(КлючКэша);
	Если Кэш = Неопределено Тогда
		Кэш = Новый Соответствие;
	КонецЕсли;
	
	Ключ = ОснованияВидовДокументов_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Кэш.Вставить(Ключ, ОснованиеВидаДокумента);
	Кэш_Поместить(КлючКэша, Кэш);
	
КонецПроцедуры

Процедура ОснованияВидовДокументов_ОчиститьКэш()
	
	КлючКэша = ОснованияВидовДокументов_КлючКэша();
	Кэш_Поместить(КлючКэша, Неопределено);
	
КонецПроцедуры

Функция ОснованияВидовДокументов_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	IdКонтрагента = "";
	Если ДанныеКонтрагента <> Неопределено Тогда
		IdКонтрагента = ДанныеКонтрагента.ID;
	КонецЕсли;
	
	Результат = ДанныеОрганизации.ID + "_" + IdКонтрагента + "_" + ВидДокумента;
	Возврат Результат;
	
КонецФункции

// Сохраняет в БД значение настройки "ТипОснования"
//
// Параметры:
//	ОснованияВидовДокументов 	- Соответствие - коллекция значений настройки по видам документа
//  ДанныеОрганизации 			- Структура - данные организации, в разрезе которой хранится настройка
//	ДанныеКонтрагента 			- Структура - данные контрагента, в разрезе которого хранится настройка
Процедура НастройкиДокументов_ОснованияВидовДокументов_Записать(ОснованияВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента =  Неопределено) Экспорт
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	Модуль_ХранениеДанных.НастройкиДокументов_ОснованияВидовДокументов_Записать(ОснованияВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
	
	ОснованияВидовДокументов_ОчиститьКэш();
	Кэш_Поместить("ОснованияВидовДокументов_ИспользуютсяТолькоНастройкиПоУмолчанию", Неопределено);
	
КонецПроцедуры

// Проверяет присутствуют ли в БД настройки по основаниям видов документов отличные
// от настроек считающихся настройками по умолчанию
//
// ВозвращаемоеЗначение:
//	Булево - Истина, если используются только настройки по умолчанию
//
Функция Настройки_ОснованияВидовДокументов_ИспользуютсяНастройкиПоУмолчанию() Экспорт
	
	КлючКэширования = "ОснованияВидовДокументов_ИспользуютсяТолькоНастройкиПоУмолчанию";
	
	Кэш = Кэш_Прочитать(КлючКэширования);
	Если Кэш <> Неопределено Тогда
		Возврат Кэш;
	КонецЕсли;
	
	Результат = Истина;
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ТаблицаВидовДокументов = ТаблицаСвойстваТипОснованияПоВидуДокумента();
	
	СуществующиеНастройки =
		Модуль_ХранениеДанных.НастройкиДокументов_ОснованияВидовДокументов_ПрочитатьНаборНастроек(ТаблицаВидовДокументов);
	
	Для Каждого ЭлементКоллекции Из СуществующиеНастройки Цикл
		
		ВидДокументаID = ЭлементКоллекции.ВидДокументаID;
		ЗначениеНастройки = ЭлементКоллекции.ЗначениеНастройки;
		
		ЗначениеНастройкиПоУмолчанию = МенеджерИнтеграции_ОснованияВидовДокументов_ЗначениеПоУмолчанию(ВидДокументаID);
		
		Если ЗначениеЗаполнено(ЗначениеНастройки)
			И ЗначениеЗаполнено(ЗначениеНастройкиПоУмолчанию)
			И НРег(ЗначениеНастройки) <> НРег(ЗначениеНастройкиПоУмолчанию) Тогда
			
			Результат = Ложь;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Кэш_Поместить(КлючКэширования, Результат);
	
	Возврат Результат;
	
КонецФункции

