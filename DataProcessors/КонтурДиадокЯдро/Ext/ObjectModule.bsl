Функция ЗаголовокАвторизацииИзКонтекста()
	
	Результат = Неопределено;
	
	КонтекстСеанса = КонтекстСеанса_СтрокиКонтекста();
	Для Каждого КлючЗначение Из КонтекстСеанса Цикл
		СтрокаКонтекста = КлючЗначение.Значение;
		Если НЕ ЗначениеЗаполнено(СтрокаКонтекста.Токен) Тогда
			Продолжить;
		КонецЕсли;
		ПараметрыСервиса = ПараметрыСервиса_Диадок(СтрокаКонтекста.BoxID);
		Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
		Результат = Модуль_МетодыAPI.ЗаголовокАвторизацииДиадок(ПараметрыСервиса);
		Прервать;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

