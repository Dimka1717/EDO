//
Процедура МетрикиКонтур_ЗаписатьСобытие_СопоставлениеДокумента1С(BoxId)
	
	Категория = "ЦелевоеДействие";
	Действие = "СопоставлениеДокумента1С";
	BoxId = АдресЯщикаВИдентификатор(BoxId);
	
