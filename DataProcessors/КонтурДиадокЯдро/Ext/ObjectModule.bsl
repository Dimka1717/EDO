// Формирует конфигурацию провайдера сервиса аутентификации
// в соответствии с настройками и конфигурационным файлом.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельАутхКонфигурацияПровайдера
//
Функция АутхКонфигурацияПровайдераСлужебный()
	
	ПоУмолчанию = АутхКонфигурацияПровайдераПоУмолчанию();
	КонфигФайл = КонфигурационныйФайл_ЗначенияПараметров();
	
	Данные = МодельАутхКонфигурацияПровайдера();
	
	Данные.Хост = КонфигФайл.Получить("auth_host");
	Если Не ЗначениеЗаполнено(Данные.Хост) Тогда
		Данные.Хост = ПоУмолчанию.Хост;
	КонецЕсли;
	
	Данные.Тип = КонфигФайл.Получить("auth_type");
	Если Не ЗначениеЗаполнено(Данные.Тип) Тогда
		Данные.Тип = ПоУмолчанию.Тип;
	КонецЕсли;
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

// Возвращает дефолтные параметры провайдера сервиса аутентификации
