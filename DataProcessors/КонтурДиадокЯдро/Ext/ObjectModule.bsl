Функция ДвоичныеДанныеBase64ИзXDTO(ОбъектXDTO)
	
	ОбъектXDTO_ДвоичныеДанные = ГенерацияXML_ОбъектXDTO_В_ДвоичныеДанные(ОбъектXDTO);
	
	Результат = Base64Строка(ОбъектXDTO_ДвоичныеДанные);	
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.ПС, "");
	
	Возврат Результат;
	
КонецФункции

// Формирует сведения о подписанте (по схеме универсального подписанта) для действий по документу 
//
// Параметры:
//  Документ - Структура - заполненный контракт входящего или исходящего документа (см. Контракт_Документ())
// 
// Возвращаемое значение:
//  Строка - бинарное представление в формате строки Base64 универсального подписанта
//
Функция Подписант_ЗаполненныйSignerContent(Документ)
	
	АдресЯщикаОрганизации = Документ.Идентификаторы.BoxId;
	
	КонтрактМЧД = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
	РегНомерМЧД = СвойствоСтруктуры(КонтрактМЧД, "Идентификатор");

	ПередаватьМЧДФайлом = МЧД_ЗначениеНастройкиПередаватьМЧДФайломПоДокументу(Документ);
	
	КлючЗначенияВКэше = Подписант_НовыйКлючЗначенияВКэше("", АдресЯщикаОрганизации, РегНомерМЧД, ПередаватьМЧДФайлом);
	
	Результат = Подписант_ПолучитьИзКэша(КлючЗначенияВКэше);
	
	Если Результат = Неопределено Тогда
		
		СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(АдресЯщикаОрганизации);
	
		ПараметрыФормирования = ГенерацияXML_Новый_ПараметрыФормированияУниверсальногоПодписанта(
			АдресЯщикаОрганизации,
			СтрокаКонтекста.ИНН,
			ПередаватьМЧДФайлом);

		SignerContent = ГенерацияXML_УниверсальныйПодписант(СтрокаКонтекста.Сертификат, КонтрактМЧД, ПараметрыФормирования);
		
		Результат = ДвоичныеДанныеBase64ИзXDTO(SignerContent);
		
		Подписант_ПоместитьВКэш(КлючЗначенияВКэше, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ЗаполненныйSignerContentДляОтложенногоПакетаАктаСверки405(Документ)
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	BoxId = АдресЯщикаВИдентификатор(Документ.Идентификаторы.BoxId);
	
	КонтрактМЧД = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "КонтрактМЧД");
	РегНомерМЧД = СвойствоСтруктуры(КонтрактМЧД, "Идентификатор");

	ПередаватьМЧДФайлом = МЧД_ЗначениеНастройкиПередаватьМЧДФайломПоДокументу(Документ);
	
	КлючЗначенияВКэше = Подписант_НовыйКлючЗначенияВКэше(ТипКонтента, BoxId, РегНомерМЧД, ПередаватьМЧДФайлом);
	
	Результат = Подписант_ПолучитьИзКэша(КлючЗначенияВКэше);
	
	Если Результат = Неопределено Тогда
		
		СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId);
	
		ПараметрыФормирования = ГенерацияXML_Новый_ПараметрыФормированияУниверсальногоПодписанта(
			BoxId,
			СтрокаКонтекста.ИНН,
			ПередаватьМЧДФайлом);

		SignerContent = ГенерацияXML_АктСверки_УниверсальныйПодписант(СтрокаКонтекста.Сертификат, КонтрактМЧД, ПараметрыФормирования);	
		
		Результат = ДвоичныеДанныеBase64ИзXDTO(SignerContent);
		
		Подписант_ПоместитьВКэш(КлючЗначенияВКэше, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подписант_ЗаполненныйSignerContentДляОтложенногоПакетаУПД970(Документ)
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	BoxId = АдресЯщикаВИдентификатор(Документ.Идентификаторы.BoxId);
	
