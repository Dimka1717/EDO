	МаркерИМ = ИнтеграционныйМодуль_Получить();
	
	Если ЗначениеЗаполнено(МаркерИМ) Тогда
		
		МодулиОФ = ИнтеграционныеМодулиОФ();
		МодулиУФ = ИнтеграционныеМодулиУФ();
		
		Если МодулиУФ.НайтиПоЗначению(МаркерИМ) <> Неопределено Тогда
