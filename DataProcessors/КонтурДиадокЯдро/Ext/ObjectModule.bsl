Процедура Конвертация970_ЗаписатьПредупрежденияКонвертацииВЖурналРегистрации(Пакет)

	Для Каждого Документ Из Пакет.Документы Цикл
		
		ОшибкиКонвертации = Неопределено;
		Документ.СлужебнаяИнформация.Свойство("ОшибкиКонвертации", ОшибкиКонвертации);
		
		Если Не ЗначениеЗаполнено(ОшибкиКонвертации) Тогда
			Продолжить;
		КонецЕсли;
			
		ИмяСобытия = "Диадок. Режим совместимости 820 и 970";
		
		Для Каждого ОшибкаКонвертации Из ОшибкиКонвертации Цикл
			
			ТекстСообщения = Новый Массив;
			ТекстСообщения.Добавить(ОшибкаКонвертации.Группа);
			ТекстСообщения.Добавить(ОшибкаКонвертации.Текст);
			ТекстСообщения.Добавить(ОшибкаКонвертации.Дополнение);
			
			Комментарий = СоединитьСтроку(ТекстСообщения, Символы.ПС);
			
			ЗаписьЖурналаРегистрации(
				ИмяСобытия,
				УровеньЖурналаРегистрации.Предупреждение,
				,
				Пакет.ДокументУчета,
				Комментарий);
		
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Документы_ИсторияДО_УдалитьПоИдентификаторам(Результат, Знач ИдентификаторыСущностейДляУдаления)
	
	МассивСтрокДляУдаления = Новый Массив;
	
	Для Каждого СтрокаТЗ Из Результат Цикл
		Если ИдентификаторыСущностейДляУдаления.Найти(СтрокаТЗ.EntityId) <> Неопределено Тогда
			МассивСтрокДляУдаления.Добавить(СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из МассивСтрокДляУдаления Цикл
		Результат.Удалить(СтрокаТЗ);
	КонецЦикла;
	
КонецПроцедуры

Функция Перечисление_СоответствиеТипаВложенияПоКодуГруппыУС()
	
	Результат = Новый Структура;
	Результат.Вставить("Receipt", "InvoiceReceipt");
	Результат.Вставить("AmendmentRequest", "InvoiceCorrectionRequest");
	Результат.Вставить("Rejection", "XmlSignatureRejection");
	Результат.Вставить("InformationMessage", "");
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ИсторияДО_ЕстьДубльСобытияВФорматеУС(ИнформацияОбУС, SortedEntities, ParentEntityId,
	ТипВложенияUniversalMessage)
	
	Результат = Ложь;
	
	Отбор = Новый Структура;
	Отбор.Вставить("ParentEntityId", ParentEntityId);
	
	ТипВложенияДляПоиска = СвойствоСтруктуры(Перечисление_СоответствиеТипаВложенияПоКодуГруппыУС(),
		ИнформацияОбУС.КодГруппы, "");
	Отбор.Вставить("AttachmentType", ТипВложенияДляПоиска);
	
	МассивСообщений = МассивСтруктур_НайтиСтроки(SortedEntities, Отбор);
	
	Для Каждого Сообщение Из МассивСообщений Цикл
		
		Если Сообщение.AttachmentType <> ТипВложенияUniversalMessage Тогда
			
			Результат = Истина;
			Прервать;
			
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Функция ОписаниеСобытияИсторииДО_УС(ИнформацияОбУС, ParentAttachmentType)
	
	Результат = "";
	ТипВложения = АПИ_Перечисление_AttachmentType();
	
	Если ИнформацияОбУС.КодСтатуса = Перечисление_КодыУниверсальногоСообщения().ИзвещениеОПолучении Тогда
		
		Результат = "отправил уведомление о получении документа";
		
	ИначеЕсли ИнформацияОбУС.КодСтатуса = Перечисление_КодыУниверсальногоСообщения().ЗапросУточнения Тогда
		
		Результат = "запросил уточнение документа";
		
	ИначеЕсли ИнформацияОбУС.КодСтатуса = Перечисление_КодыУниверсальногоСообщения().ОтказВПодписи Тогда
		
		Если ParentAttachmentType = ТипВложения.RevocationRequest Тогда
			
			Результат = "отказал в аннулировании документа";
			
		Иначе
		
			Результат = "отказал в принятии документа";
			
		КонецЕсли;
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

Функция ОписаниеСобытияИсторииДО_УС_Подписант(ДанныеУС)
	
	МассивФИО = Новый Массив;
	МассивФИО.Добавить(ДанныеУС.Отправитель.Фамилия);
	МассивФИО.Добавить(ДанныеУС.Отправитель.Имя);
	Отчество = ДанныеУС.Отправитель.Отчество;
	
	Если ЗначениеЗаполнено(Отчество) Тогда
		МассивФИО.Добавить(Отчество);
	КонецЕсли;
	
	Подписант = ФамилияИО(СоединитьСтроку(МассивФИО, " "));
	
	Возврат Подписант;
	
КонецФункции

Функция Контракт_ИнформацияОбУниверсальномСообщении()
	
	Результат = Новый Структура();
	
	Результат.Вставить("КодГруппы");
	Результат.Вставить("КодСтатуса");
	Результат.Вставить("ТекстСтатуса");
	Результат.Вставить("ИдентификаторСоздателя");
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ИсторияДО_ИнформацияОбУС(UniversalMessageInfo)
	
	ИнформацияОбУниверсальномСообщении = Контракт_ИнформацияОбУниверсальномСообщении();
	
	ИнформацияОбУниверсальномСообщении.КодГруппы = СвойствоСтруктуры(UniversalMessageInfo, "CodeGroup", "");
	
	Events = СвойствоСтруктуры(UniversalMessageInfo, "Events");
	
	Если Не Events = Неопределено
		И ТипЗнч(Events) = Тип("Массив") Тогда
		
		Event = Events[0];
		StatusCode = СвойствоСтруктуры(Event, "StatusCode", 0);
		StatusCodeСтрокой = Формат(StatusCode, "ЧГ=0");
		ИнформацияОбУниверсальномСообщении.КодСтатуса = StatusCodeСтрокой;
		ИнформацияОбУниверсальномСообщении.ТекстСтатуса = СвойствоСтруктуры(Event, "PlainText", "");
		
	КонецЕсли;
	
	UniversalMessageCreator = СвойствоСтруктуры(UniversalMessageInfo, "UniversalMessageCreator");
	Если Не UniversalMessageCreator = Неопределено Тогда
		ИнформацияОбУниверсальномСообщении.ИдентификаторСоздателя = СвойствоСтруктуры(UniversalMessageCreator, "BoxId", "");
	КонецЕсли;
	
	Возврат ИнформацияОбУниверсальномСообщении;
	
КонецФункции

Функция Документы_ИсторияДО_ДанныеУС(Content)
	
	ДанныеУС = Контракт_ДанныеУниверсальногоСообщенияРасширенный();

	Если КонтентСодержитДанные(Content) Тогда

		Если ТипЗнч(Content.Data) = Тип("Строка") Тогда
			Data = Base64Значение(Content.Data);
		Иначе 
			Data = Content.Data;
		КонецЕсли;
		
		ДанныеУС = УС_ДанныеУниверсальногоСообщенияИзXML(Data);
	КонецЕсли;
	
	Возврат ДанныеУС;
	
КонецФункции

