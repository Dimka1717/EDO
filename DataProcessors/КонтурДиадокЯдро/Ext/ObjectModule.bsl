	ИсключаемыеМодули.Добавить(ИмяИМ_БП20());
	ИсключаемыеМодули.Добавить(ИмяИМ_УТ103());
	
	ТекущийИМ = ИнтеграционныйМодуль_Получить();
	
	ИспользоватьПечатнуюФорму1С = (ИсключаемыеМодули.Найти(ТекущийИМ) = Неопределено);
	
