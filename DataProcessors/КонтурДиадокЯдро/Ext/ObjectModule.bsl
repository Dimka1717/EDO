Функция ЛичныйКабинет_ПредставлениеПредложенияПоСертификату(ПредложениеДляПокупки)
	
	Результат = "Сертификат: %1";
	ФИО = "";
	
	Если ТипЗнч(ПредложениеДляПокупки.ДопИнформация) = Тип("Соответствие")
		ИЛИ ТипЗнч(ПредложениеДляПокупки.ДопИнформация) = Тип("ФиксированноеСоответствие") Тогда
		
		КлючФИО = "user";
		ЗначениеФИО = ПредложениеДляПокупки.ДопИнформация.Получить(КлючФИО);
		
		Если ЗначениеЗаполнено(ЗначениеФИО) И ФИО <> "null" Тогда
			ФИО = ЗначениеФИО;
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Общее_ПодставитьПараметрыВСтроку(Результат, ФИО);
	
	Возврат Результат;
	
КонецФункции

