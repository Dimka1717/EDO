КонецФункции

Функция Документы_ИсторияДО_Должность(Знач ДанныеSignature)
	
	Результат = "";
	
	Если НЕ ЗначениеЗаполнено(ДанныеSignature) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеSignature.JobTitle) Тогда
		Результат = ДанныеSignature.JobTitle;
	Иначе
		Результат = "Сотрудник";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ИсторияДО_ДополнитьКомментарии(Результат, Знач AttachmentComments)
	
	Для Каждого Entity Из AttachmentComments Цикл
		
		ParentEntityId = СвойствоСтруктуры(Entity, "ParentEntityId");
		Content = СвойствоСтруктуры(Entity, "Content");
		
		СобытиеРодитель = Результат.Найти(ParentEntityId, "EntityId");
		Если СобытиеРодитель = Неопределено
			ИЛИ НЕ КонтентСодержитДанные(Content) Тогда
			Продолжить;
		КонецЕсли;
		
		Комментарий = ДвоичныеДанные_В_Текст(Base64Значение(Content.Data), КодировкаТекста.UTF8);
		СобытиеРодитель.Комментарий = Комментарий;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Документы_ИсторияДО_ДанныеМЧД(EntityId, SortedEntities, BoxID, MessageId, ПараметрыСервиса)
	// BSLLS:DuplicateStringLiteral-off
	
	Результат = Неопределено;
	
	PowerOfAttorneyEntity = МассивСтруктур_Найти(SortedEntities, EntityId, "ParentEntityId");
	
	Если PowerOfAttorneyEntity = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ParentEntityId", PowerOfAttorneyEntity.EntityId);
	PowerOfAttorneyStatuses = МассивСтруктур_НайтиСтроки(SortedEntities, ПараметрыОтбора);
	
	PowerOfAttorneyStatus = Неопределено;
	Для Каждого ЭлементСтатуса Из PowerOfAttorneyStatuses Цикл
		Если ЭлементСтатуса.Свойство("PowerOfAttorneyInfo")
			И НЕ ЭлементСтатуса.PowerOfAttorneyInfo.Свойство("RoamingSendingStatus") Тогда
			PowerOfAttorneyStatus = ЭлементСтатуса;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если PowerOfAttorneyStatus = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеМЧД = АПИ_GetPowerOfAttorneyInfo(ПараметрыСервиса, BoxID, MessageId, PowerOfAttorneyEntity.EntityId);
	ИнформацияМЧД = СвойствоСтруктуры(PowerOfAttorneyStatus, "PowerOfAttorneyInfo");
	
	Если ИнформацияМЧД <> Неопределено Тогда
		
		СтатусМЧД = СвойствоСтруктуры(ИнформацияМЧД, "Status");
		Если СтатусМЧД = Неопределено Тогда
			СтатусМЧД = СвойствоСтруктуры(ИнформацияМЧД, "SendingStatus");
		КонецЕсли;
		
		СтруктураОшибок = Новый Структура;
		
		РасшифровкаСтатуса = СвойствоСтруктуры(СтатусМЧД, "StatusText");
		ИдентификаторСтатуса = СвойствоСтруктуры(СтатусМЧД, "StatusNamedId");
		СписокОшибок = СписокОшибокВалидацииМЧД(СтатусМЧД);
		
		СтруктураОшибок.Вставить("РасшифровкаСтатуса", РасшифровкаСтатуса);
		СтруктураОшибок.Вставить("ИдентификаторСтатуса", ИдентификаторСтатуса);
		СтруктураОшибок.Вставить("СписокОшибок", СписокОшибок);
		
		ДанныеМЧД.СтатусПроверки.Статус = СтатусМЧД;
		ДанныеМЧД.СтатусПроверки.ДатаПроверки = МестноеВремя(Ticks_2_Date(PowerOfAttorneyStatus.RawCreationDate));
		ДанныеМЧД.СтатусПроверки.СтруктураОшибок = СтруктураОшибок;
		
		ДанныеМЧД.Вставить("BoxID", BoxID);
		ДанныеМЧД.Вставить("MessageId", MessageId);
		ДанныеМЧД.Вставить("EntityId", PowerOfAttorneyEntity.EntityId);
		
		Результат = ДанныеМЧД;
		
	КонецЕсли;
	
	Возврат Результат;
	// BSLLS:DuplicateStringLiteral-on
КонецФункции

Функция Документы_ИсторияДО_ПредставлениеМЧД(Знач ИдентификаторСтатуса) Экспорт
	
	Результат = "Нет МЧД";
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторСтатуса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если НРег(ИдентификаторСтатуса) = НРег("isValid") Тогда
		Результат = "МЧД прошла проверку";
	ИначеЕсли НРег(ИдентификаторСтатуса) = НРег("isNotValid") Тогда
		Результат = "МЧД не прошла проверку";
	Иначе
		Результат = "МЧД с предупреждениями";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

