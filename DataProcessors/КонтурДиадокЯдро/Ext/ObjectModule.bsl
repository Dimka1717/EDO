Функция ПодключаемыйМодуль_ПрочитатьНастройки()
	
	ОбнаруженаОшибкаПодключенияПМ = ОбщийКонтекст_Прочитать("ОбнаруженаОшибкаПодключенияПМ") = Истина;
	МестонахождениеПМ = ЗначениеНастройки_МестонахождениеПодключаемогоМодуля();
	ИспользоватьПМ = ЗначениеНастройки_ИспользоватьПодключаемыйМодуль();
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьПодключаемыйМодуль", ИспользоватьПМ);
	Результат.Вставить("ОбнаруженаОшибкаПодключенияПМ", ОбнаруженаОшибкаПодключенияПМ);
	Результат.Вставить("МестонахождениеПодключаемогоМодуля", МестонахождениеПМ);
	Результат.Вставить("ПутьКПМ", ПодключаемыйМодуль_Путь(МестонахождениеПМ));
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_ТекстОшибкиНеЯвляетсяПМ()
	
	Результат = 
	"Выбранный файл не является подключаемым модулем для модуля Универсальный.
	|1. Проверьте параметры подключаемого модуля в настройках
	|2. Проверьте, что выбранный файл не является ПМ для модуля Стандарт. Если вы переходите со Стандарта, то повторно подключать ПМ не нужно. Доработки перенесутся автоматически";
	
	Возврат Результат;
	
КонецФункции

Функция ПодключаемыйМодуль_ПроверитьВозможностьПодключения(ПутьКПМ, МестонахождениеПМ, ВозвращаемаяОшибка) Экспорт
	
	Отказ = Ложь;
	
	Попытка
		
		ЭкземплярОбработки = Обработка_Создать(ПутьКПМ, МестонахождениеПМ);
		ЭкземплярОбработки.ОсновнойМодуль = Модуль_ВызовыПМ(ЭтотОбъект);
		
	Исключение
		
		Отказ = Истина;
		
		Ошибка = ИнформацияОбОшибке();
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			"Не удалось подключить ПМ расположенный в %1;. Подробности см. в журнале регистрации.",
			Строка(ПутьКПМ)
		);
		
		ТекстЖР = Общее_ПодставитьПараметрыВСтроку(
			"Не удалось подключить ПМ (путь к ПМ = %1; расположение = %2) по причине:
			|%3",
			Строка(ПутьКПМ),
			Строка(МестонахождениеПМ),
			ПодробноеПредставлениеОшибки(Ошибка)
		);
		
		Ошибка_ДобавитьВЖурналРегистрации(
			ТекстЖР
		);
		
		ВозвращаемаяОшибка = ТекстОшибки;
		
	КонецПопытки;
	
	Если Не Отказ
		И Не ПодключаемыйМодуль_Проверить(ЭкземплярОбработки) Тогда
		
		Отказ = Истина;
		ВозвращаемаяОшибка = ПодключаемыйМодуль_ТекстОшибкиНеЯвляетсяПМ();
		
	КонецЕсли;
	
	Результат = Не Отказ;
	
	Возврат Результат;
	
КонецФункции

