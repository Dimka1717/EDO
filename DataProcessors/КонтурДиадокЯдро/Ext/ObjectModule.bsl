// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//   * Хост - Строка - адрес провайдера
//   * Тип - Строка - Тип получаемого токена: "urn:ietf:params:oauth:grant-type:device_code", "client_credentials"
//
Функция МодельАутхКонфигурацияПровайдера()
	
	Результат = Новый Структура;
	Результат.Вставить("Хост", "");
	Результат.Вставить("Тип", "");
	
	Возврат Результат;
	
КонецФункции

// Возвращает путь к конфигурационному файлу из параметров запуска.
//
// Параметры:
//  ПараметрыЗапускаСтрокой - Строка - Параметры запуска приложения
// 
// Возвращаемое значение:
//  Строка - путь к конфигурационному файлу.
//
Функция КонфигурационныйФайл_Путь(Знач ПараметрыЗапускаСтрокой) Экспорт
	
	Результат = "";
	
	СписокПараметров = РазделитьСтрокуЛок(ПараметрыЗапускаСтрокой, ";");
	
	Для Каждого Подстрока Из СписокПараметров Цикл
		
		Если Не ЗначениеЗаполнено(Подстрока) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючЗначение = КлючЗначениеИзСтроки(Подстрока);
		Если НРег(КлючЗначение.Ключ) = "diadoc-config" Тогда
			Результат = КлючЗначение.Значение;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает значения параметров, установленных в конфигурационном файле
// 
// Возвращаемое значение:
//  ФиксированноеСоответствие из КлючИЗначение:
//    * Ключ - Строка - Идентификатор параметра конфигурационнного файла.
//    * Значение - Строка, Число, Булево - Значение параметра конфигурационнного файла.
//
Функция КонфигурационныйФайл_ЗначенияПараметров()
	
	ЗначенияПараметров = ОбщийКонтекст_Прочитать("__КонфигурационныйФайл");
	Если ТипЗнч(ЗначенияПараметров) <> Тип("ФиксированноеСоответствие")
		И ТипЗнч(ЗначенияПараметров) <> Тип("Соответствие") Тогда
		ЗначенияПараметров = Новый ФиксированноеСоответствие(Новый Соответствие);
		ОбщийКонтекст_Поместить("__КонфигурационныйФайл", ЗначенияПараметров);
	КонецЕсли;
	
	Возврат ЗначенияПараметров;
	
КонецФункции

// Загружает значения параметров из конфигурационного файла в соответствие
// и помещает его в общий контекст с ключом "__КонфигурационныйФайл".
// Для совместимости значение каждого параметра помещается в общий контекст
// с тем же именем, с которым оно было указано в конфигурационном файле.
// Рекомендуется использовать значения параметров из значения ключа __КонфигурационныйФайл.
//
// Параметры:
//  КонфигФайл - ДвоичныеДанные - двоичные данные конфигурационного файла из параметров запуска.
//
Процедура КонфигурационныйФайл_ЗагрузитьПараметры(КонфигФайл) Экспорт
	
	Если ТипЗнч(КонфигФайл) <> Тип("ДвоичныеДанные") Тогда
		Ошибка = "Несоответствие типов: параметр 'КонфигурационныйФайл' должен иметь тип 'ДвоичныеДанные'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ЗначенияПараметров = КонфигурационныйФайл_Прочитать(КонфигФайл);
	ОбщийКонтекст_Поместить("__КонфигурационныйФайл", ЗначенияПараметров);
	
	// Для совместимости
	Для Каждого Параметр Из ЗначенияПараметров Цикл
		
		ИмяНастройки = Параметр.Ключ;
		Значение = Параметр.Значение;
		
		Если ЗначениеЗаполнено(Значение) Тогда
			ОбщийКонтекст_Поместить(ИмяНастройки, Значение);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает значения конфигурационного файла.
// 
// Параметры:
//  КонфигФайл - ДвоичныеДанные - двоичные данные конфигурационного файла из параметров запуска.
//
// Возвращаемое значение:
//  ФиксированноеСоответствие из КлючИЗначение:
//    * Ключ - Строка - Идентификатор параметра конфигурационнного файла.
//    * Значение - Строка, Число, Булево - Значение параметра конфигурационнного файла.
//
Функция КонфигурационныйФайл_Прочитать(КонфигФайл)
	
	ВременныйФайл = ПолучитьИмяВременногоФайла(".ini");
	КонфигФайл.Записать(ВременныйФайл);
	
	ЧтениеФайла = Новый ЧтениеТекста;
	МонопольныйРежим = Ложь;
	ЧтениеФайла.Открыть(ВременныйФайл, "UTF-8", , , МонопольныйРежим);
	
	Данные = Новый Соответствие;
	
	Пока Истина Цикл
		
		Строка = ЧтениеФайла.ПрочитатьСтроку();
		Если Не ЗначениеЗаполнено(Строка) Тогда
			Прервать;
		КонецЕсли;
		
		Если ПустаяСтрока(Строка) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючЗначение = КлючЗначениеИзСтроки(Строка);
		
		Если КлючЗначение.Значение = "Истина" 
			ИЛИ КлючЗначение.Значение = "Ложь" Тогда
			
			КлючЗначение.Значение = Булево(КлючЗначение.Значение);
			
		КонецЕсли;
		
		Данные.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
		
	КонецЦикла;
	
	ЧтениеФайла.Закрыть();
	УдалитьФайлы(ВременныйФайл);
	
	Результат = Новый ФиксированноеСоответствие(Данные);
	
	Возврат Результат;
	
КонецФункции

// Делит строку формата "Ключ=Значение" на составляющие и возвращает их в виде структуры
//
// Параметры:
//  Строка - Строка - Строка в формате "Ключ=Значение".
//
// Возвращаемое значение:
//  Структура - содержит данные:
//     ** Ключ     - Строка - Значение строки до знака "=".
//     ** Значение - Строка - Значение строки после знака "=".
//
Функция КлючЗначениеИзСтроки(Строка)
	
	ПозицияРазделителя = Найти(Строка, "=");
	ЭтоФлаг = (ПозицияРазделителя = 0);
	
	Если ЭтоФлаг Тогда
		Ключ = Строка;
		Значение = Истина;
	Иначе
		Ключ = Лев(Строка, ПозицияРазделителя - 1);
		Значение = Сред(Строка, ПозицияРазделителя + 1);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ключ", Ключ);
	Результат.Вставить("Значение", Значение);
	
	Возврат Результат;
	
КонецФункции

Функция ИспользуетсяРасширениеПодсистемыХранения()
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Результат = Модуль_ХранениеДанных.ИспользуетсяРасширениеПодсистемыХранения();
	
	Возврат Результат;
	
КонецФункции

