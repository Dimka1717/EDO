Функция ДокументыУчета_Контрагент(СсылкаНаОбъект) Экспорт
	
	ДокументыУчета = Новый Массив;
	ДокументыУчета.Добавить(СсылкаНаОбъект);
	
	РеквизитыДокументов = МенеджерИнтеграции_ЗначенияРеквизитовДокументовУчета(ДокументыУчета);
	
	ЗначенияРеквизитов = РеквизитыДокументов.Получить(СсылкаНаОбъект);
	
	Если НЕ ЗначенияРеквизитов.Свойство("Контрагент") Тогда
		
		ШаблонОшибки = НСтр(
			"ru='Ошибка при проверке сопоставления контрагента:
			|Документ учета: %1'"
		);
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(
			ШаблонОшибки,
			СсылкаНаОбъект
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = ЗначенияРеквизитов.Контрагент;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыУчета_Организация(СсылкаНаОбъект) Экспорт
	
	ДокументыУчета = Новый Массив;
	ДокументыУчета.Добавить(СсылкаНаОбъект);
	
	РеквизитыДокументов = МенеджерИнтеграции_ЗначенияРеквизитовДокументовУчета(ДокументыУчета);
	
	ЗначенияРеквизитов = РеквизитыДокументов.Получить(СсылкаНаОбъект);
	
