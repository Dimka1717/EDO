Функция Подразделения_СсылкаПоИдентификатору(DepartmentId, ДляОрганизации = Истина) Экспорт
	
	Результат = Неопределено;
	
	Если ИдентификаторЗаполнен(DepartmentId) Тогда 
		
		Если ДляОрганизации Тогда
			ИмяКэша = "УчастникиЭДО_ПодразделенияОрганизаций";
		Иначе
			ИмяКэша = "УчастникиЭДО_ПодразделенияКонтрагентов";
		КонецЕсли;
			
		УчастникиЭДО_Подразделения = Кэш_Прочитать(ИмяКэша);
		
		Если УчастникиЭДО_Подразделения = Неопределено Тогда
			
			УчастникиЭДО_Подразделения = Новый Соответствие;
			Кэш_Поместить(ИмяКэша, УчастникиЭДО_Подразделения);
			
		КонецЕсли;
		
		Идентификаторы	= Новый_ИдентификаторыСправочника(, DepartmentId);
		Ключ = Новый_КлючИдентификаторовСправочника(Идентификаторы);
		
		Результат = УчастникиЭДО_Подразделения.Получить(Ключ);
		
		Если Результат = Неопределено Тогда
			
			Результат = ХранениеДанных_СсылкаПоИдентификаторуПодразделение(Идентификаторы, ДляОрганизации);
			
			УчастникиЭДО_Подразделения.Вставить(Ключ, Результат);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

