	Действие = Метрика_НазваниеДействий().Авторизация;
	
	Для Каждого Элемент Из Контекст Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		ИдентификаторПодписки = СтрокаКонтекста.СервисПодпискиНаМодуль.Идентификатор;
		
		ПеременныеКонтекстаЯщика = Новый Соответствие;
		ПеременныеКонтекстаЯщика.Вставить("UserID", СтрокаКонтекста.Сессия.Пользователь.Идентификатор);
		ПеременныеКонтекстаЯщика.Вставить("BoxID", СтрокаКонтекста.Ящик.Идентификатор);
		ПеременныеКонтекстаЯщика.Вставить("СервисПодпискиНаМодуль", ?(ЗначениеЗаполнено(ИдентификаторПодписки), ИдентификаторПодписки, ""));
		ПеременныеКонтекстаЯщика.Вставить("Нужна МЧД", СтрокаКонтекста.ТребуетсяМЧД);
		ПеременныеКонтекстаЯщика.Вставить("IsTest", СтрокаКонтекста.Ящик.Организация.Тестовая);
		
		Если ЗначениеЗаполнено(СтрокаКонтекста.Сертификат) Тогда
			ПеременныеКонтекстаЯщика.Вставить("Сертификат", Формат(СтрокаКонтекста.Сертификат.ЭтоКЭП, "БЛ=НЭП; БИ=КЭП"));
		КонецЕсли;
		
		ДополнитьСоответствие(Переменные, ПеременныеКонтекстаЯщика, Истина);
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
		
	КонецЦикла;
	// BSLLS:LineLength-on
КонецПроцедуры

// Процедура - Метрика добавить статистику создание документов
//
// Параметры:
//  Документ - Структура - Описание электронного документа (см. Контракт_Документ).
//  ИдентификаторОперации - Строка - (Необязательный) Правило создания документа учета (см. Документы_СписокТиповДокументовДляСоздания).
//  ПараметрыСоздания - Структура - (Необязательный) Параметры создания документа учета (см. ДополнительныеПараметрыСозданияДокумента).
//
Процедура Метрика_ДобавитьСтатистику_СозданиеДокументов(Документ, ИдентификаторОперации, ПараметрыСоздания) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория	= "Создание документов";
	Действие	= "Создать";
	
	BoxId		 = Документ.Идентификаторы.BoxId;
	LetterId	 = Документ.Идентификаторы.LetterId;
	DocumentId	 = Документ.Идентификаторы.DocumentId;
	
	ТипДокумента	 = Документ.Тип.ТипДокумента;
	ФункцияДокумента = Документ.Тип.ФункцияДокумента;
	ТипКонтента		 = Документ.Тип.ТипКонтента;
	
	Операция = СокрЛП(ИдентификаторОперации);
	Если Не ЗначениеЗаполнено(Операция) Тогда
		Операция = "ПоУмолчанию";
	КонецЕсли;
	
	ЦенаВключаетНДС = Неопределено;
	Если ЗначениеЗаполнено(ПараметрыСоздания) Тогда
		ЦенаВключаетНДС = ПараметрыСоздания.ЦенаВключаетНДС;
	КонецЕсли;
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Переменные = Новый Соответствие;
	
	Переменные.Вставить("BaseID", ИдентификаторБазы1С);
	
	Переменные.Вставить("BoxID"		, BoxId);
	Переменные.Вставить("LetterId"	, LetterId);
	Переменные.Вставить("DocumentId", DocumentId);
	
	Переменные.Вставить("Тип документа"		, ТипДокумента);
	Переменные.Вставить("Функция документа"	, ФункцияДокумента);
	Переменные.Вставить("Версия документа"	, ТипКонтента);
	
	Переменные.Вставить("Операция", Операция);
	Переменные.Вставить("ЦенаВключаетНДС", ЦенаВключаетНДС);
	
	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

// Фиксирует данные о сопоставлении электронных документов с документами учета.
//
// Параметры:
//  Документ - Структура - Описание электронного документа (см. Контракт_Документ).
//  Действие - Строка - Выполняемое действие.
//
Процедура Метрика_ДобавитьСтатистику_СопоставлениеДокументов(Документ, Действие) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = "Сопоставление документов";
	
	BoxId		 = Документ.Идентификаторы.BoxId;
	LetterId	 = Документ.Идентификаторы.LetterId;
	DocumentId	 = Документ.Идентификаторы.DocumentId;
	
	ТипДокумента	 = Документ.Тип.ТипДокумента;
	ФункцияДокумента = Документ.Тип.ФункцияДокумента;
	ТипКонтента		 = Документ.Тип.ТипКонтента;
	
	Направление		 = Документ.Направление;
	
	Переменные = Новый Соответствие;
	
	Переменные.Вставить("BoxID"		, BoxId);
	Переменные.Вставить("LetterId"	, LetterId);
	Переменные.Вставить("DocumentId", DocumentId);
	
	Переменные.Вставить("Тип документа"		, ТипДокумента);
	Переменные.Вставить("Функция документа"	, ФункцияДокумента);
	Переменные.Вставить("Версия документа"	, ТипКонтента);
	Переменные.Вставить("Направление"		, Направление);
	
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	Переменные.Вставить("BaseID", ИдентификаторБазы1С);

	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

// Фиксирует статистические данные о том, какие версии библиотек модуля Диадок
// используются, а какие уже нет.
//
// Параметры:
//	Переменные - Соответствие - переменные для отправки в сервис статистики
Процедура Метрика_ДобавитьСтатистику_НастройкаБиблиотек(Переменные) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
		
	КатегорияМетрики = Метрика_НазваниеКатегории().НастройкаБиблиотек;
	ДействиеМетрики  = Метрика_НазваниеДействий().Инициализация;
	
	Метрика_ДобавитьСтатистику_СУчетомЗаполненияКонтекста(КатегорияМетрики
														, ДействиеМетрики
														, 
														, Переменные);
	
КонецПроцедуры

// Добавляет в статистику информацию об установленных плагинах.
//
Процедура Метрика_ДобавитьСтатистику_Плагины() Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ИспользоватьПлагины() Тогда
		Возврат;
	КонецЕсли;
	
	УстановленныеПлагины = КонтурПлагины_УстановленныеПлагины();
	
	Если Не ЗначениеЗаполнено(УстановленныеПлагины) Тогда
		Возврат;
	КонецЕсли;
	
	Категория = Метрика_НазваниеКатегории().НастройкиМодуля;
	Действие = Метрика_НазваниеДействий().Плагины;
	Метка = Неопределено;
	
	ОписанияПлагинов = Новый Соответствие;
	
	Для Каждого Плагин Из УстановленныеПлагины Цикл
		
		Подробности = Новый Структура;
		Подробности.Вставить("Версия", Плагин.Версия);
		Подробности.Вставить("Состояние", Плагин.Состояние);
		
		ОписанияПлагинов.Вставить(Плагин.Идентификатор, Подробности);
		
	КонецЦикла;
	
	Метрика_ДобавитьСтатистику_ПоКонтексту(
		Категория,
		Действие,
		Метка,
		ОписанияПлагинов
	);
	
КонецПроцедуры

// Фиксирует данные о системной информации. Статистические данные используются для
// понимания от каких технических ограничений можно отказаться, а какие еще требуется поддержать.
//
// Параметры:
//	ДопПеременные - Соответствие, Неопределено - переменные для отправки в сервис статистики
//
Процедура Метрика_ДобавитьСтатистику_СистемнаяИнформация(ДопПеременные = Неопределено) Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория	= Метрика_НазваниеКатегории().СистемнаяИнформация;
	Действие	= Метрика_НазваниеДействий().Инициализация;
	
	Если ДопПеременные <> Неопределено Тогда
		Переменные = Общее_СкопироватьСоответствие(ДопПеременные);
	Иначе
		Переменные = Новый Соответствие;
	КонецЕсли;
			
	РежимСовместимостиПлатформ = Строка(Метаданные.РежимСовместимости);
	РежимСовместимостиПлатформ = СтрЗаменить(РежимСовместимостиПлатформ, "Версия", "");
	
	Если ОбщийКонтекстКлиентСервер.ФайловыйРежимРаботы Тогда
		ВариантИБ = "Файловая";
	Иначе
		ВариантИБ = "Серверная";
	КонецЕсли;
	
	ОписаниеРасположенияМодуля = ОбщийКонтекст_Прочитать("РасположениеМодуля");
	Если ОписаниеРасположенияМодуля <> Неопределено Тогда
		РасположениеМодуля	= ОписаниеРасположенияМодуля.РасположениеМодуля;
	Иначе
		РасположениеМодуля	= "Не удалось определить";
	КонецЕсли;
			
	ТекущийПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();
	
	Если ПриложениеСтаршеВерсии("8.3.9.2033") Тогда
		ПредупреждатьОбОпасныхДействиях = Ложь;
	Иначе
		ПредупреждатьОбОпасныхДействиях = ТекущийПользовательИБ.ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях;
	КонецЕсли;
	
	ПраваНаЗапускВО = ПравоДоступа("ИнтерактивноеОткрытиеВнешнихОбработок", Метаданные);
	
	РасположениеСправочникаДО = Новый Массив;
	РасположениеСправочникаДО.Добавить("Диадок_Файлы");
	РасположениеСправочникаДО.Добавить("ДополнительныеОтчетыИОбработки");
	РасположениеСправочникаДО.Добавить("ВнешниеОбработки");
			
	СправочникиДО = Новый Массив;
	Для Каждого Расположение Из РасположениеСправочникаДО Цикл
		
		Если Метаданные.Справочники.Найти(Расположение) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьПравоНаИзменение = ПравоДоступа("Изменение", Метаданные.Справочники[Расположение]);
		
		ЗначениеПеременной = Новый Структура;
		ЗначениеПеременной.Вставить("ИмяСправочника", Расположение);
		ЗначениеПеременной.Вставить("ПравоНаЗапись"	, ЕстьПравоНаИзменение);
		
		СправочникиДО.Добавить(ЗначениеПеременной);
		
	КонецЦикла;

	ИспользуетсяПодсистемаДиадок = ОбщийКонтекст_Прочитать("ИспользуетсяПодсистемаДиадок");
	ИспользуетсяРасширениеПодсистемыХранения = ОбщийКонтекст_Прочитать("ИспользуетсяРасширениеПодсистемыХранения");
	
	Переменные.Вставить("РежимСовместимостиПлатформ", РежимСовместимостиПлатформ);
	Переменные.Вставить("ВариантИБ", ВариантИБ);
	Переменные.Вставить("РасположениеМодуля", РасположениеМодуля);
	Переменные.Вставить("ПредупреждатьОбОпасныхДействиях", ПредупреждатьОбОпасныхДействиях);
	Переменные.Вставить("ПраваНаЗапускВО", ПраваНаЗапускВО);
	Переменные.Вставить("СправочникиДО", СправочникиДО);
	Переменные.Вставить("ИспользуетсяПодсистемаДиадок", ИспользуетсяПодсистемаДиадок);
	Переменные.Вставить("ИспользуетсяРасширениеПодсистемыХранения", ИспользуетсяРасширениеПодсистемыХранения);
	
	ДополнитьПеременныеМетрики_BaseId(Переменные);
	ДополнитьПеременныеМетрики_ТиповойМодуль(Переменные);
	
	Метрика_ЗаписатьСтатистику(Категория, Действие, , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_ПоКонтексту(Категория, Действие, Метка = Неопределено, ДопПеременные = Неопределено, ПредставлениеМетрики = "", TraceId = "") Экспорт
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиКонтекста	= КонтекстСеанса_СтрокиКонтекста();
	ИдентификаторБазы1С = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		
		Переменные = Новый Соответствие;
		Переменные.Вставить("BoxID", АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId));
		Переменные.Вставить("UserID", СтрокаКонтекста.ОписаниеПользователя.Id);
		Переменные.Вставить("BaseID", ИдентификаторБазы1С);
		Переменные.Вставить("IsTest", СтрокаКонтекста.Ящик.Организация.Тестовая);
		
		Если ДопПеременные <> Неопределено Тогда
			Для каждого Переменная Из ДопПеременные Цикл
				Переменные.Вставить(Переменная.Ключ, Переменная.Значение);
			КонецЦикла; 
		КонецЕсли;
		
		Метрика_ЗаписатьСтатистику(Категория, Действие, Метка, Переменные, , TraceId , ПредставлениеМетрики);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_СУчетомЗаполненияКонтекста(КатегорияМетрики, ДействиеМетрики, Метка = Неопределено, ДопПеременные = Неопределено, ПредставлениеМетрики = "", TraceId = "") Экспорт

	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьСтатистику_ПоКонтексту(КатегорияМетрики, ДействиеМетрики, Метка, ДопПеременные, ПредставлениеМетрики, TraceId);
	Иначе
		Метрика_ДобавитьСтатистику_ДляОрганизации("", КатегорияМетрики, ДействиеМетрики, Метка, ДопПеременные, ПредставлениеМетрики, TraceId);
	КонецЕсли;
	
КонецПроцедуры

Процедура Метрика_ДобавитьСтатистику_ДляОрганизации(BoxId, Категория, Действие, НазваниеМетки = Неопределено, ДопПеременные = Неопределено, ПредставлениеМетрики = "", TraceId = "") Экспорт
	
