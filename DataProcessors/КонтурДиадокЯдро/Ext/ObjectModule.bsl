// Выполняет быструю проверку переданной МЧД для ящика. Актуальна при авторизации по сертификату.
// Выполняется до подписания документа, чтобы проверить, что пользователь верно выбрал серт и МЧД
//
// Параметры:
//  КонтрактМЧД	 - Структура	 - проверяемая МЧД (см. Новый_КонтрактМЧД)
//  boxId		 - Строка		 - идентификатор ящика
//
// Возвращаемое значение:
//  Структура - результат проверки, возвращаемый API:
//		* ЭтоДействующаяМЧД 	- Булево - признак, что МЧД действительна
//		* РасшифровкаСтатуса 	- Строка - расшифровка статуса проверки, возвращаемая API
//		* КритичностьСтатуса 	- Строка - критичность статуса проверки (см. Контракт_УровниКритичностиСтатусаДокумента)
//		* ИдентификаторСтатуса 	- Строка - идентификатор статуса проверки
//		* СписокОшибок 			- Массив - список детальной информации по ошибкам. Содержит структуры с описанием ошибок
//				Элемент массива:
//					* Код 			- Строка - код ошибки
//					* Расшифровка 	- Строка - текст ошибки
//
Функция МЧД_БыстраяПроверка(КонтрактМЧД, boxId) Экспорт
	
	RegistraionNumber = СвойствоСтруктуры(КонтрактМЧД, "Идентификатор", "");
	Доверитель = СвойствоСтруктуры(КонтрактМЧД, "Доверитель");
	issuerInn = СвойствоСтруктуры(Доверитель, "ИНН", "");
	Представитель = СвойствоСтруктуры(КонтрактМЧД, "Представитель");
	RepresentativeInn = СвойствоСтруктуры(Представитель, "ИНН", "");
	Thumbprint = КонтекстСеанса_Прочитать(BoxID, "ОтпечатокСертификата");
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	РезультатПроверки = Модуль_МетодыAPI.DD_API_PostPrevalidatePowerOfAttorney(
			ПараметрыСервиса,
			boxId,
			RegistraionNumber,
			issuerInn,
			RepresentativeInn,
			Thumbprint
	);
	
	Результат = МЧД_РасшифровкаPowerOfAttorneyPrevalidateResult(РезультатПроверки);
	
	Возврат Результат;
	
КонецФункции 

Функция МЧД_РасшифровкаPowerOfAttorneyPrevalidateResult(РезультатПроверки)
	
	Результат = Новый Структура;
	ЭтоДействующаяМЧД = Ложь;
	ЭтоПредупреждение = Ложь;
	СписокОшибок = Новый Массив;
	
	PrevalidateStatus = СвойствоСтруктуры(РезультатПроверки, "PrevalidateStatus");
	
	Если PrevalidateStatus <> Неопределено Тогда
		
		УровниКритичности = Контракт_УровниКритичностиСтатусаДокумента();
		
		РасшифровкаСтатуса = СвойствоСтруктуры(PrevalidateStatus, "StatusText");
		КритичностьСтатуса = СвойствоСтруктуры(PrevalidateStatus, "Severity");
		ИдентификаторСтатуса = СвойствоСтруктуры(PrevalidateStatus, "StatusNamedId");
		ЭтоДействующаяМЧД = КритичностьСтатуса = УровниКритичности.Success;
		ЭтоПредупреждение = КритичностьСтатуса = УровниКритичности.Warning;
		
		СписокОшибок = СписокОшибокВалидацииМЧД(PrevalidateStatus);
		
	КонецЕсли;
	
	Результат.Вставить("ЭтоДействующаяМЧД", ЭтоДействующаяМЧД);
	Результат.Вставить("РасшифровкаСтатуса", РасшифровкаСтатуса);
	Результат.Вставить("КритичностьСтатуса", КритичностьСтатуса);
	Результат.Вставить("ИдентификаторСтатуса", ИдентификаторСтатуса);
	Результат.Вставить("СписокОшибок", СписокОшибок);
	Результат.Вставить("ЭтоПредупреждение", ЭтоПредупреждение);
	
	Возврат Новый ФиксированнаяСтруктура(Результат);
	
КонецФункции

Функция СписокОшибокВалидацииМЧД(Знач PrevalidateStatus)
	
	Результат = Новый Массив;
	
	ПротоколВалидации = СвойствоСтруктуры(PrevalidateStatus, "ValidationProtocol");
	ОшибкаОперации = СвойствоСтруктуры(PrevalidateStatus, "OperationError");
	КоллекцияОшибок = СвойствоСтруктуры(PrevalidateStatus, "Errors");
	
	// BSLLS:IfElseIfEndsWithElse-off
	// BSLLS:DuplicateStringLiteral-off
	Если ЗначениеЗаполнено(ОшибкаОперации) Тогда
		
		ОписаниеОшибки = Новый_ОшибкаВалидацииМЧД(
				ОшибкаОперации.Code,
				ОшибкаОперации.Text);
		
		Результат.Добавить(ОписаниеОшибки);
		
	ИначеЕсли ЗначениеЗаполнено(ПротоколВалидации) Тогда
		
		РезультатыПроверки = ПротоколВалидации.CheckResults;
		
		Для Каждого Элемент Из РезультатыПроверки Цикл
			
			Ошибка = СвойствоСтруктуры(Элемент, "Error");
			
			СтатусОшибки = СвойствоСтруктуры(Элемент, "Status");
			
			Если НЕ ЗначениеЗаполнено(Ошибка) Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			ОписаниеОшибки = Новый_ОшибкаВалидацииМЧД(
					Ошибка.Code,
					Ошибка.Text,
					СтатусОшибки);
			
			Результат.Добавить(ОписаниеОшибки);
			
		КонецЦикла;
		
	ИначеЕсли ЗначениеЗаполнено(КоллекцияОшибок) Тогда
		
		Для Каждого Ошибка Из КоллекцияОшибок Цикл
			
			ОписаниеОшибки = Новый_ОшибкаВалидацииМЧД(
					Ошибка.Code,
					Ошибка.Text);
			
			Результат.Добавить(ОписаниеОшибки);
			
		КонецЦикла;
		
	КонецЕсли;
	// BSLLS:DuplicateStringLiteral-on
	// BSLLS:IfElseIfEndsWithElse-on
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ОшибкаВалидацииМЧД(Код, Расшифровка, Тип = "")
	
	Результат = Новый Структура;
	Результат.Вставить("Код", Код);
	Результат.Вставить("Расшифровка", Расшифровка);
	Результат.Вставить("Тип", Тип);
	
	Возврат Результат;
	
КонецФункции

// Возвращает коллекцию действий ЭДО, которые требуют МЧД при постинге
// 
// Возвращаемое значение:
//  Соответствие - Ключ - строка, описывающая действие ЭДО (см. Перечисление_ДействияЭДО)
//					Значение - признак Булево, что действие требует МЧД
//
Функция МЧД_ДействияТребующиеДоверенность() Экспорт

	ДействияЭДО = Перечисление_ДействияЭДО();
	
	Результат = Новый Соответствие;
	Результат.Вставить(ДействияЭДО.ПодписатьИОтправить, Истина);
	Результат.Вставить(ДействияЭДО.ПереотправитьПакет, Истина);
	Результат.Вставить(ДействияЭДО.Аннулировать, Истина);
	Результат.Вставить(ДействияЭДО.ОтправитьОтвет, Истина);
	Результат.Вставить(ДействияЭДО.Подписать, Истина);
	Результат.Вставить(ДействияЭДО.ПодписатьВходящий, Истина);
	
	ТребуетсяФормироватьУС = УС_ТребуетсяФормироватьУниверсальныеСообщения();
	
	Если НЕ ТребуетсяФормироватьУС Тогда
		
		Результат.Вставить(ДействияЭДО.ОтказатьВПодписи, Истина);
		Результат.Вставить(ДействияЭДО.ОтказатьВАннулировании, Истина);
		Результат.Вставить(ДействияЭДО.ЗапроситьУточнение, Истина);
		Результат.Вставить(ДействияЭДО.ОтправитьИзвещениеОПолучении, Истина);
		
	КонецЕсли;
	
	Возврат Новый ФиксированноеСоответствие(Результат);
	
КонецФункции

// Дополняет служебную информацию документа сведениями о машиночитаемой доверенности установленной по умолчанию.
// МЧД добавляется, если еще нет свойства КонтрактМЧД и требуется МЧД. Если МЧД не валидная, то свойство добавляется
// со значением Неопределено, что является признаком того, что нужно отправить документ без МЧД.
//
// Параметры:
//	Документ - Структура - контракт документа (см. Контракт_Документ)
//
Процедура Документ_ДополнитьСведениямиМЧД(Документ)
	
	ИмяСвойстваКонтрактМЧД = "КонтрактМЧД";
	
	Если Документ.СлужебнаяИнформация.Свойство(ИмяСвойстваКонтрактМЧД) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторЯщика = Документ.Идентификаторы.BoxId;
	
	КонтрактМЧД = МЧД_ДанныеМЧДИзПодключаемогоМодуля(ИдентификаторЯщика);
	
	Если НЕ ЗначениеЗаполнено(КонтрактМЧД) Тогда
		
		КонтекстМЧД = МЧД_ПолучитьКонтекстДляГрупповыхДействий(ИдентификаторЯщика);
		
		Если НЕ КонтекстМЧД.ТребуетсяМЧД Тогда
			Возврат;
		КонецЕсли;
		
		ЭтоДействующаяМЧД = СвойствоСтруктуры(КонтекстМЧД.РезультатПроверкиМЧД, "ЭтоДействующаяМЧД", Ложь);
		Если ЭтоДействующаяМЧД Тогда
			КонтрактМЧД = КонтекстМЧД.СписокМЧД.Получить(КонтекстМЧД.МЧД);
		КонецЕсли;
		
	КонецЕсли;
	
	Контрагент = Документы_Контрагент(Документ);
	КонтрагентНеПоддерживаетМЧД = НЕ МЧД_ОператорЭДОПоддерживаетДоверенности(ИдентификаторЯщика, Контрагент.FNSParticipantId);
	
	Если КонтрагентНеПоддерживаетМЧД Тогда
		
		ШаблонЗаписиВЖР = "Документ %1 от %2: МЧД не отправлена. Оператор контрагента не поддерживает передачу МЧД в роуминге.";
		ТекстЗаписи = Общее_ПодставитьПараметрыВСтроку(ШаблонЗаписиВЖР, Документ.Реквизиты.Номер, Документ.Реквизиты.Дата);
		ЗаписьЖурналаРегистрации("Диадок.ОператорКонтрагентаНеПоддерживаетДоверенностиВРоуминге", , , , ТекстЗаписи);
		
		КонтрактМЧД = Неопределено;
		
	КонецЕсли;
	
	Документ.СлужебнаяИнформация.Вставить(ИмяСвойстваКонтрактМЧД, КонтрактМЧД);
	
КонецПроцедуры

Процедура Пакет_ДополнитьДокументыСведениямиМЧД(Пакет)
	
	Если Пакет.СлужебнаяИнформация.Свойство("КонтрактМЧД") Тогда
		
		Для Каждого Документ Из Пакет.Документы Цикл
			Документ.СлужебнаяИнформация.Вставить("КонтрактМЧД", Пакет.СлужебнаяИнформация.КонтрактМЧД);
		КонецЦикла;
		
	Иначе
		
		Для Каждого Документ Из Пакет.Документы Цикл
			Документ_ДополнитьСведениямиМЧД(Документ);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Удаляет из кэша значения контекстов МЧД, которые использовались при групповых действиях
//
Процедура МЧД_УдалитьКонтекстДляГрупповыхДействий() Экспорт
	
	КлючЗначения = МЧД_КлючКонтекстаДляГрупповыхДействий();
	Кэш_Поместить(КлючЗначения, Неопределено);
	
КонецПроцедуры

// Возвращает контекст МЧД из кэша по идентификатору ящика
//
// Параметры:
//  ИдентификаторЯщика	 - Строка - идентификатор ящика
// 
// Возвращаемое значение:
//  Структура - см. Контракт_КонтекстМЧД 
//
Функция МЧД_ПолучитьКонтекстДляГрупповыхДействий(ИдентификаторЯщика)
	
	КлючЗначения = МЧД_КлючКонтекстаДляГрупповыхДействий();
	
	КонтекстыМЧДЯщиков = Кэш_Прочитать(КлючЗначения);
	Если КонтекстыМЧДЯщиков = Неопределено Тогда
		КонтекстыМЧДЯщиков = Новый Соответствие;
	КонецЕсли;
	
	КонтекстМЧД = КонтекстыМЧДЯщиков.Получить(ИдентификаторЯщика);
	Если КонтекстМЧД = Неопределено Тогда
		КонтекстМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(ИдентификаторЯщика, Истина);
		КонтекстыМЧДЯщиков.Вставить(ИдентификаторЯщика, КонтекстМЧД);
		Кэш_Поместить(КлючЗначения, КонтекстыМЧДЯщиков);
	КонецЕсли;
	
	Возврат КонтекстМЧД;
	
КонецФункции

Функция МЧД_КлючКонтекстаДляГрупповыхДействий()

	Возврат "КонтекстМЧДприГрупповыхДействиях";
	
КонецФункции

// Коллекция шаблонов для формирования HTML
//
// Возвращаемое значение:
//	Структура
Функция МЧД_HTMLШаблоны()
	
	Начало = "<html><head>
	|<META content=""text/html; charset=utf-8"" http-equiv=Content-Type>";
	
	ТаблицаСтилей = "
	|<style type=text/css>
	|	body {font-family: Arial; margin: 1.5%;}
	|	p.head {font-SIZE: 12pt}
	|	p.strtext{font-SIZE: 10pt;}
	|	p.strtextbold{font-SIZE: 10pt; font-weight:bold;}
	|	p.strtext2{font-SIZE: 10pt; margin-bottom: -1%;}
	|	.setting {color: #969696}
	|	.imgstyle {width: 13px;}
	|</style>";
	
	НачалоТела = "</head><body>";
	
	Окончание = "</body></html>";
	
	Шапка = "
	|<p class=head>[Текст]</p>";
	
	Абзац = "
	|<p class=strtext>[Текст]<a href=""[КомандаДействия]"">[ТекстКоманды]</a>.</p>";
	
