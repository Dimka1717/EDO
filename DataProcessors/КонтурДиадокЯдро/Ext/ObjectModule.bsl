// Скачивает и устанавливает актуальную версию модуля продуктовой аналитики
//
Процедура ПродуктоваяАналитика_УстановитьОбновитьМодуль() Экспорт
	
	СервисОбновлений = Модуль_АпдейтКлиент();
	
	Версия = СервисОбновлений.КонтекстВерсии();
	Версия.Версия = ПродуктоваяАналитика_УстановленнаяВерсия();
	Версия.ИдБазы = Строка(_ИдентификаторИнформационнойБазыДиадок());
	
	Статус = СервисОбновлений.ПроверитьОбновление(
		ПродуктоваяАналитика_ИдентификаторМодуля(),
		Версия
	);
	
	Если Не Статус.ЕстьОбновление Тогда
		Возврат;
	КонецЕсли;
	
	ТипПоставки = "data-processor";
	ФайлПоставки = СервисОбновлений.СкачатьОбновление(Статус, ТипПоставки);
	
	Если Не ФайлПоставки.Размер() Тогда
		
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"КонтурДиадокАпдейтКлиент: Файл поставки не содержит данных
			|ИдБазы = %1
			|Продукт = %2
			|ТипКонтента = %3",
			Статус.ИдБазы,
			Статус.Продукт,
			ТипПоставки
		);
		
		ВызватьИсключение Ошибка;
		
	КонецЕсли;
	
	ПродуктоваяАналитика_УстановитьМодуль(ФайлПоставки);
	
КонецПроцедуры

// Запускает задание по сбору данных.
//
// Параметры:
//  ИдентификаторФормы - Строка - идентификатор формы, из которой запускается задание
// 
// Возвращаемое значение:
//  Структура: 
//   * Статус - Строка - "Выполняется", если задание еще не завершилось;
//                       "Выполнено", если задание было успешно выполнено;
//                       "Ошибка", если задание завершено с ошибкой;
//                       "Отменено", если задание отменено пользователем или администратором.
//   * ИдентификаторЗадания - УникальныйИдентификатор - если Статус = "Выполняется", то содержит
//                            идентификатор запущенного фонового задания.
//                          - Неопределено - если Статус <> "Выполняется" и фоновое задание не запускалось.
//   * АдресРезультата - Строка - адрес временного хранилища, в которое будет помещен результат работы процедуры
//                                (или уже помещен, если Статус = "Выполнено"). Во временное хранилище помещается
//                                структура с ключом "Данные"
//   * АдресДополнительногоРезультата - Строка - если установлен параметр ДополнительныйРезультат, 
//                                      содержит адрес дополнительного временного хранилища,
//                                      в которое будет помещен результат работы процедуры
//                                      (или уже помещен, если Статус = "Выполнено").
//   * КраткоеПредставлениеОшибки - Строка - краткая информация об исключении, если Статус = "Ошибка".
//   * ПодробноеПредставлениеОшибки - Строка - подробная информация об исключении, если Статус = "Ошибка".
//   * Сообщения - ФиксированныйМассив - если Статус <> "Выполняется", то массив объектов СообщениеПользователю,
//                                      которые были сформированы в фоновом задании, иначе пустой массив.
//
Функция ПродуктоваяАналитика_ПодготовитьДанные(ИдентификаторФормы) Экспорт
	
	ИмяОбработки = ПродуктоваяАналитика_ИмяОбработки();
	ДопОбработка = ДополнительныеОтчетыИОбработки_НайтиПоИмени(ИмяОбработки);
	
	Если Не ЗначениеЗаполнено(ДопОбработка) Тогда
		Ошибка = "КонтурДиадок.Интеграция: Не найден модуль продуктовой аналитики";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	ИмяПроцедуры = "ДополнительныеОтчетыИОбработки.ВыполнитьКоманду";
	ИдентификаторКоманды = "ПодготовитьДанные";
	ПараметрыКоманды = ПродуктоваяАналитикаСлужебный_ПараметрыКоманды();
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("ДополнительнаяОбработкаСсылка", ДопОбработка);
	ПараметрыПроцедуры.Вставить("ИдентификаторКоманды", ИдентификаторКоманды);
	ПараметрыПроцедуры.Вставить("ОбъектыНазначения", Неопределено);
	ПараметрыПроцедуры.Вставить("ПараметрыКоманды", ПараметрыКоманды);
	ПараметрыПроцедуры.Вставить("РезультатВыполнения", Новый Структура); // Сюда добавится ключ "Данные"
	
	МодульДлительныеОперации = Вычислить("ДлительныеОперации");
	
	НастройкиЗапуска = МодульДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	НастройкиЗапуска.НаименованиеФоновогоЗадания = "Интеграция с Контур.Диадок: Подготовить данные";
	НастройкиЗапуска.КлючФоновогоЗадания = "КонтурДиадок.Интеграция.ПодготовитьДанные";
	НастройкиЗапуска.ЗапуститьВФоне = Истина;
	
	Результат = МодульДлительныеОперации.ВыполнитьВФоне(
		ИмяПроцедуры,
		ПараметрыПроцедуры,
		НастройкиЗапуска
	);
	
	Возврат Результат;
	
КонецФункции

// Помещает продуктовые метрики в стек событий для отправки. Данные должны быть
// предварительно подготовлены методом ПродуктоваяАналитика.ПодготовитьДанные
//
// Параметры:
//  ДлительнаяОперация - Структура - см. ПродуктоваяАналитика_ПодготовитьДанные
//
Процедура ПродуктоваяАналитика_ОтправитьДанные(ДлительнаяОперация) Экспорт
	
	РезультатЗадания = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Если Не ЗначениеЗаполнено(РезультатЗадания) Тогда
		Возврат;
	КонецЕсли;
	
	Аналитика = РезультатЗадания.Данные;
	
	Если Аналитика = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Мета = Аналитика.Мета;
	Данные = Аналитика.Данные;
	
	Если СравнитьВерсии(Мета.Версия, "0.7.0") >= 0 Тогда
		
		СтекСобытий = ПродуктоваяАналитика_ПодготовитьДанныеВерсии(Мета, Данные);
		
	Иначе
		
		ПродуктоваяАналитика_ЗаписатьМетрикуОшибкаПодготовкиДанных(Мета.Версия);
		
		Возврат;
		
	КонецЕсли;
	
	ПродуктоваяАналитика_ОтправитьМетрики(СтекСобытий);
	
КонецПроцедуры

Функция ПродуктоваяАналитика_ПодготовитьДанныеВерсии(Мета, Данные)
	
	Результат = НовыйСтекСобытийМетрики();
	
	AppContext = ОписаниеПриложения();
	AbonId = Строка(_ИдентификаторИнформационнойБазыДиадок());
	TopicKey = ТопикиМетрики_ПродуктоваяАналитика();
	
	Для Каждого Событие Из Данные Цикл
		
		Событие.AppContext = AppContext;
		Событие.Session.KeSession.AbonId = AbonId;
		
		ПродуктоваяАналитика_ДобавитьСобытиеМетрики(TopicKey, Результат, Событие);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПродуктоваяАналитика_ПодготовитьДанныеБезопасно(ИдентификаторФормы) Экспорт
	
	Если Не ИспользоватьПродуктовуюАналитику() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Отказ = Ложь;
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		Результат = ПродуктоваяАналитика_ПодготовитьДанные(ИдентификаторФормы);
		
	Исключение
		
		Отказ = Истина;
		Ошибка = ИнформацияОбОшибке();
		
	КонецПопытки;
	
	Если Отказ Тогда
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаПодготовитьДанные(),
			Ошибка
		);
		
	Иначе
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаПодготовитьДанные(),
			НачалоЗамера
		);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПродуктоваяАналитика_УстановитьОбновитьМодульБезопасно() Экспорт
	
	Если Не ИспользоватьПродуктовуюАналитику() Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		ПродуктоваяАналитика_УстановитьОбновитьМодуль();
		
	Исключение
		
		Отказ = Истина;
		Ошибка = ИнформацияОбОшибке();
		
	КонецПопытки;
	
	Если Отказ Тогда
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаУстановитьОбновить(),
			Ошибка
		);
		
	Иначе
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаУстановитьОбновить(),
			НачалоЗамера
		);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПродуктоваяАналитика_ОтправитьДанныеБезопасно(ДлительнаяОперация) Экспорт
	
	Если Не ИспользоватьПродуктовуюАналитику()
		Или Не ЗначениеЗаполнено(ДлительнаяОперация) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторЗадания = ДлительнаяОперация.ИдентификаторЗадания;
	
	Попытка
		
		МодульДлительныеОперации = Вычислить("ДлительныеОперации");
		ОперацияЗавершена = МодульДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаОтправитьДанные(),
			Ошибка
		);
		
		Возврат;
		
	КонецПопытки;
	
	Если Не ОперацияЗавершена Тогда
		
		Ошибка = "КонтурДиадок.Интеграция: Подготовка данных не завершена";
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаОтправитьДанные(),
			Ошибка
		);
		
		Возврат;
		
	КонецЕсли;
	
	Попытка
		
		ПродуктоваяАналитика_ОтправитьДанные(ДлительнаяОперация);
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияПродуктоваяАналитика(),
			Метрика_ДействиеПродуктоваяАналитикаОтправитьДанные(),
			Ошибка
		);
		
	КонецПопытки;
	
КонецПроцедуры

// Проверяет, используется ли функция сбора продуктовых метрик.
// 
// Возвращаемое значение:
//  Булево.
//
Функция ИспользоватьПродуктовуюАналитику()
	
	Ключ = "ИспользоватьПродуктовыеМетрики";
	
	Результат = ОбщийКонтекст_Прочитать(Ключ);
	
	Если Результат = Неопределено Тогда
		
		Результат = ПродуктоваяАналитика_ПроверитьОкружение();
		ОбщийКонтекст_Поместить(Ключ, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет, можно ли использовать модуль продуктовой аналитики в текущем окружении.
// Для этого используется ряд проверок:
// - используется публичная версия модуля без доработок
// - модуль запущен в конфигурации, для которой адаптирован модуль продуктовой аналитики
// 
// Возвращаемое значение:
//  Булево - Истина, если все проверки пройдены успешно.
//
Функция ПродуктоваяАналитика_ПроверитьОкружение()
	
	Отказ = Ложь;
	
	Если ЭтоСборкаДляПровайдераСервиса() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если Не ПродуктоваяАналитика_КонфигурацияПоддерживается() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Результат = Не Отказ;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, можно ли использовать модуль продуктовой аналитики в текущей конфигурации.
// 
// Возвращаемое значение:
//  Булево.
//
Функция ПродуктоваяАналитика_КонфигурацияПоддерживается()
	
	ПоддерживаемыеИМ = Новый Массив;
	ПоддерживаемыеИМ.Добавить(ИмяИМ_БП30());
	
	ИмяИМ = ИнтеграционныйМодуль_Получить();
	
	Результат = ПоддерживаемыеИМ.Найти(ИмяИМ) <> Неопределено;
	
	Возврат Результат;
	
КонецФункции

