	Если ПриложениеСтаршеВерсии("8.3.13.1644") Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Нужно использовать для автотестов или локальных запусков
	ПараметрыКонфигурационногоФайла = КонфигурационныйФайл_ЗначенияПараметров();
	ИспользоватьНативнуюКриптографию = ПараметрыКонфигурационногоФайла.Получить(
			"ИспользоватьНативнуюКриптографию");
	Если НЕ ИспользоватьНативнуюКриптографию = Неопределено Тогда
		Результат = НЕ ИспользоватьНативнуюКриптографию;
		Возврат Результат;
	КонецЕсли;
	
	ДоступнаНативнаяКриптография = ДоступнаНативнаяКриптография();
	
	Результат = НЕ ДоступнаНативнаяКриптография;
	
