	ИначеЕсли ТипКонтента = ТипыКонтента.utd Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_УПД_155(ПротоКонтентXDTO, ФайлТитулаПродавца, ФайлПодписиПродавца, ПараметрыФормированияФайла);
		
