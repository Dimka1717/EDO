	Возврат Результат;

КонецФункции

Функция ЗаблокированныеОрганизации_Наличие(ЕстьБлокировка = Истина) Экспорт
	
	МассивОрганизаций	= ЗаблокированныеОрганизации_Массив(ЕстьБлокировка);
	Результат	 		= ЗначениеЗаполнено(МассивОрганизаций);
	
	Возврат Результат;
	
КонецФункции

// Возвращает массив заблокированных организаций
//
// Параметры:
//  ЕстьБлокировка	 - 	Булево - признак блокировки
// 
// Возвращаемое значение:
//   - Массив, элементы которого содержат основные реквизиты организации - см. Новый_ЗаблокированнаяОрганизация()  
//
Функция ЗаблокированныеОрганизации_Массив(ЕстьБлокировка = Истина) Экспорт
	
	Результат = Новый Массив;
	
	СтруктураОрганизации = Новый Структура;
	
	КонтекстСеанса = ХранилищеКонтекстаСеанса();
	
	Если ЗначениеЗаполнено(КонтекстСеанса) Тогда
		
		Для Каждого КлючИЗначение Из КонтекстСеанса Цикл
			
			СтруктураКонтекста	= КлючИЗначение.Значение;
			Наименование		= СвойствоСтруктуры(СтруктураКонтекста, "ОрганизацияНаименование");
			BoxId				= СвойствоСтруктуры(СтруктураКонтекста, "BoxId");
			ИНН					= СвойствоСтруктуры(СтруктураКонтекста, "ИНН");
			КПП					= СвойствоСтруктуры(СтруктураКонтекста, "КПП");
			ТребуетсяОплатаСервиса = СвойствоСтруктуры(СтруктураКонтекста, "ТребуетсяОплатаСервиса");
			
			Если НЕ ЗначениеЗаполнено(Наименование) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ТребуетсяОплатаСервиса = ЕстьБлокировка Тогда
				
				BoxId = АдресЯщикаВИдентификатор(BoxId);
				
				ОписаниеОрганизации = Новый_ЗаблокированнаяОрганизация();
				
				ОписаниеОрганизации.Наименование	= Наименование;
				ОписаниеОрганизации.BoxId			= BoxId;
				ОписаниеОрганизации.ИНН				= ИНН;
				ОписаниеОрганизации.КПП			 	= КПП;
				
				Результат.Добавить(ОписаниеОрганизации);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

