// Конвертирует сохраненные настройки модуля Стандарт в настройки модуля ПРО.
// Вызывается при первом запуске модуля ПРО и конвертируются настройки только
// в случае использования типовых объектов 1С.
//
Процедура КонвертацияНастроек_СконвертироватьНастройки()
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	Если НЕ Модуль_ХранениеДанных.ИспользоватьПодсистемуДиадока() Тогда
		
		Модуль_ХранениеДанных.КонвертацияНастроек_Сконвертировать();
		
		КонвертацияНастроек_СконвертироватьНастройкиПрокси();
		
	КонецЕсли;
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьНастройкиПрокси()
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	
	ЕстьНастройкиПрокси = Ложь;
	
	Попытка
		
		ЕстьНастройкиПрокси = Модуль_ХранениеДанных.КонвертацияНастроек_ЕстьНастройкиПроксиВМодулеСтандарт();
		
	Исключение
		
		ЗаписьЖурналаРегистрации("Диадок", УровеньЖурналаРегистрации.Ошибка, , ОписаниеОшибки());
		
	КонецПопытки;
	
	Если ЕстьНастройкиПрокси Тогда
		
		РежимыПрокси = АПИ_РежимыИспользованияПрокси();
		
		НовыеНастройкиПрокси = АПИ_Новый_НастройкиПрокси(РежимыПрокси.ИспользоватьСистемныеНастройки);
		
		СоединениеУстановлено = АПИ_ПроверитьСоединениеDiadocAPI(НовыеНастройкиПрокси);
		
		Если СоединениеУстановлено Тогда
			ОбщиеНастройки_СохранитьНастройкиПрокси(НовыеНастройкиПрокси);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

