Функция СопоставлениеДанныхПМ_ДанныеДляСопоставления() Экспорт
	
	Результат = Новый Структура;	
	
	Результат.Вставить("ТаблицаВидовГруппировок", 			СопоставлениеДанныхПМ_ТаблицаВидовГруппировок());
	Результат.Вставить("ТаблицаВидовПакетов", 				СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов"));
	Результат.Вставить("ТаблицаВидовДокументов", 			СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыДокументов"));
	Результат.Вставить("СписокЭлементов_ВидыПакетов", 		СопоставлениеДанныхПМ_СписокЭлементовСправочникаДляВыбора("ВидыПакетов"));
	Результат.Вставить("СписокЭлементов_ВидыДокументов",	СопоставлениеДанныхПМ_СписокЭлементовСправочникаДляВыбора("ВидыДокументов"));
	Результат.Вставить("СписокЭлементов_ВидыГруппировок",	СопоставлениеДанныхПМ_СписокЭлементовСправочникаДляВыбора("ВидыГруппировкиПолученных"));
	Результат.Вставить("СписокТиповДокументов",				СопоставлениеДанныхПМ_СписокТиповДокументов());
	Результат.Вставить("СпискиФункцийТиповДокументов",		СопоставлениеДанныхПМ_СпискиФункций());
	Результат.Вставить("УстаревшийВариантОпределенияВидовДокументов", (Результат.ТаблицаВидовДокументов.Колонки.Количество() < 5));
	
	Если Результат.УстаревшийВариантОпределенияВидовДокументов Тогда
		Результат.ТаблицаВидовДокументов = СопоставлениеДанныхПМ_ТаблицаВидовДокументовИзУстаревшегоФорматаПМ(Результат.ТаблицаВидовДокументов);
	КонецЕсли;
	
	//Если функция вида документа в справочнике была сохранена ранее, то возьмем в таблицу ее значение. 
	Для Каждого СтрокаТЗ Из Результат.ТаблицаВидовДокументов Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЗ.Ссылка) Тогда
			
			ФункцияДокументаAPI = ХранениеДанных_ЗначениеДопРеквизита(СтрокаТЗ.Ссылка, "FunctionName");
			
			Если ЗначениеЗаполнено(ФункцияДокументаAPI) Тогда
				СтрокаТЗ.ФункцияДокументаAPI = ФункцияДокументаAPI;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_ТаблицаВидовСправочника(ИмяСправочника) Экспорт
	
	Если ИмяСправочника = "ВидыПакетов" Тогда
		КолонкиТаблицы = ПредопределенныеСписки_ОписаниеВидовПакетов();
		РезультатПМ = Интеграция_ПолучитьТаблицуИспользуемыхПакетов();
	ИначеЕсли ИмяСправочника = "ВидыДокументов" Тогда
		КолонкиТаблицы = ПредопределенныеСписки_ОписаниеВидовДокументов();
		РезультатПМ = Интеграция_ПолучитьТаблицуИспользуемыхВидовДокументов();
	КонецЕсли;
	
	Результат = Новый ТаблицаЗначений;
	ДобавитьКолонкиВТаблицуЗначений(Результат, КолонкиТаблицы);
	
	Результат.Колонки.Добавить("Ссылка");
	
	Если ЗначениеЗаполнено(РезультатПМ) Тогда
		
		Идентификаторы = РезультатПМ.ВыгрузитьКолонку("ID");
		
		СсылкиНаЭлементыСправочника = ХранениеДанных_СсылкиНаЭлементыДопСправочникаПоИдентификаторам(
				ИмяСправочника,
				Идентификаторы);
		
		Для Каждого СтрокаТЗ Из РезультатПМ Цикл
			
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
			
			НоваяСтрока.Ссылка = СсылкиНаЭлементыСправочника.Получить(СтрокаТЗ.ID);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_ТаблицаВидовГруппировок() Экспорт
	
	Результат = ХранениеДанных_СписокЭлементовДопСправочника("ВидыГруппировкиПолученных", "ТипыДокументов");
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_СписокЭлементовСправочникаДляВыбора(ИмяСправочника)
	
	ТЗ = ХранениеДанных_СписокЭлементовДопСправочника(ИмяСправочника);
	
	Результат = Новый СписокЗначений;
	
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		Результат.Добавить(СтрокаТЗ.Ссылка, СтрокаТЗ.Наименование);
	КонецЦикла;
	
	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_ТаблицаВидовДокументовИзУстаревшегоФорматаПМ(ТаблицаВидовДокументов)
	
	Результат = ТаблицаВидовДокументов.Скопировать();
	
	Результат.Колонки.Добавить("ТипДокументаAPI");
	Результат.Колонки.Добавить("ТипКонтентаAPI");
	Результат.Колонки.Добавить("ФункцияДокументаAPI");
	
	Для Каждого СтрокаТЗ Из Результат Цикл
		
		СтрокаТЗ.ТипДокументаAPI	= СтрокаТЗ.ТипДокумента;
		СтрокаТЗ.ТипКонтентаAPI		= "";
		
		СопоставлениеДанныхПМ_ПривестиУстаревшиеТипыВнешнейКомпонентыВТипыAPI(СтрокаТЗ.ТипДокументаAPI, СтрокаТЗ.ТипКонтентаAPI);
		
		Если Найти(СтрокаТЗ.ТипДокументаAPI, "UniversalTransferDocument") > 0 
			ИЛИ Найти(СтрокаТЗ.ТипДокументаAPI, "UniversalCorrectionDocument") > 0 Тогда
			//По умолчанию - полный УПД/УКД
			СтрокаТЗ.ФункцияДокументаAPI = Документы_ФункцияДокументаДляXML(СтрокаТЗ.ТипДокументаAPI, "InvoiceAndBasic");
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_СписокТиповДокументов()
	
	Результат = Новый СписокЗначений;
	
	ТаблицаТиповДокументов = ПредопределенныеСписки_ТипыДокументовAPI();
		
	Для Каждого СтрокаТЗ Из ТаблицаТиповДокументов Цикл		
		Если ЗначениеЗаполнено(СтрокаТЗ.TypeNamedId) И Результат.НайтиПоЗначению(СтрокаТЗ.TypeNamedId) = Неопределено Тогда
			Результат.Добавить(СтрокаТЗ.TypeNamedId, СтрокаТЗ.Title + " [" + СтрокаТЗ.TypeNamedId + "]");
		КонецЕсли;
	КонецЦикла;
	
	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_СпискиФункций()
	
	Результат = Новый Структура;
	
	ТипыДокументов = Новый Массив;
	ТипыДокументов.Добавить("UniversalTransferDocument");
	ТипыДокументов.Добавить("UniversalTransferDocumentRevision");
	ТипыДокументов.Добавить("UniversalCorrectionDocument");
	ТипыДокументов.Добавить("UniversalCorrectionDocumentRevision");
	
	Для Каждого ТипДокумента Из ТипыДокументов Цикл
		
		СписокФункций = Новый СписокЗначений;
		
		СписокФункций.Добавить(Документы_ФункцияДокументаДляXML(ТипДокумента, "InvoiceAndBasic"));
		СписокФункций.Добавить(Документы_ФункцияДокументаДляXML(ТипДокумента, "Invoice"));
		СписокФункций.Добавить(Документы_ФункцияДокументаДляXML(ТипДокумента, "Basic"));
		
		Результат.Вставить(ТипДокумента, СписокФункций);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СопоставлениеДанныхПМ_ВыполнитьСопоставление(ТаблицаВидовПакетов, ТаблицаВидовДокументов, ТаблицаВидовГруппировкиПолученных) Экспорт
	
	//Виды пакетов
	ДопРеквизиты = Новый Структура;
	ДопРеквизиты.Вставить("ID", 			"ID");
	ДопРеквизиты.Вставить("Наименование", 	"Наименование");
	ДопРеквизиты.Вставить("УПД", 			"УПД");
	
	СопоставлениеДанныхПМ_ВыполнитьСопоставлениеСправочника("ВидыПакетов", ТаблицаВидовПакетов, ДопРеквизиты);
	
	//Виды документов
	ДопРеквизиты = Новый Структура;
	ДопРеквизиты.Вставить("ID", 			"ID");
	ДопРеквизиты.Вставить("Наименование", 	"Наименование");
	ДопРеквизиты.Вставить("ТипДокумента",	"ТипДокумента");
	ДопРеквизиты.Вставить("TypeNamedId",	"ТипДокументаAPI");
	ДопРеквизиты.Вставить("FormatVersion",	"ТипКонтентаAPI");
	ДопРеквизиты.Вставить("FunctionName",	"ФункцияДокументаAPI");
	
	СопоставлениеДанныхПМ_ВыполнитьСопоставлениеСправочника("ВидыДокументов", ТаблицаВидовДокументов, ДопРеквизиты);
	
	//Виды группировки полученных
	ДопРеквизиты = Новый Структура;
	ДопРеквизиты.Вставить("Наименование", 	"Наименование");
	ДопРеквизиты.Вставить("ТипыДокументов", "ТипыДокументов");
	
	СопоставлениеДанныхПМ_ВыполнитьСопоставлениеСправочника("ВидыГруппировкиПолученных", ТаблицаВидовГруппировкиПолученных, ДопРеквизиты);
	
	Возврат Истина;
	
КонецФункции

Функция СопоставлениеДанныхПМ_ВыполнитьСопоставлениеСправочника(ИмяСправочника, ТаблицаДанных, ДопРеквизиты, ТолькоНовые = Ложь)
	
	Кэш_Поместить(ИмяСправочника, Неопределено);
	
	Для Каждого СтрокаТЧ Из ТаблицаДанных Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЧ.Ссылка) Тогда
			
			Если ТолькоНовые Тогда
				Продолжить;
			Иначе
				ТекОбъект = СтрокаТЧ.Ссылка.ПолучитьОбъект();
			КонецЕсли;
			
		Иначе
			ТекОбъект = ХранениеДанных_СоздатьДопСправочник(ИмяСправочника, СтрокаТЧ.Наименование);
		КонецЕсли;
		
		Если ТекОбъект <> Неопределено Тогда
			
			Для Каждого ДопРеквизит Из ДопРеквизиты Цикл
				ХранениеДанных_УстановитьЗначениеДопРеквизита(ТекОбъект, ДопРеквизит.Ключ, СтрокаТЧ[ДопРеквизит.Значение]);
			КонецЦикла;
			
			ТекОбъект.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Процедура СопоставлениеДанныхПМ_ПривестиУстаревшиеТипыВнешнейКомпонентыВТипыAPI(ТипДокумента, ТипКонтента)
	
	// Если тип у исходящей накладной/акта/СФ/КСФ был определен в терминах компоненты.
	// Это наследие использования компоненты в ранних версиях Про.
	
	ТипДокументаAPI = Неопределено;
	ТипКонтентаAPI  = Неопределено;
	
	СоответствиеТипов = СопоставлениеДанныхПМ_СоответствиеТиповКомпонентыИТиповAPI();	
	
	Если СоответствиеТипов.ТипыДокументов.Свойство(ТипДокумента, ТипДокументаAPI)
		И СоответствиеТипов.ТипыКонтентов.Свойство(ТипДокумента, ТипКонтентаAPI) Тогда
		
		ТипДокумента = ТипДокументаAPI;
		ТипКонтента  = ТипКонтентаAPI;
	
	// Для остальных случаев ТипДокумента в терминах компоненты совпадал с API.
	// Приведем только ТипКонтента, если он был задан явно при вызове этой процедуры.
	ИначеЕсли ТипКонтента <> Неопределено Тогда
		ТипКонтента = Списки_ОписаниеФорматаКонтента(ТипКонтента).API_FormatVersion;
	КонецЕсли;
	
КонецПроцедуры

