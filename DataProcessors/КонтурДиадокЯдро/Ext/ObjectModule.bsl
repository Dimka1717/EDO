Функция АПИ_ЗаполненныйКонтрактМЧД(PowerOfAttorney, ПоУмолчанию = Ложь)
	
	Результат = Контракт_МЧД();
	
	Если ЗначениеЗаполнено(PowerOfAttorney) Тогда
		
		Результат.Идентификатор	 = PowerOfAttorney.FullId.RegistrationNumber;
		Результат.ПоУмолчанию	 = ПоУмолчанию;
		
		ЧасовойПоясМосквы = "Europe/Moscow";
		
		ExpireAt = PowerOfAttorney.ExpireAt;
		Если ЗначениеЗаполнено(ExpireAt) Тогда
			Результат.СрокДействия = МестноеВремя(Ticks_2_Date(ExpireAt.Ticks), ЧасовойПоясМосквы);
		КонецЕсли;
		
		StartAt = PowerOfAttorney.StartAt;
		Если ЗначениеЗаполнено(StartAt) Тогда
			Результат.ДатаНачалаДействия = МестноеВремя(Ticks_2_Date(StartAt.Ticks), ЧасовойПоясМосквы);
		КонецЕсли;
		
		Issuer = PowerOfAttorney.Issuer;
		Если ЗначениеЗаполнено(Issuer) Тогда
			
			ДанныеДоверителя = СвойствоСтруктуры(Issuer, Issuer.Type);
			
			Если ЗначениеЗаполнено(ДанныеДоверителя) Тогда
			
				ДоверительНаименование	 = СвойствоСтруктуры(ДанныеДоверителя, "OrganizationName");
				Если НЕ ЗначениеЗаполнено(ДоверительНаименование) Тогда
					ДоверительНаименование	 = СвойствоСтруктуры(ДанныеДоверителя, "PersonName");
				КонецЕсли;
				
				Результат.Доверитель.Наименование	 = ДоверительНаименование;
				Результат.Доверитель.ИНН			 = СвойствоСтруктуры(ДанныеДоверителя, "Inn");
				Результат.Доверитель.КПП			 = СвойствоСтруктуры(ДанныеДоверителя, "Kpp");
			
			КонецЕсли;
			
		КонецЕсли;
		
		ЗаполнитьПредставителяВКонтрактеМЧД(Результат, PowerOfAttorney.Representatives);
		
		Результат.ПредставлениеМЧД = Представление_МЧД(Результат);
		
		Для Каждого DelegationPoA Из PowerOfAttorney.DelegationChain Цикл
			
			ДелегированнаяМЧД = АПИ_ЗаполненныйКонтрактМЧД(DelegationPoA);
			
			Результат.ДелегированныеМЧД.Добавить(ДелегированнаяМЧД);
			
		КонецЦикла;
		
		PermissionsInfo = PowerOfAttorney.PermissionsInfo;
		
		СведенияОПолномочиях = Результат.СведенияОПолномочиях;
		
		Если НРег(PermissionsInfo.JointPermissions) = НРег("Personal") Тогда
			СведенияОПолномочиях.СовместныеПолномочия = Ложь;
		Иначе
			СведенияОПолномочиях.СовместныеПолномочия = Истина;
		КонецЕсли;
		
		TransferPermissionLoss = СвойствоСтруктуры(PermissionsInfo, "TransferPermissionLoss");
		
		Если НРег(TransferPermissionLoss) = НРег("NotLossOnTransfer") Тогда 
			СведенияОПолномочиях.УтратаПолномочийПриПередоверии = Ложь;
		ИначеЕсли НРег(TransferPermissionLoss) = НРег("LossOnTransfer") Тогда
			СведенияОПолномочиях.УтратаПолномочийПриПередоверии = Истина;
		Иначе
			СведенияОПолномочиях.УтратаПолномочийПриПередоверии = Неопределено;
		КонецЕсли;
		
		Permissions = PermissionsInfo.Permissions;
		Полномочия = СведенияОПолномочиях.Полномочия;
		
		Для Каждого Permission Из Permissions Цикл
			
			Полномочие = Контракт_МЧД_Полномочия();

			Если НРег(Permission.Type) = НРег("machineReadable") Тогда
				Полномочие.МашиночитаемоеПолномочие = Истина;
			КонецЕсли;
			
			МашиночитаемыеПолномочия = Новый Массив;
			
			MachineReadablePermission = СвойствоСтруктуры(Permission, "MachineReadablePermission", Новый Массив);
			
			Для Каждого MachReadPermission Из MachineReadablePermission Цикл
				
				Mnemonic = СвойствоСтруктуры(MachReadPermission, "Mnemonic", "");
				Restrictions = СвойствоСтруктуры(MachReadPermission, "Restrictions", Новый Массив);
				
				МашиночитаемоеПолномочие = Контракт_МЧД_МашиночитаемоеПолномочие();
				МашиночитаемоеПолномочие.Код = MachReadPermission.Code;
				МашиночитаемоеПолномочие.Наименование = MachReadPermission.Name;
				МашиночитаемоеПолномочие.Мнемоника = Mnemonic;
				
				Для Каждого Restriction Из Restrictions Цикл
						
					ОграничениеПолномочия = Контракт_МЧД_ОграниченияПолномочия();
					ОграничениеПолномочия.НомерПоПорядку = Restriction.Id;
					ОграничениеПолномочия.Код = Restriction.Code;
					ОграничениеПолномочия.Наименование = Restriction.Name;
					
					ValueName = СвойствоСтруктуры(Restriction, "ValueName", "");
					ValueCode = СвойствоСтруктуры(Restriction, "ValueCode", "");
					ValueText = СвойствоСтруктуры(Restriction, "ValueText", "");

					ОграничениеПолномочия.НаименованиеЗначения = ValueName;
					ОграничениеПолномочия.КодЗначения = ValueCode;
					ОграничениеПолномочия.ТекстовоеЗначение = ValueText;
					
					МашиночитаемоеПолномочие.Ограничения.Добавить(ОграничениеПолномочия);
					
				КонецЦикла;
				
				МашиночитаемыеПолномочия.Добавить(МашиночитаемоеПолномочие);
				
			КонецЦикла;
			
			Полномочие.МашиночитаемоеОписание = МашиночитаемыеПолномочия;
			
			TextPermission = СвойствоСтруктуры(Permission, "TextPermission", "");
			Полномочие.ТекстовоеОписание = TextPermission;	
			
			Полномочия.Добавить(Полномочие);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

