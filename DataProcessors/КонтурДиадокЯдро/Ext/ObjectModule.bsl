// Возвращает файлы и описание доверенности из сервиса
//
// Параметры:
//  BoxId            - Строка - идентификатор ящика
//  MessageId        - Строка - идентификатор сообщения, в котором находится МЧД
//  EntityId         - Строка - идентификатор МЧД
// 
// Возвращаемое значение:
//  Структура - см. Контракт_ФайлМЧД
//
Функция МЧД_ДанныеФайловДоверенности(BoxId, MessageId, EntityId) Экспорт
	
	Результат = Контракт_ДанныеФайловМЧД();
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);	
	Ответ = АПИ_GetPowerOfAttorneyContent(ПараметрыСервиса, BoxId, MessageId, EntityId);
	
	СодержимоеМЧД = Ответ.Content;
	
	Результат.Идентификатор = СодержимоеМЧД.FullId.RegistrationNumber;
	Результат.ИННДоверителя = СодержимоеМЧД.FullId.IssuerInn;
	Результат.Данные = Base64Значение(СодержимоеМЧД.Content);
	Результат.ИмяФайла = МЧД_ИдентификаторФайлаДоверенности(Результат.Данные);
	Результат.Подпись.ДанныеПодписи = Base64Значение(СодержимоеМЧД.Signature);
	
	DelegationChain = СвойствоСтруктуры(Ответ, "DelegationChain", Новый Массив);
	
	Для Каждого DelegationContent Из DelegationChain Цикл
		
		ДанныеФайловДелегированнойМЧД = Контракт_ДанныеФайловМЧД();
		
		ДанныеФайловДелегированнойМЧД.Идентификатор = DelegationContent.FullId.RegistrationNumber;
		ДанныеФайловДелегированнойМЧД.ИННДоверителя = DelegationContent.FullId.IssuerInn;
		ДанныеФайловДелегированнойМЧД.Данные = Base64Значение(DelegationContent.Content);
		ДанныеФайловДелегированнойМЧД.ИмяФайла = МЧД_ИдентификаторФайлаДоверенности(ДанныеФайловДелегированнойМЧД.Данные);
		ДанныеФайловДелегированнойМЧД.Подпись.ДанныеПодписи = Base64Значение(DelegationContent.Signature);
	    
		Результат.ДанныеФайловДелегированныхМЧД.Добавить(ДанныеФайловДелегированнойМЧД);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ИдентификаторФайлаДоверенности(ДвоичныеДанныеМЧД)
	
	ДанныеXDTO = ГенерацияXML_XML_В_ОбъектXDTO(ДвоичныеДанныеМЧД);
	
	Если ДанныеXDTO.Свойства().Получить("ИдФайл") = Неопределено Тогда
		
		СведенияМЧД = ДанныеXDTO.Документ.СвДов;
		НомерМЧД = СведенияМЧД.НомДовер;
		ДатаМЧД = СтрЗаменить(СведенияМЧД.ДатаВыдДовер, "-", "");
		
		ПрефиксФайловМЧД = "ON_DOVBB_";
		Результат = ПрефиксФайловМЧД + "_" + ДатаМЧД + "_" + НомерМЧД;
		
	Иначе
		
		Результат = ДанныеXDTO.ИдФайл;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

