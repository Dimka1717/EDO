Функция ПредопределенныеСписки_ВидыПакетов() Экспорт
	
	Результат = Кэш_Прочитать("ВидыПакетов");
	
	Если Результат = Неопределено Тогда
		
		Результат = Новый Соответствие;
		
		КлючиДляОписанияВида = ПредопределенныеСписки_ОписаниеВидовПакетов();
		ТаблицаИспользуемыхВидов = Интеграция_ПолучитьТаблицуИспользуемыхПакетов();
		
		Если ЗначениеЗаполнено(ТаблицаИспользуемыхВидов) Тогда
			
			ТекКатегорияПакета = Неопределено;
			
			Для Каждого СтрокаТЗ Из ТаблицаИспользуемыхВидов Цикл
				
				ОписаниеВида = Новый Структура(КлючиДляОписанияВида);
				ЗаполнитьЗначенияСвойств(ОписаниеВида, СтрокаТЗ);
				
				ОписаниеВида.ПоУмолчанию = ЗначениеЗаполнено(ОписаниеВида.КатегорияПакета) 
										И (ТекКатегорияПакета <> ОписаниеВида.КатегорияПакета);
										
				ТекКатегорияПакета = ОписаниеВида.КатегорияПакета;
				
				Результат.Вставить(ОписаниеВида.ID, ОписаниеВида);
				
			КонецЦикла;
			
		КонецЕсли;
		
		Кэш_Поместить("ВидыПакетов", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Обработчик события ПМ "ПолучитьТаблицуИспользуемыхПакетов"
// 
// Возвращаемое значение:
//  ТаблицаЗначений - содержит колонки:
//    * ID - Строка - идентификатор вида пакета
//    * Наименование - Строка - пользовательское представление вида пакета
//    * СоставПакета - Строка - идентификаторы видов документов (через запятую)
//    * КатегорияПакета - Строка - идентификатор категории пакетов
//    * НаименованиеКатегории - Строка - пользовательское представление категории пакетов
//    * Шаблон - Булево - Истина, если пакет является шаблоном
//    * ВнутреннийДО - Булево - Истина, если пакет используется для внутреннего документооборота
//    * БазовыйВидПакета - Строка - Идентификатор вида пакета, который является основным для текущего вида.
//
Функция Интеграция_ПолучитьТаблицуИспользуемыхПакетов()
	
	ТипСтрока = Новый ОписаниеТипов("Строка");
	ТипБулево = Новый ОписаниеТипов("Булево");
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ID", ТипСтрока, "Идентификатор");
	Результат.Колонки.Добавить("Наименование", ТипСтрока, "Представление");
	Результат.Колонки.Добавить("СоставПакета", ТипСтрока, "Состав пакета");
	Результат.Колонки.Добавить("КатегорияПакета", ТипСтрока, "Идентификатор категории");
	Результат.Колонки.Добавить("НаименованиеКатегории", ТипСтрока, "Представление категории");
	Результат.Колонки.Добавить("Шаблон", ТипБулево, "Это шаблон");
	Результат.Колонки.Добавить("ВнутреннийДО", ТипБулево, "Внутренний документооборот");
	Результат.Колонки.Добавить("БазовыйВидПакета", ТипСтрока, "Базовый вид пакета");
	
	Попытка
		
		Данные = ИнтеграцияСлужебный_ПолучитьТаблицуИспользуемыхПакетов();
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		
		ИмяСобытия = "ПолучитьТаблицуИспользуемыхПакетов";
		
		Ошибка_Обработать(
			ИмяСобытия,
			ПодробноеПредставлениеОшибки(Ошибка),
			Неопределено,
			КраткоеПредставлениеОшибки(Ошибка)
		);
		
		Метрика_ДобавитьОшибку("Интеграция", ИмяСобытия, Ошибка);
		
	КонецПопытки;
	
	Если ТипЗнч(Данные) = Тип("ТаблицаЗначений") Тогда
		
		ИспользуетсяСХ1 = ИспользоватьПодсистемуДиадока();
		ЗаполнятьКатегорию = (Данные.Колонки.Найти("КатегорияПакета") = Неопределено);
		КатегорияПоУмолчанию = "ОсновнойПакет";
		
		Для Каждого Запись Из Данные Цикл
			
			ВидПакета = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(ВидПакета, Запись);
			
			Если ЗаполнятьКатегорию Тогда
				ВидПакета.КатегорияПакета = КатегорияПоУмолчанию;
				ВидПакета.НаименованиеКатегории = "Первичные документы";
			КонецЕсли;
			
			Если ИспользуетсяСХ1 И ВидПакета.КатегорияПакета = КатегорияПоУмолчанию Тогда
				ВидПакета.КатегорияПакета = "Основной пакет";
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.Сортировать("КатегорияПакета");
	
	Возврат Результат;
	
КонецФункции

// @СлужебныйПрограммныйИнтерфейс
//
Функция ИнтеграцияСлужебный_ПолучитьТаблицуИспользуемыхПакетов() Экспорт
	
	ИмяСобытия = "ПолучитьТаблицуИспользуемыхПакетов";
	ПараметрыПМ = Новый Структура;
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(Результат)
		И ЕстьИнтеграционныйМодуль() Тогда
		
		МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
		ДанныеИМ = МенеджерИнтеграции.ПоставляемыеВидыПакетов();
		
		ИспользоватьВнутреннийДО = ЗначениеНастройки_ИспользоватьВнутреннийДокументооборот();
		
		ТребуемыеКолонки =
		"ID, Наименование, СоставПакета, КатегорияПакета,
		|НаименованиеКатегории, Шаблон, ВнутреннийДО, БазовыйВидПакета";
		Фильтр = Неопределено;
		Если Не ИспользоватьВнутреннийДО Тогда
			Фильтр = Новый Структура;
			Фильтр.Вставить("ВнутреннийДО", Ложь);
		КонецЕсли;
		
		РезультатИМ = ДанныеИМ.Скопировать(Фильтр, ТребуемыеКолонки);
		
		Результат = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
			ИмяСобытия,
			ПараметрыПМ,
			РезультатИМ
		);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(
		ИмяСобытия,
		ПараметрыПМ,
		Результат
	);
	
	Возврат Результат;
	
КонецФункции

