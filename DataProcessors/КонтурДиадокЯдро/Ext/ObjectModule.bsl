		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = ЗначенияРеквизитов.Организация;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыУчета_ТребуетсяПроведениеДляОтправки(СсылкаНаОбъект) Экспорт
	
	ПризнакПроведения = Истина;
	
	ЭтоДокумент = Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(СсылкаНаОбъект));
	
	Если ЭтоДокумент Тогда
		
		ОбъектМетаданных = СсылкаНаОбъект.Метаданные();
		
		ОбъектПроводится = (ОбъектМетаданных.Проведение = Метаданные.СвойстваОбъектов.Проведение.Разрешить);
		
		Если ОбъектПроводится Тогда
			
			ПризнакПроведения = СсылкаНаОбъект.Проведен;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Организация1С = ДокументыУчета_Организация(СсылкаНаОбъект);
	ОрганизацияСопоставлена = Организации_ОрганизацияСопоставленаСЯщикомДиадок(Организация1С);
	
	Результат = Ложь;
	
	Если НЕ ПризнакПроведения
		И ОрганизацияСопоставлена Тогда
		
		Результат = НЕ ЗначениеНастройки_ОтправлятьНепроведенныеДокументы(Организация1С);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыУчета_ДокументОтправлен(СсылкаНаОбъект) Экспорт
	
	Результат = ХранениеДанных_ЕстьЭлектронныйДокументПоДокументу1С(СсылкаНаОбъект);
	
	Возврат Результат;
	
КонецФункции

Функция ДокументыУчета_ТребуетсяСчетФактура(СсылкаНаОбъект) Экспорт
	
	ИМ = ИнтеграционныйМодуль_Получить();
	
	Результат = Ложь;
	
	Если ИМ = ИмяИМ_БП30() Или ИМ = ИмяИМ_УТ11() Тогда
		
		Модуль_ИМ = Модуль_ИМ(ЭтотОбъект);
		
		Результат = Модуль_ИМ.ТребуетсяСчетФактура(СсылкаНаОбъект);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

