Процедура Конвертация970_СобытияПМСтандарта_ПослеЗаполненияКонтента(
	ПараметрыСобытия,
	СсылкаНаДокумент,
	РежимСовместимостиФорматов155и820)
	
	Если РежимСовместимостиФорматов155и820 Тогда
		Контент = УПД820_Конвертировать_в155(ПараметрыСобытия.Результат.Content);
		ТипКонтента = "UtdSellerContent";
	Иначе
		Контент = ОбъектXDTOВСтруктуру(ПараметрыСобытия.Результат.Content);
		ТипКонтента = ПараметрыСобытия.ВидДокументаРазвернутый.ТипКонтента;
	КонецЕсли;
	
	Идентификаторы = Новый_ИдентификаторыСправочника(, ПараметрыСобытия.Результат.BoxID);
	ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(Идентификаторы);

	ДопПараметрыВызова_ТиповойМодуль = ДополнительныеПараметрыПолученияКонтента();
	ДопПараметрыВызова_ТиповойМодуль.ТочностьЦены = ЗначениеНастройки_ТочностьЦены();
	ДопПараметрыВызова_ТиповойМодуль.ТочностьКоличества = ЗначениеНастройки_ТочностьКоличества();
	ДопПараметрыВызова_ТиповойМодуль.ДанныеСотрудника = ПараметрыСобытия.ДанныеСотрудника;
	ДопПараметрыВызова_ТиповойМодуль.УказыватьОтсутствиеОснованияУПД = ДанныеОрганизации.УказыватьОтсутствиеОснованияУПД;
	
	ПараметрыФормированияФайла = ГенерацияXML_ПараметрыФормированияФайла();
	ПараметрыФормированияФайла.ТочностьЦены = ДопПараметрыВызова_ТиповойМодуль.ТочностьЦены;
	ПараметрыФормированияФайла.ТочностьКоличества = ДопПараметрыВызова_ТиповойМодуль.ТочностьКоличества;

	ДопПараметрыВызова_ТиповойМодуль.Вставить("ПараметрыФормированияФайла", ПараметрыФормированияФайла);
	ДопПараметрыВызова_ТиповойМодуль.Вставить("ФункцияДокумента", ПараметрыСобытия.Результат.Функция);
	
	МенеджерИнтеграции = Модуль_МенеджерИнтеграции(ЭтотОбъект);
	МенеджерИнтеграции.Конвертация970_СобытияПМСтандарта_ПослеЗаполненияКонтента(
		Контент,
		ТипКонтента,
		СсылкаНаДокумент,
		ДопПараметрыВызова_ТиповойМодуль);
		
	Если РежимСовместимостиФорматов155и820 Тогда
		Контент820 = УПД155_Конвертировать_в820(Контент);
		УПД820_ВосстановитьДанныеПослеКонвертации_из155(Контент820, ПараметрыСобытия.Результат.Content);
	Иначе
		Контент820 = ГенерацияXML_ПолучитьПустуюПротоСтруктуру(ТипКонтента);
		ЗаполнитьКонтентXDTOПоСтруктуре(Контент820, Контент);
	КонецЕсли;
	
	ПараметрыСобытия.Результат.Content = Контент820;

КонецПроцедуры

Функция УПД970_ИспользоватьРежимСовместимостиФорматов(ТипКонтента)
	
	ТипыКонтентов = Перечисление_ТипыКонтентов();
	
	НастройкиМодуляСтандарт = ХранениеДанных_НастройкиМодуляСтандарт();
	
	ЕстьПМ = (ЕстьПодключаемыйМодуль() Или НастройкиМодуляСтандарт.ИспользоватьПодключаемыйМодуль);
	ЭтоФормат970 = (ТипКонтента = Перечисление_ТипыКонтентов().utd970);
	ИспользуетсяРежимСовместимости820и970 = Конвертация970_УстановленаНастройкаРежимаСовместимостиФорматовАвто();
	
	Результат = (ЕстьПМ И ЭтоФормат970 И ИспользуетсяРежимСовместимости820и970);
	
	Возврат Результат;

КонецФункции

// Процедура - Конвертация970 дополнить текст HTMLОшибками конвертации
//
// Параметры:
//  ТекстHTML- Строка - текст HTML документа с ошибками валидации или пустая строка,
//						если ошибок валидации не было
//  Документ - Структура - данные документа (см. Контракт_Документ())
//
Процедура Конвертация970_ДополнитьТекстHTMLОшибкамиКонвертации(ТекстHTML, Документ) Экспорт
	
	Перем ОшибкиКонвертации;

	Документ.СлужебнаяИнформация.Свойство("ОшибкиКонвертации", ОшибкиКонвертации);
	Если Не ЗначениеЗаполнено(ОшибкиКонвертации) Тогда
		Возврат;
	КонецЕсли;
	
	HTMLШаблоны = Документы_ОшибкиВалидации_HTMLШаблоны();

	Если ТекстHTML = Неопределено Тогда
		
		ЭлементыДокументаHTML = Новый Массив;
		ЭлементыДокументаHTML.Добавить(HTMLШаблоны.Начало);
		ЭлементыДокументаHTML.Добавить(HTMLШаблоны.ТаблицаСтилей);
		ЭлементыДокументаHTML.Добавить(HTMLШаблоны.НачалоТела);
		ЭлементыДокументаHTML.Добавить(HTMLШаблоны.Окончание);
		
		ТекстHTML = СоединитьСтроку(ЭлементыДокументаHTML);
		
	КонецЕсли;
	
	ТекстЗаголовкаРаздела = Конвертация970_ТекстЗаголовкаРазделаПредупрежденийHTML();
	
	ЭлементыHTMLТекста = Новый Массив;
	ЭлементыHTMLТекста.Добавить(ТекстЗаголовкаРаздела);
	ЭлементыHTMLТекста.Добавить(HTMLШаблоны.НачалоСписка);
	
	Конвертация970_ДобавитьHTMLТекстОшибокСПотерейДанных(ЭлементыHTMLТекста, ОшибкиКонвертации);
	Конвертация970_ДобавитьHTMLТекстОшибок(ЭлементыHTMLТекста, ОшибкиКонвертации);
	
	ЭлементыHTMLТекста.Добавить(HTMLШаблоны.ОкончаниеСписка);
	
	ПолныйHTMLТекстОшибки = СоединитьСтроку(ЭлементыHTMLТекста);
	
	ТегКонецТела = "</body>";
	ТекстHTML = СтрЗаменить(ТекстHTML, ТегКонецТела, ПолныйHTMLТекстОшибки + ТегКонецТела);
	
КонецПроцедуры

Процедура Конвертация970_ДобавитьHTMLТекстОшибокСПотерейДанных(ЭлементыHTMLТекста, ОшибкиКонвертации)
	
	ИмяГруппы = "ПотеряДанных";
	
	Фильтр = Новый Структура;
	Фильтр.Вставить("Группа", ИмяГруппы);
	
	ОшибкиПотериДанных = МассивСтруктур_НайтиСтроки(ОшибкиКонвертации, Фильтр);
	
	ШаблонHTMLСписка =
	"<ul style=""margin-top:-10; margin-bottom:-5;"">
	|%1
	|</ul>";

	ШаблонСтрокиHTMLСписка = "<li style=""margin-top:-5;"">%1</li>";
	
	ШаблонHTMLТекстаОшибки = 
	"<p>Документ успешно сформирован в 970 формате. Есть данные, которые не удалось перенести в новый формат:</p>
	|%1
	|<p style=""margin-top:-5;"">Документ можно отправить без этих данных, т. к. они не обязательны в новом формате.</p>";

	СтрокиHTMLСписка = Новый Массив;
	Для Каждого ОписаниеОшибки Из ОшибкиПотериДанных Цикл
		СтрокаСпискаHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиHTMLСписка, ОписаниеОшибки.Дополнение);
		СтрокиHTMLСписка.Добавить(СтрокаСпискаHTML);
	КонецЦикла;

	СтрокиHTMLСпискаСтрокой = СоединитьСтроку(СтрокиHTMLСписка);
	ОшибкиHTMLСписком = Общее_ПодставитьПараметрыВСтроку(ШаблонHTMLСписка, СтрокиHTMLСпискаСтрокой);
		
	ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонHTMLТекстаОшибки, ОшибкиHTMLСписком);
	
	ЭлементыHTMLТекста.Добавить(ТекстОшибки);
	
КонецПроцедуры

Процедура Конвертация970_ДобавитьHTMLТекстОшибок(ЭлементыHTMLТекста, ОшибкиКонвертации)
	
	ШаблонHTMLТекстаОшибки = "<p>%1</p>";
	
	ИсключаемаяГруппаОшибок = "ПотеряДанных";
	
	Для Каждого ОписаниеОшибки Из ОшибкиКонвертации Цикл
		
		Если ОписаниеОшибки.Группа <> ИсключаемаяГруппаОшибок Тогда
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонHTMLТекстаОшибки, ОписаниеОшибки.Текст);
			ЭлементыHTMLТекста.Добавить(ТекстОшибки);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

