Функция Документы_ИсторияДО_ПредставлениеСертификата(Знач SubjectType) Экспорт
	
	Результат = "";
	
	Если НЕ ЗначениеЗаполнено(SubjectType) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Перечисление_SignerType = АПИ_Перечисление_SignerType();
	// BSLLS:Typo-off
	Если SubjectType = Перечисление_SignerType.LegalEntity Тогда
		
		Результат = "Сертификат юрлица";
		
	ИначеЕсли SubjectType = Перечисление_SignerType.IndividualEntity Тогда
		
		Результат = "Сертификат ИП";
		
	ИначеЕсли SubjectType = Перечисление_SignerType.PhysicalPerson Тогда
		
		Результат = "Сертификат физлица";
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	// BSLLS:Typo-on
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ИсторияДО_ПредставлениеПодписанта(Знач ДанныеSignature)
	
	Результат = "";
	
	Если НЕ ЗначениеЗаполнено(ДанныеSignature) Тогда
