КонецФункции

// Готовит текст в разметке HTML для информирования пользователя о дальнейших действиях
// в случае, если возникли проблемы с установленной по умолчанию МЧД
//
// Параметры:
//	СписокОшибокМЧД - Массив 	- см. МЧД_ПроверитьНаличиеДоверенностейУСотрудниковПоОрганизациям
//
// Возвращаемое значение:
//	Строка
Функция МЧД_HTMLТекст_ТекстУведомленияПослеПроверкиМЧДПоУмолчанию(СписокОшибокМЧД = Неопределено) Экспорт
	
	АдресаИнтернетРесурсов = Перечисление_АдресаИнтернетРесурсов();
	СсылкаМЧДПодробнееОбИзменениях = АдресаИнтернетРесурсов.МЧДПодробнееОбИзменениях;
	СсылкаМЧДВыпуститьНовую = АдресаИнтернетРесурсов.МЧДВыпуститьНовую;
	СсылкаМЧДНастроить = ПараметрыОповещенияВСтрокуHTMLСообщения("ОбработчикОповещения_ОткрытьФормуНастроекМЧД");
	СсылкаМЧДЗагрузитьВВебе = АдресаИнтернетРесурсов.МЧДЗагрузитьВВебе;
	СсылкаОповещениеЦентрПоддержки = ПараметрыОповещенияВСтрокуHTMLСообщения("ОбработатьНажатие_ОткрытьЦентрПоддержки");
	
	Картинки = БиблиотекаКартинок();
	КартинкаСинийПлюс = Картинки.КартинкаСинийПлюс_Base64;
	КартинкаСиняяШестеренка = Картинки.КартинкаСиняяШестеренка_Base64;
	КартинкаСиняяСтрелкаВверх = Картинки.КартинкаСиняяСтрелкаВверх_Base64;
	КартинкаЦентрПоддержки = Картинки.КартинкаОнлайнКонсультант_Base64;
	СимволСтрелкаВправо = Символ(8594);
	
	HTMLШаблоны = МЧД_HTMLШаблоны();
	
	Результат = HTMLШаблоны.Начало;
	Результат = Результат + HTMLШаблоны.ТаблицаСтилей;
	Результат = Результат + HTMLШаблоны.НачалоТела;
	
	ПодстрокиТела = Новый Массив;
	
	Если ЗначениеЗаполнено(СписокОшибокМЧД) Тогда
		
		Для Каждого ТекстОшибки Из СписокОшибокМЧД Цикл
			
			Подстрока = "<p class=strtextbold>" + ТекстОшибки + "</p>";
			ПодстрокиТела.Добавить(Подстрока);
			
		КонецЦикла;
	КонецЕсли;
	
	ШаблонПодстроки = "<ul style=""margin-top: -1%;"">
		|	<li><p class=strtext2>%1</p></li>
		|	<li><p class=strtext2>%2</p></li>
		|	<li><p class=strtext2>%3</p></li>
		|</ul>";
	
	Подстрока = Общее_ПодставитьПараметрыВСтроку(
		ШаблонПодстроки,
		"Для создания доверенности выполните действие &apos;Выпустить новую МЧД&apos;.",
		"Если у вас уже есть доверенность, перейдите к действию &apos;Настроить МЧД в модуле&apos; и загрузите ее.",
		"Для работы без доверенности нажмите кнопку &apos;Продолжить без МЧД&apos;."
	);
	
	ПодстрокиТела.Добавить(Подстрока);
	
	ШаблонПодстроки = "<p class=strtext2 style=""margin-top: 4%;"">%1</p>
		|<p class=strtext2 style=""margin-top: 4%;"">%2</p>
		|<p class=strtext style=""margin-top: 4%;"">Выберите действие: </p>
		|<p class=strtext2> <IMG class=imgstyle src=""data:image/png;base64," + КартинкаСинийПлюс + """> %3</p>
		|<p class=strtext2> <IMG class=imgstyle src=""data:image/png;base64," + КартинкаСиняяШестеренка + """> %4</p>
		|<p class=strtext2> <IMG class=imgstyle src=""data:image/png;base64," + КартинкаСиняяСтрелкаВверх + """> %5 %6</p>
		|<p class=strtext2> <IMG class=imgstyle src=""data:image/png;base64," + КартинкаЦентрПоддержки + """> %7</p>";
	
	ТекстПояснения = "С 1 сентября 2024 г. вступил в силу пункт 14 статьи 1 ФЗ от 27.12.2019 № 476-ФЗ, "
		+ "в соответствии с которым для подтверждения полномочий требуется использовать машиночитаемую доверенность. "
		+ "Для этого перейдите в раздел <b>&quot;Доверенности&quot;</b> и выполните настройку.";
	
	Подстрока = Общее_ПодставитьПараметрыВСтроку(
		ШаблонПодстроки,
		ТекстПояснения,
		"<A href=""" + СсылкаМЧДПодробнееОбИзменениях + """>Подробнее об изменениях</A>",
		"<A href=""" + СсылкаМЧДВыпуститьНовую + """>Выпустить новую МЧД</A> <a class=setting>(если у вас еще нет МЧД)</a>",
		"<A href=""" + СсылкаМЧДНастроить + """>Настроить МЧД в модуле</A>",
		"<A href=""" + СсылкаМЧДЗагрузитьВВебе + """>Загрузить МЧД в веб-версии Диадока</A>",
		"<a class=setting>(в разделе ""Настройки " + СимволСтрелкаВправо + " Сотрудники"")</a>",
		"<A href=""" + СсылкаОповещениеЦентрПоддержки + """>Нужна помощь</A>"
	);
	
	ПодстрокиТела.Добавить(Подстрока);
	
	ТекстТела = СоединитьСтроку(ПодстрокиТела, Символы.ПС);
	
	Результат = Результат + ТекстТела;
	Результат = Результат + HTMLШаблоны.Окончание;
	
	Возврат Результат;
	
КонецФункции

// Проверяет для каждой строки контекста требование мчд, наличие списка мчд.
//
// Возвращаемое значение:
//	Массив - Массив строк с текстом ошибок проверки МЧД 
Функция МЧД_ПроверитьНаличиеДоверенностейУСотрудниковПоОрганизациям() Экспорт
	
	Результат = Новый Массив;
	
	ПользователиБезМЧДВОрганизациях = Новый Соответствие;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого КлючЗначение Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = КлючЗначение.Значение;
		
		Если Не СтрокаКонтекста.ТребуетсяМЧД Тогда
			Продолжить;
		КонецЕсли;
		
		КонтентСпискаМЧД = МЧД_ПолучитьКонтекстДляГрупповыхДействий(СтрокаКонтекста.BoxID);
		Если ЗначениеЗаполнено(КонтентСпискаМЧД.СписокМЧД) Тогда
			Продолжить;
		КонецЕсли;
		
		СубъектСертификата = СтрокаКонтекста.Сертификат.Наименование;
		НаименованиеОрганизации = СтрокаКонтекста.Ящик.Организация.Наименование;
		
		Организации = ПользователиБезМЧДВОрганизациях.Получить(СубъектСертификата);
		
		Если Организации = Неопределено Тогда
			ПользователиБезМЧДВОрганизациях.Вставить(СубъектСертификата, ЗначениеВМассив(НаименованиеОрганизации));
		Иначе
			Организации.Добавить(НаименованиеОрганизации);
		КонецЕсли;
		
	КонецЦикла;
	
	ШаблонНетМЧДДляОрганизации = "Отсутствует доверенность для %1 по организации %2";
	ШаблонНетМЧДДляОрганизаций = "Отсутствуют доверенности для %1 по организациям %2";
	
	Для Каждого ПользовательБезМЧДВОрганизациях Из ПользователиБезМЧДВОрганизациях Цикл
		СубъектСертификата = ПользовательБезМЧДВОрганизациях.Ключ;
		Организации = ПользовательБезМЧДВОрганизациях.Значение;
		ОрганизацииСтрокой = СоединитьСтроку(Организации, ", ");
		
		Если Организации.Количество() > 1 Тогда
			ОписаниеОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонНетМЧДДляОрганизаций, СубъектСертификата, ОрганизацииСтрокой);
		Иначе
			ОписаниеОшибки = Общее_ПодставитьПараметрыВСтроку(ШаблонНетМЧДДляОрганизации, СубъектСертификата, ОрганизацииСтрокой);
		КонецЕсли;
		
		Результат.Добавить(ОписаниеОшибки);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

Функция МЧД_СписокОшибокВТекстHTML(ОшибкиПроверокМЧД) Экспорт
	
	Шаблоны	= МЧД_ШаблоныHTMLДокументаОшибокПроверкиПриГрупповыхДействиях();
	
	РазделыОшибок = МЧД_РазделыОшибокПроверкиМЧД();
	
	ОшибкиПоРазделам = Новый Соответствие;
	
	Для Каждого ОписаниеОшибки Из ОшибкиПроверокМЧД Цикл
		
		Раздел 				= ОписаниеОшибки.Раздел;
		РасшифровкаСтатуса 	= ОписаниеОшибки.РасшифровкаСтатуса;
		РасшифровкаОшибок 	= ОписаниеОшибки.СписокОшибок;
		
		Если Раздел = РазделыОшибок.НетМЧДПоУмолчанию Тогда
			ТекстОшибкиHTML = МЧД_РасшифровкаСтатусаВСтрокуСпискаHTML(РасшифровкаСтатуса);
		ИначеЕсли Раздел = РазделыОшибок.МЧДнеПодходит Тогда
			ТекстОшибкиHTML = МЧД_РасшифровкаОшибокВСтрокуСпискаHTML(РасшифровкаСтатуса, РасшифровкаОшибок);
		Иначе
			ТекстОшибкиHTML = "";
		КонецЕсли;
			
		Если ОшибкиПоРазделам.Получить(Раздел) = Неопределено Тогда
			ОшибкиПоРазделам.Вставить(Раздел, Новый Массив);
		КонецЕсли;
		
		ОшибкиПоРазделам[Раздел].Добавить(ТекстОшибкиHTML);
		
	КонецЦикла;
	
	ЭлементыДокументаHTML = Новый Массив;
	ЭлементыДокументаHTML.Добавить(Шаблоны.Начало);
	
	Если ОшибкиПоРазделам.Получить(РазделыОшибок.НетМЧДПоУмолчанию) <> Неопределено Тогда
		СписокОшибокСтрокой = СоединитьСтроку(ОшибкиПоРазделам[РазделыОшибок.НетМЧДПоУмолчанию], Символы.ПС);
		ТекстРаздела = Общее_ПодставитьПараметрыВСтроку(Шаблоны.НетМЧДПоУмолчанию, РазделыОшибок.НетМЧДПоУмолчанию, СписокОшибокСтрокой);	
		ЭлементыДокументаHTML.Добавить(ТекстРаздела);
	КонецЕсли;
	
	Если ОшибкиПоРазделам.Получить(РазделыОшибок.МЧДнеПодходит) <> Неопределено Тогда
		СписокОшибокСтрокой = СоединитьСтроку(ОшибкиПоРазделам[РазделыОшибок.МЧДнеПодходит], Символы.ПС);
		ТекстРаздела = Общее_ПодставитьПараметрыВСтроку(Шаблоны.МЧДнеПодходит, РазделыОшибок.МЧДнеПодходит, СписокОшибокСтрокой);	
		ЭлементыДокументаHTML.Добавить(ТекстРаздела);
	КонецЕсли;
	
	ЭлементыДокументаHTML.Добавить(Шаблоны.Окончание);
	
	Результат = СоединитьСтроку(ЭлементыДокументаHTML, Символы.ПС);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_РасшифровкаОшибокВСтрокуСпискаHTML(Заголовок, СписокОшибок)

	Результат = "";
	
	Если Не ЗначениеЗаполнено(СписокОшибок) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ШаблонСтрокиСпискаHTML = "<li>- %1</li>";
	
	ТекстСпискаHTML = "";
	
	ЭлементыСпискаHTML = Новый Массив;
	Для Каждого ОписаниеОшибок Из СписокОшибок Цикл
		ТекстСтрокиСпискаHTML = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиСпискаHTML, ОписаниеОшибок.Расшифровка);
		ЭлементыСпискаHTML.Добавить(ТекстСтрокиСпискаHTML);		
	КонецЦикла;
	
	ТекстСпискаHTML = СоединитьСтроку(ЭлементыСпискаHTML, Символы.ПС);
	
	ШаблонСпискаHTML =
	"<li><p>%1
	|	<ul type=""none"">
	|			%2
	|	</ul>
	|</p></li>";

	Результат = Общее_ПодставитьПараметрыВСтроку(ШаблонСпискаHTML, Заголовок, ТекстСпискаHTML);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_РасшифровкаСтатусаВСтрокуСпискаHTML(Текст)

	ШаблонСтрокиСпискаHTML = "<li>%1</li>";

	Результат = Общее_ПодставитьПараметрыВСтроку(ШаблонСтрокиСпискаHTML, Текст);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_ШаблоныHTMLДокументаОшибокПроверкиПриГрупповыхДействиях()
	
	ШаблонНачало =
	"<HTML>
	|	<HEAD>
	|		<style type=text/css>
	|			body {font-family: Segoe UI}
	|			h4 {padding-bottom: 0em}
	|			ul.box {padding-left: 3em}
    |        	ul.sub {font-size: 10pt}
    |        	p.footer {font-size: 10pt}
	|		</style>
	|	</HEAD>
	|<BODY scroll=auto>
	|";
	
	КнопкиТехПоддрежки = ЦП_ШаблонHTMLКнопкаТехПоддержки();
	
	ШаблонНачало = ШаблонНачало + КнопкиТехПоддрежки;
	
	ШаблонОкончание =
	"</BODY>
	|</HTML>";

	СимволСтрелкаВправо = Символ(8594);
	
	ОписаниеНетМЧДПоУмолчанию = "Чтобы настроить МЧД, перейдите в раздел ""Настройки""" + СимволСтрелкаВправо +
	"""Доверенности"". Если подтверждаете полномочия иным способом, продолжите без МЧД.";
	
	ШаблонНетМЧДпоУмолчанию = 
	"<h4>%1</h4>
	|	<ul>
	|		%2
	|	</ul>
	|<p class=""footer"">" + ОписаниеНетМЧДПоУмолчанию + "</p>
	|<br/>";
	
	ОписаниеМЧДнеДействительна = "Проверьте данные в разделе ""Настройки""" + СимволСтрелкаВправо +
	"""Доверенности"". Если подтверждаете полномочия иным способом, продолжите без МЧД.";
	
	ШаблонМЧДнеДействительна =
	"<h4>%1</h4>
	|	<ul>
	|		%2
	|	</ul>
	|<p class=""footer"">" + ОписаниеМЧДнеДействительна + "</p>
	|<br/>";
	
	Результат = Новый Структура;
	Результат.Вставить("Начало"				, ШаблонНачало);
	Результат.Вставить("Окончание"			, ШаблонОкончание);
	Результат.Вставить("НетМЧДПоУмолчанию"	, ШаблонНетМЧДпоУмолчанию);
	Результат.Вставить("МЧДнеПодходит"		, ШаблонМЧДнеДействительна);
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_РазделыОшибокПроверкиМЧД() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("НетМЧДПоУмолчанию", "Не указана доверенность по умолчанию для организаций");
	Результат.Вставить("МЧДнеПодходит", "Выбранная доверенность не подходит");
	Результат.Вставить("КонтрагентНеПоддерживаетМЧДВРоуминге", "Оператор контрагента не поддерживает МЧД");
	
	Возврат Результат;
	
КонецФункции

// Регистрирует машиночитаемую доверенность в сервисе.
//
// Параметры
//  ПараметрыРегистрацииМЧД		- Структура	 - см. Контракт_ПараметрыРегистрацииМЧД()
//
// Возвращаемое значение:
//  Структура - данные о результате регистрации МЧД, см. Контракт_РезультатРегистрацииМЧД()
//
Функция МЧД_ЗарегистрироватьНовуюДоверенность(ПараметрыРегистрацииМЧД) Экспорт
	
	Результат = Контракт_РезультатРегистрацииМЧД();
	
	Попытка
		ИДЗаданияРегистрации = МЧД_НовоеЗаданиеРегистрацииДоверенности(ПараметрыРегистрацииМЧД);
	Исключение
		
		КлючОшибки = "НеизвестнаяОшибка";
		
		КраткоеПредставлениеОшибки			 = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		МЧД_ДополнитьСписокОшибокРегистрации(Результат.СписокОшибок, КлючОшибки, КраткоеПредставлениеОшибки);
		
		ПодробноеОписаниеОшибки				 = МЧД_РасшифровкаКодовОшибокДобавленияМЧД()[КлючОшибки];
		Результат.ПодробноеОписаниеОшибки	 = ПодробноеОписаниеОшибки;
		Результат.СтатусОперации			 = Перечисление_СтатусыРегистрацииМЧД().Error;
		
	КонецПопытки;
	
	Если ИДЗаданияРегистрации <> Неопределено Тогда
	
		boxId = ПараметрыРегистрацииМЧД.boxId;
		
		Для НомерПопытки = 1 По 20 Цикл
			
			Таймаут(5);
			
			Результат = МЧД_ПроверитьЗаданиеРегистрацииДоверенности(ИДЗаданияРегистрации, boxId);
			
			Если Результат.Завершено Тогда
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ Результат.Завершено 
			И НЕ ЗначениеЗаполнено(Результат.ПодробноеОписаниеОшибки) Тогда
			
			КлючОшибки = "ПревышеноВремяОжидания";
			ПодробноеОписаниеОшибки				 = МЧД_РасшифровкаКодовОшибокДобавленияМЧД()[КлючОшибки];
			Результат.ПодробноеОписаниеОшибки	 = ПодробноеОписаниеОшибки;
			
		КонецЕсли;
	
	КонецЕсли;
	
	Метрика_ДобавитьСтатистику_РезультатРегистрацииМЧД(ПараметрыРегистрацииМЧД, Результат);
	
	Возврат Результат;
	
КонецФункции

// Запускает задание на регистрацию МЧД в сервисе.
//
// Параметры:
//  ПараметрыРегистрацииМЧД	- Структура	 - см. Контракт_ПараметрыРегистрацииМЧД
//
// Возвращаемое значение:
//  Строка - Идентификатор запущенного задания
//
Функция МЧД_НовоеЗаданиеРегистрацииДоверенности(ПараметрыРегистрацииМЧД)
	
	Если ПараметрыРегистрацииМЧД.РегистрацияПоФайлу Тогда
		
		Content = Base64Строка(ПараметрыРегистрацииМЧД.ФайлМЧД);
		Signature = Base64Строка(ПараметрыРегистрацииМЧД.ФайлПодписи);
		SignedContent = АПИ_Новый_PowerOfAttorneySignedContent(Content, Signature);
		
	Иначе
		
		RegistrationNumber = ПараметрыРегистрацииМЧД.РегистрационныйНомер;
		IssuerInn = ПараметрыРегистрацииМЧД.ИННДоверителя;
		RepresentativeInn = ПараметрыРегистрацииМЧД.ИННУполномоченного;
		
		FullId = АПИ_Новый_PowerOfAttorneyFullId(
				RegistrationNumber,
				IssuerInn,
				RepresentativeInn);
		
	КонецЕсли;
	
	BoxId = ПараметрыРегистрацииМЧД.boxId;
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);
	PowerOfAttorneyToRegister = АПИ_Новый_PowerOfAttorneyToRegister(FullId, SignedContent);
	
	СтруктураTaskId = АПИ_PostRegisterPowerOfAttorney(ПараметрыСервиса, boxId, PowerOfAttorneyToRegister);
	
	Результат = "";
	Если СтруктураTaskId <> Неопределено Тогда
		Результат = СтруктураTaskId.TaskId;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет запущенное задание на регистрацию МЧД в сервисе.
//
// Параметры
//  ПараметрыРегистрацииМЧД		- Структура	 - см. Контракт_ПараметрыРегистрацииМЧД
//
// Возвращаемое значение:
//   Структура - результат регистрации, см. Контракт_РезультатРегистрацииМЧД;
//
Функция МЧД_ПроверитьЗаданиеРегистрацииДоверенности(ИДЗаданияРегистрации, boxId)
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);
	
	RegisterPowerOfAttorneyResult = АПИ_GetRegisterPowerOfAttorneyResult(ПараметрыСервиса, boxId, ИДЗаданияРегистрации);
	
	Результат = МЧД_РасшифровкаRegisterPowerOfAttorneyResult(RegisterPowerOfAttorneyResult);
	
	Возврат Результат;
	
КонецФункции

// Контракт для регистрации новой МЧД в сервисе
//
// Возвращаемое значение:
//  Структура - содержит поля:
//   * boxId				- Строка - идентификатор ящика в сервисе;
//   * РегистрацияПоФайлу	- Булево - определяет вариант регистрации, по файлу или по рег. номеру;
//   * ИННДоверителя		- Строка - ИНН доверителя МЧД;
//   * РегистрационныйНомер	- Строка - регистрационный номер МЧД в формате GUID;
//   * ФайлМЧД				- ДвоичныеДанные - файл МЧД
//   * ФайлПодписи			- ДвоичныеДанные - файл подписи МЧД
//
Функция Контракт_ПараметрыРегистрацииМЧД() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("boxId", "");
	Результат.Вставить("РегистрацияПоФайлу", Ложь);
	Результат.Вставить("ИННДоверителя", "");
	Результат.Вставить("ИННУполномоченного", "");
	Результат.Вставить("РегистрационныйНомер", "");
	Результат.Вставить("ФайлМЧД", Неопределено);
	Результат.Вставить("ФайлПодписи", Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Конвертирует контракт АПИ в контракт 1С
//
// Параметры
//  RegisterPowerOfAttorneyResult	- Структура	 - ответ метода КонтурМетодыAPI.DD_API_GetRegisterPowerOfAttorneyResult
//
// Возвращаемое значение:
//  Структура - см. Контракт_РезультатРегистрацииМЧД()
//
Функция МЧД_РасшифровкаRegisterPowerOfAttorneyResult(RegisterPowerOfAttorneyResult)
	
	Результат = Контракт_РезультатРегистрацииМЧД();
	
	Status = СвойствоСтруктуры(RegisterPowerOfAttorneyResult, "Status");
	Если Status <> Неопределено Тогда
		СтатусМЧД = СвойствоСтруктуры(Status, "Status");
	КонецЕсли;
	
	ПодробноеОписаниеОшибки		 = "";
	КодОшибки					 = "";
	ДоверенностьДействует		 = Ложь;
	
	СтатусыРегистрацииМЧД = Перечисление_СтатусыРегистрацииМЧД();
	РасшифровкаКодовОшибок = МЧД_РасшифровкаКодовОшибокДобавленияМЧД(); 
	
	СтатусОперации = СвойствоСтруктуры(RegisterPowerOfAttorneyResult, "OperationStatus");
	Если СтатусОперации = СтатусыРегистрацииМЧД.Done Тогда
		
		СтатусыМЧДПослеРегистрации = Перечисление_СтатусыМЧДПослеРегистрации();
		
		Если СтатусМЧД = СтатусыМЧДПослеРегистрации.Expired Тогда
			
			ПодробноеОписаниеОшибки = "Не удалось добавить доверенность.
			|Истек срок действия доверенности.";
			
		ИначеЕсли СтатусМЧД = СтатусыМЧДПослеРегистрации.Revoked Тогда
			
			ПодробноеОписаниеОшибки = "Не удалось добавить доверенность.
			|Доверенность отозвана и не может
			|использоваться для подписания документов.";
			
		ИначеЕсли СтатусМЧД = СтатусыМЧДПослеРегистрации.Active Тогда
			
			ДоверенностьДействует = Истина;
			
		КонецЕсли;
		
	ИначеЕсли СтатусОперации = СтатусыРегистрацииМЧД.Queued Тогда
		
		ПодробноеОписаниеОшибки				 = РасшифровкаКодовОшибок.РегистрацияНеЗавершена;
		Результат.ПодробноеОписаниеОшибки	 = ПодробноеОписаниеОшибки;
		
	ИначеЕсли СтатусОперации = СтатусыРегистрацииМЧД.Unknown Тогда
		
		ПодробноеОписаниеОшибки				 = РасшифровкаКодовОшибок.Unknown;
		Результат.ПодробноеОписаниеОшибки	 = ПодробноеОписаниеОшибки;
		
	КонецЕсли;
	
	СписокОшибок = Новый Массив;
	Errors = СвойствоСтруктуры(RegisterPowerOfAttorneyResult, "Errors");
	Если Errors <> Неопределено Тогда
		
		КоличествоОшибок = Errors.Количество();
		
		Для каждого Error Из Errors Цикл
			
			КодОшибки	 = Error.Code;
			Расшифровка	 = СвойствоСтруктуры(Error, "Text", "");
			
			ЕстьРасширеннаяРасшифровка = РасшифровкаКодовОшибок.Свойство(КодОшибки);
			Если ЕстьРасширеннаяРасшифровка Тогда
				Расшифровка = РасшифровкаКодовОшибок[КодОшибки];
			КонецЕсли;
			
			Если Расшифровка = "" Тогда
				Расшифровка = РасшифровкаКодовОшибок.НеизвестнаяОшибка;
			КонецЕсли;
			
			Если КоличествоОшибок > 1 Тогда
				МЧД_ДополнитьСписокОшибокРегистрации(СписокОшибок, КодОшибки, Расшифровка);
			Иначе
				ПодробноеОписаниеОшибки = Расшифровка;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	PowerOfAttorney = СвойствоСтруктуры(RegisterPowerOfAttorneyResult, "PowerOfAttorney");
	Если PowerOfAttorney <> Неопределено Тогда
		КонтрактМЧД = АПИ_ЗаполненныйКонтрактМЧД(PowerOfAttorney);
	КонецЕсли;
	
	Завершено = СтатусОперации = СтатусыРегистрацииМЧД.Done
	ИЛИ СтатусОперации = СтатусыРегистрацииМЧД.Error;
	
	Результат.СтатусОперации			 = СтатусОперации;
	Результат.СписокОшибок				 = СписокОшибок;
	Результат.ПодробноеОписаниеОшибки	 = ПодробноеОписаниеОшибки;
	Результат.КодОшибки					 = КодОшибки;
	Результат.Завершено					 = Завершено;
	Результат.ДоверенностьДействует		 = ДоверенностьДействует;
	Результат.КонтрактМЧД				 = КонтрактМЧД;

	Возврат Результат;
	
КонецФункции

// Дополняет переданный массив ошибок регистрации МЧД
//
// Параметры
//  СписокОшибок	- Массив	 - список ошибок регистрации в который добавляется новое значение.
//  КодОшибки		- Строка	 - .
//  Расшифровка		- Строка	 - .
//
Процедура МЧД_ДополнитьСписокОшибокРегистрации(СписокОшибок, КодОшибки, Расшифровка)

	ОписаниеОшибки = Новый Структура;
	ОписаниеОшибки.Вставить("Код"			, КодОшибки);
	ОписаниеОшибки.Вставить("Расшифровка"	, Расшифровка);
	
	СписокОшибок.Добавить(ОписаниеОшибки);
	
КонецПроцедуры

Функция МЧД_РасшифровкаКодовОшибокДобавленияМЧД()
	
	Результат = Новый Структура;

	ТекстОшибки = "Произошла ошибка при добавлении МЧД, попробуйте еще раз.";
	Результат.Вставить("Unknown"								, ТекстОшибки);
	Результат.Вставить("Timeout"								, ТекстОшибки);
	Результат.Вставить("InternalServerError"					, ТекстОшибки);
	
	ТекстОшибки = "Доверенность с такими реквизитами не найдена в ФНС. 
	|Измените номер или ИНН доверителя или загрузите файл доверенности с подписью.";
	Результат.Вставить("PowerOfAttorneyNotFound"				, ТекстОшибки);
	
	ТекстОшибки = "Произошла ошибка при поиске в реестре ФНС.";
	Результат.Вставить("FnsPowerOfAttorneyRegistryBadResponse"	, ТекстОшибки);
	Результат.Вставить("FnsPowerOfAttorneyRegistryIsUnavailable", ТекстОшибки);
	Результат.Вставить("FnsPowerOfAttorneyRegistryTimeout"		, ТекстОшибки);
	
	ТекстОшибки = "Формат доверенности не поддерживается.";
	Результат.Вставить("UnsupportedPowerOfAttorney"				, ТекстОшибки);
	
	ТекстОшибки = "Неверно указаны реквизиты доверенности.
	|Измените номер или ИНН доверителя или загрузите файл доверенности с подписью.";
	Результат.Вставить("InvalidPowerOfAttorneFullId"			, ТекстОшибки);
	
	ТекстОшибки = "Произошла ошибка при загрузке из реестра ФНС.";
	Результат.Вставить("ConflictDifferentContent"				, ТекстОшибки);
	Результат.Вставить("ConflictDifferentSignature"				, ТекстОшибки);
	Результат.Вставить("ConflictSameContentAndSameSignature"	, ТекстОшибки);
	
	ТекстОшибки = "Доверенность в процессе регистрации.
	|Проверьте результат позднее.";
	Результат.Вставить("РегистрацияНеЗавершена"					, ТекстОшибки);

	ТекстОшибки = "Не удалось добавить доверенность.
	|Превышено время ожидания.
	|Повторите попытку позже.";
	Результат.Вставить("ПревышеноВремяОжидания"					, ТекстОшибки);
	
	ТекстОшибки = "Произошла ошибка добавления доверенности,
	|попробуйте еще раз.";
	Результат.Вставить("НеизвестнаяОшибка"						, ТекстОшибки);
	
	Возврат Результат;

КонецФункции

// Ответ метода МЧД_ЗарегистрироватьНовуюДоверенность
//
// Возвращаемое значение:
//  Структура - содержит поля:
//   * Завершено				- Булево - признак завершения операция регистрации;
//   * СтатусОперации			- Строка - статус выполнения операции регистрации, см. Перечисление_СтатусыРегистрацииМЧД();
//   * СписокОшибок				- Массив - Массив структур с полями Расшифровка и Код
//   * КодОшибки				- Строка - обобщенный код ошибки регистрации МЧД
//   * ПодробноеОписаниеОшибки	- Строка - обобщенный текст ошибки регистрации МЧД
//   * ДоверенностьДействует	- Булево - Истина если доверенность действующая
//   * КонтрактМЧД				- Структура - см. Контракт_МЧД()
//
Функция Контракт_РезультатРегистрацииМЧД()
	
	Результат = Новый Структура;
	Результат.Вставить("Завершено"				, Ложь);
	Результат.Вставить("СтатусОперации"			, "");
	Результат.Вставить("СписокОшибок"			, Новый Массив);
	Результат.Вставить("КодОшибки"				, "");
	Результат.Вставить("ПодробноеОписаниеОшибки", Ложь);
	Результат.Вставить("ДоверенностьДействует"	, Ложь);
	Результат.Вставить("КонтрактМЧД"			, Неопределено);
	
	Возврат Результат;
	
КонецФункции

