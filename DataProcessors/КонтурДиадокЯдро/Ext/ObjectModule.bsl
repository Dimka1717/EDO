Функция ИоП_ПодготовитьИзвещенияОПолучении() Экспорт
	
	ЗаписьЖурналаРегистрации("Диадок.ФормированиеИзвещений", , , "Начало формирования");
	
	Результат = Новый Массив;
	
	КонтекстСеансаКлиентСервер = КонтекстСеанса_СтрокиКонтекста();
	
	Для Каждого КлючИЗначение Из КонтекстСеансаКлиентСервер Цикл
		
		СтрокаКонтекста = КлючИЗначение.Значение;
		
		BoxId = СтрокаКонтекста.BoxId;
		
		Если НЕ ЗначениеЗаполнено(BoxId) Тогда
			Продолжить;
		КонецЕсли;
		
		ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(BoxId);
	
		Если ФормироватьУС = Неопределено Тогда
			ДоступноФормированиеИоП = ИоП_ДоступноФормированиеИзвещенийОПолучении(BoxId);
		Иначе
			ДоступноФормированиеИоП = ФормироватьУС;
		КонецЕсли;
		
		Если НЕ ДоступноФормированиеИоП Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
		
		МассивИзвещенийОПолучении = Новый Массив;
		
		Если ФормироватьУС = Неопределено Тогда
			SignerContent = Подписант_ЗаполненныйSignerContentДляИоП(BoxId);
		Иначе
			SignerContent = Неопределено;
		КонецЕсли;
		
		// Входящие
		IndexKey = "";
		
		Пока IndexKey <> Неопределено Цикл
			
			DocumentList = ИоП_ДокументыТребующиеФормированияИзвещенийОПолучении(ПараметрыСервиса, boxId,
							"Any.InboundHaveToCreateReceipt", IndexKey);
			
			IndexKey = ИоП_СформироватьИзвещенияОПолучении(boxId, DocumentList.Documents, SignerContent, МассивИзвещенийОПолучении);
			
		КонецЦикла;
		
		// Исходящие
		IndexKey = "";
		
		Пока IndexKey <> Неопределено Цикл
			
			DocumentList = ИоП_ДокументыТребующиеФормированияИзвещенийОПолучении(ПараметрыСервиса, boxId,
							"Any.OutboundHaveToCreateReceipt", IndexKey);
			
			IndexKey = ИоП_СформироватьИзвещенияОПолучении(boxId, DocumentList.Documents, SignerContent, МассивИзвещенийОПолучении);
			
		КонецЦикла;
		
		Результат.Добавить(Новый Структура("boxId, ИзвещенияОПолучении", boxId, МассивИзвещенийОПолучении));
		
	КонецЦикла;
	
	ЗаписьЖурналаРегистрации("Диадок.ФормированиеИзвещений", , , "Окончание формирования");
	
	Возврат Результат;
	
КонецФункции

Функция ИоП_СформироватьИзвещенияОПолучении(boxId, Documents, SignerContent, МассивИзвещенийОПолучении)
	
	ФормироватьУС = УС_ДоступноФормированиеУниверсальныхСообщений(boxId);
	КодУС = Перечисление_КодыУниверсальногоСообщения().ИзвещениеОПолучении;
	
	IndexKey = Неопределено;
	ПараметрыСервиса = ПараметрыСервиса_Диадок(boxId);
	
	Для Каждого Document Из Documents Цикл
		
		IndexKey = Document.IndexKey;
		
		// Извещения формируем только когда подпись отправителя проверена и валидна.
		Если Document.SenderSignatureStatus	<> "SenderSignatureCheckedAndValid" Тогда
			Продолжить;
		КонецЕсли;
		
		СущностиТребующиеИоП = ИоП_СущностиТребующиеИзвещенияОПолучении(BoxId, Document);
		
		Для Каждого ParentEntityId Из СущностиТребующиеИоП Цикл
			
			MessageId = Document.MessageId;
			
			UniversalMessage = Неопределено;
			InvoiceReceipt = Неопределено;
			
			Если ФормироватьУС = Неопределено Тогда
				
				Попытка
					ReceiptGenerationRequestV2 = АПИ_Новый_ReceiptGenerationRequestV2(MessageId, ParentEntityId, SignerContent);
					InvoiceReceipt = АПИ_GenerateReceiptXml(ПараметрыСервиса, BoxId, ReceiptGenerationRequestV2);
				Исключение
					ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					ИоП_ОбработатьОшибку_СформироватьИзвещенияОПолучении(ТекстОшибки, BoxId, MessageId, ParentEntityId);
				КонецПопытки;
				
			Иначе
				
				Попытка
                    ДанныеСообщения = УС_ДанныеУниверсальногоСообщенияПоКонтексту(BoxId, КодУС);
					UniversalMessage = УС_УниверсальноеСообщение(BoxId, MessageId, ParentEntityId, ДанныеСообщения);
				Исключение
					ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					УС_ОбработатьОшибку_СформироватьУниверсальноеСообщение(ТекстОшибки, BoxId, MessageId, ParentEntityId, КодУС);
				КонецПопытки;
				
			КонецЕсли;
			
			Если InvoiceReceipt <> Неопределено
				ИЛИ UniversalMessage <> Неопределено Тогда
				
				СтруктураДанных = Новый Структура;
				
				СтруктураДанных.Вставить("MessageId", MessageId);
				СтруктураДанных.Вставить("ParentEntityId", ParentEntityId);
				СтруктураДанных.Вставить("DocumentId", Document.EntityId);
				СтруктураДанных.Вставить("InvoiceReceipt", InvoiceReceipt);
				СтруктураДанных.Вставить("UniversalMessage", UniversalMessage);
				
				МассивИзвещенийОПолучении.Добавить(СтруктураДанных);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат IndexKey;
	
КонецФункции

Функция ИоП_СущностиТребующиеИзвещенияОПолучении(BoxId, Document)
	
	Результат = Новый Массив;
	
	СтатусыДокументовЭДО	= Перечисление_СтатусыДокументов();
	СтатусыДокументовАПИ	= Перечисление_СтатусыДокументовАПИ();
	КлассыДокументов		= Перечисление_КлассыДокументов();
	
	LetterId	= Document.MessageId;
	DocumentId	= Document.EntityId;
	Direction	= СвойствоСтруктуры(Document, "DocumentDirection");
	
	СтатусТребуетсяПодписатьИзвещение = СтатусыДокументовАПИ.Получить(СтатусыДокументовЭДО.ТребуетсяПодписатьИзвещение);
	
	СтатусыДО = ДокументAPI_СтатусыДО(Document);
	
	ТребуетсяИзвещениеНаВходящий = (Direction = КлассыДокументов.Входящие
									И СтатусыДО.RecipientReceipt = СтатусТребуетсяПодписатьИзвещение);
									
	ТребуетсяИзвещениеНаУточнение = (Direction = КлассыДокументов.Исходящие
									И СтатусыДО.AmendmentReceipt = СтатусТребуетсяПодписатьИзвещение);								

	ТребуетсяИзвещениеНаПодтверждение = (СтатусыДО.ConfirmationReceipt = СтатусТребуетсяПодписатьИзвещение);
									
	ТребуетсяИзвещениеНаПодтверждениеНаИоП = (СтатусыДО.RecipientReceiptConfirmation = СтатусТребуетсяПодписатьИзвещение);
	
	ТребуетсяИзвещениеНаОтветныйТитул = (Direction = КлассыДокументов.Исходящие
										И СтатусыДО.SenderReceipt = СтатусТребуетсяПодписатьИзвещение);
	
	Если ТребуетсяИзвещениеНаВходящий Тогда
		Результат.Добавить(DocumentId);
	КонецЕсли;
	
	Если ТребуетсяИзвещениеНаУточнение
		ИЛИ ТребуетсяИзвещениеНаОтветныйТитул
		ИЛИ ТребуетсяИзвещениеНаПодтверждение
		ИЛИ ТребуетсяИзвещениеНаПодтверждениеНаИоП Тогда
		
		Попытка
			
			Entities = Документы_МассивEntities(BoxId, LetterId, DocumentId);
			
		Исключение
			
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ИоП_ОбработатьОшибку_СформироватьИзвещенияОПолучении(ТекстОшибки, BoxId, LetterId, DocumentId);
			
		КонецПопытки;
		
		Если ЗначениеЗаполнено(Entities) Тогда
			
			AttachmentType = АПИ_Перечисление_AttachmentType();
			
			Если ТребуетсяИзвещениеНаУточнение Тогда
				
				CorrectionRequestId = ДокументAPI_AttachmentEntityId(Entities, AttachmentType.InvoiceCorrectionRequest, DocumentId);
				ДополнитьМассив(Результат, CorrectionRequestId);
				
			КонецЕсли;
			
			Если ТребуетсяИзвещениеНаПодтверждение Тогда
				
				ConfirmationId = ДокументAPI_AttachmentEntityId(Entities, AttachmentType.InvoiceConfirmation, DocumentId);
				ДополнитьМассив(Результат, ConfirmationId);
				
			КонецЕсли;
			
			Если ТребуетсяИзвещениеНаПодтверждениеНаИоП Тогда
				
				ReceiptId = ДокументAPI_AttachmentEntityId(Entities, AttachmentType.InvoiceReceipt, DocumentId);
				
				Если ЗначениеЗаполнено(ReceiptId) Тогда
					
					ConfirmationId = ДокументAPI_AttachmentEntityId(Entities, AttachmentType.InvoiceConfirmation, ReceiptId[0]);
					ДополнитьМассив(Результат, ConfirmationId);
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если ТребуетсяИзвещениеНаОтветныйТитул Тогда
				
				Если Document.TypeNamedId = Тип_УПД() Тогда 
					
					AttachmentType_Title = AttachmentType.UniversalTransferDocumentBuyerTitle;
					
				ИначеЕсли Document.TypeNamedId = Тип_УКД() Тогда
					
					AttachmentType_Title = AttachmentType.UniversalCorrectionDocumentBuyerTitle;
					
				ИначеЕсли Document.TypeNamedId = Тип_Накладная() Тогда
					
					AttachmentType_Title = AttachmentType.XmlTorg12BuyerTitle;
					
				ИначеЕсли Document.TypeNamedId = Тип_АктОбОказанииУслуг() Тогда
					
					AttachmentType_Title = AttachmentType.XmlAcceptanceCertificateBuyerTitle;
					
				Иначе
					AttachmentType_Title = AttachmentType.Title;
				КонецЕсли;
				
				TitleId = ДокументAPI_AttachmentEntityId(Entities, AttachmentType_Title, DocumentId);
				
				ДополнитьМассив(Результат, TitleId);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции

Процедура ИоП_ПодписатьИзвещенияОПолучении(ПодготовленныеИзвещенияВсехОрганизаций) Экспорт
	
	Для Каждого ПодготовленныеИзвещенияОрганизации Из ПодготовленныеИзвещенияВсехОрганизаций Цикл
		
		BoxId = ПодготовленныеИзвещенияОрганизации.BoxId;
		
		Для Каждого СтруктураДанных Из ПодготовленныеИзвещенияОрганизации.ИзвещенияОПолучении Цикл
			
			InvoiceReceipt = СтруктураДанных.InvoiceReceipt;
			
			Если InvoiceReceipt <> Неопределено Тогда
			
				ДвоичныеДанныеПодписи = ПодписьДанных(BoxId, InvoiceReceipt);
				СтруктураДанных.Вставить("Signature", ДвоичныеДанныеПодписи);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ИоП_ОтправитьИзвещенияОПолучении(ПодготовленныеИзвещенияВсехОрганизаций) Экспорт
	
	ЗаписьЖурналаРегистрации("Диадок.ФормированиеИзвещений", , , "Начало отправки");
	
	Для Каждого ПодготовленныеИзвещенияОрганизации Из ПодготовленныеИзвещенияВсехОрганизаций Цикл
		
		ИоП_ОтправитьИзвещенияОПолученииДляОрганизации(ПодготовленныеИзвещенияОрганизации);
        
	КонецЦикла;
	
	ЗаписьЖурналаРегистрации("Диадок.ФормированиеИзвещений", , , "Окончание отправки");
	
КонецПроцедуры

Процедура ИоП_ОтправитьИзвещенияОПолученииДляОрганизации(ПодготовленныеИзвещенияОрганизации)
	
	BoxId = ПодготовленныеИзвещенияОрганизации.BoxId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	ДанныеМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(BoxId);
	
	PowerOfAttorney = Неопределено;
	
	Если ДанныеМЧД.ТребуетсяМЧД И ЗначениеЗаполнено(ДанныеМЧД.МЧД) Тогда
		КонтрактМЧД		 = ДанныеМЧД.СписокМЧД.Получить(ДанныеМЧД.МЧД);
		PowerOfAttorney	 = АПИ_Новый_PowerOfAttorneyToPost(КонтрактМЧД);
	КонецЕсли;
	
	Код = Перечисление_КодыУниверсальногоСообщения().ИзвещениеОПолучении;
	CodeGroup = УС_КодГруппыУниверсальногоСообщения(Код);
	
	Для Каждого СтруктураДанных Из ПодготовленныеИзвещенияОрганизации.ИзвещенияОПолучении Цикл
		
		ИзвещениеПодготовленоВСтаромФормате = (СтруктураДанных.InvoiceReceipt <> Неопределено
												И СтруктураДанных.Свойство("Signature"));
		
		ИзвещениеПодготовленоВФорматеУС = (СтруктураДанных.UniversalMessage <> Неопределено);
		
		Если НЕ ИзвещениеПодготовленоВСтаромФормате 
			И НЕ ИзвещениеПодготовленоВФорматеУС Тогда
			Продолжить;
		КонецЕсли;
		
		MessageId = СтруктураДанных.MessageId;
		DocumentId = СтруктураДанных.DocumentId;
		ParentEntityId = СтруктураДанных.ParentEntityId;
		
		MessagePatchToPost = АПИ_Новый_MessagePatchToPost(BoxId, MessageId);
		
		Если ИзвещениеПодготовленоВСтаромФормате Тогда
			
			Signature = СтруктураДанных.Signature;
			InvoiceReceipt = СтруктураДанных.InvoiceReceipt;
			SignedContent = АПИ_Новый_SignedContent(InvoiceReceipt, Signature, , , PowerOfAttorney);
			ReceiptAttachment = АПИ_Новый_ReceiptAttachment(ParentEntityId, SignedContent);
			
			Receipts = Новый Массив;
			Receipts.Добавить(ReceiptAttachment);
			MessagePatchToPost.Вставить("Receipts", Receipts);
			
		КонецЕсли;
		
		Если ИзвещениеПодготовленоВФорматеУС Тогда
			
			UniversalMessage = СтруктураДанных.UniversalMessage;
			UniversalMessageContent = АПИ_Новый_UnsignedContent(UniversalMessage);
			UniversalMessageAttachment = АПИ_Новый_UniversalMessageAttachment(ParentEntityId,
																				UniversalMessageContent,
																				CodeGroup);
			UniversalMessages = Новый Массив;
			UniversalMessages.Добавить(UniversalMessageAttachment);
			MessagePatchToPost.Вставить("UniversalMessages", UniversalMessages);
			
		КонецЕсли;
		
		Попытка
			
			РезультатОтправки = АПИ_PostMessagePatch(ПараметрыСервиса, MessagePatchToPost);
			
		Исключение
			
			ВидОперации		 = "Подписание извещений о получении документов";
			ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения	 = "Не удалось подписать извещение о получении документа";
			ДопИнформация	 = "Документ: " + СформироватьСсылкуВБраузере(BoxId, MessageId, DocumentId);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;

КонецПроцедуры

// Возвращает массив документов из ящика boxId, подходящих под определенный фильтр
//
// Параметры:
//  ПараметрыСервиса - Структура - см. функцию Модуль_МетодыAPI().ПараметрыСервиса()
//  boxId            - Строка - идентификатор ящика
//  filterCategory   - Строка - категория, по которой фильтруется список документов
//  afterIndexKey    - Строка - уникальный ключ документа, позволяющий итерироваться
//                               по всему списку документов, удовлетворяющих фильтру
// 
// Возвращаемое значение:
//  Структура - см. функцию Модуль_МетодыAPI().DD_API_DS_DocumentList()
//
Функция ИоП_ДокументыТребующиеФормированияИзвещенийОПолучении(ПараметрыСервиса, boxId, filterCategory, afterIndexKey)
	
	Попытка
		Результат = АПИ_GetDocuments(ПараметрыСервиса, boxId, filterCategory, , , , , , , , , afterIndexKey);
	Исключение
		Результат = Модуль_МетодыAPI(ЭтотОбъект).DD_API_DS_DocumentList();
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ИоП_ОбработатьОшибку_ПолучениеСпискаДокументов(ТекстОшибки, afterIndexKey, boxId, filterCategory);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ИоП_ДоступноФормированиеИзвещенийОПолучении(BoxId)
	
	Результат = Истина;
	
	ДействиеЭДО = Перечисление_ДействияЭДО().ОтправитьИзвещениеОПолучении;
	ОписаниеОшибкиПроверкиКЭП = КЭП_ДоступноДействиеЭДО(ДействиеЭДО, BoxId);
	
	Если ЗначениеЗаполнено(ОписаниеОшибкиПроверкиКЭП) Тогда
		
		Результат = Ложь;
		
	Иначе
		
		ПраваПользователя = ПраваПользователяЯщикаОрганизации(BoxId);
		
		Если НЕ ПраваПользователя.CanSignDocuments Тогда
			Результат = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИоП_ВидОперации_ПодготовкаИзвещений()
	
	Результат = НСтр("ru = 'Подготовка извещений о получении документов'");
	
	Возврат Результат;
	
КонецФункции

Процедура ИоП_ОбработатьОшибку_ПолучениеСпискаДокументов(ТекстОшибки, afterIndexKey, BoxId, filterCategory)
	
	ВидОперации = ИоП_ВидОперации_ПодготовкаИзвещений();
	ТекстСообщения = НСтр("ru = 'Не удалось получить список документов, требующих подписать извещения о получении'");
	
	ДопИнформация = Новый Массив;
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("boxId: %1", BoxId));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("filterCategory: %1", filterCategory));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("afterIndexKey: %1", afterIndexKey));
	
	Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);

КонецПроцедуры

Процедура ИоП_ОбработатьОшибку_СформироватьИзвещенияОПолучении(ТекстОшибки, BoxId, MessageId, EntityId)
	
	ВидОперации = ИоП_ВидОперации_ПодготовкаИзвещений();
	ТекстСообщения = НСтр("ru = 'Не удалось сформировать извещение о получении'");
	
	ДопИнформация = Новый Массив;
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("BoxId: %1", BoxId));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("MessageId: %1", MessageId));
	ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("EntityId: %1", EntityId));
	
	Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
	
КонецПроцедуры


