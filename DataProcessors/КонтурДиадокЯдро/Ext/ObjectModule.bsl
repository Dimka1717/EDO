// Определяет возможность выполнения сбора метрик
// с учетом их принудительного отключения на сервере.
// 
// Возвращаемое значение:
//   - Булево - Истина, если сбор метрик можно выполнять.
//
Функция ИспользоватьМетрики()
	
	Результат = Ложь;
	
	Если Не МетрикиОтключены() Тогда
		Результат = ОбщийКонтекст_Прочитать("ИспользоватьМетрики") = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Определяет, не отключена ли принудительно возможность сбора метрик на сервере.
//
// 
// Возвращаемое значение:
//   - Булево - Истина, если сбор метрик отключен.
//
Функция МетрикиОтключены()
	
	Результат = Кэш_Прочитать("ОтключитьМетрики") = Истина;
	
	Возврат Результат;
	
КонецФункции

// Отключает принудительно возможность сбора метрик на сервере.
//
Процедура ОтключитьМетрики()
	
	Кэш_Поместить("ОтключитьМетрики", Истина);
	
КонецПроцедуры

//#КонецОбласти

//#Область Служебные_методы

// Добавляет событие в стек событий.
//
// Параметры:
//  Топик          - Строка    - топик, к которому относится событие.
//  СобытиеМетрики - Структура - см. функцию Метрика_НовыйСобытие()
//  TraceID        - Строка    - идентификатор трассировки
//  Переменные     - Структура - произвольная информация
//  ДобавитьСистемнуюИнформацию - Булево - Истина, если в метрику нужно
//                                         добавить описание окружения.
//
Процедура ЗарегистрироватьСобытиеМетрики(Топик, СобытиеМетрики
	, TraceID	 = Неопределено
	, Переменные = Неопределено
	, ДобавитьСистемнуюИнформацию = Ложь)
	
	ОписаниеПеременных = Неопределено;
	ОписаниеПриложения = Неопределено;
	
	Если ДобавитьСистемнуюИнформацию Тогда
		ОписаниеПриложения = ОписаниеПриложения();
	КонецЕсли;
	
	ДополнитьПеременныеМетрики_BaseId(Переменные);
	
	ОписаниеПеременных = ОписаниеПеременныхДляМетрики(Переменные);
	
	Метрика = НоваяМетрика(СобытиеМетрики, TraceID, ОписаниеПеременных, ОписаниеПриложения);
	
	РазмерСтека = ПоместитьСобытиеМетрикиВСтекСобытий(Топик, Метрика);
	
	Если РазмерСтека >= 100 Тогда
		Метрики_Отправить();
	КонецЕсли;
	
КонецПроцедуры

// Помещает событие в стек для дальнейшей отправки
//
// Параметры:
//  Топик   - Строка       - топик, к которому относится метрика.
//  Метрика - Соответствие - метрика с событием.
//
// Возвращаемое значение:
//   Число - общее количество событий, помещенных во все топики стека.
//
Функция ПоместитьСобытиеМетрикиВСтекСобытий(Топик, Метрика)
	
	СтекСобытий = СтекСобытийМетрики();
	
	Если Не СтекСобытий.Топики.Свойство(Топик) Тогда
		СтекСобытий.Топики.Вставить(Топик, Новый Массив);
		Кэш_Поместить("СтекСобытийМетрики", СтекСобытий);
	КонецЕсли;
	
	МассивСобытий = СтекСобытий.Топики[Топик];
	
	МассивСобытий.Добавить(Метрика);
	
	СтекСобытий.РазмерСтека = СтекСобытий.РазмерСтека + 1;
	
	Результат = СтекСобытий.РазмерСтека;
	
	Метрика_Логирование(Топик, Метрика);
	
	Возврат Результат;
	
КонецФункции 

Процедура Метрика_Логирование(Топик, Метрика)
	
	Метрика_КаталогЛогирования = Метрика_КаталогЛогирования();
	
	Если ЗначениеЗаполнено(Метрика_КаталогЛогирования) Тогда
	
		СоздатьКаталог(Метрика_КаталогЛогирования);
		ИмяФайлаЛога	 = Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0") + "_" + Топик + "_" + Метрика.Path.Action + ".json";
		ПутьКФайлуЛога	 = Метрика_КаталогЛогирования + ИмяФайлаЛога;
		
		ТД = Новый ТекстовыйДокумент;
		ТД.УстановитьТекст(ПарсерJSON_Записать(Метрика));
		ТД.Записать(ПутьКФайлуЛога);
	
	КонецЕсли;
	
КонецПроцедуры

Функция Метрика_КаталогЛогирования()
	
	Результат = ОбщийКонтекст_Прочитать("Метрика_КаталогЛогирования");
	
	Возврат Результат;
	
КонецФункции

