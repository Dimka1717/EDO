	Если ОсновнойМодуль <> Неопределено Тогда
		ПодключенныеОбработки_ДобавитьОписание("ОсновнойМодуль", ОсновнойМодуль);
	КонецЕсли;
	
КонецПроцедуры

// Добавляет в подключенные описание ядра
//
Процедура ПодключенныеОбработки_ДобавитьЯдро() Экспорт
	
	ПодключенныеОбработки_ДобавитьОписание("КонтурДиадокЯдро", ЭтотОбъект);
	
КонецПроцедуры

Процедура ПодключенныеОбработки_ДобавитьОписание(ИмяМодуля, ОбъектОбработки)
	
	ВозможныеИсточники = ПодключенныеОбработки_ВозможныеИсточникиБиблиотек();
	
	ОписаниеОбработки = ПодключенныеОбработки_Прочитать(ИмяМодуля);
	
	Если ОписаниеОбработки = Неопределено Тогда
		
		ОписаниеОбработки = НовоеОписаниеПодключеннойОбработки();
		ОписаниеОбработки.ИмяМодуля = ИмяМодуля;
		ОписаниеОбработки.Путь = ИмяМодуля;
		
	КонецЕсли;

	Если ОбъектОбработки <> Неопределено Тогда
		
		МетаданныеМодуля = ОбъектОбработки.Метаданные();
		ЗаполнитьЗначенияСвойств(ОписаниеОбработки, МетаданныеМодуля);
		
		Попытка
			СведенияОВнешнейОбработке = ОбъектОбработки.СведенияОВнешнейОбработке();
			Версия = СведенияОВнешнейОбработке.Версия;
		Исключение
			Версия = "null";
		КонецПопытки;
		
		ОписаниеОбработки.Версия = Версия;
		
		ЭтоОбработкаКонфигурации = Общее_ЭтоОбработкаКонфигурации(ОбъектОбработки);
		
		Если ЭтоОбработкаКонфигурации Тогда
			
			ОписаниеОбработки.ИсточникБиблиотеки = ВозможныеИсточники.Конфигурация;
			
		Иначе
			
			ИмяФайла = ОбъектОбработки.ИспользуемоеИмяФайла;
			ОписаниеОбработки.ИспользуемоеИмяФайла = ИмяФайла;
			ПодключатьИзФайла = ПодключенныеОбработки_ПодключатьИзФайла(ИмяФайла);
				
			Если ПодключатьИзФайла Тогда
				
				ОписаниеОбработки.ИсточникБиблиотеки = ВозможныеИсточники.Файл;
				ОписаниеОбработки.Путь = ИмяФайла;
				ОписаниеОбработки.ВремяИзменения = ВремяИзмененияФайла(ИмяФайла);
				
			Иначе
				ОписаниеОбработки.ИсточникБиблиотеки = ВозможныеИсточники.Макет;	
			КонецЕсли;
       		
		КонецЕсли;
		
	КонецЕсли;
	
	ПодключенныеОбработки_Поместить(ИмяМодуля, ОписаниеОбработки);
	
КонецПроцедуры

Функция ПодключенныеОбработки_ПодключатьИзФайла(ИмяФайла)
	
	Результат = Ложь;
	
	Если РежимОтладкиВключен() Тогда
		
		ЭтоИмяФайла = Общее_ЭтоИмяФайла(ИмяФайла);
		
		Если ЭтоИмяФайла Тогда
			Результат = ФайлСуществует(ИмяФайла);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПодключенныеОбработки_Поместить(ИмяМодуля, ОписаниеОбработки)
	
	ПодключенныеОбработки = ОписанияПодключенныхОбработок();
	
	ПодключенныеОбработки.Вставить(ИмяМодуля, ОписаниеОбработки);
	
КонецПроцедуры

Функция ПодключенныеОбработки_Прочитать(ИмяМодуля)
	
	Результат = Неопределено;
	
	ПодключенныеОбработки = ОписанияПодключенныхОбработок();
	
	Результат = ПодключенныеОбработки[ИмяМодуля];
	
	Возврат Результат;
	
КонецФункции

// Получает коллекцию подключенных обработок из общего контекста.
// 
// Возвращаемое значение:
//  Соответствие - подключенные обработки:
//   * <ИмяОбработки> - Структура - см. НовоеОписаниеПодключеннойОбработки
//
Функция ОписанияПодключенныхОбработок()
	
	Результат = СвойствоСтруктуры(ОбщийКонтекстКлиентСервер, "ПодключенныеОбработки");
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		
		Результат = Новый Соответствие;
		ОбщийКонтекст_Поместить("ПодключенныеОбработки", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

