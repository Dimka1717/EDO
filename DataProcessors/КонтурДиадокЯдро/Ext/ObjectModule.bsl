//#Область Служебный_интерфейс_метрики

// Отправляет стек событий в сервис Контур.Метрика
//
// Параметры:
//  СтекСобытий                    - Структура - см. функцию НовыйСтекСобытийМетрики();
//  СформироватьОписанияПеременных - Булево - Истина, если необходимо сформировать
//                                            описание переменных в событиях стека;
//
// Возвращаемое значение:
//   Булево - Истина, если удалось отправить все события стека.
//
Функция Метрика_ОтправитьСтекСобытий(СтекСобытий, СформироватьОписанияПеременных) Экспорт
	
	Результат = Ложь;
	
	Если Не МетрикиОтключены() Тогда
		
		ДобавитьИдентификаторыВСобытияМетрики(СтекСобытий);
		
		Если СформироватьОписанияПеременных Тогда
			СформироватьОписанияПеременныхВСобытияхМетрики(СтекСобытий);
		КонецЕсли;
		
		Результат = ОтправитьСтекСобытийМетрики(СтекСобытий);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//#КонецОбласти

//#Область Регистрация_статистики

// Добавляет запись в DD_Statistics с категорией, действием, меткой и представлением.
//
// Параметры:
//  Категория - Строка - идентификатор категории ошибки
//  Действие - Строка - идентификатор действия
//  Метка - Строка - заголовок или название;
//  ДопПеременные - Структура, Соответствие - (Необязательный) значения дополнительных переменных
//  ПредставлениеМетрики - Строка - форма, интерфейс события;
//  TraceID    - Строка         - локальный идентификатор группы событий;
//             - Неопределено   - использовать общий идентификатор группы событий,
//                                см функцию TraceId();
//
Процедура Метрика_ДобавитьСтатистику(
		Категория,
		Действие,
		Метка = Неопределено,
		ДопПеременные = Неопределено,
		ПредставлениеМетрики = "",
		TraceId = "") Экспорт
	
	Если НЕ ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ПеременныеМетрики = Новый Соответствие;
	
	ДополнитьПеременныеМетрики_BaseId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_BoxId(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ТиповойМодуль(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ПроизвольныеПараметры(ПеременныеМетрики, ДопПеременные);
	
	ДобавитьСисИнфо = Истина;
	
	Метрика_ЗаписатьСтатистику(
		Категория,
		Действие,
		Метка,
		ПеременныеМетрики,
		ДобавитьСисИнфо,
		TraceId,
		ПредставлениеМетрики);
	
КонецПроцедуры


// Отправляет статистику авторизации
//
Процедура Метрика_ДобавитьСтатистику_Авторизации() Экспорт
	
	Если НЕ ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Контекст = КонтекстСеанса_СтрокиКонтекста();
	Если НЕ ЗначениеЗаполнено(Контекст) Тогда
		Возврат;
	КонецЕсли;
	
	Переменные = Новый Соответствие;
	
	// Общий контекст
	Переменные.Вставить("Ключ разработчика", ОбщийКонтекст_Прочитать("КлючРазработчика"));
	Переменные.Вставить("Режим отладки", ОбщийКонтекст_Прочитать("РежимОтладки"));
	Переменные.Вставить("BaseID", Строка(_ИдентификаторИнформационнойБазыДиадок()));
	Переменные.Вставить("KonturBaseID", Строка(_ИдентификаторИнформационнойБазыКонтур()));
	Переменные.Вставить("ТиповойМодуль", Метрика_ЗначениеПеременнойТиповойМодуль());
	Переменные.Вставить("ИспользоватьПродуктовуюАналитику", ИспользоватьПродуктовуюАналитику());
	Переменные.Вставить("Configuration_CompatibilityMode", ВерсияРежимаСовместимостиЛок());
	
	// Контекст сеанса
	Сводка = Метрика_СводнаяИнформацияКонтекстаСеанса();
	Для Каждого КлючЗначение Из Сводка Цикл
		
		ЗначениеПараметра = КлючЗначение.Значение;
		Если ТипЗнч(ЗначениеПараметра) = Тип("Булево") Тогда
			// чтобы отправить в каноничном виде - "true"/"false"
			ЗначениеПараметра = XMLСтрока(ЗначениеПараметра);
		КонецЕсли;
		
		Переменные.Вставить(КлючЗначение.Ключ, ЗначениеПараметра);
		
	КонецЦикла;
	
	ОбщиеНастройки = ОбщиеНастройки_ЗначенияНастроек();
	// BSLLS:LineLength-off
	// Общие настройки: системные
	Переменные.Вставить("Режим логирования", СвойствоСтруктуры(ОбщиеНастройки, "РежимЛогирования"));
	Переменные.Вставить("Использовать типовые объекты 1С", СвойствоСтруктуры(ОбщиеНастройки, "ИспользоватьТиповуюПодсистему1С"));
	Переменные.Вставить("УведомлятьОНовыхСобытиях", СвойствоСтруктуры(ОбщиеНастройки, "УведомлятьОНовыхСобытиях"));
	Переменные.Вставить("Режим прокси", СвойствоСтруктуры(ОбщиеНастройки, "РежимПрокси"));
	Переменные.Вставить("ИспользоватьВнешнийHTTP", ЗначениеНастройки_ИспользоватьВнешнийHTTP());
	Переменные.Вставить("ТранспортHTTP", ЗначениеНастройки_ТранспортHTTP());
	Переменные.Вставить("Интеграционный модуль", СвойствоСтруктуры(ОбщиеНастройки, "ИмяИнтеграционногоМодуля"));
	Переменные.Вставить("Автообновление модуля", СвойствоСтруктуры(ОбщиеНастройки, "АвтоматическиОбновлятьМодуль"));
	Переменные.Вставить("Разрешить фоновые операции", СвойствоСтруктуры(ОбщиеНастройки, "РазрешитьДлительныеОперацииВФоне"));
	Переменные.Вставить("Отключить контроль дублирования", СвойствоСтруктуры(ОбщиеНастройки, "ОтключитьКонтрольДублированияОтправкиПакетов"));
	Переменные.Вставить("Отключить превью неформализованного", СвойствоСтруктуры(ОбщиеНастройки, "ОтключитьПревьюНеформализованного"));
