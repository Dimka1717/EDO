Процедура Организации_ВыполнитьСинхронизацию(ТекущаяОрганизация, Organization)
	
	ОбновлениеОрганизации = Организации_НоваяОрганизацияЭДО(Organization);
	
	ЗаполнитьЗначенияСвойств(ТекущаяОрганизация, ОбновлениеОрганизации, "ID, OrgId, ИНН, КПП, Наименование, ИдентификаторУчастникаЭДО");
	ХранениеДанных_ЗаписатьОрганизацию(ТекущаяОрганизация);
	
	Подразделения_ВыполнитьСинхронизацию(Organization.Organization, ТекущаяОрганизация);
	
