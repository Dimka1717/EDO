// 
// Возвращаемое значение:
//  Булево - Истина - требуется МЧД, ложь - нет
//
Функция МЧД_ТребуетсяДоверенность(BoxId) Экспорт
	
	ТребуетсяМЧД = КонтекстСеанса_Прочитать(BoxId, "ТребуетсяМЧД", Ложь);
	
