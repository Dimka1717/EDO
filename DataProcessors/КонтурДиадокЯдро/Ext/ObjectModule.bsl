// Получает тэги документа
//
// Параметры:
//  ИдентификаторыДокумента	 - 	Структура - см. Контракт_Идентификаторы()
// 
// Возвращаемое значение:
//  Соответствие - где "Ключ" - имя тэга, "Значение" - его значение
//
Функция Документы_ПолучитьТэги(ИдентификаторыДокумента) Экспорт
	
	Результат = Новый Соответствие;
	
	BoxId = ИдентификаторыДокумента.BoxId;
	LetterId = ИдентификаторыДокумента.LetterId;
	DocumentId = ИдентификаторыДокумента.DocumentId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	Попытка
		Document = АПИ_GetDocument(ПараметрыСервиса, BoxId, LetterId, DocumentId);
	Исключение
		
		ВидОперации		 = "Получение тэгов документа";
		ТекстСообщения	 = "Не удалось получить тэги документа";
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ДопИнформация = Новый Массив;
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("BoxId: %1", BoxId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("LetterId: %1", LetterId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("DocumentId: %1", DocumentId));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Возврат Результат;
		
	КонецПопытки;
	
	Для Каждого CustomData Из Document.CustomData Цикл
		Результат.Вставить(CustomData.Key, CustomData.Value);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Добавляет или изменяет тэги документа
//
// Параметры:
//  ИдентификаторыДокумента	 - 	Структура - см. Контракт_Идентификаторы()
//  Тэги					 - 	Соответствие - где "Ключ" - имя тэга, "Значение" - его значение
// 
// Возвращаемое значение:
//  Булево - признак успешного добавления тэгов
//
Функция Документы_ДобавитьТэги(ИдентификаторыДокумента, Тэги) Экспорт
	
	Результат = Ложь;
	
	BoxId = ИдентификаторыДокумента.BoxId;
	LetterId = ИдентификаторыДокумента.LetterId;
	DocumentId = ИдентификаторыДокумента.DocumentId;
	
	МассивТэгов = Новый Массив; // для вывода в журнал, если возникнет ошибка
	CustomDataPatches = Новый Массив;
	Для Каждого Тэг Из Тэги Цикл
		
		CustomDataPatch = АПИ_Новый_CustomDataPatch(DocumentId, 0, Тэг.Ключ, Тэг.Значение);
		CustomDataPatches.Добавить(CustomDataPatch);
		
		МассивТэгов.Добавить(Общее_ПодставитьПараметрыВСтроку("%1: %2", Тэг.Ключ, Тэг.Значение));
		
	КонецЦикла;
	
	Попытка
		РезультатДобавления = РезультатPostMessagePatch(ИдентификаторыДокумента,
			Новый Структура("CustomDataPatches", CustomDataPatches));
	Исключение
		
		ВидОперации		 = "Добавление/изменение тэгов документа";
		ТекстСообщения	 = "Не удалось добавить/изменить тэги документа";
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ДопИнформация = Новый Массив;
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("BoxId: %1", BoxId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("LetterId: %1", LetterId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("DocumentId: %1", DocumentId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Тэги: %1", СоединитьСтроку(МассивТэгов, ",")));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Возврат Результат;
		
	КонецПопытки;
	
	Если ЗначениеЗаполнено(РезультатДобавления) Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Удаляет тэги документа
//
// Параметры:
//  ИдентификаторыДокумента	 - 	Структура - см. Контракт_Идентификаторы()
//  Ключи					 - 	Массив - элементами массива являются имена тэгов строкового типа
// 
// Возвращаемое значение:
//  Булево - признак успешного удаления тэгов
//
Функция Документы_УдалитьТэги(ИдентификаторыДокумента, Ключи) Экспорт
	
	Результат = Ложь;
	
	BoxId = ИдентификаторыДокумента.BoxId;
	LetterId = ИдентификаторыДокумента.LetterId;
	DocumentId = ИдентификаторыДокумента.DocumentId;
	
	CustomDataPatches = Новый Массив;
	Для Каждого Ключ Из Ключи Цикл
		CustomDataPatch = АПИ_Новый_CustomDataPatch(DocumentId, 1, Ключ);
		CustomDataPatches.Добавить(CustomDataPatch);
	КонецЦикла;
	
	Попытка
		РезультатУдаления = РезультатPostMessagePatch(ИдентификаторыДокумента,
			Новый Структура("CustomDataPatches", CustomDataPatches));
	Исключение
		
		ВидОперации		 = "Удаление тэгов документа";
		ТекстСообщения	 = "Не удалось удалить тэги документа";
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ДопИнформация = Новый Массив;
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("BoxId: %1", BoxId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("LetterId: %1", LetterId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("DocumentId: %1", DocumentId));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Тэги: %1", СоединитьСтроку(Ключи, ",")));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Возврат Результат;
		
	КонецПопытки;
	
	Если ЗначениеЗаполнено(РезультатУдаления) Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


