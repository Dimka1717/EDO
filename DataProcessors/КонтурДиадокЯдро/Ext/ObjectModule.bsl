// Возвращает сведения о последнем выгруженном в сервис ПМ указанного типа
//
// Параметры:
//  ИдентификаторИБ	 - Строка - см. ОбщийКонтекст_ИдентификаторБазы1С
//  ТипМодуляAPI	 - Строка - см. АПИ_Перечисление_ТипыПМ
// 
// Возвращаемое значение:
//  Структура - сведения о последнем выгруженном ПМ (см. МодульAPI.Plugins_ПолучитьСведения)
//
Функция АПИ_УправлениеПМ_ОписаниеПоследнегоПМ(ИдентификаторИБ, ТипМодуляAPI)

	Результат = Неопределено;
	
	ПараметрыСервиса = ПараметрыСервиса_СервисУправленияПМ();
	
	Количество = 1;
	
	МетодыAPI 	= Модуль_МетодыAPI(ЭтотОбъект);
	ТелоОтвета 	= МетодыAPI.Plugins_ПолучитьСведения(ПараметрыСервиса, ИдентификаторИБ, ТипМодуляAPI, Количество);
	
	РезультатЗапроса = ПарсерJSON_Прочитать(ТелоОтвета);
	
	СписокПлагинов = СвойствоСтруктуры(РезультатЗапроса, "plugins", Новый Массив);
	Если СписокПлагинов.Количество() > 0 Тогда
		Результат = СписокПлагинов[0];
		АПИ_УправлениеПМ_ПреобразоватьСтроковыеЗначенияДаты(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает сведения о ПМ обновления из сервиса по указанному типу и хэш-сумме файла
//
// Параметры:
//  ИдентификаторИБ	 		- Строка - см. ОбщийКонтекст_ИдентификаторБазы1С
//  ТипМодуляAPI	 		- Строка - см. АПИ_Перечисление_ТипыПМ
//  ХэшСуммаФайлаРодителя	- Строка - хэш-сумма текущего подключенного ПМ (УМ, Стандарт)
// 
// Возвращаемое значение:
//  Структура - сведения о ПМ (см. МодульAPI.Plugins_ПолучитьСведения)
//
Функция АПИ_УправлениеПМ_ОписаниеФайлаОбновления(ИдентификаторИБ, ТипМодуляAPI, ХэшСуммаФайлаРодителя)

	Результат = Неопределено;
	
	ПараметрыСервиса = ПараметрыСервиса_СервисУправленияПМ();
	
	МетодыAPI 	= Модуль_МетодыAPI(ЭтотОбъект);
	ТелоОтвета 	= МетодыAPI.Plugins_ПолучитьОбновление(ПараметрыСервиса, ИдентификаторИБ, ТипМодуляAPI, НРег(ХэшСуммаФайлаРодителя));
	
	РезультатЗапроса = ПарсерJSON_Прочитать(ТелоОтвета);
	
	СписокПлагинов = СвойствоСтруктуры(РезультатЗапроса, "plugins", Новый Массив);
	Если СписокПлагинов.Количество() > 0 Тогда
		Результат = СписокПлагинов[0];
		АПИ_УправлениеПМ_ПреобразоватьСтроковыеЗначенияДаты(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
