//  ТипМодуляAPI	 - Строка - см. АПИ_Перечисление_ТипыПМ
//  ИдентификаторПМ	 - Строка - идентификатор ПМ в сервисе
// 
// Возвращаемое значение:
//  ДвоичныеДанные, Неопределено - файл ПМ
//
Функция АПИ_УправлениеПМ_ЗагрузитьФайлОбновления(ИдентификаторИБ, ТипМодуляAPI, ИдентификаторПМ)

	Результат = Неопределено;
	
	ПараметрыСервиса = ПараметрыСервиса_СервисУправленияПМ();
	
	МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	Результат = МетодыAPI.Plugins_ЗагрузитьФайл(ПараметрыСервиса, ИдентификаторИБ, ИдентификаторПМ);
	
