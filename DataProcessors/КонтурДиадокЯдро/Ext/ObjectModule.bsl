// Сохраняет переданные настройки прокси в ИБ
//
// Параметры:
//	Настройки - Структура - см. метод "АПИ_Новый_НастройкиПрокси"
//
Функция ОбщиеНастройки_СохранитьНастройкиПрокси(Знач Настройки) Экспорт
	
	ОбщиеНастройки = ОбщиеНастройки_ЗначенияНастроек();
	
	ОбщиеНастройки.РежимПрокси 			= Настройки.РежимПрокси;
	ОбщиеНастройки.АдресПроксиСервера 	= Настройки.АдресПроксиСервера;
	ОбщиеНастройки.ЛогинПроксиСервера 	= Настройки.ЛогинПроксиСервера;
	ОбщиеНастройки.ПарольПроксиСервера 	= Настройки.ПарольПроксиСервера;
	ОбщиеНастройки.ПортПроксиСервера 	= Настройки.ПортПроксиСервера;
	
	Результат = ОбщиеНастройки_ЗаписатьНастройки(ОбщиеНастройки);
	
