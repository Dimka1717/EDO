// 
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные    - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
// 
Процедура Метрика_ДобавитьЗамер_ДляОрганизации(BoxId, КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные = Неопределено)

	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если ЭтоНачалоЗамера Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	Переменные = Новый Соответствие;
	
	Если ЗначениеЗаполнено(BoxId) Тогда
		Переменные.Вставить("BoxID",	АдресЯщикаВИдентификатор(BoxId));
	КонецЕсли;
	
	Если ДопПеременные <> Неопределено Тогда
		Для каждого Переменная Из ДопПеременные Цикл
			Переменные.Вставить(Переменная.Ключ, Переменная.Значение);			
		КонецЦикла; 
	КонецЕсли;
	
	Метрика_ЗаписатьЗамер(КатегорияМетрики, Действие, , , Переменные);

КонецПроцедуры

// Вызывает процедуру записи замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//  ЗамерОднойЗаписью - Булево - Определяет способ записи замера по контексту.
//     * Истина - Одна запись замера для всего контекста;
//     * Ложь   - Запись замера для каждого элемента контекста.
//
Процедура Метрика_ДобавитьЗамер_СУчетомЗаполненияКонтекста(КатегорияМетрики, ЭтоНачалоЗамера = Истина, ДопПеременные = Неопределено, ЗамерОднойЗаписью = Истина) Экспорт

	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		
		Если ЗамерОднойЗаписью Тогда
			Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
		Иначе
			Метрика_ДобавитьЗамер_ПоКонтексту(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
		КонецЕсли;
		
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;

КонецПроцедуры

// Вызывает процедуру записи начала замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики  - Строка - Наименование категории замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
Процедура Метрика_НачатьЗамер_СУчетомЗаполненияКонтекстаПоКонтекстуОднойЗаписью(КатегорияМетрики, ДопПеременные = Неопределено) Экспорт
	
	ЭтоНачалоЗамера = Истина;
	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;
	
КонецПроцедуры

// Вызывает процедуру записи окончания замера в зависимомсти от наполнения контекста.
//
// Параметры:
//  КатегорияМетрики  - Строка - Наименование категории замера.
//  ДопПеременные     - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
Процедура Метрика_ЗавершитьЗамер_СУчетомЗаполненияКонтекстаПоКонтекстуОднойЗаписью(КатегорияМетрики, ДопПеременные = Неопределено) Экспорт
	
	ЭтоНачалоЗамера = Ложь;
	КонтекстСеансаЗаполнен = КонтекстСеанса_ЕстьСтроки();
	
	Если КонтекстСеансаЗаполнен Тогда
		Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	Иначе
		Метрика_ДобавитьЗамер_ДляОрганизации("", КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные);
	КонецЕсли;
	
КонецПроцедуры

// Вызывает функцию записи начала замера группового сопоставления контрагентов
//
// Возвращаемое значение:
//   Структура  - см. возврат Функции НачатьЗамерДлительнойОперации(КлючеваяОперация, Действие = "") Экспорт
//
Функция Метрика_НачатьЗамер_ГрупповоеСопоставлениеКонтрагентов()
		
	НазваниеКатегорий = Метрика_НазваниеКатегории();
	
	КатегорияМетрики = НазваниеКатегорий.ДействияВСпискеКонтрагентов;
	
	ДействиеМетрики = Метрика_НазваниеДействий().ГрупповоеСопоставление;
	
	ОписаниеЗамера = НачатьЗамерДлительнойОперации(КатегорияМетрики, ДействиеМетрики);
	
	Возврат ОписаниеЗамера;

КонецФункции

// Вызывает процедуру завершения замера группового сопоставления контрагентов
//
// Параметры:
//  ОписаниеЗамера  - Структура - см. Новый_ОписаниеЗамера()
//  РезультатСопоставления - Структура - см Новый_РезультатГрупповогоСопоставления().
//  BoxId - Строка - BoxIв Организации по которой происходит сопоставление.
//
Процедура Метрика_ЗавершитьЗамер_ГрупповоеСопоставлениеКонтрагентов(ОписаниеЗамера, РезультатСопоставления, BoxId)
	
	НазваниеКатегорий = Метрика_НазваниеКатегории();
	
	КатегорияМетрики = НазваниеКатегорий.ДействияВСпискеКонтрагентов;
	
	ПеременныеМетрики = Новый Структура;
	ПеременныеМетрики.Вставить("КоличествоКА1С", РезультатСопоставления.КоличествоСопоставляемых);
	ПеременныеМетрики.Вставить("КоличествоСопоставленных", РезультатСопоставления.КоличествоСопоставленных);
	ПеременныеМетрики.Вставить("BoxId", BoxId);
	
	ЗакончитьЗамердлительнойОперации(ОписаниеЗамера, КатегорияМетрики, ПеременныеМетрики);
	
КонецПроцедуры

// Вызывает процедуру добавления замера чтение ленты контрагентов
//
// Параметры:
//  ВремяНачалаЗамера - Дата - Время начала замера
//  ИдентификаторЯщика - Строка - BoxId
//  КоличествоНовыхСобытий - Число - количество событий для пользователя новых.
//  КоличествоСобытийВсего - Число - количество всех событий прочитанных.
//  КоличествоРекомендаций - Число - количество рекомендуемых действий по собятиям.
//
Процедура Метрика_ДобавитьЗамер_ЧтениеЛентыКонтрагентов(
		ВремяНачалаЗамера,
		ИдентификаторЯщика,
		КоличествоНовыхСобытий,
		КоличествоСобытийВсего,
		КоличествоРекомендаций)
		
	ВремяОкончанияЗамера = ТекущаяУниверсальнаяДата();
	ВремяВыполненияОперации = ВремяОкончанияЗамера - ВремяНачалаЗамера;
	
	НазваниеКатегорий = Метрика_НазваниеКатегории();
	НазваниеДействий = Метрика_НазваниеДействий();
	
	КатегорияМетрики = НазваниеКатегорий.ЛентаКонтрагентов;
	ДействиеМетрики = НазваниеДействий.ЧтениеЛенты;
	Представление = Неопределено;
	Метка = Неопределено;
	
	ПеременныеМетрики = Новый Структура;
	ПеременныеМетрики.Вставить("ДатаНачалаКлючевойОперации", ВремяНачалаЗамера);
	ПеременныеМетрики.Вставить("ДатаОкончанияКлючевойОперации", ВремяОкончанияЗамера);
	ПеременныеМетрики.Вставить("Длительность", ВремяВыполненияОперации);
	ПеременныеМетрики.Вставить("КоличествоНовыхСобытий", КоличествоНовыхСобытий);
	ПеременныеМетрики.Вставить("КоличествоСобытийВсего", КоличествоСобытийВсего);
	ПеременныеМетрики.Вставить("КоличествоРекомендаций", КоличествоРекомендаций);
	ПеременныеМетрики.Вставить("BoxId", ИдентификаторЯщика);
	
	Метрика_ЗаписатьЗамер(
		КатегорияМетрики, 
		ДействиеМетрики, 
		Представление, 
		Метка, 
		ПеременныеМетрики);
	
КонецПроцедуры


Процедура Метрика_ДобавитьЗамер_СборДанныхДляОбновленияМодуля(МоментНачалаЗамера, КонтекстВыполнения) Экспорт
	
	ВремяВыполнения = ( ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаЗамера ) / 1000;
	
	BaseID = ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Категория = Метрика_НазваниеКатегории().АвтообновлениеМодуляУМ;
	Действие = "СборДанных" + КонтекстВыполнения;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BaseID", BaseID);
	Переменные.Вставить(Действие, ВремяВыполнения);
		
	Метрика_ЗаписатьЗамер(Категория, Действие, , , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьЗамер_ОбновлениеМодуля(МоментНачалаЗамера, РезультатОбновления, ДанныеДляОбновленияМодуля) Экспорт
	
	ВремяВыполнения = ( ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаЗамера ) / 1000;
    
	Категория = Метрика_НазваниеКатегории().АвтообновлениеМодуляУМ;
	Действие = "Обновление";
	
	Переменные = Метрика_ОбщиеПеременныеАвтообновленияМодуля(РезультатОбновления, ДанныеДляОбновленияМодуля);
	Метрика_ДополнитьПеременныеАвтообновленияМодуляОписаниямиОшибок(Переменные, ДанныеДляОбновленияМодуля);
	Переменные.Вставить(Действие, ВремяВыполнения);
		
	Метрика_ЗаписатьЗамер(Категория, Действие, , , Переменные);
	
КонецПроцедуры

Процедура Метрика_ДобавитьЗамер_ПолучениеОписанияПоследнегоПМвСервисе(МоментНачалаЗамера, ОписаниеПМ)
	
	РезультатСобытия = "Success";
	
