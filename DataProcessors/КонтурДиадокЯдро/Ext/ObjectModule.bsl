Функция Новый_НастройкиПечатныхФорм() Экспорт 
	
	Результат = Новый Структура;
	Результат.Вставить("ОсновнаяПечатнаяФорма");
	Результат.Вставить("ДополнительныеПечатныеФормы", Новый Массив);
	
	Возврат Результат;
	
КонецФункции

Процедура НастройкиПечатныхФорм_Записать(НастройкиПечатныхФорм, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт 
	
	Модуль_ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	Модуль_ХранениеДанных.НастройкиПечатныхФорм_Записать(НастройкиПечатныхФорм, ДанныеОрганизации, ДанныеКонтрагента);
		
	Кэш_Поместить("НастройкиПечатныхФорм", Неопределено);
	
КонецПроцедуры

// Считывает из базы настройки печатных форм для вида документа по указанной организации и/или контрагенту.
// Настройки считываются из кэша. Если в кэше нет настроек, то настройки читаются из базы данных и сохраняются в кэш.
//
// Параметры:
//  ВидДокумента		 - 	Строка - Идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//  ДанныеОрганизации	 - 	Структура - см. функцию Контракт_ОрганизацияЭДО()
//  ДанныеКонтрагента	 - 	Структура - см. функцию Контракт_КонтрагентЭДО()
// 
// Возвращаемое значение:
//  Структура - см. функцию Новый_НастройкиПечатныхФорм()
//
Функция НастройкиПечатныхФорм_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт 
	
	Результат = НастройкиПечатныхФорм_ДанныеКэша(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	
	Если Результат = Неопределено Тогда
		
		ИдентификаторыВидовДокументов = Новый Массив;
		ИдентификаторыВидовДокументов.Добавить(ВидДокумента);
		
		НастройкиПоВидамДокументов = ХранениеДанных_НастройкиПФпоВидамДокументов(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
		
		Результат = НастройкиПоВидамДокументов.Получить(ВидДокумента);
		
		НастройкиПечатныхФорм_УстановитьКэш(Результат, ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура НастройкиПечатныхФорм_УстановитьКэш(НастройкиПечатныхФорм, ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	Кэш = Кэш_Прочитать("НастройкиПечатныхФорм");
	Если Кэш = Неопределено Тогда
		Кэш = Новый Соответствие;
	КонецЕсли;
	
	Ключ = НастройкиПечатныхФорм_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Кэш.Вставить(Ключ, НастройкиПечатныхФорм);
	Кэш_Поместить("НастройкиПечатныхФорм", Кэш);
	
КонецПроцедуры

Функция НастройкиПечатныхФорм_ДанныеКэша(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	Результат = Неопределено;
	
	Кэш = Кэш_Прочитать("НастройкиПечатныхФорм");
	Если Кэш = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Ключ = НастройкиПечатныхФорм_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Результат = Кэш.Получить(Ключ);
	
	Возврат Результат;
	
КонецФункции

Функция НастройкиПечатныхФорм_КлючНастроек(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	IdКонтрагента = "";
	Если ДанныеКонтрагента <> Неопределено Тогда
		IdКонтрагента = ДанныеКонтрагента.ID;
	КонецЕсли;
	
	Результат = ДанныеОрганизации.ID + "_" + IdКонтрагента + "_" + ВидДокумента;
	Возврат Результат;
	
КонецФункции

