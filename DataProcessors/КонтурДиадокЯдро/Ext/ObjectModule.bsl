// Заполняет контекст сеанса данными из сервиса Диадок.
//
// Параметры:
//  Настройки         - Структура - TODO: Описать Настройки
//  ТекущиеСоединения - Структура - TODO: Описать ТекущиеСоединения
//  КлиентскиеСертификаты - Соответствие - (Необязательный) сертификаты, доступные пользователю
//    * Ключ - Строка - отпечаток сертификата (в нижнем регистре)
//    * Значение - ФиксированнаяСтруктура - Описание сертификата (см. Сертификаты_ОписаниеСертификата)
//
// Возвращаемое значение:
//  Соответствие - параметры ящиков, в которых авторизован текущий пользователь:
//    * Ключ - Строка - идентификатор ящика (в формате GUID)
//    * Значение - ФиксированнаяСтруктура - см. МодельСтрокаКонтекстаСеанса
//
Функция КонтекстСеанса_Заполнить(Настройки, ТекущиеСоединения, Знач КлиентскиеСертификаты = Неопределено)
	
	КонтекстСеанса_Очистить();
	МЧД_УдалитьКонтекстДляГрупповыхДействий();
	
	НовыйКонтекст = СоздатьКонтекстСеанса(Настройки, ТекущиеСоединения, КлиентскиеСертификаты);
	
	ХранилищеКонтекстаСеанса_Установить(НовыйКонтекст);
	
	Результат = ЗначениеЗаполнено(НовыйКонтекст);
	
	КэшКонтекстаСеанса_ЗаполнитьПоКонтексту(НовыйКонтекст);
	
	Возврат Результат;
	
КонецФункции

// Возвращает значение поля из строки контекста сеанса
// по указанному идентификатору ящика Диадока.
//
// Параметры:
//  BoxId              - Строка - Идентификатор ящика Диадока;
//  ИмяПоля            - Строка - Имя поля строки контекста, значение которого нужно вернуть;
//  ВызыватьИсключение - Булево - Истина, если необходимо вызвать исключение
//                                при остутствии строки по указанному BoxId.
// 
// Возвращаемое значение:
//   - Произвольное - Значение из строки контекста.
//
Функция КонтекстСеанса_Прочитать(BoxId, ИмяПоля, ВызыватьИсключение = Истина) Экспорт
	
	Результат = Неопределено;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, ВызыватьИсключение);
	
	Если СтрокаКонтекста <> Неопределено Тогда
		
		Результат = СтрокаКонтекста[ИмяПоля];
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает из контекста сеанса параметры доступа в сервис Диадок
// по указанному идентификатору ящика Диадока, или токен служебной учетной записи,
// если по идентификатору ящика токен получить не удалось.
//
// Параметры:
//  BoxId - Строка - идентификатор ящика.
//
// Возвращаемое значение:
//   ФиксированнаяСтруктура - см. МодельСессияПользователя
//
Функция КонтекстСеанса_ТокенДоступа(Знач BoxId)
	
	ДополнительныеСекундыОграниченияЖизниТокена = 10800; // 3 часа дополнительно
	
	Сессия = КонтекстСеанса_Сессия(BoxId);
	
	Если ЗначениеЗаполнено(Сессия)
		И Сессия.СхемаАутентификации = СхемаАутентификацииПорталБраузер()
		И Сессия.УниверсальнаяДатаОкончания
		- ДополнительныеСекундыОграниченияЖизниТокена
		<= ТекущаяУниверсальнаяДата() Тогда
		
		ЗаписьЖурналаРегистрации(
			"Диадок.Авторизация",
			УровеньЖурналаРегистрации.Примечание,
			Метаданные(),
			BoxId,
			"Срок действия токена доступа истек"
		);
		
		КонтекстСеанса_ОбновитьТокенДоступа(BoxId);
		
		Сессия = КонтекстСеанса_Сессия(BoxId);
		
	КонецЕсли;
	
	Возврат Сессия;
	
КонецФункции

Функция КонтекстСеанса_Сессия(Знач BoxId)
	
	КлючСессия = "Сессия";
	ВызыватьИсключение = Ложь;
	
	Сессия = КонтекстСеанса_Прочитать(BoxId, КлючСессия, ВызыватьИсключение);
	
	Если НЕ ЗначениеЗаполнено(Сессия)
		И ЗначениеЗаполнено(BoxId) Тогда
		Сессия = КонтекстСеанса_Прочитать("", КлючСессия, ВызыватьИсключение);
	КонецЕсли;
	
	Возврат Сессия;
	
КонецФункции

Процедура КонтекстСеанса_ОбновитьТокенДоступа(Знач BoxId)
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		КонтекстСеансаСлужебный_ОбновитьТокенДоступа(BoxId);
		
		Метрика_ДобавитьЗамер(
			Метрики_КатегорияАвторизация(),
			Метрика_ДействиеОбновитьТокенДоступа(),
			НачалоЗамера);
		
		ЗаписьЖурналаРегистрации(
			"Диадок.Авторизация",
			УровеньЖурналаРегистрации.Примечание,
			Метаданные(),
			BoxId,
			"Токен доступа успешно обновлен");
		
	Исключение
		
		ОшибкаИнфо = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ОшибкаИнфо);
		
		Метрика_ДобавитьОшибку(
			Метрики_КатегорияАвторизация(),
			Метрика_ДействиеОбновитьТокенДоступа(),
			ОшибкаИнфо);
		
		КомментарийЖР = Общее_ПодставитьПараметрыВСтроку(
				"Не удалось обновить токен доступа по причине:
				|%1",
				ПодробноеПредставлениеОшибки);
		
		// BSLLS:UsageWriteLogEvent-off
		ЗаписьЖурналаРегистрации(
			"Диадок.Авторизация",
			УровеньЖурналаРегистрации.Предупреждение,
			Метаданные(),
			BoxId,
			КомментарийЖР);
		// BSLLS:UsageWriteLogEvent-on
		
	КонецПопытки;
	
КонецПроцедуры

Процедура КонтекстСеансаСлужебный_ОбновитьТокенДоступа(Знач BoxId)
	
	АутхПровайдер = АутхКонфигурацияПровайдера();
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	АутхПриложение = АутхКонфигурацияПриложения();
	УстановитьПривилегированныйРежим(Ложь);
	
	Аутх = Модуль_Аутентификатор(АутхПровайдер, АутхПриложение);
	ПортальнаяСессия = Аутх.ПолучитьСессию();
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, Истина);
	СтрокаКонтекста = КопияКоллекцииЗначений(СтрокаКонтекста);
	СтрокаКонтекста.Сессия = Новый_СессияПорталБраузер(АутхКлючНастройки(), ПортальнаяСессия);
	// Устаревшее поле строки контекста, для совместимости
	СтрокаКонтекста.Токен = ПортальнаяСессия.ТокенДоступа;
	
	КонтекстСеанса_ДобавитьСтроку(BoxId, СтрокаКонтекста);
	
КонецПроцедуры

// Возвращает строку контекста по указанному идентификатору ящика Диадока.
//
// Параметры:
//  BoxId              - Строка - Идентификатор ящика Диадока;
//  ВызыватьИсключение - Булево - Истина, если необходимо вызвать исключение
//                                при остутствии строки по указанному BoxId.
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельСтрокаКонтекстаСеанса
//
Функция КонтекстСеанса_СтрокаКонтекста(BoxId, ВызыватьИсключение = Истина) Экспорт
	
	Результат = Неопределено;
	
	АдресЯщика = ИдентификаторВАдресЯщика(BoxId);
	
	ХранилищеКонтекста = ХранилищеКонтекстаСеанса();
	
	Если ЗначениеЗаполнено(ХранилищеКонтекста) Тогда
		Результат = ХранилищеКонтекста.Получить(НРег(АдресЯщика));
	КонецЕсли;
	
	Если Результат = Неопределено И ВызыватьИсключение Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
					"ru = 'Нет данных организации из Диадока. Необходима авторизация в модуле Диадок:
					|1. Нажмите в верхнем правом углу на наименование сертификата.
					|2. В главном окне выбора организаций нажмите ""К авторизации"".
					|3. Далее нажмите ""Авторизоваться"" и ""Приступить к работе""'"), BoxId);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает строки контекста сеанса за исключением служебной строки,
// а также за исключением строк где требуется оплата сервиса.
//
// Параметры:
//  ДобавитьНеоплаченные - Булево - Истина, если строки где требуется оплата сервиса
//                                  нужно включить в результат.
// 
// Возвращаемое значение:
//   - Соответствие - см. описание СоздатьКонтекстСеанса()
//
Функция КонтекстСеанса_СтрокиКонтекста(ДобавитьНеоплаченные = Ложь) Экспорт
	
	Результат = Новый Соответствие;
	
	ХранилищеКонтекста = ХранилищеКонтекстаСеанса();
	
	Если ЗначениеЗаполнено(ХранилищеКонтекста) Тогда
		
		Для Каждого КлючИЗначение Из ХранилищеКонтекста Цикл
			
			СтрокаКонтекста = КлючИЗначение.Значение;
			
			ТребуетсяОплатаСервиса		 = СтрокаКонтекста.ТребуетсяОплатаСервиса;
			ЭтоСлужебнаяУчетнаяЗапись	 = Не ЗначениеЗаполнено(СтрокаКонтекста.BoxId);
			
			Если (Не ТребуетсяОплатаСервиса Или ДобавитьНеоплаченные) И Не ЭтоСлужебнаяУчетнаяЗапись Тогда
				
				Результат.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Очищает и записывает пустой контекст во временное хранилище.
//
Процедура КонтекстСеанса_Очистить() Экспорт
	
	НовыйКонтекст = ФиксированныеДанные(Новый Соответствие);
	
	ХранилищеКонтекстаСеанса_Установить(НовыйКонтекст);
	
	КэшКонтекстаСеанса_Очистить();
	
КонецПроцедуры

// Получает контекст сеанса из временного хранилища
// 
// Возвращаемое значение:
//  Соответствие
//
Функция ХранилищеКонтекстаСеанса() Экспорт
	
	АдресКонтекстаСеанса = ОбщийКонтекст_Прочитать("АдресКонтекстаСеанса");
	
	Результат = ВременноеХранилище_Прочитать(АдресКонтекстаСеанса);
	
	Если Результат = Неопределено Тогда
		Результат = Новый ФиксированноеСоответствие(Новый Соответствие);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Записывает новый контекст сеанса во временное хранилище
//
// Параметры:
//  НовыйКонтекст - Соответствие - см. функцию СоздатьКонтекстСеанса().
//
Процедура ХранилищеКонтекстаСеанса_Установить(НовыйКонтекст)
	
	АдресВХ = ОбщийКонтекст_Прочитать("АдресКонтекстаСеанса");
	
	ВременноеХранилище_Поместить(НовыйКонтекст, АдресВХ);
	
КонецПроцедуры

// Создает и заполняет новый контекст сеанса данными из сервиса Диадок.
//
// Параметры:
//  Настройки - Массив из Структура - содержит ключи:
//    * КлючСессии - Строка - строковое представление уникального идентификатора сессии
//    * BoxId - Строка - адрес ящика
//    * ОтпечатокСертификата - Строка - отпечаток сертификата (в нижнем регистре)
//  ТекущиеСоединения - ФиксированноеСоответствие - параметры соединений с сервисом:
//    * Ключ - Строка - строковое представление уникального идентификатора сессии (см. КлючСессии)
//    * Значение - ФиксированнаяСтруктура - описание соединения:
//        ** Токен - Строка - авторизационный токен (токен доступа)
//        ** ТипАвторизации - Строка - способ аутентификации (см. Перечисление_ТипыАвторизации)
//        ** ПользовательИдентификатор - Строка - строковое представление идентификатора пользователя сервиса
//  КлиентскиеСертификаты - ФиксированноеСоответствие - (Необязательный) сертификаты, доступные пользователю:
//    * Ключ - Строка - отпечаток сертификата (в нижнем регистре)
//    * Значение - Структура - описание сертификата (см. Сертификаты_ОписаниеСертификата) плюс его двоичка:
//        ** ДатаВыдачи - Дата - дата выдачи
//        ** ИНН - Строка - ИНН владельца
//        ** КПП - Строка - КПП владельца
//        ** Издатель - Строка - Наименование удостоверяющего центра
//        ** ОрганизацияИздателя - Строка - Наименование организации УЦ
//        ** Наименование - Строка - Представление сертификата
//        ** Организация - Строка - Наименование организации
//        ** СрокДействия - Дата - срок действия сертификата
//        ** Тип - Строка - тип сертификата (ФЛ/ЮЛ/...)
//        ** ЭтоКЭП - Булево - Истина, если это сертификат квалифицированной электронной подписи
//        ** Base64 - Строка - Двоичные данные сертификата в формате строки Base-64
// 
// Возвращаемое значение:
//  Соответствие - содержит элементы:
//   * Ключ - Строка - адрес ящика Диадока
//   * Значение - ФиксированнаяСтруктура - см. МодельСтрокаКонтекстаСеанса
//
Функция СоздатьКонтекстСеанса(Знач Настройки, Знач ТекущиеСоединения, Знач КлиентскиеСертификаты = Неопределено)
	
	Если Не ЗначениеЗаполнено(КлиентскиеСертификаты) Тогда
		КлиентскиеСертификаты = Новый Соответствие;
	КонецЕсли;
	
	СозданныеСтрокиКонтекста = Новый Массив;
	
	Для Каждого СтрокаНастройки Из Настройки Цикл
		
		BoxId = СтрокаНастройки.BoxId;
		Сессия = ТекущиеСоединения[СтрокаНастройки.КлючСессии];
		Сертификат = КлиентскиеСертификаты.Получить(СтрокаНастройки.ОтпечатокСертификата);
		
		Попытка
			
			СтрокаКонтекста = СоздатьСтрокуКонтекстаСеанса(BoxId, Сессия, Сертификат);
			
		Исключение
			
			ВидОперации		 = НСтр("ru = 'Заполнение строки контекста сеанса'");
			ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ДопИнформация	 = Общее_ПодставитьПараметрыВСтроку("BoxId: %1", BoxId);
			
			ТекстСообщения	 = НСтр("ru = 'Не удалось заполнить строку контекста сеанса организации ""%1""'");
			ТекстСообщения	 = Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, СтрокаНастройки.Наименование);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
			
			Продолжить;
			
		КонецПопытки;
		
		СозданныеСтрокиКонтекста.Добавить(СтрокаКонтекста);
		
	КонецЦикла;
	
	Данные = Новый Соответствие;
	
	Для Каждого СтрокаКонтекста Из СозданныеСтрокиКонтекста Цикл
		
		АдресЯщика = ИдентификаторВАдресЯщика(СтрокаКонтекста.BoxId);
		Данные.Вставить(АдресЯщика, СтрокаКонтекста);
		
	КонецЦикла;
	
	Результат = ФиксированныеДанные(Данные);
	
	Возврат Результат;
	
КонецФункции

// Создает и заполняет строку контекста сеанса данными из сервиса Диадок.
// Если идентификатор ящика не указан (для служебной учетной записи), то
// в строке контекста заполняются только сведения о сессии пользователя.
//
// Параметры:
//  ИдентификаторЯщика - Строка - Адрес или идентификатор ящика
//  Сессия - ФиксированнаяСтруктура - см. МодельСессияПользователя
//  Сертификат - Структура - (Необязательный) см. Сертификаты_ОписаниеСертификата плюс его двоичка
// 
// Возвращаемое значение:
//   ФиксированнаяСтруктура - см. МодельСтрокаКонтекстаСеанса
//
Функция СоздатьСтрокуКонтекстаСеанса(ИдентификаторЯщика, Сессия, Сертификат = Неопределено) Экспорт
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	ПараметрыСервиса = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	
	ЭтоСУЗ = Не ЗначениеЗаполнено(ИдентификаторЯщика); // вход под служебной учетной записью без указания ящика
	
	Если ЭтоСУЗ Тогда
		Ящик = МодельЯщикОрганизации();
	Иначе
		Box = АПИ_GetBox(ПараметрыСервиса, ИдентификаторЯщика);
		Ящик = Новый_ЯщикОрганизации(Box);
	КонецЕсли;
	
	Результат = МодельСтрокаКонтекстаСеанса();
	
	Результат.Сессия = Сессия;
	Результат.Ящик = Ящик;
	
	Результат.BoxId = Ящик.Адрес;
	
	// Для совместимости
	Результат.Токен = Сессия.ТокенДоступа;
	Если Сессия.СхемаАутентификации = СхемаАутентификацииПорталБраузер() Тогда
		ТипАвторизацииУстаревшее = ТипАвторизацииПорталБраузер();
	ИначеЕсли Сессия.СхемаАутентификации = СхемаАутентификацииДиадокСертификат() Тогда
		ТипАвторизацииУстаревшее = ТипАвторизацииДиадокСертификат();
	ИначеЕсли Сессия.СхемаАутентификации = СхемаАутентификацииДиадокПароль() Тогда
		ТипАвторизацииУстаревшее = ТипАвторизацииДиадокЛогин();
	Иначе
		ТипАвторизацииУстаревшее = "null";
	КонецЕсли;
	Результат.ТипАвторизации = ТипАвторизацииУстаревшее;
	
	Если Сессия.СхемаАутентификации = СхемаАутентификацииДиадокПароль() Тогда
		Результат.Логин = Сессия.Пользователь.Логин; // Для совместимости
	КонецЕсли;
	
	Если ЭтоСУЗ Тогда
		Результат = ФиксированныеДанные(Результат);
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сертификат) Тогда
		Результат.Сертификат = Сертификат;
		Результат.ОтпечатокСертификата = Сертификат.ОтпечатокСертификата;
	КонецЕсли;
	
	// Для совместимости
	Результат.Box = Box;
	Результат.ИНН = Ящик.Организация.ИНН;
	Результат.КПП = Ящик.Организация.КПП;
	Результат.ОрганизацияНаименование = Ящик.Наименование;
	Результат.OrgId = Ящик.Организация.Идентификатор;
	Результат.ЭтоТестоваяОрганизация = Ящик.Организация.Тестовая;
	Результат.ОрганизацияДиадок = Организации_НайтиСоздатьЭлемент(Box);
	
	КонтекстСеанса_ЗаполнитьИнформациюИзБиллинга(Результат, ПараметрыСервиса);
	
	Если НЕ Результат.ТребуетсяОплатаСервиса Тогда
		
		Если ЗначениеЗаполнено(Сертификат) Тогда
			
			Результат.МожноПодписыватьДокументы = Истина;
			СертификатBase64 = Сертификат.Base64;
			
			ПроверитьРегистрациюФНС = Ящик.Организация.Реальная;
			Если ПроверитьРегистрациюФНС Тогда
				Результат.МожноПодписыватьДокументы = Сертификаты_ЕстьРегистрацияФНС(ПараметрыСервиса, Ящик.Адрес, СертификатBase64);
			КонецЕсли;
			
			Сертификаты_ПроверитьСертификат(ПараметрыСервиса, Сертификат, СертификатBase64, Ящик.Адрес);
			
			Результат.ТребуетсяМЧД = КонтекстСеанса_ТребуетсяМЧД(Сертификат, Ящик.Организация.ИНН);
			
		КонецЕсли;
		
		Результат.ПраваПользователя = КонтекстСеанса_ПраваПользователя(ПараметрыСервиса, Ящик.Идентификатор);
		Результат.ДополнительныеФункции = КонтекстСеанса_ДополнительныеФункцииЯщика(ПараметрыСервиса, Ящик.Адрес);
		
	КонецЕсли;
	
	ПользовательДД = Сессия.Пользователь;
	Результат.ОписаниеПользователя.Id = ПользовательДД.Идентификатор;
	Результат.ОписаниеПользователя.Фамилия = ПользовательДД.Фамилия;
	Результат.ОписаниеПользователя.Имя = ПользовательДД.Имя;
	Результат.ОписаниеПользователя.Отчество = ПользовательДД.Отчество;
	Результат.ОписаниеПользователя.ФИО = СокрЛП(ПользовательДД.Фамилия + " " + ПользовательДД.Имя + " " + ПользовательДД.Отчество);
	Результат.ОписаниеПользователя.ИННСертификата = СвойствоСтруктуры(Сертификат, "ИНН", "");
	Результат.ОписаниеПользователя.Должность = СокрЛП(СвойствоСтруктуры(Результат.ПраваПользователя, "JobTitle", "-"));
	
	Результат = ФиксированныеДанные(Результат);
	
	Возврат Результат;
	
КонецФункции

Процедура КонтекстСеанса_ЗаполнитьИнформациюИзБиллинга(СтрокаКонтекста, ПараметрыСервиса)
	
	BoxId = СтрокаКонтекста.BoxId;
	OrgId = СтрокаКонтекста.OrgId;
	Organization = СтрокаКонтекста.Box.Organization;
	
	ЭтоРеальнаяОрганизация = Организации_ЭтоРеальнаяОрганизация(Organization);
	
	ДанныеБиллингаДляЯщика = КонтурШлюзАвторизации_АвторизацияБиллинга(BoxId, ПараметрыСервиса);
	
	ЛицевыеСчета = ДанныеБиллингаДляЯщика.ЛицевыеСчета;
	СервисПодпискиНаМодуль = ДанныеБиллингаДляЯщика.СервисПодпискиНаМодуль;
	ТребуетсяОплатаМодуля = ДанныеБиллингаДляЯщика.ТребуетсяОплатаМодуля И ЭтоРеальнаяОрганизация;
	ТребуетсяОплатаАПИ = АПИ_ТребуетсяОплатаСервиса(ПараметрыСервиса, OrgId);
	
	СтрокаКонтекста.ТребуетсяОплатаСервиса = ТребуетсяОплатаМодуля ИЛИ ТребуетсяОплатаАПИ;
	СтрокаКонтекста.СервисПодпискиНаМодуль = СервисПодпискиНаМодуль;
	СтрокаКонтекста.ЛицевыеСчета = ЛицевыеСчета;
		
	Метрика_ДобавитьСтатистику_СервисыПодписок(СтрокаКонтекста, ТребуетсяОплатаМодуля, ТребуетсяОплатаАПИ);
	
	ЛичныйКабинет_ПроверитьДоступностьПлагинов(ЛицевыеСчета);
	
КонецПроцедуры

Функция КонтекстСеанса_ПраваПользователя(ПараметрыСервиса, boxId)
	
	Результат = Контракт_ПраваПользователя();
	
	Ответ = АПИ_GetMyEmployee(ПараметрыСервиса, boxId);
	
	Результат.JobTitle = СвойствоСтруктуры(Ответ, "Position", "");
	
	Permissions = СвойствоСтруктуры(Ответ, "Permissions");
	
	Результат.UserDepartmentId = СвойствоСтруктуры(Permissions, "UserDepartmentId", "");
    Результат.IsAdministrator = СвойствоСтруктуры(Permissions, "IsAdministrator", Ложь);
    Результат.DocumentAccessLevel = СвойствоСтруктуры(Permissions, "DocumentAccessLevel", -1);
	Результат.SelectedDepartmentIds = СвойствоСтруктуры(Permissions, "SelectedDepartmentIds", Новый Массив);
    Результат.AuthorizationPermission = СвойствоСтруктуры(Permissions, "AuthorizationPermission");
	
	Actions = СвойствоСтруктуры(Permissions, "Actions", Новый Массив);
	ПрефиксДействия = "Can";
	
	Для Каждого Action Из Actions Цикл
		
		ДанныеДействия = Новый Структура(ПрефиксДействия + Action.Name, Action.IsAllowed);
		ЗаполнитьЗначенияСвойств(Результат, ДанныеДействия);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Модель строки контекста сеанса
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//   * Сессия - Структура - см. МодельСессияПользователя
//   * Ящик - Структура - см. МодельЯщикОрганизации
//   * ПраваПользователя - Структура - см. Контракт_ПраваПользователя
//   * ОписаниеПользователя - Структура - Описание сотрудника организации (рекомендуется использовать Сессия.Пользователь)
//   * ОтпечатокСертификата - Строка - Отпечаток сертификата для работы в ящике (в верхнем регистре)
//   * Сертификат - Структура - см. Сертификаты_ОписаниеСертификата
//   * ОрганизацияДиадок - СправочникСсылка.Диадок_ЮрФизЛица - (Необязательный, только для СХ-1) ссылка на описание
//                                                             организации Диадока в информационной базе
//   * ДополнительныеФункции - Структура - см. Контракт_ДополнительныеФункцииЯщика
//   * ЛицевыеСчета - Массив - лицевые счета организации
//   * СервисПодпискиНаМодуль - Структура - см. Контракт_СервисПодписки
//   * ТребуетсяОплатаСервиса - Булево - Истина, если требуется оплата
//   * МожноПодписыватьДокументы - Булево - Истина, если есть сертификат и организация зарегистрирована в ФНС
//   * ТребуетсяМЧД - Булево - Истина, если используется сертификат КЭП с ИНН, отличным от ИНН организации
//
Функция МодельСтрокаКонтекстаСеанса()
	
	Результат = Новый Структура;
	Результат.Вставить("Сессия", МодельСессияПользователя());
	Результат.Вставить("Ящик", МодельЯщикОрганизации());
	
	Результат.Вставить("Box"); // Устарело, следует использовать Ящик
	Результат.Вставить("BoxId"); // Устарело, следует использовать Ящик.Адрес
	Результат.Вставить("OrgId"); // Устарело, следует использовать Ящик.Организация.Идентификатор
	
	Результат.Вставить("Токен"); // Устарело, следует использовать Сессия.ТокенДоступа
	Результат.Вставить("Логин"); // Устарело, следует использовать Сессия.Пользователь.Логин
	Результат.Вставить("ТипАвторизации"); // Устарело, следует использовать Сессия.СхемаАутентификации
	Результат.Вставить("ОтпечатокСертификата");
	Результат.Вставить("Сертификат");
	
	Результат.Вставить("ИНН"); // Устарело, следует использовать Ящик.Организация.ИНН
	Результат.Вставить("КПП"); // Устарело, следует использовать Ящик.Организация.КПП
	Результат.Вставить("ОрганизацияДиадок");
	Результат.Вставить("ОрганизацияНаименование"); // Устарело, следует использовать Ящик.Организация.Наименование
	Результат.Вставить("ПраваПользователя",			Контракт_ПраваПользователя());
	Результат.Вставить("ОписаниеПользователя",		Контракт_ОписаниеПользователя()); // Устарело, рекомендуется использовать Сессия.Пользователь
	
	Результат.Вставить("ОблачныйСертификат",		Ложь); // Не используется, всегда Ложь
	Результат.Вставить("ЭтоТестоваяОрганизация",	Ложь); // Устарело, следует использовать Ящик.Организация.Тестовая
	Результат.Вставить("МожноПодписыватьДокументы",	Ложь);
	
	Результат.Вставить("ТребуетсяМЧД",				Ложь);
	
	Результат.Вставить("ДополнительныеФункции",		Контракт_ДополнительныеФункцииЯщика());
	
	Результат.Вставить("ЛицевыеСчета", Новый Массив);
	Результат.Вставить("СервисПодпискиНаМодуль", Контракт_СервисПодписки());
	Результат.Вставить("ТребуетсяОплатаСервиса", Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция КонтекстСеанса_ДляСлужебнойУчетнойЗаписи() Экспорт
	
	Результат = Ложь;
	
	Сессия = КонтекстСеанса_ТокенДоступа("");
	МассивОрганизаций = Организации_ДоступныеОрганизации(Сессия);
	
	Для Каждого Organization Из МассивОрганизаций Цикл
		
		ИдентификаторЯщика = Organization.BoxId;
		СтрокаКонтекста = СоздатьСтрокуКонтекстаСеанса(ИдентификаторЯщика, Сессия);
		
		КонтекстСеанса_ДобавитьСтроку(ИдентификаторЯщика, СтрокаКонтекста);
		
		Результат = Истина;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Добавляет в хранилище контекста сеанса новую строку
//
// Параметры:
//  Ключ - Строка - Ключ строки контекста (адрес ящика или пустая строка для служебной учетки)
//  ВходящиеПараметры - Структура, ФиксированнаяСтруктура - параметры строки контекста сеанса.
//                      Ключи структуры должны соответствовать модели строки контекста (см. МодельСтрокаКонтекстаСеанса)
//
Процедура КонтекстСеанса_ДобавитьСтроку(Знач Ключ, Знач ВходящиеПараметры) Экспорт
	
	АдресЯщика = ИдентификаторВАдресЯщика(НРег(Ключ));
	
	Модель = МодельСтрокаКонтекстаСеанса();
	ЗаполнитьЗначенияСвойств(Модель, ВходящиеПараметры);
	
	СтрокаКонтекста = ФиксированныеДанные(Модель);
	
	КонтекстСеанса = ХранилищеКонтекстаСеанса();
	Данные = КопияКоллекцииЗначений(КонтекстСеанса);
	Данные.Вставить(АдресЯщика, СтрокаКонтекста);
	КонтекстСеанса = ФиксированныеДанные(Данные);
	
	КэшКонтекстаСеанса_ДобавитьСтроку(Ключ, СтрокаКонтекста);
	
	ХранилищеКонтекстаСеанса_Установить(КонтекстСеанса);
	
КонецПроцедуры

Функция КонтекстСеанса_ЕстьСтроки() Экспорт
	
	КонтекстСеанса = ХранилищеКонтекстаСеанса();
	
	Результат = ЗначениеЗаполнено(КонтекстСеанса);
	
	Возврат Результат;
	
КонецФункции

// Получает сохраненные настройки сеанса текущего пользователя.
// 
// Возвращаемое значение:
//  ФиксированныйМассив из Контракт_НастройкаСеанса.
//
Функция КонтекстСеанса_СохраненныеНастройки() Экспорт
	
	Данные = ХранилищеОбщихНастроек_Прочитать("НастройкиКонтекстаСеанса");
	
	Если ТипЗнч(Данные) <> Тип("Массив")
		И ТипЗнч(Данные) <> Тип("ФиксированныйМассив") Тогда
		Данные = Новый Массив;
	КонецЕсли;
	
	Ответ = Новый Массив;
	
	Для Каждого СохраненнаяНастройка Из Данные Цикл
		
		Если ТипЗнч(СохраненнаяНастройка) <> Тип("Структура")
			И ТипЗнч(СохраненнаяНастройка) <> Тип("ФиксированнаяСтруктура") Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			Настройка = КонтекстСеанса_РазобратьСохраненнуюНастройку(СохраненнаяНастройка);
		Исключение
			ОшибкаИнфо = ИнформацияОбОшибке();
			Продолжить;
		КонецПопытки;
		
		Ответ.Добавить(Настройка);
		
	КонецЦикла;
	
	Результат = ФиксированныеДанные(Ответ);
	
	Возврат Результат;
	
КонецФункции

// Записывает настройки контекста сеанса текущего пользователя
//
// Параметры:
//  Контекст - Соответствие, ФиксированноеСоответствие - см. КонтекстСеанса_СтрокиКонтекста
//  АутхПриложение - ФиксированнаяСтруктура - см. МодельАутхКонфигурацияПриложения
//
Процедура КонтекстСеанса_ЗаписатьНастройки(Знач Контекст, Знач АутхПриложение) Экспорт
	
	Данные = Новый Массив;
	
	Для Каждого КлючЗначение Из Контекст Цикл
		
		ИдентификаторЯщика = НРег(АдресЯщикаВИдентификатор(КлючЗначение.Ключ));
		
		Если Не ЗначениеЗаполнено(ИдентификаторЯщика) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаКонтекста = КлючЗначение.Значение;
		
		Настройка = Контракт_НастройкаСеанса();
		Настройка.ИдентификаторЯщика = ИдентификаторЯщика;
		Настройка.ИдентификаторПользователя = НРег(СтрокаКонтекста.Сессия.Пользователь.Идентификатор);
		Настройка.КлючСессии = СтрокаКонтекста.Сессия.Ключ;
		Настройка.СхемаАутентификации = СтрокаКонтекста.Сессия.СхемаАутентификации;
		Настройка.ТокенДоступаСрокДействия = СтрокаКонтекста.Сессия.УниверсальнаяДатаОкончания;
		Настройка.ОтпечатокСертификата = ВРег(СтрокаКонтекста.ОтпечатокСертификата);
		
		Если Настройка.СхемаАутентификации = СхемаАутентификацииДиадокСертификат()
			Или Настройка.СхемаАутентификации = СхемаАутентификацииДиадокПароль() Тогда
			Настройка.ТокенДоступа = СтрокаКонтекста.Сессия.ТокенДоступа;
		КонецЕсли;
		
		Если Настройка.СхемаАутентификации = СхемаАутентификацииПорталБраузер() Тогда
			Настройка.ИмяПриложения = АутхПриложение.Имя;
		КонецЕсли;
		
		Данные.Добавить(Настройка);
		
	КонецЦикла;
	
	ХранилищеОбщихНастроек_Поместить("НастройкиКонтекстаСеанса", ФиксированныеДанные(Данные));
	
КонецПроцедуры

// Восстанавливает сессию пользователя по сохраненной настройке
//
// Параметры:
//  НастройкаСеанса - ФиксированнаяСтруктура - см. Контракт_НастройкаСеанса
// 
// Возвращаемое значение:
//  ФиксированнаяСтруктура - см. МодельСессияПользователя
//
Функция КонтекстСеанса_ВосстановитьСессию(НастройкаСеанса) Экспорт
	
	ЗначенияПараметров = Новый Структура;
	ЗначенияПараметров.Вставить("КлючСессии", "");
	ЗначенияПараметров.Вставить("ТокенДоступа", "");
	ЗначенияПараметров.Вставить("СхемаАутентификации", СхемаАутентификацииДиадокНеизвестно());
	ЗначенияПараметров.Вставить("ТокенДоступаСрокДействия", '00010101');
	
	ЗаполнитьЗначенияСвойств(ЗначенияПараметров, НастройкаСеанса);
	
	Сессия = КонтекстСеансаСлужебный_СоздатьСессию(
		ЗначенияПараметров.КлючСессии,
		ЗначенияПараметров.ТокенДоступа,
		ЗначенияПараметров.СхемаАутентификации,
		ЗначенияПараметров.ТокенДоступаСрокДействия
	);
	
	Результат = ФиксированныеДанные(Сессия);
	
	Возврат Результат;
	
КонецФункции

Функция КонтекстСеанса_РазобратьСохраненнуюНастройку(СохраненнаяНастройка)
	
	Модель = Контракт_НастройкаСеанса();
	Модель.ИдентификаторЯщика = АдресЯщикаВИдентификатор(НРег(СохраненнаяНастройка.ИдентификаторЯщика));
	Модель.ТокенДоступа = СохраненнаяНастройка.ТокенДоступа;
	Модель.ОтпечатокСертификата = ВРег(СохраненнаяНастройка.ОтпечатокСертификата);
	Модель.ИдентификаторПользователя = НРег(СохраненнаяНастройка.ИдентификаторПользователя);
	
	Если Не СохраненнаяНастройка.Свойство("КлючСессии", Модель.КлючСессии) Тогда
		Модель.КлючСессии = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;
	
	Если Не СохраненнаяНастройка.Свойство("ИмяПриложения", Модель.ИмяПриложения) Тогда
		АутхПриложение = АутхКонфигурацияПриложенияПоУмолчанию();
		Модель.ИмяПриложения = АутхПриложение.Имя;
	КонецЕсли;
	
	Если СохраненнаяНастройка.Свойство("ТокенДоступаСрокДействия") Тогда
		Модель.ТокенДоступаСрокДействия = СохраненнаяНастройка.ТокенДоступаСрокДействия;
	КонецЕсли;
	
	Если СохраненнаяНастройка.Свойство("СхемаАутентификации") Тогда
		Модель.СхемаАутентификации = СохраненнаяНастройка.СхемаАутентификации;
	ИначеЕсли СохраненнаяНастройка.Свойство("ТипАвторизации") Тогда
		
		Маппинг = Новый Соответствие;
		Маппинг.Вставить(ТипАвторизацииДиадокСертификат(), СхемаАутентификацииДиадокСертификат());
		Маппинг.Вставить(ТипАвторизацииДиадокЛогин(), СхемаАутентификацииДиадокПароль());
		Маппинг.Вставить(ТипАвторизацииПорталБраузер(), СхемаАутентификацииПорталБраузер());
		
		Модель.СхемаАутентификации = Маппинг.Получить(СохраненнаяНастройка.ТипАвторизации);
		Если Не ЗначениеЗаполнено(Модель.СхемаАутентификации) Тогда
			Модель.СхемаАутентификации = СхемаАутентификацииДиадокНеизвестно();
		КонецЕсли;
		
	Иначе
		Модель.СхемаАутентификации = СхемаАутентификацииДиадокНеизвестно();
	КонецЕсли;
	
	Возврат Модель;
	
КонецФункции

// Модель сохраняемых данных контекста сеанса пользователя
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//   * ИдентификаторЯщика - Строка - СтрокаКонтекста.Ящик.Идентификатор
//   * ОтпечатокСертификата - Строка - СтрокаКонтекста.Сертификат.ОтпечатокСертификата
//   * КлючСессии - Строка - СтрокаКонтекста.Сессия.Ключ
//   * ТокенДоступа - Строка - СтрокаКонтекста.Сессия.ТокенДоступа
//   * СхемаАутентификации - Строка - СтрокаКонтекста.Сессия.СхемаАутентификации
//   * ИмяПриложения - Строка - см. МодельАутхКонфигурацияПриложения.Имя
//   * ИдентификаторПользователя - Строка - СтрокаКонтекста.Сессия.Пользователь.Идентификатор
//   * ТокенДоступаСрокДействия - Дата - СтрокаКонтекста.Сессия.УниверсальнаяДатаОкончания
//
Функция Контракт_НастройкаСеанса()
	
	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторЯщика", "");
	Результат.Вставить("ОтпечатокСертификата", "");
	Результат.Вставить("КлючСессии", "");
	Результат.Вставить("ТокенДоступа", "");
	Результат.Вставить("СхемаАутентификации", "");
	Результат.Вставить("ИмяПриложения", "");
	Результат.Вставить("ИдентификаторПользователя", "");
	Результат.Вставить("ТокенДоступаСрокДействия", '00010101');
	
	Возврат Результат;
	
КонецФункции

Процедура КонтекстСеанса_Установить(Знач BoxId, Знач ОтпечатокСертификата) Экспорт 
	
	ОтпечатокСертификата = ВРег(ОтпечатокСертификата);
	
	СтрокаКонтекста = КэшКонтекстаСеанса_СтрокаКонтекста(BoxId, ОтпечатокСертификата);
	
	Если СтрокаКонтекста = Неопределено Тогда
		
		Идентификаторы	= Новый_ИдентификаторыСправочника(, BoxId);
		Организация		= ХранениеДанных_ДанныеОрганизации(Идентификаторы);
		
		ТокенДоступа = Авторизация_СоединенияПоСертификату(ОтпечатокСертификата, Организация.Наименование);
		Если ТокенДоступа = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Сессия = Новый_СессияДиадокСертификат(ОтпечатокСертификата, ТокенДоступа);
		
		ДанныеСертификата = Сертификаты_ДанныеСертификата(ОтпечатокСертификата);
		Сертификат = Сертификаты_ОписаниеСертификата(ДанныеСертификата);
		Сертификат.Вставить("Base64", Base64Строка(ДанныеСертификата.ДвоичныеДанные));
		
		СтрокаКонтекста = СоздатьСтрокуКонтекстаСеанса(BoxId, Сессия, Сертификат);
		
	КонецЕсли;
	
	Если СтрокаКонтекста <> Неопределено Тогда
		
		КонтекстСеанса_ДобавитьСтроку(BoxId, СтрокаКонтекста);
		МЧД_УдалитьКонтекстДляГрупповыхДействий();
		
	КонецЕсли;
	
КонецПроцедуры

// Обновляет данные ящиков в контексте сеанса и возвращает обновленный контекст
//
// Возращаемое значение:
//	Массив - массив соответствий с данными ящиков (см. метод СоздатьКонтекстСеанса)
//
Функция КонтекстСеанса_ОбновитьДанныеЯщиков() Экспорт
	
	КонтекстСеанса = ХранилищеКонтекстаСеанса();
	
	Для Каждого ТекСтрока Из КонтекстСеанса Цикл
		
		СтрокаКонтекста = ТекСтрока.Значение;
		BoxId = СтрокаКонтекста.BoxId;
		
		Если ЗначениеЗаполнено(BoxId) Тогда
			
			ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
			Ящик = АПИ_GetBox(ПараметрыСервиса, BoxId);
			
			Данные = КопияКоллекцииЗначений(СтрокаКонтекста);
			Данные.Box = Ящик;
			СтрокаКонтекста = ФиксированныеДанные(Данные);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ХранилищеКонтекстаСеанса_Установить(КонтекстСеанса);
	
	КэшКонтекстаСеанса_ЗаполнитьПоКонтексту(КонтекстСеанса);
	
	Возврат КонтекстСеанса;
	
КонецФункции

Функция КэшКонтекстаСеанса()
	
	АдресВХ = ОбщийКонтекст_Прочитать("АдресКэшаКонтекстаСеанса");
	
	Результат = ВременноеХранилище_Прочитать(АдресВХ);
	
	Если Результат = Неопределено Тогда
		Результат = ФиксированныеДанные(Новый Соответствие);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КэшКонтекстаСеанса_СтрокаКонтекста(BoxId, Thumbprint)
	
	КэшКонтекста = КэшКонтекстаСеанса();
	
	Отпечатки = КэшКонтекста.Получить(BoxId);
	
	Если ЗначениеЗаполнено(Отпечатки) Тогда
		Результат = Отпечатки.Получить(Thumbprint);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура КэшКонтекстаСеанса_ЗаполнитьПоКонтексту(КонтекстСеанса)
	
	Данные = Новый Соответствие;
	
	Если ЗначениеЗаполнено(КонтекстСеанса) Тогда
		
		Для Каждого КлючЗначение Из КонтекстСеанса Цикл
			
			Отпечатки = Данные.Получить(КлючЗначение.Ключ);
			Если Отпечатки = Неопределено Тогда
				Отпечатки = Новый Соответствие;
				Данные.Вставить(КлючЗначение.Ключ, Отпечатки);
			КонецЕсли;
			
			Отпечатки.Вставить(КлючЗначение.Значение.ОтпечатокСертификата, КлючЗначение.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	КэшКонтекста = ФиксированныеДанные(Данные);
	
	КэшКонтекстаСеанса_Установить(КэшКонтекста);
	
КонецПроцедуры

Процедура КэшКонтекстаСеанса_ДобавитьСтроку(Ключ, СтрокаКонтекста)
	
	КэшКонтекста = КэшКонтекстаСеанса();
	
	Отпечатки = КэшКонтекста.Получить(Ключ);
	
	Если Отпечатки = Неопределено Тогда
		Отпечатки = Новый Соответствие;
	Иначе
		Отпечатки = КопияКоллекцииЗначений(Отпечатки);
	КонецЕсли;
	
	Отпечатки.Вставить(СтрокаКонтекста.ОтпечатокСертификата, СтрокаКонтекста);
	
	НовыйКэш = КопияКоллекцииЗначений(КэшКонтекста);
	НовыйКэш.Вставить(Ключ, Отпечатки);
	КэшКонтекста = ФиксированныеДанные(НовыйКэш);
	
	КэшКонтекстаСеанса_Установить(КэшКонтекста);
	
КонецПроцедуры

Процедура КэшКонтекстаСеанса_Установить(НовыйКэшКонтекста)
	
	АдресВХ = ОбщийКонтекст_Прочитать("АдресКэшаКонтекстаСеанса");
	
	Данные = ФиксированныеДанные(НовыйКэшКонтекста);
	ВременноеХранилище_Поместить(Данные, АдресВХ);
	
КонецПроцедуры

Процедура КэшКонтекстаСеанса_Очистить()
	
	КэшКонтекста = Новый Соответствие;
	
	КэшКонтекстаСеанса_Установить(КэшКонтекста);
	
	КэшКонтекстаСеанса_ОчиститьДанныеАвторизации();
	
КонецПроцедуры

Процедура КэшКонтекстаСеанса_ОчиститьДанныеАвторизации()
	
	КлючКэша = Сертификаты_КлючКэшаРезультатовПроверкиСертификатов();
	Кэш_Поместить(КлючКэша, Неопределено);
	
КонецПроцедуры

