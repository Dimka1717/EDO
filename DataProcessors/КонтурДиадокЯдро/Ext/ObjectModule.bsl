Функция Токен_ПолучитьИзДиадока(Сертификат = Неопределено, Логин = Неопределено, Пароль = Неопределено) Экспорт
	
	АдресСервиса = ОбщийКонтекст_Прочитать("АдресDiadocAPI");
	НастройкиКлиента = НастройкиКлиентаAPI(АдресСервиса, "", ТипТокенаДиадок());
	
	Результат = АПИ_Authenticate(НастройкиКлиента, Сертификат, Логин, Пароль);
	
	Возврат Результат;
	
КонецФункции

Функция Токен_Расшифровать(ЗашифрованныйТокен)
	
	Результат = РасшифроватьДанные(ЗашифрованныйТокен);
	
	Результат = Base64Строка(Результат);
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.ПС, "");
	
	Возврат Результат;
	
КонецФункции

// Авторизуется на сервере ДД по отпечатку сертификата
//
// Параметры:
//  ОтпечатокСертификата - Строка
// 
// Возвращаемое значение:
//  Строка - токен авторизации
//
Функция Авторизация_ПоСертификату(ОтпечатокСертификата) Экспорт
	
	Результат = Неопределено;
	
	Сертификат = ВнешниеСервисы_ПолучитьСертификат(ОтпечатокСертификата);
	
	ЗашифрованныйТокен = Токен_ПолучитьИзДиадока(Сертификат.ДвоичныеДанные);
	
	Если ЗначениеЗаполнено(ЗашифрованныйТокен) Тогда
		РасшифрованныйТокен = Токен_Расшифровать(ЗашифрованныйТокен);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РасшифрованныйТокен) Тогда
		
		ТекстОшибки = Общее_ПодставитьПараметрыВСтроку(НСтр(
		"ru = 'Не удалось выполнить авторизацию по сертификату с отпечатком %1'"), ОтпечатокСертификата);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = Токен_ПодтвердитьАутентификацию(РасшифрованныйТокен, ОтпечатокСертификата);
	
	Возврат Результат;
	
КонецФункции

// Авторизуется на сервере ДД по логину и паролю
//
// Параметры:
//  Логин - Строка
//  Пароль - Строка
//  ТекстОшибки - Строка - параметр в который записывается подробный текст ошибки при неудачной авторизации
// 
// Возвращаемое значение:
//  Строка - токен авторизации
//
Функция Авторизация_ПоПаролю(Логин, Пароль, ТекстОшибки = "") Экспорт
	
	Токен = Неопределено;
	
	Попытка
		Токен = Токен_ПолучитьИзДиадока(, Логин, Пароль);
	Исключение
		
		ВидОперации		 = "Авторизация по логину";
		ТекстСообщения	 = "Не удалось выполнить авторизацию по логину %1";
		ТекстСообщения	 = Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, Логин);
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ДопИнформация	 = Новый Массив;
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Логин: %1", Логин));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Возврат Токен;
		
	КонецПопытки;
	
	Авторизация_ДобавитьСтрокуПоЛогину(Логин, Токен);
	
	Возврат Токен;
	
КонецФункции

Функция Авторизация_ПроверкаАвторизации(Сертификат = Неопределено, Логин = Неопределено, Пароль = Неопределено) Экспорт
	
	Попытка
		Токен = Токен_ПолучитьИзДиадока(Сертификат, Логин, Пароль);
	Исключение
		Токен = Неопределено;
	КонецПопытки;
	
	Результат = Токен <> Неопределено;

	Возврат Результат;

КонецФункции

Процедура Авторизация_ДобавитьСтрокуПоЛогину(Логин, Токен) Экспорт 
	
	Сессия = Новый_СессияДиадокПароль(Логин, Токен);
	СтрокаКонтекста = СоздатьСтрокуКонтекстаСеанса("", Сессия);
	
	КонтекстСеанса_ДобавитьСтроку("", СтрокаКонтекста);
	
КонецПроцедуры

Процедура Авторизация_ПодСертификатомНаСервере1С() Экспорт
	
	Настройки = ХранениеДанных_НастройкиСертификатовНаСервере1С();
	
	ТекущиеСоединения = Новый Соответствие;
	КлиентскиеСертификаты = Новый Соответствие;
	
	Для Каждого СтруктураНастройки Из Настройки Цикл
		
		ОтпечатокСертификата = ВРег(СтруктураНастройки.ОтпечатокСертификата);
		СтруктураНастройки.Вставить("КлючСессии", ОтпечатокСертификата);
		
		Если КлиентскиеСертификаты.Получить(ОтпечатокСертификата) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеОрганизации = СтруктураНастройки.Наименование;
		ТокенДоступа = Авторизация_СоединенияПоСертификату(ОтпечатокСертификата, НаименованиеОрганизации);
		Если ТокенДоступа = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Сессия = Новый_СессияДиадокСертификат(ОтпечатокСертификата, ТокенДоступа);
		
		ДанныеСертификата = Сертификаты_ДанныеСертификата(ОтпечатокСертификата);
		Сертификат = Сертификаты_ОписаниеСертификата(ДанныеСертификата);
		Сертификат.Вставить("Base64", Base64Строка(ДанныеСертификата.ДвоичныеДанные));
		
		КлиентскиеСертификаты.Вставить(ОтпечатокСертификата, Сертификат);
		ТекущиеСоединения.Вставить(ОтпечатокСертификата, Сессия);
		
	КонецЦикла;
	
	КонтекстСеанса_Заполнить(Настройки, ТекущиеСоединения, КлиентскиеСертификаты);
	
КонецПроцедуры

Функция Авторизация_СоединенияПоСертификату(Знач ОтпечатокСертификата, Знач НаименованиеОрганизации = "") Экспорт
	
	Результат = Неопределено;
	
	Попытка
		
		РасшифрованныйТокен = Авторизация_ПоСертификату(ОтпечатокСертификата);
		
	Исключение
		
		ВидОперации		 = "Авторизация по сертификату";
		ТекстСообщения	 = "Не удалось авторизоваться в организации %1 по сертификату %2";
		ТекстСообщения	 = Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, НаименованиеОрганизации, ОтпечатокСертификата);
		ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ДопИнформация	 = Новый Массив;
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Организация: %1", НаименованиеОрганизации));
		ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Отпечаток сертификата: %1", ОтпечатокСертификата));
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Возврат Результат;
		
	КонецПопытки;
	
	Возврат РасшифрованныйТокен;
	
КонецФункции

// Служебный конструктор сессии пользователя. В процессе инициализации сессии
// выполняется запрос в Web API Диадока для получения информации о пользователе.
//
// Параметры:
//  КлючСессии - Строка - Произвольная строка, однозначно идентифицирующая сессию
//  ТокенДоступа - Строка - авторизационный токен.
//  СхемаАутентификации - Строка - см. Перечисление_СхемыАутентификации
//  ДействуетДо - Дата - дата окончания действия токена (UTC)
// 
// Возвращаемое значение:
//  Структура - см. МодельСессияПользователя
//
Функция КонтекстСеансаСлужебный_СоздатьСессию(Знач КлючСессии, Знач ТокенДоступа, Знач СхемаАутентификации, Знач ДействуетДо = '00010101')
	
	Если Не ЗначениеЗаполнено(КлючСессии) Тогда
		Ошибка = "Не указано значение параметра 'КлючСессии'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТокенДоступа) Тогда
		Ошибка = "Не указано значение параметра 'ТокенДоступа'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СхемаАутентификации) Тогда
		Ошибка = "Не указано значение параметра 'СхемаАутентификации'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если СхемаАутентификации = СхемаАутентификацииПорталБраузер() Тогда
		ТипТокена = ТипТокенаПортал();
	ИначеЕсли СхемаАутентификации = СхемаАутентификацииДиадокСертификат()
		Или СхемаАутентификации = СхемаАутентификацииДиадокПароль()
		Или СхемаАутентификации = СхемаАутентификацииДиадокНеизвестно() Тогда
		ТипТокена = ТипТокенаДиадок();
	Иначе
		Ошибка = Общее_ПодставитьПараметрыВСтроку(
			"Недопустимое значение параметра 'СхемаАутентификации' (%1)",
			СхемаАутентификации
		);
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если ТипЗнч(ДействуетДо) <> Тип("Дата") Тогда
		Ошибка = "Несоответствие типов: Параметр 'ДействуетДо' должен иметь тип 'Дата'";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДействуетДо) Тогда
		ВремяЖизниПоУмолчанию = 86400; // сутки
		ДействуетДо = ТекущаяУниверсальнаяДата() + ВремяЖизниПоУмолчанию;
	КонецЕсли;
	
	Данные = МодельСессияПользователя();
	Данные.Ключ = КлючСессии;
	Данные.ТокенДоступа = ТокенДоступа;
	Данные.ТипТокена = ТипТокена;
	Данные.СхемаАутентификации = СхемаАутентификации;
	Данные.ЭтоПортальнаяСессия = (СхемаАутентификации = СхемаАутентификацииПорталБраузер());
	Данные.УниверсальнаяДатаОкончания = ДействуетДо;
	Данные.Пользователь = АПИ_ПользовательСервиса(ТокенДоступа, ТипТокена);
	
	Возврат Данные;
	
КонецФункции

// Конструктор сессии пользователя по схеме Device flow
//
// Параметры:
//  КлючСессии - Строка - Произвольная строка, однозначно идентифицирующая сессию
//  ПортальнаяСессия - ФиксированнаяСтруктура - см. КонтурДиадокАутентификатор.МодельОтветТокен
