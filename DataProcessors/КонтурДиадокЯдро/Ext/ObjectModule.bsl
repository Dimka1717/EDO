//#Область Регистрация_замеров

// Добавляет запись в DD_Health с заданными категорией и действием:
// - Имя интеграционного модуля записывается в поле Label (значение "null", если ИМ не подключен)
// - Длительность операции в миллисекундах записывается в Variables с ключом "Duration"
// - Дополнительно в переменные метрики безусловно добавляются ключи:
//     * ТиповойМодуль - Строка - результат проверки контрольной суммы (см. Метрика_ЗначениеПеременнойТиповойМодуль)
//
// Параметры:
//  Категория - Строка - идентификатор категории замера
//  Действие - Строка - идентификатор действия
//  НачалоЗамера - Число - время старта замера в формате универсальной даты в миллисекундах
//  ДопПеременные - Структура, Соответствие - (Необязательный) значения дополнительных переменных
//
Процедура Метрика_ДобавитьЗамер(Категория, Действие, НачалоЗамера, ДопПеременные = Неопределено)
	
	ОкончаниеЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ДлительностьОперации = ОкончаниеЗамера - НачалоЗамера;
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	TraceID = TraceId();
	
	Метка = ИнтеграционныйМодуль_Получить();
	Если Не ЗначениеЗаполнено(Метка) Тогда
		Метка = "null";
	КонецЕсли;
	
	ПеременныеМетрики = Новый Соответствие;
	ПеременныеМетрики.Вставить("Duration", ДлительностьОперации);
	
	ДополнитьПеременныеМетрики_ТиповойМодуль(ПеременныеМетрики);
	ДополнитьПеременныеМетрики_ПроизвольныеПараметры(ПеременныеМетрики, ДопПеременные);
	
	ДобавитьСисИнфо = Истина;
	
	Представление = "";
	СобытиеМетрики = НовоеСобытиеМетрики(
		Категория,
		Действие,
		Метка,
		Представление
	);
	
	ЗарегистрироватьСобытиеМетрики(
		ТопикиМетрики_Health(),
		СобытиеМетрики,
		TraceID,
		ПеременныеМетрики,
		ДобавитьСисИнфо
	);
	
КонецПроцедуры

Процедура Метрика_ДобавитьЗамер_ЧтениеЛентыСобытий(КоличествоСобытий, BoxId, Начало = Истина)
	
	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	Категория = Метрика_НазваниеКатегории().ОбменССервером;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если Начало Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	ЗагружатьВходящие			= ОбщиеНастройки_Прочитать("ЗагружатьВходящиеДокументы");
	ЗагружатьИсходящие			= ОбщиеНастройки_Прочитать("ЗагружатьИсходящиеДокументы");
	ЗагружатьПоСопоставленным	= ОбщиеНастройки_Прочитать("ЗагружатьДокументыПоСопоставленнымКонтрагентам");
	ИдентификаторБазы1С			= ОбщиеНастройки_Прочитать("ИдентификаторБазы1С");
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID"							, АдресЯщикаВИдентификатор(BoxId));
	Переменные.Вставить("Количество событий"			, КоличествоСобытий);
	Переменные.Вставить("Загружать исходящие"			, ЗагружатьИсходящие);
	Переменные.Вставить("Загружать входящие"			, ЗагружатьВходящие);
	Переменные.Вставить("Загружать по сопоставленным"	, ЗагружатьПоСопоставленным);
	Переменные.Вставить("BaseID"						, ИдентификаторБазы1С);

	Метрика_ЗаписатьЗамер(Категория, Действие, , , Переменные);
	
КонецПроцедуры

// Замер для нескольких организаций. Создает одну запись замера для всех элементов контекста.
//
// Параметры:
//  КатегорияМетрики - Строка - Наименование категории замера.
//  ЭтоНачалоЗамера  - Булево - Признак начала или окончания замера.
//     * Истина - Начало замера.
//     * Ложь   - Окончание замера.
//  ДопПеременные    - Соответствие - Перечень дополнительных данных для включения в состав переменных замера.
//
Процедура Метрика_ДобавитьЗамер_ПоКонтекстуОднойЗаписью(КатегорияМетрики, ЭтоНачалоЗамера, ДопПеременные = Неопределено)

	Если Не ИспользоватьМетрики() Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыДействий = Метрика_НазваниеДействий();
	
	Если ЭтоНачалоЗамера Тогда
		Действие = ВариантыДействий.Start;
	Иначе
		Действие = ВариантыДействий.Finish;
	КонецЕсли;
	
	СтрокиКонтекста = КонтекстСеанса_СтрокиКонтекста();
	
	КоллекцияBoxId = Новый Массив;
	
	Для Каждого Элемент Из СтрокиКонтекста Цикл
		
		СтрокаКонтекста = Элемент.Значение;
		
		ИдентификаторЯщика = АдресЯщикаВИдентификатор(СтрокаКонтекста.BoxId);
		
		КоллекцияBoxId.Добавить(ИдентификаторЯщика);
		
	КонецЦикла;
	
	Переменные = Новый Соответствие;
	Переменные.Вставить("BoxID", КоллекцияBoxId);
	
	Если ДопПеременные <> Неопределено Тогда
		Для каждого Переменная Из ДопПеременные Цикл
			Переменные.Вставить(Переменная.Ключ, Переменная.Значение);			
		КонецЦикла; 
	КонецЕсли;
	
	Метрика_ЗаписатьЗамер(КатегорияМетрики, Действие, , , Переменные);

КонецПроцедуры

