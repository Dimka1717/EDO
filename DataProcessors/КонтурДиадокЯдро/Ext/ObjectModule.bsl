//{		ГЕНЕРАЦИЯ XML

// Генерирует данные формализованного документа в xml
//
// Возвращаемое значение:
//  ОбъектXDTO - контент документа, сгенерированный по соответствующей схеме xsd
Функция ГенерацияXML_НовыйДокументXML(Документ, ПроверятьXDTO = Истина)
	
	ТипКонтента = Документ.Тип.ТипКонтента;
	XDTO_SellerContent = Списки_ОписаниеФорматаКонтента(Документ.Тип.ТипКонтента).XDTO_SellerContent;
	ПротоСтруктура = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "Контент", Новый Структура);
	ПротоКонтентXDTO = ГенерацияXML_ПротоКонтент_В_ПротоКонтентXDTO(ПротоСтруктура, XDTO_SellerContent);
	ПараметрыФормированияФайла = ГенерацияXML_ПараметрыФормированияФайла();
	ПараметрыГенерацииXML = ГенерацияXML_ДополнитьПараметрыФормированияФайла(
			ПараметрыФормированияФайла,
			Документ.СлужебнаяИнформация);
	
	МодульГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	
	Если ТипКонтента = "utd" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_УПД_155(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "utd820" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_УПД_820(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = ТипКонтента_utd970() Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_УПД_970(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "ucd" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_УКД(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "ucd736" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_УКД_736(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "tovtorg" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_Торг_551(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "rezru" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_Акт_552(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = ТипКонтента_xmlproformainvoice() Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_Счет(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = "torg2" Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_Торг2(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_АктСверки_405(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = ТипКонтента_proformainvoice29() Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_Счет_ФНС29(ПротоКонтентXDTO, ПараметрыГенерацииXML);
		
	ИначеЕсли ТипКонтента = ТипКонтента_invoiceoffer29() Тогда
		
		Результат = МодульГенерацияXML.XML_ПолучитьXML_СчетОферта_ФНС29(ПротоКонтентXDTO, ПараметрыГенерацииXML);

	Иначе
		ВызватьИсключение "Тип контента " + ТипКонтента + " не поддерживается.";
	КонецЕсли;
	
	Если ПроверятьXDTO Тогда
		Результат.Проверить();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ГенерацияXML_МетаданныеДокументаXML(ДокументXML)
	
	Если СтрНачинаетсяСЛок(ДокументXML.ИдФайл, "ON_SCHET") Тогда
		
		ДатаСоздания = Дата(ДокументXML.Документ["ДатаДокПт"] + " " 
			+ СтрЗаменить(ДокументXML.Документ["ВремДокПт"], ".", ":"));
		
	ИначеЕсли СтрНачинаетсяСЛок(ДокументXML.ИдФайл, "ON_AKTSVEROTP") Тогда
		
		ДатаСоздания = Дата(ДокументXML.Документ["ДатаИнфОтпр"] + " " 
			+ СтрЗаменить(ДокументXML.Документ["ВрИнфОтпр"], ".", ":"));
		
	ИначеЕсли СтрНачинаетсяСЛок(ДокументXML.ИдФайл, "ON_CHETOP") Тогда
		
		ЭлементыДаты = Новый Массив;
		ЭлементыДаты.Добавить(ДокументXML.Документ.ДатаИнф);
		ЭлементыДаты.Добавить(СтрЗаменить(ДокументXML.Документ.ВрИнф, ".", ":"));

		ДатаСоздания = Дата(СоединитьСтроку(ЭлементыДаты, " "));

	Иначе
		
		ПостфиксАтрибутаДатыФормирования = "";
		
		Если СтрНачинаетсяСЛок(ДокументXML.ИдФайл, "DP_REZRUISP") Тогда
			ПостфиксАтрибутаДатыФормирования = "Исп";
		ИначеЕсли СтрНачинаетсяСЛок(ДокументXML.ИдФайл, "DP_PRIRASXPRIN") Тогда
			ПостфиксАтрибутаДатыФормирования = "Пок";
		Иначе
			ПостфиксАтрибутаДатыФормирования = "Пр";
		КонецЕсли;
		
		СтруктураДаты		= СтруктураДатыИзСтроки(ДокументXML.Документ["ДатаИнф" + ПостфиксАтрибутаДатыФормирования]);
		СтруктураВремени	= СтруктураВремениИзСтроки(ДокументXML.Документ["ВремИнф" + ПостфиксАтрибутаДатыФормирования]);
		
		ДатаСоздания = Дата(СтруктураДаты.Год, СтруктураДаты.Месяц, СтруктураДаты.День, СтруктураВремени.Час, СтруктураВремени.Минута, СтруктураВремени.Секунда);
		
	КонецЕсли;
	
	Результат = Новый Структура;
	
	Результат.Вставить("FileId", 		ДокументXML.ИДФайл);
	Результат.Вставить("FileName", 		ДокументXML.ИДФайл + ".xml");
	Результат.Вставить("FormationDate",	ДатаСоздания);
	Результат.Вставить("FormationTime",	Формат(ДатаСоздания, "ДФ=HH.mm.ss"));
	
	Возврат Результат;
	
КонецФункции

