Функция ПредопределенныеСписки_ОписаниеВидовДокументооборотаAPI(BoxId) Экспорт
	
	Результат = Кэш_Прочитать("ОписаниеВидовДокументооборотаAPI");
	
	Если Результат = Неопределено Тогда
		
		Результат = Новый Соответствие;
		
		ParticipantType			= АПИ_Перечисление_ParticipantType();
		ParticipantAction		= АПИ_Перечисление_ParticipantAction();
		
		Participant_Sender		= ParticipantType.Sender;
		Participant_Recipient	= ParticipantType.Recipient;
		Action_Title			= ParticipantAction.Title;
		
		ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
		
		Ответ = АПИ_GetWorkflowsSettings(ПараметрыСервиса, BoxId);
		
		DocumentWorkflowSettings = Ответ.DocumentWorkflowSettings;
		
		Для Каждого Workflow Из DocumentWorkflowSettings Цикл 
			
			ОписаниеДО = Новый_ОписаниеДокументооборотаAPI(Workflow.Id);
			
			Для Каждого SettingParticipant Из Workflow.Participants Цикл
				
				Если SettingParticipant.Participant = Participant_Recipient Тогда
					ОписаниеДО.ТитулПолучателя = (SettingParticipant.ParticipantAction = Action_Title);
				КонецЕсли;
				
			КонецЦикла;
			
			Результат.Вставить(Workflow.Id, ОписаниеДО);
			
		КонецЦикла;
		
		Кэш_Поместить("ОписаниеВидовДокументооборотаAPI", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ОписаниеДокументооборотаAPI(WorkflowId)
	
	Результат = Новый Структура;
	
	Результат.Вставить("WorkflowId", WorkflowId);
	Результат.Вставить("ТитулПолучателя", Ложь);
	
