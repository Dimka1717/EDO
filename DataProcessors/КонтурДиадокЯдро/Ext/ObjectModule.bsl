// Заполняет контекст типового модуля для управляемых форм.
//
// Параметры:
//  ТиповойМодуль	- ВнешняяОбработка	- объект модуля.
//  РежимОтладки	- Булево			- режим отладки включен/выключен.
//  КаталогСМодулем	- Строка			- каталог вложенных обработок для отладки.
//
Процедура ИнициализироватьТиповойМодульУФ(ТиповойМодуль, РежимОтладки = Ложь, КаталогСМодулем = "") Экспорт
	
	ИдентификаторФормы = ОбщийКонтекст_Прочитать("ИдентификаторФормы");
	
	Модуль_ГенерацияXML		= Модуль_ГенерацияXML(ЭтотОбъект);
	Модуль_ПечатныеФормы	= Модуль_ПечатныеФормы(ЭтотОбъект);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ПодключаемыйМодуль",					Новый Структура("ИспользоватьМодуль", Ложь));
	ДопПараметры.Вставить("РазрешитьНеструктурированныеАдреса",	Истина);
	ДопПараметры.Вставить("РежимОтладкиСервера",				РежимОтладки);
	ДопПараметры.Вставить("КаталогМодулейСервера",				КаталогСМодулем);
	ДопПараметры.Вставить("ТочностьЦены", ЗначениеНастройки_ТочностьЦены());
	ДопПараметры.Вставить("МаркерКонфигурации", ПараметрТиповогоМодуляУФ_МаркерКонфигурации());
	
	ТиповойМодуль.ИнициализироватьОбщийКонтекстКлиентСервер(ИдентификаторФормы, ДопПараметры);
	
	Ошибки_ПроверитьИнициализациюТиповогоМодуляУФ(ТиповойМодуль);
	
	ТиповойМодуль.КэшМодулей().Вставить("ГенерацияXML", Модуль_ГенерацияXML);
	ТиповойМодуль.КэшМодулей().Вставить("ПечатныеФормы", Модуль_ПечатныеФормы);
	
	ДанныеСотрудников = Новый Соответствие;
	
	Для Каждого КлючЗначение Из КонтекстСеанса_СтрокиКонтекста() Цикл
		СтрокаКонтекста = КлючЗначение.Значение;
		ДанныеСотрудников.Вставить(КлючЗначение.Ключ, СтрокаКонтекста.ОписаниеПользователя);
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеСотрудников, ТиповойМодуль.ПараметрыКлиентСервер.ВременноеХранилище.АдресДанныеСотрудников);
	
КонецПроцедуры

// Проверяет, удалось ли подключить интеграционный модуль стандартной библиотеки интеграции.
//
// Параметры:
//  ТиповойМодуль - ОбработкаОбъект, ВнешняяОбработка - объект модуля.
//
Процедура Ошибки_ПроверитьИнициализациюТиповогоМодуляУФ(ТиповойМодуль)
	
	ЕстьОшибкиПодключенияИМ = Не ЗначениеЗаполнено(ТиповойМодуль.ПараметрыКлиентСервер.МаркерКонфигурации);
	
	Если Не ЕстьОшибкиПодключенияИМ Тогда
		Возврат;
	КонецЕсли;
	
	ТекстОшибки = "Не удалось подключить интеграционный модуль стандартной библиотеки интеграции";
	Ошибка_ДобавитьВЖурналРегистрации(ТекстОшибки);
	Метрика_ДобавитьОшибку_НеЗаданыПараметрыИнтеграцииТиповогоМодуля();
	
КонецПроцедуры

