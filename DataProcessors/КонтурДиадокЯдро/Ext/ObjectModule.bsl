Функция Организации_ОсновноеПодразделения(Организация1С)

	ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(Организация1С);
	УчастникДО					= Организации_ЗаполнитьУчастникаДО(ИдентификаторыОрганизации);
	
	ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(УчастникДО.ОрганизацияЭДО, УчастникДО.BoxId);
	ДанныеОрганизации			= Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	ИдентификаторыПодразделения	= Новый_ИдентификаторыСправочника(, ДанныеОрганизации.ID_ОсновноеПодразделение);
	ДанныеПодразделения			= Подразделения_ЗаполненныеРеквизиты(ИдентификаторыПодразделения, ДанныеОрганизации);

	Результат = ДанныеПодразделения.Наименование;
	
	Возврат Результат;
	
