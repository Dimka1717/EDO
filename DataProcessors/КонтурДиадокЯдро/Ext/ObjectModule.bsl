Функция ОблачныеНастройкиСлужебный_Получить(ИдентификаторПродукта, ИдентификаторБазы, ЗаголовокАвторизации, КлючИБ)
	
	СервисОбновлений = Модуль_АпдейтКлиент(
			ЗаголовокАвторизации,
			КлючИБ);
	
	ВыборкаНастроек = СервисОбновлений.ВыбратьНастройкиИБ(
			ИдентификаторПродукта,
			ИдентификаторБазы);
	
	Результат = Новый Соответствие;
	
	Пока СервисОбновлений.Следующий(ВыборкаНастроек) Цикл
		
		ТекущийЭлемент = ВыборкаНастроек.ТекущийЭлемент;
		Если НЕ ЗначениеЗаполнено(ТекущийЭлемент)
			ИЛИ ТекущийЭлемент.ПометкаУдаления Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Вставить(ТекущийЭлемент.КлючНастроек, ТекущийЭлемент.Настройки);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

Функция ОблачныеНастройки_Получить(ИдентификаторПродукта, ИдентификаторБазы, ЗаголовокАвторизации, КлючИБ)
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Результат = Неопределено;
	
	Попытка
		
		Результат = ОблачныеНастройкиСлужебный_Получить(
				ИдентификаторПродукта,
				ИдентификаторБазы,
				ЗаголовокАвторизации,
				КлючИБ);
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеПолучениеНастроек(),
			НачалоЗамера
		);
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеПолучениеНастроек(),
			ИнформацияОбОшибке
		);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Процедура ОблачныеНастройкиСлужебный_ЗарегистрироватьИнформационнуюБазу(
		ИдентификаторПродукта,
		ИдентификаторБазы,
		ЗаголовокАвторизации)
	
	СервисОбновлений = Модуль_АпдейтКлиент(ЗаголовокАвторизации);
	
	ЗапросРегистрацииИБ = СервисОбновлений.ЗапросРегистрацииИБ();
	ЗапросРегистрацииИБ.Идентификатор = ИдентификаторБазы;
	
	РезультатСоздания = СервисОбновлений.ЗарегистрироватьИнформационнуюБазу(
			ИдентификаторПродукта,
			ЗапросРегистрацииИБ);
	
	ОблачныеНастройкиКлюч = СвойствоСтруктуры(РезультатСоздания, "Токен");
	Если ЗначениеЗаполнено(ОблачныеНастройкиКлюч) Тогда
		
		ОбщиеНастройки_Поместить("ОблачныеНастройкиКлюч", ОблачныеНастройкиКлюч);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОблачныеНастройки_ЗарегистрироватьИнформационнуюБазу(
		ИдентификаторПродукта,
		ИдентификаторБазы,
		ЗаголовокАвторизации)
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		ОблачныеНастройкиСлужебный_ЗарегистрироватьИнформационнуюБазу(
			ИдентификаторПродукта,
			ИдентификаторБазы,
			ЗаголовокАвторизации);
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеРегистрацияБазы(),
			НачалоЗамера
		);
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеРегистрацияБазы(),
			ИнформацияОбОшибке
		);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОблачныеНастройки_ДополнитьОбщийКонтекст() Экспорт
	
	ЗаголовокАвторизации = ЗаголовокАвторизацииИзКонтекста();
	ИдентификаторПродукта = ИдентификаторПродукта();
	ИдентификаторБазы = Строка(_ИдентификаторИнформационнойБазыДиадок());
	
	Если НЕ ЗначениеЗаполнено(ЗаголовокАвторизации) Тогда
		
		ИнформацияОбОшибке = "Отсутствует заголовок авторизации";
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеРегистрацияБазы(),
			ИнформацияОбОшибке
		);
		
		Возврат;
		
	КонецЕсли;
	
	КлючИБ = ОблачныеНастройки_ТокенДоступа();
	
	Если НЕ ЗначениеЗаполнено(КлючИБ) Тогда
		
		ОблачныеНастройки_ЗарегистрироватьИнформационнуюБазу(
			ИдентификаторПродукта,
			ИдентификаторБазы,
			ЗаголовокАвторизации);
		
		КлючИБ = ОблачныеНастройки_ТокенДоступа();
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючИБ) Тогда
		
		ДанныеНастроек = ОблачныеНастройки_Получить(
			ИдентификаторПродукта,
			ИдентификаторБазы,
			ЗаголовокАвторизации,
			КлючИБ);
		
		ОбщийКонтекст_Поместить("ОблачныеНастройки", ДанныеНастроек);
		
	Иначе
		
		ИнформацияОбОшибке = "Отсутствует значение настройки ОблачныеНастройкиКлюч";
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияОблачныеНастройки(),
			Метрика_ДействиеЧтениеТокена(),
			ИнформацияОбОшибке
		);
		
	КонецЕсли;
	
КонецПроцедуры

