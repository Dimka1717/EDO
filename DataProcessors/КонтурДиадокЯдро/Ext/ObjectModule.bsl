// Возвращает описание формата типа контента.
// Если тип контента не описан, то он по умолчанию считается неформализованным.
//
// Параметры:
//  ТипКонтента - Строка - Тип контента документа
//
// Возвращаемое значение:
//   Структура - Описание найденного типа контента. 
//
Функция Списки_ОписаниеФорматаКонтента(ТипКонтента) Экспорт
	
	ОписаниеФорматовКонтента = Кэш_Прочитать("ОписаниеФорматовКонтента_API_FormatVersion");
	
	Если ОписаниеФорматовКонтента = Неопределено Тогда
		
		ОписаниеФорматовКонтента = Новый Соответствие;
		
		ФорматыКонтентов = ПредопределенныеСписки_ФорматыКонтентов();
		
		Для Каждого СтрокаТЗ Из ФорматыКонтентов Цикл
			
			ОписаниеФормата = Общее_СтрокаТаблицыЗначенийВСтруктуру(СтрокаТЗ);
			ОписаниеФорматовКонтента.Вставить(СтрокаТЗ.API_FormatVersion, ОписаниеФормата);
			
		КонецЦикла;
		
		Кэш_Поместить("ОписаниеФорматовКонтента_API_FormatVersion", ОписаниеФорматовКонтента);
		
	КонецЕсли;
	
	Результат = ОписаниеФорматовКонтента.Получить(ТипКонтента);
	
	Если Результат = Неопределено Тогда
		Результат = ОписаниеФорматовКонтента.Получить("");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Списки_ОписаниеФорматаКонтента_AttachmentVersion(ТипКонтента)
	
	ОписаниеФорматовКонтента = Кэш_Прочитать("ОписаниеФорматовКонтента_API_AttachmentVersion");
	
	Если ОписаниеФорматовКонтента = Неопределено Тогда
		
		ОписаниеФорматовКонтента = Новый Соответствие;
		
		ФорматыКонтентов = ПредопределенныеСписки_ФорматыКонтентов();
		
		Для Каждого СтрокаТЗ Из ФорматыКонтентов Цикл
			
			ОписаниеФормата = Общее_СтрокаТаблицыЗначенийВСтруктуру(СтрокаТЗ);
			ОписаниеФорматовКонтента.Вставить(СтрокаТЗ.API_AttachmentVersion, ОписаниеФормата);
			
		КонецЦикла;
		
		Кэш_Поместить("ОписаниеФорматовКонтента_API_AttachmentVersion", ОписаниеФорматовКонтента);
		
	КонецЕсли;
	
	Результат = ОписаниеФорматовКонтента.Получить(ТипКонтента);
	
