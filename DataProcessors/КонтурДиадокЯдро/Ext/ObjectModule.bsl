Функция Списки_ОписаниеВидаПакета(ID) Экспорт
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(ID) Тогда
		
		ВидыПакетов = ПредопределенныеСписки_ВидыПакетов();
		Результат = ВидыПакетов.Получить(ID);
		
		Если НЕ ЗначениеЗаполнено(Результат) Тогда
			
			ИмяМетода = "Ядро.Списки_ОписаниеВидаПакета";
			ТекстОшибки = Общее_ПодставитьПараметрыВСтроку("%1: Отсутствует описание вида пакета (%2)", ИмяМетода, ID);
			Ошибка_ДобавитьВЛог(ТекстОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

