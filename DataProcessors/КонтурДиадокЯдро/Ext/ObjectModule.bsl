Функция Подразделения_ТаблицаКонтрактовПоDepartments(Organization) Экспорт
	
	Результат = Подразделения_НоваяТаблицаКонтрактов();
	
	МассивDepartments = Organization.Departments;
	
	Для Каждого Department Из МассивDepartments Цикл
		
		Если ИдентификаторЗаполнен(Department.DepartmentId) Тогда
			
			Подразделение = Подразделения_НовоеПодразделение(Organization, Department);
			
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Подразделение);
			
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Функция Подразделения_НоваяТаблицаКонтрактов()
	
	Результат = Новый ТаблицаЗначений;
	
	Результат.Колонки.Добавить("ID",						Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("ИНН",						Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(12)));
	Результат.Колонки.Добавить("КПП",						Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(9)));
	Результат.Колонки.Добавить("Наименование",				Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	Результат.Колонки.Добавить("Аббревиатура",				Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));
	Результат.Колонки.Добавить("ID_ОсновноеПодразделение",	Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
    Результат.Колонки.Добавить("ID_ВладелецПодразделения",	Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("ID_РодительПодразделения",	Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("Ссылка",					Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник1",		Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник2",		Неопределено);
	Результат.Колонки.Добавить("СвязанныйСправочник3",		Неопределено);
		
	Возврат Результат;               
	                         
КонецФункции

Функция Подразделения_НовоеПодразделение(Organization, Department)
	
	Результат = Контракт_ПодразделениеЭДО();
	
	Результат.ID				 		= Department.DepartmentId;
	Результат.Наименование				= Department.Name;
	
	Результат.ИНН				 		= СвойствоСтруктуры(Organization, "Inn", "");
	Результат.КПП						= СвойствоСтруктуры(Department, "Kpp", "");
	Результат.Аббревиатура				= СвойствоСтруктуры(Department, "Abbreviation", "");
	
	Результат.ID_ВладелецПодразделения	= Organization.Boxes[0].BoxId;
	
	Если ИдентификаторЗаполнен(Department.ParentDepartmentId) Тогда
		Результат.ID_РодительПодразделения = Department.ParentDepartmentId;
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

