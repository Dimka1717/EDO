// Определяет использование подписки для стартового тарифа
//
// Параметры:
//  ИдентификаторЯщика - Строка - адрес или идентификатор ящика
//  Сессия - ФиксированнаяСтруктура - см. МодельСессияПользователя
// 
// Возвращаемое значение:
//  Булево - Признак использования стартового тарифа организацией
//
Функция КонтурШлюзАвторизации_ЭтоСтартовыйТариф(Знач ИдентификаторЯщика, Сессия) Экспорт
	
	Результат = Ложь;
	
	АдресСервиса = АдресШлюзаАвторизации();
	НастройкиКлиента = НастройкиКлиентаAPI(АдресСервиса, Сессия.ТокенДоступа, Сессия.ТипТокена);
	
	ИдентификаторТарифаСтартовый = КонтурШлюзАвторизации_ИмяСервисаСтартовыйУМ();
	
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(ИдентификаторЯщика);
	ДанныеБиллинга = КонтурШлюзАвторизации_АвторизацияБиллинга(ИдентификаторЯщика, НастройкиКлиента);
	
	Если ЗначениеЗаполнено(ДанныеБиллинга) 
		И ДанныеБиллинга.СервисПодпискиНаМодуль.Идентификатор = ИдентификаторТарифаСтартовый Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

