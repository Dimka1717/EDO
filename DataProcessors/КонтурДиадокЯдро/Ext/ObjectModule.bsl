КонецФункции

Функция Списки_ТаблицаИспользуемыхВидовПакетов()
	
	Результат = Новый ТаблицаЗначений;
	
	ПараметрыСтроки = Новый КвалификаторыСтроки(50);
	
	Результат.Колонки.Добавить("ID",				Новый ОписаниеТипов("Строка", , ПараметрыСтроки));
	Результат.Колонки.Добавить("КатегорияПакета",	Новый ОписаниеТипов("Строка", , ПараметрыСтроки));
	Результат.Колонки.Добавить("ПоУмолчанию",		Новый ОписаниеТипов("Булево"));
	Результат.Колонки.Добавить("УПД",				Новый ОписаниеТипов("Булево"));
	
	ВидыПакетов	= ПредопределенныеСписки_ВидыПакетов();
	
	Для Каждого КлючЗначение Из ВидыПакетов Цикл
		ЗаполнитьЗначенияСвойств(Результат.Добавить(), КлючЗначение.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МассивВидовПакетов(КатегорияПакета = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	ВидыПакетов	= ПредопределенныеСписки_ВидыПакетов();
	
	Для Каждого КлючЗначение Из ВидыПакетов Цикл
		
		ВидПакета = КлючЗначение.Значение;
		
		ДобавитьВидПакета = КатегорияПакета = Неопределено
							ИЛИ КатегорияПакета = ВидПакета.КатегорияПакета;
		
		Если ДобавитьВидПакета Тогда
							
			ИдентификаторВида	= ВидПакета.ID;
			СсылкаНаВидПакета	= ХранениеДанных_СсылкаПоИдентификаторуДопСправочника("ВидыПакетов", ИдентификаторВида);
			
			СтруктураВидаПакета = Новый Структура;
			СтруктураВидаПакета.Вставить("Ссылка",			СсылкаНаВидПакета);
			СтруктураВидаПакета.Вставить("Идентификатор",	ИдентификаторВида);
			СтруктураВидаПакета.Вставить("Наименование",	ВидПакета.Наименование);
			
			Результат.Добавить(СтруктураВидаПакета);
		
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МассивВидовДокументов() Экспорт
	
	Результат = Новый Массив;
	
	ВидыДокументов = ПредопределенныеСписки_ВидыДокументов();
	
	Для Каждого Элемент Из ВидыДокументов Цикл
		
		Идентификатор	 = Элемент.Ключ;
		ОписаниеВида	 = Элемент.Значение;
		Наименование	 = ОписаниеВида.Наименование;
		
		Ссылка = ХранениеДанных_СсылкаПоИдентификаторуДопСправочника("ВидыДокументов", Идентификатор);
		
		НовыйЭлемент = Новый Структура;
		НовыйЭлемент.Вставить("Ссылка"			, Ссылка);
		НовыйЭлемент.Вставить("Идентификатор"	, Идентификатор);
		НовыйЭлемент.Вставить("Наименование"	, Наименование);
		
		Результат.Добавить(НовыйЭлемент);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

