// Загружает список уведомлений из сервиса и заполняет отметки о прочтении.
//
// Параметры:
//  КлючНастроек - Строка - Идентификатор формы-владельца уведомлений
//  Фильтр - Структура - Параметры для отбора уведомлений
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. Контракт_СписокУведомлений
//
Функция УведомленияПользователей_СписокУведомлений(КлючНастроек, Фильтр)
	
	Уведомления = Уведомления_ПолучитьСписок(Фильтр);
	
	Результат = Контракт_СписокУведомлений();
	
	ОтметкиОПрочтении = УведомленияПользователей_ПрочитатьТаблицуСостояний(КлючНастроек);
	
	Для Каждого Элемент Из Уведомления Цикл
		
		НоваяСтрокаУведомлений = Результат.Добавить();
		
		НоваяСтрокаУведомлений.Ид = Элемент.Ид;
		НоваяСтрокаУведомлений.ДатаНачала = Элемент.ДатаНачала;
		НоваяСтрокаУведомлений.ДатаОкончания = Элемент.ДатаОкончания;
		НоваяСтрокаУведомлений.Важное = УведомленияПользователей_ЭтоВажноеУведомление(Элемент.Приоритет);
		
		УведомленияПользователей_РазобратьКонтент(НоваяСтрокаУведомлений, Элемент.Контент);
		
		НоваяСтрокаУведомлений.Прочитано = УведомленияПользователей_ОтметкаОПрочтении(
			Элемент.Ид,
			ОтметкиОПрочтении
		);
		
		Если Не ЗначениеЗаполнено(НоваяСтрокаУведомлений.Текст) Тогда
			
			ТекстОшибки = "Пустое тело уведомления";
			
			Метрика_ДобавитьОшибку_ЗаполнениеКонтентаУведомления(
				ТекстОшибки,
				НоваяСтрокаУведомлений.Ид
			);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат
	
КонецФункции

