		КонецЕсли;
		
		Если МодулиОФ.НайтиПоЗначению(МаркерИМ) <> Неопределено Тогда
			Результат = ИмяТиповогоМодуляОФ();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
