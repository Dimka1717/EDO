// Возвращает значение настройки "Передавать МЧД файлом" для контрагента или организации
//
// Параметры:
//  ДанныеОрганизации	 - Структура 				- см. Организация_ЗаполненныеРеквизиты
//  ДанныеКонтрагента	 - Структура, Неопределено	- см. Контрагенты_ЗаполненныеРеквизиты
// 
// Возвращаемое значение:
//  Булево - Истина - настройка включена, Ложь - нет
//
Функция НастройкиДокументов_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт

	Результат = ХранениеДанных_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации, ДанныеКонтрагента);
	Если Результат = Неопределено Тогда
		
		Результат = ХранениеДанных_ЗначениеНастройкиПередаватьМЧДФайлом(ДанныеОрганизации);	
		
		ТипНастройки = Тип("Булево");
		ЗначениеПоУмолчанию = Ложь;
		
		Результат = ЗначениеНастройки(Результат, ТипНастройки, ЗначениеПоУмолчанию);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

