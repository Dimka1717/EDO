Функция Пакеты_ДокументыПакетаАПИ(Идентификаторы) Экспорт
	
	Результат = Новый Массив;
	
	BoxId		= Идентификаторы.BoxId;
	LetterId	= Идентификаторы.LetterId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	DocumentList = АПИ_GetDocumentsByMessageId(ПараметрыСервиса, BoxId, LetterId);
	
	МассивDocuments = DocumentList.Documents;
	
	Для Каждого ТекДокумент Из МассивDocuments Цикл
		
		ИдентификаторыДокумента = Новый Структура;
		ИдентификаторыДокумента.Вставить("ДокументАПИ",	ТекДокумент);
		ИдентификаторыДокумента.Вставить("BoxID", 		BoxId);
		ИдентификаторыДокумента.Вставить("LetterID", 	ТекДокумент.MessageId);
		ИдентификаторыДокумента.Вставить("DocumentID",	ТекДокумент.EntityId);
		
		Результат.Добавить(ИдентификаторыДокумента);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции	

//Перезаполняет пакеты по переданным строкам списка документов
//
//Параметры:
//    СтрокиСписка     - Массив из Структур - строки списка документов см. Новый_СписокДокументов()
//
//Возвращаемое значение:
//    Массив - элементы массива:
//  Структура:
//    * ПерезаполняемыйПакет - Структура - см. Контракт_Пакет().
//    * ПерезаполненныйПакет - Структура - см. Контракт_Пакет().
//    * СтрокаСписка         - Структура - см. Новый_СписокДокументов().
//    * ПакетОтправлен         - Булево     - Истина если у исходной строки списка заполнен LetterId.
//
//
Функция Пакеты_ПерезаполнитьПакетыПоСтрокамСписка(СтрокиСписка) Экспорт

	Результат = Новый Массив;
	
	Для каждого СтрокаСписка Из СтрокиСписка Цикл
	
		ПакетОтправлен = ЗначениеЗаполнено(СтрокаСписка.LetterId);
		
		ПерезаполняемыйПакет = Неопределено;
			
		Если ЗначениеЗаполнено(СтрокаСписка.Пакет)
			ИЛИ ЗначениеЗаполнено(СтрокаСписка.LetterId) Тогда
			
			ПерезаполняемыйПакет = Контракт_ИдентификаторыПакета();
			ПерезаполняемыйПакет.LetterId	= СтрокаСписка.LetterId;
			ПерезаполняемыйПакет.ПакетЭДО	= СтрокаСписка.Пакет;
			
		КонецЕсли;
		
		ПерезаполненныйПакет = СписокДокументов_ОбновитьДанныеСтрокиПакетаНаОтправку(СтрокаСписка);
		
		Если ЗначениеЗаполнено(ПерезаполненныйПакет)
			И ЗначениеЗаполнено(ПерезаполняемыйПакет) Тогда
			
			ЗначениеПоУмолчанию = Новый Структура("BoxId", "");
			Идентификаторы = СвойствоСтруктуры(ПерезаполненныйПакет, "Идентификаторы", ЗначениеПоУмолчанию);
			ПерезаполняемыйПакет.BoxId = Идентификаторы.BoxId;
			
		КонецЕсли;
		
		ОписаниеПакета = Новый Структура;
		ОписаниеПакета.Вставить("ПерезаполняемыйПакет"	, ПерезаполняемыйПакет);
		ОписаниеПакета.Вставить("ПерезаполненныйПакет"	, ПерезаполненныйПакет);
		ОписаниеПакета.Вставить("СтрокаСписка"			, СтрокаСписка);
		ОписаниеПакета.Вставить("ПакетОтправлен"		, ПакетОтправлен);
		
		Результат.Добавить(ОписаниеПакета);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

//Очищает подготовленные пакеты которые уже были отправлены
//
Процедура Пакеты_ВыполнитьОчисткуУстаревшихПодготовленных() Экспорт
	
	ХранениеДанных = Модуль_ХранениеДанных(ЭтотОбъект);
	ХранениеДанных.Пакеты_ВыполнитьОчисткуУстаревшихПодготовленных();
	
КонецПроцедуры

Процедура Пакеты_ДобавитьВПакетДокументыСДиска(Пакет, КлючПакета)
	
	ДокументыСДиска = Пакеты_ДокументыСДискаПрочитатьИзКэша(КлючПакета);
	
	Если ЗначениеЗаполнено(ДокументыСДиска) Тогда
		ЗашифрованныйПакет = СвойствоСтруктуры(Пакет.СлужебнаяИнформация,
		"ЗашифрованныйПакет",
		Ложь);
	Иначе
		ЗашифрованныйПакет = Неопределено;
	КонецЕсли;
	
	Для Каждого ДокументСДиска Из ДокументыСДиска Цикл
		
		ДокументВПакет = КопияКоллекцииЗначений(ДокументСДиска);
		
		ДокументВПакет.Отправитель = Пакет.Отправитель;
		ДокументВПакет.Получатель = Пакет.Получатель;
		ДокументВПакет.ИдентификаторВидаПакета = Пакет.ИдентификаторВида;
		ДокументВПакет.Шаблон = Пакет.Шаблон;
		ДокументВПакет.Идентификаторы.BoxId = Пакет.Отправитель.BoxID;
		ДокументВПакет.СлужебнаяИнформация.ПараметрыОтправки.ЗашифрованныйПакет = ЗашифрованныйПакет;
		
		Пакет.Документы.Добавить(ДокументВПакет);
		
	КонецЦикла;
	
КонецПроцедуры

//ПОДПИСАНИЕ ПАКЕТА

Функция Пакеты_ПередПодписаниемПакетаНаОтправку(Пакет) Экспорт
	
	Результат = Истина;
	
	ЗаполнитьПодписантаВОтложенномПакете = Пакеты_ПакетОтправлен(Пакет);
	
	Пакет_ДополнитьДокументыСведениямиМЧД(Пакет);
	
	ПолномочияЗаполнены = ПолномочияПодписанта_ЗаполненыДляДокументовПакета(Пакет);
	
	Если ЗаполнитьПодписантаВОтложенномПакете Тогда
		
		Если ПолномочияЗаполнены Тогда
			
			Попытка
				Пакеты_ЗаполнитьПодписантаВОтложенномПакете(Пакет);
			Исключение
				
				Ошибка			= ИнформацияОбОшибке();
				ПодробнаяОшибка	= ПодробноеПредставлениеОшибки(Ошибка);
				
				ВидОперации		 = "Отправка отложенного пакета документов";
				Представление	= ПредставлениеПакета(Пакет);
				ТекстОшибки		= "Пакет: %1 Не удалось заполнить подписанта в отложенном пакете документов: %2";
				ТекстОшибки		= Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Представление, ПодробнаяОшибка);
				
				Ошибка_Обработать(ВидОперации, ТекстОшибки);
				
				Результат = Ложь;
				
			КонецПопытки;
			
		Иначе
			Результат = Ложь;
		КонецЕсли;
		
		Пакет.СлужебнаяИнформация.Вставить("ОтложеннаяОтправка", Истина);
		
	Иначе
		
		Если ПолномочияЗаполнены Тогда
			Пакеты_ЗаполнитьМетаданныеДокументов(Пакет, Истина, Истина);
		Иначе
			Результат = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ПередПодписаниемПакетовНаОтправку(Пакеты) Экспорт
	
	Результат = Новый Массив;
	
	Для каждого Пакет Из Пакеты Цикл
		
		Если Пакет.Шаблон Тогда 
			РезультатПроверки = Истина;
		Иначе
			РезультатПроверки = Пакеты_ПередПодписаниемПакетаНаОтправку(Пакет);
		КонецЕсли;
		
		Если РезультатПроверки Тогда
		
			Результат.Добавить(Пакет);
		
		КонецЕсли;
	
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ПодписатьПакетНаОтправку(Пакет) Экспорт
	
	Пакеты_ДобавитьПодписиФайловПакета(Пакет); // второй параметр - это пинкод.
	
	ЗашифрованныйПакет = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ЗашифрованныйПакет", Ложь);
	
	Если ЗашифрованныйПакет Тогда
		Пакеты_ЗашифроватьФайлыВПакете(Пакет);
	КонецЕсли;
	
КонецПроцедуры

Процедура Пакеты_ЗаполнитьПодписантаВОтложенномПакете(Пакет) Экспорт 
	
	BoxId = Пакет.Идентификаторы.BoxId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);	
	
	PrepareDocumentsToSignRequest = АПИ_Новый_PrepareDocumentsToSignRequest(BoxId);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		Если НЕ Документ.Тип.Формализованный Тогда
			Продолжить;
		КонецЕсли;
		
		DocumentId      = АПИ_Новый_DocumentId(Документ.Идентификаторы.LetterID, Документ.Идентификаторы.DocumentID);
		DocumentToPatch = АПИ_Новый_DocumentToPatch(DocumentId);
		
		ТипКонтента = Документ.Тип.ТипКонтента;
		ТипыКонтента = Перечисление_ТипыКонтентов();
		
		Если Подписант_ИспользоватьДетальныеДанные(ТипКонтента) Тогда
			
			ExtendedSigner = ЗаполненныйExtendedSigner(Документ); 
			DocumentToPatch.ExtendedSigner.Добавить(ExtendedSigner);
			
		ИначеЕсли ТипКонтента = ТипыКонтента.Utd970
			Или ТипКонтента = ТипыКонтента.proformainvoice29
			Или ТипКонтента = ТипыКонтента.invoiceoffer29 Тогда
			
			SignerContent = Подписант_ЗаполненныйSignerContentДляОтложенногоПакетаУПД970(Документ);
			DocumentToPatch.Вставить("SignerContent", SignerContent);
			
		ИначеЕсли ЭтоФормализованныйАктСверки405(ТипКонтента) Тогда
			
			SignerContent = Подписант_ЗаполненныйSignerContentДляОтложенногоПакетаАктаСверки405(Документ);
			DocumentToPatch.Вставить("SignerContent", SignerContent);
			
		Иначе
			Signer = ЗаполненныйSigner(BoxId);
			DocumentToPatch.Вставить("Signer", Signer);
		КонецЕсли;
		
		PrepareDocumentsToSignRequest.Documents.Добавить(DocumentToPatch);
		
	КонецЦикла;
	
	PrepareDocumentsToSignResponse = АПИ_PrepareDocumentsToSign(ПараметрыСервиса, PrepareDocumentsToSignRequest);
	
	Для Каждого DocumentPatchedContent Из PrepareDocumentsToSignResponse.DocumentPatchedContents Цикл
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("LetterID",   DocumentPatchedContent.DocumentId.MessageId);
		ПараметрыОтбора.Вставить("DocumentID", DocumentPatchedContent.DocumentId.EntityId);
		
		Для Каждого Документ Из Пакет.Документы Цикл
			
			LetterID	= Документ.Идентификаторы.LetterID;
			DocumentID	= Документ.Идентификаторы.DocumentID;
			
			Если DocumentID = ПараметрыОтбора.DocumentID
				И LetterID = ПараметрыОтбора.LetterID Тогда
				
				Документ.СлужебнаяИнформация.Вставить("PatchedContentId", DocumentPatchedContent.PatchedContentId);
				
				ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
				ХранилищеКонтента.Данные = Base64Значение(DocumentPatchedContent.Content);
				
				Прервать;
				
			КонецЕсли;	
			
		КонецЦикла;	
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПодготовитьSignerDetails(BoxId)
	
	Результат = Новый Структура;
	
	СтрокаКонтекста	= КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	
	Если СтрокаКонтекста = Неопределено Тогда
		Сообщить("Отсутствует контекст для ящика " + BoxId, СтатусСообщения.Важное);
		Возврат Результат;
	КонецЕсли;
	
	Фамилия		= СтрокаКонтекста.ОписаниеПользователя.Фамилия;
	Имя			= СтрокаКонтекста.ОписаниеПользователя.Имя;
	Отчество	= СтрокаКонтекста.ОписаниеПользователя.Отчество;
	Должность	= СтрокаКонтекста.ОписаниеПользователя.Должность;
	ИНН			= СтрокаКонтекста.Box.Organization.Inn;
	
	Результат = АПИ_Новый_SignerDetails(Фамилия, Имя, Отчество, Должность, ИНН);
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ДобавитьПодписиФайловПакета(Пакет, ПарольКонтейнера = "") Экспорт 
	
	BoxId = Пакет.Идентификаторы.BoxId;
	ОтпечатокСертификата = КонтекстСеанса_Прочитать(BoxId, "ОтпечатокСертификата");
	
	Если ОтпечатокСертификата = "" Тогда 
		ВызватьИсключение "Подписание доступно только при авторизации по сертификату";	
	КонецЕсли;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		ХранилищеКонтента						= СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
		ДвоичныеДанные							= ХранилищеКонтента.Данные;
		ХранилищеКонтента.Подпись.ДанныеПодписи = ПодписатьДанные(ДвоичныеДанные, ОтпечатокСертификата, ПарольКонтейнера);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Пакеты добавить подписи госключ файлов пакета
//
// Параметры:
//  Пакет						 - Структура  - см. Пакеты_НовыйПакет
//  РезультатПодписанияГосключ	 - Структура  - см. Контракт_РезультатПодписанияГосключ()
//
Процедура Пакеты_ДобавитьПодписиГосключФайловПакета(Пакет, РезультатПодписанияГосключ) Экспорт
	
	ДокументыПакета = Пакет.Документы;
	РезультатыПодписания = РезультатПодписанияГосключ.СписокРезультатовПодписанияФайлов;
	
	КоличествоДокументовПакета = ДокументыПакета.Количество();
	КоличествоРезультатов = РезультатыПодписания.Количество();
	
	Если КоличествоДокументовПакета <> КоличествоРезультатов Тогда
		// BSLLS:Typo-off
		ТекстОшибки = НСтр("ru = 'Количество результатов подписания госключем не совпадает
		|с количеством переданных документов'");
		// BSLLS:Typo-on
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Для НомерДокумента = 0 По КоличествоДокументовПакета - 1 Цикл
		Документ = ДокументыПакета[НомерДокумента];
		РезультатПодписания = РезультатыПодписания[НомерДокумента];

		ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
		ХранилищеКонтента.Подпись.ДанныеПодписи = Base64Значение(РезультатПодписания.ЭлектроннаяПодпись);
	КонецЦикла;
	
КонецПроцедуры

Процедура Пакеты_ЗашифроватьФайлыВПакете(Пакет) Экспорт 
	
	МассивСертификатов = Пакеты_СертификатыДляШифрования(Пакет);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		ХранилищеКонтента						= СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
		ДвоичныеДанные							= ХранилищеКонтента.Данные;
		ХранилищеКонтента.ЗашифрованныеДанные	= ЗашифроватьДанные(ДвоичныеДанные, МассивСертификатов);
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_СертификатыДляШифрования(Пакет)
	
	BoxId				 = Пакет.Отправитель.BoxId;
	CounteragentBoxId	 = Пакет.Получатель.BoxId;
	
	КлючКэш = "СертификатыДляШифрования_" + BoxId + "_" + CounteragentBoxId;
	
	Результат = Кэш_Прочитать(КлючКэш);
	
	Если Результат = Неопределено Тогда
		ПараметрыСобытия = Новый Структура;
		ПараметрыСобытия.Вставить("Пакет", Пакет);
		Результат = ПодключаемыйМодуль_ОбработатьСобытие("ПолучитьСертификатыДляШифрования", ПараметрыСобытия);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		Результат = Документы_СертификатыДляШифрованияИзДиадока(BoxId, CounteragentBoxId);
		Кэш_Поместить(КлючКэш, Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


//ОТПРАВКА ПАКЕТОВ

// Заполнение реквизитов электронных документов добавленных в ручную по метаданным 
//
// Параметры:
//  Пакет	 - Структура - см. Контракт Новый_Пакет 
//
Процедура Пакеты_ЗаполнитьРеквизитыДокументов(Пакет) Экспорт
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		ДокументДобавленВРучную = Не ЗначениеЗаполнено(Документ.ИдентификаторВида);
		
		Если ДокументДобавленВРучную Тогда
			
			Документы_ЗаполнитьРеквизитыПодготовленногоДокумента(Документ);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_МаксКоличествоДокументовMessageToPost() Экспорт
	
	Возврат 30;
	
КонецФункции

Функция Пакеты_ПакетОтправлен(Пакет) Экспорт
	
	Результат = ЗначениеЗаполнено(Пакет.Идентификаторы.LetterId);
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ОтправитьИСохранить(Пакет) Экспорт
	
	ОтложеннаяОтправка		= СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОтложеннаяОтправка", Ложь);
	ПакетОтправлен			= Пакеты_ПакетОтправлен(Пакет);
	ЕстьСогласование		= Пакеты_СодержитДокументыДляСогласования(Пакет);
	ПроизвольныйПакет		= НЕ ЗначениеЗаполнено(Пакет.ИдентификаторВида);
	ПопыткаОтправкиДубля	= Ложь;
	Результат				= Ложь;
	
	Если Не ЕстьСогласование Тогда
		
		ДействиеЭДО = Перечисление_ДействияЭДО().Отправить;
		ОписаниеОшибкиПроверкиКЭП = КЭП_ДоступноДействиеЭДО(ДействиеЭДО, Пакет.Идентификаторы.BoxID);
		Если ЗначениеЗаполнено(ОписаниеОшибкиПроверкиКЭП) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Пакет_ДополнитьДокументыСведениямиМЧД(Пакет);
		
	КонецЕсли;
	
	Если ОтложеннаяОтправка И ПакетОтправлен Тогда
		
		ОтправкаВыполнена = Пакеты_ОтправитьОтложенный(Пакет);
		
	Иначе
		
		Если Пакет.Шаблон Тогда
			ОтправкаВыполнена = Пакеты_ОтправитьШаблоны(Пакет);
		Иначе
			
			Если ЕстьСогласование Тогда
				Пакет.СлужебнаяИнформация.Вставить("ОтложеннаяОтправка", Истина);
			КонецЕсли;
			
			ОтправкаВыполнена = Пакеты_Отправить(Пакет);
			
		КонецЕсли;
		
		Если ОтправкаВыполнена Тогда
			ПопыткаОтправкиДубля = НЕ Пакеты_ПакетОтправлен(Пакет);
		Иначе
			
			ТекстОшибки = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОшибкиОтправки");
			
			Если НЕ ЗначениеЗаполнено(ТекстОшибки) Тогда
				ТекстОшибки = "Ошибки отправки";
				Пакет.СлужебнаяИнформация.Вставить("ОшибкиОтправки", ТекстОшибки);
			КонецЕсли;
			
			Ключ = Новый_КлючИдентификатораСтроки(Пакет.ДокументУчета, Пакет.ИдентификаторВида);
			КэшОшибокСтрокСписка_Поместить(Ключ, ТекстОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПопыткаОтправкиДубля Тогда
		
		ВидОперации			= "Отправка пакета документов";
		ПредставлениеПакета	= ПредставлениеПакета(Пакет);
		ТекстСообщения		= "Не удалось отправить пакет %1
							  |%2. 
							  |Для отправки пакета перейдите в карточку документа.";
		ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку(
			ТекстСообщения,
			ПредставлениеПакета,
			Ошибка_ПакетОтправленРанее()
		);
		ИдентификаторФормы	= ОбщийКонтекст_Прочитать("ИдентификаторФормы");
		
		Ошибка_Обработать(ВидОперации, , , ТекстСообщения, ИдентификаторФормы);
		
	ИначеЕсли ОтправкаВыполнена ИЛИ НЕ ПроизвольныйПакет Тогда
		
		Пакеты_Сохранить(Пакет);
		
	КонецЕсли;
	
	ПакетОтправлен = Пакеты_ПакетОтправлен(Пакет);
	
	Если ПакетОтправлен И ЕстьСогласование Тогда
		Пакеты_МаршрутизироватьДокументы(Пакет);
	КонецЕсли;
	
	Если ПакетОтправлен Тогда
		Ключ = Новый_КлючИдентификатораСтроки(Пакет.ДокументУчета, Пакет.ИдентификаторВида);
		КэшОшибокСтрокСписка_Удалить(Ключ);
	КонецЕсли;	
	
	Результат = ОтправкаВыполнена И НЕ ПопыткаОтправкиДубля;
	
	Если Результат Тогда
		Конвертация970_ЗаписатьПредупрежденияКонвертацииВЖурналРегистрации(Пакет);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

// Проверяет список накопленных ошибок на наличие ошибки о повторной отправке пакета
// 
// Возвращаемое значение:
//  Булево - Истина, если есть ошибка о повторной отправке пакета
//
Функция СписокОшибок_ЕстьОшибкаКонтроляДублированияОтправки() Экспорт
	
	Результат = Ложь;
	
	СписокОшибок = СписокОшибок();
	ВидОперации = НСтр("ru='Отправка пакета документов.'");
	КлючТекстаСообщения = НСтр("ru='ТекстСообщения'");
	
	СообщениеОтправкиПакета = МассивСтруктур_Найти(
		СписокОшибок,
		ВидОперации,
		КлючТекстаСообщения
	);
	
	Если СообщениеОтправкиПакета = Неопределено Тогда
		
		Возврат Результат;
		
	КонецЕсли;
	
	ТекстОшибкиКонтроляДублирования = Ошибка_ПакетОтправленРанее();
	
	Для Каждого СтрокаСообщения Из СообщениеОтправкиПакета.Строки Цикл
		
		Если Найти(СтрокаСообщения.ТекстСообщения, ТекстОшибкиКонтроляДублирования) > 0 Тогда
			
			Результат = Истина;
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Ошибка_ПакетОтправленРанее()
	Возврат "Этот пакет уже был отправлен ранее";
КонецФункции

Функция Ошибка_КоличествоДокументовПакетаНеПоддержаноДляТЭДО(ИмяПакета, Документ1С)
	
	ШаблонСтроки = НСтр(
		"ru='Не удалось отправить пакет %1 по документу %2 по причине:
		|""В трансграничном пакете должно быть не более одного документа"".'");
	
	Результат = Общее_ПодставитьПараметрыВСтроку(
		ШаблонСтроки,
		ИмяПакета,
		Документ1С
	);
	
	Возврат Результат;
	
КонецФункции

Функция Ошибка_ТипДокументаНеПоддержанВРоуминге(ИмяПакета, Документ1С, ИдентификаторФНС, ТипЭД)
	
	ФорматОтправки = ФорматОтправкиПоТипуДокумента(ТипЭД);
	
	ШаблонСтроки = НСтр(
		"ru='Не удалось отправить пакет %1 по документу %2 по причине:
		|""Оператор получателя не поддерживает данный тип документа"".
		|
		|ФНСИД оператора: %3.
		|Тип документа: %4.
		|Версия документа: %5.
		|Функция документа: %6.'");
	
	Результат = Общее_ПодставитьПараметрыВСтроку(
		ШаблонСтроки,
		ИмяПакета,
		Документ1С,
		ИдентификаторФНС,
		ФорматОтправки.ИмяТипа,
		ФорматОтправки.ВерсияФормата,
		ФорматОтправки.ФункцияДокумента
	);
	
	Возврат Результат;
	
КонецФункции

Функция Ошибка_ИсключениеБезКатегорииПриОтправкеПакета(Ошибка, Пакет)
	
	ШаблонОшибки = НСтр("ru='Пакет: %1 Не удалось отправить пакет документов: %2'");
	Представление = ПредставлениеПакета(Пакет);
	ПодробнаяОшибка = ПодробноеПредставлениеОшибки(Ошибка);
	
	Результат = Общее_ПодставитьПараметрыВСтроку(ШаблонОшибки, Представление, ПодробнаяОшибка);
	
	Возврат Результат;
	
КонецФункции

// Отправляет Пакеты
// 
// Параметры:
//  Пакеты -Массив из Структура - Электронные пакеты документов (см. Контракт_Пакет).
// 
Функция Пакеты_ОтправитьИСохранитьПоСписку(Пакеты) Экспорт 
	
	Для каждого Пакет Из Пакеты Цикл
	
		Пакеты_ОтправитьИСохранить(Пакет);
		
	КонецЦикла;
	
	Возврат Неопределено; // Функция используется как процедура, результат не важен.
	
КонецФункции

Функция Пакеты_Сохранить(Пакет) Экспорт
	
	Результат = ХранениеДанных_ЗаписатьПакет(Пакет);
	
	Пакет.Идентификаторы.ПакетЭДО = Результат;
	
	Если Пакет.Состояние = Перечисление_СтатусыПакетов().Отправлен Тогда
		
		ОтложеннаяОтправка = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОтложеннаяОтправка", Ложь);
		
		ПараметрыПМ = Новый Структура;
		ПараметрыПМ.Вставить("Пакет",				Пакет);
		ПараметрыПМ.Вставить("ОтложеннаяОтправка",	ОтложеннаяОтправка);
		
		ПодключаемыйМодуль_ОбработатьСобытие("ПослеОтправкиПакета", ПараметрыПМ);
		
		Пакеты_ОбновитьКомментарийДокументаУчета(Пакет);
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

// Сохраняет пакеты по массиву пакетов
// 
// Параметры:
//  Пакеты -Массив из Структура - Электронные пакеты документов (см. Контракт_Пакет).
// 
Процедура Пакеты_СохранитьПоСписку(Пакеты) Экспорт
	
	Для каждого Пакет Из Пакеты Цикл
	
		Пакеты_Сохранить(Пакет);
	
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_Отправить(Пакет)
	
	Отказ					= Ложь;
	ПопыткаОтправкиДубля	= Ложь;
	
	MessageToPost = ПодготовитьMessageToPost(Пакет);
	
	МаксКоличествоДокументовMessageToPost = Пакеты_МаксКоличествоДокументовMessageToPost();
	
	ПорцииDocumentAttachments = ПорцииДанныхМассива(MessageToPost.DocumentAttachments, МаксКоличествоДокументовMessageToPost);
	
	InitialDocumentId		= Неопределено;
	ПредыдущийLetterID		= Неопределено;
	МаксКолПопытокОтправки	= 100;
	
	Для Каждого DocumentAttachments Из ПорцииDocumentAttachments Цикл
		
		Пакеты_УстановитьСвязиСПервымДокументом(DocumentAttachments);
		
		MessageToPost.DocumentAttachments = DocumentAttachments;
		
		Если InitialDocumentId <> Неопределено Тогда
			MessageToPost.DocumentAttachments[0].InitialDocumentIds.Добавить(InitialDocumentId);
		КонецЕсли;
		
		OperationId = Пакеты_ИдентификаторОперации(Пакет, ПредыдущийLetterID);
		
		РезультатОтправки = Пакеты_ОтправитьPostMessage(Пакет, MessageToPost, OperationId);
		
		Отказ = (РезультатОтправки = Неопределено);
		ПопыткаОтправкиДубля = (НЕ Отказ И НЕ Пакеты_ПакетОтправлен(Пакет));
		
		КолПопытокОтправки = 1;
		
		Пока ПопыткаОтправкиДубля Цикл
			
			BoxId		= Пакет.Идентификаторы.BoxId;
			MessageId	= РезультатОтправки.MessageId;
			
			ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
			Message	= АПИ_GetMessage(ПараметрыСервиса, BoxId, MessageId);
			
			Если Message.IsDeleted Тогда
				
				OperationId = Пакеты_ИдентификаторОперации(Пакет, MessageId + "_IsDeleted");
				РезультатОтправки = Пакеты_ОтправитьPostMessage(Пакет, MessageToPost, OperationId);
				
				Отказ = (РезультатОтправки = Неопределено);
				ПопыткаОтправкиДубля = (НЕ Отказ И НЕ Пакеты_ПакетОтправлен(Пакет));
				
			Иначе
				Прервать;
			КонецЕсли;
			
			КолПопытокОтправки = КолПопытокОтправки + 1;
			
			Если КолПопытокОтправки > МаксКолПопытокОтправки Тогда
				
				ВидОперации			= "Отправка пакета документов";
				ПредставлениеПакета	= ПредставлениеПакета(Пакет);
				ТекстСообщения		= "Не удалось отправить пакет %1
									  |Превышено допустимое количество попыток отправки пакета.";
				ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПредставлениеПакета);
				
				Ошибка_Обработать(ВидОперации, , , ТекстСообщения);
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Отказ ИЛИ ПопыткаОтправкиДубля Тогда
			Прервать;
		Иначе
			
			ПредыдущийLetterID = РезультатОтправки.MessageId;
			
			Если InitialDocumentId = Неопределено Тогда
				Идентификаторы = Пакет.Документы[0].Идентификаторы;
				InitialDocumentId = АПИ_Новый_DocumentId(Идентификаторы.LetterId, Идентификаторы.DocumentId);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Отказ ИЛИ ПопыткаОтправкиДубля Тогда
		Пакеты_УдалитьОтправленныеДокументы(Пакет);
		Пакеты_УстановитьСтатусПодготовлен(Пакет);
	Иначе
		Если InitialDocumentId <> Неопределено Тогда
			Пакет.Идентификаторы.LetterId = InitialDocumentId.MessageId;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыПереотправки = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ПараметрыПереотправки");
	
	УдалятьПриПереотправкеПредыдущийДокумент = ЗначениеНастройки_УдалитьПредыдущийДокумент();
	
	ТребуетсяУдалитьИсходныйПакет = НЕ Отказ
									И УдалятьПриПереотправкеПредыдущийДокумент
									И ПараметрыПереотправки <> Неопределено
									И ЗначениеЗаполнено(ПараметрыПереотправки.ПереотправляемыйПакет.LetterId);
	
	Если ТребуетсяУдалитьИсходныйПакет Тогда
		
		ПереотправляемыйПакет = ХранениеДанных_ДанныеПакета(ПараметрыПереотправки.ПереотправляемыйПакет);
		Пакеты_УдалитьОтправленныеДокументы(ПереотправляемыйПакет);
		
	КонецЕсли;
	
	Результат = НЕ Отказ;
	
	Если НЕ Отказ Тогда
		МетрикиКонтур_ЗаписатьСобытие_ОбработкаИсходящегоДокумента(Пакет);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет в документах пакета коллекцию InitialDocumentIds ссылкой на первый документ.
// Требуется в роуминге для связи документов в пакет.
//
// Параметры:
//  DocumentAttachments - Массив - см. фукнцию АПИ_Новый_DocumentAttachment()
//
Процедура Пакеты_УстановитьСвязиСПервымДокументом(DocumentAttachments)
	
	Если DocumentAttachments.Количество() > 1 Тогда
		
		CustomDocumentId	= DocumentAttachments[0].CustomDocumentId;
		InitialDocumentId	= АПИ_Новый_DocumentId("", CustomDocumentId);
		
		Для Сч = 1 По DocumentAttachments.ВГраница() Цикл
			
			DocumentAttachment = DocumentAttachments[Сч];
			DocumentAttachment.InitialDocumentIds.Добавить(InitialDocumentId);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Пакеты_ОтправитьPostMessage(Пакет, MessageToPost, OperationId)
	
	Отказ = Ложь;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(Пакет.Идентификаторы.BoxId);
	
	Попытка
		РезультатОтправки = АПИ_PostMessage(ПараметрыСервиса, MessageToPost, OperationId);
	Исключение
		
		Отказ = Истина;
		
		Ошибка = ИнформацияОбОшибке();
		Пакеты_ОбработатьОшибкуОтправки(Пакет, Ошибка);
		
	КонецПопытки;
	
	Если НЕ Отказ Тогда
		Результат = РезультатОтправки.Message;
		ЗаполнитьИдентификаторыПослеОтправкиПакета(Пакет, Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ОбработатьОшибкуОтправки(Пакет, Знач Ошибка)
	
	ИсключениеОбработано = Истина;
	
	BoxId = Пакет.Идентификаторы.BoxId;
	ДокументЭДО = Пакет.Документы[0];
	ИмяПакета = ДокументЭДО.ИмяФайла;
	Документ1С = ДокументЭДО.ДокументУчета;
	
	Если ЯвляетсяОшибкойКатегории(Ошибка, ТипДокументаНеПоддержанВРоуминге()) Тогда
		
		ИдентификаторФНС = ДокументЭДО.Получатель.FnsParticipantId;
		ТипЭД = ДокументЭДО.Тип;
		
		ТекстОшибки = Ошибка_ТипДокументаНеПоддержанВРоуминге(ИмяПакета, Документ1С, ИдентификаторФНС, ТипЭД);
		
	ИначеЕсли ЯвляетсяОшибкойКатегории(Ошибка, КоличествоДокументовБольшеДопустимого()) Тогда
		
		ТекстОшибки = Ошибка_КоличествоДокументовПакетаНеПоддержаноДляТЭДО(ИмяПакета, Документ1С);
		
	Иначе
		
		ТекстОшибки = Ошибка_ИсключениеБезКатегорииПриОтправкеПакета(Ошибка, Пакет);
		
		ИсключениеОбработано = Ложь;
		
	КонецЕсли;
	
	ОбработатьОшибкуОтправкиПакета(BoxId, ТекстОшибки);
	
	Если Не ИсключениеОбработано Тогда
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЯвляетсяОшибкойКатегории(Знач Ошибка, Знач Категория)
	
	Если Категория = ТипДокументаНеПоддержанВРоуминге() Тогда
		Результат = ЭтоОшибкаТипДокументаНеПоддержан(Ошибка);
	ИначеЕсли Категория = КоличествоДокументовБольшеДопустимого() Тогда
		Результат = ЭтоОшибкаКоличествоДокументовТЭДО(Ошибка);
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоОшибкаТипДокументаНеПоддержан(Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	Результат = СтрНайтиЛок(ТекстОшибки, "recipient operator does not support this type of document");
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоОшибкаКоличествоДокументовТЭДО(Ошибка)
	
	Если ТипЗнч(Ошибка) = Тип("Строка") Тогда
		ТекстОшибки = НРег(Ошибка);
	Иначе
		ТекстОшибки = НРег(ПодробноеПредставлениеОшибки(Ошибка));
	КонецЕсли;
	
	Результат = СтрНайтиЛок(ТекстОшибки, "в трансграничном письме должно быть не больше одного документа");
	
	Возврат Результат;
	
КонецФункции

Функция ТипДокументаНеПоддержанВРоуминге()
	
	Возврат "RoamingDoesntSupportEntities";
	
КонецФункции

Функция КоличествоДокументовБольшеДопустимого()
	
	Возврат "TransportLetterDocumentsCountExceeded";
	
КонецФункции

Процедура ОбработатьОшибкуОтправкиПакета(BoxId, ОшибкаИнфо)
	
	ВидОперации = "Отправка пакета документов";
	
	Ошибка_Обработать(ВидОперации, ОшибкаИнфо);
	
	КатегорияМетрики = Метрики_КатегорияОтправкаДокумента();
	ДействиеМетрики = "Исходящие";
	
	Метрика_ДобавитьОшибку_ДляОрганизации(BoxId, КатегорияМетрики, ДействиеМетрики, ОшибкаИнфо);
	
КонецПроцедуры

Функция Пакеты_УдалитьОтправленныеДокументы(Пакет)
	
	Результат = Истина;
	
	BoxId = Пакет.Идентификаторы.BoxId;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	MessageId = Неопределено;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		LetterId = Документ.Идентификаторы.LetterId;
		
		Если ЗначениеЗаполнено(LetterId) И MessageId <> LetterId Тогда
			
			MessageId = LetterId;
			
			Попытка
				РезультатУдаления = АПИ_Delete(ПараметрыСервиса, BoxId, MessageId);
			Исключение
				
				Результат = Ложь;
				
				Ошибка				= ИнформацияОбОшибке();
				ТекстОшибки		 	= ПодробноеПредставлениеОшибки(Ошибка);
				ПредставлениеПакета	= ПредставлениеПакета(Пакет);
				ВидОперации			= "Удаление отправленных документов";
				ДопИнформация	 	= "Пакет: " + ПредставлениеПакета;
				ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку("Не удалось удалить отправленные документы пакета %1", ПредставлениеПакета);
				
				Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_УстановитьСтатусПодготовлен(Пакет)
	
	Пакет.Состояние = Перечисление_СтатусыПакетов().Подготовлен;
	Пакет.Идентификаторы.LetterId = "";
	
	Для Каждого Документ Из Пакет.Документы Цикл
		
		Документ.Состояние = Перечисление_СтатусыПакетов().Подготовлен;
		Документ.Идентификаторы.LetterId	= "";
		Документ.Идентификаторы.DocumentId	= "";
		
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_ИдентификаторОперации(Пакет, ПредыдущийLetterID = Неопределено)

	ПроизвольныйПакет = НЕ ЗначениеЗаполнено(Пакет.ИдентификаторВида);
	ОтключитьКонтрольДублированияОтправкиПакетов = ОбщиеНастройки_Прочитать("ОтключитьКонтрольДублированияОтправкиПакетов");
	
	Если ПроизвольныйПакет 
		ИЛИ ОтключитьКонтрольДублированияОтправкиПакетов Тогда
		
		Результат = Неопределено;
		
	ИначеЕсли Пакет.СлужебнаяИнформация.Свойство("OperationId") Тогда
		
		Результат = Пакет.СлужебнаяИнформация.OperationId;
		
	Иначе
		
		ИдентификаторВидаПакета = Пакет.ИдентификаторВида;
		
		Если ЗначениеЗаполнено(Пакет.ДокументУчета) Тогда
			ИдентификаторДокументаУчета = Строка(Пакет.ДокументУчета.УникальныйИдентификатор());
		Иначе
			ИдентификаторДокументаУчета = ПустойИдентификатор();
		КонецЕсли;
		
		ПараметрыПереотправки = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ПараметрыПереотправки");
		
		Если ПараметрыПереотправки <> Неопределено Тогда
			ПереотправляемыйLetterID = ПараметрыПереотправки.ПереотправляемыйПакет.LetterID;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ПереотправляемыйLetterID) Тогда
			ПереотправляемыйLetterID = ПустойИдентификатор();
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ПредыдущийLetterID) Тогда
			ПредыдущийLetterID = ПустойИдентификатор();
		КонецЕсли;
		
		Результат	= ИдентификаторВидаПакета + " "
					+ ИдентификаторДокументаУчета + " "
					+ ПереотправляемыйLetterID + " "
					+ ПредыдущийLetterID;
		
	КонецЕсли;
				
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ОтправитьОтложенный(Пакет)
	
	Отказ = Ложь;
	
	ПодготовленныеСтруктуры = Пакеты_СтруктураДляОтправкиОтложенногоПакета(Пакет.Документы);
	
	Для Каждого ПодготовленнаяСтруктура Из ПодготовленныеСтруктуры Цикл
		
		ИдентификаторыMessage = Контракт_ИдентификаторыПакета();
		
		ИдентификаторыMessage.BoxId		= Пакет.Идентификаторы.BoxId;
		ИдентификаторыMessage.LetterId	= ПодготовленнаяСтруктура.Ключ;
		
		Попытка
			РезультатОтправки = РезультатPostMessagePatch(ИдентификаторыMessage, ПодготовленнаяСтруктура.Значение);
		Исключение
			
			Ошибка			= ИнформацияОбОшибке();
			ПодробнаяОшибка	= ПодробноеПредставлениеОшибки(Ошибка);
			
			ВидОперации		 = "Отправка отложенного пакета документов";
			Представление	= ПредставлениеПакета(Пакет);
			ТекстОшибки		= "Пакет: %1 Не удалось отправить пакет документов: %2";
			ТекстОшибки		= Общее_ПодставитьПараметрыВСтроку(ТекстОшибки, Представление, ПодробнаяОшибка);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки);
			
			Отказ = Истина;
			Прервать;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если НЕ Отказ И РезультатОтправки <> Неопределено Тогда
		
		Пакет.ДатаЭДО = Ticks_2_Date(РезультатОтправки.MessagePatch.TimestampTicks);
		
		Для Каждого Документ Из Пакет.Документы Цикл
			Документ.ДатаЭДО = Пакет.ДатаЭДО;
			Документ.СлужебнаяИнформация.Вставить("PatchedContentId", "");
		КонецЦикла;
		
	КонецЕсли;
	
	Результат = НЕ Отказ;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_СтруктураДляОтправкиОтложенногоПакета(ДокументыПакета)
	
	Результат = Новый Соответствие;
	
	ИмяКоллекции = "Signatures";
	
	Для Каждого Документ Из ДокументыПакета Цикл
		
		MessageId	 	 = Документ.Идентификаторы.LetterId;
		DocumentId		 = Документ.Идентификаторы.DocumentId;
		PatchedContentId = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "PatchedContentId", Неопределено);
		ДанныеПодписи	 = Документ.Документооборот.ХранилищеКонтента.Подпись.ДанныеПодписи;
		
		Если ЗначениеЗаполнено(ДанныеПодписи) Тогда
			
			PowerOfAttorney = МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
			
			DocumentSignature = АПИ_Новый_DocumentSignature(DocumentId, ДанныеПодписи, PatchedContentId, , PowerOfAttorney);
			
			КоллекцииMessageId = Результат.Получить(MessageId);
			
			Если КоллекцииMessageId = Неопределено Тогда
				
				КоллекцииMessageId = Новый Структура(ИмяКоллекции, Новый Массив); 
				Результат.Вставить(MessageId, КоллекцииMessageId);
				
			КонецЕсли;
			
			КоллекцииMessageId[ИмяКоллекции].Добавить(DocumentSignature);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_СодержитДокументыДляСогласования(Пакет)
	
	Результат = Ложь;
	
	Для Каждого ОписаниеДокумента Из Пакет.Документы Цикл
		Если ОписаниеДокумента.СлужебнаяИнформация.Свойство("Маршрутизация") Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьMessageToPost(Пакет)
	
	Результат = АПИ_Новый_MessageToPost(Пакет.Идентификаторы.BoxId);
	
	ОтложеннаяОтправка = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОтложеннаяОтправка", Ложь);
	
	Результат.Вставить("ToBoxId", Пакет.Получатель.BoxId);
	Результат.Вставить("DelaySend", ОтложеннаяОтправка);
	Результат.Вставить("LockPacket", Пакет.Заблокирован);
	
	Если Пакет.СлужебнаяИнформация.Свойство("ПараметрыОтправки") Тогда
		
		ПараметрыОтправки = Пакет.СлужебнаяИнформация.ПараметрыОтправки;
		
		ПромежуточныйПолучатель = ПараметрыОтправки.ПромежуточныйПолучатель;
		
		Если ЗначениеЗаполнено(ПромежуточныйПолучатель.BoxId) Тогда
			
			Результат.Вставить("ProxyBoxId", ПромежуточныйПолучатель.BoxId);
			
			Если ЗначениеЗаполнено(ПромежуточныйПолучатель.DepartmentId) Тогда
				
				Результат.Вставить("ProxyDepartmentId", ПромежуточныйПолучатель.DepartmentId);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.Вставить("FromDepartmentId", Пакет.Отправитель.DepartmentId);
	Результат.Вставить("ToDepartmentId", Пакет.Получатель.DepartmentId);
	
	Если Пакет.Направление = Перечисление_Направления().Внутреннее Тогда
		Результат.Вставить("IsInternal", Истина);
		Результат.Удалить("ToBoxId");
	КонецЕсли;
	
	Результат.Вставить("DocumentAttachments", Новый Массив);
	
	Для Каждого Документ Из Пакет.Документы Цикл
		DocumentAttachment = ПодготовитьDocumentAttachment(Документ);
		Результат.DocumentAttachments.Добавить(DocumentAttachment);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьDocumentAttachment(Документ)
	
	ТипДокумента = Документ.Тип.ТипДокумента;
	ТипКонтента = Документ.Тип.ТипКонтента;
	ФункцияДокумента = Документ.Тип.ФункцияДокумента;
	Формализованный = Документ.Тип.Формализованный;
	BoxId = Документ.Идентификаторы.BoxId;
	
	ХранилищеКонтента = СвойствоСтруктуры(Документ.Документооборот, "ХранилищеКонтента", Контракт_ДанныеХранения());
	ОписаниеТипаДокументаAPI = Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
	ДокументЗашифрован = ОписаниеТипаДокументаAPI.SupportsEncrypting
		И ЗначениеЗаполнено(ХранилищеКонтента.ЗашифрованныеДанные);
	Данные = ?(ДокументЗашифрован, ХранилищеКонтента.ЗашифрованныеДанные, ХранилищеКонтента.Данные);
	ДанныеПодписи = ХранилищеКонтента.Подпись.ДанныеПодписи;
	
	PowerOfAttorneyToPost = МЧД_ЗаполненныйКонтрактPowerOfAttorneyToPost(Документ);
	
	NameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		Данные);
		
	SignatureNameOnShelf = АПИ_ЗагрузитьКонтентНаПолку(
		BoxId,
		ДанныеПодписи);
	
	SignedContent = АПИ_Новый_SignedContent(, , NameOnShelf, SignatureNameOnShelf, PowerOfAttorneyToPost);
	
	Результат = АПИ_Новый_DocumentAttachment(SignedContent, ОписаниеТипаДокументаAPI.TypeNamedId);
	Результат.Вставить("CustomDocumentId", Документ.Ключ);
	Результат.Вставить("IsEncrypted", ДокументЗашифрован);
	Результат.Вставить("Comment", Документ.Комментарий);
	
	ПараметрыОтправки = Неопределено;
	
	Если Документ.СлужебнаяИнформация.Свойство("ПараметрыОтправки", ПараметрыОтправки) Тогда
		Результат.Вставить("NeedReceipt", ПараметрыОтправки.ЗапрашиватьИзвещение);
		Результат.Вставить("NeedRecipientSignature", ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеТипаДокументаAPI.FunctionName) Тогда
		Результат.Вставить("Function", ОписаниеТипаДокументаAPI.FunctionName);
	Иначе
		Результат.Вставить("Function", ФункцияДокументаПоУмолчанию());
	КонецЕсли;
	
	Результат.Вставить("Version", ОписаниеТипаДокументаAPI.Version);
	
	Результат.InitialDocumentIds = КопияКоллекцииЗначений(Документ.Связи.InitialDocumentIds);
	Результат.SubordinateDocumentIds = КопияКоллекцииЗначений(Документ.Связи.SubordinateDocumentIds);
	
	Если ДокументЗашифрован ИЛИ НЕ Формализованный Тогда
		
		МетаданныеДокумента = ПолучитьМетаданныеДокументаДляОтправки(ОписаниеТипаДокументаAPI, Документ, ДокументЗашифрован);
		
		Если ЗначениеЗаполнено(МетаданныеДокумента) Тогда
			Результат.Вставить("Metadata", МетаданныеДокумента);
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьТегиДокумента(Результат, Документ);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьМетаданныеДокументаДляОтправки(ОписаниеТипаДокументаAPI, Документ, ДокументЗашифрован)
	
	Результат = Новый Массив;
	
	MetadataItems = ?(ДокументЗашифрован, ОписаниеТипаДокументаAPI.EncryptedMetadataItems, ОписаниеТипаДокументаAPI.MetadataItems);
	
	Для Каждого ЭлементСтруктуры Из MetadataItems Цикл
		
		Если НРег(ЭлементСтруктуры.Source) = "xml"
			ИЛИ ЭлементСтруктуры.Source = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Значение = Неопределено;
		Документ.Метаданные.Свойство(ЭлементСтруктуры.Id, Значение);
		
		Если ЗначениеЗаполнено(Значение) Тогда
			
			Если ЭлементСтруктуры.Type = "Date"
				ИЛИ ЭлементСтруктуры.Type = 3 Тогда
				Значение = Формат(Значение, "ДФ=dd.MM.yyyy");
			ИначеЕсли ЭлементСтруктуры.Type = "Time"
				ИЛИ ЭлементСтруктуры.Type = 4 Тогда
				Значение = Формат(Значение, "ДФ=HH.mm.ss; ДП=00.00.00");
			КонецЕсли;
			
		ИначеЕсли ЭлементСтруктуры.IsRequired = Истина Тогда
			
			Если ЭлементСтруктуры.Type = "Decimal"
				ИЛИ ЭлементСтруктуры.Type = 2 Тогда
				Значение = 0;
			ИначеЕсли ЭлементСтруктуры.Type = "Date"
				ИЛИ ЭлементСтруктуры.Type = 3 Тогда
				Значение = Документ.Реквизиты.Дата; 
			ИначеЕсли ЭлементСтруктуры.Type = "Time"
				ИЛИ ЭлементСтруктуры.Type = 4 Тогда
				Значение = "00.00.00";
			Иначе
				Значение = "-";
			КонецЕсли;
			
		Иначе
			Значение = Неопределено;
		КонецЕсли;
		
		Если Значение <> Неопределено Тогда
			MetadataItem = АПИ_Новый_MetadataItem(ЭлементСтруктуры.Id, Значение);
			Результат.Добавить(MetadataItem);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Заполняет теги отправляемого документа. Список тегов представляет собой
// список пар вида «ключ-значение»,передаваемый в свойстве документа CustomData.
Процедура ЗаполнитьТегиДокумента(DocumentAttachment, Документ)
	
	ТегиДокумента = Новый Массив;
	
	Если ЭтоФормализованныйСчет(Документ.Тип.ТипКонтента) Тогда 
		
		// включаем отображение в веб-интерфесе кнопки оплаты счета
		Тег = АПИ_Новый_MetadataItem("Custom-data-ShowPaymentButton", "Yes");
		ТегиДокумента.Добавить(Тег);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТегиДокумента) Тогда 
		DocumentAttachment.Вставить("CustomData", ТегиДокумента);
	КонецЕсли;
	
КонецПроцедуры

// Проверяет, что тип документа соответствует формализованному счету.
//
// Параметры:
//  ОписаниеТипаДокумента - Структура - описание типа электронного документа (см. ЭДО_ОписаниеТипаДокументаAPI());
// 
// Возвращаемое значение:
//  Булево - Истина, если это описание типа формализованного счета.
//
Функция ЭтоФормализованныйСчет(ТипКонтента)
	
	Результат = Ложь;
	
	Если ВРег(ТипКонтента) = ВРег("XmlProformaInvoice") Тогда 
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьИдентификаторыПослеОтправкиПакета(Пакет, Message)
	
	КатегорияМетрики	= Метрики_КатегорияОтправкаДокумента();
	ДействиеМетрики		= "Исходящие";

	КлючиДокументов = Новый Соответствие;
	
	Для Каждого Документ Из Пакет.Документы Цикл
		КлючиДокументов.Вставить(Строка(Документ.Ключ), Документ);
	КонецЦикла;
	
	ДатаСоздания = Ticks_2_Date(Message.TimestampTicks);
	
	ОтправленНовыйПакет = Ложь;
	
	Для Каждого Entity Из Message.Entities Цикл
		
		Если Entity.Свойство("DocumentInfo")
			И Entity.ParentEntityId = "" Тогда
			
			Документ = КлючиДокументов.Получить(Entity.DocumentInfo.CustomDocumentId);
			
			Если Документ <> Неопределено Тогда
				
				Документ.Состояние					 = Перечисление_СтатусыПакетов().Отправлен;
				Документ.Идентификаторы.LetterId	 = Message.MessageId;
				Документ.Идентификаторы.DocumentId	 = Entity.EntityId;
				Документ.ДатаЭДО					 = ДатаСоздания;
				Документ.Тип.WorkflowId				 = Entity.DocumentInfo.WorkflowId;
				
				Метрика_ДобавитьСтатистику_ДействиеДокументаАПИ(КатегорияМетрики, ДействиеМетрики, Документ);	
				
				ОтправленНовыйПакет = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОтправленНовыйПакет Тогда
		
		Пакет.Состояние					= Перечисление_СтатусыПакетов().Отправлен;
		Пакет.ДатаЭДО					= ДатаСоздания;
		Пакет.Идентификаторы.LetterId	= Message.MessageId;
		
	Иначе
		Пакет.Идентификаторы.LetterId	= "";
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ОтложенныеДокументыДляОтправкиКонтрагенту(СтрокиСписка) Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого СтрокаСписка Из СтрокиСписка Цикл
		
		МожноОтправлять = Документы_МожноОтправлятьКонтрагенту(СтрокаСписка);
		
		Если МожноОтправлять Тогда
			Результат.Добавить(СтрокаСписка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

Функция Документы_МожноОтправлятьКонтрагенту(СтрокаСписка)
	
	Статус					= СтрокаСписка.Статус;
	ДополнительныйСтатус	= СтрокаСписка.ДополнительныйСтатус;
	
	Результат = (Статус = Перечисление_СтатусыДокументов().ТребуетсяПодписатьИОтправить
				И ДополнительныйСтатус <> Перечисление_ДополнительныеСтатусыДокументов().НаСогласовании);
				
	Возврат Результат;
	
КонецФункции

