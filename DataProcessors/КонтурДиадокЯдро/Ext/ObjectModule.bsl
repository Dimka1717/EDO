Функция АПИ_GenerateSignatureRejectionXml(ПараметрыСервиса, boxId, SignatureRejectionGenerationRequestV2)
Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	Ответ = Модуль_МетодыAPI.DD_API_GenerateSignatureRejectionXml(ПараметрыСервиса, boxId, SignatureRejectionGenerationRequestV2);
	
	КодОтвета = Ответ.КодОтвета;
	
	Если КодОтвета = 200 Тогда
		
		Результат = Ответ.ТелоОтвета;
		
	ИначеЕсли КодОтвета = 409 Тогда
		
		Результат = НСтр("ru='Невозможно выполнить действие с документом.
						|Возможно данное действие было выполнено ранее.'");
		
		ВызватьИсключение Результат;
		
	Иначе
		
		Результат = Ответ.ТелоОтвета;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

