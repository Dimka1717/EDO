// Создает типовой модуль из макета вызывающего модуля,
// или из "каталога с модулем" в случае режима отладки.
//
// Параметры:
//  ВызывающийМодуль - ВнешняяОбработка	- объект модуля.
//  РежимОтладки - Булево, Неопределено - Булево режим отладки включен/выключен иначе определяется автоматически
//  КаталогСМодулем	- Строка - каталог вложенных обработок для отладки.
//
// Возвращаемое значение:
//   ВнешняяОбработка - ВнешняяОбработка - объект модуля.
//
Функция Модуль_ТиповойМодуль(ВызывающийМодуль, Знач РежимОтладки = Неопределено, Знач КаталогСМодулем = "") Экспорт
	
	ИмяМодуля = ИмяТиповогоМодуля();
	Результат = КэшМодулей_Прочитать(ИмяМодуля);
	
	Если Результат = Неопределено Тогда
		
		Результат = Модуль_Создать(ИмяМодуля);
		
		Если РежимОтладки = Неопределено Тогда
			
			РежимОтладки = ТиповойМодуль_РежимОтладки();
			
			// BSLLS:RewriteMethodParameter-off
			КаталогСМодулем = "";
			Если РежимОтладки = Истина Тогда
				КаталогСМодулем = ТиповойМодуль_КаталогОтладки();
			КонецЕсли;
			// BSLLS:RewriteMethodParameter-on
			
		КонецЕсли;
		
		Если Результат <> Неопределено Тогда
			
			ЭтоТиповойМодульУФ = Прав(Результат.Метаданные().Имя, 2) = "УФ";
			
			// BSLLS:SetPrivilegedMode-off
			УстановитьПривилегированныйРежим(Истина);
			// BSLLS:SetPrivilegedMode-on
			
			Если ЭтоТиповойМодульУФ Тогда
				ИнициализироватьТиповойМодульУФ(Результат, РежимОтладки, КаталогСМодулем);
			Иначе
				ИнициализироватьТиповойМодульОФ(Результат, РежимОтладки, КаталогСМодулем);
			КонецЕсли;
			
		КонецЕсли;
		
		КэшМодулей_Поместить(ИмяМодуля, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяНастройкиПутьПодключаемогоМодуля(Знач МестонахождениеПодключаемогоМодуля)
	
	Если МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиФайл() Тогда
		
		ИмяНастройки = "ПодключаемыйМодульПуть";
		
	ИначеЕсли МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиКонфигурация() Тогда
		
		ИмяНастройки = "ПодключаемыйМодульИмяОбработки";
		
	ИначеЕсли МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиСправочник() Тогда
		
		ИмяНастройки = "ПодключаемыйМодульСсылка";
		
	Иначе
		
		ИмяНастройки = "";
		
	КонецЕсли;
	
	Возврат ИмяНастройки;

КонецФункции

Функция ПодключаемыйМодуль_Путь(МестонахождениеПодключаемогоМодуля)
	
