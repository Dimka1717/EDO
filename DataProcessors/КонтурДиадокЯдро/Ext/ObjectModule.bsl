Функция РеквизитыИмениФайла(ИмяФайла)
	
	Результат = Новый Структура;
	Результат.Вставить("Имя"				, "");
	Результат.Вставить("Путь"				, "");
	Результат.Вставить("Расширение"			, "");
	Результат.Вставить("ИмяБезРасширения"	, "");
	
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Файл = Новый Файл(ИмяФайла);
	
	ЗаполнитьЗначенияСвойств(Результат, Файл);
	
	Возврат Результат;
	
КонецФункции

Функция СтруктураДаты(Знач ПеремДата)
	
	Если ПеремДата = Неопределено Тогда
		ПеремДата = Дата(1,1,1);
	КонецЕсли;
	
	Год 	= Формат(Год(ПеремДата), "ЧГ=0");
	Месяц 	= Строка(Месяц(ПеремДата));
	День	= Строка(День(ПеремДата));
	
	Результат = Новый Структура("Год, Месяц, День", Год, Месяц, День);
	
	Возврат Результат;
	
КонецФункции

// Проверяет что указанный адрес является адресом из временного хранилища
// нужен для совместимости с 8.1
//
// Параметры:
//  Адрес - Строка - адрес, который нужно проверить
// 
// Возвращаемое значение:
//  Булево - Истина, если адрес из временного хранилища
//
Функция ЭтоАдресИзВременногоХранилища(Адрес)
	
	Результат = Ложь;
	
	Если ТипЗнч(Адрес) <> Тип("Строка") Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтрокаНачалаАдресаВХ 	= "e1cib\tempstorage\";
	СтрокаНачалаАдресаВХ_ОФ = "e1cib/tempstorage/";
	ДлинаНачалаАдресаВХ	 = СтрДлина(СтрокаНачалаАдресаВХ);
	
	Если Лев(Адрес, ДлинаНачалаАдресаВХ) = СтрокаНачалаАдресаВХ
		ИЛИ Лев(Адрес, ДлинаНачалаАдресаВХ) = СтрокаНачалаАдресаВХ_ОФ Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеЗаполненоИзВременногоХранилища(АдресВХ) Экспорт
	
	ЗначениеВХ = ПолучитьИзВременногоХранилища(АдресВХ);
	
	Результат = ЗначениеЗаполнено(ЗначениеВХ);
	
	Возврат Результат;
	
КонецФункции

