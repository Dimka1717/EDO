// Обрабатывает ошибку интеграции с Логистикой
//
// Параметры:
//  Действие	 - Строка	 - см. Метрика_НазваниеДействий()
//  ТекстОшибки	 - Строка	 - Текст ошибки интеграции
//
Процедура КонтурЛогистика_ОбработатьОшибку(Действие, ТекстОшибки) Экспорт
	
	Категория = Метрика_НазваниеКатегории().ИнтеграцияСЛогистикой;
	
	ДопПеременные = Новый Соответствие;
	ДопПеременные.Вставить("KonturBaseID", ОбщийКонтекст_КонтурИдентификаторИБ());
	
	Метрика_ДобавитьОшибку(Категория, Действие, ТекстОшибки, ДопПеременные);
	
	ВидОперации = Категория + "." + Действие;
	СписокОшибок_ДобавитьОшибку(ВидОперации, ТекстОшибки);
	
КонецПроцедуры

