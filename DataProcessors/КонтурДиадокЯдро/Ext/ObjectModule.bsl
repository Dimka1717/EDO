// Собирает техническую информацию о подключаемом модуле
//
// Параметры:
//  Настройки - Структура - настройки ПМ (для УМ или для Стандарта)
//                          см. ХранениеДанных_ОбщиеНастройки и ХранениеДанных_НастройкиМодуляСтандарт
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//    * Использовать - Булево - Истина, если включена настройка использования ПМ
//    * Путь - Строка - (Необязательный) Навигационная ссылка, путь к файлу или полное имя метаданных
//    * Представление - Строка - (Необязательный) Заполняется, если настроен путь к ПМ
//    * Расположение - Строка - (Необязательный) Заполняется, если включено использование ПМ
//
Функция ТехИнфо_ПодключаемыйМодуль(Настройки)
	
	Путь = ТехИнфо_НеопределенноеЗначение();
	Представление = "";
	Расположение = "";
	
	Если Настройки.ИспользоватьПодключаемыйМодуль Тогда
		
		Если Настройки.МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиСправочник() Тогда
			
			Расположение = ВариантРасположенияОбработкиСправочник();
			ПодключаемыйМодульСсылка = Настройки.ПодключаемыйМодульСсылка;
			
			Если ЗначениеЗаполнено(ПодключаемыйМодульСсылка) Тогда
				Путь = ПолучитьНавигационнуюСсылку(ПодключаемыйМодульСсылка);
				Представление = Строка(ПодключаемыйМодульСсылка);
			КонецЕсли;
			
		ИначеЕсли Настройки.МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиФайл() Тогда
			
			Расположение = ВариантРасположенияОбработкиФайл();
			
			Если ЗначениеЗаполнено(Настройки.ПодключаемыйМодульПуть) Тогда
				Путь = Строка(Настройки.ПодключаемыйМодульПуть);
				Файл = Новый Файл(Путь);
				Представление = Файл.ИмяБезРасширения;
			КонецЕсли;
			
		ИначеЕсли Настройки.МестонахождениеПодключаемогоМодуля = ВариантРасположенияОбработкиКонфигурация() Тогда
			
			Расположение = ВариантРасположенияОбработкиКонфигурация();
			
			МетаданныеПМ = Метаданные.Обработки.Найти(Настройки.ПодключаемыйМодульИмяОбработки);
			Если МетаданныеПМ <> Неопределено Тогда
				Путь = МетаданныеПМ.ПолноеИмя();
				Представление = МетаданныеПМ.Имя;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		Путь = "";
		Представление = "";
		Расположение = "";
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Использовать", Настройки.ИспользоватьПодключаемыйМодуль);
	Если ЗначениеЗаполнено(Путь) Тогда
		Результат.Вставить("Путь", Путь);
	КонецЕсли;
	Если ЗначениеЗаполнено(Представление) Тогда
		Результат.Вставить("Представление", Представление);
	КонецЕсли;
	Если ЗначениеЗаполнено(Расположение) Тогда
		Результат.Вставить("Расположение", Расположение);
	КонецЕсли;
	Если ЗначениеЗаполнено(Путь) 
		И ЗначениеЗаполнено(Расположение) Тогда
		Результат.Вставить("ХэшСумма", "");
		ТехИнфо_ЗаполнитьХэшСуммуПМ(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет хэш сумму подключаемого модуля если это возможно.
//
// Параметры:
//  ТехИнфоПМ - ФиксированнаяСтруктура - см. ТехИнфо_ПодключаемыйМодуль
//
Процедура ТехИнфо_ЗаполнитьХэшСуммуПМ(ТехИнфоПМ)
	
	РасположениеПМ = ТехИнфоПМ.Расположение;
	
	Если НЕ ЗначениеЗаполнено(РасположениеПМ) Тогда
		Возврат;
	КонецЕсли;
	
	Если РасположениеПМ = ВариантРасположенияОбработкиКонфигурация() Тогда
		ТехИнфоПМ.ХэшСумма = "unavailable";
		Возврат;
	КонецЕсли;
	
	Попытка
		
		ДвоичныеДанныеПМ = ФайлПодключаемогоМодуля(ТехИнфоПМ);
		ХэшСумма = Хэш_Рассчитать(ДвоичныеДанныеПМ, "MD5");
		ТехИнфоПМ.ХэшСумма = НРег(ХэшСумма);
		
	Исключение
		
		ВидОперации = НСтр("ru = 'Получение хэш суммы подключаемого модуля'");
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		КраткоеПредставлениеОбОшибке = КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		ШаблонОшибки = "error: %1";
		
		ТехИнфоПМ.ХэшСумма = Общее_ПодставитьПараметрыВСтроку(
				ШаблонОшибки,
				КраткоеПредставлениеОбОшибке);
		
		Ошибка_Обработать(ВидОперации, ИнформацияОбОшибке);
		
		Категория = "Хэш сумма ПМ";
		Действие = "Получение хэш суммы ПМ";
		Метрика_ДобавитьОшибку(
			Категория,
			Действие,
			ИнформацияОбОшибке);
		
	КонецПопытки;
	
КонецПроцедуры

Функция ТехИнфо_ИнтеграцияКонтурМаркировка(ИспользоватьКМ)
	
	Результат = Новый Структура;
	Результат.Вставить("Использовать", ИспользоватьКМ);
	
	Если ИспользоватьКМ Тогда
		Результат.Вставить("ВерсияМодуля", ВерсияМодуляКонтурМаркировка());
		Результат.Вставить("ВерсияПодсистемы", ВерсияПодсистемыКонтурМаркировки());
	КонецЕсли;
	
	Возврат Результат;
	
