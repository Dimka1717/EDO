Функция АПИ_DocumentTitleType(ВидДокумента, Сторона)
	
	ТипыТитулов = Новый Соответствие;
	
	Если Сторона = "Покупатель" Тогда
		// BSLLS:MagicNumber-off
		ТипыТитулов.Вставить("Utd", 1);
		ТипыТитулов.Вставить("Ucd", 3);
		ТипыТитулов.Вставить("TovTorg551", 5);
		ТипыТитулов.Вставить("AccCert552", 7);
		ТипыТитулов.Вставить("Utd820", 8);
		ТипыТитулов.Вставить("Torg2", 10);
		ТипыТитулов.Вставить("Ucd736", 11);
		ТипыТитулов.Вставить("Utd970", 13);
		ТипыТитулов.Вставить("torgblr", 13);
		
	Иначе
		
		ТипыТитулов.Вставить("Utd", 0);
		ТипыТитулов.Вставить("Utd820", 0);
		ТипыТитулов.Вставить("Ucd", 2);
		ТипыТитулов.Вставить("Ucd736", 2);
		ТипыТитулов.Вставить("TovTorg551", 4);
		ТипыТитулов.Вставить("AccCert552", 6);
		ТипыТитулов.Вставить("Torg2", 9);
		ТипыТитулов.Вставить("Utd970", 12);
		ТипыТитулов.Вставить("XmlProformaInvoice", 14);
		ТипыТитулов.Вставить("XmlInvoiceOffer", 14);
		ТипыТитулов.Вставить("torgblr", 12);
		// BSLLS:MagicNumber-on
	КонецЕсли;
	
	Результат = ТипыТитулов[ВидДокумента];
	
	Если Результат = Неопределено Тогда
		
		ТекстОшибки = ПараметрыВСтроку(НСтр(
					"ru = 'Неизвестный вид документа для получения полномочий подписанта %1'"), ВидДокумента);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

