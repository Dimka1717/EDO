// Уникальный идентификатор текущей информационной базы.
// 
// Возвращаемое значение:
//  УникальныйИдентификатор
//
Функция _ИдентификаторИнформационнойБазыДиадок()
	
	Идентификатор = ЗначениеНастройки_ИдентификаторБазы1С();
	Если ТипЗнч(Идентификатор) = Тип("УникальныйИдентификатор") Тогда
		Возврат Идентификатор;
	КонецЕсли;
	
	Попытка
		Результат = Новый УникальныйИдентификатор(Идентификатор);
	Исключение
		Результат = ИдентификаторИнформационнойБазыНеОпределен();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Уникальный идентификатор текущей информационной базы.
// Формируется по алгоритму для общепродуктовых метрик
// 
// Возвращаемое значение:
//  УникальныйИдентификатор
//
Функция _ИдентификаторИнформационнойБазыКонтур()
	
	Результат = ОбщийКонтекст_КонтурИдентификаторИБ();
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		
		Результат = МетрикиКонтурСлужебный_КонтурИдентификаторИБ();
		
		ОбщийКонтекст_Поместить("КонтурИдентификаторИБ", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Идентификатор пользователя операционной системы.
// 
// Возвращаемое значение:
//  УникальныйИдентификатор
//
Функция _ИдентификаторПользователяОС()
	
	СистемнаяИнформация1 = Новый СистемнаяИнформация;
	СистемнаяИнформация2 = Новый СистемнаяИнформация;
	
	Если СистемнаяИнформация1.ИдентификаторКлиента = СистемнаяИнформация2.ИдентификаторКлиента Тогда
		ИдентификаторКлиента = СистемнаяИнформация1.ИдентификаторКлиента;
	Иначе
		// https://devtrainingforum.v8.1c.ru/forum/thread.jsp?id=588350&threadtype=0
		ИдентификаторКлиента = ИдентификаторКлиентаПеременный();
	КонецЕсли;
	
	Если ИдентификаторКлиента = ПустойУникальныйИдентификатор() Тогда
		ИдентификаторКлиента = ИдентификаторКлиентаПустой();
	КонецЕсли;
	
	Возврат ИдентификаторКлиента;
	
КонецФункции

