// Получает сведения о сопоставленном контрагенте из сервиса
//
// Параметры:
//  BoxId - Строка - BoxId организации для получения сведений о контрагенте из сервиса
//  counteragentBoxId - Строка - BoxId контрагента для которого необходимо получить сведения из сервиса
//
Функция Контрагенты_РеквизитыСопоставленногоКонтрагента(BoxId, counteragentBoxId) Экспорт
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	
	ИдентификаторОрганизации = АдресЯщикаВИдентификатор(BoxId);
	ИдентификаторКонтрагента = АдресЯщикаВИдентификатор(counteragentBoxId);
	
	Counteragent = АПИ_GetCounteragentV3(ПараметрыСервиса, ИдентификаторОрганизации, ИдентификаторКонтрагента);
	
	Результат = Контрагенты_НовыйКонтрагентИзСтруктуры(Counteragent);
	
	Возврат Результат
	
КонецФункции

// Признак того, что у контрагента с указанным ИНН есть ящик в Диадок
//
// Параметры:
//  ИННКонтрагента - Строка - ИНН контрагента
//  BoxId - строка - BoxId организации для проверки наличия ящика контрагента в сервисе
//
// Возвращаемое значение:
//  Булево - Истина, если ящик есть, иначе Ложь
//
Функция Контрагенты_КонтрагентЕстьВДиадок(ИННКонтрагента, BoxId) Экспорт
	
	КонтрагентыСервиса = Контрагенты_СписокДляСопоставленияКонтрагентаИБ(ИННКонтрагента, BoxId);
	
	Результат = КонтрагентыСервиса.Количество() > 0;
	
	Возврат Результат;
	
КонецФункции


// СИНХРОНИЗАЦИЯ КОНТРАГЕНТОВ

// Обновляет данные контрагентов в базе 1С данными с сервера Диадока.
//
// Параметры:
//	Организация - Структура - см. Контракт_ОрганизацияЭДО()
//  ДобавитьКонтрагентовДляПриглашения - Булево - признак необходимости обновления контрагентов, 
//												  с которым еще не установлены отношения
//
Процедура Контрагенты_ВыполнитьСинхронизацию(Организация, ДобавитьКонтрагентовДляПриглашения = Истина) Экспорт
	
	КонецСинхронизации = ТекущаяУниверсальнаяДата();
	
	Контрагенты_ЗаполнениеОсновныхСтатусов(Организация);
	
	Если ДобавитьКонтрагентовДляПриглашения Тогда
		
		ТаблицаКонтрактов = Контрагенты_ПоискИПриглашениеДляОрганизации(Организация);
		
		Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов);
		Контрагенты_ОбновлениеСтатусов(ТаблицаКонтрактов, Организация, Истина);
	
	КонецЕсли;
	
	ЛентаКонтрагентов_ГраницаСинхронизацииУстановить(Организация, КонецСинхронизации);
	
КонецПроцедуры

// Обновляет данные контрагентов в базе 1С данными с сервера Диадока.
//
// Параметры:
//	Организация - Структура - см. Контракт_ОрганизацияЭДО()
//
Процедура Контрагенты_ВыполнитьСинхронизациюОсновныхСтатусов(Знач Организация) Экспорт
	
	КонецСинхронизации = ТекущаяУниверсальнаяДата();
	
	Контрагенты_ЗаполнениеОсновныхСтатусов(Организация);
	
	ЛентаКонтрагентов_ГраницаСинхронизацииУстановить(Организация, КонецСинхронизации);
	
КонецПроцедуры

// Обновляет данные контрагентов в базе 1С данными с сервера Диадока для поиск и приглашение.
//
// Параметры:
//	Организация - Структура - см. Контракт_ОрганизацияЭДО()
//
Процедура Контрагенты_ВыполнитьСинхронизациюДляПриглашения(Знач Организация) Экспорт
	
	КонецСинхронизации = ТекущаяУниверсальнаяДата();
	
	Контрагенты_ЗаполнениеОсновныхСтатусов(Организация);
	
	ТаблицаКонтрактов = Контрагенты_ПоискИПриглашениеДляОрганизации(Организация);
	
	Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов);
	
	Контрагенты_ОбновлениеСтатусов(
		ТаблицаКонтрактов,
		Организация,
		Истина);
	
	ЛентаКонтрагентов_ГраницаСинхронизацииУстановить(Организация, КонецСинхронизации);
	
КонецПроцедуры

Функция Контрагенты_ТаблицаКонтрактовПоКоллекцииИдентификаторов(Знач ИдентификаторЯщика, Знач КоллекцияИдентификаторов)
	
	Результат = Контрагенты_НоваяТаблицаКонтрактов();
	Перечисление_СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	
	Для Каждого ИдентификаторКонтрагента Из КоллекцияИдентификаторов Цикл
		
		Контрагент = Контрагенты_РеквизитыСопоставленногоКонтрагента(
				ИдентификаторЯщика,
				ИдентификаторКонтрагента);
				
		Статус = Контрагент.Статус;		
		Если Статус = Перечисление_СтатусыКонтрагентов.РаботаетВДиадок Тогда
			
			Контрагент = Контрагенты_РеквизитыКонтрагента_АПИ(ИдентификаторКонтрагента);
			Контрагент.Статус = Статус;
			
		КонецЕсли;
		
		ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника( , Контрагент.ID);
		РеквизитыКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
		Контрагент.Ссылка = РеквизитыКонтрагента.Ссылка;
		
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Контрагент);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные контрагента из АПИ не зависимо от системы хранения
//
// Параметры:
//  ИдентификаторЯщика		- Строка - BoxId организации для получения сведений о контрагенте из сервиса
//  ИдентификаторКонтрагента 	- Строка - BoxId контрагента для которого необходимо получить сведения из сервиса
// 
// Возвращаемое значение:
//   - Структура - см. Контракт_КонтрагентЭДО
//
Функция Контрагенты_ДанныеКонтрагентаАПИ(Знач ИдентификаторЯщика, Знач ИдентификаторКонтрагента) Экспорт
	
	Перечисление_СтатусыКонтрагентов = Перечисление_СтатусыКонтрагентов();
	
	Результат = Контрагенты_РеквизитыСопоставленногоКонтрагента(
			ИдентификаторЯщика,
			ИдентификаторКонтрагента);
			
	Статус = Результат.Статус;		
	Если Статус = Перечисление_СтатусыКонтрагентов.РаботаетВДиадок Тогда
		
		Результат = Контрагенты_РеквизитыКонтрагента_АПИ(ИдентификаторКонтрагента);
		Результат.Статус = Статус;
		
	КонецЕсли;
	
	ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника( , Результат.ID);
	РеквизитыКонтрагента = Контрагенты_ЗаполненныеРеквизиты(ИдентификаторыКонтрагента);
	Результат.Ссылка = РеквизитыКонтрагента.Ссылка;
		
	Возврат Результат;
	
КонецФункции

// выполняет синхронизацию статусов контрагентов по ленте контрагентов
//
// Параметры:
//  Организация	 - Структура - см. Контракт_ОрганизацияЭДО()
//
Процедура ЛентаКонтрагентов_ВыполнитьСинхронизациюСтатусов(Знач Организация) Экспорт
	
	ТаблицаКонтрактов = Контрагенты_НоваяТаблицаКонтрактов();
	
	НачалоСинхронизации = ЛентаКонтрагентов_ГраницаСинхронизацииПрочитать(Организация);
	Если НЕ ЗначениеЗаполнено(НачалоСинхронизации) Тогда
		НачалоСинхронизации = ТекущаяУниверсальнаяДата();
	КонецЕсли;
	КонецСинхронизации = ТекущаяУниверсальнаяДата();
	
	ИдентификаторЯщика = АдресЯщикаВИдентификатор(Организация.ID);
	ТаблицаСобытий = ЛентаКонтрагентов_События(
			ИдентификаторЯщика,
			НачалоСинхронизации);
	
	ИмяКолонкиИдентификаторов = "ИдентификаторКонтрагента";
	
	ТаблицаСобытий.Свернуть(ИмяКолонкиИдентификаторов);
	КоллекцияИдентификаторов = ТаблицаСобытий.ВыгрузитьКолонку(ИмяКолонкиИдентификаторов);
	
	ТаблицаКонтрактов = Контрагенты_ТаблицаКонтрактовПоКоллекцииИдентификаторов(
			ИдентификаторЯщика,
			КоллекцияИдентификаторов);
	
	Контрагенты_ОбновлениеСправочника(ТаблицаКонтрактов);
	
	Для Каждого Контрагент Из ТаблицаКонтрактов Цикл
		
		ХранениеДанных_ЗаписатьСтатусКонтрагента(Контрагент, Организация);
		ХранениеДанных_ЗаписатьДатуИзмененияКонтрагента(Контрагент, Организация);
		
	КонецЦикла;
	
	Контрагенты_ОбновлениеПодразделений(Организация, ТаблицаКонтрактов);
	
	ЛентаКонтрагентов_ГраницаСинхронизацииУстановить(Организация, КонецСинхронизации);
	
КонецПроцедуры

Функция ЛентаКонтрагентов_ГраницаСинхронизацииПрочитать(Знач Организация)
	
	Организация = Организации_ЗаполненныеРеквизиты(Организация);
	Результат = Организация.ДатаСинхронизацииСтатусовКонтрагентов;
	
	Возврат Результат;
	
КонецФункции

Процедура ЛентаКонтрагентов_ГраницаСинхронизацииУстановить(Знач Организация, Знач КонецСинхронизации)
	
	РеквизитыДляОбновления = Новый Структура(
			"ДатаСинхронизацииСтатусовКонтрагентов", КонецСинхронизации);
	
	Организации_ОбновлениеРеквизитов(Организация, РеквизитыДляОбновления);
	
КонецПроцедуры

Функция ЛентаКонтрагентов_События(Знач ИдентификаторЯщика, Знач ГраницаСинхронизации)
	
	Результат = ЛентаКонтрагентов_КонтрактТаблицаСобытий();
	
	ПраваПользователя = ПраваПользователяЯщикаОрганизации(
		ИдентификаторЯщика);
	
	Если НЕ ПраваПользователя.CanManageCounteragents Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(ИдентификаторЯщика);
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	ПорцияСобытий = 100;
	ИндексСобытия = "";
	МеткаВремени = Date_2_Ticks(ГраницаСинхронизации);
	
	Пока Истина Цикл
		
		СобытияКонтрагентов = Модуль_МетодыAPI.DD_API_GetCounteragentEvents(
				ПараметрыСервиса,
				ИдентификаторЯщика,
				МеткаВремени,
				ИндексСобытия);
		
		Для Каждого Событие Из СобытияКонтрагентов.Events Цикл
			
			CounteragentBoxId = Событие.Counteragent.CounteragentBoxId;
			Комментарий = СвойствоСтруктуры(Событие.Counteragent, "LastEventComment", "");
			ТипСобытия = "";
			Если ЗначениеЗаполнено(Событие.EventTypes) Тогда
				ТипСобытия = Событие.EventTypes[0];
			КонецЕсли;
			
			СтатусКонтрагента = Событие.Counteragent.Status;
			
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.ИндексСобытия = Событие.IndexKey;
			НоваяСтрока.ДатаСобытия = Ticks_2_Date(Событие.Counteragent.EventTimestampTicks);
			НоваяСтрока.ТипСобытия = ТипСобытия;
			НоваяСтрока.ИдентификаторКонтрагента = CounteragentBoxId;
			НоваяСтрока.СтатусКонтрагента = СтатусКонтрагента;
			НоваяСтрока.Комментарий = Комментарий;
			
		КонецЦикла;
		
		EventsCount = СобытияКонтрагентов.Events.Количество();
		
		Если EventsCount > 0 Тогда
			
			Event = СобытияКонтрагентов.Events[EventsCount - 1];
			ИндексСобытия = Event.IndexKey;
			
		КонецЕсли;
		
		Если (СобытияКонтрагентов.TotalCount < ПорцияСобытий) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЛентаКонтрагентов_СрезПоследних(ТаблицаСобытий)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаСобытий.ДатаСобытия КАК ДатаСобытия,
		|	ТаблицаСобытий.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ТаблицаСобытий.СтатусКонтрагента КАК СтатусКонтрагента,
		|	ТаблицаСобытий.ИндексСобытия КАК ИндексСобытия,
		|	ТаблицаСобытий.ТипСобытия КАК ТипСобытия,
		|	ТаблицаСобытий.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ВТ_ТаблицаСобытий
		|ИЗ
		|	&ТаблицаСобытий КАК ТаблицаСобытий
		|ГДЕ
		|	ТаблицаСобытий.ТипСобытия <> """"
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаСобытий.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	МАКСИМУМ(ВТ_ТаблицаСобытий.ДатаСобытия) КАК ДатаСобытия
		|ПОМЕСТИТЬ ВТ_КонечныеДаты
		|ИЗ
		|	ВТ_ТаблицаСобытий КАК ВТ_ТаблицаСобытий
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТаблицаСобытий.ИдентификаторКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаСобытий.ДатаСобытия КАК ДатаСобытия,
		|	ВТ_ТаблицаСобытий.ИдентификаторКонтрагента КАК ИдентификаторКонтрагента,
		|	ВТ_ТаблицаСобытий.ТипСобытия КАК ТипСобытия,
		|	ВТ_ТаблицаСобытий.ИндексСобытия КАК ИндексСобытия,
		|	ВТ_ТаблицаСобытий.СтатусКонтрагента КАК СтатусКонтрагента,
		|	ВТ_ТаблицаСобытий.Комментарий КАК Комментарий
		|ИЗ
		|	ВТ_ТаблицаСобытий КАК ВТ_ТаблицаСобытий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КонечныеДаты КАК ВТ_КонечныеДаты
		|		ПО ВТ_ТаблицаСобытий.ДатаСобытия = ВТ_КонечныеДаты.ДатаСобытия
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСобытия УБЫВ";
	
	Запрос.УстановитьПараметр("ТаблицаСобытий", ТаблицаСобытий);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Проверяет наличие новых событий по ленте контрагентов у пользователя
//
// Параметры:
//  ИдентификаторЯщика	 - Строка - Идентификатор ящика организации
//
// Возвращаемое значение:
//  Булево - Есть новые события в ленте контрагентов дляпользователя
//
Функция ЛентаКонтрагентов_ЕстьНовыеСобытияДляПользователя(Знач ИдентификаторЯщика) Экспорт
	
	ГраницаСинхронизации = ДатаПоследнегоПрочитанногоСобытияКонтрагентов(
			ИдентификаторЯщика);
	
	Результат = Ложь;
	
	ПраваПользователя = ПраваПользователяЯщикаОрганизации(
		ИдентификаторЯщика);
	
	Если НЕ ПраваПользователя.CanManageCounteragents Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(ИдентификаторЯщика);
	Модуль_МетодыAPI = Модуль_МетодыAPI(ЭтотОбъект);
	
	ИндексСобытия = "";
	МеткаВремени = Date_2_Ticks(ГраницаСинхронизации);

	СобытияКонтрагентов = Модуль_МетодыAPI.DD_API_GetCounteragentEvents(
			ПараметрыСервиса,
			ИдентификаторЯщика,
			МеткаВремени,
			ИндексСобытия);
			
	Результат = ЗначениеЗаполнено(СобытияКонтрагентов.Events);
	
	Возврат Результат;
	
КонецФункции

Функция ЛентаКонтрагентов_КонтрактТаблицаСобытий()
	// BSLLS:MagicNumber-off
	ОписаниеТипаСтрока = Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100));
	ОписаниеТипаСтрока1000 = Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(1000));
	ОписаниеТипаДата = Новый ОписаниеТипов("Дата", , Новый КвалификаторыДаты);
	// BSLLS:MagicNumber-on
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИндексСобытия", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("ДатаСобытия", ОписаниеТипаДата);
	Результат.Колонки.Добавить("ТипСобытия", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("ИдентификаторКонтрагента", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("СтатусКонтрагента", ОписаниеТипаСтрока);
	Результат.Колонки.Добавить("Комментарий", ОписаниеТипаСтрока1000);
	
	Возврат Результат;
	
КонецФункции

// Функция - HTML события ленты контрагентов
//
// Параметры:
//  ИдентификаторЯщика	 - Строка - Идентификатор ящика организации
//
// Возвращаемое значение:
//   Строка - HTML событий по контрагентам
//
Функция HTML_СобытияЛентыКонтрагентов(ИдентификаторЯщика) Экспорт
	
	ВремяНачалаЗамера = ТекущаяУниверсальнаяДата();
	КоличествоНовыхСобытий = 0; 
	КоличествоСобытийВсего = 0; 
	КоличествоРекомендаций = 0;	
	
	Результат = HTML_СобытияЛентыКонтрагентовШаблонСтраницы();
	
	ЗаголовокНетСобытий = "<div class=""empty""><p>Пока событий нет</p></div></body>";
	
	ПраваПользователя = ПраваПользователяЯщикаОрганизации(
		ИдентификаторЯщика);
	
	Если НЕ ПраваПользователя.CanManageCounteragents Тогда
		ЗаголовокНетСобытий = "<div class=""empty""><p>Недостаточно прав для работы с контрагентами.</p></div></body>";
	КонецЕсли;
	
	ИдентификаторыОрганизации = Новый_ИдентификаторыСправочника( , ИдентификаторЯщика);
	ДанныеОрганизации = Организации_ЗаполненныеРеквизиты(ИдентификаторыОрганизации);
	
	ДатаПоследнегоПрочитанногоСобытияКонтрагентов = ДатаПоследнегоПрочитанногоСобытияКонтрагентов(
		ИдентификаторЯщика);
		
	ДатаПоследнегоСобытия = ТекущаяУниверсальнаяДата();
	
	ЗаписатьДатуПоследнегоПрочитанногоСобытияКонтрагентов(
		ИдентификаторЯщика, 
		ДатаПоследнегоСобытия);
		
	СекундВСутках = 86400;
	КоличествоДней = 15;
	НачалоТаблицыСобытий = ТекущаяУниверсальнаяДата() - (СекундВСутках * КоличествоДней);
	ТаблицаСобытий = ЛентаКонтрагентов_События(
			ИдентификаторЯщика,
			НачалоТаблицыСобытий);
	
	ТаблицаСобытий = ЛентаКонтрагентов_СрезПоследних(ТаблицаСобытий);
	
	Если НЕ ЗначениеЗаполнено(ТаблицаСобытий) Тогда
		
		Метрика_ДобавитьЗамер_ЧтениеЛентыКонтрагентов(
			ВремяНачалаЗамера, 
			ИдентификаторЯщика,
			КоличествоНовыхСобытий, 
			КоличествоСобытийВсего, 
			КоличествоРекомендаций);
			
		Возврат Результат + ЗаголовокНетСобытий;
	КонецЕсли;
	
	ИмяКолонкиИдентификаторов = "ИдентификаторКонтрагента";
	
	ТаблицаИдентификаторов = ТаблицаСобытий.Скопировать();
	ТаблицаИдентификаторов.Свернуть(ИмяКолонкиИдентификаторов);
	КоллекцияИдентификаторов = ТаблицаИдентификаторов.ВыгрузитьКолонку(ИмяКолонкиИдентификаторов);
	
	ТаблицаКонтрактов = Контрагенты_ТаблицаКонтрактовПоКоллекцииИдентификаторов(
			ИдентификаторЯщика,
			КоллекцияИдентификаторов);
	
	Для Каждого Стр Из ТаблицаСобытий Цикл
		
		Результат = Результат + "<div class=""notification"">";
		
		ВремяСобытия = МестноеВремя(Стр.ДатаСобытия, ЧасовойПояс());
		
		ТипСобытия = Стр.ТипСобытия;
		Статус = Стр.СтатусКонтрагента;
		ДатаСобытия = Формат(ВремяСобытия, "ДФ='dd MMMM ЧЧ:мм'");
		ЭтоНовоеСобытие = Стр.ДатаСобытия > ДатаПоследнегоПрочитанногоСобытияКонтрагентов;
		Комментарий = Стр.Комментарий;
		
		Если ЭтоНовоеСобытие Тогда
			Результат = Результат + "<div class=""indicator""></div>";
		Иначе
			Результат = Результат + "<div class=""space_left""></div>";
		КонецЕсли;
		
		АдресЯщикаКонтрагента = ИдентификаторВАдресЯщика(Стр.ИдентификаторКонтрагента);
		СтрокаКонтрагента = ТаблицаКонтрактов.Найти(АдресЯщикаКонтрагента, "ID");
		
		ИдентификаторыКонтрагента = Новый_ИдентификаторыСправочника(
				СтрокаКонтрагента.Ссылка,
				СтрокаКонтрагента.ID);
		
		СвязанныеСправочники = Контрагенты_СопоставленныеВ1С(ИдентификаторыКонтрагента);
		ЕстьСопоставление = ЗначениеЗаполнено(СвязанныеСправочники);
		
		HTML_СобытияЛентыКонтрагентовСтрокаСтатуса(
			Результат,
			ДанныеОрганизации,
			СтрокаКонтрагента,
			ЕстьСопоставление,
			Статус,
			ТипСобытия,
			ДатаСобытия,
			Комментарий);
		
		Результат = Результат + "</div>";
		
	КонецЦикла;
	
	Результат = Результат + "
		|</body>
		|</HTML>";
	
	КоличествоНовыхСобытий = СтрЧислоВхождений(Результат, "indicator"); 
	КоличествоСобытийВсего = СтрЧислоВхождений(Результат, "notification"); 
	КоличествоРекомендаций = СтрЧислоВхождений(Результат, "buttondiv");
	Метрика_ДобавитьЗамер_ЧтениеЛентыКонтрагентов(
			ВремяНачалаЗамера, 
			ИдентификаторЯщика,
			КоличествоНовыхСобытий, 
			КоличествоСобытийВсего, 
			КоличествоРекомендаций);
	
	Возврат Результат;
	
КонецФункции

