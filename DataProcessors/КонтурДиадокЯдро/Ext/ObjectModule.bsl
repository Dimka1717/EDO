Функция Пакеты_ОтправитьОтветНаВходящий(Пакет) Экспорт
	
	Результат = Истина;
	
	ПодготовленныеДанные = Документы_ДанныеДляMessagePatchToPost(Пакет.Документы);
	
	Попытка
		Документы_ПодписатьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
		Документы_ОтправитьДанныеДляMessagePatchToPost(ПодготовленныеДанные);
	Исключение
		
		ВидОперации		 	= "Отправка ответа на пакет документов";
		ТекстОшибки		 	= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ПредставлениеПакета	= ПредставлениеПакета(Пакет);
		ДопИнформация		= "Пакет: " + ПредставлениеПакета;
		ТекстСообщения		= Общее_ПодставитьПараметрыВСтроку("Не удалось отправить ответ на пакет документов %1", ПредставлениеПакета);
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции


