// Возвращает коллекцию контрактов МЧД для ящика
//
// Параметры:
//  BoxId				 - Строка	 - идентификатор ящика
//  ТолькоДействующие	 - Булево	 - признак того, что нужно вернуть только действующие МЧД
//
// Возвращаемое значение:
//  ФиксированноеСоответствие - коллекция контрактов МЧД (см. Новый_КонтрактМЧД)
//
Функция МЧД_СписокДоверенностей(BoxId, ТолькоДействующие = Истина) Экспорт
	
	Результат = Новый Соответствие;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(BoxId);
	ОписаниеПользователя = КонтекстСеанса_Прочитать(BoxId, "ОписаниеПользователя", Ложь);
	Ответ = АПИ_GetEmployeePowersOfAttorney(ПараметрыСервиса, BoxId, ОписаниеПользователя.Id, ТолькоДействующие);
	
	Для Каждого EmployeePowerOfAttorney Из Ответ.PowersOfAttorney Цикл
		
		PowerOfAttorney = EmployeePowerOfAttorney.PowerOfAttorney;
		IsDefault = EmployeePowerOfAttorney.IsDefault;
		
		КонтрактМЧД = АПИ_ЗаполненныйКонтрактМЧД(PowerOfAttorney, IsDefault);
		РезультатПроверки = МЧД_БыстраяПроверка(КонтрактМЧД, boxId);
		КонтрактМЧД.СтатусПроверки.СтруктураОшибок = РезультатПроверки;
		
		Результат.Вставить(КонтрактМЧД.Идентификатор, КонтрактМЧД);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МЧД_УстановитьЗначениеПризнакаПоУмолчанию(ИдентификаторЯщика, КонтрактМЧД) Экспорт
	
	Результат = Ложь;
	
	ПараметрыСервиса = ПараметрыСервиса_Диадок(ИдентификаторЯщика);
	ОписаниеПользователя = КонтекстСеанса_Прочитать(ИдентификаторЯщика, "ОписаниеПользователя", Ложь);
	
	КонтекстМЧД = МЧД_ДанныеПоИспользованиюДоверенностей(ИдентификаторЯщика);
	Если ЗначениеЗаполнено(КонтекстМЧД.МЧД) Тогда
		
		ТекущаяМЧДПоУмолчанию = КонтекстМЧД.СписокМЧД.Получить(КонтекстМЧД.МЧД);
		
		ПоУмолчанию = Ложь;
		
		МЧДСотрудника = АПИ_UpdateEmployeePowerOfAttorney(
				ПараметрыСервиса,
				ИдентификаторЯщика,
				ОписаниеПользователя.Id,
				ТекущаяМЧДПоУмолчанию.Идентификатор,
				ТекущаяМЧДПоУмолчанию.Доверитель.ИНН,
				ТекущаяМЧДПоУмолчанию.Представитель.ИНН,
				ПоУмолчанию);
		
		Если МЧДСотрудника.IsDefault = Истина Тогда
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	МЧДСотрудника = АПИ_UpdateEmployeePowerOfAttorney(
			ПараметрыСервиса,
			ИдентификаторЯщика,
			ОписаниеПользователя.Id,
			КонтрактМЧД.Идентификатор,
			КонтрактМЧД.Доверитель.ИНН,
			КонтрактМЧД.Представитель.ИНН,
			Истина);
	
	Результат = (МЧДСотрудника.IsDefault = Истина);
	
	Возврат Результат;
	
КонецФункции

Процедура МЧД_ПривязатьДоверенностьКСотруднику(BoxId, ИдентификаторМЧД, ИННДоверителя, ИННПредставителя) Экспорт
	
