// Определяет имя объекта метаданных, соответствующего указанному справочнику
//
// Параметры:
//  ИмяСправочника - Строка - принимает значения: "Организации", "Контрагенты"
// 
// Возвращаемое значение:
//  Строка - имя типа объекта
//
Функция Интеграция_ОпределитьТипЗначенияОбъекта(ИмяСправочника)
	
	ИмяСобытия = "ОпределитьТипЗначенияОбъекта";
	
	ПараметрыПМ = Новый Структура;
	ПараметрыПМ.Вставить("Синоним", ИмяСправочника);
	
	Результат = ПодключаемыйМодуль_ОбработатьСобытиеПередИМ(
		ИмяСобытия,
		ПараметрыПМ
	);
	
	Если ПодключаемыйМодуль_ТребуетсяВызватьИМ(Результат) Тогда
		
		Если ВРег(ИмяСправочника) = ВРег("Организации") Тогда
			
			РезультатИМ = "СправочникСсылка.Организации";
			
		ИначеЕсли ВРег(ИмяСправочника) = ВРег("Контрагенты") Тогда
			
			РезультатИМ = "СправочникСсылка.Контрагенты";
			
		Иначе
			
			Ошибка = Общее_ПодставитьПараметрыВСтроку(
				"Интеграция_ОпределитьТипЗначенияОбъекта: Неожиданное имя справочника (%1)",
				ИмяСправочника
			);
			
			Ошибка_Обработать(
				ИмяСобытия,
				Ошибка
			);
			
			РезультатИМ = Неопределено
			
		КонецЕсли;
		
		Результат = ПодключаемыйМодуль_ОбработатьСобытиеПослеИМ(
			ИмяСобытия,
			ПараметрыПМ,
			РезультатИМ
		);
		
	КонецЕсли;
	
	КонтурПлагины_ОбработатьСобытие(ИмяСобытия, ПараметрыПМ, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТипЗначенияОбъекта(Синоним, Формат = "Полный") Экспорт
	
	Результат = Интеграция_ОпределитьТипЗначенияОбъекта(Синоним);
	
	Если Формат = "Краткий" Тогда
		Результат = СтрЗаменить(Результат,	"СправочникСсылка.",	"");
		Результат = СтрЗаменить(Результат,	"ДокументСсылка.",		"");
	ИначеЕсли Формат = "ДляЗапроса" Тогда
		Результат = СтрЗаменить(Результат,	"Ссылка.",	".");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

