// Получает из сервиса значения функциональных опций для текущей информационной базы.
//
// Возвращаемое значение:
//  ФиксированноеСоответствие - значения опций.
//
Функция ФункциональныеОпции_Получить()
	
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка
		
		ЗначенияОпций = ФункциональныеОпцииСлужебный_Получить();
		
		ДопПеременные = Новый Структура();
		ДопПеременные.Вставить("ФункциональныеОпции", ЗначенияОпций);
		
		Метрика_ДобавитьЗамер(
			Метрика_КатегорияФункциональныеОпции(),
			Метрика_ДействиеПолучениеФункциональныхОпций(),
			НачалоЗамера,
			ДопПеременные
		);
		
	Исключение
		
		ЗначенияОпций = Новый Соответствие;
		
		ВидОперации = НСтр("ru = 'Получение функциональных опций'");
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		
		Ошибка_Обработать(ВидОперации, ИнформацияОбОшибке);
		
		Метрика_ДобавитьОшибку(
			Метрика_КатегорияФункциональныеОпции(),
			Метрика_ДействиеПолучениеФункциональныхОпций(),
			ИнформацияОбОшибке
		);
		
	КонецПопытки;
	
	Результат = Новый ФиксированноеСоответствие(ЗначенияОпций);
	
	Возврат Результат;
	
КонецФункции

Функция ФункциональныеОпцииСлужебный_Получить()
	
	ИдентификаторПродукта = ИдентификаторПродукта();
	ИдентификаторБазы = Строка(_ИдентификаторИнформационнойБазыДиадок());
	
	СервисОбновлений = Модуль_АпдейтКлиент();
	
	ЗапросФункциональныхОпций = СервисОбновлений.ЗапросФункциональныхОпций();
	ЗапросФункциональныхОпций.ИдентификаторКлиента = ИдентификаторБазы;
	
	ФункциональныеОпцииПродукта = СервисОбновлений.ПолучитьСписокФункциональныхОпцийПродукта(
		ИдентификаторПродукта,
		ЗапросФункциональныхОпций
	);
	
	Результат = Новый Соответствие;
	
	Для Каждого ТекущийЭлемент Из ФункциональныеОпцииПродукта Цикл
		
		Результат.Вставить(ТекущийЭлемент.ИмяФункциональнойОпции, ТекущийЭлемент.Значение);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

