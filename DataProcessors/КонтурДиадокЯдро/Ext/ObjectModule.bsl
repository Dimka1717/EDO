//{		ОТКРЫТИЕ ДОКУМЕНТА УЧЕТА

Функция ДокументыУчета_СтрокаСписка(ДокументУчета) Экспорт
	
	Результат = Контракт_СтрокаСпискаДокументов();
	
	РеквизитыДокумента = ДокументыУчета_РеквизитыДокументаУчетаДляПакетаНаОтправку(ДокументУчета);
		
	Документ = Неопределено;
	ДокументыОснования = ЗначениеВМассив(РеквизитыДокумента.Документ);
	
	ИдентификаторыДокументов = ХранениеДанных_ИдентификаторыОтправленныхДокументовПоДокументам1С(
		Документ,
		ДокументыОснования
	);
	
	Если ИдентификаторыДокументов.Количество() Тогда
		ИдентификаторыДокумента = ИдентификаторыДокументов[ИдентификаторыДокументов.ВГраница()];
	Иначе
		ИдентификаторыДокумента = Неопределено;
	КонецЕсли;
	
	Если ИдентификаторыДокумента = Неопределено Тогда
		
		ВидПакетаID = ДокументыУчета_ВидПакетаОтправляемогоДокумента(РеквизитыДокумента);
		
		Если Не ЗначениеЗаполнено(ВидПакетаID) Тогда
			Ошибка = "ОткрытиеДокументаУчета: Не удалось определить вид пакета для документа %1";
			Ошибка = СтрЗаменить(Ошибка, "%1", РеквизитыДокумента.Документ);
			ВызватьИсключение Ошибка;
		КонецЕсли;
		
		Результат.ВидПакетаID = ВидПакетаID;
		Результат.ТребуемоеДействие = "Отправить пакет";
		Результат.Документ = РеквизитыДокумента.Документ;
		Результат.Организация = РеквизитыДокумента.Организация;
		Результат.Контрагент = РеквизитыДокумента.Контрагент;
		Результат.НомерДокумента = РеквизитыДокумента.НомерДокумента;
		Результат.ДатаДокумента = РеквизитыДокумента.ДатаДокумента;
		Результат.СуммаДокумента = РеквизитыДокумента.СуммаДокумента;
		Результат.Направление = "Исходящее";
		
	Иначе
		
		ИдентификаторОрганизации = Организации_ИдентификаторПоСсылке(РеквизитыДокумента.Организация);
		
		BoxID = АдресЯщикаВИдентификатор(ИдентификаторОрганизации);
		
		ОтборПоПакету = Новый Структура("BoxID, LetterID, DocumentID, ИдентификаторПакета");
		ОтборПоПакету.BoxID = BoxID;
		ОтборПоПакету.LetterID = ИдентификаторыДокумента.MessageId;
		ОтборПоПакету.DocumentID = ИдентификаторыДокумента.EntityId;
		ОтборПоПакету.ИдентификаторПакета = ИдентификаторыДокумента.MessageId;
		
		ПараметрыСпискаДокументов = Контракт_ПараметрыПолученияСпискаДокументов();
		ПараметрыСпискаДокументов.НачалоПериода = НачалоДня(РеквизитыДокумента.ДатаДокумента);
		ПараметрыСпискаДокументов.КонецПериода = КонецДня(РеквизитыДокумента.ДатаДокумента);
		ПараметрыСпискаДокументов.РежимОтбораПоПериоду = "ПоДатеДокумента";
		ПараметрыСпискаДокументов.ОтборПоПакету = ОтборПоПакету;
		
		СписокДокументов = СписокДокументов_ОтправленныеДокументы(ПараметрыСпискаДокументов);
		
		Для Каждого СтрокаСписка Из СписокДокументов Цикл
			
			ЗаполнитьЗначенияСвойств(Результат, СтрокаСписка);
			Прервать;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

