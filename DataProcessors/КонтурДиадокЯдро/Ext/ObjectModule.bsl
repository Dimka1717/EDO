Функция Новый_ОписаниеВалюты(СимвольныйКод, НаименованиеПолное, ПараметрыПрописи)
	
	Модель = Новый Структура;
	Модель.Вставить("Наименование", СокрЛП(СимвольныйКод));
	Модель.Вставить("НаименованиеПолное", СокрЛП(НаименованиеПолное));
	Модель.Вставить("ПараметрыПрописи", СокрЛП(ПараметрыПрописи));
	
	Результат = Новый ФиксированнаяСтруктура(Модель);
	
	Возврат Результат;
	
КонецФункции

Функция НовыйОбщероссийскийКлассификаторВалют()
	
	ГенерацияXML = Модуль_ГенерацияXML(ЭтотОбъект);
	Данные = ГенерацияXML.ПолучитьОКВ();
	
	Модель = Новый Соответствие;
	
	Для Каждого Запись Из Данные Цикл
		
		ЦифровойКод = СокрЛП(Запись.Код);
		ОписаниеВалюты = Новый_ОписаниеВалюты(
			Запись.КодСимвольный,
			Запись.Наименование,
			Запись.ПараметрыИсчисления
		);
		
		Модель.Вставить(ЦифровойКод, ОписаниеВалюты);
		
	КонецЦикла;
	
	Результат = Новый ФиксированноеСоответствие(Модель);
	
	Возврат Результат;
	
