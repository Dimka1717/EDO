// Модель данных о сессии пользователя Диадока
// 
// Возвращаемое значение:
//  Структура - содержит ключи:
//    * Ключ - Строка - ключ (идентификатор) сессии
//    * ТокенДоступа - Строка - авторизационный токен (access_token)
//    * ТипТокена - Строка - тип авторизационного токена (см. Перечисление_ТипыТокенов)
//    * СхемаАутентификации - Строка - идентификатор схемы получения токена (см. Перечисление_СхемыАутентификации)
//    * Пользователь - Структура - см. МодельПользовательСервиса
//    * ЭтоПортальнаяСессия - Булево - Истина, если использовалась схема получения токена через Портал
//    * УниверсальнаяДатаОкончания - Дата - дата окончания действия токена (UTC)
//
Функция МодельСессияПользователя()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Ключ", "");
	Результат.Вставить("ТокенДоступа", "");
	Результат.Вставить("ТипТокена", "");
	Результат.Вставить("СхемаАутентификации", "");
	Результат.Вставить("Пользователь", МодельПользовательСервиса());
	Результат.Вставить("ЭтоПортальнаяСессия", Ложь);
	Результат.Вставить("УниверсальнаяДатаОкончания", Дата(1, 1, 1));
	
	Возврат Результат;
	
КонецФункции

// Модель ящика организации Диадока
// 
// Возвращаемое значение:
//  Структура - содержит поля:
//    * Идентификатор - Строка - идентификатор ящика в нижнем регистре (BoxIdGuid)
//    * Адрес - Строка - идентификатор ящика в нижнем регистре в формате <...@diadoc.ru>
//    * Наименование - Строка - наименование ящика
//    * Организация - Структура - см. МодельОрганизацияСервиса
//
Функция МодельЯщикОрганизации()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("Адрес", "");
	Результат.Вставить("Наименование", "");
	Результат.Вставить("Организация", МодельОрганизацияСервиса());
	
	Возврат Результат;
	
КонецФункции

// Модель организации Диадока
// 
// Возвращаемое значение:
//  Структура - содержит поля:
//   * Идентификатор - Строка - идентификатор организации в нижнем регистре (OrgId)
//   * Наименование - Строка - Краткое наименование организации
//   * НаименованиеПолное - Строка - Полное наименование организации
//   * ИНН - Строка - ИНН организации
//   * КПП - Строка - КПП организации
//   * ОГРН - Строка - ОГРН организации
//   * ИдентификаторУчастникаЭДО - Строка - зарегистрированный в ФНС идентификатор участника документооборота
//   * Тестовая - Булево - Истина, если это тестовая организация
//   * Реальная - Булево - Истина, если это реальная организация
//   * Роуминговая - Булево - Истина, если это роуминговая организация
//
Функция МодельОрганизацияСервиса()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Идентификатор", "");
	Результат.Вставить("Наименование", "");
	Результат.Вставить("НаименованиеПолное", "");
	Результат.Вставить("ИНН", "");
	Результат.Вставить("КПП", "");
	Результат.Вставить("ОГРН", "");
	Результат.Вставить("ИдентификаторУчастникаЭДО", "");
	Результат.Вставить("Тестовая", Ложь);
	Результат.Вставить("Реальная", Истина);
	Результат.Вставить("Роуминговая", Ложь);
	
	Возврат Результат;
	
КонецФункции

