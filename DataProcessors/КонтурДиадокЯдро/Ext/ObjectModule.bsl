	ИначеЕсли ТипКонтента = ТипыКонтента.ucd736 Тогда
		
		Результат = Модуль_ГенерацияXML.XML_ОтветныйТитул_УКД_736(ПротоКонтентXDTO, ФайлТитулаПродавца, ФайлПодписиПродавца, ПараметрыФормированияФайла);
		
