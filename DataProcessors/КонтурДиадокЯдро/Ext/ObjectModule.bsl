Функция ГенерацияШаблонаКодаПМ_ДеревоСобытийПодключаемогоМодуля(Дерево = Неопределено) Экспорт
	
	Если Дерево = Неопределено Тогда
		Дерево = Новый ДеревоЗначений;
		ДобавитьКолонкиВТаблицуЗначений(Дерево, "Имя, АдресСправки, Описание, ЭтоГруппа, ПереопределитьПолностью, ОбработатьТиповойРезультат, ПроцедурныйТипСобытия");
	КонецЕсли;
	
	Макет	= Макеты_СобытияПодключаемогоМодуля();
	Область	= Макет.ПолучитьОбласть("События");
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		
		Родитель		= ПолучитьТекстЯчейкиОбласти(Область, Сч, 1);
		Имя				= ПолучитьТекстЯчейкиОбласти(Область, Сч, 2);
		АдресСправки	= ПолучитьТекстЯчейкиОбласти(Область, Сч, 3);
		Описание		= ПолучитьТекстЯчейкиОбласти(Область, Сч, 4);
		ПроцедурныйТип	= ПолучитьТекстЯчейкиОбласти(Область, Сч, 5);
		
		ТекРодитель = Дерево.Строки.Найти(Родитель, "Имя", Истина);
		
		Если ТекРодитель = Неопределено Тогда
			
			ТекРодитель = Дерево.Строки.Добавить();		
			ТекРодитель.Имя			= Родитель;
			ТекРодитель.ЭтоГруппа	= Истина;
			
		КонецЕсли;
		
		НовСтрокаДерева = ТекРодитель.Строки.Добавить();		
		
		НовСтрокаДерева.Имя							= Имя;
		НовСтрокаДерева.АдресСправки				= АдресСправки;
		НовСтрокаДерева.Описание					= Описание;
		НовСтрокаДерева.ЭтоГруппа 					= Ложь;
		НовСтрокаДерева.ПереопределитьПолностью		= Ложь;
		НовСтрокаДерева.ОбработатьТиповойРезультат	= Ложь;
		НовСтрокаДерева.ПроцедурныйТипСобытия		= (ПроцедурныйТип = "Да");
		
	КонецЦикла;
	
	Возврат Дерево;
	
КонецФункции

Функция ГенерацияШаблонаКодаПМ_ТекстШаблонаПМ(Дерево) Экспорт
	
	Макет = Макеты_СобытияПодключаемогоМодуля();
	
	ТекстМодуля					= "";
	ТекстКодаФормированияВПФ	= "";
	
	ИменаТиповXDTO				= Новый Массив;
	СобытияПереопределения		= Новый Массив;
	СобытияОбработкиРезультата	= Новый Массив;
	
	ИмяБлока_ГенерацииКонтента	= "Генерация контента";
	ИмяБлока_Другое				= "Другое";
	
	ТекстКодаОбработкиСобытий		= "";
	ТекстФункцииОбработатьСобытие	= "";
	
	Для Каждого СтрокаВерхнегоУровня Из Дерево.Строки Цикл
		Для Каждого СтрокаДерева Из СтрокаВерхнегоУровня.Строки Цикл
			
			Если СтрокаВерхнегоУровня.Имя = ИмяБлока_ГенерацииКонтента Тогда
				
				Если СтрокаДерева.ПереопределитьПолностью ИЛИ СтрокаДерева.ОбработатьТиповойРезультат Тогда
					ИменаТиповXDTO.Добавить(СтрокаДерева.Описание);
				КонецЕсли;
				
			ИначеЕсли СтрокаВерхнегоУровня.Имя = ИмяБлока_Другое Тогда	
				
				Если СтрокаДерева.Описание = "ВПФ" 
					И (СтрокаДерева.ПереопределитьПолностью ИЛИ СтрокаДерева.ОбработатьТиповойРезультат) Тогда
					
					Если ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули.ДополнительныеОтчетыИОбработки") Тогда
						ПостфиксОбласти = "ДополнительныеОтчетыИОбработки";
					ИначеЕсли ПроверитьНаличиеОбъектаМетаданных("ОбщиеМодули.УниверсальныеМеханизмы") Тогда
						ПостфиксОбласти = "УниверсальныеМеханизмы";
					Иначе
						ПостфиксОбласти = "МодульОбъекта";
					КонецЕсли;
					
					ТекстКодаФормированияВПФ = Макет.ПолучитьОбласть("ОбщийКодФормированияВПФ_" + ПостфиксОбласти).ТекущаяОбласть.Текст + "
																	|";
					
				КонецЕсли;
				
			Иначе
				Если СтрокаДерева.ОбработатьТиповойРезультат ИЛИ СтрокаДерева.ПереопределитьПолностью Тогда
					
					ТекстФункцииОбработатьСобытие = ТекстФункцииОбработатьСобытие + "
													|
													|	ИначеЕсли ИмяСобытия = """ + СтрокаДерева.Имя + """ Тогда
													|
													|		Возврат " + СтрокаДерева.Имя + "(Параметры);";
						
						Если Макет.Области.Найти("Шаблон_" + СтрокаДерева.Имя) <> Неопределено Тогда
							ШаблонПереопределения	= Макет.ПолучитьОбласть("Шаблон_" + СтрокаДерева.Имя + "|Переопределение").ТекущаяОбласть.Текст;
							ШаблонОбработки			= Макет.ПолучитьОбласть("Шаблон_" + СтрокаДерева.Имя + "|Обработка").ТекущаяОбласть.Текст;
						Иначе
							ШаблонПереопределения	= "";
							ШаблонОбработки			= "";
						КонецЕсли;
						
				КонецЕсли;
				
				Если СтрокаДерева.ОбработатьТиповойРезультат Тогда
					
					ТекстКодаОбработкиСобытий = ТекстКодаОбработкиСобытий + "
												|Функция " + СтрокаДерева.Имя + "(Параметры)
												|
												|	Если ТипЗнч(Параметры) = Тип(""Структура"") И Параметры.Свойство(""Результат_ИМ"") Тогда
												|
												|" + ?(ШаблонОбработки = "", "		//Возврат " + ?(СтрокаДерева.ПроцедурныйТипСобытия, "Истина", "Результат") + ";", ШаблонОбработки) + "
												|
												|	КонецЕсли;
												|
												|КонецФункции
												|";
					
				ИначеЕсли СтрокаДерева.ПереопределитьПолностью Тогда
					
					ТекстКодаОбработкиСобытий = ТекстКодаОбработкиСобытий + "
												|Функция " + СтрокаДерева.Имя + "(Параметры)
												|
												|" + ?(ШаблонПереопределения = "", "	//Возврат " + ?(СтрокаДерева.ПроцедурныйТипСобытия, "Истина", "Результат") + ";", ШаблонПереопределения) + "
												|
												|КонецФункции
												|";
					
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Если ТекстФункцииОбработатьСобытие <> "" Тогда
		
		ТекстФункцииОбработатьСобытие = СокрЛП(ТекстФункцииОбработатьСобытие);
		ТекстФункцииОбработатьСобытие = Символы.Таб + Прав(ТекстФункцииОбработатьСобытие, СтрДлина(ТекстФункцииОбработатьСобытие)-5);
		
		ТекстФункцииОбработатьСобытие = "
										|Функция ОбработатьСобытие(ИмяСобытия, Параметры) Экспорт
										|
										|" + ТекстФункцииОбработатьСобытие + "
										|
										|	КонецЕсли;
										|
										|КонецФункции
										|
										|";
			
		ТекстКодаОбработкиСобытий = ТекстКодаОбработкиСобытий + "
									|";
								
	КонецЕсли;
	
	
	ТекстЗаполненияТиповXDTO = ГенерацияШаблонаКодаПМ_ТекстКодаДляЗаполненияТиповXDTO(ИменаТиповXDTO);
	
	ТекстОбщегоКодаXDTO	= ?(ЗначениеЗаполнено(ТекстЗаполненияТиповXDTO), Макет.ПолучитьОбласть("ОбщийКодXDTO").ТекущаяОбласть.Текст, "");
	ТекстОбщегоКода		= Макет.ПолучитьОбласть("ОбщийКод").ТекущаяОбласть.Текст;
		
	ТекстМодуля = "
		    	|Перем ОсновнойМодуль Экспорт;
				|" 
				+ ТекстФункцииОбработатьСобытие
				+ ТекстКодаОбработкиСобытий
				+ ТекстЗаполненияТиповXDTO
				+ ТекстОбщегоКодаXDTO
				+ ТекстКодаФормированияВПФ
				+ ТекстОбщегоКода;	
	
	Результат = Новый ТекстовыйДокумент;
	Результат.УстановитьТекст(ТекстМодуля);
	
	Возврат Результат;
	
КонецФункции

Функция ГенерацияШаблонаКодаПМ_ТекстКодаДляЗаполненияТиповXDTO(ИменаТипов)
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	
	// Определим требуемые для генерации типы XDTO
	КоллекцияОбъектовXDTO = Новый Соответствие;
	
	СсылкиНаДокументацию = Новый Соответствие;
	
	Для Каждого Пакет Из ГенерацияXML_ProtoФабрикаXDTO().Пакеты Цикл
		Если Пакет.URIПространстваИмен = ГенерацияШаблонаКодаПМ_URIТиповКомпоненты() Тогда
			
			Для Каждого Свойство Из Пакет Цикл
				
				Если ТипЗнч(Свойство) = Тип("ТипОбъектаXDTO")
					И ИменаТипов.Найти(Свойство.Имя) <> Неопределено Тогда
					
					КоллекцияОбъектовXDTO.Вставить(Свойство.Имя, Свойство);
					ГенерацияШаблонаКодаПМ_ДобавитьВспомогательныеТипы(КоллекцияОбъектовXDTO, Свойство);
					
					ГенерацияШаблонаКодаПМ_СгенерироватьСсылкиНаДокументацию(СсылкиНаДокументацию, Свойство);
					
				КонецЕсли;
				
			КонецЦикла;
			
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Для Каждого ТекущийОбъектXDTO Из КоллекцияОбъектовXDTO Цикл
		
		Элемент = ТекущийОбъектXDTO.Значение;
		
		Запись.ЗаписатьБезОбработки("
									|Процедура Заполнить_" + ТекущийОбъектXDTO.Ключ + "(Контент, Параметры)
									|");
		
		ТекстСсылкиНаДокументацию = СсылкиНаДокументацию[ТекущийОбъектXDTO.Ключ];
		Если ЗначениеЗаполнено(ТекстСсылкиНаДокументацию) Тогда
			ТекстСсылкиНаДокументацию = "
			|	" + ТекстСсылкиНаДокументацию + "
			|
			|";
		Иначе
			ТекстСсылкиНаДокументацию = "
			|";
		КонецЕсли;
		
		Запись.ЗаписатьБезОбработки(ТекстСсылкиНаДокументацию);
		
		// Запишем заполнение свойств
		Для Каждого Свойство Из Элемент.Свойства Цикл
			
			Если Прав(Свойство.Имя, 9) = "_ReadOnly" Тогда
				Продолжить;
			КонецЕсли;
			
			Если ТипЗнч(Свойство.Тип) <> Тип("ТипОбъектаXDTO")
				Или Свойство.Тип.Имя = "anyType" Тогда // anyType - для ссылок на справочники 1С
				
				Если Свойство.ВерхняяГраница <> 1 Тогда
					// массив
					Запись.ЗаписатьБезОбработки("
					|	Для Сч = 1 По 0 Цикл
					|		НовЭлемент = Контент." + Свойство.Имя + ".Добавить();
					|		НовЭлемент." + Свойство.Имя + " = Неопределено;
					|	КонецЦикла;
					|
					|");
					
				Иначе
					// единичный элемент
					СтрТабов = ГенерацияШаблонаКодаПМ_ПодстрокаДляВыравнивания("""" + Свойство.Имя + """,", 7);
					Запись.ЗаписатьБезОбработки("	УстановитьЗначениеXDTO(Контент, """ + Свойство.Имя + """," + СтрТабов + "Неопределено);
					|");
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Запись.ЗаписатьБезОбработки(Символы.ПС);
		
		// Запишем заполнение вложенных объектов
		Для Каждого Свойство Из Элемент.Свойства Цикл
			
			Если Прав(Свойство.Имя, 9) = "_ReadOnly" 
				Или Свойство.Тип.Имя = "anyType" Тогда
				Продолжить;
			КонецЕсли;
			
			Если ТипЗнч(Свойство.Тип) = Тип("ТипОбъектаXDTO") Тогда
				
				ИмяТипаXDTO = ГенерацияШаблонаКодаПМ_ИмяТипаXDTO(Свойство);
				
				Если Свойство.ВерхняяГраница <> 1 Тогда
					
					// массив
					Запись.ЗаписатьБезОбработки("
					|	Для Сч = 1 По 0 Цикл
					|		НовЭлемент = НовыйЭлементСпискаXDTO(Контент." + Свойство.Имя + ");
					|		Заполнить_" + ИмяТипаXDTO + "(НовЭлемент, Неопределено);
					|	КонецЦикла;
					|
					|");
					
				Иначе	
					// единичный элемент
					СтрТабов = ГенерацияШаблонаКодаПМ_ПодстрокаДляВыравнивания("Заполнить_" + ИмяТипаXDTO, 10);
					Запись.ЗаписатьБезОбработки("	Заполнить_" + ИмяТипаXDTO + СтрТабов + "(Контент." + Свойство.Имя + ", Неопределено);
					|");
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Запись.ЗаписатьБезОбработки("
		|КонецПроцедуры
		|");
		
	КонецЦикла;
	
	Результат = Запись.Закрыть();
	
	Возврат Результат;	
	
КонецФункции

Процедура ГенерацияШаблонаКодаПМ_ДобавитьВспомогательныеТипы(КоллекцияОбъектовXDTO, ТипОбъектаXDTO)
	
	Для Каждого Свойство Из ТипОбъектаXDTO.Свойства Цикл
		
		Если ТипЗнч(Свойство.Тип) = Тип("ТипОбъектаXDTO") Тогда
			
			ИмяТипаXDTO = ГенерацияШаблонаКодаПМ_ИмяТипаXDTO(Свойство);
			
			Если КоллекцияОбъектовXDTO.Получить(ИмяТипаXDTO) = Неопределено
				И ИмяТипаXDTO <> "anyType" Тогда
				
				КоллекцияОбъектовXDTO.Вставить(ИмяТипаXDTO, Свойство.Тип);
				ГенерацияШаблонаКодаПМ_ДобавитьВспомогательныеТипы(КоллекцияОбъектовXDTO, Свойство.Тип);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ГенерацияШаблонаКодаПМ_ИмяТипаXDTO(Свойство)
	
	Результат = Свойство.Тип.Имя;
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Результат = Свойство.ТипВладелец.Имя + "_" + Свойство.Имя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ГенерацияШаблонаКодаПМ_ПодстрокаДляВыравнивания(ИсходнаяСтрока, КоличествоТабуляций)
	
	Результат = "";
	
	Табов = Макс(КоличествоТабуляций - Цел(СтрДлина(ИсходнаяСтрока) / 4), 0);
	
	Для Сч = 1 По Табов Цикл
		Результат = Результат + Символы.Таб;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

