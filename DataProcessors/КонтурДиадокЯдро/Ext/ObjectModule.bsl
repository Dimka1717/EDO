// Возвращает информацию о подписанте из двоичных данных подписи
//
// Параметры:
//  ДанныеПодписи	 - 	Строка - данные подписи, закодированные по алгоритму base64
//
// Возвращаемое значение:
//  Структура:
//   *Организация	 - Строка
//   *Подписант		 - Строка
//   *Должность		 - Строка
//
Функция ДанныеПодписантаИзПодписи(ДанныеПодписи) Экспорт
	
	Сертификат = ВнешниеСервисы_ПолучитьСертификатИзПодписи(Base64Значение(ДанныеПодписи));
	
	SN = СвойствоСтруктуры(Сертификат.Субъект, "SN", "");
	G = СвойствоСтруктуры(Сертификат.Субъект, "G", "");
	GN = СвойствоСтруктуры(Сертификат.Субъект, "GN", "");
	
	Подписант = СокрЛП(SN + ?(ЗначениеЗаполнено(G), " " + G, "") + ?(ЗначениеЗаполнено(GN), " " + GN, ""));
	
	Результат = Новый Структура;
	Результат.Вставить("Организация", СвойствоСтруктуры(Сертификат.Субъект, "O", ""));
	Результат.Вставить("Подписант", Подписант);
	Результат.Вставить("Должность", СвойствоСтруктуры(Сертификат.Субъект, "T", ""));
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеСобытияИсторииДО(BoxId, DocumentId, DocumentDirection, Событие)
	
	ТипВложения = АПИ_Перечисление_AttachmentType();
	
	AttachmentType = Событие.AttachmentType;
	
	Результат = "";
	
	Если Событие.IsApprovementSignature Тогда
		
		Результат = "подписал документ";
		
	ИначеЕсли Событие.EntityId = DocumentId Тогда
		
		Если Событие.Шаблон Тогда
			
			Результат = "отправлен шаблон";
			
		Иначе
			
			СтрокаПолучил	 = "подписал документ и завершил документооборот";
			СтрокаОтправил	 = "подписал и отправил документ";
			
			Если DocumentDirection = "Inbound" Тогда
				Результат = ?(Событие.BoxId = BoxId, СтрокаПолучил, СтрокаОтправил);
			Иначе
				Результат = ?(Событие.BoxId = BoxId, СтрокаОтправил, СтрокаПолучил);
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли Найти(AttachmentType, "Receipt") > 0 Тогда
		
		Результат = "подписал и отправил извещение о получении";
		
	ИначеЕсли AttachmentType = ТипВложения.XmlSignatureRejection Тогда
		
		Если Событие.ParentAttachmentType = "RevocationRequest" Тогда
			Результат = "отказал в аннулировании документа";
		Иначе
			Результат = "отказал в подписи документа";
		КонецЕсли;
		
	ИначеЕсли Найти(AttachmentType, "BuyerTitle") > 0 Тогда
		
		Если Событие.ПодписанСРазногласиями Тогда
			Результат = "подписал документ с разногласиями и завершил документооборот";
		ИначеЕсли Событие.ОтказаноВПодписи Тогда
			Результат = "отказал в подписи документа и завершил документооборот";
		Иначе	
			Результат = "подписал документ и завершил документооборот";
		КонецЕсли;
		
	ИначеЕсли AttachmentType = ТипВложения.RevocationRequest Тогда
		
		Результат = ?(Событие.BoxId = BoxId,
					  "подписал и отправил соглашение об аннулировании",
					  "аннулировал документ и подписал соглашение об аннулировании");
		
	ИначеЕсли AttachmentType = ТипВложения.InvoiceCorrectionRequest Тогда
		
		Результат = "запросил уточнение документа";
		
	ИначеЕсли AttachmentType = ТипВложения.Resolution Тогда
		
		Если Событие.ResolutionType = "Approve" Тогда
			Результат = "согласовал документ";
		ИначеЕсли Событие.ResolutionType = "Disapprove" Тогда
			Результат = "отказал в согласовании документа";
		КонецЕсли;
		
	ИначеЕсли AttachmentType = ТипВложения.ResolutionRequest Тогда
		
		Результат		 = "передал документ на %1 %2";
		ТипЗапроса		 = "";
		КомуНаправлен	 = "";
		
		Если Событие.RequestType = "ApprovementRequest" Тогда
			ТипЗапроса = "согласование";
		ИначеЕсли Событие.RequestType = "SignatureRequest" Тогда
			ТипЗапроса = "подпись";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Событие.User) И ЗначениеЗаполнено(Событие.UserId) Тогда
			КомуНаправлен = "сотруднику: " + ФамилияИО(Событие.User);
		ИначеЕсли ЗначениеЗаполнено(Событие.Department) И ЗначениеЗаполнено(Событие.DepartmentId) Тогда
			КомуНаправлен = "в подразделение: " + Событие.Department;
		КонецЕсли;
		
		Результат = Общее_ПодставитьПараметрыВСтроку(Результат, ТипЗапроса, КомуНаправлен);
		
	ИначеЕсли AttachmentType = ТипВложения.ResolutionRequestDenial Тогда
		
		Результат = "отказал в запросе подписи сотруднику";
		
	ИначеЕсли AttachmentType = "ResolutionRouteAssignmentAttachment" Тогда
		
		Результат = Общее_ПодставитьПараметрыВСтроку("передал документ по маршруту ""%1""", Событие.Маршрут);
		
	ИначеЕсли AttachmentType = "ResolutionRouteRemovalAttachment" Тогда
		
		Результат = Общее_ПодставитьПараметрыВСтроку("снял документ с маршрута ""%1""", Событие.Маршрут);
		
	ИначеЕсли AttachmentType = ТипВложения.TemplateTransformation Тогда
		
		Результат = "из шаблона создан";
		
	ИначеЕсли AttachmentType = ТипВложения.TemplateRefusal Тогда
		
		СтрокаОтозванШаблон	 = "отозван шаблон";
		СтрокаОтклоненШаблон = "отклонен шаблон";
		
		Если DocumentDirection = "Inbound" Тогда
			Результат = ?(Событие.BoxId = BoxId, СтрокаОтклоненШаблон, СтрокаОтозванШаблон);
		Иначе
			Результат = ?(Событие.BoxId = BoxId, СтрокаОтозванШаблон, СтрокаОтклоненШаблон);
		КонецЕсли;
		
	ИначеЕсли AttachmentType = ТипВложения.OuterDocflow Тогда
		
		// чтобы не потерять ранее сформированное описание
		Результат = Событие.Описание;
		
	ИначеЕсли AttachmentType = ТипВложения.MoveDocument Тогда
		
		Результат = Общее_ПодставитьПараметрыВСтроку("Документ перемещен в %1", Событие.Department);
		
	ИначеЕсли AttachmentType = ТипВложения.Title Тогда
		
		Если DocumentDirection = "Inbound" 
			ИЛИ DocumentDirection = "Outbound" 
			ИЛИ DocumentDirection = "Internal" Тогда
			Результат = "подписал документ и завершил документооборот";
		КонецЕсли;
		
	ИначеЕсли AttachmentType = ТипВложения.TtGisFixationCancellationRequest  Тогда
		
		Результат = "отменил сведения об отгрузке, ранее переданные в ГИС МТ";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДолжностиПользователей(ПараметрыСервиса, BoxId) Экспорт
	
	Результат = Новый Соответствие;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	Если Не СтрокаКонтекста = Неопределено Тогда
		
		OrganizationUsersList = АПИ_GetOrganizationUsers(ПараметрыСервиса, СтрокаКонтекста.OrgId);
		Для Каждого OrganizationUser Из OrganizationUsersList.Users Цикл
			Результат.Вставить(OrganizationUser.Name, OrganizationUser.Position);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция МаршрутыСогласования(ПараметрыСервиса, BoxId) Экспорт
	
	Результат = Новый Соответствие;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxId, Ложь);
	Если Не СтрокаКонтекста = Неопределено Тогда
		
		ResolutionRouteList = АПИ_GetResolutionRoutesForOrganization2(ПараметрыСервиса, СтрокаКонтекста.OrgId);
		Для Каждого ResolutionRoute Из ResolutionRouteList.ResolutionChains Цикл
			Результат.Вставить(ResolutionRoute.ChainId, ResolutionRoute.Name);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ResolutionAttachmentTypesСollectionsNames()
	
	Результат = Новый Структура;
	Результат.Вставить("Resolution"							, "ResolutionInfo");
	Результат.Вставить("ResolutionRequest"					, "ResolutionRequestInfo");
	Результат.Вставить("ResolutionRequestDenial"			, "ResolutionRequestDenialInfo");
	Результат.Вставить("ResolutionRouteAssignment"			, "ResolutionRouteAssignmentInfo");
	Результат.Вставить("ResolutionRouteRemoval"				, "ResolutionRouteRemovalInfo");
	Результат.Вставить("ResolutionRouteAssignmentAttachment", "ResolutionRouteAssignmentInfo");
	Результат.Вставить("ResolutionRouteRemovalAttachment"	, "ResolutionRouteRemovalInfo");
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеМаршрутизации(AttachmentType, Entity, BoxId)
	
	Результат = Новый Структура("BoxId, Author, ResolutionType, RequestType, RouteId, User, UserId, Department, DepartmentId, Комментарий");
	
	ИмяКоллекции = "";
	Если ResolutionAttachmentTypesСollectionsNames().Свойство(AttachmentType, ИмяКоллекции) Тогда
		
		Коллекция	 = Entity[ИмяКоллекции];
		Target		 = СвойствоСтруктуры(Коллекция, "Target");
		Content		 = СвойствоСтруктуры(Entity, "Content");
		
		Результат.BoxId				 = BoxId;
		
		Результат.Author			 = СвойствоСтруктуры(Коллекция, "Author", "");
		Результат.ResolutionType	 = СвойствоСтруктуры(Коллекция, "ResolutionType", "");
		Результат.RequestType		 = СвойствоСтруктуры(Коллекция, "RequestType", "");
		Результат.RouteId			 = СвойствоСтруктуры(Коллекция, "RouteId", "");
		
		Результат.User				 = СвойствоСтруктуры(Target, "User", "");
		Результат.UserId			 = СвойствоСтруктуры(Target, "UserId", "");
		Результат.Department		 = СвойствоСтруктуры(Target, "Department", "");
		Результат.DepartmentId		 = СвойствоСтруктуры(Target, "DepartmentId", "");
		
		Комментарий = "";
		Если КонтентСодержитДанные(Content) Тогда
			Комментарий = ДвоичныеДанные_В_Текст(Base64Значение(Content.Data), КодировкаТекста.UTF8);
			Результат.Комментарий = Комментарий;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КомментарийСобытияИсторииДО(Content)
	
	Результат = "";
	
	Если КонтентСодержитДанные(Content) Тогда
		
		Если ТипЗнч(Content.Data) = Тип("Строка") Тогда
			Data = Base64Значение(Content.Data);
		Иначе 
			Data = Content.Data;
		КонецЕсли;	
			
		ContentXDTO	= ГенерацияXML_XML_В_ОбъектXDTO(Data);
		
		Если Лев(ContentXDTO.ИдФайл, 10) = "DP_PRANNUL" Тогда
			ТекстКомментария = ContentXDTO.Документ.СвПредАн.ТекстПредАн;
		Иначе	
			ТекстКомментария = ContentXDTO.Документ.СвУведУточ.ТекстУведУточ;
		КонецЕсли;	
		
		Если ТипЗнч(ТекстКомментария) = Тип("Строка") Тогда
			Результат = ТекстКомментария;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КомментарийСобытияИсторииДО_ТЭДО(Content)
	
	Результат = "";
	
	Если КонтентСодержитДанные(Content) Тогда
		
		Если ТипЗнч(Content.Data) = Тип("Строка") Тогда
			Data = Base64Значение(Content.Data);
		Иначе 
			Data = Content.Data;
		КонецЕсли;	
			
		ContentXDTO	= ГенерацияXML_XML_В_ОбъектXDTO(Data);
		
		СтруктураКомментария = Новый Структура("ErrorOrAcknowledgement");
		
		ЗаполнитьЗначенияСвойств(СтруктураКомментария, ContentXDTO); 
		
		ТекстКомментария = Неопределено;
		Если НЕ СтруктураКомментария.ErrorOrAcknowledgement = Неопределено Тогда
			ТекстКомментария = СтруктураКомментария.ErrorOrAcknowledgement.Description;
		КонецЕсли;
		
		Если ТипЗнч(ТекстКомментария) = Тип("Строка") Тогда
			Результат = ТекстКомментария;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


