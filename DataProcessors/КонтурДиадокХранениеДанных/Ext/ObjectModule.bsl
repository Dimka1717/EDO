Функция Контрагенты_МассивСопоставленныхВ1С_Диадок(Идентификаторы)
	
	Результат = Новый Массив;
			
	ИмяСправочника 	= Перечисление_ИменаСправочников_Диадок().Контрагенты;
	ИмяСвойства 	= Перечисление_ИменаСвойствНастроек_Диадок().СвязанныйСправочник;
	
	СвязанныеСправочники = Справочники_СвязанныеСправочники_Диадок(ИмяСправочника, Идентификаторы);
		
	Для каждого ЭлементТЗ Из СвязанныеСправочники Цикл
		
		Если ЗначениеЗаполнено(ЭлементТЗ.ОбъектИБ) Тогда
			Результат.Добавить(ЭлементТЗ.ОбъектИБ);	
		КонецЕсли;
		
	КонецЦикла;
			
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_УчастникДО_Диадок(ИдентификаторыКонтрагента, ИдентификаторыОрганизации)
	
	Результат = Контракт_УчастникДокументооборота();
	
	Запрос = Новый Запрос;
	Запрос.Текст = Контрагенты_ТекстЗапросаУчастникаЭДО_Диадок(ИдентификаторыКонтрагента, ИдентификаторыОрганизации);
	
	Запрос.УстановитьПараметр("ID", ИдентификаторВАдресЯщика(ИдентификаторыКонтрагента.ID));
	Запрос.УстановитьПараметр("Ссылка", ИдентификаторыКонтрагента.Ссылка);
	Запрос.УстановитьПараметр("Статус_ПартнерскиеОтношения", Перечисление_СтатусыКонтрагентов().ПартнерскиеОтношения);
	Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	Если ИдентификаторыОрганизации <> Неопределено Тогда
		
		Запрос.УстановитьПараметр("ОрганизацияID", ИдентификаторВАдресЯщика(ИдентификаторыОрганизации.ID));
		Запрос.УстановитьПараметр("Организация", ИдентификаторыОрганизации.Ссылка);
		
	КонецЕсли;
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаЗапроса);
	Иначе	
		Результат.BoxId				= ИдентификаторыКонтрагента.ID;
		Результат.ОрганизацияЭДО	= ИдентификаторыКонтрагента.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапросаУчастникаЭДО_Диадок(ИдентификаторыКонтрагента, ИдентификаторыОрганизации)
	
	Если ИдентификаторыОрганизации = Неопределено Тогда
		ОтборОрганизация = "Истина";
	ИначеЕсли ЗначениеЗаполнено(ИдентификаторыОрганизации.Ссылка) Тогда
		ОтборОрганизация = "Диадок_НастройкиКонтрагентов.Организация = &Организация";
	Иначе
		ОтборОрганизация = "Диадок_НастройкиКонтрагентов.Организация.ID = &ОрганизацияID";
	КонецЕсли;
	
	КонтрагентСсылка = ИдентификаторыКонтрагента.Ссылка;
	ОтборКонтрагент = "Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты""";
	ОтборПоСопоставленномуКонтрагенту = Ложь;
	
	Если ТипЗнч(КонтрагентСсылка) = ТипЗнч(Контрагенты_ПустаяСсылка_Диадок()) Тогда
		
		ОтборКонтрагент = ОтборКонтрагент + " И Диадок_ЮрФизЛица.Ссылка = &Ссылка";
		
	ИначеЕсли ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		
		ОтборПоСопоставленномуКонтрагенту = Истина;
		
	Иначе
		ОтборКонтрагент = ОтборКонтрагент + " И Диадок_ЮрФизЛица.ID = &ID";
	КонецЕсли;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		Результат = Контрагенты_ТекстЗапроса_УчастникЭДО_ДиадокРасширение(ОтборПоСопоставленномуКонтрагенту);
	Иначе
		Результат = Контрагенты_ТекстЗапроса_УчастникЭДО_ДиадокСХ1(ОтборПоСопоставленномуКонтрагенту);
	КонецЕсли;
	
	Результат = Результат + ТекстЗапроса_РазделительЗапросов()
				+ Контрагенты_ТекстЗапросаДляОтбораКонтрагентовПоСтатусуПартнерскихОтношений_Диадок();
	
	Результат = СтрЗаменить(Результат, "&ОтборКонтрагент",	ОтборКонтрагент);
	Результат = СтрЗаменить(Результат, "&ОтборОрганизация",	ОтборОрганизация);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_УчастникЭДО_ДиадокРасширение(ОтборПоСопоставленномуКонтрагенту)
	
	Если ОтборПоСопоставленномуКонтрагенту Тогда
		Результат = Контрагенты_ТекстЗапроса_УчастникЭДОПоСопоставленнойСвязи_ДиадокРасширение();
	Иначе
		Результат = Контрагенты_ТекстЗапроса_УчастникЭДОПоИдентификатору_ДиадокРасширение();
	КонецЕсли;
	
	Результат = Результат + "
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОрганизацияЭДО";
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_УчастникЭДОПоСопоставленнойСвязи_ДиадокРасширение()
	
	Результат = 
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ПОМЕСТИТЬ ВТ_Контрагенты
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|			И (Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты"")
	|ГДЕ
	|   &ОтборКонтрагент
	|   И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &Ссылка";
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_УчастникЭДОПоИдентификатору_ДиадокРасширение()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ПОМЕСТИТЬ ВТ_Контрагенты
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита = ""СвязанныйСправочник1"")
	|ГДЕ
	|	&ОтборКонтрагент
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_УчастникЭДО_ДиадокСХ1(ОтборПоСопоставленномуКонтрагенту)
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛица.СвязанныйСправочник1 КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ПОМЕСТИТЬ ВТ_Контрагенты
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&ОтборКонтрагент
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Если ОтборПоСопоставленномуКонтрагенту Тогда
		
		Результат = Результат + "
		| И (Диадок_ЮрФизЛица.СвязанныйСправочник1 = &Ссылка
		| 	ИЛИ Диадок_ЮрФизЛица.СвязанныйСправочник2 = &Ссылка
		| 	ИЛИ Диадок_ЮрФизЛица.СвязанныйСправочник3 = &Ссылка)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	Диадок_ЮрФизЛица.ID,
		|	Диадок_ЮрФизЛица.Наименование,
		|	Диадок_ЮрФизЛица.Ссылка,
		|	Диадок_ЮрФизЛица.СвязанныйСправочник1,
		|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО,
		|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
		|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
		|			И (Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты"")
		|ГДЕ
		|   НЕ Диадок_ЮрФизЛица.ПометкаУдаления
		|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник
		|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &Ссылка";
		
	КонецЕсли;
	
	Результат = Результат + "
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОрганизацияЭДО";
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапросаДляОтбораКонтрагентовПоСтатусуПартнерскихОтношений_Диадок()
	
	Результат =
	"ВЫБРАТЬ
	|	ВТ_Контрагенты.*,
	|	ВЫБОР
	|		КОГДА Диадок_НастройкиКонтрагентов.Значение = &Статус_ПартнерскиеОтношения
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ПриоритетСтатуса
	|ИЗ
	|	ВТ_Контрагенты КАК ВТ_Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|		ПО ВТ_Контрагенты.ОрганизацияЭДО = Диадок_НастройкиКонтрагентов.Контрагент
	|			И &ОтборОрганизация
	|			И (Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус"")
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриоритетСтатуса";

	Возврат Результат;
	
КонецФункции


Функция Контрагенты_НастройкиПоОрганизациям_Диадок(Идентификаторы)
	
	Если ЗначениеЗаполнено(Идентификаторы.Ссылка) Тогда
		Отбор = "Диадок_НастройкиКонтрагентов.Контрагент = &Ссылка";
	Иначе
		Отбор = "Диадок_НастройкиКонтрагентов.Контрагент.ID = &ID";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Контрагенты_ТекстЗапросаНастройкиПоОрганизациям_Диадок(Отбор);
	
	Запрос.УстановитьПараметр("ID",		Идентификаторы.ID);
	Запрос.УстановитьПараметр("Ссылка",	Идентификаторы.Ссылка);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапросаНастройкиПоОрганизациям_Диадок(Отбор)
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_НастройкиКонтрагентов.Организация,
	|	Диадок_НастройкиКонтрагентов.Контрагент,
	|	Диадок_НастройкиКонтрагентов.ИмяСвойства,
	|	Диадок_НастройкиКонтрагентов.Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	&Отбор";
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции	

Процедура Контрагенты_Записать_Диадок(Контрагент)
	
	КонтрагентСсылка = Контрагент.Ссылка;
	
	Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		ЮрЛицо = КонтрагентСсылка.ПолучитьОбъект();
	Иначе
		ЮрЛицо = Справочники.Диадок_ЮрФизЛица.СоздатьЭлемент();
	КонецЕсли;
	
	ЮрЛицо.ИмяСправочника	= "Контрагенты";
	ЮрЛицо.ID				= Контрагент.ID;	
	ЮрЛицо.Наименование		= Контрагент.Наименование;
	ЮрЛицо.ИНН				= Контрагент.ИНН;
	ЮрЛицо.КПП				= Контрагент.КПП;
	
	ЮрЛицо.ИдентификаторУчастникаЭДО = Контрагент.ИдентификаторУчастникаЭДО;
	
	ДопРеквизиты_УстановитьЗначение(ЮрЛицо, "OrgId", Контрагент.OrgId);
	ДопРеквизиты_УстановитьЗначение(ЮрЛицо, "ДатаЛиквидации", Контрагент.ДатаЛиквидации);
	
	ЮрЛицо.Записать();
	
	Контрагент.Ссылка = ЮрЛицо.Ссылка;
	
КонецПроцедуры

Процедура Контрагенты_ОбновлениеРеквизитов_Диадок(Идентификаторы, СтруктураРеквизитов)
	
	КонтрагентЭДО = СвойствоСтруктуры(Идентификаторы, "Ссылка");
	
	КонтрагентОбъект = КонтрагентЭДО.ПолучитьОбъект();
	
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		Справочники_ЮрФизЛицоОбъект_ОчиститьСвязанныеСправочники(КонтрагентОбъект);
										
		СвязанныеСправочники = СтруктураРеквизитов.СвязанныеСправочники;
		Справочники_ЮрФизЛицоОбъект_ЗаполнитьСвязанныеСправочники(КонтрагентОбъект, СвязанныеСправочники);
						
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ID_ОсновноеПодразделение") Тогда
		КонтрагентОбъект.ID_ОсновноеПодразделение = СтруктураРеквизитов.ID_ОсновноеПодразделение;
	КонецЕсли;	
	
	КонтрагентОбъект.Записать();
	
КонецПроцедуры

Процедура Контрагенты_ЗаписатьНастройкиПоОрганизациям_Диадок(Контрагент, НастройкиПоОрганизациям)
	
	НачатьТранзакцию();
	
	Попытка
		
		КонтрагентЭДО = СвойствоСтруктуры(Контрагент, "Ссылка");
		
		НаборЗаписей = РегистрыСведений.Диадок_НастройкиКонтрагентов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Контрагент.Установить(КонтрагентЭДО);
		
		Для Каждого Настройка Из НастройкиПоОрганизациям Цикл
			ЗаписьРегистра = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(ЗаписьРегистра, Настройка);
			ЗаписьРегистра.Контрагент = КонтрагентЭДО;
		КонецЦикла;
		
		НаборЗаписей.Записать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		_Ошибка = ОписаниеОшибки();
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

Функция Контрагенты_СконвертироватьСоответствиеКонтрагентов_Диадок()
	
	Результат = Новый Массив;
	
	ТаблицаСоответствий = ТаблицаСтарыхСоответствийКонтрагентов();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(парам.ID КАК СТРОКА(50)) КАК ID,
	|	ВЫРАЗИТЬ(парам.Контрагент КАК Справочник.Контрагенты) КАК Контрагент
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&ТаблицаСоответствий КАК парам
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка,
	|	ВТ.Контрагент
	|ИЗ
	|	ВТ КАК ВТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО ВТ.ID = Диадок_ЮрФизЛица.ID
	|			И ВТ.Контрагент <> Диадок_ЮрФизЛица.СвязанныйСправочник1
	|			И (Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты"")"
	);
	
	Запрос.УстановитьПараметр("ТаблицаСоответствий", ТаблицаСоответствий);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОбъектКонтрагента = Выборка.Ссылка.ПолучитьОбъект();
		ОбъектКонтрагента.ОбменДанными.Загрузка	= Истина;
		ОбъектКонтрагента.СвязанныйСправочник1	= Выборка.Контрагент;
		ОбъектКонтрагента.Записать();
		
		Результат.Добавить(ОбъектКонтрагента.Наименование);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


Функция Подразделения_ДанныеПодразделения_Диадок(Идентификаторы, ДляОрганизации)
	
	Результат = Контракт_Подразделение();
	
	ИмяСправочника	= ?(ДляОрганизации, "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	ВыборкаДанных	= Справочники_ВыборкаДанныхСправочника_Диадок(ИмяСправочника, Идентификаторы);
	
	Если ВыборкаДанных <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаДанных);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подразделения_СопоставленныйВ1С_Диадок(Идентификаторы, ДляОрганизации)

	ИмяСправочника	= ?(ДляОрганизации, "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	Результат		= Справочники_СвязанныйСправочник_Диадок(ИмяСправочника, Идентификаторы);
	
	Возврат Результат;
	
КонецФункции

Функция Подразделения_СопоставленныеВ1С_Диадок(Идентификаторы, ДляОрганизации = Истина)
	
	Если ДляОрганизации Тогда
		ИмяСправочника = Перечисление_ИменаСправочников_Диадок().ПодразделенияОрганизаций;
	Иначе
		ИмяСправочника = Перечисление_ИменаСправочников_Диадок().ПодразделенияКонтрагентов;
	КонецЕсли;
	
	Результат = Справочники_СопоставленныеВ1С_Диадок(ИмяСправочника, Идентификаторы);
			
	Возврат Результат;
	
КонецФункции


Функция Подразделения_СсылкаПоИдентификатору_Диадок(Идентификаторы, ДляОрганизации)

	ИмяСправочника = ?(ДляОрганизации, "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	
	Результат = Справочники_СсылкаПоИдентификатору_Диадок(Идентификаторы, ИмяСправочника);
	
	Возврат Результат;

КонецФункции


Функция Подразделения_ТаблицаПодразделенийВладельца_Диадок(ДанныеВладельца, ДанныеОрганизации)
	
	ДляОрганизации	= (ДанныеОрганизации = Неопределено);
	ID_Владельца	= СвойствоСтруктуры(ДанныеВладельца, "ID", "");
	
	ИмяСправочника = ?(ДляОрганизации, "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	
	Запрос = Новый Запрос;
	Запрос.Текст = Справочники_ТекстЗапросаТаблицаПодразделенийВладельца_Диадок();
	
	Запрос.УстановитьПараметр("ИмяСправочника", ИмяСправочника);
	Запрос.УстановитьПараметр("Владелец",		ID_Владельца);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапросаТаблицаПодразделенийВладельца_Диадок()
	
	Отбор = "Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника И Диадок_ЮрФизЛица.ID_ВладелецПодразделения = &Владелец";
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		Результат = Справочники_ТекстЗапроса_ДанныеСправочника_ДиадокРасширение();
	Иначе
		Результат = Справочники_ТекстЗапроса_ДанныеСправочника_ДиадокСХ1();
	КонецЕсли;
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции


Процедура Подразделения_Записать_Диадок(Подразделение, Владелец)
	
	Если ЗначениеЗаполнено(Подразделение.Ссылка) Тогда
		ЮрЛицо = Подразделение.Ссылка.ПолучитьОбъект();
	Иначе
		ЮрЛицо = Справочники.Диадок_ЮрФизЛица.СоздатьЭлемент();
	КонецЕсли;
	
	ЮрЛицо.ИмяСправочника	= ?(Владелец.Ссылка.ИмяСправочника = "Организации", "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	ЮрЛицо.ID				= Подразделение.ID;	
	ЮрЛицо.Наименование		= Подразделение.Наименование;
	ЮрЛицо.ИНН				= Подразделение.ИНН;
	ЮрЛицо.КПП				= Подразделение.КПП;

	ЮрЛицо.Аббревиатура				= Подразделение.Аббревиатура;
	ЮрЛицо.ID_ВладелецПодразделения	= Подразделение.ID_ВладелецПодразделения;
	ЮрЛицо.ID_РодительПодразделения	= Подразделение.ID_РодительПодразделения;
	
	ЮрЛицо.Записать();
		
КонецПроцедуры

Процедура Подразделения_ОбновлениеРеквизитов_Диадок(Подразделение, СтруктураРеквизитов)
	
	ПодразделениеЭДО = СвойствоСтруктуры(Подразделение, "Ссылка");
	
	ПодразделениеОбъект = ПодразделениеЭДО.ПолучитьОбъект();
			
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		Справочники_ЮрФизЛицоОбъект_ОчиститьСвязанныеСправочники(ПодразделениеОбъект);
		
		СвязанныеСправочники = СтруктураРеквизитов.СвязанныеСправочники;
		Справочники_ЮрФизЛицоОбъект_ЗаполнитьСвязанныеСправочники(ПодразделениеОбъект, СвязанныеСправочники);
				
	КонецЕсли;
	
	ПодразделениеОбъект.Записать();
	
КонецПроцедуры

Процедура Подразделения_ОбновитьСправочник_Диадок(ТаблицаКонтрактов, Владелец) 
	
	ИмяСправочника = ?(Владелец.Ссылка.ИмяСправочника = "Организации", "ПодразделенияОрганизаций", "ПодразделенияКонтрагентов");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID КАК ID,
	|	ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ТаблицаКонтрактов.КПП КАК КПП,
	|	ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ТаблицаКонтрактов.Аббревиатура КАК Аббревиатура,
	|	ТаблицаКонтрактов.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	ТаблицаКонтрактов.ID_РодительПодразделения КАК ID_РодительПодразделения
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Диадок_ЮрФизЛица.ID КАК ID,
	|	Диадок_ЮрФизЛица.ИНН КАК ИНН,
	|	Диадок_ЮрФизЛица.КПП КАК КПП,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Аббревиатура КАК Аббревиатура,
	|	Диадок_ЮрФизЛица.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	Диадок_ЮрФизЛица.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	Диадок_ЮрФизЛица.Ссылка КАК ПодразделениеЭДО
	|ПОМЕСТИТЬ ВТ_ПодразделенияЭДО
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК ВладелецПодразделения
	|		ПО Диадок_ЮрФизЛица.ID_ВладелецПодразделения = ВладелецПодразделения.ID
	|			И (ВладелецПодразделения.Ссылка = &Владелец)
	|ГДЕ
	|	НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""НОВЫЙ"" КАК Признак,
	|	ВТ_ТаблицаКонтрактов.ID КАК ID,
	|	ВТ_ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП КАК КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ВТ_ТаблицаКонтрактов.Аббревиатура КАК Аббревиатура,
	|	ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	ВТ_ТаблицаКонтрактов.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	ВТ_ПодразделенияЭДО.ПодразделениеЭДО КАК Ссылка,
	|	ЛОЖЬ КАК ПометкаУдаления
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_ПодразделенияЭДО.ID
	|ГДЕ
	|	ВТ_ПодразделенияЭДО.ПодразделениеЭДО ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""ИЗМЕНЕН"" КАК Признак,
	|	ВТ_ТаблицаКонтрактов.ID КАК ID,
	|	ВТ_ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП КАК КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ВТ_ТаблицаКонтрактов.Аббревиатура КАК Аббревиатура,
	|	ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	ВТ_ТаблицаКонтрактов.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	ВТ_ПодразделенияЭДО.ПодразделениеЭДО КАК Ссылка,
	|	ЛОЖЬ КАК ПометкаУдаления
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_ПодразделенияЭДО.ID
	|ГДЕ
	|	НЕ (ВТ_ТаблицаКонтрактов.ИНН = ВТ_ПодразделенияЭДО.ИНН
	|		И ВТ_ТаблицаКонтрактов.КПП = ВТ_ПодразделенияЭДО.КПП
	|		И ВТ_ТаблицаКонтрактов.Наименование = ВТ_ПодразделенияЭДО.Наименование
	|		И ВТ_ТаблицаКонтрактов.Аббревиатура = ВТ_ПодразделенияЭДО.Аббревиатура
	|		И ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения = ВТ_ПодразделенияЭДО.ID_ВладелецПодразделения
	|		И ВТ_ТаблицаКонтрактов.ID_РодительПодразделения = ВТ_ПодразделенияЭДО.ID_РодительПодразделения)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""УДАЛЕН"",
	|	ВТ_ПодразделенияЭДО.ID,
	|	ВТ_ПодразделенияЭДО.ИНН,
	|	ВТ_ПодразделенияЭДО.КПП,
	|	ВТ_ПодразделенияЭДО.Наименование,
	|	ВТ_ПодразделенияЭДО.Аббревиатура,
	|	ВТ_ПодразделенияЭДО.ID_ВладелецПодразделения,
	|	ВТ_ПодразделенияЭДО.ID_РодительПодразделения,
	|	ВТ_ПодразделенияЭДО.ПодразделениеЭДО,
	|	ИСТИНА
	|ИЗ
	|	ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ПО ВТ_ПодразделенияЭДО.ID = ВТ_ТаблицаКонтрактов.ID
	|ГДЕ
	|	ВТ_ТаблицаКонтрактов.ID ЕСТЬ NULL";

	Запрос.УстановитьПараметр("ТаблицаКонтрактов",	ТаблицаКонтрактов);
	Запрос.УстановитьПараметр("ИмяСправочника",		ИмяСправочника);
	Запрос.УстановитьПараметр("Владелец",			Владелец.Ссылка);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаНовыхИИзмененных = РезультатЗапроса[2].Выбрать();
	Пока ВыборкаНовыхИИзмененных.Следующий() Цикл
		
		Подразделение = Контракт_Подразделение();
		ЗаполнитьЗначенияСвойств(Подразделение, ВыборкаНовыхИИзмененных);
		
		Подразделения_Записать_Диадок(Подразделение, Владелец);
		
	КонецЦикла;	
	
	ВыборкаУдаленных = РезультатЗапроса[3].Выбрать();
	Пока ВыборкаУдаленных.Следующий() Цикл
		
		Попытка
			
			ПодразделениеОбъект = ВыборкаУдаленных.ПодразделениеЭДО.ПолучитьОбъект();
			ПодразделениеОбъект.УстановитьПометкуУдаления(Истина);
			
		Исключение
			
			ВидОперации		= "Обновление справочника ""Подразделения""";
			ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ДопИнформация	= Общее_ПодставитьПараметрыВСтроку("Юр/физ лицо: %1", Владелец.Наименование);
			
			ТекстСообщения	= "Не удалось пометить на удаление подразделение ""%1""";
			ТекстСообщения	= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПодразделениеОбъект.Наименование);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);

		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// Описание метода см. Подразделения_ВыполнитьПакетноеОбновлениеСправочника
//
Процедура Подразделения_ВыполнитьПакетноеОбновлениеСправочника_Диадок(Подразделения, КонтрагентыЭДО)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID КАК ID,
	|	ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ТаблицаКонтрактов.КПП КАК КПП,
	|	ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ТаблицаКонтрактов.Аббревиатура КАК Аббревиатура,
	|	ТаблицаКонтрактов.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	ТаблицаКонтрактов.ID_РодительПодразделения КАК ID_РодительПодразделения
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК ID,
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_КонтрагентыЭДО
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочникаКонтрагенты
	|	И Диадок_ЮрФизЛица.ID В(&Владельцы)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Диадок_ЮрФизЛица.ID КАК ID,
	|	Диадок_ЮрФизЛица.ИНН КАК ИНН,
	|	Диадок_ЮрФизЛица.КПП КАК КПП,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Аббревиатура КАК Аббревиатура,
	|	Диадок_ЮрФизЛица.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	Диадок_ЮрФизЛица.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка,
	|	ВладелецПодразделения.Ссылка КАК ВладелецПодразделенияСсылка
	|ПОМЕСТИТЬ ВТ_ПодразделенияЭДО
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КонтрагентыЭДО КАК ВладелецПодразделения
	|		ПО Диадок_ЮрФизЛица.ID_ВладелецПодразделения = ВладелецПодразделения.ID
	|ГДЕ
	|	НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочникаПодразделения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""НОВЫЙ"" КАК Признак,
	|	ВТ_ТаблицаКонтрактов.ID КАК ID,
	|	ВТ_ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП КАК КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ВТ_ТаблицаКонтрактов.Аббревиатура КАК Аббревиатура,
	|	ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	ВТ_ТаблицаКонтрактов.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	ВТ_ПодразделенияЭДО.Ссылка КАК Ссылка,
	|	ВТ_КонтрагентыЭДО.Ссылка КАК ВладелецПодразделенияСсылка,
	|	ЛОЖЬ КАК ПометкаУдаления
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_ПодразделенияЭДО.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыЭДО КАК ВТ_КонтрагентыЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения = ВТ_КонтрагентыЭДО.ID
	|ГДЕ
	|	ВТ_ПодразделенияЭДО.Ссылка ЕСТЬ NULL
	|	И НЕ ВТ_КонтрагентыЭДО.Ссылка ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""ИЗМЕНЕН"",
	|	ВТ_ТаблицаКонтрактов.ID,
	|	ВТ_ТаблицаКонтрактов.ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование,
	|	ВТ_ТаблицаКонтрактов.Аббревиатура,
	|	ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения,
	|	ВТ_ТаблицаКонтрактов.ID_РодительПодразделения,
	|	ВТ_ПодразделенияЭДО.Ссылка,
	|	ВТ_КонтрагентыЭДО.Ссылка,
	|	ЛОЖЬ
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_ПодразделенияЭДО.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыЭДО КАК ВТ_КонтрагентыЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения = ВТ_КонтрагентыЭДО.ID
	|ГДЕ
	|	НЕ(ВТ_ТаблицаКонтрактов.ИНН = ВТ_ПодразделенияЭДО.ИНН
	|				И ВТ_ТаблицаКонтрактов.КПП = ВТ_ПодразделенияЭДО.КПП
	|				И ВТ_ТаблицаКонтрактов.Наименование = ВТ_ПодразделенияЭДО.Наименование
	|				И ВТ_ТаблицаКонтрактов.Аббревиатура = ВТ_ПодразделенияЭДО.Аббревиатура
	|				И ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения = ВТ_ПодразделенияЭДО.ID_ВладелецПодразделения
	|				И ВТ_ТаблицаКонтрактов.ID_РодительПодразделения = ВТ_ПодразделенияЭДО.ID_РодительПодразделения)
	|	И НЕ ВТ_КонтрагентыЭДО.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""УДАЛЕН"" КАК Признак,
	|	ВТ_ПодразделенияЭДО.Ссылка,
	|	ВТ_КонтрагентыЭДО.Ссылка КАК ВладелецПодразделенияСсылка
	|ИЗ
	|	ВТ_ПодразделенияЭДО КАК ВТ_ПодразделенияЭДО
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ПО ВТ_ПодразделенияЭДО.ID = ВТ_ТаблицаКонтрактов.ID
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыЭДО КАК ВТ_КонтрагентыЭДО
	|		ПО ВТ_ПодразделенияЭДО.ID_ВладелецПодразделения = ВТ_КонтрагентыЭДО.ID
	|ГДЕ
	|	ВТ_ТаблицаКонтрактов.ID ЕСТЬ NULL
	|	И НЕ ВТ_КонтрагентыЭДО.Ссылка ЕСТЬ NULL";

	Запрос.УстановитьПараметр("ИмяСправочникаПодразделения",	"ПодразделенияКонтрагентов");
	Запрос.УстановитьПараметр("ИмяСправочникаКонтрагенты",		"Контрагенты");
	Запрос.УстановитьПараметр("ТаблицаКонтрактов",				Подразделения);
	Запрос.УстановитьПараметр("Владельцы",						КонтрагентыЭДО.ВыгрузитьКолонку("ID"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаНовыхИИзмененных = РезультатЗапроса[3].Выбрать();
	Пока ВыборкаНовыхИИзмененных.Следующий() Цикл
		
		Подразделение = Контракт_Подразделение();
		ЗаполнитьЗначенияСвойств(Подразделение, ВыборкаНовыхИИзмененных);
		
		ИдентификаторыОбъекта = Новый_ИдентификаторыСправочника(ВыборкаНовыхИИзмененных.ВладелецПодразделенияСсылка);
		
		Подразделения_Записать_Диадок(Подразделение, ИдентификаторыОбъекта);
		
	КонецЦикла;	
	
	ВыборкаУдаленных = РезультатЗапроса[4].Выбрать();
	Пока ВыборкаУдаленных.Следующий() Цикл
		
		Попытка
			
			ПодразделениеОбъект = ВыборкаУдаленных.Ссылка.ПолучитьОбъект();
			ПодразделениеОбъект.УстановитьПометкуУдаления(Истина);
			
		Исключение
			
			ВидОперации		= "Обновление справочника ""Подразделения""";
			ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ДопИнформация	= Общее_ПодставитьПараметрыВСтроку("Юр/физ лицо: %1", ВыборкаУдаленных.ВладелецПодразделенияСсылка);
			
			ТекстСообщения	= "Не удалось пометить на удаление подразделение ""%1""";
			ТекстСообщения	= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, ПодразделениеОбъект.Наименование);
			
			Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);

		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// См. метод Подразделения_ИдентификаторПоСвязаннымСправочникам
Функция Подразделения_ИдентификаторПоСвязаннымСправочникам_Диадок(IdВладельца, СвязанныйСправочник, ДляОрганизации)
	
	ИмяСправочника = Перечисление_ИменаСправочников_Диадок();
	
	Если ДляОрганизации Тогда
		ИмяСправочника = ИмяСправочника.ПодразделенияОрганизаций;
	Иначе
		ИмяСправочника = ИмяСправочника.ПодразделенияКонтрагентов;
	КонецЕсли;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса = Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокРасширение();
	Иначе
		ТекстЗапроса = Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокСХ1();
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Отбор", "Диадок_ЮрФизЛица.ID_ВладелецПодразделения = &ID_ВладелецПодразделения");
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Запрос.УстановитьПараметр("ИмяСправочника", ИмяСправочника);
	Запрос.УстановитьПараметр("ИмяРеквизита", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	Запрос.УстановитьПараметр("ID_ВладелецПодразделения", IdВладельца);
	Запрос.УстановитьПараметр("СсылкаНаОбъект", СвязанныйСправочник);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.ID;
	Иначе
		Результат = "";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

