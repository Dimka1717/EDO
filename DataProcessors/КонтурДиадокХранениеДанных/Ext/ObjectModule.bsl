			Результат,
			"&ИмяРеквизитаFromDepartmentID",
			"""" + Перечисление_ИменаСвойств.FromDepartmentID + """");
			
	Результат = СтрЗаменить(
			Результат,
			"&ИмяРеквизитаToDepartmentID",
			"""" + Перечисление_ИменаСвойств.ToDepartmentID + """");
	
	Возврат Результат;
	
КонецФункции
// BSLLS:MethodSize-on

Функция Документы_КонтрактДокументаПоВыборке_Диадок(Выборка)
	
	Результат = Контракт_Документ();
	
	// BSLLS:LineLength-off
	ЗаполнитьЗначенияСвойств(Результат, Выборка, "Направление, ДокументУчета, ИмяФайла, ДатаЭДО, Состояние, Заблокирован, ИдентификаторВидаПакета, ИдентификаторВида, Шаблон");
	ЗаполнитьЗначенияСвойств(Результат.Реквизиты, Выборка, "Дата, Номер, Сумма, СуммаНДС, КодВалюты");
	ЗаполнитьЗначенияСвойств(Результат.Идентификаторы, Выборка, "BoxId, LetterId, DocumentID, ДокументЭДО, ПакетЭДО");
	ЗаполнитьЗначенияСвойств(Результат.РезультатАнализа, Выборка, "АнализПроведен, ТребуемоеДействиеВ1С, ТребуемоеДействиеВДД, ТекстОшибки");
	ЗаполнитьЗначенияСвойств(Результат.Тип, Выборка, "ТипДокумента, ТипКонтента, ФункцияДокумента, Представление, WorkflowId");
	ЗаполнитьЗначенияСвойств(Результат.Статусы, Выборка, "Статус, ДополнительныйСтатус, ТребуетсяОбработка, СтатусМЧДКритичность, СтатусМЧД, СтатусПКФНСКритичность, СтатусПКФНС");
	ЗаполнитьЗначенияСвойств(Результат.Связи, Выборка, "PacketID");
	// BSLLS:LineLength-on
	
	Документы_СтатусыОбъектМаршрутизации_Диадок(Выборка, Результат);
	
	Тип = Результат.Тип;
	
	ТипДокумента = Тип.ТипДокумента;
	ТипКонтента = Тип.ТипКонтента;
	ФункцияДокумента = Тип.ФункцияДокумента;
	
	ОписаниеТипаДокумента = Списки_ОписаниеТипаДокументаAPI(ТипДокумента, ТипКонтента, ФункцияДокумента);
	ФорматКонтента = Списки_ОписаниеФорматаКонтента(ТипКонтента);
	
	Тип.ФункцияДокумента = Документы_ФункцияДокументаДляХранения(Тип.ФункцияДокумента);
	Тип.Формализованный = ФорматКонтента.Формализованный;
	Тип.Представление = ОписаниеТипаДокумента.Title;
	
	Если Результат.Направление = "Входящее" Тогда
		Результат.Получатель.DepartmentId = СокрЛП(Выборка.DepartmentId);
	ИначеЕсли Результат.Направление = "Внутреннее" Тогда
		Результат.Отправитель.DepartmentId = СокрЛП(Выборка.FromDepartmentId);
		Результат.Получатель.DepartmentId = СокрЛП(Выборка.ToDepartmentId);
	Иначе
		Результат.Отправитель.DepartmentId = СокрЛП(Выборка.DepartmentId);
	КонецЕсли;
	
	ЗаполнитьУчастниковДокументооборота(Результат.Отправитель, Результат.Получатель, Выборка);
	
	МетаданныеДокумента = Выборка.Хранилище.Получить();
	
	Если МетаданныеДокумента <> Неопределено Тогда
		Результат.Метаданные = МетаданныеДокумента;
	КонецЕсли;
	
	КонтентОтвета = Выборка.ХранилищеОтвета.Получить();
	
	Если КонтентОтвета <> Неопределено Тогда
		Результат.СлужебнаяИнформация.Вставить("КонтентОтвета", КонтентОтвета);
	КонецЕсли;
	
	Результат.СлужебнаяИнформация.Вставить("ТребуетсяРасшифровка", Выборка.ТребуетсяРасшифровка);
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_СтатусыОбъектМаршрутизации_Диадок(Выборка, Результат)
	
	ОбъектМаршрутизаци = Результат.Статусы.ОбъектМаршрутизации;
	
	ОбъектМаршрутизаци.Наименование = Выборка.ОбъектМаршрутизацииНаименование;
	ОбъектМаршрутизаци.Идентификатор = Выборка.ОбъектМаршрутизацииИдентификатор;
	
КонецПроцедуры

Функция Документы_НаличиеДанных1С_Диадок(ИдентификаторыДокументов)
	
	Результат = Новый Структура;
	
	ИменаРеквизитовДокумента =
	"BoxId,
	|LetterId,
	|DocumentId,
	|ДокументЭДО,
	|PacketId,
	|DepartmentId,
	|FromDepartmentId,
	|ToDepartmentId,
	|СтатусМЧД,
	|СтатусМЧДКритичность,
	|СтатусДТС,
	|Статус,
	|ОбъектМаршрутизации,
	|ДополнительныйСтатус,
	|ТребуетсяОбработка,
	|ВнешниеСтатусы";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса_Документы_НаличиеДанных1С_Диадок();
	
	Перечисление_ИменаСвойств = Перечисление_ИменаСвойствНастроек_Диадок();
	
	Запрос.Параметры.Вставить("ИдентификаторыДокументов", ИдентификаторыДокументов);
	Запрос.Параметры.Вставить("ИмяРеквизита_СтатусМЧД", Перечисление_ИменаСвойств.СтатусМЧД);
	Запрос.Параметры.Вставить("ИмяРеквизита_СтатусМЧДКритичность", Перечисление_ИменаСвойств.СтатусМЧДКритичность);
	Запрос.Параметры.Вставить("ИмяРеквизита_СтатусГИСМТ", Документы_ИмяДопРеквизита_ВнешнийСтатусГИСМТ());
	Запрос.Параметры.Вставить("ИмяРеквизита_СтатусКонтурЛогистика", Документы_ИмяДопРеквизита_ВнешнийСтатусКонтурЛогистика());
	Запрос.Параметры.Вставить("ИмяРеквизита_СтатусДТС", Перечисление_ИменаСвойств.СтатусДТС);
	Запрос.Параметры.Вставить("ИмяРеквизита_FromDepartmentID", Перечисление_ИменаСвойств.FromDepartmentID);
	Запрос.Параметры.Вставить("ИмяРеквизита_ToDepartmentID", Перечисление_ИменаСвойств.ToDepartmentID);
	Запрос.Параметры.Вставить("ИмяРеквизита_ОбъектМаршрутизации", Перечисление_ИменаСвойств.ОбъектМаршрутизации);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ТекущиеДанные = Новый Структура(ИменаРеквизитовДокумента);
		Ключ = Новый_КлючИдентификатораДокумента(Выборка.LetterId, Выборка.DocumentId);
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, Выборка);
		ТекущиеДанные.PacketId = СокрЛП(Выборка.PacketId);
		
		ВнешниеСтатусы = Новый Структура;
		Если ЗначениеЗаполнено(Выборка.ВнешнийСтатусГИСМТ) Тогда
			ВнешниеСтатусы.Вставить(Ядро_ИдентификаторВнешнегоДО_ГИСМТ(), Выборка.ВнешнийСтатусГИСМТ);
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ВнешнийСтатусКонтурЛогистика) Тогда
			ВнешниеСтатусы.Вставить(Ядро_ИдентификаторВнешнегоДО_КонтурЛогистика(), Выборка.ВнешнийСтатусКонтурЛогистика);
		КонецЕсли;
		
		ТекущиеДанные.ВнешниеСтатусы = ВнешниеСтатусы;
		
		ОбъектМаршрутизации = Контракт_ОбъектМаршрутизации();
		ОбъектМаршрутизации.Идентификатор = Выборка.ОбъектМаршрутизацииИдентификатор;
		ОбъектМаршрутизации.Наименование = Выборка.ОбъектМаршрутизацииНаименование;
		
		ТекущиеДанные.ОбъектМаршрутизации = ОбъектМаршрутизации;
		
		Результат.Вставить(Ключ, ТекущиеДанные);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_Документы_НаличиеДанных1С_Диадок()
	
	Результат =
	"ВЫБРАТЬ
	|	ИдентификаторыДокументов.BoxId КАК BoxId,
	|	ИдентификаторыДокументов.LetterId КАК LetterId,
	|	ИдентификаторыДокументов.DocumentId КАК DocumentId
	|ПОМЕСТИТЬ ИдентификаторыДокументов
	|ИЗ
	|	&ИдентификаторыДокументов КАК ИдентификаторыДокументов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИдентификаторыДокументов.BoxId КАК BoxId,
	|	ИдентификаторыДокументов.LetterId КАК LetterId,
	|	ИдентификаторыДокументов.DocumentId КАК DocumentId,
	|	Диадок_Документы.Ссылка КАК ДокументЭДО,
	|	Диадок_Документы.PacketId КАК PacketId,
	|	Диадок_Документы.DepartmentId КАК DepartmentId,
	|	Диадок_Документы.Статус КАК Статус,
	|	Диадок_Документы.ДополнительныйСтатус КАК ДополнительныйСтатус,
	|	Диадок_Документы.ТребуетсяОбработка КАК ТребуетсяОбработка
	|ПОМЕСТИТЬ ПредварительнаяВыборка
	|ИЗ
	|	ИдентификаторыДокументов КАК ИдентификаторыДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы КАК Диадок_Документы
	|		ПО (Диадок_Документы.BoxId = ИдентификаторыДокументов.BoxId)
	|			И (Диадок_Документы.DocumentId = ИдентификаторыДокументов.DocumentId)
	|			И (Диадок_Документы.LetterId = ИдентификаторыДокументов.LetterId)
	|			И (НЕ Диадок_Документы.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПредварительнаяВыборка.BoxId КАК BoxId,
	|	ПредварительнаяВыборка.LetterId КАК LetterId,
	|	ПредварительнаяВыборка.DocumentId КАК DocumentId,
	|	ПредварительнаяВыборка.ДокументЭДО КАК ДокументЭДО,
	|	ПредварительнаяВыборка.PacketId КАК PacketId,
	|	ПредварительнаяВыборка.DepartmentId КАК DepartmentId,
	|	ПредварительнаяВыборка.Статус КАК Статус,
	|	ПредварительнаяВыборка.ДополнительныйСтатус КАК ДополнительныйСтатус,
	|	ПредварительнаяВыборка.ТребуетсяОбработка КАК ТребуетсяОбработка,
	|	ЕСТЬNULL(Диадок_СтатусМЧД.Значение, """") КАК СтатусМЧД,
	|	ЕСТЬNULL(Диадок_СтатусМЧДКритичность.Значение, """") КАК СтатусМЧДКритичность,
	|	ЕСТЬNULL(Диадок_ДокументыДополнительныеРеквизиты.Значение, """") КАК ВнешнийСтатусГИСМТ,
	|	ЕСТЬNULL(Диадок_ЛогистическиеСтатусыДокументов.Значение, """") КАК ВнешнийСтатусКонтурЛогистика,
	|	ЕСТЬNULL(Диадок_СтатусДТС.Значение, """") КАК СтатусДТС,
	|	ЕСТЬNULL(РеквизитFromDepartmentID.Значение, ""&ПустойИдентификатор"") КАК FromDepartmentId,
	|	ЕСТЬNULL(РеквизитToDepartmentID.Значение, ""&ПустойИдентификатор"") КАК ToDepartmentId,
	|	ЕСТЬNULL(РеквизитОбъектМаршрутизации.Значение, """") КАК ОбъектМаршрутизацииИдентификатор,
	|	ЕСТЬNULL(РеквизитОбъектМаршрутизации.ЗначениеСтрока, """") КАК ОбъектМаршрутизацииНаименование
	|ИЗ
	|	ПредварительнаяВыборка КАК ПредварительнаяВыборка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК Диадок_СтатусМЧД
	|		ПО ПредварительнаяВыборка.ДокументЭДО = Диадок_СтатусМЧД.Ссылка
	|			И (Диадок_СтатусМЧД.ИмяРеквизита = &ИмяРеквизита_СтатусМЧД)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК Диадок_СтатусМЧДКритичность
	|		ПО ПредварительнаяВыборка.ДокументЭДО = Диадок_СтатусМЧДКритичность.Ссылка
	|			И (Диадок_СтатусМЧДКритичность.ИмяРеквизита = &ИмяРеквизита_СтатусМЧДКритичность)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК Диадок_ДокументыДополнительныеРеквизиты
	|		ПО ПредварительнаяВыборка.ДокументЭДО = Диадок_ДокументыДополнительныеРеквизиты.Ссылка
	|			И (Диадок_ДокументыДополнительныеРеквизиты.ИмяРеквизита = &ИмяРеквизита_СтатусГИСМТ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК Диадок_ЛогистическиеСтатусыДокументов
	|		ПО ПредварительнаяВыборка.ДокументЭДО = Диадок_ЛогистическиеСтатусыДокументов.Ссылка
	|			И (Диадок_ЛогистическиеСтатусыДокументов.ИмяРеквизита = &ИмяРеквизита_СтатусКонтурЛогистика)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК Диадок_СтатусДТС
	|		ПО ПредварительнаяВыборка.ДокументЭДО = Диадок_СтатусДТС.Ссылка
	|			И (Диадок_СтатусДТС.ИмяРеквизита = &ИмяРеквизита_СтатусДТС)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК РеквизитFromDepartmentID
	|		ПО ПредварительнаяВыборка.ДокументЭДО = РеквизитFromDepartmentID.Ссылка
	|			И (РеквизитFromDepartmentID.ИмяРеквизита = &ИмяРеквизита_FromDepartmentID)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК РеквизитToDepartmentID
	|		ПО ПредварительнаяВыборка.ДокументЭДО = РеквизитToDepartmentID.Ссылка
	|			И (РеквизитToDepartmentID.ИмяРеквизита = &ИмяРеквизита_ToDepartmentID)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы.ДополнительныеРеквизиты КАК РеквизитОбъектМаршрутизации
	|		ПО ПредварительнаяВыборка.ДокументЭДО = РеквизитОбъектМаршрутизации.Ссылка
	|			И (РеквизитОбъектМаршрутизации.ИмяРеквизита = &ИмяРеквизита_ОбъектМаршрутизации)";
	
	Результат = СтрЗаменить(Результат, "&ПустойИдентификатор", ПустойИдентификатор());
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДублиДокумента_Диадок(Идентификаторы)
	
	Результат = Новый Массив;
	
	ДокументЭДО	= СвойствоСтруктуры(Идентификаторы, "ДокументЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");
	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Диадок_Документы.Ссылка
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|ГДЕ
	|	Диадок_Документы.Ссылка <> &Ссылка
	|	И Диадок_Документы.BoxId = &BoxId
	|	И Диадок_Документы.LetterId = &LetterId
	|	И Диадок_Документы.DocumentId = &DocumentId
	|	И НЕ Диадок_Документы.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("BoxId",		BoxId);
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	Запрос.УстановитьПараметр("DocumentId",	DocumentId);
	Запрос.УстановитьПараметр("Ссылка",		ДокументЭДО);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат.Добавить(Выборка.Ссылка);
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ИдентификаторыОтправленныхПоДокументам1С_Диадок(Документ, ДокументыОснования)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Диадок_Документы.LetterId,
	|	Диадок_Документы.DocumentId
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|ГДЕ
	|	&ОтборПоОрганизации
	|	И &ОтборПоКонтрагенту
	|	И Диадок_Документы.Документ В(&Документы1С)
	|	И Диадок_Документы.LetterId <> """"
	|	И Диадок_Документы.DocumentId <> """"
	|	И НЕ Диадок_Документы.ПометкаУдаления
	|	И Диадок_Документы.Метка <> ""Переотправлен""");
	
	Запрос.УстановитьПараметр("Документы1С", ДокументыОснования);
	
	Если ЗначениеЗаполнено(Документ) Тогда
		
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст,
			"&ОтборПоОрганизации",
			"Диадок_Документы.ОрганизацияДиадок = &ОрганизацияЭДО"
		);
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст,
			"&ОтборПоКонтрагенту",
			"Диадок_Документы.КонтрагентДиадок = &КонтрагентЭДО"
		);
		
		Запрос.УстановитьПараметр("ОрганизацияЭДО", Документ.Отправитель.ОрганизацияЭДО);
		Запрос.УстановитьПараметр("КонтрагентЭДО", Документ.Получатель.ОрганизацияЭДО);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "Истина");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоКонтрагенту", "Истина");
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		DocumentId = Новый Структура;
		DocumentId.Вставить("MessageId",	Выборка.LetterId);
		DocumentId.Вставить("EntityId",		Выборка.DocumentId);
		
		Результат.Добавить(DocumentId);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_УстановитьЗначениеРеквизита_ФункцияДокумента(ОбъектДокумента, ФункцияДокумента)
	
	МетаданныеРеквизита = Метаданные.Справочники.Диадок_Документы.Реквизиты.ФункцияДокумента;
	МаксимальнаяДлина = МетаданныеРеквизита.Тип.КвалификаторыСтроки.Длина;
	
	СохраняемоеЗначение = Документы_ФункцияДокументаДляХранения(ФункцияДокумента);
	
	Если СтрДлина(СохраняемоеЗначение) > МаксимальнаяДлина Тогда
		
		КомментарийЖР = "Длина функции (%1) превышает масимально возможную длину (%2)";
		КомментарийЖР = СтрЗаменить(КомментарийЖР, "%1", СохраняемоеЗначение);
		КомментарийЖР = СтрЗаменить(КомментарийЖР, "%2", XMLСтрока(МаксимальнаяДлина));
		
		ЗаписьЖурналаРегистрации(
			"Диадок",
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеРеквизита,
			ОбъектДокумента,
			КомментарийЖР
		);
		
	КонецЕсли;
	
	ОбъектДокумента.ФункцияДокумента = СохраняемоеЗначение;
	
КонецПроцедуры

Функция Документы_Записать_Диадок(Документ)
	
	Результат = Неопределено;
	
	РеквизитыДокумента = Документ.Реквизиты;
	Идентификаторы = Документ.Идентификаторы;
	Отправитель = Документ.Отправитель;
	Получатель = Документ.Получатель;
	СтруктураСтатусов = Документ.Статусы;
	СтруктураТипа = Документ.Тип;
	ДопРеквизиты = Документ.ДопРеквизиты;
	Связи = Документ.Связи;
	Документооборот = Документ.Документооборот;
	ПараметрыШаблона = Документ.ПараметрыШаблона;
	
	Если Идентификаторы.ДокументЭДО = Неопределено Тогда
		ОбъектДокумента = Справочники.Диадок_Документы.СоздатьЭлемент();
	Иначе
		ОбъектДокумента = Идентификаторы.ДокументЭДО.ПолучитьОбъект();
	КонецЕсли;
	
	Если Идентификаторы.ПакетЭДО = Неопределено Тогда
		
		ПакетЭДО = Пакеты_СсылкаПоИдентификаторам_Диадок(Идентификаторы);
		
		Если ПакетЭДО = Неопределено Тогда
			ПакетЭДО = Пакеты_ЗаписатьПоДокументу(Документ);
		КонецЕсли;
		
	Иначе
		ПакетЭДО = Идентификаторы.ПакетЭДО;
	КонецЕсли;
	
	Направление = Документ.Направление;
	
	ОбъектДокумента.Пакет = ПакетЭДО;
	ОбъектДокумента.Направление = Направление;
	ОбъектДокумента.Документ = Документ.ДокументУчета;
	ОбъектДокумента.ИмяФайла = Документ.ИмяФайла;
	ОбъектДокумента.Метка = Документ.Состояние;
	ОбъектДокумента.ДатаЗагрузки = Документ.ДатаЭДО;
	ОбъектДокумента.ВидДокумента =
		ДопСправочники_СсылкаПоИдентификатору_Диадок("ВидыДокументов", Документ.ИдентификаторВида);
	
	ОбъектДокумента.НомерДокумента = РеквизитыДокумента.Номер;
	ОбъектДокумента.ДатаДокумента = РеквизитыДокумента.Дата;
	ОбъектДокумента.СуммаДокумента = РеквизитыДокумента.Сумма;
	ОбъектДокумента.СуммаНДС = РеквизитыДокумента.СуммаНДС;
	ОбъектДокумента.Валюта = РеквизитыДокумента.КодВалюты;
	
	ОбъектДокумента.BoxId = АдресЯщикаВИдентификатор(Идентификаторы.BoxId);
	ОбъектДокумента.LetterId = Идентификаторы.LetterId;
	ОбъектДокумента.DocumentId = Идентификаторы.DocumentId;
	ОбъектДокумента.PacketId = Документ.Связи.PacketId;
	ОбъектДокумента.DepartmentId = ?(Направление = "Исходящее", Отправитель.DepartmentId, Получатель.DepartmentId);
	
	ОбъектДокумента.ОрганизацияДиадок =
		?(Направление = "Исходящее", Отправитель.ОрганизацияЭДО, Получатель.ОрганизацияЭДО);
	ОбъектДокумента.Организация = ?(Направление = "Исходящее", Отправитель.Организация, Получатель.Организация);
	ОбъектДокумента.КонтрагентДиадок = ?(Направление = "Исходящее", Получатель.ОрганизацияЭДО, Отправитель.ОрганизацияЭДО);
	ОбъектДокумента.Контрагент = ?(Направление = "Исходящее", Получатель.Организация, Отправитель.Организация);
	
	ОбъектДокумента.Статус = СтруктураСтатусов.Статус;
	ОбъектДокумента.ДополнительныйСтатус = СтруктураСтатусов.ДополнительныйСтатус;
	
	ОбъектМаршрутизации_УстановитьЗначение_Диадок(ОбъектДокумента, СтруктураСтатусов);
	
	ОбъектДокумента.ТребуетсяОбработка = СтруктураСтатусов.ТребуетсяОбработка;
	
	ОбъектДокумента.ТипДокумента = СтруктураТипа.ТипДокумента;
	ОбъектДокумента.ТипКонтента = СтруктураТипа.ТипКонтента;
	ОбъектДокумента.WorkflowId = СтруктураТипа.WorkflowId;
	
	Документы_УстановитьЗначениеРеквизита_ФункцияДокумента(ОбъектДокумента, СтруктураТипа.ФункцияДокумента);
	
	ОбъектДокумента.Хранилище = Новый ХранилищеЗначения(Документ.Метаданные);
	
	ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, "Комментарий", Документ.Комментарий, "");
	
	Если Документ.Шаблон Тогда
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, "Шаблон", Истина, "");
		
		Для Каждого Элемент Из ПараметрыШаблона Цикл
			ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, Элемент.Ключ, Элемент.Значение, "");
		КонецЦикла;
		
	КонецЕсли;
	
	ПараметрыОтправки = Неопределено;
	
	Если Документ.СлужебнаяИнформация.Свойство("ПараметрыОтправки", ПараметрыОтправки) Тогда
		
		Если ПараметрыОтправки.ЗапрашиватьИзвещение Тогда
			ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, "ЗапрашиватьИзвещение", Истина, "");
		КонецЕсли;
		
		Если ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись Тогда
			ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, "ЗапрашиватьОтветнуюПодпись", Истина, "");
		КонецЕсли;
		
	КонецЕсли;
	
	Для Каждого ТекРеквизит Из ДопРеквизиты Цикл
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ТекРеквизит.Ключ, ТекРеквизит.Значение, "");
	КонецЦикла;
	
	Для Каждого ТекРеквизит Из Связи Цикл
		
		Если ТекРеквизит.Ключ = "CustomDocumentId" ИЛИ ТекРеквизит.Ключ = "OriginMessageId" Тогда
			ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ТекРеквизит.Ключ, ТекРеквизит.Значение, "");
		ИначеЕсли ТекРеквизит.Ключ = "PacketId" Тогда
			Продолжить; // Записан в шапке документа
		Иначе
			ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ТекРеквизит.Ключ,
				Новый ХранилищеЗначения(ТекРеквизит.Значение), "");
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Документ.Отправитель.DepartmentId) Тогда
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.FromDepartmentId,
			Документ.Отправитель.DepartmentId, "");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.Получатель.DepartmentId) Тогда
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.ToDepartmentID,
			Документ.Получатель.DepartmentId, "");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураСтатусов.СтатусМЧД) Тогда
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.СтатусМЧД,
			СтруктураСтатусов.СтатусМЧД, "");
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.СтатусМЧДКритичность,
			СтруктураСтатусов.СтатусМЧДКритичность, "");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураСтатусов.СтатусПКФНС) Тогда
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.СтатусПКФНС,
			СтруктураСтатусов.СтатусПКФНС, "");
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИменаСвойствНастроек.СтатусПКФНСКритичность,
			СтруктураСтатусов.СтатусПКФНСКритичность, "");
		
	КонецЕсли;
	
	Для Каждого КлючЗначение Из СтруктураСтатусов.ВнешниеСтатусы Цикл
		
		ИдентификаторВнешнегоСтатуса = КлючЗначение.Ключ;
		ЗначениеВнешнегоСатуса = КлючЗначение.Значение;
		
		ИмяДопРеквизита = Документы_ИмяДопРеквизита_ВнешнийСтатус(ИдентификаторВнешнегоСтатуса);
		
		ОбновитьЗначениеДопРеквизитаДиадок(ОбъектДокумента, ИмяДопРеквизита, ЗначениеВнешнегоСатуса, "");
		
	КонецЦикла;
	
	ОбъектДокумента.Записать();
	
	Для Каждого ТекХранилище Из Документооборот Цикл
		
		ИмяХранилища = ТекХранилище.Ключ;
		ДанныеХранения = ТекХранилище.Значение;
		Документы_ЗаписатьДанныеХранилища(ДанныеХранения, ИмяХранилища, ОбъектДокумента.Ссылка);
		
	КонецЦикла;
	
	Документ.Идентификаторы.ПакетЭДО = ПакетЭДО;
	Документ.Идентификаторы.ДокументЭДО = ОбъектДокумента.Ссылка;
	
	Результат = Документ.Идентификаторы.ДокументЭДО;
	
	Возврат Результат;
	
КонецФункции

Процедура ОбъектМаршрутизации_УстановитьЗначение_Диадок(ОбъектДокумента, СтруктураСтатусов)
	
	ОбъектМаршрутизации = Неопределено;
	
	Если НЕ СтруктураСтатусов.Свойство("ОбъектМаршрутизации", ОбъектМаршрутизации) Тогда
		Возврат;
	КонецЕсли;
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
	ОбъектМаршрутизации = СтруктураСтатусов.ОбъектМаршрутизации;
	
	ИдентификаторОбъектаМаршрутизации = СвойствоСтруктуры(ОбъектМаршрутизации, "Идентификатор");
	НаименованиеОбъектаМаршрутизации = СвойствоСтруктуры(ОбъектМаршрутизации, "Наименование");
	
	ОбновитьЗначениеДопРеквизитаДиадок(
		ОбъектДокумента,
		ИменаСвойствНастроек.ОбъектМаршрутизации,
		ИдентификаторОбъектаМаршрутизации,
		НаименованиеОбъектаМаршрутизации
	);
	
КонецПроцедуры

Функция Документы_СсылкаНаДокументЭДО_Диадок(Идентификаторы)
	
	Результат = Неопределено;
	
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Диадок_Документы.Ссылка
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|ГДЕ
	|	Диадок_Документы.BoxId = &BoxId
	|	И Диадок_Документы.LetterId = &LetterId
	|	И Диадок_Документы.DocumentId = &DocumentId";
	
	Запрос.УстановитьПараметр("BoxId",		BoxId);
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	Запрос.УстановитьПараметр("DocumentId",	DocumentId);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		Результат = ВыборкаЗапроса.Ссылка;
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ОбновлениеРеквизитов_Диадок(Идентификаторы, СтруктураРеквизитов)
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
	
	ДокументЭДО = СвойствоСтруктуры(Идентификаторы, "ДокументЭДО");
	
	ДокументОбъект = ДокументЭДО.ПолучитьОбъект();
	
	Если СтруктураРеквизитов.Свойство("DepartmentId") Тогда
		ДокументОбъект.DepartmentId = СтруктураРеквизитов.DepartmentId;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("PacketId") Тогда
		ДокументОбъект.PacketId = СтруктураРеквизитов.PacketId;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("Статус") Тогда
		ДокументОбъект.Статус = СтруктураРеквизитов.Статус;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ДополнительныйСтатус") Тогда
		ДокументОбъект.ДополнительныйСтатус = СтруктураРеквизитов.ДополнительныйСтатус;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ВнешниеСтатусы") Тогда
		
		ЗначениеВнешнегоСатуса = Ядро_СтатусГИСМТ(СтруктураРеквизитов.ВнешниеСтатусы);
		
		Если ЗначениеВнешнегоСатуса <> Неопределено Тогда
			ИмяДопРеквизита = Документы_ИмяДопРеквизита_ВнешнийСтатусГИСМТ();
			ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИмяДопРеквизита, ЗначениеВнешнегоСатуса, "");
		КонецЕсли;
		
		ЗначениеВнешнегоСатуса = Ядро_СтатусКонтурЛогистика(СтруктураРеквизитов.ВнешниеСтатусы);
		
		Если ЗначениеВнешнегоСатуса <> Неопределено Тогда
			ИмяДопРеквизита = Документы_ИмяДопРеквизита_ВнешнийСтатусКонтурЛогистика();
			ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИмяДопРеквизита, ЗначениеВнешнегоСатуса, "");
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТребуетсяОбработка") Тогда
		ДокументОбъект.ТребуетсяОбработка = СтруктураРеквизитов.ТребуетсяОбработка;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТребуемоеДействиеВДД") Тогда
		ДокументОбъект.ТребуемоеДействиеВДД = СтруктураРеквизитов.ТребуемоеДействиеВДД;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТребуемоеДействиеВ1С") Тогда
		ДокументОбъект.ТребуемоеДействиеВ1С = СтруктураРеквизитов.ТребуемоеДействиеВ1С;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("АнализПроведен") Тогда
		ДокументОбъект.АнализПроведен = СтруктураРеквизитов.АнализПроведен;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ДокументУчета") Тогда
		ДокументОбъект.Документ = СтруктураРеквизитов.ДокументУчета;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("Организация") Тогда
		ДокументОбъект.Организация = СтруктураРеквизитов.Организация;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("Контрагент") Тогда
		ДокументОбъект.Контрагент = СтруктураРеквизитов.Контрагент;
	КонецЕсли;
	
	СтатусМЧД = Неопределено;
	Если СтруктураРеквизитов.Свойство("СтатусМЧД", СтатусМЧД) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.СтатусМЧД, СтатусМЧД, "");
	КонецЕсли;
	
	СтатусМЧДКритичность = Неопределено;
	Если СтруктураРеквизитов.Свойство("СтатусМЧДКритичность", СтатусМЧДКритичность) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.СтатусМЧДКритичность,
			СтатусМЧДКритичность, "");
	КонецЕсли;
	
	СтатусПКФНС = Неопределено;
	Если СтруктураРеквизитов.Свойство("СтатусПКФНС", СтатусПКФНС) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.СтатусПКФНС, СтатусПКФНС, "");
	КонецЕсли;
	
	СтатусПКФНСКритичность = Неопределено;
	Если СтруктураРеквизитов.Свойство("СтатусПКФНСКритичность", СтатусПКФНСКритичность) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.СтатусПКФНСКритичность,
			СтатусПКФНСКритичность, "");
	КонецЕсли;
	
	СтатусДТС = Неопределено;
	Если СтруктураРеквизитов.Свойство("СтатусДТС", СтатусДТС) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.СтатусДТС, СтатусДТС, "");
	КонецЕсли;
	
	FromDepartmentId = Неопределено;
	Если СтруктураРеквизитов.Свойство("FromDepartmentId", FromDepartmentId) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.FromDepartmentId, FromDepartmentId, "");
	КонецЕсли;
	
	ToDepartmentId = Неопределено;
	Если СтруктураРеквизитов.Свойство("ToDepartmentId", ToDepartmentId) Тогда
		ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИменаСвойствНастроек.ToDepartmentId, ToDepartmentId, "");
	КонецЕсли;
	
	ОбъектМаршрутизации_УстановитьЗначение_Диадок(ДокументОбъект, СтруктураРеквизитов);
	
	ДокументОбъект.Записать();
	
КонецПроцедуры

Процедура ОбновитьЗначениеДопРеквизитаДиадок(ДокументОбъект, ИмяРеквизита, ЗначениеРеквизита, ЗначениеСтрока)
	
	СтрокаРеквизита = ДокументОбъект.ДополнительныеРеквизиты.Найти(ИмяРеквизита, "ИмяРеквизита");
	
	Если СтрокаРеквизита = Неопределено Тогда
		
		ЗначениеДляУстановкиНеЗаполнено =
			(НЕ ЗначениеЗаполнено(ЗначениеРеквизита) ИЛИ ЗначениеРеквизита = Ложь ИЛИ ЗначениеРеквизита = ПустойИдентификатор())
			И (НЕ ЗначениеЗаполнено(ЗначениеСтрока) ИЛИ ЗначениеСтрока = ПустойИдентификатор());
		
		Если ЗначениеДляУстановкиНеЗаполнено Тогда
			Возврат;
		КонецЕсли;
		
		СтрокаРеквизита = ДокументОбъект.ДополнительныеРеквизиты.Добавить();
		СтрокаРеквизита.ИмяРеквизита = ИмяРеквизита;
		
	КонецЕсли;
	
	Если ТипЗнч(ЗначениеРеквизита) = Тип("ХранилищеЗначения") Тогда
		СтрокаРеквизита.ЗначениеХранилищеЗначения = ЗначениеРеквизита;
	ИначеЕсли ТипЗнч(ЗначениеРеквизита) = Тип("Структура") Тогда
		СтрокаРеквизита.ЗначениеХранилищеЗначения = Новый ХранилищеЗначения(ЗначениеРеквизита);
	Иначе
		СтрокаРеквизита.Значение = ЗначениеРеквизита;
	КонецЕсли;
	
	СтрокаРеквизита.ЗначениеСтрока = ЗначениеСтрока;
	
КонецПроцедуры

