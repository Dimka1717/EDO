// Управляет настройкой использования ПМ модуля Стандарт
//
// Параметры:
//  ЗначениеИспользоватьПМСтандарта - Булево, Строка - Значение настройки ИспользоватьПодключаемыйМодуль
//
Процедура УстановитьНастройкуИспользоватьПМСтандарта(ЗначениеИспользоватьПМСтандарта) Экспорт
	
	ВключитьИспользованиеПМ = (Строка(ЗначениеИспользоватьПМСтандарта) <> "Нет");
	
	Если ВключитьИспользованиеПМ Тогда
		ПодключитьПМСтандарта(ЗначениеИспользоватьПМСтандарта);
	Иначе
		ОтключитьПМСтандарта(ЗначениеИспользоватьПМСтандарта);
	КонецЕсли;
	
КонецПроцедуры

// Отключает использование подключаемого модуда Стандарта
//
// Параметры:
//  ЗначениеНастройки - Булево, Строка - Значение настройки ИспользоватьПодключаемыйМодуль
//
Процедура ОтключитьПМСтандарта(ЗначениеНастройки)
	
	Настройка = НастройкиМодуляСтандарт();
	
	Если Настройка.ИспользоватьПодключаемыйМодуль Тогда
		
		УстановитьНастройкуСтандарта_ИспользоватьПодключаемыйМодуль(ЗначениеНастройки);
		
		Кэш_Поместить("НастройкиМодуляСтандарт", Неопределено);
		
	КонецЕсли;
	
КонецПроцедуры

// Включает использование подкулючаемого модуля Стандарта
//
// Параметры:
//  ЗначениеНастройки - Булево, Строка - Значение настройки ИспользоватьПодключаемыйМодуль
//
Процедура ПодключитьПМСтандарта(ЗначениеНастройки)
	
	Если МожноПодключитьПМСтандарта(ЗначениеНастройки) Тогда
		
		УстановитьНастройкуСтандарта_ИспользоватьПодключаемыйМодуль(ЗначениеНастройки);
		
		Кэш_Поместить("НастройкиМодуляСтандарт", Неопределено);
		
	КонецЕсли;
	
КонецПроцедуры

Функция МожноПодключитьПМСтандарта(ЗначениеНастройки)
	
	Настройка = НастройкиМодуляСтандарт();
	
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	Если ИмяРегистра = "ЗначенияСвойствОбъектов" Тогда
		
		ЕстьНастройкиПМНаДиске = (ЗначениеНастройки = "Диск"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульПуть));
		
		ЕстьНастройкиПМВСправочнике = (ЗначениеНастройки = "1С"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульСсылка));
		
		ЕстьНастройкиПМВКонфигурации = (ЗначениеНастройки = "Конфигурация"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульИмяОбработки));
		
	ИначеЕсли ИмяРегистра = "ДополнительныеСведения" Тогда
		
		ЕстьНастройкиПМНаДиске = (Настройка.МестонахождениеПодключаемогоМодуля = "Диск"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульПуть));
		
		ЕстьНастройкиПМВСправочнике = (Настройка.МестонахождениеПодключаемогоМодуля = "1С"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульСсылка));
		
		ЕстьНастройкиПМВКонфигурации = (Настройка.МестонахождениеПодключаемогоМодуля = "Конфигурация"
			И ЗначениеЗаполнено(Настройка.ПодключаемыйМодульИмяОбработки));
		
	Иначе
		
		ТекстОшибки = НСтр("ru='Не определено имя регистра хранения настроек'");
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Результат = (НЕ Настройка.ИспользоватьПодключаемыйМодуль
		И (ЕстьНастройкиПМНаДиске
		ИЛИ ЕстьНастройкиПМВСправочнике
		ИЛИ ЕстьНастройкиПМВКонфигурации));
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьНастройкуСтандарта_ИспользоватьПодключаемыйМодуль(ЗначениеНастройки)
	
	Объект = ОбъектОбщихНастроек_1С();
	ИмяСвойства = НастройкиМодуляСтандарт_СвойствоИспользоватьПодключаемыйМодуль();
	СПрефиксом = Ложь;
	
	ДопРеквизиты_УстановитьЗначение_1С(
		Объект,
		ИмяСвойства,
		ЗначениеНастройки,
		СПрефиксом
	);
	
КонецПроцедуры

Функция НастройкиМодуляСтандарт_СвойствоИспользоватьПодключаемыйМодуль()
	
	ИдентификаторСвойства = "ИспользоватьПодключаемыйМодуль";
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	ИменаСвойств = НастройкиМодуляСтандарт_НаименованияСвойствПВХ(ИмяРегистра);
	
	Результат = ИменаСвойств.Получить(ИдентификаторСвойства);
	
	Возврат Результат;
	
КонецФункции

// Управляет настройкой использования конвертации форматов из 820@ в 970@
//
// Параметры:
//  ВключитьРежимСовместимости - Булево - Истина, если требуется установить настройку конвертации в значение "Авто"
//
Процедура УстановитьНастройкуРежимСовместимости_820_970(ВключитьРежимСовместимости) Экспорт
	
	ОбщиеНастройки = Настройки_ОбщиеНастройки();
	
	ТекущийРежимСовместимости = ОбщиеНастройки.РежимСовместимостиФорматов820и970;
	
	Если ВключитьРежимСовместимости Тогда
		ВключитьРежимСовместимости_820_970(ТекущийРежимСовместимости);
	Иначе
		ОтключитьРежимСовместимости_820_970(ТекущийРежимСовместимости);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВключитьРежимСовместимости_820_970(ТекущееЗначениеНастройки)
	
	РежимыСовместимости = Настройки_Конвертация970_РежимыСовместимостиФорматов820и970();
	
	Если ТекущееЗначениеНастройки <> РежимыСовместимости.Авто Тогда
		
		СтруктураНастроек = Настройки_ОбщиеНастройки();
		СтруктураНастроек.Вставить("РежимСовместимостиФорматов820и970", РежимыСовместимости.Авто);
		
		Настройки_ЗаписатьОбщиеНастройки(СтруктураНастроек);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтключитьРежимСовместимости_820_970(ТекущееЗначениеНастройки)
	
	РежимыСовместимости = Настройки_Конвертация970_РежимыСовместимостиФорматов820и970();
	
	Если ТекущееЗначениеНастройки <> РежимыСовместимости.НеИспользуется Тогда
		
		СтруктураНастроек = Настройки_ОбщиеНастройки();
		СтруктураНастроек.Вставить("РежимСовместимостиФорматов820и970", РежимыСовместимости.НеИспользуется);
		
		Настройки_ЗаписатьОбщиеНастройки(СтруктураНастроек);
		
	КонецЕсли;
	
КонецПроцедуры

// Настройки документов на отправку по сопоставленным организациям
//
// Параметры:
//  ВидыДокументов - Массив - Идентификаторы видов документов на отправку
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Настройки по сопоставленным организациям
//   * Организация - Ссылка - Ссылка на организацию-владельца настроек видов документов на отправку
//   * Свойство - Строка, ПланВидовХарактеристикСсылка - Дополнительное свойство формата документа на отправку
//   * Значение - Строка - Значение настройки вида документана отправку
//
Функция НастройкиДокументовНаОтправкуПоСопоставленнымОрганизациям(ВидыДокументов) Экспорт
	
	ДопСвойства_ВидыДокументов = ДопСвойства_ВидыПервичныхДокументов(ВидыДокументов);
	
	ТекстЗапроса = ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДопСвойства_ВидыДокументов", ДопСвойства_ВидыДокументов);
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Записывает настройку для организации или контрагента
//
// Параметры:
//  КлючНастройки - Строка, ПланВидовХарактеристикСсылка - Дополнительное свойство формата документа на отправку
//  ЗначениеЗастройки - Строка - Значение настройки вида документана отправку
//  ОрганизацияЭДО - Ссылка - Ссылка на организацию-владельца настройки вида документа на отправку
//  КонтрагентЭДО - Ссылка, Неопределено - Ссылка на контрагента-владельца настройки вида документа на отправку
//
Процедура ЗаписатьНастройкуУчастникаДО(
		КлючНастройки,
		ЗначениеЗастройки,
		ОрганизацияЭДО,
		КонтрагентЭДО = Неопределено) Экспорт
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		ВладелецНастройкиКонтрагент = Контрагенты_ПустаяСсылка_Диадок();
		Если ЗначениеЗаполнено(КонтрагентЭДО) Тогда
			ВладелецНастройкиКонтрагент = КонтрагентЭДО;
		КонецЕсли;
		
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("ОрганизацияЭДО", ОрганизацияЭДО);
		СтруктураДанных.Вставить("КонтрагентЭДО", ВладелецНастройкиКонтрагент);
		СтруктураДанных.Вставить("ИмяСвойства", КлючНастройки);
		СтруктураДанных.Вставить("Значение", ЗначениеЗастройки);
		
		Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
		
	Иначе
		
		ВладелецНастройки = ОрганизацияЭДО;
		Если ЗначениеЗаполнено(КонтрагентЭДО) Тогда
			ВладелецНастройки = КонтрагентЭДО;
		КонецЕсли;
		
		ДопРеквизиты_УстановитьЗначение(ВладелецНастройки, КлючНастройки, ЗначениеЗастройки);
		
	КонецЕсли;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку()
	
	ЭтоСХ1_Расширение = (ИспользоватьПодсистемуДиадока()
		И ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц());
	
	ЭтоСХ1_Конфигурация = (ИспользоватьПодсистемуДиадока()
		И НЕ ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц());
	
	ЭтоСХ2 = ИспользоватьТиповуюПодсистему1С();
	
	Если ЭтоСХ1_Расширение Тогда
		Результат = ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_Расширение();
	ИначеЕсли ЭтоСХ1_Конфигурация Тогда
		Результат = ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_Диадок();
	ИначеЕсли ЭтоСХ2 Тогда
		Результат = ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_1С();
	Иначе
		
		ТекстОшибки = НСтр("ru='Не удалось определить систему хранения'");
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_Расширение()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Т.Организация КАК Организация,
	|	Т.ИмяСвойства КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛица_Организация
	|		ПО Т.Организация = Диадок_ЮрФизЛица_Организация.Ссылка
	|			И Диадок_ЮрФизЛица_Организация.ИмяРеквизита = ""СвязанныйСправочник1""
	|ГДЕ
	|	Т.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Т.Контрагент = ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Диадок_ЮрФизЛица_Организация.Значение <> НЕОПРЕДЕЛЕНО
	|	И Т.ИмяСвойства В(&ДопСвойства_ВидыДокументов)";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_Диадок()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Т.Организация КАК Организация,
	|	Т.ИмяСвойства КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Организация
	|		ПО Т.Организация = Диадок_ЮрФизЛица_Организация.Ссылка
	|ГДЕ
	|	Т.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Т.Контрагент = ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Диадок_ЮрФизЛица_Организация.СвязанныйСправочник1 <> НЕОПРЕДЕЛЕНО
	|	И Т.ИмяСвойства В(&ДопСвойства_ВидыДокументов)";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ОбщиеНастройкиДокументовНаОтправку_1С()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(Т.Объект КАК Справочник.Организации) КАК Организация,
	|	Т.Свойство КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК Т
	|ГДЕ
	|	Т.Объект ССЫЛКА Справочник.Организации
	|	И Т.Свойство В(&ДопСвойства_ВидыДокументов)";
	
	ИмяТаблицыОрганизации = ТипЗначенияОбъекта("Организации", "ДляЗапроса");
	Результат = СтрЗаменить(Результат, "Справочник.Организации", ИмяТаблицыОрганизации);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ДопСвойства_ВидыПервичныхДокументов(ВидыДокументов)
	
	Результат = Новый Массив;
	
	Для Каждого Элемент Из ВидыДокументов Цикл
		Результат.Добавить(Свойства_ФорматОтправкиПоВидуДокумента(Элемент));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Настройки документов на отправку по сопоставленным контрагентам
//
// Параметры:
//  ВидыДокументов - Массив - Идентификаторы видов документов на отправку
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Настройки по сопоставленным контрагентам
//   * Организация - Ссылка - Ссылка на организацию-владельца настроек видов документов на отправку
//   * Контрагент - Ссылка - Ссылка на контрагента-владельца настроек видов документов на отправку
//   * Свойство - Строка, ПланВидовХарактеристикСсылка - Дополнительное свойство формата документа на отправку
//   * Значение - Строка - Значение настройки вида документана отправку
//
Функция НастройкиДокументовНаОтправкуПоСопоставленнымКонтрагентам(ВидыДокументов) Экспорт
	
	ДопСвойства_ВидыДокументов = ДопСвойства_ВидыПервичныхДокументов(ВидыДокументов);
	
	ТекстЗапроса = ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДопСвойства_ВидыДокументов", ДопСвойства_ВидыДокументов);
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку()
	
	ЭтоСХ1_Расширение = (ИспользоватьПодсистемуДиадока()
		И ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц());
	
	ЭтоСХ1_Конфигурация = (ИспользоватьПодсистемуДиадока()
		И НЕ ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц());
	
	ЭтоСХ2 = ИспользоватьТиповуюПодсистему1С();
	
	Если ЭтоСХ1_Расширение Тогда
		Результат = ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_Расширение();
	ИначеЕсли ЭтоСХ1_Конфигурация Тогда
		Результат = ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_Диадок();
	ИначеЕсли ЭтоСХ2 Тогда
		Результат = ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_1С();
	Иначе
		
		ТекстОшибки = НСтр("ru='Не удалось определить систему хранения'");
		
		ВызватьИсключение ТекстОшибки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_Расширение()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Т.Организация КАК Организация,
	|	Т.Контрагент КАК Контрагент,
	|	Т.ИмяСвойства КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛица_Организация
	|		ПО Т.Организация = Диадок_ЮрФизЛица_Организация.Ссылка
	|			И Диадок_ЮрФизЛица_Организация.ИмяРеквизита = ""СвязанныйСправочник1""
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛица_Контрагент
	|		ПО Т.Контрагент = Диадок_ЮрФизЛица_Контрагент.Ссылка
	|			И Диадок_ЮрФизЛица_Контрагент.ИмяРеквизита = ""СвязанныйСправочник1""
	|ГДЕ
	|	Т.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Т.Контрагент <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Диадок_ЮрФизЛица_Организация.Значение <> НЕОПРЕДЕЛЕНО
	|	И Диадок_ЮрФизЛица_Контрагент.Значение <> НЕОПРЕДЕЛЕНО
	|	И Т.ИмяСвойства В(&ДопСвойства_ВидыДокументов)";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_Диадок()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Т.Организация КАК Организация,
	|	Т.Контрагент КАК Контрагент,
	|	Т.ИмяСвойства КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Организация
	|		ПО Т.Организация = Диадок_ЮрФизЛица_Организация.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Контрагент
	|		ПО Т.Контрагент = Диадок_ЮрФизЛица_Контрагент.Ссылка
	|ГДЕ
	|	Т.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Т.Контрагент <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
	|	И Диадок_ЮрФизЛица_Организация.СвязанныйСправочник1 <> НЕОПРЕДЕЛЕНО
	|	И Диадок_ЮрФизЛица_Контрагент.СвязанныйСправочник1 <> НЕОПРЕДЕЛЕНО
	|	И Т.ИмяСвойства В(&ДопСвойства_ВидыДокументов)";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ИндивидуальныеНастройкиДокументовНаОтправку_1С()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(Т.Объект КАК Справочник.Организации) КАК Организация,
	|	ВЫРАЗИТЬ(Т.Объект КАК Справочник.Контрагенты) КАК Контрагент,
	|	Т.Свойство КАК Свойство,
	|	Т.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК Т
	|ГДЕ
	|	Т.Объект ССЫЛКА Справочник.Контрагенты
	|	И Т.Свойство В(&ДопСвойства_ВидыДокументов)";
	
	ИмяТаблицыОрганизации = ТипЗначенияОбъекта("Контрагенты", "ДляЗапроса");
	Результат = СтрЗаменить(Результат, "Справочник.Контрагенты", ИмяТаблицыОрганизации);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Результат);
	
	Возврат Результат;
	
КонецФункции

