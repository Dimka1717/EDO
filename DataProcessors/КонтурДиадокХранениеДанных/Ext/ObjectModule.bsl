Процедура ДопРеквизиты_ОчиститьСвязанныеСправочники_Диадок(ЮрФизЛицоОбъект)
	
	ДополнительныеРеквизиты = ЮрФизЛицоОбъект.ДополнительныеРеквизиты;
	
	УдаляемыеСтрокиТЧ = Новый Массив;
	
	Для каждого СтрокаТЧ Из ДополнительныеРеквизиты Цикл
		
		ИмяРеквизита = СтрокаТЧ.ИмяРеквизита;
		
		Если Найти(ИмяРеквизита, Перечисление_ИменаСвойствНастроек_Диадок().СвязанныйСправочник) > 0 Тогда
			УдаляемыеСтрокиТЧ.Добавить(СтрокаТЧ);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтрокиТЧ Цикл
		ДополнительныеРеквизиты.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

Функция ДопСправочники_НайтиПоНаименованию_Диадок(ИмяСправочника, Наименование)
	
	Результат = Неопределено;
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.Диадок_ДополнительныеСправочники") Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочники.Ссылка
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники КАК Диадок_ДополнительныеСправочники
		|ГДЕ
		|	Диадок_ДополнительныеСправочники.ИмяСправочника = &ИмяСправочника
		|	И Диадок_ДополнительныеСправочники.Наименование = &Наименование"
		);
		
		Запрос.УстановитьПараметр("ИмяСправочника",	ИмяСправочника);
		Запрос.УстановитьПараметр("Наименование",	Наименование);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаЗапроса.Следующий() Тогда
			Результат = ВыборкаЗапроса.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция ДопСправочники_СписокЭлементов_Диадок(ИмяСправочника, ПереченьРеквизитов)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Ссылка");
	Результат.Колонки.Добавить("Наименование");
	
	Если ПереченьРеквизитов = Неопределено
		И (ИмяСправочника = "ВидыПакетов" ИЛИ ИмяСправочника = "ВидыДокументов") Тогда
		
		ПереченьРеквизитов = "ID";

	КонецЕсли;
	
	СписокДопРеквизитов = РазделитьСтрокуЛок(ПереченьРеквизитов);
	
	Для Каждого ДопРеквизит Из СписокДопРеквизитов Цикл
		Результат.Колонки.Добавить(ДопРеквизит);
	КонецЦикла;
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.Диадок_ДополнительныеСправочники") Тогда
		
		Запрос = Новый Запрос( 
		"ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочники.Ссылка КАК Ссылка,
		|	Диадок_ДополнительныеСправочники.Наименование КАК Наименование,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ИмяРеквизита КАК ИмяРеквизита,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ЗначениеСтрока,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ЗначениеХранилищеЗначения
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники КАК Диадок_ДополнительныеСправочники
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Диадок_ДополнительныеСправочникиДополнительныеРеквизиты
		|		ПО Диадок_ДополнительныеСправочники.Ссылка = Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка
		|			И (Диадок_ДополнительныеСправочники.ИмяСправочника = &ИмяСправочника)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Диадок_ДополнительныеСправочники.Наименование"
		);
		
		Запрос.УстановитьПараметр("ИмяСправочника", ИмяСправочника);			   
		
		СтарЭлемент = Неопределено;
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.Ссылка <> СтарЭлемент Тогда
				
				НоваяСтрока = Результат.Добавить();
				НоваяСтрока.Ссылка			= Выборка.Ссылка;
				НоваяСтрока.Наименование	= Выборка.Наименование;
				
				СтарЭлемент = Выборка.Ссылка;	
				
			КонецЕсли;
			
			Если СписокДопРеквизитов.Найти(Выборка.ИмяРеквизита) <> Неопределено Тогда
				НоваяСтрока[Выборка.ИмяРеквизита] = Справочники_ЗначениеДопРеквизита_Диадок(Выборка);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИмяСправочника = "ВидыГруппировкиПолученных"
		И ПереченьРеквизитов = "ТипыДокументов" Тогда
		ДопСправочники_ЗаполнитьВидыГруппировкиПолученных(Результат);
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция ДопСправочники_СсылкаПоИдентификатору_Диадок(ИмяСправочника, Идентификатор)
	
	Результат = Неопределено;
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.Диадок_ДополнительныеСправочники") Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Диадок_ДополнительныеСправочникиДополнительныеРеквизиты
		|ГДЕ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка.ИмяСправочника = &ИмяСправочника
		|	И Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ИмяРеквизита = ""ID""
		|	И Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение = &Идентификатор"
		);
		
		Запрос.УстановитьПараметр("ИмяСправочника",	ИмяСправочника);
		Запрос.УстановитьПараметр("Идентификатор",	Идентификатор);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаЗапроса.Следующий() Тогда
			Результат = ВыборкаЗапроса.Ссылка;
		КонецЕсли;	 
		
	КонецЕсли;

	Возврат Результат;

КонецФункции

// см. ДопСправочники_СсылкиНаЭлементыСправочникаПоИдентификаторам
//
Функция ДопСправочники_СсылкиНаЭлементыСправочникаПоИдентификаторам_Диадок(ИмяСправочника, Идентификаторы)
	
	Результат = Новый Соответствие;
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники.Диадок_ДополнительныеСправочники") Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Реквизиты.Ссылка,
		|	Реквизиты.Значение
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Реквизиты
		|ГДЕ
		|	Реквизиты.Ссылка.ИмяСправочника = &ИмяСправочника
		|	И Реквизиты.ИмяРеквизита = ""ID""
		|	И Реквизиты.Значение В (&Идентификаторы)"
		);
		
		Запрос.УстановитьПараметр("ИмяСправочника",	ИмяСправочника);
		Запрос.УстановитьПараметр("Идентификаторы",	Идентификаторы);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Пока ВыборкаЗапроса.Следующий() Цикл
			Результат.Вставить(ВыборкаЗапроса.Значение, ВыборкаЗапроса.Ссылка);
		КонецЦикла;	 
		
	КонецЕсли;
	
	Возврат Результат;
	
