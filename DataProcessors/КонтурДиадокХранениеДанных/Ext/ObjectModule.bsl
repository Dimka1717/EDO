// Приводит значения ключей организации к формату хранения.
// Идентификатор ящика организации записывается в базу в формате
// адреса электронной почты, а во входящем параметре идентификатор
// ящика может быть указан в формате уникального идентификатора
//
// Параметры:
//  Идентификаторы - Структура - Новый_ИдентификаторыСправочника
// 
// Возвращаемое значение:
//  Структура - Новый_ИдентификаторыСправочника, где ID в формате e-mail
//
Функция ИдентификаторыОрганизации(Знач Идентификаторы)
	
	Если Не ЗначениеЗаполнено(Идентификаторы.ID)
		Или Найти(Идентификаторы.ID, "@") > 0 Тогда
		Возврат Идентификаторы;
	КонецЕсли;
	
	АдресЯщика = ИдентификаторВАдресЯщика(Идентификаторы.ID);
	Результат = Новый_ИдентификаторыСправочника(Идентификаторы.Ссылка, АдресЯщика);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ПустаяСсылка_Диадок()
	
	Результат = Справочники.Диадок_ЮрФизЛица.ПустаяСсылка();
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ДанныеОрганизации_Диадок(Идентификаторы)
	
	Результат = Контракт_ОрганизацияЭДО();
	ВыборкаДанных = Справочники_ВыборкаДанныхСправочника_Диадок("Организации", Идентификаторы);
	
	Если ВыборкаДанных <> Неопределено Тогда
		
		Результат.ID = ВыборкаДанных.ID;
		Результат.ИНН = ВыборкаДанных.ИНН;
		Результат.КПП = ВыборкаДанных.КПП;
		Результат.Наименование = ВыборкаДанных.Наименование;
		Результат.Ссылка = ВыборкаДанных.Ссылка;
		Результат.СвязанныйСправочник1 = ВыборкаДанных.СвязанныйСправочник1;
		Результат.ID_ОсновноеПодразделение = ВыборкаДанных.ID_ОсновноеПодразделение;
		Результат.ИдентификаторУчастникаЭДО = ВыборкаДанных.ИдентификаторУчастникаЭДО;
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
		
		МассивДопРеквизитов = Новый Массив;
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.AfterIndexKey);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ДатаГраницыСинхронизации);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ОтпечатокСертификатаНаСервере);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.OrgId);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.УказыватьОтсутствиеОснованияУПД);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ОтправлятьНепроведенныеДокументы);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ЗаписыватьКомментарииВДокументы1С);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ТекстКомментарияОтправка);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ТекстКомментарияПолучение);
		МассивДопРеквизитов.Добавить(ИменаСвойствНастроек.ДатаСинхронизацииСтатусовКонтрагентов);
		
		ИменаДопРеквизитов = СоединитьСтроку(МассивДопРеквизитов, ",");
		ДопРеквизиты = ДопРеквизиты_СписокРеквизитов_Диадок(Результат.Ссылка, ИменаДопРеквизитов);
		ЗаполнитьЗначенияСвойств(Результат, ДопРеквизиты);
		
		Результат.ЗаписыватьКомментарииВДокументы1С =
			?(Результат.ЗаписыватьКомментарииВДокументы1С = Неопределено,
				Ложь,
				Результат.ЗаписыватьКомментарииВДокументы1С);
		Результат.УказыватьОтсутствиеОснованияУПД =
			?(Результат.УказыватьОтсутствиеОснованияУПД = Неопределено,
				Ложь,
				Результат.УказыватьОтсутствиеОснованияУПД);
		Результат.ОтправлятьНепроведенныеДокументы =
			?(Результат.ОтправлятьНепроведенныеДокументы = Неопределено,
				Ложь,
				Результат.ОтправлятьНепроведенныеДокументы);
		Результат.ДатаСинхронизацииСтатусовКонтрагентов =
			?(Результат.ДатаСинхронизацииСтатусовКонтрагентов = Неопределено,
				Дата("00010101"),
				Результат.ДатаСинхронизацииСтатусовКонтрагентов);
		
		Результат.ОсновнойПакет = ДопРеквизиты_ЗначениеОсновногоПакета_Диадок(Результат.Ссылка);
		
		Если НЕ ЗначениеЗаполнено(Идентификаторы.Ссылка) Тогда
			Идентификаторы.Ссылка = Результат.Ссылка;
		КонецЕсли;
		
		Результат.ШифроватьДокументы = ДопРеквизиты_ЗначениеШифрованияДокумента_Диадок(Идентификаторы, Новый Структура);
		Результат.ШифроватьДокументы = ?(Результат.ШифроватьДокументы = Неопределено, Ложь, Результат.ШифроватьДокументы);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_СопоставленнаяВ1С_Диадок(Идентификаторы)

	Результат = Справочники_СвязанныйСправочник_Диадок("Организации", Идентификаторы);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_СопоставленныеВ1С_Диадок(ИсходныеИдентификаторы)
	
	Идентификаторы = ИдентификаторыОрганизации(ИсходныеИдентификаторы);
	
	ИмяСправочника = Перечисление_ИменаСправочников_Диадок().Организации;
	
	Результат = Справочники_СопоставленныеВ1С_Диадок(ИмяСправочника, Идентификаторы);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_МассивСопоставленныхВ1С_Диадок(ИсходныеИдентификаторы)
	
	Идентификаторы = ИдентификаторыОрганизации(ИсходныеИдентификаторы);
	
	Результат = Новый Массив;
	
	ИмяСправочника 	= Перечисление_ИменаСправочников_Диадок().Организации;
	ИмяСвойства 	= Перечисление_ИменаСвойствНастроек_Диадок().СвязанныйСправочник;
	
	СвязанныеСправочники = Справочники_СвязанныеСправочники_Диадок(ИмяСправочника, Идентификаторы);
	
	Для каждого ЭлементТЗ Из СвязанныеСправочники Цикл
		
		Если ЗначениеЗаполнено(ЭлементТЗ.ОбъектИБ) Тогда
			Результат.Добавить(ЭлементТЗ.ОбъектИБ);
		КонецЕсли;
		
	КонецЦикла;
			
	Возврат Результат;
	
КонецФункции

Функция Организации_СсылкаПоИдентификатору_Диадок(Идентификаторы)

	Результат = Справочники_СсылкаПоИдентификатору_Диадок(Идентификаторы, "Организации");
	
	Возврат Результат;

КонецФункции

Функция Организации_ИдентификаторПоСсылке_Диадок(Идентификаторы)
	
	УчастникДО = Организации_УчастникДО_Диадок(Идентификаторы);
	
	Результат = УчастникДО.BoxId;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_УчастникДО_Диадок(Идентификаторы)
	
	Результат = Контракт_УчастникДокументооборота();
	
	Запрос = Новый Запрос;
	Запрос.Текст = Организации_ТекстЗапросаУчастникаЭДО_Диадок(Идентификаторы);
	
	Запрос.УстановитьПараметр("ID",		ИдентификаторВАдресЯщика(Идентификаторы.ID));
	Запрос.УстановитьПараметр("Ссылка",	Идентификаторы.Ссылка);
	Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаЗапроса);
	Иначе	
		Результат.BoxId				= Идентификаторы.ID;
		Результат.ОрганизацияЭДО	= Идентификаторы.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапросаУчастникаЭДО_Диадок(Идентификаторы)
	
	ОрганизацияСсылка = Идентификаторы.Ссылка;
	Отбор = "Диадок_ЮрФизЛица.ИмяСправочника = ""Организации""";
	ОтборПоСопоставленнойОрганизации = Ложь;
	
	Если ТипЗнч(ОрганизацияСсылка) = ТипЗнч(Организации_ПустаяСсылка_Диадок()) Тогда
		
		Отбор = Отбор + " И Диадок_ЮрФизЛица.Ссылка = &Ссылка";
		
	ИначеЕсли ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
		
		ОтборПоСопоставленнойОрганизации = Истина;
		
	Иначе
		Отбор = Отбор + " И Диадок_ЮрФизЛица.ID = &ID";
	КонецЕсли;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		Результат = Организации_ТекстЗапроса_УчастникЭДО_ДиадокРасширение(ОтборПоСопоставленнойОрганизации);
	Иначе
		Результат = Организации_ТекстЗапроса_УчастникЭДО_ДиадокСХ1(ОтборПоСопоставленнойОрганизации);
	КонецЕсли;
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапроса_УчастникЭДО_ДиадокРасширение(ОтборПоСопоставленнойОрганизации)
	
	Если ОтборПоСопоставленнойОрганизации Тогда
		Результат = Организации_ТекстЗапроса_УчастникЭДОПоСопоставленнойСвязи_ДиадокРасширение();
	Иначе
		Результат = Организации_ТекстЗапроса_УчастникЭДОПоИдентификатору_ДиадокРасширение();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапроса_УчастникЭДОПоСопоставленнойСвязи_ДиадокРасширение()
	
	Результат = 
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|			И (Диадок_ЮрФизЛица.ИмяСправочника = ""Организации"")
	|ГДЕ
	|   &Отбор
	|   И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &Ссылка";
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапроса_УчастникЭДОПоИдентификатору_ДиадокРасширение()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита = ""СвязанныйСправочник1"")
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТекстЗапроса_УчастникЭДО_ДиадокСХ1(ОтборПоСопоставленнойОрганизации)
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.ID КАК BoxId,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК ОрганизацияЭДО,
	|	Диадок_ЮрФизЛица.СвязанныйСправочник1 КАК Организация,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК FNSParticipantId,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК DepartmentId
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Если ОтборПоСопоставленнойОрганизации Тогда
		
		Результат = Результат + "
		| И (Диадок_ЮрФизЛица.СвязанныйСправочник1 = &Ссылка
		| 	ИЛИ Диадок_ЮрФизЛица.СвязанныйСправочник2 = &Ссылка
		| 	ИЛИ Диадок_ЮрФизЛица.СвязанныйСправочник3 = &Ссылка)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	Диадок_ЮрФизЛица.ID,
		|	Диадок_ЮрФизЛица.Наименование,
		|	Диадок_ЮрФизЛица.Ссылка,
		|	Диадок_ЮрФизЛица.СвязанныйСправочник1,
		|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО,
		|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
		|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
		|			И (Диадок_ЮрФизЛица.ИмяСправочника = ""Организации"")
		|ГДЕ
		|   НЕ Диадок_ЮрФизЛица.ПометкаУдаления
		|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник
		|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &Ссылка";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


Функция Организации_Записать_Диадок(Организация)
	
	ОрганизацияСсылка = Организация.Ссылка;
	
	Если ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
		ЮрЛицо = ОрганизацияСсылка.ПолучитьОбъект();
	Иначе
		ЮрЛицо = Справочники.Диадок_ЮрФизЛица.СоздатьЭлемент();
	КонецЕсли;
	
	ЮрЛицо.ИмяСправочника = "Организации";
	ЮрЛицо.ID = Организация.ID;
	ЮрЛицо.Наименование = Организация.Наименование;
	ЮрЛицо.ИНН = Организация.ИНН;
	ЮрЛицо.КПП = Организация.КПП;
	ЮрЛицо.ID_ОсновноеПодразделение = Организация.ID_ОсновноеПодразделение;
	ЮрЛицо.ИдентификаторУчастникаЭДО = Организация.ИдентификаторУчастникаЭДО;
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
	
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.AfterIndexKey,
		Организация.AfterIndexKey);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.ДатаГраницыСинхронизации,
		Организация.ДатаГраницыСинхронизации);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.ОтпечатокСертификатаНаСервере,
		Организация.ОтпечатокСертификатаНаСервере);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.OrgId,
		Организация.OrgId);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.УказыватьОтсутствиеОснованияУПД,
		Организация.УказыватьОтсутствиеОснованияУПД);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.ОтправлятьНепроведенныеДокументы,
		Организация.ОтправлятьНепроведенныеДокументы);
	ДопРеквизиты_УстановитьЗначение(
		ЮрЛицо,
		ИменаСвойствНастроек.ЗаписыватьКомментарииВДокументы1С,
		Организация.ЗаписыватьКомментарииВДокументы1С);
	ДопРеквизиты_УстановитьЗначение(
