Функция Новый_ВнешниеСтатусы(СтатусГИСМТ, СтатусКонтурЛогистика)
	
	Результат = Новый Структура;
	
	Если ЗначениеЗаполнено(СтатусГИСМТ) Тогда
		Ключ = Ядро_ИдентификаторВнешнегоДО_ГИСМТ();
		Результат.Вставить(Ключ, СтатусГИСМТ);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатусКонтурЛогистика) Тогда
		Ключ = Ядро_ИдентификаторВнешнегоДО_КонтурЛогистика();
		Результат.Вставить(Ключ, СтатусКонтурЛогистика);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

