Функция ДопРеквизиты_СписокРеквизитов(Ссылка, СписокДопРеквизитов = "") Экспорт 
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = ДопРеквизиты_СписокРеквизитов_Диадок(Ссылка, СписокДопРеквизитов);
	Иначе
		Результат = ДопРеквизиты_СписокРеквизитов_1С(Ссылка, СписокДопРеквизитов);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДопРеквизиты_Значение(Ссылка, ИмяРеквизита) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = ДопРеквизиты_Значение_Диадок(Ссылка, ИмяРеквизита);
	Иначе
		Результат = ДопРеквизиты_Значение_1С(Ссылка, ИмяРеквизита);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДопРеквизиты_УстановитьЗначение(Элемент, ИмяРеквизита, Значение, ЗначениеСтрока = "") Экспорт

	Если ИспользоватьПодсистемуДиадока() Тогда		
		ДопРеквизиты_УстановитьЗначение_Диадок(Элемент, ИмяРеквизита, Значение, ЗначениеСтрока);
	Иначе
		ДопРеквизиты_УстановитьЗначение_1С(Элемент, ИмяРеквизита, Значение);
	КонецЕсли;

