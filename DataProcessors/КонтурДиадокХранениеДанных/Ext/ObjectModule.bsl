Функция Контрагенты_ТекстСвязанныхСправочников()
	
	ТекстЗапроса =  
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыСервиса.ИНН КАК ИНН,
	|	КонтрагентыСервиса.КПП КАК КПП,
	|	СУММА(КонтрагентыСервиса.КоличествоЯщиковДД) КАК КоличествоЯщиковДД,
	|	СУММА(КонтрагентыСервиса.КоличествоЯщиковРоуминг) КАК КоличествоЯщиковРоуминг
	|ПОМЕСТИТЬ ВремДублиПоИННКПП
	|ИЗ
	|	ВТ_КонтрагентыСервиса КАК КонтрагентыСервиса
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрагентыСервиса.ИНН,
	|	КонтрагентыСервиса.КПП
	|
	|ИМЕЮЩИЕ
	|	(СУММА(КонтрагентыСервиса.КоличествоЯщиковДД) > 1
	|		ИЛИ СУММА(КонтрагентыСервиса.КоличествоЯщиковДД) = 0
	|			И СУММА(КонтрагентыСервиса.КоличествоЯщиковРоуминг) > 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты1С.Ссылка КАК КонтрагентИБ,
	|	КонтрагентыСервиса.Ссылка КАК КонтрагентСервиса_Ссылка,
	|	КонтрагентыСервиса.ID КАК КонтрагентСервиса_ID
	|ПОМЕСТИТЬ ВремСвязиКонтрагентовПоИНН
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты1С
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыСервиса КАК КонтрагентыСервиса
	|		ПО Контрагенты1С.ИНН = КонтрагентыСервиса.ИНН
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВремДублиПоИННКПП КАК Дубли
	|		ПО Контрагенты1С.ИНН = Дубли.ИНН
	|			И Контрагенты1С.КПП = Дубли.КПП
	|ГДЕ
	|	НЕ Контрагенты1С.ПометкаУдаления
	|	И НЕ КонтрагентыСервиса.Ссылка ЕСТЬ NULL
	|	И Дубли.ИНН ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СвязиКонтрагентов.КонтрагентИБ,
	|	СвязиКонтрагентов.КонтрагентСервиса_Ссылка,
	|	СвязиКонтрагентов.КонтрагентСервиса_ID
	|ПОМЕСТИТЬ ВремНовыеСвязи
	|ИЗ
	|	ВремСвязиКонтрагентовПоИНН КАК СвязиКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаСоСвязями КАК ТаблицаСоСвязями
	|		ПО СвязиКонтрагентов.КонтрагентИБ = ТаблицаСоСвязями.Контрагент1С
	|			И СвязиКонтрагентов.КонтрагентСервиса_Ссылка = ТаблицаСоСвязями.КонтрагентЭДО
	|ГДЕ
	|	ТаблицаСоСвязями.ID ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|	НастроенныеСвязиКонтрагентов.Контрагент1С КАК КонтрагентИБ,
	|	НастроенныеСвязиКонтрагентов.КонтрагентЭДО КАК КонтрагентСервиса_Ссылка,
	|	НастроенныеСвязиКонтрагентов.ID КАК КонтрагентСервиса_ID
	|ИЗ
	|	ВТ_ТаблицаСоСвязями КАК НастроенныеСвязиКонтрагентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремНовыеСвязи КАК НовыеСвязи
	|		ПО НастроенныеСвязиКонтрагентов.ID = НовыеСвязи.КонтрагентСервиса_ID
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВремНовыеСвязи.КонтрагентИБ,
	|	ВремНовыеСвязи.КонтрагентСервиса_Ссылка,
	|	ВремНовыеСвязи.КонтрагентСервиса_ID
	|ИЗ
	|	ВремНовыеСвязи КАК ВремНовыеСвязи
	|ИТОГИ ПО
	|	КонтрагентСервиса_ID";
	
	ИмяТаблицыКонтрагенты	= ТипЗначенияОбъекта("Контрагенты", "ДляЗапроса");
	Результат				= СтрЗаменить(ТекстЗапроса, "Справочник.Контрагенты", ИмяТаблицыКонтрагенты);
	
	Если Не ЕстьРеквизитКПП(ИмяТаблицыКонтрагенты) Тогда
		Результат = СтрЗаменить(Результат, "Контрагенты1С.КПП = Дубли.КПП", "ИСТИНА");
	КонецЕсли;
	
	Возврат Результат;
	
