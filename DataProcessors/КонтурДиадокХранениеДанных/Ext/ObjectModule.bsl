Функция Контрагенты_ТекстЗапросаВременнаяТаблицаКонтрагентовОрганизацииСоСтатусами_Диадок()
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	Диадок_НастройкиКонтрагентов.Контрагент КАК Ссылка,
		|	Диадок_НастройкиКонтрагентов.Значение КАК Статус,
		|	Диадок_НастройкиКонтрагентовДатаИзменения.Значение КАК ДатаИзменения
		|ПОМЕСТИТЬ ВТ_ЮрФизЛицаДиадок
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентовДатаИзменения
		|		ПО Диадок_НастройкиКонтрагентов.Контрагент = Диадок_НастройкиКонтрагентовДатаИзменения.Контрагент
		|			И Диадок_НастройкиКонтрагентов.Организация = Диадок_НастройкиКонтрагентовДатаИзменения.Организация
		|			И (Диадок_НастройкиКонтрагентовДатаИзменения.ИмяСвойства = ""ДатаИзмененияСтатуса"")
		|ГДЕ
		|	Диадок_НастройкиКонтрагентов.Организация = &Организация
		|	И Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус""
		|	И Диадок_НастройкиКонтрагентов.Значение В(&Статусы)";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция Контрагенты_ТекстЗапросаРеквизитыКонтрагентовОрганизации_Диадок()
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	Диадок_ЮрФизЛица.ID КАК ID,
		|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка,
		|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
		|	Диадок_ЮрФизЛица.ИНН КАК ИНН,
		|	Диадок_ЮрФизЛица.КПП КАК КПП,
		|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК ID_ОсновноеПодразделение,
		|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК ИдентификаторУчастникаЭДО,
		|	КонтрагентыЭДО.Статус КАК Статус,
		|	КонтрагентыЭДО.ДатаИзменения КАК ДатаИзменения,
		|	ДопРеквизитыИдентификаторы.Значение КАК OrgId,
		|	ДопРеквизитыДатаЛиквидации.Значение КАК ДатаЛиквидации
		|	//ПОЛЯ
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК КонтрагентыЭДО
		|		ПО Диадок_ЮрФизЛица.Ссылка = КонтрагентыЭДО.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК ДопРеквизитыИдентификаторы
		|		ПО Диадок_ЮрФизЛица.Ссылка = ДопРеквизитыИдентификаторы.Ссылка
		|			И (ДопРеквизитыИдентификаторы.ИмяРеквизита = ""OrgId"")
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК ДопРеквизитыДатаЛиквидации
		|		ПО Диадок_ЮрФизЛица.Ссылка = ДопРеквизитыДатаЛиквидации.Ссылка
		|			И (ДопРеквизитыДатаЛиквидации.ИмяРеквизита = ""ДатаЛиквидации"")
		|		//СОЕДИНЕНИЯ
		|ГДЕ
		|	НЕ(Диадок_ЮрФизЛица.ИНН = &ИНН
		|				И Диадок_ЮрФизЛица.КПП = &КПП)
		|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Функция -  контрагенты сервиса по ИНН из СХ1
//
// Параметры:
//  КоллекцияИНН - Массив - массив ИНН контрагентов
//	ОрганизацияЭДО - СправочникСсылка.Диадок_ЮрФизЛица - Ссылка на организацию в подсистеме Диадок
//
// Возвращаемое значение:
//  ТаблицаЗначений - содержит таблицу значений не связанных контрагентов
//	 * ID - Строка - Идентификатор контрагента в ДД
//	 * Ссылка - СправочникСсылка.Контрагенты
//	 * ИНН - Строка - ИНН контрагент
//	 * КПП - Строка - КПП контрагент
//
Функция Контрагенты_КонтрагентыСервисаПоИНН_Диадок(КоллекцияИНН, ОрганизацияЭДО) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СправочникЮрФизЛица.ID КАК ID,
		|	СправочникЮрФизЛица.Ссылка КАК Ссылка,
		|	СправочникЮрФизЛица.ИНН КАК ИНН,
		|	СправочникЮрФизЛица.КПП КАК КПП,
		|	ВЫБОР
		|		КОГДА ПОДСТРОКА(ЕСТЬNULL(СправочникЮрФизЛица.ИдентификаторУчастникаЭДО, """"), 1, 3) = ""2BM""
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК Роуминговый,
		|	Диадок_НастройкиКонтрагентов.Значение КАК Статус,
		|	ЕСТЬNULL(ДопРеквизитыДатаЛиквидации.Значение, ДАТАВРЕМЯ(1,1,1,0,0,0)) КАК ДатаЛиквидации
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица КАК СправочникЮрФизЛица
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|		ПО СправочникЮрФизЛица.Ссылка = Диадок_НастройкиКонтрагентов.Контрагент
		|			И (Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус"")
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК ДопРеквизитыДатаЛиквидации
		|		ПО СправочникЮрФизЛица.Ссылка = ДопРеквизитыДатаЛиквидации.Ссылка
		|			И (ДопРеквизитыДатаЛиквидации.ИмяРеквизита = ""ДатаЛиквидации"")
		|ГДЕ
		|	СправочникЮрФизЛица.ИмяСправочника = ""Контрагенты""
		|	И НЕ СправочникЮрФизЛица.ПометкаУдаления
		|	И СправочникЮрФизЛица.ИНН В(&МассивИНН)
		|	И Диадок_НастройкиКонтрагентов.Организация = &Организация";
	
	Запрос.Параметры.Вставить("МассивИНН", КоллекцияИНН);
	Запрос.Параметры.Вставить("Организация", ОрганизацияЭДО);
	
	ТаблицаКонтрактов = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаКонтрактов;
	
КонецФункции
//**********************************************
// СПИСКИ КОНТРАГЕНТОВ: 1С-ЭДО

Функция Контрагенты_СписокСоСтатусами_1С(ПараметрыСписка)
	
	Организация = ПараметрыСписка.Отбор.ОрганизацияЭДО;
	Статусы		= ПараметрыСписка.Отбор.Статусы;

	Статус = Контрагенты_СтатусАПИ(Статусы);	
	
	ID_Организация = СвойствоСтруктуры(Организация, "ID", "");
	
	МассивCounteragents	= Контрагенты_МассивCounteragents(Организация, Статус);
	ТаблицаКонтрактов	= Контрагенты_ТаблицаКонтрактовПоCounteragents(МассивCounteragents);
	
	НайденныйСтатус = Статусы.Найти(Перечисление_СтатусыКонтрагентов().РаботаетВДиадок);
	
	Если НайденныйСтатус <> Неопределено Тогда
		
		ТаблицаКонтрактов_Приглашение = Контрагенты_ПоискИПриглашениеДляОрганизации(Организация);
		
		Для Каждого ТекКонтрагент Из ТаблицаКонтрактов_Приглашение Цикл
			
			НоваяСтрока = ТаблицаКонтрактов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекКонтрагент);
			
		КонецЦикла;
		
	КонецЕсли;
	
	ДобавитьРеквизитыКонтрагентовИБ = ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ;
	
	Контрагенты_ДополнитьТаблицуКонтрактовДаннымиИБ_1С(ТаблицаКонтрактов, Организация, ДобавитьРеквизитыКонтрагентовИБ);
	
	Если ПараметрыСписка.Упорядочить Тогда
		ТаблицаКонтрактов.Сортировать("Наименование");
	КонецЕсли;

	Возврат ТаблицаКонтрактов;	
	
КонецФункции

Функция Контрагенты_СтатусАПИ(Статусы)
	
	Если Статусы.Найти(Перечисление_СтатусыКонтрагентов().ЗаблокировалМеня) <> Неопределено
		ИЛИ Статусы.Найти(Перечисление_СтатусыКонтрагентов().ЗаблокированМной) <> Неопределено Тогда
		
		Результат = "Rejected";
		
	ИначеЕсли Статусы.Количество() = 1 Тогда
		
		Результат = Статусы[0];
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;	
			
	Возврат Результат;
	
КонецФункции	

Процедура Контрагенты_ДополнитьТаблицуКонтрактовДаннымиИБ_1С(ТаблицаКонтрактов, ОрганизацияЭДО, ДобавитьРеквизитыКонтрагентовИБ)
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТаблицаКонтрактов.Колонки.Добавить("РеквизитыСвязанныхСправочников", Новый ОписаниеТипов("Массив"));
	КонецЕсли;
	
	Свойство_IDОсновногоПодразделения 	= Свойство_IDОсновногоПодразделения();
	Свойство_IDКонтрагента 				= Свойство_IDКонтрагента();
	
	ИдентификаторыКонтрагентовЭДО = ТаблицаКонтрактов.ВыгрузитьКолонку("ID");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Свойство_BoxId"			, Свойство_IDКонтрагента);
	Запрос.УстановитьПараметр("Свойство_IDПодразделения", Свойство_IDОсновногоПодразделения);
	Запрос.УстановитьПараметр("МассивBoxId"				, ИдентификаторыКонтрагентовЭДО);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Значение КАК ID,
	|	ЗначенияСвойствОбъектов.Объект КАК КонтрагентИБ,
	|	ЕСТЬNULL(ИдентификаторыПодразделений.Значение, """") КАК ID_ОсновноеПодразделение
	|	//ПОЛЯ
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ИдентификаторыПодразделений
	|	ПО ЗначенияСвойствОбъектов.Объект = ИдентификаторыПодразделений.Объект
	|		И (ИдентификаторыПодразделений.Свойство = &Свойство_IDПодразделения)
	|	//СОЕДИНЕНИЯ
	|	
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство = &Свойство_BoxId
	|	И ЗначенияСвойствОбъектов.Значение В(&МассивBoxId)
	|ИТОГИ ПО
	|	ID";
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса 	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		
		ДополнительныеПоляЗапроса = ",
		|	ПРЕДСТАВЛЕНИЕ(ЗначенияСвойствОбъектов.Объект) 	КАК НаименованиеКонтрагентаИБ,
		|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """") 			КАК ИННКонтрагентаИБ,
		|	ЕСТЬNULL(КонтрагентыИБ.КПП, """") 			КАК КППКонтрагентаИБ";
		
		СоединениеСТаблицейДопПолей = "
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
		|	ПО ЗначенияСвойствОбъектов.Объект = КонтрагентыИБ.Ссылка";
		
		ИмяТаблицыКонтрагенты = ТипЗначенияОбъекта("Контрагенты", "ДляЗапроса");
		СоединениеСТаблицейДопПолей = СтрЗаменить(СоединениеСТаблицейДопПолей, "Справочник.Контрагенты", ИмяТаблицыКонтрагенты);
		
		Если Не ЕстьРеквизитИНН(ИмяТаблицыКонтрагенты) Тогда
			ДополнительныеПоляЗапроса = СтрЗаменить(ДополнительныеПоляЗапроса, "ЕСТЬNULL(КонтрагентыИБ.ИНН, """")", """""");
		КонецЕсли;
		
		Если Не ЕстьРеквизитКПП(ИмяТаблицыКонтрагенты) Тогда
			ДополнительныеПоляЗапроса = СтрЗаменить(ДополнительныеПоляЗапроса, "ЕСТЬNULL(КонтрагентыИБ.КПП, """")", """""");
		КонецЕсли;
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//ПОЛЯ"		, ДополнительныеПоляЗапроса);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//СОЕДИНЕНИЯ"	, СоединениеСТаблицейДопПолей);
		
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	МаксимальныйНомерСвязи = 3;
	
	ТаблицаКонтрактов.Индексы.Добавить("ID");
	
	ВыборкаКонтрагентовЭДО = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаКонтрагентовЭДО.Следующий() Цикл
		
		СтрокаКонтракта = ТаблицаКонтрактов.Найти(ВыборкаКонтрагентовЭДО.ID, "ID");
		Если СтрокаКонтракта = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущийНомерСвязи = 1;
		
		ВыборкаДетальныхДанных = ВыборкаКонтрагентовЭДО.Выбрать();
		Пока ВыборкаДетальныхДанных.Следующий() Цикл
			
			Если Не ЗначениеЗаполнено(ВыборкаДетальныхДанных.КонтрагентИБ) Тогда
				Продолжить;
			КонецЕсли; 
			
			Если ТекущийНомерСвязи <= МаксимальныйНомерСвязи Тогда
				СтрокаКонтракта["СвязанныйСправочник" + ТекущийНомерСвязи] = ВыборкаДетальныхДанных.КонтрагентИБ;
			КонецЕсли;
			
			Если ТекущийНомерСвязи = 1 Тогда
				СтрокаКонтракта.ID_ОсновноеПодразделение = ВыборкаДетальныхДанных.ID_ОсновноеПодразделение;
			КонецЕсли;
			
			Если ДобавитьРеквизитыКонтрагентовИБ Тогда
				
				ЗначенияРеквизитовКонтрагентаИБ = Контракт_РеквизитыКонтрагентов1С();
				ЗначенияРеквизитовКонтрагентаИБ.Ссылка 			= ВыборкаДетальныхДанных.КонтрагентИБ;
				ЗначенияРеквизитовКонтрагентаИБ.Наименование 	= ВыборкаДетальныхДанных.НаименованиеКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.ИНН 			= ВыборкаДетальныхДанных.ИННКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.КПП 			= ВыборкаДетальныхДанных.КППКонтрагентаИБ;

				СтрокаКонтракта.РеквизитыСвязанныхСправочников.Добавить(ЗначенияРеквизитовКонтрагентаИБ);
				
			КонецЕсли;
			
			ТекущийНомерСвязи = ТекущийНомерСвязи + 1;
			
		КонецЦикла;	
		
	КонецЦикла;
	
КонецПроцедуры	

Функция Контрагенты_ЗаполненныеСвязиВТаблицеКонтрактов_1С(ТаблицаКонтрактов)
	
	Результат = ТаблицаКонтрактов;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Значение КАК ID,
	|	ЗначенияСвойствОбъектов.Объект КАК СвязанныйСправочник
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство = &Свойство_BoxId
	|	И ЗначенияСвойствОбъектов.Значение В(&МассивBoxId)
	|ИТОГИ ПО
	|	ID";
	
	Запрос.УстановитьПараметр("Свойство_BoxId",	Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().IDКонтрагента, Ложь));
	Запрос.УстановитьПараметр("МассивBoxId",	ТаблицаКонтрактов.ВыгрузитьКолонку("ID"));
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	ВыборкаID = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаID.Следующий() Цикл
		
		НайденнаяСтрока = Результат.Найти(ВыборкаID.ID, "ID");
		
		ВыборкаСвязей = ВыборкаID.Выбрать();
		
		Сч = 1;
		
		Пока ВыборкаСвязей.Следующий() Цикл
			
			НайденнаяСтрока["СвязанныйСправочник" + Сч] = ВыборкаСвязей.СвязанныйСправочник;
			
			Если Сч = 1 Тогда
				ID_ОсновноеПодразделение = ДопРеквизиты_Значение_1С(ВыборкаСвязей.СвязанныйСправочник, Перечисление_ИменаСвойствНастроек_1С().IDОсновноеПодразделениеКонтрагента, Ложь);
				НайденнаяСтрока.ID_ОсновноеПодразделение = ?(ID_ОсновноеПодразделение = Неопределено, "", ID_ОсновноеПодразделение);
			КонецЕсли;
			
			Сч = Сч + 1;
			
			Если Сч > 3 Тогда
				Прервать;
			КонецЕсли;	
			
		КонецЦикла;	
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции	

Функция Контрагенты_РезультатГрупповогоСопоставления_1С(Организация, СтатусКонтрагентаЭДО)
	
	Результат = Новый Структура;
	Результат.Вставить("КоличествоСопоставленных",	0);
	Результат.Вставить("МассивОшибокДублей",		Новый Массив);
	Результат.Вставить("МассивОшибокСопоставления",	Новый Массив);
	
	Если СтатусКонтрагентаЭДО <> Перечисление_СтатусыКонтрагентов().РаботаетВДиадок Тогда	
		МассивCounteragents	= Контрагенты_МассивCounteragents(Организация, СтатусКонтрагентаЭДО);
		ТаблицаКонтрактов	= Контрагенты_ТаблицаКонтрактовПоCounteragents(МассивCounteragents);
	КонецЕсли;
	
	Если СтатусКонтрагентаЭДО = Неопределено
		Или СтатусКонтрагентаЭДО = Перечисление_СтатусыКонтрагентов().РаботаетВДиадок Тогда
		
		КонтрагентыРаботающиеВДиадок = Контрагенты_ПоискИПриглашениеДляОрганизации(Организация);
		
		Если ЗначениеЗаполнено(ТаблицаКонтрактов) Тогда
			Для Каждого ДанныеКонтрагента Из КонтрагентыРаботающиеВДиадок Цикл
				НоваяСтрока = ТаблицаКонтрактов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеКонтрагента);
			КонецЦикла;
		Иначе
			ТаблицаКонтрактов = КонтрагентыРаботающиеВДиадок;
		КонецЕсли;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ТаблицаКонтрактов", ТаблицаКонтрактов);
	
	Запрос.Текст = Контрагенты_ТекстЗапросаКонтрагентовСервиса_1С(Запрос.Параметры) + ТекстЗапроса_РазделительЗапросов() +
		Контрагенты_ТекстСвязанныхСправочников();
		
	РезультатЗапросаСвязанныхКонтрагентов = Запрос.Выполнить();
	
	Запрос.Текст = Контрагенты_ТекстДублейЯщиков();
	ВыборкаДублейКонтрагентов = Запрос.Выполнить().Выбрать();
	
	РезультатСопоставления = Контрагенты_УстановленныеСвязи(РезультатЗапросаСвязанныхКонтрагентов);
	
	ЗаполнитьЗначенияСвойств(Результат, РезультатСопоставления);
	
	Результат.МассивОшибокДублей = Контрагенты_ДополнитьОшибкиСопоставления(ВыборкаДублейКонтрагентов);
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
	Возврат Результат;
	
КонецФункции	

Функция Контрагенты_ТекстЗапросаКонтрагентовСервиса_1С(Параметры)
	
	Результат = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID,
	|	ТаблицаКонтрактов.ИНН,
	|	ТаблицаКонтрактов.КПП,
	|	ТаблицаКонтрактов.ИдентификаторУчастникаЭДО
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НЕОПРЕДЕЛЕНО КАК Ссылка,
	|	ВТ_ТаблицаКонтрактов.ID КАК ID,
	|	ВТ_ТаблицаКонтрактов.ИНН КАК ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП КАК КПП,
	|	ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО КАК ИдентификаторУчастникаЭДО,
	|	ПОДСТРОКА(ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО, 1, 3) КАК КодОператораЭДО,
	|	ВЫБОР
	|		КОГДА ПОДСТРОКА(ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО, 1, 3) = ""2BM""
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоЯщиковДД,
	|	ВЫБОР
	|		КОГДА ПОДСТРОКА(ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО, 1, 3) <> ""2BM""
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоЯщиковРоуминг
	|ПОМЕСТИТЬ ВТ_КонтрагентыСервиса
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ИНН,
	|	КПП
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_КонтрагентыСервиса.ID,
	|	ВТ_КонтрагентыСервиса.ИдентификаторУчастникаЭДО,
	|	ВТ_КонтрагентыСервиса.Ссылка КАК КонтрагентЭДО,
	|	ЕСТЬNULL(ЗначенияСвойствОбъектов.Объект, НЕОПРЕДЕЛЕНО) КАК Контрагент1С
	|ПОМЕСТИТЬ ВТ_ТаблицаСоСвязями
	|ИЗ
	|	ВТ_КонтрагентыСервиса КАК ВТ_КонтрагентыСервиса
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ПО ВТ_КонтрагентыСервиса.ID = ЗначенияСвойствОбъектов.Значение
	|			И (ЗначенияСвойствОбъектов.Свойство = &Свойство_BoxId)
	|ГДЕ
	|	НЕ ЗначенияСвойствОбъектов.Значение ЕСТЬ NULL";
	
	ИмяРегистра	= Свойства_ИмяРегистраСведений();
	Результат	= СтрЗаменить(Результат, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);

	Параметры.Вставить("Свойство_BoxId", Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().IDКонтрагента, Ложь));
		
	Возврат Результат;
	
КонецФункции	

