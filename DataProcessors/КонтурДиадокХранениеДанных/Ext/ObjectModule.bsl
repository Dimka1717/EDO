// Возвращает признак наличия у объекта метаданных реквизита ИНН
//
// Параметры:
//	ИмяОбъектаМетаданных - Строка - полное имя объекта метаданных.
//									Например, Справочники.Контрагенты
//									или строка, полученная методом ТипЗначенияОбъекта("Контрагенты", "ДляЗапроса")
//
// Возвращаемое значение:
//	Результат - Булево - Истина, если реквизит есть
//
Функция ЕстьРеквизитИНН(ИмяОбъектаМетаданных)
	
	ИмяРеквизита = "ИНН";
	
	ИмяСправочника = СтрЗаменить(ИмяОбъектаМетаданных, "Справочник.", "");
	
	ОбъектМетаданных = Метаданные.Справочники[ИмяСправочника];
	
	Результат = Общее_ЕстьРеквизитОбъекта(ИмяРеквизита, ОбъектМетаданных);
	
	Возврат Результат;
	
КонецФункции

// Возвращает признак наличия у объекта метаданных реквизита КПП
