КонецФункции

Функция Организации_НастройкиСертификатовНаСервере1С_Диадок()
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка.ID КАК BoxId,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка.ИНН КАК ИНН,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка.КПП КАК КПП,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка КАК ОрганизацияДиадокСсылка,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК ОтпечатокСертификата,
	|	ЛОЖЬ КАК Облачный
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита = ""ОтпечатокСертификатаНаСервере""
	|	И Диадок_ЮрФизЛица.ИмяСправочника = ""Организации""
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ОтпечатокСертификата) Тогда
			
			СтруктураНастройки = Новый Структура("BoxId, Наименование, ИНН, КПП, ОрганизацияДиадокСсылка, ОтпечатокСертификата, Облачный");
			ЗаполнитьЗначенияСвойств(СтруктураНастройки, ВыборкаДетальныеЗаписи);
			СтруктураНастройки.ОтпечатокСертификата = ВРег(СтруктураНастройки.ОтпечатокСертификата);
			
			Результат.Добавить(СтруктураНастройки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Организации_ОбновлениеРеквизитов_Диадок(Организация, СтруктураРеквизитов)
	
	ОрганизацияЭДО = СвойствоСтруктуры(Организация, "Ссылка");
	
	ОрганизацияОбъект = ОрганизацияЭДО.ПолучитьОбъект();
	ОрганизацияОбъект.Заблокировать();
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_Диадок();
	
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		Справочники_ЮрФизЛицоОбъект_ОчиститьСвязанныеСправочники(ОрганизацияОбъект);
		
		СвязанныеСправочники = СтруктураРеквизитов.СвязанныеСправочники;
		Справочники_ЮрФизЛицоОбъект_ЗаполнитьСвязанныеСправочники(ОрганизацияОбъект, СвязанныеСправочники);
		
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("AfterIndexKey") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.AfterIndexKey,
			СтруктураРеквизитов.AfterIndexKey);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ДатаГраницыСинхронизации") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ДатаГраницыСинхронизации,
			СтруктураРеквизитов.ДатаГраницыСинхронизации);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ID_ОсновноеПодразделение") Тогда
		ОрганизацияОбъект.ID_ОсновноеПодразделение = СтруктураРеквизитов.ID_ОсновноеПодразделение;
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ОтпечатокСертификатаНаСервере") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ОтпечатокСертификатаНаСервере,
			СтруктураРеквизитов.ОтпечатокСертификатаНаСервере);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ОсновнойПакет") Тогда
		ДопРеквизиты_ЗаписатьОсновнойПакет_Диадок(
			ОрганизацияОбъект.Ссылка,
			СтруктураРеквизитов.ОсновнойПакет);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ШифроватьДокументы") Тогда
		ДопРеквизиты_ЗаписатьШифрованиеДокумента_Диадок(
			ОрганизацияОбъект.Ссылка,
			Неопределено,
			СтруктураРеквизитов.ШифроватьДокументы);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("УказыватьОтсутствиеОснованияУПД") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.УказыватьОтсутствиеОснованияУПД,
			СтруктураРеквизитов.УказыватьОтсутствиеОснованияУПД);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ОтправлятьНепроведенныеДокументы") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ОтправлятьНепроведенныеДокументы,
			СтруктураРеквизитов.ОтправлятьНепроведенныеДокументы);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ЗаписыватьКомментарииВДокументы1С") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ЗаписыватьКомментарииВДокументы1С,
			СтруктураРеквизитов.ЗаписыватьКомментарииВДокументы1С);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТекстКомментарияОтправка") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ТекстКомментарияОтправка,
			СтруктураРеквизитов.ТекстКомментарияОтправка);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ТекстКомментарияПолучение") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ТекстКомментарияПолучение,
			СтруктураРеквизитов.ТекстКомментарияПолучение);
	КонецЕсли;
	
	Если СтруктураРеквизитов.Свойство("ДатаСинхронизацииСтатусовКонтрагентов") Тогда
		ДопРеквизиты_УстановитьЗначение(
			ОрганизацияОбъект,
			ИменаСвойствНастроек.ДатаСинхронизацииСтатусовКонтрагентов,
			СтруктураРеквизитов.ДатаСинхронизацииСтатусовКонтрагентов);
	КонецЕсли;
	
	ОрганизацияОбъект.Записать();
	
КонецПроцедуры

Функция Организации_ТаблицаСопоставленныхОрганизаций_Диадок()
	
	Запрос = Новый Запрос;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса = Организации_ТексЗапроса_СопоставленныеОрганизации_ДиадокРасширение();
		Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	Иначе
		ТекстЗапроса = Организации_ТексЗапроса_СопоставленныеОрганизации_ДиадокСХ1();
	КонецЕсли;
	
	ИмяТаблицыОрганизации = ТипЗначенияОбъекта("Организации", "ДляЗапроса");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Справочник.Организации", ИмяТаблицыОрганизации);
	
	Запрос.Текст = ТекстЗапроса;
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТексЗапроса_СопоставленныеОрганизации_ДиадокРасширение()
	
	Результат = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Диадок_ЮрФизЛица.ID КАК BoxID,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка.ИмяСправочника = ""Организации""
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение <> НЕОПРЕДЕЛЕНО
	|	И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)";
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ТексЗапроса_СопоставленныеОрганизации_ДиадокСХ1()
	
	Результат =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Диадок_ЮрФизЛица.ID КАК BoxID,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
