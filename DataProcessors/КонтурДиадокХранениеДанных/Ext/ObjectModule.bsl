Процедура Документы_ОбновитьКомментарийДокумента1С(Документ1С, ДобавляемыйКомментарий) Экспорт
	
	Если Документ1С = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	//проверка на "Общие реквизиты"
	Документ1СКомментарий = Неопределено;
	Попытка 
		Документ1СКомментарий = Документ1С.Комментарий;
	Исключение
	КонецПопытки;
	
	Если Документ1СКомментарий = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоОбъект	= ЭтоОбъект(Документ1С);
	ДокОбъект	= ?(ЭтоОбъект, Документ1С, Документ1С.ПолучитьОбъект());
	
	ТекущийКомментарий = ДокОбъект.Комментарий;
	
	Если ЗначениеЗаполнено(ТекущийКомментарий) Тогда
		
		Если Найти(ТекущийКомментарий, ДобавляемыйКомментарий) > 0 Тогда
			Возврат;
		КонецЕсли;
	
		НачалоКомментария = ТекущийКомментарий + " ";
	Иначе
		НачалоКомментария = "";
	КонецЕсли;
	
	ДокОбъект.Комментарий = НачалоКомментария + ДобавляемыйКомментарий;
	
	ДокОбъект.ОбменДанными.Загрузка = Истина;

	Попытка
		
		ДокОбъект.Заблокировать();
		ДокОбъект.Записать();
		
	Исключение
		
		ВидОперации		= "Обновление комментария в документе 1С";
		ТекстОшибки		= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ДопИнформация	= Общее_ПодставитьПараметрыВСтроку("Документ: %1", Документ1С);
		
		ТекстСообщения	= "Не удалось обновить комментарий в документе %1";
		ТекстСообщения	= Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, Документ1С);
		
		Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
		
	КонецПопытки;
	
КонецПроцедуры

