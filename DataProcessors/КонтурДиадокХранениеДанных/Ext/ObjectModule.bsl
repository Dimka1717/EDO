Функция ОшибкиДоступаКПодсистемеХранения() Экспорт
	
	Результат = Новый СписокЗначений;
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = ОшибкиДоступаКПодсистемеХранения_Диадок();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет структуру конфигурации на наличие метаданных,
// необходимых для функционирования модуля на объектах Диадока.
//
// Возвращаемое значение: Булево
//
Функция УстановленаПодсистемаДиадока() Экспорт
	
	Результат = Истина;
	
	НеобходимыеМетаданные = Новый Массив;
	
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_ДополнительныеСправочники");
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_ЮрФизЛица");
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_Документы");
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_ПакетыДокументов");
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_ХранениеДанных");
	НеобходимыеМетаданные.Добавить("Справочники.Диадок_Файлы");
	НеобходимыеМетаданные.Добавить("РегистрыСведений.Диадок_НастройкиКонтрагентов");
	НеобходимыеМетаданные.Добавить("РегистрыСведений.Диадок_СтатусыДокументов");
	
	Для Каждого Элемент Из НеобходимыеМетаданные Цикл
		
		Результат = Результат И ПроверитьНаличиеОбъектаМетаданных(Элемент);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Проверяет структуру конфигурации на наличие метаданных,
// необходимых для функционирования модуля на стандартных объектах.
//
// Возвращаемое значение: Булево
//
Функция УстановленРегистрДопСведений() Экспорт
	
	ИмяРегистраСведений = Свойства_ИмяРегистраСведений();
	
	Результат = Ложь;

	Если ЗначениеЗаполнено(ИмяРегистраСведений) Тогда
					
		Результат = Истина;
		
		ЕстьСправочник = ПроверитьНаличиеОбъектаМетаданных("Справочники.Валюты");
		Если Не ЕстьСправочник Тогда
			ЕстьСправочник = ПроверитьНаличиеОбъектаМетаданных("Справочники.ПрофилиГруппДоступа");
		КонецЕсли;
		
		НеобходимыеМетаданные = Новый Массив;
		
		//*НеобходимыеМетаданные.Добавить("Справочники.Валюты");
		НеобходимыеМетаданные.Добавить("РегистрыСведений." + ИмяРегистраСведений);
		НеобходимыеМетаданные.Добавить("РегистрыСведений." + ИмяРегистраСведений + ".Измерения.Объект");
		
		ЕстьРегистр = Истина;
		
		Для Каждого Элемент Из НеобходимыеМетаданные Цикл
			
			ЕстьРегистр = ЕстьРегистр И ПроверитьНаличиеОбъектаМетаданных(Элемент);
			//*Результат = Результат И ПроверитьНаличиеОбъектаМетаданных(Элемент);
			
		КонецЦикла;
		
		Результат = ЕстьСправочник И ЕстьРегистр;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОшибкиДоступаКПодсистемеХранения_Диадок()
	
	Результат = Новый СписокЗначений;
	
	ПроверитьДоступностьОбъектаМетаданных(Результат, "Справочники.Диадок_ДополнительныеСправочники");
	ПроверитьДоступностьОбъектаМетаданных(Результат, "Справочники.Диадок_ЮрФизЛица");
	ПроверитьДоступностьОбъектаМетаданных(Результат, "РегистрыСведений.Диадок_НастройкиКонтрагентов");
	
	Возврат Результат;
	
КонецФункции

