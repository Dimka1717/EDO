Процедура ДопСправочники_ЗаписатьТипыДокументовАПИ_Диадок(ТипыДокументовAPI)
	
	Для Каждого ТипДокументаAPI Из ТипыДокументовAPI Цикл
		
		ID		= ТипДокументаAPI.Значение.Name;
		Ссылка	= ДопСправочники_СсылкаПоИдентификатору_Диадок("ТипыДокументовAPI", ID);
		
		Если ЗначениеЗаполнено(Ссылка) Тогда
			ТекОбъект = Ссылка.ПолучитьОбъект();
			ТекОбъект.ДополнительныеРеквизиты.Очистить();
		Иначе
			ТекОбъект = ДопСправочники_СоздатьЭлемент_Диадок("ТипыДокументовAPI", ТипДокументаAPI.Значение.Title);
		КонецЕсли;
		
		ДопРеквизиты_УстановитьЗначение_Диадок(ТекОбъект, "ID",					ТипДокументаAPI.Значение.Name,	ТипДокументаAPI.Значение.Title);
		ДопРеквизиты_УстановитьЗначение_Диадок(ТекОбъект, "ХранилищеОписания",	Новый ХранилищеЗначения(ТипДокументаAPI.Значение), "");
		
		ТекОбъект.Записать();
		
	КонецЦикла;
	
КонецПроцедуры	
	
