Функция Пакеты_ДанныеПакета_Диадок(Идентификаторы)
	
	Результат = Контракт_Пакет();
	
	ПакетЭДО	= СвойствоСтруктуры(Идентификаторы, "ПакетЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",	"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",	"");
	
	Если ЗначениеЗаполнено(ПакетЭДО) Тогда
		Отбор = "ПакетыДокументов.Ссылка = &Пакет";
	Иначе
		Отбор = "ПакетыДокументов.BoxId = &BoxId И ПакетыДокументов.LetterId = &LetterId";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Пакеты_ТекстЗапросаДляЗаполненияКонтракта_Диадок(Отбор);
	
	Запрос.УстановитьПараметр("Пакет",		ПакетЭДО);
	Запрос.УстановитьПараметр("BoxID",		BoxID);
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		
		Результат				= Пакеты_КонтрактПоВыборкеДанных_Диадок(Выборка);
		Результат.Документы		= Пакеты_МассивКонтрактовДокументовПакета_Диадок(Идентификаторы);
		
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ДокументыПакета_Диадок(Идентификаторы)

	ПакетЭДО	= СвойствоСтруктуры(Идентификаторы, "ПакетЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",	"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",	"");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Диадок_Документы.Ссылка КАК ДокументЭДО,
	|	Диадок_Документы.BoxId КАК BoxId,
	|	Диадок_Документы.LetterId КАК LetterId,
	|	Диадок_Документы.DocumentId КАК DocumentId
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|ГДЕ "
	+ ?(ЗначениеЗаполнено(ПакетЭДО), "
	|	Диадок_Документы.Пакет = &Пакет", "
	|	Диадок_Документы.BoxId = &BoxId
	|	И Диадок_Документы.Пакет.LetterId = &LetterId") + " 
	|	И НЕ Диадок_Документы.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("Пакет", 		ПакетЭДО);
	Запрос.УстановитьПараметр("BoxId", 		BoxId);
	Запрос.УстановитьПараметр("LetterId", 	LetterId);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Результат = ТаблицаЗначенийВМассивСтруктур(РезультатЗапроса);
	
	Возврат Результат;

КонецФункции

Функция Пакеты_Записать_Диадок(Пакет)
	
	Результат = Неопределено;
	
	РеквизитыПакета			= Пакет.Реквизиты;
	Идентификаторы			= Пакет.Идентификаторы;
	Отправитель				= Пакет.Отправитель;
	Получатель				= Пакет.Получатель;
	ДополнительныеРеквизиты	= Пакет.ДопРеквизиты;
	ПараметрыШаблона		= Пакет.ПараметрыШаблона;
	ВидПакета				= ДопСправочники_СсылкаПоИдентификатору_Диадок("ВидыПакетов", Пакет.ИдентификаторВида);
	
	НачатьТранзакцию();
	
	Попытка
		
		Если Идентификаторы.ПакетЭДО = Неопределено Тогда
			ОбъектПакета = Справочники.Диадок_ПакетыДокументов.СоздатьЭлемент();
		Иначе	
			ОбъектПакета = Идентификаторы.ПакетЭДО.ПолучитьОбъект();
		КонецЕсли;
		
		Пакеты_ПредОбработкаПодготовленного_Диадок(Пакет);
		
		Направление = Пакет.Направление;
		
		ОбъектПакета.Направление			= Направление;
		ОбъектПакета.Документ				= Пакет.ДокументУчета;
		ОбъектПакета.ДатаЗагрузки			= Пакет.ДатаЭДО;
		ОбъектПакета.Метка					= Пакет.Состояние;
		ОбъектПакета.ЗаблокированныйПакет	= Пакет.Заблокирован;
		ОбъектПакета.ВидПакета				= ВидПакета;
		
		ОбъектПакета.НомерДокумента			= РеквизитыПакета.Номер;
		ОбъектПакета.ДатаДокумента			= РеквизитыПакета.Дата;
		ОбъектПакета.СуммаДокумента			= РеквизитыПакета.Сумма;
		
		ОбъектПакета.BoxId					= АдресЯщикаВИдентификатор(Идентификаторы.BoxId);
		ОбъектПакета.LetterId				= Идентификаторы.LetterId;
		
		ЭтоИсходящийПакет = (Направление = Перечисление_Направления().Исходящее);
		
		ОбъектПакета.ОрганизацияДиадок		= ?(ЭтоИсходящийПакет, Отправитель.ОрганизацияЭДО, 	Получатель.ОрганизацияЭДО);
		ОбъектПакета.Организация			= ?(ЭтоИсходящийПакет, Отправитель.Организация, 	Получатель.Организация);
		ОбъектПакета.КонтрагентДиадок		= ?(ЭтоИсходящийПакет, Получатель.ОрганизацияЭДО, 	Отправитель.ОрганизацияЭДО);
		ОбъектПакета.Контрагент				= ?(ЭтоИсходящийПакет, Получатель.Организация, 		Отправитель.Организация);
		
		ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "FromDepartmentId",	Отправитель.DepartmentId);
		ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ToDepartmentId",		Получатель.DepartmentId);
		
		Если Направление = Перечисление_Направления().Исходящее Тогда
			ОбъектПакета.ТекстОшибки = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ОшибкиОтправки");
		КонецЕсли;
		
		ЗашифрованныйПакет = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ЗашифрованныйПакет");
		ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ЗашифрованныйПакет", ЗашифрованныйПакет);
		
		ПакетОтправлен = ЗначениеЗаполнено(Идентификаторы.LetterId);
		Если НЕ ПакетОтправлен Тогда
			ПромежуточныйПолучатель = СвойствоСтруктуры(Пакет.СлужебнаяИнформация.ПараметрыОтправки, "ПромежуточныйПолучатель");
			ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ProxyBoxId", 		ПромежуточныйПолучатель.BoxId);
			ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ProxyDepartmentId", 	ПромежуточныйПолучатель.DepartmentId);
		КонецЕсли;
		
		ПараметрыПереотправки = СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ПараметрыПереотправки");
		ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ПараметрыПереотправки", ПараметрыПереотправки);
		
		Для Каждого ТекРеквизит Из ДополнительныеРеквизиты Цикл
			ДопРеквизиты_УстановитьЗначение(ОбъектПакета, ТекРеквизит.Ключ, ТекРеквизит.Значение);
		КонецЦикла;
		
		Если Пакет.Шаблон Тогда
			
			ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "Шаблон", Истина);
			
			Для Каждого Элемент Из ПараметрыШаблона Цикл
				ДопРеквизиты_УстановитьЗначение(ОбъектПакета, Элемент.Ключ, Элемент.Значение);
			КонецЦикла;
			
		КонецЕсли;
		
		ОбъектПакета.Записать();
		
		Для Каждого Документ Из Пакет.Документы Цикл
			
			Документ.Идентификаторы.ПакетЭДО = ОбъектПакета.Ссылка;
			СохраненныйДокумент = Документы_Записать_Диадок(Документ);
			Документ.Идентификаторы.ДокументЭДО	= СохраненныйДокумент;
			
		КонецЦикла;
		
		Пакеты_ЗаписатьСвязанныеПакеты_Диадок(Пакет, ОбъектПакета);
		
		Результат = ОбъектПакета.Ссылка;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		_Ошибка = ОписаниеОшибки();
		
		ИнформацияОбОшибке 	= ИнформацияОбОшибке();
		
		ВидОперации			= "Диадок.Запись пакета";
		ТекстОшибки			= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ДопИнформация		= ДополнительнаяИнформацияОПакете(РеквизитыПакета, Идентификаторы);
		ТекстСообщения 		= "Не удалось записать пакет.";

		Ядро.Ошибка_Обработать(	ВидОперации, 
								ТекстОшибки, 
								ДопИнформация, 
								ТекстСообщения);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции 

// Создает новый элемент справочника Диадок_ПакетыДокументов для связанного пакета.
//
// Параметры:
//  Пакет					 - Структура - заполненный связанный пакет
//  ОбъектОсновногоПакета	 - ДиадокОбъект.Диадок_ПакетыДокументов - заполненный объект основного пакета
//
Процедура Пакеты_ЗаписатьСвязанныеПакеты_Диадок(Пакет, ОбъектОсновногоПакета)
	
	Перем ПараметрыОтправки, СвязанныеПакеты;
	
	Если НЕ ЗначениеЗаполнено(Пакет.Идентификаторы.ПакетЭДО) Тогда
		
		Если Пакет.СлужебнаяИнформация.Свойство("ПараметрыОтправки", ПараметрыОтправки)
			И ПараметрыОтправки.Свойство("СвязанныеПакеты", СвязанныеПакеты) Тогда
			
			Для Каждого ОписаниеСвязанногоПакета Из СвязанныеПакеты Цикл
				
				ВидПакета = ДопСправочники_СсылкаПоИдентификатору_Диадок("ВидыПакетов", ОписаниеСвязанногоПакета.ИдентификаторВида);
				
				ОбъектПакета = Справочники.Диадок_ПакетыДокументов.СоздатьЭлемент();
				
				ОбъектПакета.ВидПакета = ВидПакета;
				ОбъектПакета.Документ = ОписаниеСвязанногоПакета.ДокументУчета;
				
				РеквизитыДляЗаполнения = "Направление, Метка, ОрганизацияДиадок, Организация, КонтрагентДиадок, Контрагент";
				ЗаполнитьЗначенияСвойств(ОбъектПакета, ОбъектОсновногоПакета, РеквизитыДляЗаполнения);
				
				ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ОсновнойСвязанныйПакет", ОбъектОсновногоПакета.Ссылка);
				
				ОбъектПакета.Записать();
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ДополнительнаяИнформацияОПакете(РеквизитыПакета, Идентификаторы)
	Результат = Новый Массив;
	
	СтруктураПолей = Новый Структура;
	СтруктураПолей.Вставить("Номер", 	РеквизитыПакета.Номер);
	СтруктураПолей.Вставить("Дата", 	РеквизитыПакета.Дата);
	СтруктураПолей.Вставить("BoxId", 	Идентификаторы.BoxId);
	СтруктураПолей.Вставить("LetterId", Идентификаторы.LetterId);
	
	Для Каждого ПолеИнформации Из СтруктураПолей Цикл
		ЗначениеПоля = ПолеИнформации.Значение;
		Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
			Результат.Добавить(ПолеИнформации.Ключ + ": " + ЗначениеПоля);
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Результат;
КонецФункции


Функция Пакеты_ТекстЗапросаДляЗаполненияКонтракта_Диадок(Отбор = "Истина")
	
	ТекстЗапроса_РазделительЗапросов = ТекстЗапроса_РазделительЗапросов();
	
	ТекстЗапросаВсеПодразделения = Пакеты_ТекстЗапросаВсеПодразделения_Диадок();
	ТекстЗапросаВидыПакетов = Пакеты_ТекстЗапросаВидыПакетов_Диадок();
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		
		ТекстЗапросаОсновной = Пакеты_ТекстЗапросаОсновной_ДиадокРасширение();
		
	Иначе
		
		ТекстЗапросаОсновной = Пакеты_ТекстЗапросаОсновной_ДиадокСХ1();
		
	КонецЕсли;
	
	ЧастиТекстаЗапроса = Новый Массив;
	
	ЧастиТекстаЗапроса.Добавить(ТекстЗапросаВсеПодразделения);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапросаВидыПакетов);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапросаОсновной);
	
	Результат = СоединитьСтроку(ЧастиТекстаЗапроса, ТекстЗапроса_РазделительЗапросов);
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ТекстЗапросаВсеПодразделения_Диадок()
	
