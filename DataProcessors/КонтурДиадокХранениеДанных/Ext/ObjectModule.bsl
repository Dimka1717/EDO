Процедура ВнешнееХранение_ВыполнитьОчисткуУстаревшихДокументов() Экспорт
	
	ОбщиеНастройки = Настройки_ОбщиеНастройки();
	
	Если ОбщиеНастройки.УдалятьСодержимоеУстаревшихДокументов <> Истина
		ИЛИ ОбщиеНастройки.СрокОчисткиДокументов <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	КолСекундВСутках = 60 * 60 * 24;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаЗагрузки", ТекущаяДата() - ОбщиеНастройки.СрокОчисткиДокументов * КолСекундВСутках);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_ПакетыДокументов.Код КАК Код
	|ИЗ
	|	Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
	|ГДЕ
	|	Диадок_ПакетыДокументов.ДатаЗагрузки < &ДатаЗагрузки
	|	И Диадок_ПакетыДокументов.Метка <> ""Подготовлен""";
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		
		Каталог	= ВнешнееХранение_КаталогПакета(Выборка.Код);
		
		Файл = Новый Файл(Каталог);
		
		Если Файл.Существует() Тогда
			
			Попытка
				УдалитьФайлы(Каталог);
			Исключение
				
				ВидОперации		 = "Очистка устаревших документов";
				ТекстСообщения	 = "Не удалось удалить каталог %1 пакета %2";
				ТекстСообщения	 = Общее_ПодставитьПараметрыВСтроку(ТекстСообщения, Каталог, Выборка.Код);
				ТекстОшибки		 = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ДопИнформация	 = Новый Массив;
				ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Пакет: %1", Выборка.Код));
				ДопИнформация.Добавить(Общее_ПодставитьПараметрыВСтроку("Каталог: %1", Каталог));
				
				Ошибка_Обработать(ВидОперации, ТекстОшибки, ДопИнформация, ТекстСообщения);
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ВнешнееХранение_ИмяФайлаНаДиске(КодПакета, КодДокумента, ИмяХранилища, ЭтоЗашифрованныеДанные = Ложь, ЭтоПодпись = Неопределено)
	
	Результат = Новый Структура("Каталог, ИмяФайла");
	
	МассивЧастейПути = Новый Массив;
	
	МассивЧастейПути.Добавить(Настройки_ОбщиеНастройки().КорневойКаталогДокументов);
	МассивЧастейПути.Добавить(ВнешнееХранение_ПрефиксКаталогаПакета() + КодПакета);
	МассивЧастейПути.Добавить(ВнешнееХранение_ПрефиксКаталогаДокумента() + КодДокумента);
	
	Результат.Каталог = СоединитьСтроку(МассивЧастейПути, "\");
	
	МассивЧастейПути.Добавить(ИмяХранилища
							 + ?(ЭтоЗашифрованныеДанные, ".enc", "")
							 + ?(ЭтоПодпись <> Неопределено, ".sgn", "")
							 );
	
	Результат.ИмяФайла = СоединитьСтроку(МассивЧастейПути, "\");
	
	Возврат Результат;
	
КонецФункции

