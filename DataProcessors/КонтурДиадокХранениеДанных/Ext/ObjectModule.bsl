//  Булево - Истина - используется регистр ЗначенияСвойствОбъектов, Ложь - нет
//
Функция Настройки_ИспользуетсяРегистрСведенийЗначенияСвойствОбъектов()
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	ИмяРегистраСведений	= "ЗначенияСвойствОбъектов";
	ТипИзмерения		= Метаданные.РегистрыСведений[ИмяРегистраСведений].Измерения.Свойство.Тип.Типы()[0];
	
	ИмяПланаВидовХарактеристик = Метаданные.НайтиПоТипу(ТипИзмерения).Имя;
	
	СвойствоЯщикДиадокДляОрганизации = ПланыВидовХарактеристик[ИмяПланаВидовХарактеристик].НайтиПоНаименованию(
		ИменаСвойствНастроек.IDОрганизации, Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Объект
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов
	|ГДЕ
	|	Свойство = &Свойство"
	);
	Запрос.УстановитьПараметр("Свойство", СвойствоЯщикДиадокДляОрганизации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Результат = НЕ РезультатЗапроса.Пустой();
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_1С(ИдентификаторыВидовДокументов)
	
	Результат = "";
	
	Результат = ТекстЗапроса_ВременнаяТаблицаСвойствИспользуемыхДляХраненияНастроекПечатныхФорм_1С(ИдентификаторыВидовДокументов);
		
	Результат = Результат + ТекстЗапроса_РазделительЗапросов() +
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремСвойства.ИмяСвойства 		КАК ИмяСвойства,
	|	ВремСвойства.Ссылка 			КАК Свойство,
	|	ВремСвойства.ИдВидаДокумента 	КАК ИдВидаДокумента,
	|	ДополнительныеСведения.Значение КАК Значение
	|ПОМЕСТИТЬ ВремНастройкиПФКонтрагента
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ДополнительныеСведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремСвойстваПФ КАК ВремСвойства
	|		ПО ДополнительныеСведения.Свойство = ВремСвойства.Ссылка
	|ГДЕ
	|	ДополнительныеСведения.Объект = &Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиПФКонтрагента.ИмяСвойства 		КАК ИмяСвойства,
	|	НастройкиПФКонтрагента.ИдВидаДокумента	КАК ИдВидаДокумента,
	|	НастройкиПФКонтрагента.Значение 		КАК Значение
	|ИЗ
	|	ВремНастройкиПФКонтрагента КАК НастройкиПФКонтрагента
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВремСвойства.ИмяСвойства,
	|	ВремСвойства.ИдВидаДокумента,
	|	ДополнительныеСведения.Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ДополнительныеСведения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремСвойстваПФ КАК ВремСвойства
	|		ПО ДополнительныеСведения.Свойство = ВремСвойства.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ КОЛИЧЕСТВО(Свойство) КАК Количество ИЗ ВремНастройкиПФКонтрагента) КАК ВремКоличествоНастроекКонтрагента
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ДополнительныеСведения.Объект = &Организация
	|	И ЕСТЬNULL(ВремКоличествоНастроекКонтрагента.Количество, 0) = 0
	|
	|ИТОГИ ПО
	|	ИдВидаДокумента";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Результат);

	Возврат Результат;
	
КонецФункции

// Переопределяет имена свойств пакета задействованных в подсистеме хранения 1С 
//
// Параметры:
//	Пакет - Структура - контракт документа (см. Ядро.Контракт_Пакет())
//
// Возвращаемое значение:
//	Структура - с ключами:	"ДокументУчетаПакета"
Функция Пакеты_ПереопределяемыеИменаСвойств1С(Пакет)
	
	ИменаСвойствНастроек_1С = Перечисление_ИменаСвойствНастроек_1С();
	
	Результат = Новый Структура;
	Результат.Вставить("ДокументУчетаПакета", ИменаСвойствНастроек_1С.ДокументУчетаПакета);
	
	ИспользуютсяНастройкиПоУмолчаниюДляСчетов = Ядро.Настройки_ОснованияВидовДокументов_ИспользуютсяНастройкиПоУмолчанию();
	ЭтоИдентификаторВидаСчет = Ядро.ЭтоИдентификаторВидаСчет(Пакет.ИдентификаторВида);
	
	Если НЕ ИспользуютсяНастройкиПоУмолчаниюДляСчетов И ЭтоИдентификаторВидаСчет Тогда
		
		ЭтоДокументКонфигурацииСчетНаОплату = Ядро.Общее_ЭтоДокументКонфигурацииСчетНаОплату(Пакет.ДокументУчета);
		Если НЕ ЭтоДокументКонфигурацииСчетНаОплату Тогда
			
			Результат.ДокументУчетаПакета = ИменаСвойствНастроек_1С.ДокументУчетаПакетаСчет;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
	
