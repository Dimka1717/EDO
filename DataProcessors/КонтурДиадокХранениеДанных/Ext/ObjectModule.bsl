Функция ДопСправочники_ПустаяСсылка_1С(ИмяСправочника)
	
	Результат = Неопределено;
	
	Если ИмяСправочника = "ВидыПакетов" Тогда
		
		Результат = "";
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Процедура ДопСправочники_ЗаписатьТипыДокументовАПИ_1С(ТипыДокументовAPI)
	
	ТаблицаТиповДокументовAPI = Новый ТаблицаЗначений;
	ТаблицаТиповДокументовAPI.Колонки.Добавить("Наименование");
	ТаблицаТиповДокументовAPI.Колонки.Добавить("ID");
	ТаблицаТиповДокументовAPI.Колонки.Добавить("ХранилищеОписания");
	
	Для Каждого ТипДокументаAPI Из ТипыДокументовAPI Цикл
		
		НоваяСтрока = ТаблицаТиповДокументовAPI.Добавить();
		
		НоваяСтрока.Наименование		= ТипДокументаAPI.Значение.Title;
		НоваяСтрока.ID					= ТипДокументаAPI.Значение.Name;
		НоваяСтрока.ХранилищеОписания	= ТипДокументаAPI.Значение;
		
	КонецЦикла;
	
	Кэш_Поместить("ТаблицаТиповДокументовAPI", ТаблицаТиповДокументовAPI);
	
КонецПроцедуры

Функция ДопСправочники_ВидыГруппировкиПолученных_1С()
	
	Результат = Новый ТаблицаЗначений;
	КолонкиТаблицы = "Наименование, ТипыДокументов, Ссылка";
	ДобавитьКолонкиВТаблицуЗначений(Результат, КолонкиТаблицы);
	
	ДопСправочники_ЗаполнитьВидыГруппировкиПолученных(Результат);
	
	Результат.Колонки.Добавить("ID");
	МассивНаименований = Результат.ВыгрузитьКолонку("Наименование");
	Результат.ЗагрузитьКолонку(МассивНаименований, "ID");
			
	Возврат Результат;
	
КонецФункции

