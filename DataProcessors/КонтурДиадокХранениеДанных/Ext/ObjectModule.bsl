Функция Документы_МассивДокументов_Диадок(ДокументыЭДО)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументыЭДО", ДокументыЭДО);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_Документы.Ссылка КАК Ссылка,
	|	Диадок_Документы.Пакет,
	|	Диадок_Документы.Пакет.ЗаблокированныйПакет КАК ЗаблокированныйПакет
	|ПОМЕСТИТЬ ВТ_ВыбранныеДокументы
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|ГДЕ
	|	Диадок_Документы.Ссылка В(&ДокументыЭДО)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Диадок_Документы.Ссылка
	|ПОМЕСТИТЬ ВТ_ДополненнаяТаблица
	|ИЗ
	|	ВТ_ВыбранныеДокументы КАК ВТ_ВыбранныеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_Документы КАК Диадок_Документы
	|		ПО ВТ_ВыбранныеДокументы.Пакет = Диадок_Документы.Пакет
	|			И (ВТ_ВыбранныеДокументы.ЗаблокированныйПакет)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_ВыбранныеДокументы.Ссылка
	|ИЗ
	|	ВТ_ВыбранныеДокументы КАК ВТ_ВыбранныеДокументы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДополненнаяТаблица.Ссылка
	|ИЗ
	|	ВТ_ДополненнаяТаблица КАК ВТ_ДополненнаяТаблица
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ДополненнаяТаблица.Ссылка";
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		ИдентификаторыДокумента = Новый Структура;
		ИдентификаторыДокумента.Вставить("ДокументЭДО", ВыборкаЗапроса.Ссылка);
		
		Документ = Документы_ДанныеДокумента_Диадок(ИдентификаторыДокумента);
		
		Результат.Добавить(Документ);
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

