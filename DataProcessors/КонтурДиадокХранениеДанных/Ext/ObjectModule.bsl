Функция Справочники_СвязанныйСправочник_Диадок(ИмяСправочника, Идентификаторы)
	
	Результат = Неопределено;

	Если ЗначениеЗаполнено(Идентификаторы.Ссылка) Тогда
		Отбор = "Диадок_ЮрФизЛица.Ссылка = &Ссылка";
	Иначе
		Отбор = "Диадок_ЮрФизЛица.ИмяСправочника = """ + ИмяСправочника + """ И Диадок_ЮрФизЛица.ID = &ID";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		Запрос.Текст = Справочники_ТекстЗапроса_ОсновныеСвязи_ДиадокРасширение();
	Иначе
		Запрос.Текст = Справочники_ТекстЗапроса_ОсновныеСвязи_ДиадокСХ1();
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Отбор", Отбор);
	
	Запрос.УстановитьПараметр("ID",		Идентификаторы.ID);
	Запрос.УстановитьПараметр("Ссылка",	Идентификаторы.Ссылка);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.СвязанныйСправочник;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_ОсновныеСвязи_ДиадокРасширение()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК СвязанныйСправочник
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО Диадок_ЮрФизЛица.Ссылка = Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита = ""СвязанныйСправочник1"")
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_ОсновныеСвязи_ДиадокСХ1()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.СвязанныйСправочник1 КАК СвязанныйСправочник
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_СвязанныеСправочники_Диадок(ИмяСправочника, Идентификаторы)
	
	Если ЗначениеЗаполнено(Идентификаторы.Ссылка) Тогда
		Отбор = "Диадок_ЮрФизЛица.Ссылка = &Ссылка";
	Иначе
		Отбор = "Диадок_ЮрФизЛица.ИмяСправочника = """ + ИмяСправочника + """ И Диадок_ЮрФизЛица.ID = &ID";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ЮрФизЛицаДиадок
	|ИЗ        
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|" + Справочники_ТекстЗапросаВременнойТаблицыСвязиОбъектов_Диадок(ИмяСправочника);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Отбор", Отбор);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПОМЕСТИТЬ ВремСвязиОбъектов", "");
	
	Запрос.УстановитьПараметр("ID",		Идентификаторы.ID);
	Запрос.УстановитьПараметр("Ссылка",	Идентификаторы.Ссылка);
	
	Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	Результат = Запрос.Выполнить().Выгрузить();
		
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапросаВременнойТаблицыСвязиОбъектов_Диадок(ИмяСправочника)
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса = Справочники_ТекстЗапроса_ТаблицаСвязейОбъектов_ДиадокРасширение(ИмяСправочника);
	Иначе
		ТекстЗапроса = Справочники_ТекстЗапроса_ТаблицаСвязейОбъектов_ДиадокСХ1();
	КонецЕсли;
	
	ИмяТаблицыКонтрагенты = Справочники_УстановитьИмяТаблицыКонтрагентовВТекстеЗапроса(ТекстЗапроса);
	
	Если Не ЕстьРеквизитИНН(ИмяТаблицыКонтрагенты) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ЕСТЬNULL(КонтрагентыИБ.ИНН, """")", """""");
	КонецЕсли;
	
	Если Не ЕстьРеквизитКПП(ИмяТаблицыКонтрагенты) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ЕСТЬNULL(КонтрагентыИБ.КПП, """")", """""");		
	КонецЕсли;
		
	Если ИмяСправочника = "Организации" Тогда
		ТекстЗапроса_УстановитьИмяТаблицыОрганизаций(ТекстЗапроса);
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция Справочники_ТекстЗапроса_ТаблицаСвязейОбъектов_ДиадокРасширение(ИмяСправочника)
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка КАК ОбъектДиадок,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК ОбъектИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.Наименование, """") КАК НаименованиеОбъектаИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """") КАК ИННОбъектаИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.КПП, """") КАК КППОбъектаИБ,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита КАК ИмяРеквизита
	|ПОМЕСТИТЬ ВремСвязиОбъектов
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК ЮрФизЛицаДиадок
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = ЮрФизЛицаДиадок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = КонтрагентыИБ.Ссылка
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник";
	
	Если ИмяСправочника = "Организации" Тогда
		Результат = СтрЗаменить(Результат, "Справочник.Контрагенты", "Справочник." + ИмяСправочника);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_ТаблицаСвязейОбъектов_ДиадокСХ1()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диадок_ЮрФизЛица.Ссылка 					КАК ОбъектДиадок,
	|	Диадок_ЮрФизЛица.СвязанныйСправочник1 		КАК ОбъектИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.Наименование, """") 	КАК НаименованиеОбъектаИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """") 			КАК ИННОбъектаИБ,
	|	ЕСТЬNULL(КонтрагентыИБ.КПП, """") 			КАК КППОбъектаИБ,
	|	""СвязанныйСправочник1"" 					КАК ИмяРеквизита
	|ПОМЕСТИТЬ ВремСвязиОбъектов
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК ЮрФизЛицаДиадок
	|		ПО Диадок_ЮрФизЛица.Ссылка = ЮрФизЛицаДиадок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
	|		ПО Диадок_ЮрФизЛица.СвязанныйСправочник1 = КонтрагентыИБ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
