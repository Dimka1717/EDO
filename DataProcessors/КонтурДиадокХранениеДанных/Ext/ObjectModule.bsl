	|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """"),
	|	ЕСТЬNULL(КонтрагентыИБ.КПП, """"),
	|	""СвязанныйСправочник2""
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК ЮрФизЛицаДиадок
	|		ПО Диадок_ЮрФизЛица.Ссылка = ЮрФизЛицаДиадок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
	|		ПО Диадок_ЮрФизЛица.СвязанныйСправочник2 = КонтрагентыИБ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка,
	|	Диадок_ЮрФизЛица.СвязанныйСправочник3,
	|	ЕСТЬNULL(КонтрагентыИБ.Наименование, """"),
	|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """"),
	|	ЕСТЬNULL(КонтрагентыИБ.КПП, """"),
	|	""СвязанныйСправочник3""
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК ЮрФизЛицаДиадок
	|		ПО Диадок_ЮрФизЛица.Ссылка = ЮрФизЛицаДиадок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
	|		ПО Диадок_ЮрФизЛица.СвязанныйСправочник3 = КонтрагентыИБ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение,
	|	ЕСТЬNULL(КонтрагентыИБ.Наименование, """"),
	|	ЕСТЬNULL(КонтрагентыИБ.ИНН, """"),
	|	ЕСТЬNULL(КонтрагентыИБ.КПП, """"),
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК ЮрФизЛицаДиадок
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = ЮрФизЛицаДиадок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентыИБ
	|		ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = КонтрагентыИБ.Ссылка
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник";
	
	Возврат Результат;
	
КонецФункции


Функция Справочники_ЗначениеДопРеквизита_Диадок(Выборка)
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(Выборка.Значение) Тогда
		Результат = Выборка.Значение;
	ИначеЕсли ЗначениеЗаполнено(Выборка.ЗначениеСтрока) Тогда
		Результат = Выборка.ЗначениеСтрока;
	Иначе
		Результат = Выборка.ЗначениеХранилищеЗначения.Получить();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ЗначениеЗаписиНастроекКонтрагентов_Диадок(СтруктураДанных)
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Диадок_НастройкиКонтрагентов.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	Диадок_НастройкиКонтрагентов.Организация = &Организация
	|	И Диадок_НастройкиКонтрагентов.Контрагент = &Контрагент
	|	И Диадок_НастройкиКонтрагентов.ИмяСвойства = &ИмяСвойства");
	
	Запрос.УстановитьПараметр("Организация",	СтруктураДанных.ОрганизацияЭДО);
	Запрос.УстановитьПараметр("Контрагент",		СтруктураДанных.КонтрагентЭДО);
	Запрос.УстановитьПараметр("ИмяСвойства",	СтруктураДанных.ИмяСвойства);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Значение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных)
	
	ОрганизацияЭДО	= СтруктураДанных.ОрганизацияЭДО;
	КонтрагентЭДО	= СтруктураДанных.КонтрагентЭДО;
	ИмяСвойства		= СтруктураДанных.ИмяСвойства;
	Значение		= СтруктураДанных.Значение;
	
	НаборЗаписей	= РегистрыСведений.Диадок_НастройкиКонтрагентов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(ОрганизацияЭДО);
	НаборЗаписей.Отбор.Контрагент.Установить(КонтрагентЭДО);
	НаборЗаписей.Отбор.ИмяСвойства.Установить(ИмяСвойства);
	
	НаборЗаписей.Очистить();
	
	ЗаписьРегистра	= НаборЗаписей.Добавить();
	ЗаписьРегистра.Контрагент	= КонтрагентЭДО;
	ЗаписьРегистра.Организация	= ОрганизацияЭДО;
	ЗаписьРегистра.ИмяСвойства	= ИмяСвойства;
	ЗаписьРегистра.Значение		= Значение;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура Справочники_УдалитьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных)
	
	МенеджерЗаписи = РегистрыСведений.Диадок_НастройкиКонтрагентов.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Организация	= СтруктураДанных.ОрганизацияЭДО;
	МенеджерЗаписи.Контрагент	= СтруктураДанных.КонтрагентЭДО;
	МенеджерЗаписи.ИмяСвойства	= СтруктураДанных.ИмяСвойства;
	
	МенеджерЗаписи.Удалить();
	
КонецПроцедуры

// Очищает сопоставленные объектам подсистемы Диадок справочники 1С(Организации, Контрагенты, Подразделения)
//
// Параметры:
//	Идентификаторы	- Структура	- коллекция индентификаторов для получения объекта исходя из выбранной системы хранения
//	ИмяСправочника	- Строка 	- значение псевдоперечисления "Перечисление_ИменаСправочников_Диадок()"
Процедура Справочники_ОчиститьСвязанныеСправочники(Идентификаторы, ИмяСправочника) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Справочники_ОчиститьСвязанныеСправочники_Диадок(Идентификаторы, ИмяСправочника);
	Иначе
		Справочники_ОчиститьСвязанныеСправочники_1С(Идентификаторы, ИмяСправочника);
	КонецЕсли;
	
КонецПроцедуры

Процедура Справочники_ОчиститьСвязанныеСправочники_Диадок(Идентификаторы, ИмяСправочника)
	
	ЮрФизЛицоЭДО = СвойствоСтруктуры(Идентификаторы, "Ссылка");
	
	Если НЕ ЗначениеЗаполнено(ЮрФизЛицоЭДО) Тогда
		ЮрФизЛицоЭДО = Справочники_СсылкаПоИдентификатору_Диадок(Идентификаторы, ИмяСправочника);
	КонецЕсли;
	
	ЮрФизЛицоОбъект = ЮрФизЛицоЭДО.ПолучитьОбъект();
	
	Справочники_ЮрФизЛицоОбъект_ОчиститьСвязанныеСправочники(ЮрФизЛицоОбъект);
			
	ЮрФизЛицоОбъект.Записать();
	
КонецПроцедуры

Процедура Справочники_ОчиститьСвязанныеСправочники_1С(Идентификаторы, ИмяСправочника)
	
	ИменаСправочников = Перечисление_ИменаСправочников_Диадок();
	
	Если ИмяСправочника = ИменаСправочников.Организации Тогда
		
		МассивСопоставленных = Организации_МассивСопоставленныхВ1С_1С(Новый Структура("ID", Идентификаторы.ID));
		Свойство = Свойства_IDОрганизации();
		
	ИначеЕсли ИмяСправочника = ИменаСправочников.Контрагенты Тогда
		
		МассивСопоставленных = Контрагенты_МассивСопоставленныхВ1С_1С(Новый Структура("ID", Идентификаторы.ID));
		Свойство = Свойства_IDКонтрагента();
		
	ИначеЕсли ИмяСправочника = ИменаСправочников.ПодразделенияОрганизаций 
		Или ИмяСправочника = ИменаСправочников.ПодразделенияКонтрагентов Тогда
		
		ДляОрганизации = (ИмяСправочника = ИменаСправочников.ПодразделенияОрганизаций);
		
		МассивСопоставленных = Подразделения_МассивСопоставленныхВ1С_1С(Новый Структура("ID", Идентификаторы.ID), ДляОрганизации);
		Свойство = ИмяСвойстваПодразделения(ДляОрганизации);

	КонецЕсли;
		
	Для Каждого СопоставленныйСправочник Из МассивСопоставленных Цикл
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленныйСправочник, Свойство);
	КонецЦикла;
		
КонецПроцедуры

Функция ТипыДокументовПоВидамДокументов(МассивВидовДокументов)
	
	Результат = Новый Массив;
	
	Если ЗначениеЗаполнено(МассивВидовДокументов) Тогда 
		
		ТаблицаВидовДокументов = ДопСправочники_СписокЭлементов_1С("ВидыДокументов", "ТипДокументаAPI");
		
		Для Каждого ВидДокумента Из МассивВидовДокументов Цикл
			
			НайденныйВид = ТаблицаВидовДокументов.Найти(ВидДокумента, "Ссылка");
			
			Если НайденныйВид <> Неопределено Тогда
				Результат.Добавить(НайденныйВид.ТипДокументаAPI);
			КонецЕсли;	
			
		КонецЦикла;
		
	Иначе
		Результат.Добавить("Any");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

