КонецФункции

Процедура КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе_Диадок(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина);
		
	Иначе
		
		КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе_1С(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе_1С(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина)
	
	Перечисления_ИменаСвойств = Перечисление_ИменаСвойствНастроек_1С();
	Свойство_ДобавлятьСчетВПакет = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ДобавлятьСчетВПакет, Истина);
	
	СвойстваТиповОснованийДляВидовДокументов = Новый Массив;
	
	Для Каждого ВидДокумента Из ВидыДокументовСчетов Цикл
		
		ИмяСвойства = КлючСвойстваТипОснования(ВидДокумента);
		СсылкаНаСвойство = Свойства_СсылкаНаСвойство(ИмяСвойства, Истина);
		СвойстваТиповОснованийДляВидовДокументов.Добавить(СсылкаНаСвойство);
		
	КонецЦикла;
	
	КатегорияПакетаСчета = "СчетНаОплату";
	Свойство_СчетНаОплату = Свойства_СсылкаНаСвойство(КатегорияПакетаСчета, Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДополнительныеСведенияВидПакета.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияВидПакета
	|ГДЕ
	|	ДополнительныеСведенияВидПакета.Свойство = &Свойство_СчетНаОплату";
	
	Запрос.УстановитьПараметр("Свойство_СчетНаОплату", Свойство_СчетНаОплату);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, Свойство_ДобавлятьСчетВПакет, Истина);
		
		Для Каждого СсылкаНаСвойство Из СвойстваТиповОснованийДляВидовДокументов Цикл
			ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, СсылкаНаСвойство, ОснованиеДляСчетаИзПлагина);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонтурПлагины_СчетВПакете_УстановитьНастройкиПриПереходе_Диадок(ВидыДокументовСчетов, ОснованиеДляСчетаИзПлагина)
	
	НастройкиДляУстановки = Новый Структура;
	
	Свойство_ДобавлятьСчетВПакет = "ДобавлятьСчетВПакет";
	НастройкиДляУстановки.Вставить(Свойство_ДобавлятьСчетВПакет, Истина);
	
	Для Каждого ВидДокумента Из ВидыДокументовСчетов Цикл
		
		ИмяСвойства = КлючСвойстваТипОснования(ВидДокумента);
		НастройкиДляУстановки.Вставить(ИмяСвойства, ОснованиеДляСчетаИзПлагина);
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Диадок_НастройкиКонтрагентов.Организация КАК Организация,
	|	Диадок_НастройкиКонтрагентов.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	Диадок_НастройкиКонтрагентов.ИмяСвойства = ""СчетНаОплату""";

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
        ДанныеОрганизации = Новый Структура("Ссылка", Выборка.Организация);
		ДанныеКонтрагента = Новый Структура("Ссылка", Выборка.Контрагент);
		
		Настройки_ЗаписатьЗначенияСвойств_Диадок(НастройкиДляУстановки, ДанныеОрганизации, ДанныеКонтрагента);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты(ДатаКонвертацииДанных, ОснованиеДляСчетаИзПлагина) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты_Диадок(ДатаКонвертацииДанных);
		
	Иначе
		
		КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты_1С(ОснованиеДляСчетаИзПлагина);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты_1С(ОснованиеДляСчетаИзПлагина)
	
	Если ОснованиеДляСчетаИзПлагина <> "ДокументПродажи" Тогда
		Возврат;
	КонецЕсли;
	
	Перечисления_ИменаСвойств = Перечисление_ИменаСвойствНастроек_1С();
	
	Свойство_ВидПакета = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ВидПакета, Истина);
	Свойство_ВидПакетаСчет = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ВидПакетаСчет, Истина);
	
	ИдентификаторыВидовПакета = Новый Массив;
	ИдентификаторыВидовПакета.Добавить("ID_ТОРГ12_Акт_БезНДС");
	ИдентификаторыВидовПакета.Добавить("ID_УПД_БезНДС");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДополнительныеСведенияВидПакета.Объект КАК Объект,
	|	ДополнительныеСведенияВидПакета.Свойство КАК Свойство,
	|	ДополнительныеСведенияВидПакета.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияВидПакета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияВидПакетаСчет
	|		ПО ДополнительныеСведенияВидПакета.Объект = ДополнительныеСведенияВидПакетаСчет.Объект
	|			И (ДополнительныеСведенияВидПакетаСчет.Свойство = &Свойство_ВидПакетаСчет)
	|ГДЕ
	|	ДополнительныеСведенияВидПакета.Свойство = &Свойство_ВидПакета
	|	И ДополнительныеСведенияВидПакета.Значение В(&ИдентификаторыВидовПакета)
	|	И ДополнительныеСведенияВидПакетаСчет.Объект ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Свойство_ВидПакета", Свойство_ВидПакета);
	Запрос.УстановитьПараметр("Свойство_ВидПакетаСчет", Свойство_ВидПакетаСчет);
	Запрос.УстановитьПараметр("ИдентификаторыВидовПакета", ИдентификаторыВидовПакета);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, Свойство_ВидПакетаСчет, "ID_СчетПлагина");
	КонецЦикла;
	
КонецПроцедуры

Процедура КонтурПлагины_СчетВПакете_СконвертироватьОтправленныеПакеты_Диадок(ДатаКонвертацииДанных)
	
	ИдентификаторыСчетовНаОплату = Ядро.ВидыЭлектронныхСчетовНаОплату();
	ВидыПакетовСчетов = Новый Массив;
	
	Для Каждого ИдентификаторСчета Из ИдентификаторыСчетовНаОплату Цикл
		
		ВидПакета = ДопСправочники_СсылкаПоИдентификатору_Диадок("ВидыПакетов", ИдентификаторСчета);
		
		Если ВидПакета <> Неопределено Тогда
			ВидыПакетовСчетов.Добавить(ВидПакета);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ВидыПакетовСчетов.Количество() > 0 Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Диадок_Документы.Документ,
		|	Диадок_Документы.Направление,
		|	Диадок_Документы.Организация,
		|	Диадок_Документы.Контрагент,
		|	Диадок_Документы.ОрганизацияДиадок,
		|	Диадок_Документы.КонтрагентДиадок,
		|	Диадок_Документы.Метка,
		|	Диадок_Документы.Пакет КАК ОсновнойСвязанныйПакет,
		|	Диадок_Документы.ДатаЗагрузки КАК ДатаОтправкиСчета
		|ИЗ
		|	Справочник.Диадок_Документы КАК Диадок_Документы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
		|		ПО Диадок_Документы.Направление = Диадок_ПакетыДокументов.Направление
		|			И Диадок_Документы.Документ = Диадок_ПакетыДокументов.Документ
		|			И (Диадок_ПакетыДокументов.ВидПакета В (&ВидыПакетовСчетов))
		|ГДЕ
		|	НЕ Диадок_Документы.ПометкаУдаления
		|	И Диадок_Документы.Направление = &Направление
		|	И Диадок_Документы.Метка = &Метка
		|	И Диадок_Документы.ТипДокумента = &ТипДокумента
		|	И Диадок_Документы.Документ <> НЕОПРЕДЕЛЕНО
		|	И Диадок_Документы.ДатаЗагрузки >= &ДатаЗагрузки
		|	И Диадок_ПакетыДокументов.Ссылка ЕСТЬ NULL
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаОтправкиСчета УБЫВ";
		
		Запрос.УстановитьПараметр("Направление", Перечисление_Направления().Исходящее);
		Запрос.УстановитьПараметр("Метка", Перечисление_СтатусыПакетов().Отправлен);
		Запрос.УстановитьПараметр("ТипДокумента", Тип_СчетНаОплату());
		Запрос.УстановитьПараметр("ВидыПакетовСчетов", ВидыПакетовСчетов);
		Запрос.УстановитьПараметр("ДатаЗагрузки", ДатаКонвертацииДанных);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ОбъектПакета = Справочники.Диадок_ПакетыДокументов.СоздатьЭлемент();
			
			ЗаполнитьЗначенияСвойств(ОбъектПакета, Выборка);
			ОбъектПакета.ВидПакета = ВидыПакетовСчетов[0];
			ДопРеквизиты_УстановитьЗначение(ОбъектПакета, "ОсновнойСвязанныйПакет", Выборка.ОсновнойСвязанныйПакет);
			
			ОбъектПакета.Записать();
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

