//{		НАСТРОЙКИ МОДУЛЯ СТАНДАРТ

// Заполняет настройки модуля Страндарт
//
// Возвращаемое значение:
//  Результат - Структура - см. функцию Ядро.Контракт_НастройкиМодуляСтандарт()
//
Функция НастройкиМодуляСтандарт() Экспорт
	
	Результат = Кэш_Прочитать("НастройкиМодуляСтандарт");
	
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Результат = Контракт_НастройкиМодуляСтандарт();
	
	НастройкиМодуляСтандарт_ЗаполнитьНастройкиПоДаннымРС(Результат);
	НастройкиМодуляСтандарт_ОбработатьНастройки(Результат);	
	
	Кэш_Поместить("НастройкиМодуляСтандарт", Результат);
	
	Возврат Результат;
	
КонецФункции

// Заполняет настройки модуля Страндарт
//
// Параметры:
//  Результат - Структура - см. функцию Ядро.Контракт_НастройкиМодуляСтандарт()
//
Процедура НастройкиМодуляСтандарт_ЗаполнитьНастройкиПоДаннымРС(Результат)
	
	ИмяРегистра	= Свойства_ИмяРегистраСведений();
	
	Если НЕ ЗначениеЗаполнено(ИмяРегистра) Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеСвойств = НастройкиМодуляСтандарт_НаименованияСвойствПВХ(ИмяРегистра);

	ОбъединенияЗапросов = "	
	|
	| ОБЪЕДИНИТЬ ВСЕ
	| ";
	
	ТекстЗапроса = "";
	
	Для Каждого Свойство Из СоответствиеСвойств Цикл
		
		Если Не ПустаяСтрока(ТекстЗапроса) Тогда
			ТекстЗапроса = ТекстЗапроса + ОбъединенияЗапросов;
		КонецЕсли;
		
		ТекстЗапроса = ТекстЗапроса + НастройкиМодуляСтандарт_ТекстЗапроса_ДанныеРС(ИмяРегистра, Свойство.Значение, Свойство.Ключ);
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Объект",	ОбъектОбщихНастроек_1С());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
		Пока ВыборкаЗапроса.Следующий() Цикл
			
			Ключ		= ВыборкаЗапроса.ИмяСвойства;
			Значение	= ВыборкаЗапроса.ЗначениеСвойства;
							
			Результат.Вставить(Ключ, Значение);
				
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Подготавливает данные для формирования запроса по доп. сведениям модуля Стандарт
//
// Параметры:
//	ИмяРегистра	- Строка - см. функцию Свойства_ИмяРегистраСведений()
//
// Возвращаемое значение: Соответствие
//
Функция НастройкиМодуляСтандарт_НаименованияСвойствПВХ(ИмяРегистра)
	
	Результат = Новый Соответствие;
	
	Если ИмяРегистра = "ЗначенияСвойствОбъектов" Тогда

		Результат.Вставить("ИспользоватьПодключаемыйМодуль"		, "ДиадокПодключаемыйМодульТип");
		Результат.Вставить("МестонахождениеПодключаемогоМодуля"	, "ДиадокПодключаемыйМодульТип");
		Результат.Вставить("ПодключаемыйМодульПуть"				, "ДиадокПодключаемыйМодульПуть");
		Результат.Вставить("ПодключаемыйМодульСсылка"			, "ДиадокПодключаемыйМодульGUID");
		Результат.Вставить("ПодключаемыйМодульИмяОбработки"		, "ДиадокПодключаемыйМодульИмяОбработки");
		Результат.Вставить("ПодключаемыйМодульИмяСправочника"	, "ДиадокПодключаемыйМодульВидСправочника");
		
	ИначеЕсли ИмяРегистра = "ДополнительныеСведения" Тогда

		Результат.Вставить("ИспользоватьПодключаемыйМодуль"		, "ИспользоватьПодключаемыйМодуль");
		Результат.Вставить("МестонахождениеПодключаемогоМодуля"	, "РасположениеПодключаемогоМодуля");
		Результат.Вставить("ПодключаемыйМодульПуть"				, "ПутьКПодключаемомуМодулю");
		Результат.Вставить("ПодключаемыйМодульСсылка"			, "ПутьКПодключаемомуМодулю");
		Результат.Вставить("ПодключаемыйМодульИмяОбработки"		, "ПутьКПодключаемомуМодулю");
		
	КонецЕсли;
	
	Результат.Вставить("РежимСовместимостиФорматов155и820", "РежимСовместимостиФорматов155и820");
	
	Возврат Результат;
	
КонецФункции	

// Добавляет в текст запроса блок по каждому свойству 
// см. функцию НастройкиМодуляСтандарт_НаименованияСвойствПВХ()
//
// Параметры:
//	ИмяРегистра		- Строка - см. функцию Свойства_ИмяРегистраСведений()
//	ИмяСвойства		- Строка - см. функцию НастройкиМодуляСтандарт_НаименованияСвойствПВХ()
//	ИмяПараметра	- Строка - см. функцию НастройкиМодуляСтандарт_НаименованияСвойствПВХ()
//
// Возвращаемое значение: Строка
//
Функция НастройкиМодуляСтандарт_ТекстЗапроса_ДанныеРС(ИмяРегистра, ИмяСвойства, ИмяПараметра)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	&ИмяПараметра КАК ИмяСвойства,
	|	ЕСТЬNULL(ЗначенияСвойствОбъектов.Значение,"""") КАК ЗначениеСвойства
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Объект
	|	И ЗначенияСвойствОбъектов.Свойство.Наименование = &ИмяСвойства";
	 
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяПараметра",	"""" + ИмяПараметра + """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяСвойства",	"""" + ИмяСвойства  + """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Обрабатывает и дозаполняет значения после выполнения запроса
//
// Параметры:
//  Результат	- Структура - см. функцию Ядро.Контракт_НастройкиМодуляСтандарт()
//
Процедура НастройкиМодуляСтандарт_ОбработатьНастройки(Результат)
	
	ПодключаемыйМодульСсылка = Неопределено;
	
	ИмяРегистра	= Свойства_ИмяРегистраСведений();
	
	Если ИмяРегистра = "ЗначенияСвойствОбъектов" Тогда
			
		Результат.ИспользоватьПодключаемыйМодуль = Результат.МестонахождениеПодключаемогоМодуля		= "Диск" 
												Или Результат.МестонахождениеПодключаемогоМодуля	= "1С"
												Или Результат.МестонахождениеПодключаемогоМодуля	= "Конфигурация";

		Если Результат.МестонахождениеПодключаемогоМодуля = "1С" Тогда
			ПодключаемыйМодульСсылка = ПодключаемыйМодульСсылка(Результат);
		КонецЕсли;
		
	ИначеЕсли ИмяРегистра = "ДополнительныеСведения" Тогда
		
		Если Результат.ИспользоватьПодключаемыйМодуль = "" Тогда
			Результат.ИспользоватьПодключаемыйМодуль = Ложь;		
		КонецЕсли;

		Если Результат.МестонахождениеПодключаемогоМодуля = "НаДиске" Тогда
			Результат.МестонахождениеПодключаемогоМодуля = "Диск";
		ИначеЕсли Результат.МестонахождениеПодключаемогоМодуля = "ВБазеДанных" Тогда
			Результат.МестонахождениеПодключаемогоМодуля = "1С";
		ИначеЕсли Результат.МестонахождениеПодключаемогоМодуля = "ВСоставеКонфигурации" Тогда
			Результат.МестонахождениеПодключаемогоМодуля = "Конфигурация";
		КонецЕсли;
			
		Если Результат.МестонахождениеПодключаемогоМодуля = "1С"
			И ЗначениеЗаполнено(Результат.ПодключаемыйМодульСсылка) Тогда	  
			
			Результат.ПодключаемыйМодульПуть			= "";
			Результат.ПодключаемыйМодульИмяОбработки	= "";
			
			ЧтениеXML = Новый ЧтениеXML();
		    ЧтениеXML.УстановитьСтроку(Результат.ПодключаемыйМодульСсылка);
			
			ПодключаемыйМодульСсылка = ПрочитатьXML(ЧтениеXML);

		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПодключаемыйМодульСсылка) Тогда
		Результат.ПодключаемыйМодульСсылка = ПодключаемыйМодульСсылка;
	КонецЕсли;	
	
	Результат.ПодключаемыйМодульПредставление = Ядро.ПредставлениеПодключаемогоМодуля(Результат);
	
	Если Результат.РежимСовместимостиФорматов155и820 = "" Тогда
		Результат.РежимСовместимостиФорматов155и820 = Ложь;
	КонецЕсли;
	
КонецПроцедуры	

//}		НАСТРОЙКИ МОДУЛЯ СТАНДАРТ


// {	КОНВЕРТАЦИЯ НАСТРОЕК МОДУЛЯ СТАНДАРТ
Процедура КонвертацияНастроек_Сконвертировать() Экспорт
	
	КонвертацияНастроек_СконвертироватьФорматы();
	КонвертацияНастроек_СконвертироватьПечатныеФормы();
	КонвертацияНастроек_СконвертироватьПодразделения();
	КонвертацияНастроек_СконвертироватьКомментарии();
	КонвертацияНастроек_СконвертироватьАвтообновление();
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьФорматы()
	
	ПВХ = ПланыВидовХарактеристик[Свойства_ИмяПланаВидовХарактеристик()];
	
	СвойствоДляОрганизации = ПВХ.НайтиПоНаименованию("ДиадокФормироватьУПД",			Истина);
	СвойствоДляКонтрагента = ПВХ.НайтиПоНаименованию("ДиадокФормироватьУПДКонтрагент",	Истина);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоДляОрганизации);
	СписокСвойств.Добавить(СвойствоДляКонтрагента);
	
	Выборка = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	
	Пока Выборка.Следующий() Цикл
		КонвертацияНастроек_СконвертироватьНастройкуФорматов(Выборка.Объект, Выборка.Значение);
	КонецЦикла;
	
КонецПроцедуры

Функция КонвертацияНастроек_ВыборкаСвойств(СписокСвойств)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект КАК Объект,
	|	ЗначенияСвойствОбъектов.Свойство КАК Свойство,
	|	ЗначенияСвойствОбъектов.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство В(&СписокСвойств)";
	
	Запрос.УстановитьПараметр("СписокСвойств", СписокСвойств);
	
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат;
	
КонецФункции

Процедура КонвертацияНастроек_СконвертироватьНастройкуФорматов(ОбъектНастройки, ЗначениеНастройки)
	
	СоответвиеНастроек = КонвертацияНастроек_СоответвиеНастроекФорматов();
	НастройкаДляЗаписи = СоответвиеНастроек.Получить(ЗначениеНастройки);
	
	Если ЗначениеЗаполнено(НастройкаДляЗаписи) Тогда
		
		ТаблицаВидовПакетов		= СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыПакетов");
		ТаблицаВидовДокументов	= СопоставлениеДанныхПМ_ТаблицаВидовСправочника("ВидыДокументов");
		
		КатегорииПакетоДляНастройки = Новый Массив;
		КатегорииПакетоДляНастройки.Добавить("ОсновнойПакет");
		КатегорииПакетоДляНастройки.Добавить("КорректировочныйПакет");
		
		Для Каждого КатегорияПакета Из КатегорииПакетоДляНастройки Цикл
			
			ВидПакетаДляКатегории = НастройкаДляЗаписи[КатегорияПакета];
			
			ДопРеквизиты_УстановитьЗначение_1С(ОбъектНастройки, КатегорияПакета, ВидПакетаДляКатегории);
			
			ОписаниеПакета = ТаблицаВидовПакетов.Найти(ВидПакетаДляКатегории);
			
			Если ОписаниеПакета <> Неопределено Тогда
				
				СоставПакета = РазделитьСтрокуЛок(ОписаниеПакета.СоставПакета);
				
				Для Каждого ВидДокумента Из СоставПакета Цикл
					
					ОписаниеДокумента = ТаблицаВидовДокументов.Найти(ВидДокумента);
					
					Если ОписаниеДокумента <> Неопределено Тогда
						
						КлючФормата = Лев(ОписаниеДокумента.ТипКонтентаAPI, 3);
						
						ЗначениеФормата = Неопределено;
						
						Если НастройкаДляЗаписи.Свойство(КлючФормата, ЗначениеФормата) Тогда
							ДопРеквизиты_УстановитьЗначение_1С(ОбъектНастройки, "Формат_" + ВидДокумента, ЗначениеФормата);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция КонвертацияНастроек_СоответвиеНастроекФорматов()
	
	Результат = Новый Соответствие;
	
	КлючиНастройки = "ОсновнойПакет, КорректировочныйПакет, utd, ucd";
	utd820 = "utd820";
	ucd736 = "ucd736";
	
	// BSLLS:NumberOfValuesInStructureConstructor-off
	СтруктураУПДУКД = Новый Структура(КлючиНастройки, "ID_УПД", "ID_УКД", utd820, ucd736);
	СтруктураУПДУКДРаздельно = Новый Структура(КлючиНастройки, "ID_УПД_раздельно", "ID_УКД_раздельно", utd820, ucd736);
	СтруктураОсновнойПакетКСФ = Новый Структура(КлючиНастройки, "ID_ОсновнойПакет", "ID_КСФ", utd820, ucd736);
	// BSLLS:NumberOfValuesInStructureConstructor-on
	
	Результат.Вставить("СЧФДОП_820", СтруктураУПДУКД);
	Результат.Вставить("СЧФДОП_820_736", СтруктураУПДУКД);
	Результат.Вставить("СЧФ_ДОП_820", СтруктураУПДУКДРаздельно);
	Результат.Вставить("СЧФ_ДОП_820_736", СтруктураУПДУКДРаздельно);
	Результат.Вставить("СФТОРГ12АКТ_820", СтруктураОсновнойПакетКСФ);
	Результат.Вставить("СФТОРГ12АКТ_820_736", СтруктураОсновнойПакетКСФ);
	
	Возврат Результат;
	
КонецФункции

Процедура КонвертацияНастроек_СконвертироватьПечатныеФормы()
	
	ПВХ = ПланыВидовХарактеристик[Свойства_ИмяПланаВидовХарактеристик()];
	
	СвойствоВПФДляАкта 					= ПВХ.НайтиПоНаименованию("ДиадокВнешняяПечатнаяФормаАкта",			Истина);
	
	СвойствоВПФДляАктаСверки 			= ПВХ.НайтиПоНаименованию("ДиадокВнешняяПечатнаяФормаАктаСверки",	Истина);
	СвойствоВПФДляАктаСверкиОФ 			= ПВХ.НайтиПоНаименованию("ДиадокВнешняяПечатнаяФормаСверки",		Истина);
	
	СвойствоВПФДляСчета					= ПВХ.НайтиПоНаименованию("ДиадокВнешняяПечатнаяФормаСчета",		Истина);
	СвойствоВПФДляСчетаОФ				= ПВХ.НайтиПоНаименованию("ДиадокВнешняяПечатнаяФорма",				Истина);
	СвойствоСтандартнаяФормаДляСчета	= ПВХ.НайтиПоНаименованию("ДиадокСтандартнаяФормаСчетаНаОплату",	Истина);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоВПФДляАкта);
	
	КонвертацияНастроек_СконвертироватьВПФ(СписокСвойств, "ID_АктФормализованный");
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоВПФДляАктаСверки);
	СписокСвойств.Добавить(СвойствоВПФДляАктаСверкиОФ);
	
	КонвертацияНастроек_СконвертироватьВПФ(СписокСвойств, "ID_АктСверки");
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоВПФДляСчета);
	СписокСвойств.Добавить(СвойствоВПФДляСчетаОФ);
	
	КонвертацияНастроек_СконвертироватьВПФ(СписокСвойств, "ID_Счет");
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоСтандартнаяФормаДляСчета);
	
	КонвертацияНастроек_УстановитьИспользованиеСтандартнойПечатнойФормы(СписокСвойств, "ID_Счет");
	
	КонвертацияНастроек_СконвертироватьДополнительныеВПФ();
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьВПФ(СписокСвойств, ВидДокумента)
	
	Выборка = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Значение) Тогда
			
			ИмяСвойства = "ПФ_" + ВидДокумента;
			ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, ИмяСвойства, Выборка.Значение);
			
			ИмяСвойства = "Формат_" + ВидДокумента;
			ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, ИмяСвойства, "epf");
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_УстановитьИспользованиеСтандартнойПечатнойФормы(СписокСвойств, ВидДокумента)
	
	Выборка = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Значение = Истина Тогда
			ИмяСвойства = "Формат_" + ВидДокумента;
			ДопРеквизиты_УстановитьЗначение_1С(Выборка.Объект, ИмяСвойства, "pf_1c");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьДополнительныеВПФ()
	
	ПВХ = ПланыВидовХарактеристик[Свойства_ИмяПланаВидовХарактеристик()];
	
	СвойствоИспользованияВПФ	= ПВХ.НайтиПоНаименованию("ДиадокСписокДополнительныхВПФ",	Истина);
	СвойствоДополнительнойВПФ	= ПВХ.НайтиПоНаименованию("ДиадокНомерВПФ",					Истина);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоИспользованияВПФ);
	
	ВыборкаИспользованияВПФ = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоДополнительнойВПФ);
	
	ВыборкаДополнительныхВПФ = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	
	Пока ВыборкаИспользованияВПФ.Следующий() Цикл
		
		ОбъектНастройки	= ВыборкаИспользованияВПФ.Объект;
		НастройкаВПФ	= Строка(ВыборкаИспользованияВПФ.Значение);
		
		Если ЗначениеЗаполнено(НастройкаВПФ) Тогда
			
			НомераИспользуемыхВПФ = Новый Массив;
			
			Для Позиция = 1 По СтрДлина(НастройкаВПФ) Цикл
				Если Сред(НастройкаВПФ, Позиция, 1) = "1" Тогда
					НомераИспользуемыхВПФ.Добавить(Позиция);
				КонецЕсли;
			КонецЦикла;
			
			ИспользуемыеВПФ = Новый Массив;
			
			ВыборкаДополнительныхВПФ.Сбросить();
			
			Пока ВыборкаДополнительныхВПФ.Следующий() Цикл
				
				НомерВПФ = Число(ВыборкаДополнительныхВПФ.Значение);
				
				Если НомераИспользуемыхВПФ.Найти(НомерВПФ) <> Неопределено Тогда
					ИспользуемыеВПФ.Добавить(ВыборкаДополнительныхВПФ.Объект);
				КонецЕсли;
				
			КонецЦикла;
			
			КонвертацияНастроек_УстановитьДополнительныеВПФ(ОбъектНастройки, ИспользуемыеВПФ);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_УстановитьДополнительныеВПФ(ОбъектНастройки, ИспользуемыеВПФ)
	
	ВидыДокументов = Новый Массив;
	ВидыДокументов.Добавить("ID_УПД");
	ВидыДокументов.Добавить("ID_УПД_ДОП");
	ВидыДокументов.Добавить("ID_ТОРГ12");
	ВидыДокументов.Добавить("ID_АктФормализованный");
	
	Для НомерВПФ = 1 По ИспользуемыеВПФ.Количество() Цикл
		
		ЗначениеСвойства = ИспользуемыеВПФ[НомерВПФ - 1].УникальныйИдентификатор();
		
		Для Каждого ВидДокумента Из ВидыДокументов Цикл
			
			ИмяСвойства = "ПФ_" + НомерВПФ + "_" + ВидДокумента;
			ДопРеквизиты_УстановитьЗначение_1С(ОбъектНастройки, ИмяСвойства, ЗначениеСвойства);
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_ТочностьЦены() Экспорт 
	
	ТочностьЦены = НастройкаМодуляСтандарт_ТочностьЦены();
	
	ОбщиеНастройки = Настройки_ОбщиеНастройки();
	ОбщиеНастройки.ТочностьЦены = ТочностьЦены;
	
	Настройки_ЗаписатьОбщиеНастройки(ОбщиеНастройки);
	
	КлючНастроек = НастройкаМодуляСтандарт_ИмяНастройкиТочностьЦены();
	ИмяПользователя = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	ХранилищеОбщихНастроек.Удалить("НастройкаОпций_Диадок", КлючНастроек, ИмяПользователя);
	
КонецПроцедуры

// Проверяет наличие сохраненных настроек прокси-сервера модуля Стандарт.
// Настройки хранятся в регистре сведений в разрезе пользователей.
//
// Возвращаемое значение:
//	Булево - Истина, если есть настройки хотя бы у одного пользователя, Ложь - нет настроек.
//
Функция КонвертацияНастроек_ЕстьНастройкиПроксиВМодулеСтандарт() Экспорт
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Объект
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов
	|ГДЕ
	|	Свойство = &Свойство
	|	И Значение В (&Значения)";
	
	ИмяРегистра 	= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст 	= ТекстЗапроса;
	
	ИмяПланаВидовХарактеристик = Свойства_ИмяПланаВидовХарактеристик();
	ПВХ = ПланыВидовХарактеристик[ИмяПланаВидовХарактеристик];
	
	СвойствоНастройкиПрокси = ПВХ.НайтиПоНаименованию("ДиадокНастройкиПрокси", Истина);
	
	ЗначенияСвойстваНастройкиПрокси = Новый Массив;
	ЗначенияСвойстваНастройкиПрокси.Добавить("ИспользоватьНастройкиIE");
	ЗначенияСвойстваНастройкиПрокси.Добавить("ИспользоватьПроксиСервер");
	
	Запрос.УстановитьПараметр("Свойство", СвойствоНастройкиПрокси);
	Запрос.УстановитьПараметр("Значения", ЗначенияСвойстваНастройкиПрокси);

	РезультатЗапроса = Запрос.Выполнить();
	
	ЕстьНастройкиПрокси = Не РезультатЗапроса.Пустой();
	
	Если Не ЕстьНастройкиПрокси
		И Метаданные.РегистрыСведений.Найти("НастройкиПользователей") <> Неопределено Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Пользователь КАК Объект
		|ИЗ
		|	РегистрСведений.НастройкиПользователей
		|ГДЕ
		|	Настройка = &Свойство
		|	И Значение В (&Значения)";
		
		ТипИзмерения = Метаданные.РегистрыСведений["НастройкиПользователей"].Измерения.Настройка.Тип.Типы()[0];
		ИмяПланаВидовХарактеристик = Метаданные.НайтиПоТипу(ТипИзмерения).Имя;
		
		ПВХ = ПланыВидовХарактеристик[ИмяПланаВидовХарактеристик];
		СвойствоНастройкиПрокси = ПВХ.НайтиПоНаименованию("ДиадокНастройкиПрокси", Истина);
		
		Запрос.УстановитьПараметр("Свойство", СвойствоНастройкиПрокси);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ЕстьНастройкиПрокси = Не РезультатЗапроса.Пустой();
		
	КонецЕсли;
	
	Возврат ЕстьНастройкиПрокси;
	
КонецФункции

Процедура КонвертацияНастроек_СконвертироватьПодразделения()
	
	ИмяСвойстваМодуляСтандарт 	= "Подр_DepartmentID";
	ИмяСвойстваМодуляПРО		= "IDПодразделенияОрганизации";
	
	СвойствоМодуляСтандарт = Свойства_СсылкаНаСвойство(ИмяСвойстваМодуляСтандарт, Ложь);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоМодуляСтандарт);
	
	ВыборкаДанныхМодуляСтандарт = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	Пока ВыборкаДанныхМодуляСтандарт.Следующий() Цикл
		
		Значение = ВыборкаДанныхМодуляСтандарт.Значение;
		
		Если ЗначениеЗаполнено(Значение) Тогда
			
			Объект = ВыборкаДанныхМодуляСтандарт.Объект;
			
			ДопРеквизиты_УстановитьЗначение_1С(Объект, ИмяСвойстваМодуляПРО, Значение);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьКомментарии()
	
	ИмяСвойстваМодуляСтандарт 	= "ТекстКомментарияДиадок";
	ИмяСвойстваМодуляПРО		= "ЗаписыватьКомментарииВДокументы1С";
	
	СвойствоМодуляСтандарт = Свойства_СсылкаНаСвойство(ИмяСвойстваМодуляСтандарт, Ложь);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоМодуляСтандарт);
	
	ВыборкаДанныхМодуляСтандарт = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	Пока ВыборкаДанныхМодуляСтандарт.Следующий() Цикл
		
		Значение = ВыборкаДанныхМодуляСтандарт.Значение;
		
		Если ЗначениеЗаполнено(Значение) Тогда
			
			Объект = ВыборкаДанныхМодуляСтандарт.Объект;
			
			ДопРеквизиты_УстановитьЗначение_1С(Объект, ИмяСвойстваМодуляПРО, Истина);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура КонвертацияНастроек_СконвертироватьАвтообновление()
	
	ИмяСвойстваМодуляСтандарт = "ДиадокОтключитьАвтоматическоеОбновлениеМодуля";
	
	СвойствоМодуляСтандарт = Свойства_НайтиСвойство(ИмяСвойстваМодуляСтандарт, Ложь);
	Если Не ЗначениеЗаполнено(СвойствоМодуляСтандарт) Тогда
		Возврат;
	КонецЕсли;
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(СвойствоМодуляСтандарт);
	
	ИмяСвойстваМодуляПРО = "АвтоматическиОбновлятьМодуль";
	
	ВыборкаДанныхМодуляСтандарт = КонвертацияНастроек_ВыборкаСвойств(СписокСвойств);
	Пока ВыборкаДанныхМодуляСтандарт.Следующий() Цикл
		
		ЗначениеСтандарт = ВыборкаДанныхМодуляСтандарт.Значение;
		
		Если ТипЗнч(ЗначениеСтандарт) = Тип("Булево") Тогда
			
			Объект = ВыборкаДанныхМодуляСтандарт.Объект;
			ЗначениеПро = Не ЗначениеСтандарт;
			
			ДопРеквизиты_УстановитьЗначение_1С(Объект, ИмяСвойстваМодуляПРО, ЗначениеПро);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

