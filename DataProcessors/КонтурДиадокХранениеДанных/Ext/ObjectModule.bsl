Функция Пакеты_ОсновнойСвязанныйПакет_1С(ИдентификаторыПакета)
	
	Результат = Неопределено;
	
	Перечисления_ИменаСвойств = Перечисление_ИменаСвойствНастроек_1С();
	
	Свойство_ВидПакета				= Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ВидПакета, Истина);
	Свойство_ДокументУчетаПакета	= Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ДокументУчетаПакета, Истина);
	Свойство_ОсновнойСвязанныйПакет	= Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ОсновнойСвязанныйПакет, Истина);
			
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидПакета.Значение КАК ИдентификаторВидаПакета,
	|	ДокументУчетаПакета.Объект КАК ДокументУчета
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ОсновнойСвязанныйПакет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДокументУчетаПакета
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ВидПакета
	|			ПО ДокументУчетаПакета.Объект = ВидПакета.Объект
	|				И (ВидПакета.Свойство = &Свойство_ВидПакета)
	|		ПО (ДокументУчетаПакета.Свойство = &Свойство_ДокументУчетаПакета)
	|			И ОсновнойСвязанныйПакет.Значение = ДокументУчетаПакета.Значение
	|ГДЕ
	|	ОсновнойСвязанныйПакет.Свойство = &Свойство_ОсновнойСвязанныйПакет
	|	И ОсновнойСвязанныйПакет.Значение = &LetterId");
	
	Запрос.УстановитьПараметр("Свойство_ВидПакета", Свойство_ВидПакета);
	Запрос.УстановитьПараметр("Свойство_ДокументУчетаПакета", Свойство_ДокументУчетаПакета);
	Запрос.УстановитьПараметр("Свойство_ОсновнойСвязанныйПакет", Свойство_ОсновнойСвязанныйПакет);
	Запрос.УстановитьПараметр("LetterId", ИдентификаторыПакета.LetterId);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Результат = Ядро.Контракт_ОписаниеСвязанногоПакета();
		
		Результат.ИдентификаторВида 	= Выборка.ИдентификаторВидаПакета;
		Результат.ДокументУчета 		= Выборка.ДокументУчета;
		
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции


