// ПАКЕТЫ: 1С

Функция Пакет_ДанныеПакета_1С(Идентификаторы)
	
	Результат = Контракт_Пакет();
	
	ЗаполнитьЗначенияСвойств(Результат.Идентификаторы, Идентификаторы);
	
	Результат.ДокументУчета = Пакеты_ДокументУчета_1С(Результат.Идентификаторы);
	Результат.Документы = Пакеты_МассивКонтрактовДокументовПакета_1С(Результат.Идентификаторы);
	
	Если Результат.Документы.Количество() > 0 Тогда
		
		ДокументПакета = Результат.Документы[0];
		
		Результат.ИдентификаторВида = ДокументПакета.ИдентификаторВидаПакета;
		Результат.Направление = ДокументПакета.Направление;
		ЗаполнитьЗначенияСвойств(Результат.Отправитель, ДокументПакета.Отправитель);
		ЗаполнитьЗначенияСвойств(Результат.Получатель, ДокументПакета.Получатель);
		ЗаполнитьЗначенияСвойств(Результат.Реквизиты, ДокументПакета.Реквизиты);
		
		ЗашифрованныйПакет = СвойствоСтруктуры(ДокументПакета.СлужебнаяИнформация, "ЗашифрованныйПакет", Ложь);
		
		Результат.СлужебнаяИнформация.Вставить("ЗашифрованныйПакет", ЗашифрованныйПакет);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_Записать_1С(Пакет)
	
	Результат = Неопределено;
	
	ДокументУчета = Пакет.ДокументУчета;
	LetterId = Пакет.Идентификаторы.LetterId;
	
	ИменаСвойствНастроек_1С = Перечисление_ИменаСвойствНастроек_1С();
	
	Если ЗначениеЗаполнено(ДокументУчета)
		И ЗначениеЗаполнено(LetterId) Тогда
		
		ПереопределяемыеИменаСвойств1С = Пакеты_ПереопределяемыеИменаСвойств1С(Пакет);
		
		ДопРеквизиты_УстановитьЗначение_1С(ДокументУчета, ПереопределяемыеИменаСвойств1С.ДокументУчетаПакета, LetterId);
		
		Если Пакет.Документы.Количество() > 0 Тогда
			
			МаксИндекс = Пакет.Документы.ВГраница();
			
			Для ОбратныйИндекс = -МаксИндекс По 0 Цикл
				
				Документ = Пакет.Документы[-ОбратныйИндекс];
				Документы_Записать_1С(Документ);
				
			КонецЦикла;
			
		КонецЕсли;
		
		Пакеты_ЗаписатьСвязанныеПакеты_1C(Пакет, ИменаСвойствНастроек_1С);
		
	ИначеЕсли ЗначениеЗаполнено(ДокументУчета)
		И Пакет.СлужебнаяИнформация.Свойство("ПараметрыПереотправки")
		И Пакет.СлужебнаяИнформация.ПараметрыПереотправки.ВыполнитьУдалениеНеактуальныхДокументовПакета Тогда
		
		Идентификаторы = Пакет.СлужебнаяИнформация.ПараметрыПереотправки.ПереотправляемыйПакет;
		Идентификаторы.BoxId = Пакет.Идентификаторы.BoxId;
		
		Пакеты_ОчиститьНастройки_1С(Идентификаторы);
		
		ДопРеквизиты_УстановитьЗначение_1С(
			ДокументУчета,
			ИменаСвойствНастроек_1С.ПереотправляемыйПакет,
			Идентификаторы.LetterId);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Заполняет для документа учета связанного пакета доп.свойство с идентификатором основного пакета (документа)
//
// Параметры:
//  Пакет					 - Структура - заполненный контракт связанного пакета
//  ИменаСвойствНастроек_1С	 - Структура - программное перечисление имен свойств (см. Перечисление_ИменаСвойствНастроек_1С)
//
Процедура Пакеты_ЗаписатьСвязанныеПакеты_1C(Пакет, ИменаСвойствНастроек_1С)
	
	LetterId = Пакет.Идентификаторы.LetterId;
		
	ПараметрыОтправки 	= СвойствоСтруктуры(Пакет.СлужебнаяИнформация, "ПараметрыОтправки", Неопределено);
	СвязанныеПакеты 	= СвойствоСтруктуры(ПараметрыОтправки, "СвязанныеПакеты", Новый Массив);
	
	Для Каждого ОписаниеСвязанногоПакета Из СвязанныеПакеты Цикл
		
		ИмяСвойства_ОсновнойСвязанныйПакет = ИменаСвойствНастроек_1С.ОсновнойСвязанныйПакет;	
		
		ДопРеквизиты_УстановитьЗначение_1С(ОписаниеСвязанногоПакета.ДокументУчета, ИмяСвойства_ОсновнойСвязанныйПакет, LetterId);
		
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_МассивКонтрактовДокументовПакета_1С(Идентификаторы)

	Результат = Новый Массив;
	
	МассивИдентификаторовДокументов	= Пакеты_ДокументыПакетаАПИ(Идентификаторы);
	
	Для Каждого ИдентификаторыДокумента Из МассивИдентификаторовДокументов Цикл
		
		Документ = Документы_ДанныеДокумента_1С(ИдентификаторыДокумента, ИдентификаторыДокумента.ДокументАПИ);
		Документы_ДополнитьДаннымиИнформационнойБазы_1С(Документ);
		
		Результат.Добавить(Документ);
		
	КонецЦикла;
	
	Пакеты_ДозаполнитьИдентификаторВидаПакета_1С(Результат);
	
	Возврат Результат;

КонецФункции

Функция Пакеты_ДокументУчета_1С(Идентификаторы)
	
	Результат = Неопределено;
	
	LetterId = СвойствоСтруктуры(Идентификаторы, "LetterId", "");
	ПеречислениеНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	Если LetterId <> "" Тогда
		
		Результат = Свойства_ЗначениеОбъекта(ПеречислениеНастроек.ДокументУчетаПакета, LetterId);
		Если НЕ ЗначениеЗаполнено(Результат) Тогда
			Результат = Свойства_ЗначениеОбъекта(ПеречислениеНастроек.ДокументУчетаПакетаСчет, LetterId);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ОчиститьНастройки_1С(Идентификаторы)
	
	ДокументУчета = Пакеты_ДокументУчета_1С(Идентификаторы);
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	ДопРеквизиты_УдалитьЗначение_1С(ДокументУчета, ИменаСвойствНастроек.ДокументУчетаПакета);
	ДопРеквизиты_УдалитьЗначение_1С(ДокументУчета, ИменаСвойствНастроек.ДокументУчетаПакетаСчет);
	
	ДокументыПакета = Пакеты_МассивКонтрактовДокументовПакета_1С(Идентификаторы);
	
	Для Каждого Документ Из ДокументыПакета Цикл
		Документы_ОчиститьНастройки_1С(Документ.Идентификаторы);
	КонецЦикла;
	
КонецПроцедуры

Функция Пакеты_ПереотправляемыйПакет_1С(ДокументУчета)
	
	Результат = Свойства_ЗначениеСвойства(Перечисление_ИменаСвойствНастроек_1С().ПереотправляемыйПакет, ДокументУчета);
	
	Возврат Результат;
	
КонецФункции	

Процедура Пакеты_ДозаполнитьИдентификаторВидаПакета_1С(ДокументыПакета)
	
	ИдентификаторВидаПакета = Неопределено;
	
	Для Каждого Документ Из ДокументыПакета Цикл
		
		Если ЗначениеЗаполнено(Документ.ИдентификаторВидаПакета) Тогда
			ИдентификаторВидаПакета = Документ.ИдентификаторВидаПакета;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ИдентификаторВидаПакета) Тогда
		
		Для Каждого Документ Из ДокументыПакета Цикл
			
			Если НЕ ЗначениеЗаполнено(Документ.ИдентификаторВидаПакета) Тогда
				Документ.ИдентификаторВидаПакета = ИдентификаторВидаПакета;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

