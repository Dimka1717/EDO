Процедура Запросы_ЗаполнитьПараметрыСвойствИдентификаторовДокумента(Запрос)
	
	СвойстваИдентификаторовДокументов = Новый Массив;
	СвойстваИдентификаторовДокументов.Добавить(Свойства_ИдентификаторДокумента());
	СвойстваИдентификаторовДокументов.Добавить(Свойства_ИдентификаторСчетаУФ());
	СвойстваИдентификаторовДокументов.Добавить(Свойства_ИдентификаторСчетаОФ());
	
	Запрос.УстановитьПараметр("СвойстваИдентификаторовДокументов", СвойстваИдентификаторовДокументов);
	
	СвойстваИдентификаторовЯщиков = Новый Массив;
