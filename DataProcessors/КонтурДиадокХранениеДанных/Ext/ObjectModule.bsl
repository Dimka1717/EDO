Функция Подразделения_ЗаполненныеСвязиВТаблицеКонтрактов_1С(ТаблицаКонтрактов, ДляОрганизации)
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID,
	|	ТаблицаКонтрактов.ИНН,
	|	ТаблицаКонтрактов.КПП,
	|	ТаблицаКонтрактов.Наименование,
	|	ТаблицаКонтрактов.Аббревиатура,
	|	ТаблицаКонтрактов.ID_ОсновноеПодразделение,
	|	ТаблицаКонтрактов.ID_ВладелецПодразделения,
	|	ТаблицаКонтрактов.ID_РодительПодразделения
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_ТаблицаКонтрактов.ID,
	|	МАКСИМУМ(ЗначенияСвойствОбъектов.Объект) КАК Связь1
	|ПОМЕСТИТЬ ВТ_ПервыйСвязанный
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ПО ВТ_ТаблицаКонтрактов.ID = ЗначенияСвойствОбъектов.Значение
	|			И (ЗначенияСвойствОбъектов.Свойство = &Свойство_BoxId)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ТаблицаКонтрактов.ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ
	|	ВТ_ТаблицаКонтрактов.ID,
	|	ВТ_ТаблицаКонтрактов.ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование,
	|	ВТ_ТаблицаКонтрактов.Аббревиатура,
	|	ВТ_ТаблицаКонтрактов.ID_ОсновноеПодразделение,
	|	ВТ_ТаблицаКонтрактов.ID_ВладелецПодразделения,
	|	ВТ_ТаблицаКонтрактов.ID_РодительПодразделения,
	|	ВТ_ПервыйСвязанный.Связь1 КАК СвязанныйСправочник1,
	|	НЕОПРЕДЕЛЕНО КАК Ссылка
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПервыйСвязанный КАК ВТ_ПервыйСвязанный
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_ПервыйСвязанный.ID
	|;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ ВТ_ТаблицаКонтрактов
	|;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ ВТ_ПервыйСвязанный";
		
	ИмяСвойства = ИмяСвойстваПодразделения(ДляОрганизации);
	
	Запрос.УстановитьПараметр("Свойство_BoxId", 	ИмяСвойства);
	Запрос.УстановитьПараметр("ТаблицаКонтрактов",	ТаблицаКонтрактов);
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Процедура Подразделения_ОбновлениеРеквизитов_1С(Подразделение, СтруктураРеквизитов, ДляОрганизации)
	
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		ID = СвойствоСтруктуры(Подразделение, "ID", "");
		
		Подразделения_ОчиститьНастройки_1С(ID, ДляОрганизации);
		
		ИмяСвойства = ИмяСвойстваПодразделения(ДляОрганизации);
							
		Для каждого ЭлементКоллекции Из СтруктураРеквизитов.СвязанныеСправочники Цикл
			Если ЗначениеЗаполнено(ЭлементКоллекции.Ссылка) Тогда
				ДопРеквизиты_УстановитьЗначение_1С(ЭлементКоллекции.Ссылка, ИмяСвойства, ID);
			КонецЕсли;	
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Подразделения_ОчиститьНастройки_1С(ID, ДляОрганизации)
	
	МассивСопоставленных	= Подразделения_МассивСопоставленныхВ1С_1С(Новый Структура("ID", ID), ДляОрганизации);
	ИмяСвойства				= ИмяСвойстваПодразделения(ДляОрганизации);
	
	Для Каждого СвязанныйСправочник Из МассивСопоставленных Цикл
		ДопРеквизиты_УдалитьЗначение_1С(СвязанныйСправочник, ИмяСвойства);
	КонецЦикла;	
	
КонецПроцедуры

