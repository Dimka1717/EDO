Функция ДопРеквизиты_ЗначениеШифрованияДокумента_Диадок(ИдентификаторыОрганизации, ИдентификаторыКонтрагента)
	
	ОрганизацияЭДО	= СвойствоСтруктуры(ИдентификаторыОрганизации, "Ссылка");
	КонтрагентЭДО	= СвойствоСтруктуры(ИдентификаторыКонтрагента, "Ссылка");
	
	Если КонтрагентЭДО = Неопределено Тогда
		КонтрагентЭДО = Контрагенты_ПустаяСсылка_Диадок();
	КонецЕсли;
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО",	ОрганизацияЭДО);
	СтруктураДанных.Вставить("КонтрагентЭДО",	КонтрагентЭДО);
	СтруктураДанных.Вставить("ИмяСвойства",		Перечисление_ИменаСвойствНастроек_Диадок().ШифроватьДокументы);
	
	Результат = Справочники_ЗначениеЗаписиНастроекКонтрагентов_Диадок(СтруктураДанных);
	
	Возврат Результат;
	
