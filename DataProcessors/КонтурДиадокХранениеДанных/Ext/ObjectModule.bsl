// Заполняет список документов данными документов из API и дополняет данными информационной базы 
//
// Параметры:
//  СписокДокументов - ТаблицаЗначений 	- см. Ядро.Новый_СписокДокументов()
//  ДокументыАПИ	 - Массив	 		- массив структур, содержащий идентификаторы документов и данные документов, полученные из API
//  ОтборПоСтатусу	 - Строка	 		- значение статуса документа, по которому выполняется отбор, если заполнен 
//
Процедура СписокДокументов_ЗаполнитьДаннымиДокументовАПИ_1С(СписокДокументов, ДокументыАПИ, ОтборПоСтатусу)
	
	ТаблицаДокументовАПИ = СписокДокументов_МассивДокументовАПИвТаблицуЗначений(ДокументыАПИ, ОтборПоСтатусу);
	
	ИдентификаторыДокументов = ТаблицаДокументовАПИ.Скопировать(, "АдресЯщика, ИдентификаторДокумента");
	ДокументыИБ = СписокДокументов_ДокументыИнформационнойБазы(ИдентификаторыДокументов);
	
	Для Каждого СтрокаДокументАПИ Из ТаблицаДокументовАПИ Цикл
		
		КонтрактДокументаЭДО = СтрокаДокументАПИ.Документ;

		Отбор = Новый Структура("АдресЯщика, ИдентификаторДокумента");
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаДокументАПИ);
				
		НайденныеСтроки = ДокументыИБ.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() > 0 Тогда
			КонтрактДокументаЭДО.ДокументУчета = НайденныеСтроки[0].Документ;
		КонецЕсли;
		
		СтрокаСписка = СписокДокументов.Добавить();
		СписокДокументов_ЗаполнитьСтрокуСпискаПоДокументу_1С(СтрокаСписка, КонтрактДокументаЭДО);
		
	КонецЦикла;
	
КонецПроцедуры

Функция СписокДокументов_МассивДокументовАПИвТаблицуЗначений(ДокументыАПИ, ОтборПоСтатусу)
	
	Результат = Новый_ТаблицаДокументовАПИ();
	
	Для Каждого Идентификаторы Из ДокументыАПИ Цикл
		
		ДокументАПИ	= СвойствоСтруктуры(Идентификаторы, "ДокументАПИ");
		
		ДокументПодходитПоСтатусу = СписокДокументов_ДокументПодходитПоСтатусу_1С(ДокументАПИ, ОтборПоСтатусу);
		
		Если ДокументПодходитПоСтатусу Тогда
			
			Документ 	= Документы_ДанныеДокумента_1С(Идентификаторы, ДокументАПИ);
			ИдДокумента = Документы_ИдентификаторДокумента_1С(Идентификаторы);
            АдресЯщика 	= ИдентификаторВАдресЯщика(Идентификаторы.BoxID);
			
			НоваяСтрока = Результат.Добавить();
						
			НоваяСтрока.ИдентификаторДокумента 	= ИдДокумента;
			НоваяСтрока.АдресЯщика 				= АдресЯщика;
			НоваяСтрока.Документ 				= Документ;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Формирует коллекцию документов информационной базы с идентификаторами API
//
// Параметры:
//  ИдентификаторыДокументов - ТаблицаЗначений	 - см. Новый_КоллекцияКлючейДокументовИнформационнойБазы()
// 
// Возвращаемое значение:
//  ТаблицаЗначений - ссылки на документы и значения их свойств
//		* Документ 					- Ссылка - ссылка на документ информационной базы
//		* ИдентификаторДокумента 	- Строка - идентификатор документа в информационной базе, составленный из пары LetterID и DocumentID
//		* АдресЯщика				- Строка - идентфикатор ящика в виде адреса <guid>@diadoc.ru
//		* ВидПакета					- Строка - идентфикатор вида пакета (напр. ID_УПД, ID_УПД_раздельно, ID_УКД и др.)
//
Функция СписокДокументов_ДокументыИнформационнойБазы(ИдентификаторыДокументов)

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таб.АдресЯщика,
	|	Таб.ИдентификаторДокумента
	|ПОМЕСТИТЬ ВремИдДокументов
	|ИЗ
	|	&ВнешняяТаблица КАК Таб
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект КАК Документ,
	|	ВремИдДокументов.ИдентификаторДокумента,
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов_Организации.Значение КАК СТРОКА(100)) КАК АдресЯщика
	|ПОМЕСТИТЬ ВремВсеДокументы
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремИдДокументов КАК ВремИдДокументов
	|		ПО ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(100)) = ВремИдДокументов.ИдентификаторДокумента
	|			И (ЗначенияСвойствОбъектов.Свойство В (&СвойстваИдентификаторовДокументов))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов_Организации
	|		ПО ЗначенияСвойствОбъектов.Объект = ЗначенияСвойствОбъектов_Организации.Объект
	|			И (ЗначенияСвойствОбъектов_Организации.Свойство В (&СвойстваИдентификаторовЯщика))
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВремВсеДокументы.Документ,
	|	ВремИдДокументов.ИдентификаторДокумента,
	|	ВремИдДокументов.АдресЯщика
	|ИЗ
	|	ВремИдДокументов КАК ВремИдДокументов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремВсеДокументы КАК ВремВсеДокументы
	|		ПО ВремИдДокументов.АдресЯщика = ВремВсеДокументы.АдресЯщика
	|			И ВремИдДокументов.ИдентификаторДокумента = ВремВсеДокументы.ИдентификаторДокумента";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	Запрос.УстановитьПараметр("ВнешняяТаблица", ИдентификаторыДокументов);
	Запросы_ЗаполнитьПараметрыСвойствИдентификаторовДокумента(Запрос);
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = РезультатЗапроса.Выгрузить();

	Результат.Индексы.Добавить("АдресЯщика, ИдентификаторДокумента");
	
	МенеджерВременныхТаблиц.Закрыть();
	
	Возврат Результат;

КонецФункции

Процедура СписокДокументов_ДополнитьСписокИдентификаторамиВидовПакетов(СписокДокументов)
	
	СписокДокументов.Индексы.Добавить("Документ");
	
	ДокументыИБ = СписокДокументов.ВыгрузитьКолонку("Документ");
	Общее_УдалитьПустыеЭлементыМассива(ДокументыИБ);
	
	Выборка = ПолучитьВыборкуПоСвойствамДокументовУчета_1С(ДокументыИБ);
	Пока Выборка.Следующий() Цикл
		
		ПараметрыПоискаСтрок = Новый Структура("Документ", Выборка.Документ);
		СтрокиПоиска = СписокДокументов.НайтиСтроки(ПараметрыПоискаСтрок);
		
		Для Каждого СтрокаСписка Из СтрокиПоиска Цикл 	
			
			ВидПакетаID = ВидПакетаПоДокументуУчета_1С(СтрокаСписка.ТипДокумента, 
				СтрокаСписка.Документ,
				Выборка.ИдентификаторВидаПакетаСчет,
				Выборка.ИдентификаторВидаПакета
			);
			
			СтрокаСписка.ВидПакетаID = ВидПакетаID;
			ВидПакета = Списки_ОписаниеВидаПакета(ВидПакетаID);
			
			Если ВидПакета <> Неопределено Тогда
				СтрокаСписка.ВидПакета	= ВидПакета.Наименование;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция Тип_СчетНаОплату()

	Возврат "ProformaInvoice";

КонецФункции

Функция Новый_ТаблицаДокументовАПИ()
	
	ТипЗначенияКолонки = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИдентификаторДокумента", ТипЗначенияКолонки);
	Результат.Колонки.Добавить("АдресЯщика", ТипЗначенияКолонки);
	Результат.Колонки.Добавить("Документ");
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_ДополненныеПараметрыНаОтправку_1С(Параметры)
	
	Результат = Параметры;
	
	Результат.Вставить("ТаблицаКонтрагентов",						Новый ТаблицаЗначений);
	Результат.Вставить("Свойство_IDОрганизации",					Неопределено);
	Результат.Вставить("Свойство_IDКонтрагента",					Неопределено);
	Результат.Вставить("Свойство_ВидПакета",						Неопределено);
	Результат.Вставить("Свойство_ОсновнойПакет",					Неопределено);
	Результат.Вставить("Свойство_ОтправлятьНепроведенныеДокументы",	Неопределено);
	Результат.Вставить("СвойстваИдентификаторовДокументов",			Новый Массив);
			
	Результат.ТаблицаКонтрагентов = СписокДокументов_ТаблицаКонтрагентовДляОтправки();
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	Результат.Свойство_IDОрганизации					= Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.IDОрганизации, Ложь);
	Результат.Свойство_IDКонтрагента					= Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.IDКонтрагента, Ложь);
	Результат.Свойство_ВидПакета						= Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ВидПакета);
	Результат.Свойство_ОсновнойПакет					= Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ОсновнойПакет);
	Результат.Свойство_ОтправлятьНепроведенныеДокументы	= Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ОтправлятьНепроведенныеДокументы, Ложь);
	
	Результат.СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторДокумента, Ложь));
	Результат.СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторСчетаУФ, Ложь));
	Результат.СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторСчетаОФ, Ложь));

	ТаблицаВидовПакетов = Параметры.ТаблицаВидовПакетов;
	
	ИмяТипаСвойств = "ПланВидовХарактеристикСсылка." + Свойства_ИмяПланаВидовХарактеристик();
	ТаблицаВидовПакетов.Колонки.Добавить("КатегорияПакетаСсылка", Новый ОписаниеТипов(ИмяТипаСвойств));
		
	Для Каждого ВидПакета Из ТаблицаВидовПакетов Цикл
		
		Если ЗначениеЗаполнено(ВидПакета.КатегорияПакета) Тогда
			ВидПакета.КатегорияПакетаСсылка = Свойства_СсылкаНаСвойство(ВидПакета.КатегорияПакета);
		КонецЕсли;
						
	КонецЦикла;
					
	Возврат Результат;
	
КонецФункции

Процедура СписокДокументов_ЗаполнитьСтрокуСпискаПоДокументу_1С(Результат, Документ)
	
	Результат.ВидПакетаID		= Документ.ИдентификаторВидаПакета;
	Результат.ВидЭлДокументаID	= Документ.ИдентификаторВида;
	Результат.ДокументЭДО		= Документ.Идентификаторы.ДокументЭДО;
	Результат.Документ			= Документ.ДокументУчета;
	
	Результат.ТипДокумента		= Документ.Тип.ТипДокумента;
	Результат.ФункцияДокумента	= Документ.Тип.ФункцияДокумента;
	
	Результат.Направление			= Документ.Направление;
	Результат.Документ				= Документ.ДокументУчета;
	Результат.Метка					= Документ.Состояние;
	Результат.ДатаОтправки      	= Документ.ДатаЭДО;
	Результат.ДатаПолучения      	= Документ.ДатаЭДО;
	Результат.ЗаблокированныйПакет	= Документ.Заблокирован;
	Результат.Шаблон				= Документ.Шаблон;
	Результат.BoxId					= Документ.Идентификаторы.BoxId;
	Результат.LetterId				= Документ.Идентификаторы.LetterId;
	Результат.DocumentId			= Документ.Идентификаторы.DocumentId;
	Результат.ТребуетсяРасшифровка	= СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ТребуетсяРасшифровка", Ложь);
	
	Реквизиты = Документ.Реквизиты;
	Результат.ДатаДокумента		= Реквизиты.Дата;
	Результат.НомерДокумента	= Реквизиты.Номер;
	Результат.СуммаДокумента	= Реквизиты.Сумма;
	
	Статусы = Документ.Статусы;
	Результат.Статус = Статусы.Статус;
	Результат.ДополнительныйСтатус = Статусы.ДополнительныйСтатус;
	
	Результат.ОбъектМаршрутизации = Статусы.ОбъектМаршрутизации.Наименование;
	
	Результат.ВнешнийСтатус = Ядро_ПредставлениеВнешнихСтатусов(Статусы.ВнешниеСтатусы);
	Результат.СтатусМЧД = Статусы.СтатусМЧД;
	Результат.СтатусМЧДКритичность = Статусы.СтатусМЧДКритичность;
	
	Результат.СтатусПКФНС = Статусы.СтатусПКФНС;
	Результат.СтатусПКФНСКритичность = Статусы.СтатусПКФНСКритичность;
	
	Результат.СтатусТЭДО = Статусы.СтатусДТС;
	
	Результат.АнализПроведен		= Ложь;
	Результат.ОшибкиПроверкиТекст	= "";
	Результат.ДействиеВ1С			= "";
	Результат.ДействиеВДД			= "";
	Результат.ОшибкиПроверкиТекст	= "";
	
	Если Документ.Направление = Перечисление_Направления().Исходящее Тогда
		
		Результат.Организация	= Документ.Отправитель.Организация;
		Результат.Контрагент	= Документ.Получатель.Организация;
		Результат.ПредставлениеКонтрагентаЭДО = СокрЛП(Документ.Получатель.Наименование);
		
		ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(, Документ.Отправитель.BoxId);
		ИдентификаторыПодразделения = Новый_ИдентификаторыСправочника(, Документ.Отправитель.DepartmentId);
		
		ДанныеВладельца = ХранениеДанных_ДанныеОрганизации(ИдентификаторыОрганизации);
		Подразделение	= Подразделения_ДанныеПодразделения_1С(ИдентификаторыПодразделения, ДанныеВладельца, Истина);
		Результат.Подразделение = Подразделение.Наименование;
		
	ИначеЕсли Документ.Направление = Перечисление_Направления().Внутреннее Тогда
		
		Результат.Организация	= Документ.Отправитель.Организация;
		Результат.Контрагент	= Документ.Отправитель.Организация;
		Результат.ПредставлениеКонтрагентаЭДО = СокрЛП(Документ.Отправитель.Наименование);
		
		ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(, Документ.Получатель.BoxId);
		ИдентификаторыПодразделенияПолучателя = Новый_ИдентификаторыСправочника(, Документ.Получатель.DepartmentId);
		ИдентификаторыПодразделенияОтправителя = Новый_ИдентификаторыСправочника(, Документ.Отправитель.DepartmentId);
		
		ДанныеВладельца = ХранениеДанных_ДанныеОрганизации(ИдентификаторыОрганизации);
		ПодразделениеПолучатель = Подразделения_ДанныеПодразделения_1С(ИдентификаторыПодразделенияПолучателя, ДанныеВладельца, Истина); 
		ПодразделениеОтправитель = Подразделения_ДанныеПодразделения_1С(ИдентификаторыПодразделенияОтправителя, ДанныеВладельца, Истина);
		Подразделение	= Подразделения_ДанныеПодразделения_1С(ПодразделениеПолучатель, ДанныеВладельца, Истина);
		
		Результат.Подразделение = Подразделение.Наименование;
		Результат.ПодразделениеПолучатель = ПодразделениеПолучатель.Наименование;
		Результат.ПодразделениеОтправитель = ПодразделениеОтправитель.Наименование;
		
	Иначе
		
		Результат.Организация	= Документ.Получатель.Организация;
		Результат.Контрагент	= Документ.Отправитель.Организация;
		Результат.ПредставлениеКонтрагентаЭДО = СокрЛП(Документ.Отправитель.Наименование);
		
		ИдентификаторыОрганизации	= Новый_ИдентификаторыСправочника(, Документ.Получатель.BoxId);
		ИдентификаторыПодразделения = Новый_ИдентификаторыСправочника(, Документ.Получатель.DepartmentId);
		
		ДанныеВладельца = ХранениеДанных_ДанныеОрганизации(ИдентификаторыОрганизации);
		Подразделение	= Подразделения_ДанныеПодразделения_1С(ИдентификаторыПодразделения, ДанныеВладельца, Истина);
		Результат.Подразделение = Подразделение.Наименование;
	
	КонецЕсли;
	
	ВидПакета = Списки_ОписаниеВидаПакета(Результат.ВидПакетаID);
	
	Если ВидПакета <> Неопределено Тогда
		Результат.ВидПакета	= ВидПакета.Наименование;
	КонецЕсли;
	
	ВидДокумента = Списки_ОписаниеВидаДокумента(Результат.ВидЭлДокументаID);
	
	Если ВидДокумента <> Неопределено Тогда
		Результат.ВидЭлДокумента = ВидДокумента.Наименование;
	КонецЕсли;
	
	Результат.ПредставлениеДокументаДиадок = Документ.ИмяФайла;
	
КонецПроцедуры

Функция СписокДокументов_ДокументПодходитПоСтатусу_1С(ДокументАПИ, ОтборПоСтатусу)
	
	Результат = Истина;
	
	СтатусАПИ = ДокументАПИ.DocflowStatus.PrimaryStatus;
	Если СтатусАПИ.Свойство("StatusText") Тогда
		
		СтатусДокументаАПИ = СтатусАПИ.StatusText;	
		
		Если ЗначениеЗаполнено(ОтборПоСтатусу)
			И Найти(СтатусДокументаАПИ, ОтборПоСтатусу) = 0 Тогда
			
			Результат = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура СписокДокументов_ДозаполнитьВидыПакетов_1С(СписокДокументов)
	
	ИдентификаторыВидовПакетов	= Новый Соответствие;
	НаименованияВидовПакетов	= Новый Соответствие;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		
		Если ЗначениеЗаполнено(СтрокаСписка.ВидПакетаID) Тогда
			
			ИдентификаторыВидовПакетов.Вставить(СтрокаСписка.LetterId,  СтрокаСписка.ВидПакетаID);
			НаименованияВидовПакетов.Вставить(СтрокаСписка.LetterId, СтрокаСписка.ВидПакета);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаСписка.ВидПакетаID) Тогда
			
			ВидПакетаID	= ИдентификаторыВидовПакетов.Получить(СтрокаСписка.LetterId);
			ВидПакета	= НаименованияВидовПакетов.Получить(СтрокаСписка.LetterId);
			
			Если ВидПакетаID <> Неопределено Тогда
				
				СтрокаСписка.ВидПакетаID	= ВидПакетаID;
				СтрокаСписка.ВидПакета		= ВидПакета;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция Ядро_ПредставлениеВнешнихСтатусов(ВнешниеСтатусы)
	
	Результат = Ядро.СписокДокументов_ПредставлениеВнешнихСтатусов(ВнешниеСтатусы);
	Возврат Результат;
	
КонецФункции

