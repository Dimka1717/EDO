Функция Пакеты_Записать(Пакет) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Пакеты_Записать_Диадок(Пакет);
	Иначе
		Результат = Пакеты_Записать_1С(Пакет);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ЗаписатьПоДокументу(Документ)
	
	Результат = Неопределено;
	
	Пакет = Контракт_Пакет();
	
	ЗаполнитьЗначенияСвойств(Пакет,					Документ, "Направление, ДокументУчета, ДатаЭДО, Состояние, Заблокирован, ИдентификаторВида");
	ЗаполнитьЗначенияСвойств(Пакет.Реквизиты,		Документ.Реквизиты);
	ЗаполнитьЗначенияСвойств(Пакет.Идентификаторы,	Документ.Идентификаторы);
	ЗаполнитьЗначенияСвойств(Пакет.Отправитель,		Документ.Отправитель);
	ЗаполнитьЗначенияСвойств(Пакет.Получатель,		Документ.Получатель);
	
	ЗашифрованныйПакет = СвойствоСтруктуры(Документ.СлужебнаяИнформация, "ЗашифрованныйПакет", Ложь);
	Пакет.СлужебнаяИнформация.Вставить("ЗашифрованныйПакет", ЗашифрованныйПакет);
	
	Результат = Пакеты_Записать(Пакет);

	Возврат Результат;
	
КонецФункции

Функция Пакеты_ДокументУчета(Идентификаторы) Экспорт 
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Пакеты_ДокументУчета_Диадок(Идентификаторы);
