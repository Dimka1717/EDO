// Заполняет общие настройки
//
// Возвращаемое значение: Структура
//
Функция Настройки_ОбщиеНастройки() Экспорт
	
	Результат = Кэш_Прочитать("ОбщиеНастройки");
	
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ОбщиеНастройки_Диадок();
	Иначе
		Результат = Настройки_ОбщиеНастройки_1С();
	КонецЕсли;
	
	// дефолтные настройки, не заданные в предыдущем релизе модуля
	Если ТипЗнч(Результат.ХранитьДокументыНаДиске) <> Тип("Булево") Тогда
		Результат.ХранитьДокументыНаДиске = Ложь;
	КонецЕсли;
	
	Если Результат.СрокОчисткиДокументов = Неопределено Тогда
		Результат.СрокОчисткиДокументов = 0;
	КонецЕсли;
	
	Если ТипЗнч(Результат.ОтключитьПревьюНеформализованного) <> Тип("Булево") Тогда
		Результат.ОтключитьПревьюНеформализованного = Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Результат.ОтключитьКонтрольДублированияОтправкиПакетов) <> Тип("Булево") Тогда
		Результат.ОтключитьКонтрольДублированияОтправкиПакетов = Ложь;
	КонецЕсли;
	
	Если Не ПриложениеСтаршеВерсии("8.3.14") Тогда
		Результат.ОтключитьПревьюНеформализованного = Истина;
	КонецЕсли;
	
	Если ТипЗнч(Результат.УдалятьПриПереотправкеПредыдущийДокумент) <> Тип("Булево") Тогда
		Результат.УдалятьПриПереотправкеПредыдущийДокумент = Ложь;
	КонецЕсли;
	
	Если Результат.ИдентификаторБазы1С = "" Тогда
		
		Результат.ИдентификаторБазы1С = Новый УникальныйИдентификатор;
		
		Если Результат.СохраненнаяВерсияМодуля <> "0.0.0" Тогда
			Настройки_ЗаписатьОбщиеНастройки(Результат);
		КонецЕсли;
		
	КонецЕсли;
	
	Настройки_Конвертация970_ЗаполнитьЗначениеПоУмолчанию(Результат);
	
	Результат = ОбщиеНастройки_ОбработанныеЗначенияПослеЧтения(Результат);
	
	Настройки_ОбщиеНастройки_УстановитьКэш(Результат);
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗаписатьОбщиеНастройки(СтруктураНастроек) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ЗаписатьОбщиеНастройки_Диадок(СтруктураНастроек);
	Иначе
		Результат = Настройки_ЗаписатьОбщиеНастройки_1С(СтруктураНастроек);
		СтруктураНастроек.ПодключаемыйМодульСсылка = ПодключаемыйМодульСсылка(СтруктураНастроек);
	КонецЕсли;
	
	СтруктураНастроек = ОбщиеНастройки_ОбработанныеЗначенияПослеЧтения(СтруктураНастроек);
	
	Настройки_ОбщиеНастройки_УстановитьКэш(СтруктураНастроек);
	
	Возврат Результат;
	
КонецФункции 

Функция Настройки_Конвертация970_РежимыСовместимостиФорматов820и970()

	Результат = Новый Структура;
	Результат.Вставить("НеИспользуется", "НеИспользуется");
	Результат.Вставить("Авто", "Авто");
	
	Возврат Результат;
	
КонецФункции

Процедура Настройки_Конвертация970_ЗаполнитьЗначениеПоУмолчанию(ОбщиеНастройки)
	
	Если ОбщиеНастройки.РежимСовместимостиФорматов820и970 = Неопределено Тогда
		РежимСовместимости = Настройки_Конвертация970_РежимыСовместимостиФорматов820и970().НеИспользуется;
		ОбщиеНастройки.РежимСовместимостиФорматов820и970 = РежимСовместимости;
	КонецЕсли;

КонецПроцедуры

Функция Настройки_Конвертация970_УстановленаНастройкаРежимаСовместимостиФорматовАвто() Экспорт
	
	ОбщиеНастройки = Настройки_ОбщиеНастройки();
	
	ТекущийРежимСовместимости = ОбщиеНастройки.РежимСовместимостиФорматов820и970;
	РежимыСовместимости = Настройки_Конвертация970_РежимыСовместимостиФорматов820и970();
		
	Результат = (ТекущийРежимСовместимости = РежимыСовместимости.Авто);
	
	Возврат Результат;
	
КонецФункции


// Устанавливает кэш общих настроек
// Вызывается также из ядра при выполнении фонового задания
//
// Параметры:
//  ОбщиеНастройки - Структура -  см. функцию Настройки_ОбщиеНастройки
//
Процедура Настройки_ОбщиеНастройки_УстановитьКэш(ОбщиеНастройки) Экспорт
	
	Кэш_Поместить("ОбщиеНастройки", ОбщиеНастройки);
	
КонецПроцедуры

Функция ОбщиеНастройки_ОбработанныеЗначенияПослеЧтения(ЗначенияНастроек)
	
	Результат = ЗначенияНастроек;
	
	Если ТипЗнч(Результат.СохранениеДокументовИмяКаталогаПакета) = Тип("Строка") Тогда
		
		ПриоритетыИменКаталогаПакета = РазделитьСтрокуЛок(Результат.СохранениеДокументовИмяКаталогаПакета, ";");
		
		Результат.СохранениеДокументовИмяКаталогаПакета = Новый СписокЗначений;
		
		Для Каждого Имя Из ПриоритетыИменКаталогаПакета Цикл
			Если ЗначениеЗаполнено(Имя) Тогда
				Результат.СохранениеДокументовИмяКаталогаПакета.Добавить(Имя);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаполнитьПрокси(Результат);
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьПрокси(Результат)
	
	ПортПроксиСервера = Неопределено;
	Результат.Свойство("ПортПроксиСервера", ПортПроксиСервера);
	Результат.Вставить("ПортПроксиСервера",	?(ЗначениеЗаполнено(ПортПроксиСервера), Число(ПортПроксиСервера), 0));
	
КонецПроцедуры

Функция ПодключаемыйМодульСсылка(СтруктураНастроек)
	
	Результат = Неопределено;
	
	Если СтруктураНастроек.Свойство("ПодключаемыйМодульИмяСправочника")
		И СтруктураНастроек.Свойство("ПодключаемыйМодульСсылка")
		И ЗначениеЗаполнено(СтруктураНастроек.ПодключаемыйМодульИмяСправочника)
		И ЗначениеЗаполнено(СтруктураНастроек.ПодключаемыйМодульСсылка) Тогда
		
		Попытка
			ГУИД = Новый УникальныйИдентификатор(СтруктураНастроек.ПодключаемыйМодульСсылка);
			Результат = Справочники[СтруктураНастроек.ПодключаемыйМодульИмяСправочника].ПолучитьСсылку(ГУИД);
		Исключение
			Сообщить("Не удалось прочитать настройки подключаемого модуля");	
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	


Функция Настройки_ЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ЗначениеСвойства_Диадок(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		Результат = Настройки_ЗначениеСвойства_1С(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает сохраненные в информационной базе настройки видо пакетов документов на отправку в разрезе категорий для организации или контрагента
// (если для контрагента были включена индивидуальная настройка).
//
// Параметры:
//  КатегорииПакетов	 - Массив	 - имена категорий пакетов (например, ОсновнойПакет, КорректировочныйПакет, СчетФактураНаАванс и т.п.)
//  ДанныеОрганизации	 - Структура	- заполненный контракт данных организации (см. Контракт_ОрганизацияЭДО)
//  ДанныеКонтрагента	 - Структура	- заполненный контракт данных контрагента (см. Контракт_КонтрагентЭДО). Необязательный параметр. 
// 
// Возвращаемое значение:
//  Соответствие - Ключ - имя категории, значение - вид пакета (строка (СХ2) или ссылка (СХ1))
//
Функция Настройки_ВидыПакетовНаОтправку(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт

	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ВидыПакетовНаОтправку_Диадок(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		Результат = Свойства_ЗначенияСвойствОбъекта_1С(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает коллекцию установленных форматов документов для видов документов для организации или контрагента
// (если для контрагента были включена индивидуальная настройка).
//
// Параметры:
//  ИдентификаторыВидовДокументов	- Массив 	- массив строк идентификаторов видов документов
//												(пример ид. видов документов: ID_УПД, ID_УКД, ID_ТОРГ12, ID_СчетФактура и др).
//  ДанныеОрганизации	 			- Структура	- заполненный контракт данных организации (см. Контракт_ОрганизацияЭДО)
//  ДанныеКонтрагента	 			- Структура	- заполненный контракт данных контрагента (см. Контракт_КонтрагентЭДО). Необязательный параметр. 
// 
// Возвращаемое значение:
//  Соответствие - ключ - ид. вида документа (строка), значение - формат, установленный для данного вида документа (строка)
//
Функция Настройки_ФорматыВидовПакетовНаОтправку(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт

	Результат = Новый Соответствие;

	ИменаСвойств = Новый Массив;
	Для Каждого ИдВидаДокумента Из ИдентификаторыВидовДокументов Цикл
		ИмяСвойства = "Формат_" + ИдВидаДокумента;
		ИменаСвойств.Добавить(ИмяСвойства);
	КонецЦикла;

	ЗначенияСвойств = Настройки_ЗначенияСвойствОбъекта(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	
	Для Каждого ЭлементКоллекции Из ЗначенияСвойств Цикл
		ИдВидаДокумента = Сред(ЭлементКоллекции.Ключ, 8);
		Результат.Вставить(ИдВидаДокумента, ЭлементКоллекции.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает коллекцию значений свойств в разрезе их (свойств) имен для организации или контрагента
// (если для контрагента были включена индивидуальная настройка).
//
// Параметры:
//  ИменаСвойств		 - Массив	 - имена свойств строкой
//  ДанныеОрганизации	 - Структура	- заполненный контракт данных организации (см. Контракт_ОрганизацияЭДО)
//  ДанныеКонтрагента	 - Структура	- заполненный контракт данных контрагента (см. Контракт_КонтрагентЭДО). Необязательный параметр. 
// 
// Возвращаемое значение:
//  Соответствие - ключ - имя свойства (строка), значение - значение свойства (произвольный тип)
//
Функция Настройки_ЗначенияСвойствОбъекта(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента)
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ЗначенияСвойствОбъекта_Диадок(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		Результат = Свойства_ЗначенияСвойствОбъекта_1С(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// см. Настройки_ВидыПакетовНаОтправку
//
Функция Настройки_ВидыПакетовНаОтправку_Диадок(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента)

	Результат = Новый Соответствие;
	
	ВидДопСправочника = "ВидыПакетов";
	
	ТекстЗапроса = ТекстЗапроса_НастройкиКонтрагентаСПриведениемКТипуЗначений_Диадок(ВидДопСправочника);
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Настройки_ЗаполнитьОбщиеПараметрыЗапроса_Диадок(Запрос, ДанныеОрганизации, ДанныеКонтрагента);
	Запрос.УстановитьПараметр("ИменаСвойств", ИменаСвойств);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.ИмяСвойства, Выборка.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// см. Настройки_ЗначенияСвойствОбъекта 
//
Функция Свойства_ЗначенияСвойствОбъекта_1С(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента)
	
	Результат = Новый Соответствие;

	ТекстЗапроса = ТекстЗапроса_ЗначенияСвойствОбъекта_1С();
	Запрос = Новый Запрос(ТекстЗапроса);
	
	КоллекцияСвойств = Новый Массив;
	Для Каждого ИмяСвойства Из ИменаСвойств Цикл
		Свойство = Свойства_СсылкаНаСвойство(ИмяСвойства);
		КоллекцияСвойств.Добавить(Свойство);
	КонецЦикла;
	
	Если ДанныеКонтрагента <> Неопределено Тогда
		ОбъектНастроек = ДанныеКонтрагента.СвязанныйСправочник1;
	Иначе
		ОбъектНастроек = ДанныеОрганизации.СвязанныйСправочник1;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Свойства", КоллекцияСвойств);
	Запрос.УстановитьПараметр("Объект"	, ОбъектНастроек);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПрефиксИмен = ПрефиксНастройки_1С(Истина);
	
	Пока Выборка.Следующий() Цикл
		ИмяСвойстваБезПрефикса = СтрЗаменить(Выборка.ИмяСвойства, ПрефиксИмен, "");
		Результат.Вставить(ИмяСвойстваБезПрефикса, Выборка.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// см. Настройки_ЗначенияСвойствОбъекта 
//
Функция Настройки_ЗначенияСвойствОбъекта_Диадок(ИменаСвойств, ДанныеОрганизации, ДанныеКонтрагента)
	
	Результат = Новый Соответствие;
	
	ТекстЗапроса = ТекстЗапроса_НастройкиКонтрагента_Диадок();
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Настройки_ЗаполнитьОбщиеПараметрыЗапроса_Диадок(Запрос, ДанныеОрганизации, ДанныеКонтрагента);
	Запрос.УстановитьПараметр("ИменаСвойств", ИменаСвойств);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.ИмяСвойства, Выборка.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Вспомогательный метод, заполняет параметры запроса ОрганизацияЭДО и КонтрагентЭДО
//
Процедура Настройки_ЗаполнитьОбщиеПараметрыЗапроса_Диадок(Запрос, ДанныеОрганизации, ДанныеКонтрагента)
	
	ОрганизацияЭДО = ДанныеОрганизации.Ссылка;
	
	Если ДанныеКонтрагента = Неопределено Тогда
		КонтрагентЭДО = Контрагенты_ПустаяСсылка_Диадок();
	Иначе
		КонтрагентЭДО = ДанныеКонтрагента.Ссылка;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ОрганизацияЭДО"	, ОрганизацияЭДО);
	Запрос.УстановитьПараметр("КонтрагентЭДО"	, КонтрагентЭДО);
	
КонецПроцедуры

Процедура Настройки_ЗаписатьЗначенияСвойств(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Настройки_ЗаписатьЗначенияСвойств_Диадок(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		Настройки_ЗаписатьЗначенияСвойств_1С(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
	
КонецПроцедуры

Процедура Настройки_ЗаписатьКатегорииПакетов(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		Для Каждого Элемент Из КатегорииПакетов Цикл
			
			Если ЗначениеЗаполнено(Элемент.Значение)
				И ТипЗнч(Элемент.Значение) = Тип("Строка") Тогда
				
				ЗначениеДляЗаписи = ДопСправочники_СсылкаПоИдентификатору("ВидыПакетов", Элемент.Значение);
				КатегорииПакетов.Вставить(Элемент.Ключ, ЗначениеДляЗаписи);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	                                                                              
	Настройки_ЗаписатьЗначенияСвойств(КатегорииПакетов, ДанныеОрганизации, ДанныеКонтрагента);
		
КонецПроцедуры

Процедура Настройки_УдалитьЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("ОрганизацияЭДО",	ДанныеОрганизации.Ссылка);
		СтруктураДанных.Вставить("ИмяСвойства",		ИмяСвойства);
		
		Если ДанныеКонтрагента = Неопределено Тогда
			СтруктураДанных.Вставить("КонтрагентЭДО", Контрагенты_ПустаяСсылка_Диадок());
		Иначе
			СтруктураДанных.Вставить("КонтрагентЭДО", ДанныеКонтрагента.Ссылка);
		КонецЕсли;
		
		Справочники_УдалитьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
		
	Иначе
		
		ХранителиСвойств = СвязанныеСправочники(ДанныеОрганизации, ДанныеКонтрагента);
						
		Для Каждого ЭлементКоллекции Из ХранителиСвойств Цикл
		
			ДопРеквизиты_УдалитьЗначение_1С(ЭлементКоллекции.Ссылка, ИмяСвойства);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает значение сохраненной настройки модуля Diadoc.StandartUF "ТочностьЦеныСФ_Диадок"
