Процедура ОбщиеНастройки_УдалитьЗапись(ИмяНастройки) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		ОбщиеНастройки_УдалитьЗапись_Диадок(ИмяНастройки);	
	Иначе
		ОбщиеНастройки_УдалитьЗапись_1С(ИмяНастройки)	
	КонецЕсли;
	
	Настройки_ОбщиеНастройки_УстановитьКэш(Неопределено);
	
КонецПроцедуры

Процедура ОбщиеНастройки_УдалитьЗапись_Диадок(ИмяНастройки)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДопСправочник.Ссылка
	|ИЗ
	|	Справочник.Диадок_ДополнительныеСправочники КАК ДопСправочник
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК ДопРеквизиты
	|		ПО ДопСправочник.Ссылка = ДопРеквизиты.Ссылка
	|ГДЕ
	|	ДопСправочник.Наименование = ""ОбщиеНастройки""
	|	И ДопРеквизиты.ИмяРеквизита = &ИмяРеквизита"
	);
	Запрос.УстановитьПараметр("ИмяРеквизита", ИмяНастройки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		ОбщиеНастройкиОбъект = Выборка.Ссылка.ПолучитьОбъект();
	
		ДопРеквизит = ОбщиеНастройкиОбъект.ДополнительныеРеквизиты.Найти(ИмяНастройки, "ИмяРеквизита");
		ОбщиеНастройкиОбъект.ДополнительныеРеквизиты.Удалить(ДопРеквизит);
		
		ОбщиеНастройкиОбъект.ОбменДанными.Загрузка = Истина;
		ОбщиеНастройкиОбъект.Записать();
		
	КонецЕсли;
		
КонецПроцедуры

Процедура ОбщиеНастройки_УдалитьЗапись_1С(ИмяНастройки)
	
	ИмяСПрефиксом = Истина;
	
	Свойство = Свойства_НайтиСвойство(ИмяНастройки, ИмяСПрефиксом);
	Если Не ЗначениеЗаполнено(Свойство) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектОбщихНастроек = ОбъектОбщихНастроек_1С();
	Если ЗначениеЗаполнено(ОбъектОбщихНастроек) Тогда
		ДопРеквизиты_УдалитьЗначение_1С(ОбъектОбщихНастроек, Свойство);
	КонецЕсли;
	
КонецПроцедуры

// Тексты запросов

Функция ТекстЗапроса_НастройкиКонтрагента_Диадок()
	
	Результат = 
	"ВЫБРАТЬ
	|	НастройкиКонтрагентов.ИмяСвойства 	КАК ИмяСвойства,
	|	НастройкиКонтрагентов.Значение  	КАК Значение
	|	//ДОП_ПОЛЯ
	|//ИМЯ_ВРЕМЕННОЙ_ТАБЛИЦЫ
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК НастройкиКонтрагентов
	|ГДЕ
	|	НастройкиКонтрагентов.Организация = &ОрганизацияЭДО
	|	И НастройкиКонтрагентов.Контрагент = &КонтрагентЭДО
	|	И НастройкиКонтрагентов.ИмяСвойства В (&ИменаСвойств)
	|	//ДОП_ОТБОРЫ";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_НастройкиКонтрагентаСПриведениемКТипуЗначений_Диадок(ВидДопСправочника)
	
	Результат = ТекстЗапроса_НастройкиКонтрагента_Диадок();
	
	Результат = СтрЗаменить(Результат, "//ИМЯ_ВРЕМЕННОЙ_ТАБЛИЦЫ", "ПОМЕСТИТЬ ВремЗначенияНастроек");

	Результат = Результат + ТекстЗапроса_РазделительЗапросов() + 
	"ВЫБРАТЬ
	|	ЗначенияНастроек.ИмяСвойства 	КАК ИмяСвойства,
	|	ЗначенияНастроек.Значение  		КАК Значение
	|ПОМЕСТИТЬ ВремСтроковыеЗначенияНастроек
	|ИЗ
	|	ВремЗначенияНастроек КАК ЗначенияНастроек
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ЗначенияНастроек.Значение) = ТИП(СТРОКА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДопРеквизиты.Ссылка					КАК Ссылка,
	|	СтроковыеЗначенияНастроек.Значение 	КАК Значение
	|ПОМЕСТИТЬ ВремСсылкиНаЗначенияНастроек
	|ИЗ
	|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК ДопРеквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ДополнительныеСправочники КАК ДопСправочники
	|		ПО ДопРеквизиты.Ссылка = ДопСправочники.Ссылка
	|			И (ДопСправочники.ИмяСправочника = """ + ВидДопСправочника + """)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремСтроковыеЗначенияНастроек КАК СтроковыеЗначенияНастроек
	|		ПО ДопРеквизиты.Значение = СтроковыеЗначенияНастроек.Значение
	|ГДЕ  
	|	НЕ ДопСправочники.Ссылка ЕСТЬ NULL
	|	И ДопРеквизиты.ИмяРеквизита = ""ID""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиКонтрагентов.ИмяСвойства КАК ИмяСвойства,
	|	ВЫБОР
	|		КОГДА СсылкиНаЗначенияНастроек.Ссылка ЕСТЬ NULL
	|			ТОГДА НастройкиКонтрагентов.Значение
	|		ИНАЧЕ СсылкиНаЗначенияНастроек.Ссылка
	|	КОНЕЦ КАК Значение
	|ИЗ
	|	ВремЗначенияНастроек КАК НастройкиКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВремСсылкиНаЗначенияНастроек КАК СсылкиНаЗначенияНастроек
	|		ПО НастройкиКонтрагентов.Значение = СсылкиНаЗначенияНастроек.Значение";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ЗначенияСвойствОбъекта_1С()
	
	Результат =	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойств.Свойство				КАК Свойство,
	|	ЗначенияСвойств.Свойство.Наименование 	КАК ИмяСвойства,
	|	ЗначенияСвойств.Значение 				КАК Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойств
	|ГДЕ
	|	ЗначенияСвойств.Свойство В (&Свойства)
	|	И ЗначенияСвойств.Объект = &Объект";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Результат);
	
	Возврат Результат;
	
КонецФункции

