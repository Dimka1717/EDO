Функция Документы_ДанныеДокумента_1С(Идентификаторы, ДокументАПИ = Неопределено)
	
	BoxID		= Идентификаторы.BoxID;
	LetterId	= Идентификаторы.LetterId;
	DocumentId	= Идентификаторы.DocumentId;
	
	Если ДокументАПИ = Неопределено Тогда
		ДокументАПИ = API_GetDocument(BoxId, LetterId, DocumentId);
	КонецЕсли;
	
	Результат = Документы_КонтрактПоДокументуАПИ(BoxID, ДокументАПИ);
	
	Результат.Идентификаторы.BoxID = BoxID;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_КоллекцияСопоставленныхВ1С(Идентификаторы)

	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов_Организации
	|		ПО ЗначенияСвойствОбъектов.Объект = ЗначенияСвойствОбъектов_Организации.Объект
	|			И (ЗначенияСвойствОбъектов.Свойство В (&СвойстваИдентификаторовДокументов))
	|			И (ЗначенияСвойствОбъектов_Организации.Свойство В (&СвойстваИдентификаторовЯщика))
	|			И (ЗначенияСвойствОбъектов_Организации.Значение = &IDОрганизации)
	|			И (ЗначенияСвойствОбъектов.Значение = &ИдентификаторДокумента)";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	IDОрганизации			= ИдентификаторВАдресЯщика(Идентификаторы.BoxID);
	ИдентификаторДокумента	= Документы_ИдентификаторДокумента_1С(Идентификаторы);
	
	Запрос.УстановитьПараметр("ИдентификаторДокумента",	ИдентификаторДокумента);
	Запрос.УстановитьПараметр("IDОрганизации",			IDОрганизации);
	
	Запросы_ЗаполнитьПараметрыСвойствИдентификаторовДокумента(Запрос);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Объект");
	
	Возврат Результат;

КонецФункции

Функция Документы_СопоставленныйВ1С_1С(Идентификаторы)

	Результат = Неопределено;
	
	КоллекцияДокументов = Документы_КоллекцияСопоставленныхВ1С(Идентификаторы);
	
	Если КоллекцияДокументов.Количество() > 0 Тогда
		Результат = КоллекцияДокументов[0];
	КонецЕсли;	
	
	Возврат Результат;

КонецФункции

Функция Документы_ИдентификаторыОтправленныхПоДокументам1С_1С(ДокументыОснования)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЗначенияСвойствОбъектов.Значение КАК ИдентификаторДокумента
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство В(&СвойстваИдентификаторовДокументов)
	|	И ЗначенияСвойствОбъектов.Объект В(&МассивДокументов1С)";
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	СвойстваИдентификаторовДокументов = Новый Массив;
	СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторДокумента, Ложь));
	СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторСчетаУФ, Ложь));
	СвойстваИдентификаторовДокументов.Добавить(Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ИдентификаторСчетаОФ, Ложь));
	
	Запрос.УстановитьПараметр("СвойстваИдентификаторовДокументов",	СвойстваИдентификаторовДокументов);
	Запрос.УстановитьПараметр("МассивДокументов1С",					ДокументыОснования);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СтруктураИдентификаторов = Документы_СтруктураИдентифкаторов_1С(Выборка.ИдентификаторДокумента);
		
		DocumentId = Новый Структура;
		DocumentId.Вставить("MessageId",	СтруктураИдентификаторов.LetterId);
		DocumentId.Вставить("EntityId",		СтруктураИдентификаторов.DocumentId);
		
		Результат.Добавить(DocumentId);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_Записать_1С(Документ)
	
	Результат = Неопределено;
	
	ДокументУчета = Документ.ДокументУчета;
	
	Если ЗначениеЗаполнено(ДокументУчета) Тогда
		
		ИдентификаторДокумента = Документы_ИдентификаторДокумента_1С(Документ.Идентификаторы);
		ИдентификаторЯщикаДокумента = ИдентификаторВАдресЯщика(Документ.Идентификаторы.BoxID);
		
		ПереопределяемыеИменаСвойств = Документы_ПереопределяемыеИменаСвойств1С(Документ);
		
		ИмяСвойства_ВидПакета = ПереопределяемыеИменаСвойств.ВидПакета;
		ИмяСвойства_ИдентификаторДокумента = ПереопределяемыеИменаСвойств.ИдентификаторДокумента;
		ИмяСвойства_ИдентификаторЯщикаДокумента = ПереопределяемыеИменаСвойств.ИдентификаторЯщикаДокумента;
		
		ДопРеквизиты_УстановитьЗначение_1С(
			ДокументУчета,
			ИмяСвойства_ИдентификаторДокумента,
			ИдентификаторДокумента,
			Ложь);
		
		ДопРеквизиты_УстановитьЗначение_1С(
			ДокументУчета,
			ИмяСвойства_ИдентификаторЯщикаДокумента,
			ИдентификаторЯщикаДокумента,
			Ложь);
		
		ДопРеквизиты_УстановитьЗначение_1С(
			ДокументУчета,
			ИмяСвойства_ВидПакета,
			Документ.ИдентификаторВидаПакета);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Переопределяет имена свойств документа задействованных в подсистеме хранения 1С 
//
// Параметры:
//	Документ - Структура - контракт документа (см. Ядро.Контракт_Документ())
//
// Возвращаемое значение:
//	Структура - с ключами:	"ИдентификаторДокумента"
//							"ИдентификаторЯщикаДокумента"
Функция Документы_ПереопределяемыеИменаСвойств1С(Документ)
	
	ИменаСвойствНастроек_1С = Перечисление_ИменаСвойствНастроек_1С();
	
	Результат = Новый Структура;
	
	Результат.Вставить("ВидПакета", ИменаСвойствНастроек_1С.ВидПакета);
	Результат.Вставить("ИдентификаторДокумента", ИменаСвойствНастроек_1С.ИдентификаторДокумента);
	Результат.Вставить("ИдентификаторЯщикаДокумента", ИменаСвойствНастроек_1С.ИдентификаторЯщикаДокумента);
	
	ИспользуютсяНастройкиПоУмолчаниюДляСчетов = Ядро.Настройки_ОснованияВидовДокументов_ИспользуютсяНастройкиПоУмолчанию();
	ЭтоИдентификаторВидаСчет = Ядро.ЭтоИдентификаторВидаСчет(Документ.ИдентификаторВида);
	
	Если НЕ ИспользуютсяНастройкиПоУмолчаниюДляСчетов И ЭтоИдентификаторВидаСчет Тогда
		
		ЭтоДокументКонфигурацииСчетНаОплату = Ядро.Общее_ЭтоДокументКонфигурацииСчетНаОплату(Документ.ДокументУчета);
		Если НЕ ЭтоДокументКонфигурацииСчетНаОплату Тогда
			
			Результат.ВидПакета = ИменаСвойствНастроек_1С.ВидПакетаСчет;
			Результат.ИдентификаторДокумента = ИменаСвойствНастроек_1С.ИдентификаторДокументаСчет;
			Результат.ИдентификаторЯщикаДокумента = ИменаСвойствНастроек_1С.ИдентификаторЯщикаДокументаСчет;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Документы_ОбновлениеРеквизитов_1С(Идентификаторы, СтруктураРеквизитов)
	
	Если СтруктураРеквизитов.Свойство("ДокументУчета") Тогда
		
		ДокументУчета = СтруктураРеквизитов.ДокументУчета;
		
		Документы_ОчиститьНастройки_1С(Идентификаторы);
		
		Если ДокументУчета <> Неопределено Тогда 
			
			ИдентификаторДокумента		= Документы_ИдентификаторДокумента_1С(Идентификаторы);
			ИдентификаторЯщикаДокумента	= ИдентификаторВАдресЯщика(Идентификаторы.BoxID);
			
			ДопРеквизиты_УстановитьЗначение_1С(ДокументУчета, Перечисление_ИменаСвойствНастроек_1С().ИдентификаторДокумента, ИдентификаторДокумента, Ложь);
			ДопРеквизиты_УстановитьЗначение_1С(ДокументУчета, Перечисление_ИменаСвойствНастроек_1С().ИдентификаторЯщикаДокумента, ИдентификаторЯщикаДокумента, Ложь);
		
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

Функция Документы_ИдентификаторДокумента_1С(Идентификаторы)
	
	GUID = Идентификаторы.LetterID + Идентификаторы.DocumentID;
	
	Результат = GUID_2_Base64(GUID);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_СтруктураИдентифкаторов_1С(ИдентификаторДокумента)
	
	GUID = Base64_2_GUID(ИдентификаторДокумента);
	
	Результат = Новый Структура;
	Результат.Вставить("LetterID",		Лев(GUID, 36));
	Результат.Вставить("DocumentID",	Прав(GUID, 36));
	
	Возврат Результат;
	
КонецФункции	

// Дополняет контракт документа значением из информационной базы.
//
// Параметры:
//  Документ - Структура - контракт документа (см. Ядро.Контракт_Документ())
// 
Процедура Документы_ДополнитьДаннымиИнформационнойБазы_1С(Документ)
	
	ДокументУчета = Документы_СопоставленныйВ1С_1С(Документ.Идентификаторы);
	
	Если ЗначениеЗаполнено(ДокументУчета) Тогда
		
		МассивДокументов = Новый Массив;
		МассивДокументов.Добавить(ДокументУчета);
		Выборка = ПолучитьВыборкуПоСвойствамДокументовУчета_1С(МассивДокументов);
		
		Если Выборка.Следующий() Тогда
			
			ВидПакетаID = ВидПакетаПоДокументуУчета_1С(Документ.Тип.ТипДокумента, 
				ДокументУчета, 
				Выборка.ИдентификаторВидаПакетаСчет, 
				Выборка.ИдентификаторВидаПакета);
			
			Документ.ИдентификаторВидаПакета = ВидПакетаID;
			
		КонецЕсли;

		Документ.ДокументУчета = ДокументУчета;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ВидПакетаПоДокументуУчета_1С(ТипДокумента, ДокументУчета, ИдентификаторВидаПакетаСчет, ИдентификаторВидаПакета)
	
	ВидПакетаID = ИдентификаторВидаПакета;

	Если ТипДокумента = Тип_СчетНаОплату() 
		И Не Ядро.Общее_ЭтоДокументКонфигурацииСчетНаОплату(ДокументУчета) 
		И ЗначениеЗаполнено(ИдентификаторВидаПакетаСчет) Тогда
		ВидПакетаID = ИдентификаторВидаПакетаСчет;
	КонецЕсли;
	
	Возврат ВидПакетаID;

КонецФункции

Функция ПолучитьВыборкуПоСвойствамДокументовУчета_1С(ДокументыУчета)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект КАК Документ,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ЗначенияСвойствОбъектов.Свойство = &СвойствоВидПакетаСчет
	|				ТОГДА ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(100))
	|			ИНАЧЕ НЕОПРЕДЕЛЕНО
	|		КОНЕЦ) КАК ИдентификаторВидаПакетаСчет,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ЗначенияСвойствОбъектов.Свойство = &СвойствоВидПакета
	|				ТОГДА ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(100))
	|			ИНАЧЕ НЕОПРЕДЕЛЕНО
	|		КОНЕЦ) КАК ИдентификаторВидаПакета
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство В(&СвойстваВидаПакета)
	|	И ЗначенияСвойствОбъектов.Объект В(&ДокументыУчета)
	|	И (ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(100))) <> """"
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗначенияСвойствОбъектов.Объект");
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
	
	СвойствоВидПакета = Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ВидПакета);
	СвойствоВидПакетаСчет = Свойства_СсылкаНаСвойство(ИменаСвойствНастроек.ВидПакетаСчет);
	
	СвойстваВидаПакета = Новый Массив;
	СвойстваВидаПакета.Добавить(СвойствоВидПакета);
	СвойстваВидаПакета.Добавить(СвойствоВидПакетаСчет);
	
	Запрос.УстановитьПараметр("СвойстваВидаПакета", СвойстваВидаПакета);
	Запрос.УстановитьПараметр("СвойствоВидПакетаСчет", СвойствоВидПакетаСчет);
	Запрос.УстановитьПараметр("СвойствоВидПакета", СвойствоВидПакета);
	Запрос.УстановитьПараметр("ДокументыУчета", ДокументыУчета);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;

КонецФункции

Процедура Документы_ОчиститьНастройки_1С(Идентификаторы)
	
	КоллекцияДокументовУчета = Документы_КоллекцияСопоставленныхВ1С(Идентификаторы);
	
	Для Каждого Элемент Из КоллекцияДокументовУчета Цикл

		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторДокумента());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторЯщикаДокумента());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторЯщикаДокументаСчет());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ВидПакета());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ВидПакетаСчет());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ДокументУчетаПакета());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ДокументУчетаПакетаСчет());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ДиадокCustomDocumentIdСчет());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторСчетаОФ());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторСчетаУФ());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ИдентификаторЯщикаСчета());
		ДопРеквизиты_УдалитьЗначение_1С(Элемент, Свойства_ДиадокCustomDocumentId());
		
	КонецЦикла;
	
КонецПроцедуры

Функция Документы_ЕстьЭлектронныйДокументПоДокументу1С_1С(Документ1С)
	
	ДокументыОснования = Новый Массив;
	ДокументыОснования.Добавить(Документ1С);
	
	ИдентификаторыДокумента = Документы_ИдентификаторыОтправленныхПоДокументам1С_1С(ДокументыОснования);
	
	Результат = ЗначениеЗаполнено(ИдентификаторыДокумента);
	
	Возврат Результат;
	
КонецФункции

//**********************************************
// ДОКУМЕНТЫ: ДАННЫЕ ХРАНИЛИЩА

Функция Документы_СсылкаНаДанныеХранилища_Диадок(Идентификаторы, ИмяХранилища)
	
	Выборка	= Документы_ВыборкаДанныхХранилищаИзБазы_Диадок(Идентификаторы, ИмяХранилища);
		
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДанныеХранилища_Диадок(Идентификаторы, ИмяХранилища, НомерПодписи)

	Результат = Контракт_ДанныеХранения();
	
	Выборка	= Документы_ВыборкаДанныхХранилищаИзБазы_Диадок(Идентификаторы, ИмяХранилища);
		
	Если Выборка.Следующий() Тогда
		
		Результат = Документы_КонтрактДанныхХранилищаПоВыборке_Диадок(Выборка, ИмяХранилища);
		
		Если Истина
			И НЕ ЗначениеЗаполнено(Результат.Данные)
			И НЕ ЗначениеЗаполнено(Результат.ЗашифрованныеДанные) Тогда
			
			ПакетОтправлен = ЗначениеЗаполнено(Выборка.LetterId);
			Если ПакетОтправлен Тогда
				
				Если Не ЗначениеЗаполнено(Идентификаторы.BoxId) Тогда
					Документ = Документы_ДанныеДокумента_Диадок(Идентификаторы);
					ЗаполнитьЗначенияСвойств(Идентификаторы, Документ.Идентификаторы, "BoxId, LetterId, DocumentID");
				КонецЕсли;
				
				Результат = Документы_ДанныхХранения_АПИ(Идентификаторы, ИмяХранилища);
				Документы_ЗаписатьДанныеХранилища(Результат, ИмяХранилища, Выборка.ДокументЭДО);
				
			КонецЕсли;
			
		Иначе
			Результат.Подпись = Документы_ДанныеПодписи_Диадок(Идентификаторы, ИмяХранилища, НомерПодписи);
		КонецЕсли;
		
	Иначе
		
		ПакетОтправлен = ЗначениеЗаполнено(Идентификаторы.LetterId);
		
		Если ПакетОтправлен Тогда
			
			Если Не ЗначениеЗаполнено(Идентификаторы.BoxId) Тогда
				Документ = Документы_ДанныеДокумента_Диадок(Идентификаторы);
				ЗаполнитьЗначенияСвойств(Идентификаторы, Документ.Идентификаторы, "BoxId, LetterId, DocumentID");
			КонецЕсли;
			
			Результат = Документы_ДанныхХранения_АПИ(Идентификаторы, ИмяХранилища);
			
		КонецЕсли;
		
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

Функция Документы_ВыборкаДанныхХранилищаИзБазы_Диадок(Идентификаторы, ИмяХранилища = "")
	
	ДокументЭДО	= СвойствоСтруктуры(Идентификаторы, "ДокументЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");

	Если ЗначениеЗаполнено(ДокументЭДО) Тогда
		Отбор = "ХранениеДанных.Владелец = &Документ";
	Иначе
		Отбор = "ХранениеДанных.Владелец.BoxId = &BoxId И ХранениеДанных.Владелец.LetterId = &LetterId И ХранениеДанных.Владелец.DocumentId = &DocumentId";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяХранилища) Тогда
		Отбор = Отбор + "
				|	И ХранениеДанных.Наименование = &Наименование";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Документы_ТекстЗапросаДанныхХранилищаДляКонтракта_Диадок(Отбор);
	
	Запрос.УстановитьПараметр("Документ",		ДокументЭДО);
	Запрос.УстановитьПараметр("BoxID",			BoxID);
	Запрос.УстановитьПараметр("LetterId",		LetterId);
	Запрос.УстановитьПараметр("DocumentID",		DocumentID);
	Запрос.УстановитьПараметр("Наименование",	ИмяХранилища);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТекстЗапросаДанныхХранилищаДляКонтракта_Диадок(Отбор = "Истина")
	
	Результат = 
	"ВЫБРАТЬ
	|	ХранениеДанных.Ссылка КАК Ссылка,
	|	ХранениеДанных.ХранилищеДанных КАК ХранилищеДанных,
	|	ХранениеДанных.ДатаСоздания КАК ДатаСоздания,
	|	ХранениеДанных.Описание КАК Описание,
	|	ХранениеДанных.ИмяФайла КАК ИмяФайла,
	|	ХранениеДанных.РасширениеФайла КАК РасширениеФайла,
	|	ХранениеДанных.ХранилищеЗашифрованныхДанных КАК ХранилищеЗашифрованныхДанных,
	|	ХранениеДанных.ТребуетсяРасшифровка КАК ТребуетсяРасшифровка,
	|	ХранениеДанных.Владелец.Пакет.Код КАК КодПакета,
	|	ХранениеДанных.Владелец.Код КАК КодДокумента,
	|	ХранениеДанных.ХранилищеДанных.Размер КАК Размер,
	|	ХранениеДанных.Владелец.BoxId КАК BoxId,
	|	ХранениеДанных.Владелец.LetterId КАК LetterId,
	|	ХранениеДанных.Владелец.DocumentId КАК DocumentId,
	|	ХранениеДанных.Владелец КАК ДокументЭДО,
	|	ХранениеДанных.Наименование КАК ИмяХранилища
	|ИЗ
	|	Справочник.Диадок_ХранениеДанных КАК ХранениеДанных
	|ГДЕ
	|	&Отбор";
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_КонтрактДанныхХранилищаПоВыборке_Диадок(Выборка, ИмяХранилища)
	
	Результат = Контракт_ДанныеХранения();
	
	ЗаполнитьЗначенияСвойств(Результат, Выборка, "ИмяФайла, Размер, ДатаСоздания, Описание, ТребуетсяРасшифровка");

	Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске Тогда
		
		СтруктураДанных = Документы_ДвоичныеДанныеХранилища_ВнешнееХранение(Результат, Выборка.КодПакета, Выборка.КодДокумента, ИмяХранилища);
		ЗаполнитьЗначенияСвойств(Результат, СтруктураДанных, "Данные, ЗашифрованныеДанные");
		
	Иначе
		
		Результат.Данные				= Выборка.ХранилищеДанных.Хранилище.Получить();
		Результат.ЗашифрованныеДанные	= Выборка.ХранилищеЗашифрованныхДанных.Хранилище.Получить();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДвоичныеДанныеХранилища_ВнешнееХранение(ДанныеХранения, КодПакета, КодДокумента, ИмяХранилища)
	
	Результат = Новый Структура;
	Результат.Вставить("Данные",				Неопределено);
	Результат.Вставить("ЗашифрованныеДанные",	Неопределено);
	
	//данные
	РасположениеФайла	= ВнешнееХранение_ИмяФайлаНаДиске(КодПакета, КодДокумента, ИмяХранилища);
	ФайлДанныхХранилища	= Новый Файл(РасположениеФайла.ИмяФайла);
	
	Если ФайлДанныхХранилища.Существует() Тогда
		Данные	= Новый ДвоичныеДанные(РасположениеФайла.ИмяФайла);
		Результат.Вставить("Данные", Данные);
	КонецЕсли;
	
	//зашифрованные данные
	РасположениеФайла	= ВнешнееХранение_ИмяФайлаНаДиске(КодПакета, КодДокумента, ИмяХранилища, Истина);
	ФайлДанныхХранилища	= Новый Файл(РасположениеФайла.ИмяФайла);
	
	Если ФайлДанныхХранилища.Существует() Тогда
		ЗашифрованныеДанные	= Новый ДвоичныеДанные(РасположениеФайла.ИмяФайла);
		Результат.Вставить("ЗашифрованныеДанные", ЗашифрованныеДанные);
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции


Функция Документы_ДанныеПодписи_Диадок(Идентификаторы, ИмяХранилища, НомерПодписи)

	Результат = Контракт_Подпись();
	
	Выборка	= Документы_ВыборкаДанныхПодписиИзБазы_Диадок(Идентификаторы, ИмяХранилища, НомерПодписи);
		
	Если Выборка.Следующий() Тогда
		
		Результат = Документы_КонтрактПодписиПоВыборке_Диадок(Выборка, ИмяХранилища);
		
		Если НЕ ЗначениеЗаполнено(Результат.ДанныеПодписи) Тогда
			
			ПакетОтправлен = ЗначениеЗаполнено(Выборка.LetterId);
			
			Если ПакетОтправлен Тогда
				
				КонтрактПодписи	= Документы_ДанныеПодписи_АПИ(Идентификаторы, ИмяХранилища);
				ЗаполнитьЗначенияСвойств(Результат, КонтрактПодписи); 
				Документы_ЗаписатьДанныеПодписи_Диадок(Результат, ИмяХранилища, Выборка.ДокументЭДО);
				
			КонецЕсли;
			
		КонецЕсли;
				
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

Функция Документы_ВыборкаДанныхПодписиИзБазы_Диадок(Идентификаторы, ИмяХранилища, НомерПодписи)
	
	ДокументЭДО	= СвойствоСтруктуры(Идентификаторы, "ДокументЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");
	
	Если ЗначениеЗаполнено(ДокументЭДО) Тогда
		Отбор = "ПодписиХранилища.Ссылка.Владелец = &Документ";
	Иначе
		Отбор = "ПодписиХранилища.Ссылка.Владелец.BoxId = &BoxId И ПодписиХранилища.Ссылка.Владелец.LetterId = &LetterId И ПодписиХранилища.Ссылка.Владелец.DocumentId = &DocumentId";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Документы_ТекстЗапросаДанныхПодписиДляКонтракта_Диадок(Отбор);
	
	Запрос.УстановитьПараметр("Документ",		ДокументЭДО);
	Запрос.УстановитьПараметр("BoxID",			BoxID);
	Запрос.УстановитьПараметр("LetterId",		LetterId);
	Запрос.УстановитьПараметр("DocumentID",		DocumentID);
	Запрос.УстановитьПараметр("Наименование",	ИмяХранилища);
	Запрос.УстановитьПараметр("НомерСтроки",	НомерПодписи);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТекстЗапросаДанныхПодписиДляКонтракта_Диадок(Отбор = "Истина")
	
	Результат = 
	"ВЫБРАТЬ
	|	ПодписиХранилища.Ссылка КАК Ссылка,
	|	ПодписиХранилища.ХранилищеПодписи.Хранилище КАК ХранилищеПодписи,
	|	ПодписиХранилища.ДатаПодписи КАК ДатаПодписи,
	|	ПодписиХранилища.ПодписьВерна КАК ПодписьВерна,
	|	ПодписиХранилища.Ссылка.Владелец.Пакет.Код КАК КодПакета,
	|	ПодписиХранилища.Ссылка.Владелец.Код КАК КодДокумента,
	|	ПодписиХранилища.Ссылка.Владелец КАК ДокументЭДО,
	|	ПодписиХранилища.Ссылка.Владелец.BoxId КАК BoxId,
	|	ПодписиХранилища.Ссылка.Владелец.LetterId КАК LetterId,
	|	ПодписиХранилища.Ссылка.Владелец.DocumentId КАК DocumentId
	|ИЗ
	|	Справочник.Диадок_ХранениеДанных.Подписи КАК ПодписиХранилища
	|ГДЕ
	|	&Отбор
	|	И ПодписиХранилища.НомерСтроки = &НомерСтроки
	|	И ПодписиХранилища.Ссылка.Наименование = &Наименование";
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Документы_КонтрактПодписиПоВыборке_Диадок(Выборка, ИмяХранилища)
	
	Результат = Контракт_Подпись();
	
	ЗаполнитьЗначенияСвойств(Результат, Выборка, "ДатаПодписи, ПодписьВерна");
	
	Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске Тогда
		ДанныеПодписи			= Документы_ДвоичныеДанныеПодписи_ВнешнееХранение(Выборка.КодПакета, Выборка.КодДокумента, ИмяХранилища);
		Результат.ДанныеПодписи = ДанныеПодписи;
	ИначеЕсли ЗначениеЗаполнено(Выборка.ХранилищеПодписи) Тогда
		Результат.ДанныеПодписи	= Выборка.ХранилищеПодписи.Получить();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ДвоичныеДанныеПодписи_ВнешнееХранение(КодПакета, КодДокумента, ИмяХранилища)
	
	Результат = Неопределено;
	
	РасположениеФайлаПодписи	= ВнешнееХранение_ИмяФайлаНаДиске(КодПакета, КодДокумента, ИмяХранилища, Ложь, Истина);
	ФайлДанныхПодписи			= Новый Файл(РасположениеФайлаПодписи.ИмяФайла);
	
	Если ФайлДанныхПодписи.Существует() Тогда
		Результат = Новый ДвоичныеДанные(РасположениеФайлаПодписи.ИмяФайла);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


Процедура Документы_ЗаписатьДанныеХранилища_Диадок(ДанныеХранения, ИмяХранилища, ДокументЭДО)
	
	СсылкаХраненияДанных = Справочники.Диадок_ХранениеДанных.НайтиПоНаименованию(ИмяХранилища, Истина, , ДокументЭДО);
	
	Если ЗначениеЗаполнено(СсылкаХраненияДанных) Тогда
		ОбъектХраненияДанных = СсылкаХраненияДанных.ПолучитьОбъект();
	Иначе
		
		Если  НЕ ЗначениеЗаполнено(ДанныеХранения.Данные)
			И НЕ ЗначениеЗаполнено(ДанныеХранения.ЗашифрованныеДанные)
			И НЕ ЗначениеЗаполнено(ДанныеХранения.Подпись.ДанныеПодписи) Тогда
			Возврат;
		КонецЕсли;
		
		ОбъектХраненияДанных = Справочники.Диадок_ХранениеДанных.СоздатьЭлемент();
		ОбъектХраненияДанных.Владелец		= ДокументЭДО;
		ОбъектХраненияДанных.ДатаСоздания	= ТекущаяДата();
		ОбъектХраненияДанных.Наименование	= ИмяХранилища;
		
	КонецЕсли;
	
	ОбъектХраненияДанных.ДатаСоздания	= ДанныеХранения.ДатаСоздания;
	ОбъектХраненияДанных.ИмяФайла		= ДанныеХранения.ИмяФайла;
	ОбъектХраненияДанных.Описание		= ДанныеХранения.Описание;
		
	МассивПодстрок = РазделитьСтрокуЛок(ДанныеХранения.ИмяФайла, ".");
	
	Если МассивПодстрок.Количество() > 1 Тогда
		ОбъектХраненияДанных.РасширениеФайла = МассивПодстрок[МассивПодстрок.ВГраница()];
	КонецЕсли;		
	
	ОбъектХраненияДанных.Записать();
	
	//данные
	Если ТипЗнч(ДанныеХранения.Данные) = Тип("Строка") Тогда
		Данные = Base64Значение(ДанныеХранения.Данные);
	Иначе
		Данные = ДанныеХранения.Данные;
	КонецЕсли;
	
	Если Данные <> Неопределено Тогда
		Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске Тогда
			Документы_ЗаписатьДанныеХранилища_НаДиске(Данные, ДокументЭДО, ИмяХранилища);
		Иначе
			ОбъектХраненияДанных.ХранилищеДанных = Документы_ЗаписатьДанныеХранилища_ВСправочнике(Данные, ОбъектХраненияДанных.ХранилищеДанных);
		КонецЕсли;
	КонецЕсли;
	
	//зашифрованные данные
	Если ТипЗнч(ДанныеХранения.ЗашифрованныеДанные) = Тип("Строка") Тогда
		ЗашифрованныеДанные = Base64Значение(ДанныеХранения.ЗашифрованныеДанные);
	Иначе
		ЗашифрованныеДанные = ДанныеХранения.ЗашифрованныеДанные;
	КонецЕсли;
	
	Если ЗашифрованныеДанные <> Неопределено Тогда
		Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске Тогда
			Документы_ЗаписатьДанныеХранилища_НаДиске(ЗашифрованныеДанные, ДокументЭДО, ИмяХранилища, Истина);
		Иначе
			ОбъектХраненияДанных.ХранилищеЗашифрованныхДанных = Документы_ЗаписатьДанныеХранилища_ВСправочнике(ЗашифрованныеДанные, ОбъектХраненияДанных.ХранилищеЗашифрованныхДанных);
		КонецЕсли;
	КонецЕсли;
	
	ОбъектХраненияДанных.ТребуетсяРасшифровка = ДанныеХранения.ТребуетсяРасшифровка;
	
	Если ЗначениеЗаполнено(ДанныеХранения.Подпись.ДанныеПодписи) Тогда
		Документы_ЗаписатьДанныеПодписи_Диадок(ДанныеХранения.Подпись, ИмяХранилища, ДокументЭДО, ОбъектХраненияДанных);
	Иначе
		ОбъектХраненияДанных.Записать();
	КонецЕсли;
	
КонецПроцедуры

Процедура Документы_ЗаписатьДанныеПодписи_Диадок(Контракт_ДанныеПодписи, ИмяХранилища, ДокументЭДО, ОбъектХраненияДанных  = Неопределено)
	
	Если ОбъектХраненияДанных = Неопределено Тогда
		
		СсылкаХраненияДанных = Справочники.Диадок_ХранениеДанных.НайтиПоНаименованию(ИмяХранилища, Истина, , ДокументЭДО);
		
		Если ЗначениеЗаполнено(СсылкаХраненияДанных) Тогда
			ОбъектХраненияДанных = СсылкаХраненияДанных.ПолучитьОбъект();
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеПодписи = Контракт_ДанныеПодписи.ДанныеПодписи;
	
	НомерПодписи = 0;  // пока сохраняем только одну подпись
	СтрокаПодписи = ?(ОбъектХраненияДанных.Подписи.Количество() = 0, ОбъектХраненияДанных.Подписи.Добавить(), ОбъектХраненияДанных.Подписи[НомерПодписи]);
	
	Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске Тогда
		Документы_ЗаписатьДанныеХранилища_НаДиске(ДанныеПодписи, ДокументЭДО, ИмяХранилища, , НомерПодписи);
	Иначе
		СтрокаПодписи.ХранилищеПодписи = Документы_ЗаписатьДанныеХранилища_ВСправочнике(ДанныеПодписи, СтрокаПодписи.ХранилищеПодписи);
	КонецЕсли;
	
	СтрокаПодписи.ДатаПодписи = Контракт_ДанныеПодписи.ДатаПодписи;
	
	СтрокаПодписи = ?(ОбъектХраненияДанных.Подписи.Количество() = 0, ОбъектХраненияДанных.Подписи.Добавить(), ОбъектХраненияДанных.Подписи[0]);
	СтрокаПодписи.ПодписьВерна = Контракт_ДанныеПодписи.ПодписьВерна;
	
	ОбъектХраненияДанных.Записать();
	
КонецПроцедуры	

Процедура Документы_ЗаписатьДанныеХранилища_НаДиске(ДвоичныеДанные, ДокументЭДО, ИмяХранилища, ЭтоЗашифрованныеДанные = Ложь, НомерПодписи = Неопределено)
	
	Если ЗначениеЗаполнено(ДвоичныеДанные) Тогда
		
		Идентификаторы = Новый Структура;
		Идентификаторы.Вставить("ДокументЭДО", ДокументЭДО);
		
		Выборка = Документы_ВыборкаДанныхХранилищаИзБазы(Идентификаторы, ИмяХранилища);
		
		Если Выборка.Следующий() Тогда
			
			РасположениеФайла = ВнешнееХранение_ИмяФайлаНаДиске(Выборка.КодПакета, Выборка.КодДокумента, ИмяХранилища, ЭтоЗашифрованныеДанные, НомерПодписи);
			
			СоздатьКаталог(РасположениеФайла.Каталог);
			
			Если ЗначениеЗаполнено(Выборка.BoxId) Тогда
				
				ИмяФайлаURL	= РасположениеФайла.Каталог + "\" + "web.url";
				ФайлURL		= Новый Файл(ИмяФайлаURL);
				
				Если Не ФайлURL.Существует() Тогда
					
					ТД = Новый ТекстовыйДокумент;
					
					СодержимоеЯрлыка = 
					"[InternetShortcut]
					|URL=" + СформироватьСсылкуВБраузере(Выборка.BoxId, Выборка.LetterId, Выборка.DocumentId);
					
					ТД.УстановитьТекст(СодержимоеЯрлыка);
					ТД.Записать(ИмяФайлаURL);
					
				КонецЕсли;
				
			КонецЕсли;
			
			ДвоичныеДанные.Записать(РасположениеФайла.ИмяФайла);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Документы_ЗаписатьДанныеХранилища_ВСправочнике(ДвоичныеДанные, Ссылка_Диадок_Файлы = Неопределено) 
	
	Результат = Неопределено;
	
	Если Не ЗначениеЗаполнено(Ссылка_Диадок_Файлы) Тогда
		
		ОбъектСправочника = Справочники.Диадок_Файлы.СоздатьЭлемент();
		
	Иначе
		
		ОбъектСправочника = Ссылка_Диадок_Файлы.ПолучитьОбъект();
		СохраненныеДанные = ОбъектСправочника.Хранилище.Получить();
		
		Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные")
			И ТипЗнч(СохраненныеДанные) = Тип("ДвоичныеДанные")
			И ДвоичныеДанные = СохраненныеДанные Тогда
			
			Результат = Ссылка_Диадок_Файлы;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		ОбъектСправочника.Хранилище = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
		
		Если ДвоичныеДанные <> Неопределено Тогда
			ОбъектСправочника.Размер = ДвоичныеДанные.Размер();
		КонецЕсли;
		
		Если ОбъектСправочника.ЭтоНовый() Тогда
			ОбъектСправочника.УстановитьНовыйКод();
		КонецЕсли;
		
		ОбъектСправочника.Записать();
		
		Результат = ОбъектСправочника.Ссылка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


Функция Документы_ПометитьНедействительныеДанныеХранилища_Диадок(ДокументЭДО, ИмяХранилища)
	
	ХранениеДанныхСсылка = Справочники.Диадок_ХранениеДанных.НайтиПоНаименованию(ИмяХранилища, Истина, , ДокументЭДО);
	
	Если ЗначениеЗаполнено(ХранениеДанныхСсылка) Тогда
		
		ХранениеДанныхОбъект = ХранениеДанныхСсылка.ПолучитьОбъект();
		ХранениеДанныхОбъект.Наименование = "DEL " + ХранениеДанныхОбъект.Наименование;
		ХранениеДанныхОбъект.Записать();
		
	КонецЕсли;	
	
	Результат = ХранениеДанныхСсылка;
	
	Возврат Результат;
	
КонецФункции	

Функция Документы_ОписаниеДанныхХранилища_Диадок(Идентификаторы)
	
	Результат = Новый Структура;
	
	ДокументЭДО	= СвойствоСтруктуры(Идентификаторы, "ДокументЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");
		
	Если ЗначениеЗаполнено(ДокументЭДО) Тогда
		Отбор = "ХранениеДанных.Владелец = &Документ";
	Иначе
		Отбор = "ХранениеДанных.Владелец.BoxId = &BoxId И ХранениеДанных.Владелец.LetterId = &LetterId И ХранениеДанных.Владелец.DocumentId = &DocumentId";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Документы_ТекстЗапросаОписаниеДанныхХранилища_Диадок(Отбор);
	
	Запрос.УстановитьПараметр("Документ",	ДокументЭДО);
	Запрос.УстановитьПараметр("BoxID",		BoxID);
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	Запрос.УстановитьПараметр("DocumentID",	DocumentID);
	
	ВыборкаХранилищ = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаХранилищ.Следующий() Цикл
		
		Если Лев(ВыборкаХранилищ.Наименование, 3) <> "DEL" Тогда
			
			Значение = Новый Структура;
			Значение.Вставить("Id", 				ВыборкаХранилищ.Описание);
			Значение.Вставить("ДатаСоздания", 		ВыборкаХранилищ.ДатаСоздания);
			Значение.Вставить("ПодписьЗагружена",	ВыборкаХранилищ.ПодписьЗагружена);
			Значение.Вставить("ДанныеЗагружены",	ВыборкаХранилищ.ДанныеЗагружены);
			
			Результат.Вставить(ВыборкаХранилищ.Наименование, Значение);
			
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Функция Документы_ТекстЗапросаОписаниеДанныхХранилища_Диадок(Отбор = "Истина")
	
	Результат = 
	"ВЫБРАТЬ
	|	ХранениеДанных.Наименование КАК Наименование,
	|	ХранениеДанных.Описание КАК Описание,
	|	ХранениеДанных.ДатаСоздания,
	|	ВЫБОР
	|		КОГДА ХранениеДанныхПодписи.ХранилищеПодписи ЕСТЬ NULL 
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПодписьЗагружена,
	|	ВЫБОР
	|		КОГДА ХранениеДанных.ХранилищеДанных ЕСТЬ NULL 
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ДанныеЗагружены
	|ИЗ
	|	Справочник.Диадок_ХранениеДанных КАК ХранениеДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ХранениеДанных.Подписи КАК ХранениеДанныхПодписи
	|		ПО (ХранениеДанныхПодписи.Ссылка = ХранениеДанных.Ссылка)
	|			И (ХранениеДанныхПодписи.НомерСтроки = 1)
	|ГДЕ
	|	&Отбор
	|	И НЕ ХранениеДанных.ПометкаУдаления";
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

