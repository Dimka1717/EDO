Функция Свойства_СсылкаНаСвойство(Наименование, СПрефиксом = Истина)
	
	Результат = Кэш_Прочитать(ПрефиксНастройки_1С(СПрефиксом) + Наименование);
	
	Если Результат = Неопределено Тогда
		
		Результат = Свойства_НайтиСвойство(Наименование, СПрефиксом);
		
		Если НЕ ЗначениеЗаполнено(Результат) Тогда
			Результат = Свойства_СоздатьСвойство(Наименование, СПрефиксом);
		КонецЕсли;

		Кэш_Поместить(ПрефиксНастройки_1С(СПрефиксом) + Наименование, Результат);

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_НайтиСвойство(Наименование, СПрефиксом = Истина)
	
	Результат = ПланыВидовХарактеристик[Свойства_ИмяПланаВидовХарактеристик()].НайтиПоНаименованию(ПрефиксНастройки_1С(СПрефиксом) + Наименование, Истина);
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_ЗначениеСвойства(СтрокаИлиСсылка, ОбъектСсылка, СПрефиксом = Истина)
	
	Результат = Неопределено;
	
	ПараметрСвойство = СтрокаИлиСсылка;
	Если ТипЗнч(СтрокаИлиСсылка) = Тип("Строка") Тогда
		ПараметрСвойство = Свойства_СсылкаНаСвойство(СтрокаИлиСсылка, СПрефиксом);
	КонецЕсли;
	
	Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗначенияСвойствОбъектов.Объект,
			|	ЗначенияСвойствОбъектов.Свойство.Наименование КАК ИмяСвойства,
			|	ЗначенияСвойствОбъектов.Значение КАК ЗначениеСвойства
			|ИЗ
			|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
			|ГДЕ
			|	ЗначенияСвойствОбъектов.Свойство = &Свойство
			|	И ЗначенияСвойствОбъектов.Объект = &Объект
			|
			|УПОРЯДОЧИТЬ ПО
			|	Объект");
	
	Запрос.УстановитьПараметр("Свойство", ПараметрСвойство);
	Запрос.УстановитьПараметр("Объект", ОбъектСсылка);
	
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.ЗначениеСвойства;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_ЗначениеОбъекта(НаименованиеСвойства, Значение, СПрефиксом = Истина)
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект КАК Ссылка
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Значение = &Значение
	|	И ЗначенияСвойствОбъектов.Свойство = &Свойство";
	
	Запрос.УстановитьПараметр("Значение",	Значение);
	Запрос.УстановитьПараметр("Свойство",	Свойства_СсылкаНаСвойство(НаименованиеСвойства, СПрефиксом));
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.Ссылка;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция Свойства_ОбщиеНастройки()
	
	Результат = Новый Структура;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Объект,
	|	ЗначенияСвойствОбъектов.Свойство.Наименование КАК ИмяСвойства,
	|	ЗначенияСвойствОбъектов.Значение КАК ЗначениеСвойства
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Объект
	|	И ПОДСТРОКА(ЗначенияСвойствОбъектов.Свойство.Наименование, 1, 6) = &ПрефиксНастройки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗначенияСвойствОбъектов.Объект");
	
	Запрос.УстановитьПараметр("Объект",				ОбъектОбщихНастроек_1С());
	Запрос.УстановитьПараметр("ПрефиксНастройки",	ПрефиксНастройки_1С());
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	Запрос.Текст	= СтрЗаменить(Запрос.Текст, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл	
		
		Ключ		= СтрЗаменить(ВыборкаЗапроса.ИмяСвойства, ПрефиксНастройки_1С(), "");
		Значение	= ВыборкаЗапроса.ЗначениеСвойства;
		Результат.Вставить(Ключ, Значение);	

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_СправочникИспользуетсяДляХраненияСвойств(ИмяСправочника)
	
	Результат = Ложь;
	
	Если ПроверитьНаличиеОбъектаМетаданных("Справочники." + ИмяСправочника) Тогда
	
		ИмяРегистра = Свойства_ИмяРегистраСведений();
		МетаданныеРегистра = Метаданные.РегистрыСведений.Найти(ИмяРегистра);
		
		Если МетаданныеРегистра <> Неопределено Тогда
			
			ИзмерениеРегистра = МетаданныеРегистра.Измерения.Найти("Объект");
			
			Если ИзмерениеРегистра <> Неопределено Тогда
				
				ТипСправочника = Тип("СправочникСсылка." + ИмяСправочника);
				Результат = ИзмерениеРегистра.Тип.СодержитТип(ТипСправочника);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_ИмяРегистраСведений()
	
	Результат = Кэш_Прочитать("ИмяРегистраСведений");
	
	Если Результат = Неопределено Тогда

		ИмяРегистраДополнительныеСведения 	= "ДополнительныеСведения";
		ИмяРегистраЗначенияСвойствОбъектов 	= "ЗначенияСвойствОбъектов";

		Результат = "";
		
		ЕстьРегистрДополнительныеСведения 	= (Метаданные.РегистрыСведений.Найти(ИмяРегистраДополнительныеСведения) <> Неопределено);
		ЕстьРегистрЗначенияСвойствОбъектов 	= (Метаданные.РегистрыСведений.Найти(ИмяРегистраЗначенияСвойствОбъектов) <> Неопределено);
		
		Если ЕстьРегистрЗначенияСвойствОбъектов И ЕстьРегистрДополнительныеСведения Тогда
			
			Если Настройки_ИспользуетсяРегистрСведенийЗначенияСвойствОбъектов() Тогда
				Результат = ИмяРегистраЗначенияСвойствОбъектов;	
			Иначе
				Результат = ИмяРегистраДополнительныеСведения;	
			КонецЕсли;		
			
		ИначеЕсли ЕстьРегистрЗначенияСвойствОбъектов Тогда
			
			Результат = ИмяРегистраЗначенияСвойствОбъектов;
			
		ИначеЕсли ЕстьРегистрДополнительныеСведения Тогда
			
			Результат = ИмяРегистраДополнительныеСведения;
			
		КонецЕсли;
		
		Кэш_Поместить("ИмяРегистраСведений", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_ИмяПланаВидовХарактеристик()

	Результат = "";
	
	ИмяРегистраСведений	= Свойства_ИмяРегистраСведений();
	ТипИзмерения		= Метаданные.РегистрыСведений[ИмяРегистраСведений].Измерения.Свойство.Тип.Типы()[0];
	
	Результат = Метаданные.НайтиПоТипу(ТипИзмерения).Имя;
	
	Возврат Результат;

КонецФункции

Функция Свойства_ИмяСправочникаДополнительныхОбработок()
	
	Результат = Кэш_Прочитать("ИмяСправочникаДополнительныхОбработок");
	Если Результат = Неопределено Тогда
		
		ИменаСправочников = Новый Массив;
		ИменаСправочников.Добавить("ВнешниеОбработки");
		ИменаСправочников.Добавить("ДополнительныеОтчетыИОбработки");
		ИменаСправочников.Добавить("ВнешниеПечатныеФормы");
		
		Для Каждого ИмяСправочника Из ИменаСправочников Цикл
			
			Если Метаданные.Справочники.Найти(ИмяСправочника) <> Неопределено Тогда
				Результат = ИмяСправочника;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Кэш_Поместить("ИмяСправочникаДополнительныхОбработок", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Свойства_СоздатьСвойство(Наименование, СПрефиксом)
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	ИмяПланаВидовХарактеристик = Свойства_ИмяПланаВидовХарактеристик();
	
	ОбъектМетаданных = Метаданные.ПланыВидовХарактеристик[ИмяПланаВидовХарактеристик];
	Если Не ПравоДоступа("Добавление", ОбъектМетаданных) Тогда
		Ошибка = "У текущего пользователя недостаточно прав для инициализации настроек модуля!";
		ВызватьИсключение Ошибка;
	КонецЕсли;
	
	СвойствоОбъект = ПланыВидовХарактеристик[ИмяПланаВидовХарактеристик].СоздатьЭлемент();
	
	СвойствоОбъект.Наименование	= ПрефиксНастройки_1С(СПрефиксом) + Наименование;
	СвойствоОбъект.ТипЗначения	= Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(50));	
	СвойствоОбъект.УстановитьНовыйКод();
	
	СтрокаМетаданных = "ПланыВидовХарактеристик." + ИмяПланаВидовХарактеристик + ".Реквизиты.Заголовок";
	Если ПроверитьНаличиеОбъектаМетаданных(СтрокаМетаданных) Тогда
		СвойствоОбъект.Заголовок = СвойствоОбъект.Наименование;
	КонецЕсли;
	
	СвойствоОбъект.ОбменДанными.Загрузка = Истина;
	СвойствоОбъект.Записать();
	
	Результат = СвойствоОбъект.Ссылка;
	
	Возврат Результат; 
	
КонецФункции

