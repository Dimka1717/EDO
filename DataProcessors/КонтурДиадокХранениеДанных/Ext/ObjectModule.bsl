Процедура Пакеты_ПредОбработкаПодготовленного_Диадок(Пакет)
	
	ПараметрыПереотправки = Неопределено;
	
	Пакет.СлужебнаяИнформация.Свойство("ПараметрыПереотправки", ПараметрыПереотправки);
	
	Если ПараметрыПереотправки <> Неопределено Тогда
		
		ПереотправляемыйПакет = ПараметрыПереотправки.ПереотправляемыйПакет;
		
		Если ЗначениеЗаполнено(ПереотправляемыйПакет.ПакетЭДО)
			И ПереотправляемыйПакет.ПакетЭДО.Метка = Метка_Отправлен()
			И Настройки_ОбщиеНастройки().УдалятьПриПереотправкеПредыдущийДокумент Тогда
			
			Пакеты_ОбработкаПереотправки_Диадок(Пакет);
			
		КонецЕсли;	
		
		Если ПараметрыПереотправки.ВыполнитьУдалениеНеактуальныхДокументовПакета Тогда
			Пакеты_ПометитьНаУдалениеНеактуальныеДокументы_Диадок(Пакет);
		КонецЕсли;
		
		ПараметрыПереотправки = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры	

Процедура Пакеты_ОбработкаПереотправки_Диадок(Пакет)
	
	Идентификаторы = Пакет.СлужебнаяИнформация.ПараметрыПереотправки.ПереотправляемыйПакет;
	
	ДокументыПереотправляемогоПакета = Пакеты_ДокументыПакета_Диадок(Идентификаторы);
	
	Для Каждого ИдентификаторыДокумента Из ДокументыПереотправляемогоПакета Цикл				
		
		ТекДокумент = ИдентификаторыДокумента.ДокументЭДО;
		
		ПереотправляемыйДокументОбъект			= ТекДокумент.ПолучитьОбъект();
		ПереотправляемыйДокументОбъект.Метка	= Метка_Переотправлен();
		ПереотправляемыйДокументОбъект.Записать();
		
	КонецЦикла;
	
	ПереотправляемыйПакет = Идентификаторы.ПакетЭДО;
	
	ПереотправляемыйПакетОбъект = ПереотправляемыйПакет.ПолучитьОбъект();
	ПереотправляемыйПакетОбъект.Метка = Метка_Переотправлен();
	ПереотправляемыйПакетОбъект.Записать();
	
	Пакет.ДопРеквизиты.Вставить("ПереотправленныйПакет", ПереотправляемыйПакет);	
	
КонецПроцедуры

Процедура Пакеты_ПометитьНаУдалениеНеактуальныеДокументы_Диадок(Пакет)
	
	ТекущиеДокументыПакета = Новый Массив;
	
	Для Каждого СтрокаСостава Из Пакет.Документы Цикл
		
		ДокументЭДО = СтрокаСостава.Идентификаторы.ДокументЭДО;
		
		Если ДокументЭДО <> Неопределено Тогда
			ТекущиеДокументыПакета.Добавить(ДокументЭДО);
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_Документы.Пакет КАК ПакетДД,
	|	Диадок_Документы.Ссылка КАК ДокументДД,
	|	Диадок_ХранениеДанных.Ссылка КАК ЗаписьХранилищаДД,
	|	Диадок_Документы.ДатаЗагрузки КАК ДатаЗагрузки
	|ИЗ
	|	Справочник.Диадок_Документы КАК Диадок_Документы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ХранениеДанных КАК Диадок_ХранениеДанных
	|		ПО (Диадок_ХранениеДанных.Владелец = Диадок_Документы.Ссылка)
	|ГДЕ
	|	Диадок_Документы.Пакет = &Пакет
	|	И НЕ Диадок_Документы.Ссылка В (&ТекущиеДокументыПакета)
	|	И НЕ Диадок_Документы.ПометкаУдаления
	|ИТОГИ ПО
	|	ПакетДД,
	|	ДокументДД,
	|	ЗаписьХранилищаДД";
	
	Запрос.УстановитьПараметр("Пакет",					Пакет.Идентификаторы.ПакетЭДО);
	Запрос.УстановитьПараметр("ТекущиеДокументыПакета",	ТекущиеДокументыПакета);
	
	ВыборкаПакеты = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаПакеты.Следующий() Цикл
		Пакеты_ОчиститьСохраненныеДанныеДокументов_Диадок(ВыборкаПакеты, Истина);
	КонецЦикла;
	
КонецПроцедуры

Процедура Пакеты_ОчиститьСохраненныеДанныеДокументов_Диадок(ВыборкаПакеты, УдалятьДокументыДД = Ложь)
	
	УдалятьНепосредственно = Ложь;
	
	МассивУдаляемыхСсылок		= Новый Массив;
	МассивУдаляемыхКаталогов	= Новый Массив;
	
	ВыборкаДокументы = ВыборкаПакеты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокументы.Следующий() Цикл
		
		Если Настройки_ОбщиеНастройки().ХранитьДокументыНаДиске = Истина Тогда
			
			РазмещениеФайла = ВнешнееХранение_ИмяФайлаНаДиске(ВыборкаДокументы.ДокументДД.Пакет.Код, ВыборкаДокументы.ДокументДД.Код, "");
			МассивУдаляемыхКаталогов.Добавить(РазмещениеФайла.Каталог);
			
		КонецЕсли;
		
		Если УдалятьДокументыДД Тогда
			МассивУдаляемыхСсылок.Добавить(ВыборкаДокументы.ДокументДД);
		КонецЕсли;
		
		ВыборкаЗаписиХранилища = ВыборкаДокументы.Выбрать();
		
		Пока ВыборкаЗаписиХранилища.Следующий() Цикл
			
			Если ЗначениеЗаполнено(ВыборкаЗаписиХранилища.ЗаписьХранилищаДД) Тогда
				
				МассивУдаляемыхСсылок.Добавить(ВыборкаЗаписиХранилища.ЗаписьХранилищаДД);
				МассивУдаляемыхСсылок.Добавить(ВыборкаЗаписиХранилища.ЗаписьХранилищаДД.ХранилищеДанных);
				МассивУдаляемыхСсылок.Добавить(ВыборкаЗаписиХранилища.ЗаписьХранилищаДД.ХранилищеЗашифрованныхДанных);
				
				Для Каждого СтрокаПодписи Из ВыборкаЗаписиХранилища.ЗаписьХранилищаДД.Подписи Цикл
					МассивУдаляемыхСсылок.Добавить(СтрокаПодписи.ХранилищеПодписи);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Для Каждого Каталог Из МассивУдаляемыхКаталогов Цикл
		
		Ф = Новый Файл(Каталог);
		Если Ф.Существует() Тогда
			УдалитьФайлы(Каталог);
		КонецЕсли;
		
	КонецЦикла;
	
	РежимСовместимости_8_1 = (Метаданные.РежимСовместимости = Метаданные.СвойстваОбъектов.РежимСовместимости.Версия8_1);
	
	НачатьТранзакцию();
	
	Попытка
		
		Для Каждого Ссылка Из МассивУдаляемыхСсылок Цикл
			
			Если РежимСовместимости_8_1 Тогда
				ВерсияДанныхСсылки = "_";
			Иначе
				ВерсияДанныхСсылки = Ссылка.ВерсияДанных;
			КонецЕсли;
			
			Если Истина
				И ЗначениеЗаполнено(Ссылка)
				И ЗначениеЗаполнено(ВерсияДанныхСсылки) Тогда
				
				УдаляемыйОбъект = Ссылка.ПолучитьОбъект();
				
				Если УдалятьНепосредственно Тогда
					УдаляемыйОбъект.Удалить();
				Иначе
					
					Если Не УдаляемыйОбъект.ПометкаУдаления Тогда
						УдаляемыйОбъект.УстановитьПометкуУдаления(Истина);
					КонецЕсли;
					
				КонецЕсли;
			
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		_Ошибка = ОписаниеОшибки();
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

Функция МассивВидовГруппировок_В_МассивВидовДокументов(МассивВидовГруппировок)
	
	ВидыГруппировок = ДопСправочники_СписокЭлементов("ВидыГруппировкиПолученных", "ТипыДокументов");
	
	Результат = Новый Массив;
	
	Для Каждого ТекВид Из ВидыГруппировок Цикл
		
		Если МассивВидовГруппировок.Найти(ТекВид.Ссылка) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТипыДокументовТекВидаМассивом = РазделитьСтрокуЛок(ТекВид.ТипыДокументов, ",");
		
		Для Каждого ТекТип Из ТипыДокументовТекВидаМассивом Цикл
			Результат.Добавить(ТекТип);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

Процедура ЗаполнитьУчастниковДокументооборота(Отправитель, Получатель, Выборка)
	
	Если Выборка.Направление = "Входящее" Тогда
		ДанныеКонтрагента = Отправитель;
		ДанныеОрганизации = Получатель;
	Иначе
		ДанныеОрганизации = Отправитель;
		ДанныеКонтрагента = Получатель;
	КонецЕсли;
	
	ДанныеКонтрагента.BoxId				= Выборка.Контрагент_BoxId;
	ДанныеКонтрагента.FNSParticipantId	= Выборка.Контрагент_FNSParticipantId;
	ДанныеКонтрагента.Организация		= Выборка.Контрагент_Организация;
	ДанныеКонтрагента.ОрганизацияЭДО	= Выборка.Контрагент_ОрганизацияЭДО;
	
	ДанныеОрганизации.BoxId				= Выборка.Организация_BoxId;
	ДанныеОрганизации.FNSParticipantId	= Выборка.Организация_FNSParticipantId;
	ДанныеОрганизации.Организация		= Выборка.Организация_Организация;
	ДанныеОрганизации.ОрганизацияЭДО	= Выборка.Организация_ОрганизацияЭДО;
	
КонецПроцедуры

// Находит всех контрагентов сервиса, сопоставленных с контрагентом информационной базы.
//
// Параметры:
//  КонтрагентИБ - ЛюбаяСсылка - контрагент ИБ, по связи с которым требуется отобрать контрагентов ДД.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.Диадок_ЮрФизЛица - элементы справочника с типом "Контрагенты".
//
Функция Справочники_СвязанныеКонтрагентыСервиса_Диадок(КонтрагентИБ)
	
	Если Не ЗначениеЗаполнено(КонтрагентИБ) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяСправочника = "Контрагенты";
	
	Результат = Справочники_СвязанныеЮрФизЛица_Диадок(КонтрагентИБ, ИмяСправочника);
	
	Возврат Результат;
	
КонецФункции

// Находит все организации сервиса, сопоставленные с организацией информационной базы.
//
// Параметры:
//  ОрганизацияИБ - ЛюбаяСсылка - организация ИБ, по связи с которой требуется отобрать организации ДД.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.Диадок_ЮрФизЛица - элементы справочника с типом "Организации".
//
Функция Справочники_СвязанныеОрганизацииСервиса_Диадок(ОрганизацияИБ)
	
	Если Не ЗначениеЗаполнено(ОрганизацияИБ) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяСправочника = "Организации";
	
	Результат = Справочники_СвязанныеЮрФизЛица_Диадок(ОрганизацияИБ, ИмяСправочника);
	
	Возврат Результат;
	
КонецФункции

// Получает все элементы справочника юридических и физических лиц,
// с которыми сопоставлена указанная сущность информационной базы
//
// Параметры:
//  СсылкаНаОбъект - ЛюбаяСсылка - сущность ИБ, по связи с которой требуется отобрать сущности сервиса
//  ИмяСправочника - Строка - тип сущностей сервиса ("Контрагенты", "Организации", "ПодразделенияКонтрагентов" или "ПодразделенияОрганизаций")
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.Диадок_ЮрФизЛица
//
Функция Справочники_СвязанныеЮрФизЛица_Диадок(СсылкаНаОбъект, ИмяСправочника)
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса = Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокРасширение();
	Иначе
		ТекстЗапроса = Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокСХ1();
	КонецЕсли;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Запрос.УстановитьПараметр("ИмяСправочника", ИмяСправочника);
	Запрос.УстановитьПараметр("ИмяРеквизита", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	Запрос.УстановитьПараметр("СсылкаНаОбъект", СсылкаНаОбъект);
	Запрос.УстановитьПараметр("Отбор", Истина);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокРасширение()

	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка КАК Ссылка,
	|	Диадок_ЮрФизЛица.ID КАК ID
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО (&Отбор)
	|			И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ИмяРеквизита)
	|			И (Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника)
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &СсылкаНаОбъект
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_СвязанныеЮрФизЛица_ДиадокСХ1()

	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка,
	|	Диадок_ЮрФизЛица.ID КАК ID
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|	И Диадок_ЮрФизЛица.СвязанныйСправочник1 = &СсылкаНаОбъект
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка,
	|	Диадок_ЮрФизЛица.ID
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|	И Диадок_ЮрФизЛица.СвязанныйСправочник2 = &СсылкаНаОбъект
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка,
	|	Диадок_ЮрФизЛица.ID
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	&Отбор
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|	И Диадок_ЮрФизЛица.СвязанныйСправочник3 = &СсылкаНаОбъект
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка,
	|	Диадок_ЮрФизЛица.ID
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО (&Отбор)
	|			И Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ИмяРеквизита)
	|			И (Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника)
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = &СсылкаНаОбъект
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции
	

Функция Справочники_СсылкаПоИдентификатору_Диадок(Идентификаторы, ИмяСправочника)

	Результат = Неопределено;
	
	BoxId = СвойствоСтруктуры(Идентификаторы, "ID",	"");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|ГДЕ
	|	Диадок_ЮрФизЛица.ID = &BoxId
	|	И Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("BoxId", BoxId); 
		
	Запрос.УстановитьПараметр("ИмяСправочника",	ИмяСправочника);
		
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.Ссылка;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция Справочники_СопоставленныеВ1С_Диадок(ИмяСправочника, Идентификаторы)
	
	Результат = Новый Массив;
	
	ИмяСвойства = Перечисление_ИменаСвойствНастроек_Диадок().СвязанныйСправочник;
	
	Буфер = Новый ТаблицаЗначений;
	Буфер.Колонки.Добавить("Ссылка");
	Буфер.Колонки.Добавить("НомерСвязи");
	
	СвязанныеСправочники = Справочники_СвязанныеСправочники_Диадок(ИмяСправочника, Идентификаторы);
		
	Для каждого ЭлементТЗ Из СвязанныеСправочники Цикл
		
		// При переходе на множественное сопоставление организаций(контрагентов, подразделений)
		// возможны ситуации, когда реквизиты не заполнены.
		
		Если Не ЗначениеЗаполнено(ЭлементТЗ.ОбъектИБ) Тогда
			Продолжить;
		КонецЕсли;
		
		НомерСвойства = СтрЗаменить(СокрЛП(ЭлементТЗ.ИмяРеквизита), ИмяСвойства, "");
		
		НовыйЭлементБуфера = Буфер.Добавить();
		НовыйЭлементБуфера.Ссылка 		= ЭлементТЗ.ОбъектИБ;
		НовыйЭлементБуфера.НомерСвязи 	= Число(НомерСвойства);
						
	КонецЦикла;
	
	Буфер.Сортировать("НомерСвязи");
	
	Для Каждого ЭлементБуфера Из Буфер Цикл
		Результат.Добавить(ЭлементБуфера.Ссылка);
	КонецЦикла;
			
	Возврат Результат;
	
КонецФункции


Функция Справочники_ВыборкаДанныхСправочника_Диадок(ИмяСправочника, Идентификаторы)

	Результат = Неопределено;
	
	ID = Идентификаторы.ID;
	Ссылка = Идентификаторы.Ссылка;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Справочники_ТекстЗапросаПоСправочникам_Диадок(Ссылка);
	
	Запрос.УстановитьПараметр("ID", ID);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ИмяСправочника", ИмяСправочника);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция Справочники_ТекстЗапросаПоСправочникам_Диадок(Ссылка)
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Отбор = "Диадок_ЮрФизЛица.Ссылка = &Ссылка";
	Иначе
		Отбор = "Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника И Диадок_ЮрФизЛица.ID = &ID";
	КонецЕсли;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		Результат = Справочники_ТекстЗапроса_ДанныеСправочника_ДиадокРасширение();
	Иначе
		Результат = Справочники_ТекстЗапроса_ДанныеСправочника_ДиадокСХ1();
	КонецЕсли;
	
	Результат = СтрЗаменить(Результат, "&Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

Функция Справочники_ТекстЗапроса_ДанныеСправочника_ДиадокРасширение()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка,
	|	Диадок_ЮрФизЛица.Наименование КАК Наименование,
	|	Диадок_ЮрФизЛица.ID КАК ID,
	|	Диадок_ЮрФизЛица.ИНН КАК ИНН,
	|	Диадок_ЮрФизЛица.КПП КАК КПП,
	|	Диадок_ЮрФизЛица.Аббревиатура КАК Аббревиатура,
	|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК ID_ОсновноеПодразделение,
	|	Диадок_ЮрФизЛица.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения,
	|	Диадок_ЮрФизЛица.ID_РодительПодразделения КАК ID_РодительПодразделения,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО КАК ИдентификаторУчастникаЭДО,
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК СвязанныйСправочник1
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита = ""СвязанныйСправочник1"")
	|ГДЕ
	|	&Отбор
	|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	Возврат Результат;
	
КонецФункции

