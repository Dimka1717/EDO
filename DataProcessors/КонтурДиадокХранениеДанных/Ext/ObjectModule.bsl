// Записывает сопоставление контрагента 1С и контрагента ДД
//
// Параметры:
//  КонтрагентИБ	 - СправочникСсылка.Контрагенты	- ссылка справочника Контрагенты. 
//  ИдентификаторЭДО - Структура - см. описание Новый_ИдентификаторыСправочника()
//
Процедура Контрагенты_СопоставитьКонтрагентов(КонтрагентИБ, ИдентификаторЭДО) Экспорт
	
	СвязанныеСправочники = Контрагенты_МассивСопоставленныхВ1С(ИдентификаторЭДО);
	
	Если  НЕ СвязанныеСправочники.Найти(КонтрагентИБ) = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СвязанныеСправочники.Добавить(КонтрагентИБ);
	
	СтруктураРеквизитов = Новый Структура("СвязанныеСправочники", СвязанныеСправочники);	
		
	Контрагенты_ОбновлениеРеквизитов(ИдентификаторЭДО, СтруктураРеквизитов);

КонецПроцедуры

// Возвращает таблицу значений контрагентов 1С, сопоставленных с контрагентами ЭДО.
// Сопоставление контрагентов выполняется по значениям реквизитов ИНН и КПП.
//
// Параметры:
//	КонтрагентыЭДО - ТаблицаЗначений - состав колонок см. Модуль_Ядро.Контрагенты_НоваяТаблицаКонтрактов
//
// Возвращаемое значение:
//	ТаблицаЗначений - содержит таблицу связанных контрагентов 1С.
//					Колонки:
//						КонтрагентЭДО 	- Строка - идентификатор контрагента ЭДО
//						Контрагент1С	- СправочникСсылка.Контрагенты
//
Функция Контрагенты_СопоставитьКонтрагентовПоИННКПП(КонтрагентыЭДО) Экспорт
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	КонтрагентыЭДО.ID,
		|	КонтрагентыЭДО.ИНН,
		|	КонтрагентыЭДО.КПП
		|ПОМЕСТИТЬ ВремКонтрагентыЭДО
		|ИЗ
		|	&ВнешняяТаблица КАК КонтрагентыЭДО
		|
		|;
		|////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыЭДО.ID 		КАК КонтрагентЭДО,
		|	Контрагенты1С.Ссылка 	КАК Контрагент1С
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты1С
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВремКонтрагентыЭДО КАК КонтрагентыЭДО
		|		ПО Контрагенты1С.ИНН = КонтрагентыЭДО.ИНН
		|			И Контрагенты1С.КПП = КонтрагентыЭДО.КПП
		|ГДЕ
		|	НЕ КонтрагентыЭДО.ID ЕСТЬ NULL
		|	И НЕ Контрагенты1С.ПометкаУдаления";
	
	ИмяТаблицыКонтрагенты = ТипЗначенияОбъекта("Контрагенты", "ДляЗапроса");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Справочник.Контрагенты", ИмяТаблицыКонтрагенты);
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ВнешняяТаблица", КонтрагентыЭДО);
	
	РеквизитКПП = ИмяТаблицыКонтрагенты + ".Реквизиты.КПП";
	
	РеквизитКПП = СтрЗаменить(РеквизитКПП, "Справочник", "Справочники");
	
	Если Не ПроверитьНаличиеОбъектаМетаданных(РеквизитКПП) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Контрагенты1С.КПП = КонтрагентыЭДО.КПП", "ИСТИНА");
	КонецЕсли;
	
	СвязиКонтрагентов = Запрос.Выполнить().Выгрузить();
	
	Возврат СвязиКонтрагентов;
	
КонецФункции

//**********************************************
// СИНХРОНИЗАЦИЯ КОНТРАГЕНТОВ: ПОДСИСТЕМА ДИАДОКА

Функция Контрагенты_МассивКонтрагентовДляОбновленияРеквизитов_Диадок(ТаблицаКонтрактов)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID,
	|	ТаблицаКонтрактов.OrgId,
	|	ТаблицаКонтрактов.ИНН,
	|	ТаблицаКонтрактов.КПП,
	|	ТаблицаКонтрактов.Наименование,
	|	ТаблицаКонтрактов.ИдентификаторУчастникаЭДО,
	|	ТаблицаКонтрактов.ДатаЛиквидации
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Диадок_ЮрФизЛица.Ссылка КАК КонтрагентЭДО,
	|	Диадок_ЮрФизЛица.ИНН,
	|	Диадок_ЮрФизЛица.КПП,
	|	Диадок_ЮрФизЛица.ID,
	|	ЕСТЬNULL(Диадок_ЮрФизЛицаOrgId.Значение, """") КАК OrgId,
	|	Диадок_ЮрФизЛица.Наименование,
	|	Диадок_ЮрФизЛица.ИдентификаторУчастникаЭДО,
	|	ЕСТЬNULL(Диадок_ЮрФизЛицаДатаЛиквидации.Значение, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаЛиквидации
	|ПОМЕСТИТЬ ВТ_КонтрагентыЭДО
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДатаЛиквидации
	|		ПО Диадок_ЮрФизЛица.Ссылка = Диадок_ЮрФизЛицаДатаЛиквидации.Ссылка
	|			И (Диадок_ЮрФизЛицаДатаЛиквидации.ИмяРеквизита = ""ДатаЛиквидации"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаOrgId
	|		ПО Диадок_ЮрФизЛица.Ссылка = Диадок_ЮрФизЛицаOrgId.Ссылка
	|			И (Диадок_ЮрФизЛицаOrgId.ИмяРеквизита = ""OrgId"")
	|ГДЕ
	|	НЕ Диадок_ЮрФизЛица.ПометкаУдаления
	|	И Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТаблицаКонтрактов.ID,
	|	ВТ_ТаблицаКонтрактов.OrgId,
	|	ВТ_ТаблицаКонтрактов.ИНН,
	|	ВТ_ТаблицаКонтрактов.КПП,
	|	ВТ_ТаблицаКонтрактов.Наименование КАК Наименование,
	|	ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО,
	|	ВТ_ТаблицаКонтрактов.ДатаЛиквидации,
	|	ВТ_КонтрагентыЭДО.КонтрагентЭДО КАК Ссылка
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыЭДО КАК ВТ_КонтрагентыЭДО
	|		ПО ВТ_ТаблицаКонтрактов.ID = ВТ_КонтрагентыЭДО.ID
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТ_КонтрагентыЭДО.КонтрагентЭДО ЕСТЬ NULL 
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ВТ_ТаблицаКонтрактов.ИНН = ВТ_КонтрагентыЭДО.ИНН
	|							И ВТ_ТаблицаКонтрактов.КПП = ВТ_КонтрагентыЭДО.КПП
	|							И ВТ_ТаблицаКонтрактов.Наименование = ВТ_КонтрагентыЭДО.Наименование
	|							И ВТ_ТаблицаКонтрактов.ИдентификаторУчастникаЭДО = ВТ_КонтрагентыЭДО.ИдентификаторУчастникаЭДО
	|							И ВТ_ТаблицаКонтрактов.ДатаЛиквидации = ВТ_КонтрагентыЭДО.ДатаЛиквидации
	|							И ВТ_ТаблицаКонтрактов.OrgId = ВТ_КонтрагентыЭДО.OrgId
	|						ТОГДА ЛОЖЬ
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование
	|АВТОУПОРЯДОЧИВАНИЕ";

	Запрос.УстановитьПараметр("ТаблицаКонтрактов", ТаблицаКонтрактов);	
	
	РезультатЗапроса	= Запрос.Выполнить();
	ВыборкаЗапроса		= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		Контрагент = Контракт_КонтрагентЭДО();
		
		ЗаполнитьЗначенияСвойств(Контрагент, ВыборкаЗапроса);
		
		Результат.Добавить(Контрагент);
		
	КонецЦикла;	

	Возврат Результат;
	
КонецФункции

Функция Контрагенты_МассивКонтрагентовДляОбновленияСтатусов_Диадок(ТаблицаКонтрактов, Организация, Приглашения)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаКонтрактов.ID,
	|	ТаблицаКонтрактов.Статус
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
	|ИЗ
	|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ЭтоПриглашения
	|				ТОГДА ТаблицаКонтрактов.Статус = &Статус_РаботаетВДиадок
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТаблицаКонтрактов.Статус,
	|	Диадок_ЮрФизЛица.Ссылка КАК КонтрагентЭДО
	|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактовСопоставленная
	|ИЗ
	|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|		ПО (Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты"")
	|			И ВТ_ТаблицаКонтрактов.ID = Диадок_ЮрФизЛица.ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Диадок_НастройкиКонтрагентов.Контрагент,
	|	ВЫРАЗИТЬ(Диадок_НастройкиКонтрагентов.Значение КАК СТРОКА(30)) КАК ТекущийСтатус
	|ПОМЕСТИТЬ ВТ_Статусы
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	Диадок_НастройкиКонтрагентов.Организация = &Организация
	|	И Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус""
	|	И ВЫБОР
	|			КОГДА &ЭтоПриглашения
	|				ТОГДА (ВЫРАЗИТЬ(Диадок_НастройкиКонтрагентов.Значение КАК СТРОКА(30))) = &Статус_РаботаетВДиадок
	|			ИНАЧЕ (ВЫРАЗИТЬ(Диадок_НастройкиКонтрагентов.Значение КАК СТРОКА(30))) <> &Статус_РаботаетВДиадок
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО, ВТ_Статусы.Контрагент) КАК Ссылка,
	|	ЕСТЬNULL(ВТ_ТаблицаКонтрактовСопоставленная.Статус, """") КАК Статус
	|ИЗ
	|	ВТ_ТаблицаКонтрактовСопоставленная КАК ВТ_ТаблицаКонтрактовСопоставленная
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Статусы КАК ВТ_Статусы
	|		ПО ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО = ВТ_Статусы.Контрагент
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТ_Статусы.Контрагент ЕСТЬ NULL 
	|					ИЛИ ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО ЕСТЬ NULL 
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ВТ_Статусы.ТекущийСтатус = ВТ_ТаблицаКонтрактовСопоставленная.Статус
	|						ТОГДА ЛОЖЬ
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|		КОНЕЦ
	|АВТОУПОРЯДОЧИВАНИЕ";

	Запрос.УстановитьПараметр("Организация",			Организация.Ссылка);
	Запрос.УстановитьПараметр("ТаблицаКонтрактов",		ТаблицаКонтрактов);
	Запрос.УстановитьПараметр("ЭтоПриглашения",			Приглашения);
	Запрос.УстановитьПараметр("Статус_РаботаетВДиадок",	Перечисление_СтатусыКонтрагентов().РаботаетВДиадок);
	
	РезультатЗапроса	= Запрос.Выполнить();
	ВыборкаЗапроса		= РезультатЗапроса.Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		Контрагент = Контракт_КонтрагентЭДО();
		
		Контрагент.Ссылка	= ВыборкаЗапроса.Ссылка;
		Контрагент.Статус	= ВыборкаЗапроса.Статус;
		
		Результат.Добавить(Контрагент);
		
	КонецЦикла;	

	Возврат Результат;
	
КонецФункции

Функция Контрагенты_МассивКонтрагентовДляОбновленияДатыИзменения_Диадок(ТаблицаКонтрактов, Организация)
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаКонтрактов.ID КАК ID,
		|	ТаблицаКонтрактов.ДатаИзменения КАК ДатаИзменения
		|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактов
		|ИЗ
		|	&ТаблицаКонтрактов КАК ТаблицаКонтрактов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаКонтрактов.ДатаИзменения КАК ДатаИзменения,
		|	Диадок_ЮрФизЛица.Ссылка КАК КонтрагентЭДО
		|ПОМЕСТИТЬ ВТ_ТаблицаКонтрактовСопоставленная
		|ИЗ
		|	ВТ_ТаблицаКонтрактов КАК ВТ_ТаблицаКонтрактов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
		|		ПО (Диадок_ЮрФизЛица.ИмяСправочника = ""Контрагенты"")
		|			И ВТ_ТаблицаКонтрактов.ID = Диадок_ЮрФизЛица.ID
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Диадок_НастройкиКонтрагентов.Контрагент КАК Контрагент,
		|	ВЫРАЗИТЬ(Диадок_НастройкиКонтрагентов.Значение КАК Дата) КАК ДатаИзменения
		|ПОМЕСТИТЬ ВТ_ДатыИзменения
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|ГДЕ
		|	Диадок_НастройкиКонтрагентов.Организация = &Организация
		|	И Диадок_НастройкиКонтрагентов.ИмяСвойства = ""ДатаИзмененияСтатуса""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО, ВТ_ДатыИзменения.Контрагент) КАК Ссылка,
		|	ЕСТЬNULL(ВТ_ТаблицаКонтрактовСопоставленная.ДатаИзменения, ДАТАВРЕМЯ(1,1,1,0,0,0)) КАК ДатаИзменения
		|ИЗ
		|	ВТ_ТаблицаКонтрактовСопоставленная КАК ВТ_ТаблицаКонтрактовСопоставленная
		|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ДатыИзменения КАК ВТ_ДатыИзменения
		|		ПО ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО = ВТ_ДатыИзменения.Контрагент
		|ГДЕ
		|	ВЫБОР
		|			КОГДА ВТ_ДатыИзменения.Контрагент ЕСТЬ NULL 
		|					ИЛИ ВТ_ТаблицаКонтрактовСопоставленная.КонтрагентЭДО ЕСТЬ NULL 
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ВТ_ДатыИзменения.ДатаИзменения = ВТ_ТаблицаКонтрактовСопоставленная.ДатаИзменения
		|						ТОГДА ЛОЖЬ
		|					ИНАЧЕ ИСТИНА
		|				КОНЕЦ
		|		КОНЕЦ
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Организация", Организация.Ссылка);
	Запрос.УстановитьПараметр("ТаблицаКонтрактов", ТаблицаКонтрактов);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаЗапроса = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		Контрагент = Контракт_КонтрагентЭДО();
		
		Контрагент.Ссылка = ВыборкаЗапроса.Ссылка;
		Контрагент.ДатаИзменения = ВыборкаЗапроса.ДатаИзменения;
		
		Результат.Добавить(Контрагент);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура Контрагенты_ЗаписатьСтатус_Диадок(Контрагент, Организация)
	
	КонтрагентЭДО		= Контрагент.Ссылка;
	ОрганизацияЭДО		= Организация.Ссылка;
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО",	ОрганизацияЭДО);
	СтруктураДанных.Вставить("КонтрагентЭДО",	КонтрагентЭДО);
	СтруктураДанных.Вставить("ИмяСвойства",		"Статус");
	СтруктураДанных.Вставить("Значение",		Контрагент.Статус);
	
	Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);	
	
КонецПроцедуры

Процедура Контрагенты_ЗаписатьДатуИзменения_Диадок(Контрагент, Организация)
	
	КонтрагентЭДО = Контрагент.Ссылка;
	ОрганизацияЭДО = Организация.Ссылка;
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО", ОрганизацияЭДО);
	СтруктураДанных.Вставить("КонтрагентЭДО", КонтрагентЭДО);
	СтруктураДанных.Вставить("ИмяСвойства", "ДатаИзмененияСтатуса");
	СтруктураДанных.Вставить("Значение", Контрагент.ДатаИзменения);
	
	Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
	
КонецПроцедуры

Процедура Контрагенты_ЗаписатьСтатусДляМассива_Диадок(МассивКонтрагентов, Организация, Статус)
	
	Для Каждого Контрагент Из МассивКонтрагентов Цикл
		
		Контрагент.Статус = Статус;
		Контрагенты_ЗаписатьСтатус_Диадок(Контрагент, Организация);
		
	КонецЦикла;	
	
КонецПроцедуры

Функция Контрагенты_НеСопоставленныеКонтрагенты_Диадок()
	
	Запрос = Новый Запрос;
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса = Контрагенты_ТекстЗапроса_НесопоставленныеКонтрагенты_ДиадокРасширение();
	Иначе
		ТекстЗапроса = Контрагенты_ТекстЗапроса_НесопоставленныеКонтрагенты_ДиадокСХ1();
	КонецЕсли;
	
	Справочники_УстановитьИмяТаблицыКонтрагентовВТекстеЗапроса(ТекстЗапроса);
	
	ИмяСправочника = ТипЗначенияОбъекта("Контрагенты", "Краткий");
	МетаданныеСправочника = Метаданные.Справочники[ИмяСправочника];
	
	Если НЕ Общее_ЕстьРеквизитОбъекта("КПП", МетаданныеСправочника) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтрагентыИБ.КПП", """""");
	КонецЕсли;
	
	Если Общее_ЕстьСтандартныйРеквизитОбъекта("ЭтоГруппа", МетаданныеСправочника) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПоЭтоГруппа", "НЕ КонтрагентыИБ.ЭтоГруппа");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПоЭтоГруппа", "Истина");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ИмяСправочника", "Контрагенты");
	Запрос.УстановитьПараметр("ИмяРеквизита", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = РезультатЗапроса.Выгрузить();
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_НесопоставленныеКонтрагенты_ДиадокРасширение()
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыИБ.Ссылка КАК Ссылка,
	|	КонтрагентыИБ.ИНН КАК ИНН,
	|	КонтрагентыИБ.КПП КАК КПП
	|ИЗ
	|	Справочник.Контрагенты КАК КонтрагентыИБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
	|			ПО Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка = Диадок_ЮрФизЛица.Ссылка
	|				И (Диадок_ЮрФизЛица.ИмяСправочника = &ИмяСправочника)
	|		ПО (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ИмяРеквизита)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение = КонтрагентыИБ.Ссылка)
	|ГДЕ
	|	Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка ЕСТЬ NULL
	|	И НЕ КонтрагентыИБ.ПометкаУдаления
	|	И &УсловиеПоЭтоГруппа";
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_НесопоставленныеКонтрагенты_ДиадокСХ1()
	
	Результат =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЮрФизЛица.СвязанныйСправочник1 КАК Контрагент1С,
	|	ЮрФизЛица.Ссылка КАК КонтрагентЭДО
	|ПОМЕСТИТЬ ВТ_ТаблицаСоСвязями
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|ГДЕ
	|	НЕ ЮрФизЛица.СвязанныйСправочник1 = НЕОПРЕДЕЛЕНО
	|	И НЕ ЮрФизЛица.СвязанныйСправочник1 = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЮрФизЛица.СвязанныйСправочник2,
	|	ЮрФизЛица.Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|ГДЕ
	|	НЕ ЮрФизЛица.СвязанныйСправочник2 = НЕОПРЕДЕЛЕНО
	|	И НЕ ЮрФизЛица.СвязанныйСправочник2 = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЮрФизЛица.СвязанныйСправочник3,
	|	ЮрФизЛица.Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|ГДЕ
	|	НЕ ЮрФизЛица.СвязанныйСправочник3 = НЕОПРЕДЕЛЕНО
	|	И НЕ ЮрФизЛица.СвязанныйСправочник3 = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЮрФизЛицаДопРеквизиты.Значение,
	|	ЮрФизЛица.Ссылка
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК ЮрФизЛицаДопРеквизиты
	|		ПО ЮрФизЛица.Ссылка = ЮрФизЛицаДопРеквизиты.Ссылка
	|ГДЕ
	|	ЮрФизЛицаДопРеквизиты.ИмяРеквизита ПОДОБНО &ИмяРеквизита
	|	И НЕ ЮрФизЛицаДопРеквизиты.Значение = НЕОПРЕДЕЛЕНО
	|	И НЕ ЮрФизЛицаДопРеквизиты.Значение = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыИБ.Ссылка КАК Ссылка,
	|	КонтрагентыИБ.ИНН КАК ИНН,
	|	КонтрагентыИБ.КПП КАК КПП
	|ИЗ
	|	Справочник.Контрагенты КАК КонтрагентыИБ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаСоСвязями КАК ВТ_ТаблицаСоСвязями
	|		ПО КонтрагентыИБ.Ссылка = ВТ_ТаблицаСоСвязями.Контрагент1С
	|ГДЕ
	|	НЕ КонтрагентыИБ.ПометкаУдаления
	|	И ВТ_ТаблицаСоСвязями.КонтрагентЭДО ЕСТЬ NULL
	|	И &УсловиеПоЭтоГруппа";
	
	Возврат Результат;
	
КонецФункции


//**********************************************
// СИНХРОНИЗАЦИЯ КОНТРАГЕНТОВ: 1С-ЭДО

Функция Контрагенты_НеСопоставленныеКонтрагенты_1С()
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	КонтрагентыИБ.ИНН КАК ИНН,
		|	КонтрагентыИБ.КПП КАК КПП,
		|	КонтрагентыИБ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК КонтрагентыИБ
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО КонтрагентыИБ.Ссылка = ДополнительныеСведения.Объект
		|			И (ДополнительныеСведения.Свойство = &Свойство_BoxId)
		|ГДЕ
		|	НЕ КонтрагентыИБ.ПометкаУдаления
		|   И &УсловиеПоЭтоГруппа
		|	И ДополнительныеСведения.Объект ЕСТЬ NULL";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(ТекстЗапроса);
	
	ИмяСправочника = ТипЗначенияОбъекта("Контрагенты", "Краткий");
	МетаданныеСправочника = Метаданные.Справочники[ИмяСправочника];
	
	Если НЕ Общее_ЕстьРеквизитОбъекта("КПП", МетаданныеСправочника) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КонтрагентыИБ.КПП", """""");
	КонецЕсли;
	
	Если Общее_ЕстьСтандартныйРеквизитОбъекта("ЭтоГруппа", МетаданныеСправочника) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПоЭтоГруппа", "НЕ КонтрагентыИБ.ЭтоГруппа");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПоЭтоГруппа", "Истина");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.Параметры.Вставить("Свойство_BoxId", Свойства_IDКонтрагента());
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = РезультатЗапроса.Выгрузить();
	
	Возврат Результат;
	
КонецФункции

