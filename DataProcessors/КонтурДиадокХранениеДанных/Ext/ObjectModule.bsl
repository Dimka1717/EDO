Процедура ДопРеквизиты_УстановитьЗначение_Диадок(Знач Элемент, ИмяРеквизита, Значение, ЗначениеСтрока)
	
	Если Элемент = Неопределено Тогда
		Элемент = ДопСправочники_НайтиПоНаименованию_Диадок("ОбщиеНастройки", "ОбщиеНастройки");
	КонецЕсли;
	
	ЭтоОбъект	= ЭтоОбъект(Элемент);
	Объект		= ?(ЭтоОбъект, Элемент, Элемент.ПолучитьОбъект());
	
	СтрокаРеквизита = Объект.ДополнительныеРеквизиты.Найти(ИмяРеквизита, "ИмяРеквизита");
	
	Если СтрокаРеквизита = Неопределено Тогда
		
		ЗначениеДляУстановкиНеЗаполнено = (НЕ ЗначениеЗаполнено(Значение) 
											ИЛИ Значение = Ложь 
											ИЛИ Значение = ПустойИдентификатор())
										И (НЕ ЗначениеЗаполнено(ЗначениеСтрока) 
											ИЛИ ЗначениеСтрока = ПустойИдентификатор());
		
		Если ЗначениеДляУстановкиНеЗаполнено Тогда
			Возврат;
		КонецЕсли;
		
		СтрокаРеквизита					= Объект.ДополнительныеРеквизиты.Добавить();
		СтрокаРеквизита.ИмяРеквизита	= ИмяРеквизита;
		
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("ХранилищеЗначения") Тогда
		СтрокаРеквизита.ЗначениеХранилищеЗначения = Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Структура") Тогда
		СтрокаРеквизита.ЗначениеХранилищеЗначения = Новый ХранилищеЗначения(Значение);
	Иначе	
		СтрокаРеквизита.Значение = Значение;
	КонецЕсли;
	
	СтрокаРеквизита.ЗначениеСтрока = ЗначениеСтрока;
	
	Если Не ЭтоОбъект Тогда
		Объект.Записать();
	КонецЕсли;

КонецПроцедуры

Процедура ДопРеквизиты_ЗаписатьОсновнойПакет_Диадок(ОрганизацияЭДО, Значение)
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО",	ОрганизацияЭДО);
	СтруктураДанных.Вставить("КонтрагентЭДО",	Контрагенты_ПустаяСсылка_Диадок());
	СтруктураДанных.Вставить("ИмяСвойства",		Перечисление_ИменаСвойствНастроек_Диадок().ОсновнойПакет);
	СтруктураДанных.Вставить("Значение",		Значение);
	
	Если ЗначениеЗаполнено(Значение) Тогда
		Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
	Иначе
		Справочники_УдалитьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
	КонецЕсли;	
	
КонецПроцедуры

Процедура ДопРеквизиты_ЗаписатьШифрованиеДокумента_Диадок(ОрганизацияЭДО, КонтрагентЭДО, Значение)
	
	Если КонтрагентЭДО = Неопределено Тогда
		КонтрагентЭДО = Контрагенты_ПустаяСсылка_Диадок();
	КонецЕсли;
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО",	ОрганизацияЭДО);
	СтруктураДанных.Вставить("КонтрагентЭДО",	КонтрагентЭДО);
	СтруктураДанных.Вставить("ИмяСвойства",		Перечисление_ИменаСвойствНастроек_Диадок().ШифроватьДокументы);
	СтруктураДанных.Вставить("Значение",		Значение);
	
