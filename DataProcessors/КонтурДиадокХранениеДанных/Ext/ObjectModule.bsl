	ВыборкаДанных	= Справочники_ВыборкаДанныхСправочника_Диадок("Контрагенты", Идентификаторы);
	
	Если ВыборкаДанных <> Неопределено Тогда
		
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаДанных);
		
		ИменаДопРеквизитов	= "ДатаЛиквидации, OrgId";
		ДопРеквизиты		= ДопРеквизиты_СписокРеквизитов_Диадок(Результат.Ссылка, ИменаДопРеквизитов);
