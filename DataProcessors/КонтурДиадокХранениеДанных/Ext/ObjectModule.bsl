	Число2	= Число2_Из_Base64(Base64);
	Число16 = Число16_Из_Числа2(Число2);
	
	Если СтрДлина(Число16) > 64 Тогда 
		Число16 = Прав(Число16, 64);
	КонецЕсли;
	
	Результат = GUID_Из_Числа16(Число16);
	
	Возврат Результат; 
		
