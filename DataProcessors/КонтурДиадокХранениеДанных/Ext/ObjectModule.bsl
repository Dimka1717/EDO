//{		НАСТРОЙКИ ПЕЧАТНЫХ ФОРМ

// Записывает в базу настройки печатных форм для вида документа в разрезе организации и/или контрагента,
// удаляя при этом ранее записанные данные.
//
// Для подсистемы хранения 1С настройки могут храниться только в одном разрезе: или организации, или контрагента.
// Подсистема хранения Диадок может хранить настройки одновременно в разрезе организации и контрагента.
//
// Настройки хранятся в виде уникальных идентификаторов печатных форм
//
// Параметры:
//  ВидДокумента			 - 	Строка - идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//  НастройкиПечатныхФорм	 - 	Структура - см. функцию Ядро.Новый_НастройкиПечатныхФорм()
//  ДанныеОрганизации		 - 	Структура - см. функцию Ядро.Контракт_ОрганизацияЭДО()
//  ДанныеКонтрагента		 - 	Структура - см. функцию Ядро.Контракт_КонтрагентЭДО()
//
Процедура НастройкиПечатныхФорм_Записать(НастройкиПечатныхФорм, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт 
	
	КоллекцияСвойств = Новый Соответствие;
	
	Для Каждого ЭлементКоллекции Из НастройкиПечатныхФорм Цикл
		
		ВидДокумента			= ЭлементКоллекции.Ключ;
		НастройкаПечатныхФорм	= ЭлементКоллекции.Значение;
		
		Если Не НастройкаПечатныхФорм.ОсновнаяПечатнаяФорма = Неопределено Тогда
			КоллекцияСвойств.Вставить("ПФ_" + ВидДокумента, НастройкаПечатныхФорм.ОсновнаяПечатнаяФорма.УникальныйИдентификатор());
		КонецЕсли;
		
		НастройкиПечатныхФорм_Удалить(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
		
		НастройкиПечатныхФорм_СоздатьКоллекциюНастроек(ВидДокумента, КоллекцияСвойств, НастройкаПечатныхФорм);
		
	КонецЦикла;
	
	Настройки_ЗаписатьЗначенияСвойств(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	
КонецПроцедуры

Процедура НастройкиПечатныхФорм_СоздатьКоллекциюНастроек(ВидДокумента, КоллекцияСвойств, НастройкаПечатныхФорм)
	
	Для сц = 1 По НастройкаПечатныхФорм.ДополнительныеПечатныеФормы.Количество() Цикл
		
		ПечатнаяФорма = НастройкаПечатныхФорм.ДополнительныеПечатныеФормы[сц - 1];
		КоллекцияСвойств.Вставить("ПФ_" + Формат(сц, "ЧГ=0") + "_" + ВидДокумента, ПечатнаяФорма.УникальныйИдентификатор());
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает сохраненные в информационной базе настройки печатных форм в разрезе видов документов для организации или контрагента,
// если для него были включена индивидуальная настройка.
//
// Параметры:
//  ИдентификаторыВидовДокументов	 - Массив 		- массив строк идентификаторов видов документов
//														(пример ид. видов документов: ID_УПД, ID_УКД, ID_ТОРГ12, ID_СчетФактура и др).
//  ДанныеОрганизации				 - Структура	- заполненный контракт данных организации (см. Контракт_ОрганизацияЭДО)
//  ДанныеКонтрагента				 - Структура	- заполненный контракт данных контрагента (см. Контракт_КонтрагентЭДО). Необязательный параметр. 
// 
// Возвращаемое значение:
//  Соответствие - Ключ - ид. вида документа, значение - настройки ПФ (см. НастройкиПечатныхФорм_НовыеНастройкиПоВидамДокументов)
//
Функция НастройкиПечатныхФорм_ПоВидамДокументов(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт 
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = НастройкиПечатныхФорм_ПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		Результат = НастройкиПечатныхФорм_ПоВидамДокументов_1С(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

// см. НастройкиПечатныхФорм_ПоВидамДокументов
//
Функция НастройкиПечатныхФорм_ПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) 

	Результат = НастройкиПечатныхФорм_НовыеНастройкиПоВидамДокументов(ИдентификаторыВидовДокументов);
	
	Если ДанныеКонтрагента = Неопределено Тогда
		ТекстЗапроса = ТекстЗапроса_НастройкиПечатныхФормОрганизацииПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов);
	Иначе
		ТекстЗапроса = ТекстЗапроса_НастройкиПечатныхФормКонтрагентаПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов);
	КонецЕсли;

	Запрос = Новый Запрос(ТекстЗапроса);
	
	Настройки_ЗаполнитьОбщиеПараметрыЗапроса_Диадок(Запрос, ДанныеОрганизации, ДанныеКонтрагента);

	ВыборкаВидовДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВидовДокументов.Следующий() Цикл
		
		НовыеНастройки = Результат.Получить(ВыборкаВидовДокументов.ВидДокумента);
		
		ИмяСвойстваОсновнойПечатнойФормы = "ПФ_" + ВыборкаВидовДокументов.ВидДокумента;
		
		Выборка = ВыборкаВидовДокументов.Выбрать();
		НастройкиПечатныхФорм_Заполнить(НовыеНастройки, Выборка, ИмяСвойстваОсновнойПечатнойФормы);
		
		НастройкиПечатныхФорм_ДополнитьСсылкамиНаВнешниеПечатныеФормы(НовыеНастройки);
		
		Результат.Вставить(ВыборкаВидовДокументов.ВидДокумента, НовыеНастройки);
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

// см. НастройкиПечатныхФорм_ПоВидамДокументов
//
Функция НастройкиПечатныхФорм_ПоВидамДокументов_1С(ИдентификаторыВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) 
	
	Результат = НастройкиПечатныхФорм_НовыеНастройкиПоВидамДокументов(ИдентификаторыВидовДокументов);

	ТекстЗапроса = ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_1С(ИдентификаторыВидовДокументов);

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Организация", ДанныеОрганизации.СвязанныйСправочник1);
	
	Если ДанныеКонтрагента = Неопределено Тогда
		Запрос.УстановитьПараметр("Контрагент", ДанныеОрганизации.СвязанныйСправочник1);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", ДанныеКонтрагента.СвязанныйСправочник1);
	КонецЕсли;

	ВыборкаВидовДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВидовДокументов.Следующий() Цикл
		
		НовыеНастройки = Результат.Получить(ВыборкаВидовДокументов.ИдВидаДокумента);
		
		ИмяСвойстваОсновнойПечатнойФормы = ПрефиксНастройки_1С(Истина) + "ПФ_" + ВыборкаВидовДокументов.ИдВидаДокумента;
		
		Выборка = ВыборкаВидовДокументов.Выбрать();
		НастройкиПечатныхФорм_Заполнить(НовыеНастройки, Выборка, ИмяСвойстваОсновнойПечатнойФормы);
		
		НастройкиПечатныхФорм_ДополнитьСсылкамиНаВнешниеПечатныеФормы(НовыеНастройки);
		
		Результат.Вставить(ВыборкаВидовДокументов.ИдВидаДокумента, НовыеНастройки);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Дополняет контракт с настройками печатных форм ссылка на элемент справочника доп. обработок (внешнюю печатную форму)
//
Процедура НастройкиПечатныхФорм_ДополнитьСсылкамиНаВнешниеПечатныеФормы(Настройки)
	
	ИмяСправочника = Свойства_ИмяСправочникаДополнительныхОбработок();
	
	Если ЗначениеЗаполнено(Настройки.ОсновнаяПечатнаяФорма) Тогда
		ИдентификаторПечатнойФормы = Новый УникальныйИдентификатор(Настройки.ОсновнаяПечатнаяФорма);
		Настройки.ОсновнаяПечатнаяФорма = Справочники[ИмяСправочника].ПолучитьСсылку(ИдентификаторПечатнойФормы);
	КонецЕсли;
	
	Для ИндексСтроки = 0 По Настройки.ДополнительныеПечатныеФормы.ВГраница() Цикл
		ИдентификаторПечатнойФормы = Новый УникальныйИдентификатор(Настройки.ДополнительныеПечатныеФормы[ИндексСтроки]);
		Настройки.ДополнительныеПечатныеФормы[ИндексСтроки] = Справочники[ИмяСправочника].ПолучитьСсылку(ИдентификаторПечатнойФормы);
	КонецЦикла;
	
КонецПроцедуры

// Возвращает коллекцию контрактов настроек печатных форм в разрезе видов документов 
//
// Параметры:
//  ИдентификаторыВидовДокументов	 - Массив 		- массив строк идентификаторов видов документов
//														(пример ид. видов документов: ID_УПД, ID_УКД, ID_ТОРГ12, ID_СчетФактура и др).
// 
// Возвращаемое значение:
//  Соответствие - Ключ - ид. вида документа, значение - контракт настроек ПФ (см. Ядро.Новый_НастройкиПечатныхФорм)
//
Функция НастройкиПечатныхФорм_НовыеНастройкиПоВидамДокументов(ИдентификаторыВидовДокументов)
	
	Результат = Новый Соответствие;
	
	Для Каждого ИдВидаДокумента Из ИдентификаторыВидовДокументов Цикл
		
		НовыеНастройки = Ядро.Новый_НастройкиПечатныхФорм();	
		
		Результат.Вставить(ИдВидаДокумента, НовыеНастройки);
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

// Считывает из базы настройки печатных форм для вида документа по указанной организации и/или контрагенту
//
// Параметры:
//  ВидДокумента		 - 	Строка - Идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//  ДанныеОрганизации	 - 	Структура - см. функцию Ядро.Контракт_ОрганизацияЭДО()
//  ДанныеКонтрагента	 - 	Структура - см. функцию Ядро.Контракт_КонтрагентЭДО()
// 
// Возвращаемое значение:
//  Структура - см. функцию Ядро.Новый_НастройкиПечатныхФорм()
//
Функция НастройкиПечатныхФорм_Прочитать(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт 
	
	ИдВидовДокументов = Новый Массив;
	ИдВидовДокументов.Добавить(ВидДокумента);
	
	НастройкиПФ = НастройкиПечатныхФорм_ПоВидамДокументов(ИдВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента);
	
	Результат = НастройкиПФ.Получить(ВидДокумента);
	
	Возврат Результат;
	
КонецФункции

// Заполняет настройки печатных форм данными заполнения
//
// Параметры:
//  НастройкиПечатныхФорм				 - 	Структура - см. функцию Ядро.Новый_НастройкиПечатныхФорм()
//  ДанныеЗаполнения					 - 	ВыборкаИзРезультатаЗапроса - Выборка с полями "ИмяСвойства", "Значение"
//  ИмяСвойстваОсновнойПечатнойФормы	 - 	Строка - Имя свойства вида : "ПФ_ID_АктФормализованный", "DDPro_ПФ_ID_АктФормализованный" и т.д.
//
Процедура НастройкиПечатныхФорм_Заполнить(НастройкиПечатныхФорм, ДанныеЗаполнения, ИмяСвойстваОсновнойПечатнойФормы)
	
	Пока ДанныеЗаполнения.Следующий() Цикл
		
		Если ДанныеЗаполнения.ИмяСвойства = ИмяСвойстваОсновнойПечатнойФормы Тогда
			НастройкиПечатныхФорм.ОсновнаяПечатнаяФорма = ДанныеЗаполнения.Значение;
		Иначе
			НастройкиПечатныхФорм.ДополнительныеПечатныеФормы.Добавить(ДанныеЗаполнения.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура НастройкиПечатныхФорм_Удалить(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		НастройкиПечатныхФорм_Удалить_Диадок(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	Иначе
		НастройкиПечатныхФорм_Удалить_1С(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента);
	КонецЕсли;
	
КонецПроцедуры

Процедура НастройкиПечатныхФорм_Удалить_Диадок(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	Организация = ДанныеОрганизации.Ссылка;
	Контрагент = ?(ДанныеКонтрагента = Неопределено, Контрагенты_ПустаяСсылка_Диадок(), ДанныеКонтрагента.Ссылка);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_НастройкиКонтрагентов.ИмяСвойства КАК ИмяСвойства
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	Диадок_НастройкиКонтрагентов.Организация = &Организация
	|	И Диадок_НастройкиКонтрагентов.Контрагент = &Контрагент
	|	И Диадок_НастройкиКонтрагентов.ИмяСвойства ПОДОБНО &ИмяСвойства";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ИмяСвойства", "ПФ_%" + ВидДокумента);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.Диадок_НастройкиКонтрагентов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(Организация);
	НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НаборЗаписей.Отбор.ИмяСвойства.Установить(Выборка.ИмяСвойства);
		НаборЗаписей.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура НастройкиПечатныхФорм_Удалить_1С(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента)
	
	ХранителиСвойств = СвязанныеСправочники(ДанныеОрганизации, ДанныеКонтрагента);
				
	Если ХранителиСвойств.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
			
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияСвойствОбъектов.Свойство КАК Свойство
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.СвойстваОбъектов КАК СвойстваОбъектов
	|		ПО ЗначенияСвойствОбъектов.Свойство = СвойстваОбъектов.Ссылка
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Объект
	|	И СвойстваОбъектов.Наименование ПОДОБНО &ИмяСвойства";
	
	ИмяСвойства = ПрефиксНастройки_1С(Истина) + "ПФ_%" + ВидДокумента;
	
	Запрос.УстановитьПараметр("Объект"		, ХранителиСвойств[0].Ссылка);
	Запрос.УстановитьПараметр("ИмяСвойства"	, ИмяСвойства);
	
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	ИмяПланаВидовХарактеристик = Свойства_ИмяПланаВидовХарактеристик();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланВидовХарактеристик.СвойстваОбъектов", "ПланВидовХарактеристик." + ИмяПланаВидовХарактеристик);
	
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда
		
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Для Каждого ИскомыйОбъект Из ХранителиСвойств Цикл
				
				НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Объект.Установить(ИскомыйОбъект.Ссылка);
				НаборЗаписей.Отбор.Свойство.Установить(Выборка.Свойство);
				НаборЗаписей.Записать();
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Тексты запросов

Функция ТекстЗапроса_НастройкиПечатныхФормКонтрагентаПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов)

	ТекстЗапросаНастроекОрганизации = ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_Диадок(
		ИдентификаторыВидовДокументов, "ВремНастройкиПФОрганизации");
	ТекстЗапросаНастроекКонтрагента = ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_Диадок(
		ИдентификаторыВидовДокументов, "ВремНастройкиПФКонтрагента");

	ТекстЗапросаНастроекОрганизации = СтрЗаменить(ТекстЗапросаНастроекОрганизации, "&КонтрагентЭДО", "ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)");
	
	ТекстДопУсловия = "И НастройкиКонтрагентов.Контрагент <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)";
	ТекстЗапросаНастроекКонтрагента = СтрЗаменить(ТекстЗапросаНастроекКонтрагента, "//ДОП_УСЛОВИЯ", ТекстДопУсловия);

	Результат = ТекстЗапросаНастроекКонтрагента + ТекстЗапроса_РазделительЗапросов() + ТекстЗапросаНастроекОрганизации;
	
	Результат = Результат + ТекстЗапроса_РазделительЗапросов() +
	"ВЫБРАТЬ
	|	НастройкиПФКонтрагента.ИмяСвойства 		КАК ИмяСвойства,
	|	НастройкиПФКонтрагента.Значение 		КАК Значение,
	|	НастройкиПФКонтрагента.ВидДокумента 	КАК ВидДокумента
	|ИЗ
	|	ВремНастройкиПФКонтрагента КАК НастройкиПФКонтрагента
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НастройкиПФОрганизации.ИмяСвойства,
	|	НастройкиПФОрганизации.Значение,
	|	НастройкиПФОрганизации.ВидДокумента
	|ИЗ
	|	ВремНастройкиПФОрганизации КАК НастройкиПФОрганизации
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ КОЛИЧЕСТВО(Значение) КАК Количество ИЗ ВремНастройкиПФКонтрагента) КАК ВремКоличествоНастроекКонтрагента
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ЕСТЬNULL(ВремКоличествоНастроекКонтрагента.Количество, 0) = 0
	|
	|ИТОГИ ПО
	|	ВидДокумента";
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_НастройкиПечатныхФормОрганизацииПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов)

	Результат = ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов);
	
	ИменаПолейИтогов = "ВидДокумента";

	Результат = Результат + ТекстЗапроса_ПоляИтогов(ИменаПолейИтогов);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_НастройкиПечатныхФормПоВидамДокументов_Диадок(ИдентификаторыВидовДокументов, Знач ИмяВременнойТаблицы = "")
	
	Результат = "";
	
	ШаблонТекстаЗапроса = ТекстЗапроса_НастройкиКонтрагента_Диадок();
	
	УдаляемоеУсловие 	= "И НастройкиКонтрагентов.ИмяСвойства В (&ИменаСвойств)";
	НовоеУсловие 		= "И НастройкиКонтрагентов.ИмяСвойства ПОДОБНО ""%2""";
	
	ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, УдаляемоеУсловие, НовоеУсловие);
	ШаблонТекстаЗапроса = СтрЗаменить(ШаблонТекстаЗапроса, "//ДОП_ПОЛЯ", ", ""%1"" КАК ВидДокумента");
	
	ПрефиксНастроекПФ = "ПФ_%";
	
	ШаблонДопПоляЗапроса = ", %1 КАК ВидДокумента";
	
	Для Каждого ВидДокумента Из ИдентификаторыВидовДокументов Цикл
		
		ШаблонИмениСвойства = ПрефиксНастроекПФ + ВидДокумента;
		
		ТекстЗапроса = Общее_ПодставитьПараметрыВСтроку(ШаблонТекстаЗапроса, ВидДокумента, ШаблонИмениСвойства);
		
		Если НЕ ПустаяСтрока(ИмяВременнойТаблицы) Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//ИМЯ_ВРЕМЕННОЙ_ТАБЛИЦЫ", "ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
			ИмяВременнойТаблицы = "";
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Результат) Тогда
			Результат = Результат + ТекстЗапроса_ОбъединениеЗапросов();
		КонецЕсли;
		
		Результат = Результат + ТекстЗапроса; 
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапроса_ВременнаяТаблицаСвойствИспользуемыхДляХраненияНастроекПечатныхФорм_1С(ИдентификаторыВидовДокументов)
	
	Результат = "";
	
	ШаблонТекстаЗапроса_СвойстваНастроекПФ = 
	"ВЫБРАТЬ
	|	Свойства.Ссылка 		КАК Ссылка,
	|	Свойства.Наименование 	КАК ИмяСвойства,
	|	""%1"" 					КАК ИдВидаДокумента
	|%2
	|ИЗ
	|	ПланВидовХарактеристик.СвойстваОбъектов КАК Свойства
	|ГДЕ
	|	Свойства.Наименование ПОДОБНО ""%3""";
	
	ИмяВременнойТаблицы = "ПОМЕСТИТЬ ВремСвойстваПФ";
	ПрефиксНастроекПФ 	= ПрефиксНастройки_1С(Истина) + "ПФ_%";
	
	Для Каждого ИдВидаДокумента Из ИдентификаторыВидовДокументов Цикл
		
		Если НЕ ПустаяСтрока(Результат) Тогда
			Результат = Результат + ТекстЗапроса_ОбъединениеЗапросов();
			ИмяВременнойТаблицы = "";
		КонецЕсли;
		
		ИмяСвойства = ПрефиксНастроекПФ + ИдВидаДокумента;
		
		ВремТекстЗапроса = Общее_ПодставитьПараметрыВСтроку(
			ШаблонТекстаЗапроса_СвойстваНастроекПФ,
			ИдВидаДокумента,
			ИмяВременнойТаблицы,
			ИмяСвойства);
		
		Результат = Результат + ВремТекстЗапроса;
		
	КонецЦикла;
	
	ТекстЗапроса_УстановитьИмяПланаВидовХарактеристик(Результат);

	Возврат Результат;
	
КонецФункции

