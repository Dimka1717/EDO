КонецФункции

Процедура ДопСправочники_ЗаполнитьВидыГруппировкиПолученных(ТаблицаВидовГруппировки)
	
	МассивДобавленныхТипов = Новый Массив;
	
	ТаблицаТиповДокументов = ПредопределенныеСписки_ТипыДокументовAPI();
	
	Для Каждого СтрокаТЗ Из ТаблицаТиповДокументов Цикл		
		
		Если ЗначениеЗаполнено(СтрокаТЗ.TypeNamedId) Тогда
			
			СтрокаРезультата = ТаблицаВидовГруппировки.Найти(СтрокаТЗ.ГруппировкаДокументов, "Наименование");
			
			Если СтрокаРезультата = Неопределено Тогда
				
				СтрокаРезультата = ТаблицаВидовГруппировки.Добавить();
				СтрокаРезультата.Наименование	= СтрокаТЗ.ГруппировкаДокументов;
				СтрокаРезультата.ТипыДокументов	= "";
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаРезультата.Ссылка) Тогда
				Продолжить;
			КонецЕсли;
			
			Если МассивДобавленныхТипов.Найти(СтрокаТЗ.TypeNamedId) = Неопределено Тогда
				
				Если СтрокаРезультата.ТипыДокументов = "" Тогда
					СтрокаРезультата.ТипыДокументов = СтрокаТЗ.TypeNamedId;
				Иначе	
					СтрокаРезультата.ТипыДокументов = СтрокаРезультата.ТипыДокументов + "," + СтрокаТЗ.TypeNamedId;
				КонецЕсли;
				
				МассивДобавленныхТипов.Добавить(СтрокаТЗ.TypeNamedId);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры	

// Получает значения реквизитов для коллекции элементов СправочникСсылка
//
// Параметры:
//	КоллекцияСсылок	- Массив 	- массив с элементами СправочникСсылка
//	ИменаРеквизитов	- Строка	- имена реквизитов через запятую, значения которых необходимо получить
//
// Возвращаемое значение:
//	массив структур
Функция Справочники_ЗначенияРеквизитовЭлементовСправочникаИБ(КоллекцияСсылок, ИменаРеквизитов) Экспорт
	
	КонструкторЗапроса = КонструкторЗапросаРеквизитыЭлементовСправочникаИБ(КоллекцияСсылок, ИменаРеквизитов); 
			
	Запрос = Новый Запрос;
			
	ОбъединенияЗапросов = "	
							|
							| ОБЪЕДИНИТЬ ВСЕ
							| ";
	ТекстЗапроса = "";
	
	Для Каждого КлючЗначение Из КонструкторЗапроса Цикл
		
		Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
			ТекстЗапроса = ТекстЗапроса + ОбъединенияЗапросов;
		КонецЕсли;
						
		ТекстЗапроса = ТекстЗапроса + СвойствоСтруктуры(КлючЗначение.Значение, "ТекстЗапроса", "");
		
		ПараметрыПодзапроса = СвойствоСтруктуры(КлючЗначение.Значение, "ПараметрыЗапроса", Новый Массив);
			
		Запрос.УстановитьПараметр("СвязанныеСправочники_" + КлючЗначение.Ключ, ПараметрыПодзапроса); 
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
		ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ" + Сред(ТекстЗапроса, СтрДлина("ВЫБРАТЬ") + 1);
		
		Запрос.Текст 		= ТекстЗапроса;
		РезультатЗапроса 	= Запрос.Выполнить().Выгрузить();
		
		Результат = ТаблицаЗначенийВМассивСтруктур(РезультатЗапроса);
	Иначе
		Результат = Новый Массив;
	КонецЕсли;
						
	Возврат Результат;
	
КонецФункции

Функция КонструкторЗапросаРеквизитыЭлементовСправочникаИБ(КоллекцияСсылок, ИменаРеквизитов)
	
	КонструкторЗапроса = Новый Структура;
	
	Ключ_ТекстЗапроса 		= "ТекстЗапроса";
	Ключ_ПараметрыЗапроса 	= "ПараметрыЗапроса";
		
	ТребуемыеРеквизиты = РазделитьСтрокуЛок(ИменаРеквизитов);
	
	Для Каждого СправочникСсылка Из КоллекцияСсылок Цикл
		
		ИмяТаблицы = СправочникСсылка.Метаданные().Имя;
		
		ЭлементыЗапроса = СвойствоСтруктуры(КонструкторЗапроса, ИмяТаблицы, Новый Структура);
						
		// Текст запроса
		ТекстЗапроса = СвойствоСтруктуры(ЭлементыЗапроса, Ключ_ТекстЗапроса, "");
						
		Если Не ЗначениеЗаполнено(ТекстЗапроса) Тогда
			ТекстЗапроса = Справочники_ТекстЗапросаКТаблице(ИмяТаблицы, ТребуемыеРеквизиты);
			ЭлементыЗапроса.Вставить(Ключ_ТекстЗапроса, ТекстЗапроса);
		КонецЕсли;
		
		// Параметры
		ПараметрыЗапроса = СвойствоСтруктуры(ЭлементыЗапроса, Ключ_ПараметрыЗапроса, Новый Массив); 
								
		Если ПараметрыЗапроса.Найти(СправочникСсылка) = Неопределено Тогда
			ПараметрыЗапроса.Добавить(СправочникСсылка);
			ЭлементыЗапроса.Вставить(Ключ_ПараметрыЗапроса, ПараметрыЗапроса);
		КонецЕсли;
		
		КонструкторЗапроса.Вставить(ИмяТаблицы, ЭлементыЗапроса);
		
	КонецЦикла;
	
	Возврат КонструкторЗапроса;
	
КонецФункции

Функция Справочники_ТекстЗапросаКТаблице(ИмяТаблицы, ТребуемыеРеквизиты)
	
	ТекстЗапроса_Реквизиты = "";
	
	Счетчик = 1;
	Для Каждого ИмяРеквизита Из ТребуемыеРеквизиты Цикл
		
		РеквизитТаблицы = "Т."  + ИмяРеквизита;
		
		ТекстЗапроса_Реквизиты = ТекстЗапроса_Реквизиты + "
									| " + РеквизитТаблицы + " КАК " + ИмяРеквизита
									+ ?(Счетчик = ТребуемыеРеквизиты.Количество(), "", ",");
			
		СтрокаМетаданных = "Справочники." + ИмяТаблицы + ".Реквизиты." + ИмяРеквизита;
		Если Не ПроверитьНаличиеОбъектаМетаданных(СтрокаМетаданных) Тогда
			ТекстЗапроса_Реквизиты = СтрЗаменить(ТекстЗапроса_Реквизиты, РеквизитТаблицы, "НЕОПРЕДЕЛЕНО");	
		КонецЕсли;	
			
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
	Результат =
		"ВЫБРАТЬ
		| Т.Ссылка," +
        ТекстЗапроса_Реквизиты + "
		|ИЗ
       	|	Справочник.%ИмяТаблицы% КАК Т
	   	|ГДЕ
	   	|	Т.Ссылка В (&СвязанныеСправочники_%ИмяТаблицы%)";
			
	Результат = СтрЗаменить(Результат, "%ИмяТаблицы%", ИмяТаблицы);
	
	Возврат Результат;
			
КонецФункции

Функция СвязанныеСправочники(ДанныеОрганизации, ДанныеКонтрагента)
	
	// метод предназначен для поддержки совместимости с подключаемыми модулями прошлых версий,
	// написанными до реализации множественного сопоставления организаций, контрагентов, подразделений 
	
	Если ДанныеКонтрагента = Неопределено Тогда
		ОбрабатываемыеДанные = ДанныеОрганизации;
	Иначе
		ОбрабатываемыеДанные = ДанныеКонтрагента;
	КонецЕсли;
	
	Результат = СвойствоСтруктуры(ОбрабатываемыеДанные, "СвязанныеСправочники");
	
	Если Результат = Неопределено Тогда
		Результат = Новый Массив;
		СвязанныйСправочник = ОбрабатываемыеДанные.СвязанныйСправочник1;
		Результат.Добавить(СвязанныйСправочник);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Справочники_ЮрФизЛицоОбъект_ЗаполнитьСвязанныеСправочники(СправочникДиадокОбъект, СвязанныеСправочники)
	
	ИмяСвойстваСвязанныйСправочник = Перечисление_ИменаСвойствНастроек_Диадок().СвязанныйСправочник;
	
	Для Индекс = 0 По СвязанныеСправочники.ВГраница() Цикл
			
		ЭлементКоллекции = СвязанныеСправочники.Получить(Индекс);
		
		ИмяСвойстваСНомером = ИмяСвойстваСвязанныйСправочник + Формат(Индекс + 1, "ЧГ=0");
		
		Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() ИЛИ Индекс > 2 Тогда
			
			ДопРеквизиты_УстановитьЗначение(СправочникДиадокОбъект, ИмяСвойстваСНомером, ЭлементКоллекции.Ссылка);
			
		Иначе
			
			СправочникДиадокОбъект[ИмяСвойстваСНомером] = ЭлементКоллекции.Ссылка;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Справочники_ЮрФизЛицоОбъект_ОчиститьСвязанныеСправочники(ДиадокЮрФизЛицоОбъект)
	
	Если НЕ ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		
		Для Сч = 1 По 3 Цикл 
			ДиадокЮрФизЛицоОбъект["СвязанныйСправочник" + Сч] = Неопределено;
		КонецЦикла;
		
	КонецЕсли;
	
	ДопРеквизиты_ОчиститьСвязанныеСправочники_Диадок(ДиадокЮрФизЛицоОбъект);
	
КонецПроцедуры

