Функция СписокНаОтправку_ТекстЗапроса_ВременныеТаблицы_Диадок()
	
	ТекстЗапроса_РазделительЗапросов = ТекстЗапроса_РазделительЗапросов();
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапроса_СопоставленныеКонтрагенты = СписокНаОтправку_ТекстЗапроса_СопоставленныеКонтрагенты_ДиадокРасширение();
	Иначе
		ТекстЗапроса_СопоставленныеКонтрагенты = СписокНаОтправку_ТекстЗапроса_СопоставленныеКонтрагенты_ДиадокСХ1();
	КонецЕсли;
	
	ТекстЗапроса_НастройкиВидовПакетов = СписокНаОтправку_ТекстЗапроса_НастройкиВидовПакетов_Диадок();
	ТекстЗапроса_ОтправленныеДокументы = СписокНаОтправку_ТекстЗапроса_ОтправленныеДокументы_Диадок();
	ТекстЗапроса_УничтожениеВТ = СписокНаОтправку_ТекстЗапроса_УничтожениеВТ_Диадок();
	
	ЧастиТекстаЗапроса = Новый Массив;
	
	ЧастиТекстаЗапроса.Добавить(ТекстЗапроса_СопоставленныеКонтрагенты);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапроса_НастройкиВидовПакетов);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапроса_ОтправленныеДокументы);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапроса_УничтожениеВТ);
	
	Результат = СоединитьСтроку(ЧастиТекстаЗапроса, ТекстЗапроса_РазделительЗапросов);
				
	Возврат Результат;
	
КонецФункции

Функция СписокНаОтправку_ТекстЗапроса_СопоставленныеКонтрагенты_ДиадокРасширение()
	
	Результат =
	"ВЫБРАТЬ
	|	Диадок_НастройкиКонтрагентов.Организация КАК Организация,
	|	Диадок_НастройкиКонтрагентов.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВТ_МоиКонтрагентыЭДО
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус""
	|	И Диадок_НастройкиКонтрагентов.Значение = ""IsMyCounteragent""
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_МоиКонтрагенты.Организация КАК Организация,
	|	ВТ_МоиКонтрагенты.Контрагент КАК Контрагент,
	|	ВЫРАЗИТЬ(Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Справочник.Организации) КАК СвязанныйСправочник
	|ПОМЕСТИТЬ ВТ_СопоставленныеОрганизации
	|ИЗ
	|	ВТ_МоиКонтрагентыЭДО КАК ВТ_МоиКонтрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО ВТ_МоиКонтрагенты.Организация = Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение <> НЕОПРЕДЕЛЕНО)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_МоиКонтрагенты.Организация КАК Организация,
	|	ВТ_МоиКонтрагенты.Контрагент КАК Контрагент,
	|	ВЫРАЗИТЬ(Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение КАК Справочник.Контрагенты) КАК СвязанныйСправочник
	|ПОМЕСТИТЬ ВТ_СопоставленныеКонтрагенты
	|ИЗ
	|	ВТ_МоиКонтрагентыЭДО КАК ВТ_МоиКонтрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты
	|		ПО ВТ_МоиКонтрагенты.Контрагент = Диадок_ЮрФизЛицаДополнительныеРеквизиты.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.ИмяРеквизита ПОДОБНО &ШаблонИмениРеквизита_СвязанныйСправочник)
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты.Значение <> НЕОПРЕДЕЛЕНО)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СопоставленныеОрганизации.СвязанныйСправочник КАК Организация1С,
	|	ВТ_СопоставленныеКонтрагенты.СвязанныйСправочник КАК Контрагент1С,
	|	ВТ_МоиКонтрагенты.Организация КАК Организация,
	|	ВТ_МоиКонтрагенты.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВТ_КэшКонтрагентов
	|ИЗ
	|	ВТ_МоиКонтрагентыЭДО КАК ВТ_МоиКонтрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СопоставленныеОрганизации КАК ВТ_СопоставленныеОрганизации
	|		ПО ВТ_МоиКонтрагенты.Организация = ВТ_СопоставленныеОрганизации.Организация
	|			И ВТ_МоиКонтрагенты.Контрагент = ВТ_СопоставленныеОрганизации.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СопоставленныеКонтрагенты КАК ВТ_СопоставленныеКонтрагенты
	|		ПО ВТ_МоиКонтрагенты.Контрагент = ВТ_СопоставленныеКонтрагенты.Контрагент
	|			И ВТ_МоиКонтрагенты.Организация = ВТ_СопоставленныеКонтрагенты.Организация
	|ГДЕ
	|	НЕ ВТ_СопоставленныеОрганизации.СвязанныйСправочник ЕСТЬ NULL
	|	И НЕ ВТ_СопоставленныеКонтрагенты.СвязанныйСправочник ЕСТЬ NULL
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация1С,
	|	Контрагент1С";
	
	Возврат Результат;

КонецФункции

