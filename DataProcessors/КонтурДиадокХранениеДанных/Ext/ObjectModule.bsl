	Возврат Результат;
	
КонецФункции

Функция Контрагенты_УстановленныеСвязи(РезультатЗапроса)
	
	Результат = Новый Структура;
	
	КоличествоСопоставленных	= 0;
	МассивОшибокСопоставления	= Новый Массив;
	
	ВыборкаКонтрагентыЭДО = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаКонтрагентыЭДО.Следующий() Цикл
		
		КонтрагентЭДО = Неопределено;
		СвязанныеСправочники = Новый Массив;
		
		ВыборкаКонтрагентов1С = ВыборкаКонтрагентыЭДО.Выбрать();
		Пока ВыборкаКонтрагентов1С.Следующий() Цикл
			
			Если КонтрагентЭДО = Неопределено Тогда
				КонтрагентЭДО = ВыборкаКонтрагентов1С.КонтрагентСервиса_Ссылка;
			КонецЕсли;
			
			СвязанныеСправочники.Добавить(ВыборкаКонтрагентов1С.КонтрагентИБ);
			
		КонецЦикла;
		
		ID				= ВыборкаКонтрагентыЭДО.КонтрагентСервиса_ID;
		Идентификаторы	= Новый_ИдентификаторыСправочника(КонтрагентЭДО, ID);
		
		СтруктураРеквизитов	= Новый Структура("СвязанныеСправочники", СвязанныеСправочники);
		
		Контрагенты_ОбновлениеРеквизитов(Идентификаторы, СтруктураРеквизитов);
		
		КоличествоСопоставленных = КоличествоСопоставленных + 1;
		
	КонецЦикла;
	
	Результат.Вставить("КоличествоСопоставленных",	КоличествоСопоставленных);
	Результат.Вставить("МассивОшибокСопоставления",	МассивОшибокСопоставления);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ДополнитьОшибкиСопоставления(ВыборкаКонтрагентов)
	
	Результат = Новый Массив;
	
	Пока ВыборкаКонтрагентов.Следующий() Цикл
		
		КоличествоЯщиков = ВыборкаКонтрагентов.КоличествоЯщиковДД;
		
		Если КоличествоЯщиков > 1 Тогда
			
			ИНН = ВыборкаКонтрагентов.ИНН;
			КПП = ВыборкаКонтрагентов.КПП;
			
			ТекстОшибки = Контрагенты_ЗаполнитьОшибкуСопоставления(ИНН, КПП, КоличествоЯщиков, "ДублиДиадока");
			Результат.Добавить(ТекстОшибки);
						
		КонецЕсли;
		
		КоличествоЯщиков = ВыборкаКонтрагентов.КоличествоЯщиковРоуминг;
		
		Если КоличествоЯщиков > 1 Тогда
			
			ИНН = ВыборкаКонтрагентов.ИНН;
			КПП = ВыборкаКонтрагентов.КПП;
			
			ТекстОшибки = Контрагенты_ЗаполнитьОшибкуСопоставления(ИНН, КПП, КоличествоЯщиков, "ДублиРоуминга");
			Результат.Добавить(ТекстОшибки);
						
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ЗаполнитьОшибкуСопоставления(ИНН, КПП, КоличествоЯщиков, ВариантОшибки)
	
	Результат = "";
	
	ОписаниеОшибки	= НСтр("ru = 'Не удалось сопоставить контрагентов с ИНН/КПП %1/%2 по причине:'") + Символы.ПС;
	ОписаниеОшибки	= Общее_ПодставитьПараметрыВСтроку(ОписаниеОшибки
					, ?(ЗначениеЗаполнено(ИНН), ИНН, "<не указан>")
					, ?(ЗначениеЗаполнено(КПП), КПП, "<не указан>"));
					
	Если ВариантОшибки = "Дубли1С" Тогда
		ПричинаОшибки = НСтр("ru = 'Найдены дубли (%1 шт.) в справочнике 1С.'");
	ИначеЕсли ВариантОшибки = "ДублиДиадока" Тогда
		ПричинаОшибки = НСтр("ru = 'В сервисе Диадок заведено несколько ящиков (%1 шт.).'");
	ИначеЕсли ВариантОшибки = "ДублиРоуминга" Тогда
		ПричинаОшибки = НСтр("ru = 'В роуминге заведено несколько ящиков (%1 шт.).'");	
	КонецЕсли;	
	
	ПричинаОшибки	= Общее_ПодставитьПараметрыВСтроку(ПричинаОшибки, КоличествоЯщиков);
	
	Результат = ОписаниеОшибки + ПричинаОшибки;
	
	Возврат Результат;
	
КонецФункции	

