КонецФункции

Функция ИспользоватьТиповуюПодсистему1С()
	
	ИмяНастройки = Перечисление_ИменаСвойствНастроек_1С().ИспользоватьТиповуюПодсистему1С;
	
	Результат = Кэш_Прочитать(ИмяНастройки);
	
	Если Результат = Неопределено Тогда
		
		ОписаниеОшибкиИнициализации	= "";
		ОбъектОбщихНастроек			= ОбъектОбщихНастроек_1С(ОписаниеОшибкиИнициализации);
		ОшибкаИнициализации			= ЗначениеЗаполнено(ОписаниеОшибкиИнициализации);
		
		Если НЕ ОшибкаИнициализации Тогда
			
			Попытка
				Результат = Свойства_ЗначениеСвойства(ИмяНастройки, ОбъектОбщихНастроек);
			Исключение
				Ошибка						 = ИнформацияОбОшибке();
				ОписаниеОшибкиИнициализации	 = КраткоеПредставлениеОшибки(Ошибка);
				ОшибкаИнициализации			 = Истина;
			КонецПопытки;
			
		КонецЕсли;
		
		Если Результат = Ложь Тогда
			
			УстановленаПодсистемаДиадока = УстановленаПодсистемаДиадока();
			
			Если НЕ УстановленаПодсистемаДиадока Тогда
				Результат = Неопределено;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипЗнч(Результат) <> Тип("Булево") Тогда
			
			УстановленаПодсистемаДиадока = УстановленаПодсистемаДиадока();
			УстановленРегистрДопСведений = УстановленРегистрДопСведений();
			
			МожноИспользоватьРегистрДопСведений = (УстановленРегистрДопСведений И НЕ ОшибкаИнициализации);
			
			Если УстановленаПодсистемаДиадока Тогда
				Результат = Ложь;
			ИначеЕсли МожноИспользоватьРегистрДопСведений Тогда
				Результат = Истина;
			Иначе
				
				Если ОшибкаИнициализации Тогда
					ТекстСообщения = ОписаниеОшибкиИнициализации;
				Иначе
					ТекстСообщения = " Не удалось определить систему хранения.";
				КонецЕсли;
				
				ТекстСообщения = "Ошибка инициализации модуля." + Символы.ПС + ТекстСообщения; 
				
				Если УстановленРегистрДопСведений И ОшибкаИнициализации Тогда
					// не найден ОбъектОбщихНастроек
					ВызватьИсключение ТекстСообщения;
				Иначе
					ЗаписьЖурналаРегистрации("Диадок.Определение системы хранения", УровеньЖурналаРегистрации.Ошибка, , , ТекстСообщения);
				КонецЕсли;
				
			КонецЕсли;
			
			Если МожноИспользоватьРегистрДопСведений Тогда
				ДопРеквизиты_УстановитьЗначение_1С(ОбъектОбщихНастроек, ИмяНастройки, Результат);
			КонецЕсли;
			
		КонецЕсли;
		
		Кэш_Поместить(ИмяНастройки, Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбъектОбщихНастроек_1С(ОписаниеОшибки = "")
	
	ОписаниеРеквизита = Неопределено;
	
	Если Свойства_СправочникИспользуетсяДляХраненияСвойств("Валюты") Тогда
		
		ОписаниеРеквизита = "валюта с кодом 643";
		
		КодВалютыРубли = "643";
		Результат = Справочники.Валюты.НайтиПоКоду(КодВалютыРубли);
		
	ИначеЕсли Свойства_СправочникИспользуетсяДляХраненияСвойств("ПрофилиГруппДоступа") Тогда
		
		ОписаниеРеквизита = "профиль группы доступа Администратор";
		
		// Розница
		Результат = ПредопределенноеЗначение("Справочник.ПрофилиГруппДоступа.Администратор");	
		
	ИначеЕсли Свойства_СправочникИспользуетсяДляХраненияСвойств("Организации") Тогда
		
		ОписаниеРеквизита = "данные об организации";
		
		// BSLLS:SetPrivilegedMode-off
		УстановитьПривилегированныйРежим(Истина);
		// BSLLS:SetPrivilegedMode-on
		
		ВыборкаОрганизаций = Справочники.Организации.Выбрать();
		
		Пока ВыборкаОрганизаций.Следующий() Цикл
			Если НЕ ВыборкаОрганизаций.ПометкаУдаления Тогда
				Результат = ВыборкаОрганизаций.Ссылка;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ПривилегированныйРежим() Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		
		ОписаниеОшибки = "Не найден типовой реквизит";
		
		Если ОписаниеРеквизита <> Неопределено Тогда
			ОписаниеОшибки = ОписаниеОшибки + ": " + ОписаниеРеквизита;
		КонецЕсли;
		
		ЗаписьЖурналаРегистрации("Диадок", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

