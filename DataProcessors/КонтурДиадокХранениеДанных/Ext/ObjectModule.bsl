// НАСТРОЙКИ: 1С

Функция Настройки_ОбщиеНастройки_1С()
	
	Результат = Контракт_ОбщиеНастройки();
	
	СтруктураНастроек = Свойства_ОбщиеНастройки();
	ЗаполнитьЗначенияСвойств(Результат, СтруктураНастроек);
	
	Результат.ПодключаемыйМодульСсылка = ПодключаемыйМодульСсылка(СтруктураНастроек);
	
	// TODO - сократить названия настроек с учетом ограничения: длина строки в регистре 50 - длина префикса "DDPro_"
	Если СтруктураНастроек.Свойство("СохранениеДокументовИмяКаталогаПакетаПоУмолч") Тогда
		ИмяКаталогаПакетаПоУмолчанию = Настройки_ЗначениеНастройки_1С(СтруктураНастроек, "СохранениеДокументовИмяКаталогаПакетаПоУмолч");
		Результат.СохранениеДокументовИмяКаталогаПакетаПоУмолчанию = ИмяКаталогаПакетаПоУмолчанию;
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("СохранениеДокументовИмяКаталогаПакета") Тогда
		ИмяКаталогаПакета = Настройки_ЗначениеНастройки_1С(СтруктураНастроек, "СохранениеДокументовИмяКаталогаПакета");
		Результат.СохранениеДокументовИмяКаталогаПакета = ИмяКаталогаПакета;
	КонецЕсли;
		
	Если СтруктураНастроек.Свойство("ЗагружатьДокументыПоСопоставленнымКонтрагент") Тогда
		Результат.ЗагружатьДокументыПоСопоставленнымКонтрагентам = СтруктураНастроек.ЗагружатьДокументыПоСопоставленнымКонтрагент;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗаписатьОбщиеНастройки_1С(СтруктураНастроек)
	
	Результат = Новый Массив;
	
	НачатьТранзакцию();
	
	Попытка
		
		Если ЗначениеЗаполнено(СтруктураНастроек.ПодключаемыйМодульСсылка)
			И Метаданные.Справочники.Содержит(СтруктураНастроек.ПодключаемыйМодульСсылка.Метаданные()) Тогда
			
			СтруктураНастроек.Вставить("ПодключаемыйМодульИмяСправочника",	СтруктураНастроек.ПодключаемыйМодульСсылка.Метаданные().Имя);
			СтруктураНастроек.Вставить("ПодключаемыйМодульСсылка",			Строка(СтруктураНастроек.ПодключаемыйМодульСсылка.УникальныйИдентификатор()));
			
		КонецЕсли;
		
		Результат = Настройки_МассивОшибок_1С(СтруктураНастроек);
		
		Если Результат.Количество() = 0 Тогда
			
			Для Каждого ТекНастройка Из СтруктураНастроек Цикл
				
				// TODO - сократить названия настроек с учетом ограничения: длина строки в регистре 50 - длина префикса "DDPro_"
				Если ТекНастройка.Ключ = "СохранениеДокументовИмяКаталогаПакетаПоУмолчанию" Тогда
					
					Настройки_СохранитьЗначениеНастройки_1С(ТекНастройка.Значение, "СохранениеДокументовИмяКаталогаПакетаПоУмолч");					
					
				ИначеЕсли ТекНастройка.Ключ = "ЗагружатьДокументыПоСопоставленнымКонтрагентам" Тогда
					
					ДопРеквизиты_УстановитьЗначение(, "ЗагружатьДокументыПоСопоставленнымКонтрагент", ТекНастройка.Значение);
					
				ИначеЕсли ТекНастройка.Ключ = "СохранениеДокументовИмяКаталогаПакета" Тогда
					
					Настройки_СохранитьЗначениеНастройки_1С(ТекНастройка.Значение, "СохранениеДокументовИмяКаталогаПакета");	
					
				Иначе
					ДопРеквизиты_УстановитьЗначение(, ТекНастройка.Ключ, ТекНастройка.Значение);
					
				КонецЕсли;	
				
			КонецЦикла;
			
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		_Ошибка = ОписаниеОшибки();
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_МассивОшибок_1С(СтруктураНастроек)
	
	Результат = Новый Массив;
	
	Если ТекущийРежимЗапускаПриложения() = "Обычное приложение" Тогда
		
		НастройкиДляПроверки = 
		"ПодключаемыйМодульИмяОбработки
		|ПодключаемыйМодульПуть
		|СохранениеДокументовПуть
		|КорневойКаталогДокументов
		|ПутьКМодулюВСправочнике1С";
		
		МассивНастроек = РазделитьСтрокуЛок(НастройкиДляПроверки, Символы.ПС);
		
		Для Каждого ИмяНастройки Из МассивНастроек Цикл
			
			ЗначениеНастройки = СтруктураНастроек[ИмяНастройки];
			
			Если СтрДлина(ЗначениеНастройки) > 50 Тогда
				ТекстОшибки = Настройки_ЗаполнитьОшибкуПроверки_1С(ИмяНастройки);
				Результат.Добавить(ТекстОшибки);
			КонецЕсли;
			
		КонецЦикла;				
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗаполнитьОшибкуПроверки_1С(ИмяНастройки)
	
	Результат = "";
	
	ОписаниеОшибки	= НСтр("ru = 'Длина пути в настройке %1 должна быть меньше 50 символов'") + Символы.ПС;
	
	Результат = Общее_ПодставитьПараметрыВСтроку(ОписаниеОшибки, ИмяНастройки);
						
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗначениеНастройки_1С(СтруктураНастроек, ИмяНастройки)
	
	Если ТекущийРежимЗапускаПриложения() = "Обычное приложение" Тогда
		Результат = ХранилищеОбщихНастроек.Загрузить("НастройкиКонтурЭДО", ИмяНастройки);
	Иначе
		Результат = СтруктураНастроек[ИмяНастройки];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Настройки_СохранитьЗначениеНастройки_1С(ЗначениеНастройки, ИмяНастройки)
	
	Если ТекущийРежимЗапускаПриложения() = "Обычное приложение" Тогда
		ХранилищеОбщихНастроек.Сохранить("НастройкиКонтурЭДО", ИмяНастройки, ЗначениеНастройки);
	Иначе
		ДопРеквизиты_УстановитьЗначение(, ИмяНастройки, ЗначениеНастройки);
	КонецЕсли;
	
КонецПроцедуры

Функция Настройки_ЗначениеСвойства_1С(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	Если ДанныеКонтрагента <> Неопределено Тогда
		ЭлементХраненияСвойств = ДанныеКонтрагента.СвязанныйСправочник1;
	Иначе
		ЭлементХраненияСвойств = ДанныеОрганизации.СвязанныйСправочник1;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлементХраненияСвойств) Тогда
		Результат = ДопРеквизиты_Значение_1С(ЭлементХраненияСвойств, ИмяСвойства);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура Настройки_ЗаписатьЗначенияСвойств_1С(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	ХранителиСвойств = СвязанныеСправочники(ДанныеОрганизации, ДанныеКонтрагента);
	
	Для Каждого ЭлементКоллекции Из ХранителиСвойств Цикл
				
		Для Каждого Элемент Из КоллекцияСвойств Цикл
			ДопРеквизиты_УстановитьЗначение_1С(ЭлементКоллекции.Ссылка, Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

