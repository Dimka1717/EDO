Функция Пакеты_СвязанныеПакеты_Диадок(ИдентификаторыПакета)

	Результат = Новый Массив;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РеквизитыСвязанногоПакета.Ссылка КАК Ссылка,
	|	РеквизитыСвязанногоПакета.Документ КАК ДокументУчета,
	|	ДопРеквизитыВидыПакетов.Значение КАК ИдентификаторВидаПакета
	|ИЗ
	|	Справочник.Диадок_ПакетыДокументов КАК РеквизитыСвязанногоПакета
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ПакетыДокументов.ДополнительныеРеквизиты КАК ДопРеквизитыСвязанногоПакета
	|		ПО (ДопРеквизитыСвязанногоПакета.Ссылка = РеквизитыСвязанногоПакета.Ссылка)
	|			И (ДопРеквизитыСвязанногоПакета.ИмяРеквизита = ""ОсновнойСвязанныйПакет"")
	|			И (ДопРеквизитыСвязанногоПакета.Значение = &ОсновнойСвязанныйПакет)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК ДопРеквизитыВидыПакетов
	|		ПО РеквизитыСвязанногоПакета.ВидПакета = ДопРеквизитыВидыПакетов.Ссылка
	|			И (ДопРеквизитыВидыПакетов.ИмяРеквизита = ""ID"")
	|ГДЕ
	|	НЕ ДопРеквизитыСвязанногоПакета.Ссылка ЕСТЬ NULL
	|	И НЕ РеквизитыСвязанногоПакета.ПометкаУдаления"); 
	
	Запрос.УстановитьПараметр("ОсновнойСвязанныйПакет", ИдентификаторыПакета.ПакетЭДО);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОписаниеСвязанногоПакета = Ядро.Контракт_ОписаниеСвязанногоПакета();
		
		ОписаниеСвязанногоПакета.ИдентификаторВида 	= Выборка.ИдентификаторВидаПакета;
		ОписаниеСвязанногоПакета.ДокументУчета 		= Выборка.ДокументУчета;
		
		Результат.Добавить(ОписаниеСвязанногоПакета);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_СвязанныеПакеты_1С(ИдентификаторыПакета)
	
	Результат = Новый Массив;
	
	Перечисления_ИменаСвойств = Перечисление_ИменаСвойствНастроек_1С();
	
	Свойство_ВидПакета = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ВидПакета, Истина);
	Свойство_ВидПакетаСчет = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ВидПакетаСчет, Истина);
	Свойство_ОсновнойСвязанныйПакет = Свойства_СсылкаНаСвойство(Перечисления_ИменаСвойств.ОсновнойСвязанныйПакет, Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СвязанныеДокументыУчета.Объект КАК ДокументУчета,
	|	ИдентификаторВидаПакета.Значение КАК ИдентификаторВидаПакета
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК СвязанныеДокументыУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ИдентификаторВидаПакета
	|		ПО СвязанныеДокументыУчета.Объект = ИдентификаторВидаПакета.Объект
	|ГДЕ
	|	СвязанныеДокументыУчета.Свойство = &Свойство_ОсновнойСвязанныйПакет
	|	И СвязанныеДокументыУчета.Значение = &LetterId
	|	И ИдентификаторВидаПакета.Свойство = &Свойство_ВидПакета
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СвязанныеДокументыУчета.Объект КАК ДокументУчета,
	|	ИдентификаторВидаПакета.Значение КАК ИдентификаторВидаПакета
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК СвязанныеДокументыУчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ИдентификаторВидаПакета
	|		ПО СвязанныеДокументыУчета.Объект = ИдентификаторВидаПакета.Объект
	|ГДЕ
	|	СвязанныеДокументыУчета.Свойство = &Свойство_ОсновнойСвязанныйПакет
	|	И СвязанныеДокументыУчета.Значение = &LetterId
	|	И ИдентификаторВидаПакета.Свойство = &Свойство_ВидПакетаСчет");
	
	Запрос.УстановитьПараметр("Свойство_ВидПакета", Свойство_ВидПакета);
	Запрос.УстановитьПараметр("Свойство_ВидПакетаСчет", Свойство_ВидПакетаСчет);
	Запрос.УстановитьПараметр("Свойство_ОсновнойСвязанныйПакет", Свойство_ОсновнойСвязанныйПакет);
	Запрос.УстановитьПараметр("LetterId", ИдентификаторыПакета.LetterId);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОписаниеСвязанногоПакета = Ядро.Контракт_ОписаниеСвязанногоПакета();
		
		ОписаниеСвязанногоПакета.ИдентификаторВида 	= Выборка.ИдентификаторВидаПакета;
		ОписаниеСвязанногоПакета.ДокументУчета 		= Выборка.ДокументУчета;
		
		Результат.Добавить(ОписаниеСвязанногоПакета);
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции


