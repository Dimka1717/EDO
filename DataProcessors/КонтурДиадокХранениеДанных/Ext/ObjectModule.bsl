Функция СписокДокументов_Отправленные_1С(Параметры)
	
	Результат = Новый_СписокДокументов();

	Если ЗначениеЗаполнено(Параметры.ОтборПоПакету) Тогда
		
		Идентификаторы	= Новый Структура("BoxID, LetterID, DocumentID, ДокументАПИ");
		ЗаполнитьЗначенияСвойств(Идентификаторы, Параметры.ОтборПоПакету);
		
		Попытка
			
			Идентификаторы.ДокументАПИ = API_GetDocument(Идентификаторы.BoxId, Идентификаторы.LetterId, Идентификаторы.DocumentId);
			
			МассивИдентификаторовДокументов = Новый Массив();
			МассивИдентификаторовДокументов.Добавить(Идентификаторы);
			
			СписокДокументов_ЗаполнитьДаннымиДокументовАПИ_1С(Результат, МассивИдентификаторовДокументов, Параметры.ОтборПоСтатусу);
			СписокДокументов_ДополнитьСписокИдентификаторамиВидовПакетов(Результат);
			
		Исключение
			
			Ошибка = ИнформацияОбОшибке();
			
			Если Найти(Ошибка.Описание, "Код ошибки: 403") > 0 Тогда 
				//передали в другое подразделение на которое нет прав
			Иначе 
				ВызватьИсключение;
			КонецЕсли;
			
		КонецПопытки;
		
	Иначе
		
		ТипыДокументов = ТипыДокументовПоВидамДокументов(Параметры.МассивВыбранныхВидов);
			
		Для Каждого ТипДокумента Из ТипыДокументов Цикл
			
			Параметры.Вставить("ТипДокумента", ТипДокумента);
			
			МассивИдентификаторовДокументов	= СписокДокументов_ИдентификаторыОтправленныхДокументовАПИ(Параметры);
			
			СписокДокументов_ЗаполнитьДаннымиДокументовАПИ_1С(Результат, МассивИдентификаторовДокументов, Параметры.ОтборПоСтатусу);
			СписокДокументов_ДополнитьСписокИдентификаторамиВидовПакетов(Результат);
			
		КонецЦикла;
		
		Результат.Сортировать("ДатаОтправки УБЫВ, LetterId");

	КонецЕсли;
	
	СписокДокументов_ДозаполнитьВидыПакетов_1С(Результат);
	
	Возврат Результат;
	
КонецФункции

