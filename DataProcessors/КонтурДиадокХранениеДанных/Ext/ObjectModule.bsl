Функция GUID_2_Base64(GUID) 
		
	Число16	= Число16_Из_GUID(GUID);
	Base64	= Base64_Из_Числа16(Число16);
	
	Результат = Прав(Base64, Окр(СтрДлина(Число16) / 1.5));
	
	Возврат Результат;
		
КонецФункции

Функция Число16_Из_GUID(GUID)
	
	Результат = СтрЗаменить(GUID, "-", ""); 
	
	Возврат Результат;
	
КонецФункции

Функция Base64_Из_Числа16(Число)
	
	Результат = "";

	ТаблицаПерекодировки = ТаблицаПерекодировки();
	
	Число16 = Число;
	
	Пока СтрДлина(Число16) > 0 Цикл 
		
		Разряд = ДобавитьНулиВПредставлениеЧисла(Прав(Число16, 3), 3);
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Число16", Разряд);
		
		ВыборкаСтрок = ТаблицаПерекодировки.НайтиСтроки(СтруктураПоиска);
		
		Если ВыборкаСтрок.Количество() > 0 Тогда 
			Результат = ВыборкаСтрок[0].Число64 + Результат;
		КонецЕсли;
		
		ДлинаСтроки16	= СтрДлина(Число16);
		Число16			= ?(ДлинаСтроки16 >= 4, Лев(Число16, ДлинаСтроки16 - 3), "");
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции 

Функция ТаблицаПерекодировки() Экспорт
		
	//Формируем таблицу соответствия 3-хсимвольных 16-ричных слов и 2-х символьных 64-ричных слов
	//Готовую сформированную таблицу берем из подготовленного макета
	
	Результат = Кэш_Прочитать("ТаблицаПерекодировки");
	
	Если Результат = Неопределено Тогда
		
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Тип("Строка"));
		
		Макет		= ПолучитьМакет("ТаблицаПерекодировки");
		ОбластьТела	= Макет.ПолучитьОбласть("ТелоМакета");
		
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Вывести(ОбластьТела);
		
		Результат = Новый ТаблицаЗначений;
		Результат.Колонки.Добавить("Число2",	Новый ОписаниеТипов(МассивТипов));
		Результат.Колонки.Добавить("Число16",	Новый ОписаниеТипов(МассивТипов));
		Результат.Колонки.Добавить("Число64",	Новый ОписаниеТипов(МассивТипов));
		
		Результат.Индексы.Добавить("Число16");
		
		Для НомерСтроки = 1 По 4096 Цикл
			
			СтрокаТЗ = Результат.Добавить();
			СтрокаТЗ.Число2		= ТабДок.Область(НомерСтроки, 1).Текст;
			СтрокаТЗ.Число16	= ТабДок.Область(НомерСтроки, 2).Текст;
			СтрокаТЗ.Число64	= ТабДок.Область(НомерСтроки, 3).Текст;
			
		КонецЦикла;
		
		Кэш_Поместить("ТаблицаПерекодировки", Результат);
		
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции	
	
Функция ДобавитьНулиВПредставлениеЧисла(ЧС, Длина)
		
	Результат = Формат(ЧС, "ЧН=; ЧГ=");
	
	Пока СтрДлина(Результат) < Длина Цикл 
		Результат = "0" + Результат;
	КонецЦикла;
	
	Возврат Результат;
	
