	ЗначениеПоУмолчанию = "";
	
	СсылкаНаСвойство = ИмяСвойстваПодразделения(ДляОрганизации);
	
	ЗначениеСвойства = Свойства_ЗначениеСвойства(СсылкаНаСвойство, СвязанныйСправочник, Истина);
	
