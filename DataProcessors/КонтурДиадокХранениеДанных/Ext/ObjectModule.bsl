// Получает из БД значение настройки "ТипОснования" для вида документа исходя из используемой подсистемы хранения
//
// Параметры:
//	IDВидаДокумента		- Строка					- идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//  ДанныеОрганизации	- Структура					- данные организации, в разрезе которой хранится настройка
//	ДанныеКонтрагента	- Структура, Неопределено	- данные контрагента, в разрезе которого хранится настройка
//
// Возвращаемое значение:
//	Строка - значение настройки
Функция НастройкиДокументов_ОснованияВидовДокументов_Прочитать(IDВидаДокумента, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	ИмяСвойства = КлючСвойстваТипОснования(IDВидаДокумента);
	
	Результат = Настройки_ЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);
			
	Возврат Результат;
	
КонецФункции

// Сохраняет в БД значение настройки "ТипОснования" для вида документа исходя из используемой подсистемы хранения
//
// Параметры:
//	ОснованияВидовДокументов	- Соответствие				- коллекция значений настройки по видам документа
//  ДанныеОрганизации			- Структура					- данные организации, в разрезе которой хранится настройка
//	ДанныеКонтрагента			- Структура, Неопределено	- данные контрагента, в разрезе которого хранится настройка
//
Процедура НастройкиДокументов_ОснованияВидовДокументов_Записать(ОснованияВидовДокументов, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	КоллекцияСвойств = Новый Соответствие;
	
	Для Каждого КлючЗначение Из ОснованияВидовДокументов Цикл
		ИмяСвойства = КлючСвойстваТипОснования(КлючЗначение.Ключ);
		КоллекцияСвойств.Вставить(ИмяСвойства, КлючЗначение.Значение);
	КонецЦикла;
	
	Настройки_ЗаписатьЗначенияСвойств(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
			
КонецПроцедуры

// Возвращает таблицу со значениями оснований для вида электронного документа, записанными в БД
//
// Параметры:
//	ТаблицаВидовДокументов - ТаблицаЗначений - См. Новый_ТаблицаСвойстваТипОснованияПоВидуДокумента()
//
// ВозвращаемоеЗначение:
//	ТаблицаЗначений с колонками: 
//		* ВидДокументаID
//		* ЗначениеНастройки
Функция НастройкиДокументов_ОснованияВидовДокументов_ПрочитатьНаборНастроек(ТаблицаВидовДокументов) Экспорт
			
	Если ИспользоватьПодсистемуДиадока() Тогда
						
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаВидовДокументов.ВидДокументаID КАК ВидДокументаID,
		|	ТаблицаВидовДокументов.СвойствоТипОснования КАК СвойствоТипОснования
		|ПОМЕСТИТЬ ВТ_ТаблицаВидовДокументов
		|ИЗ
		|	&ТаблицаВидовДокументов КАК ТаблицаВидовДокументов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ВТ_ТаблицаВидовДокументов.ВидДокументаID КАК ВидДокументаID,
		|	Диадок_НастройкиКонтрагентов.Значение КАК ЗначениеНастройки
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТаблицаВидовДокументов КАК ВТ_ТаблицаВидовДокументов
		|		ПО Диадок_НастройкиКонтрагентов.ИмяСвойства = ВТ_ТаблицаВидовДокументов.СвойствоТипОснования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_ТаблицаВидовДокументов";
						
	Иначе
				
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаВидовДокументов.ВидДокументаID КАК ВидДокументаID,
		|	ТаблицаВидовДокументов.СвойствоТипОснования КАК СвойствоТипОснования
		|ПОМЕСТИТЬ ВТ_ТаблицаВидовДокументов
		|ИЗ
		|	&ТаблицаВидовДокументов КАК ТаблицаВидовДокументов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ВТ_ТаблицаВидовДокументов.ВидДокументаID КАК ВидДокументаID,
		|	ДополнительныеСведения.Значение КАК ЗначениеНастройки
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТаблицаВидовДокументов КАК ВТ_ТаблицаВидовДокументов
		|		ПО ДополнительныеСведения.Свойство = ВТ_ТаблицаВидовДокументов.СвойствоТипОснования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_ТаблицаВидовДокументов";
		
		ТекстЗапроса_УстановитьИмяРегистраСведений(ТекстЗапроса);
						
	КонецЕсли;
			
	Запрос = Новый Запрос;
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("ТаблицаВидовДокументов", ТаблицаВидовДокументов);
		
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Удаляет из БД значение настройки "ТипОснования" для вида документа исходя из используемой подсистемы хранения 
//
// Параметры:
//	ВидДокумента 		- Строка					- идентификатор вида документа: "ID_АктФормализованный", "ID_ТОРГ12" и т.д.
//	ДанныеОрганизации 	- Структура					- данные организации, в разрезе которой хранится настройка
//	ДанныеКонтрагента 	- Структура, Неопределено	- данные контрагента, в разрезе которого хранится настройка
Процедура НастройкиДокументов_ОснованияВидовДокументов_Удалить(ВидДокумента, ДанныеОрганизации, ДанныеКонтрагента) Экспорт
	
	ИмяСвойства = КлючСвойстваТипОснования(ВидДокумента);
	
	Настройки_УдалитьЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);
	
КонецПроцедуры

// Функция - Таблица свойства тип основания по виду документа
//
// Параметры:
//  ВидыДокументов	 - Массив - коллекция идентификаторов видов документов/пакетов 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. Контракт Новый_ТаблицаСвойстваТипОснованияПоВидуДокумента  
//
Функция ТаблицаСвойстваТипОснованияПоВидуДокумента(ВидыДокументов) Экспорт
	
	Результат = Новый_ТаблицаСвойстваТипОснованияПоВидуДокумента();
	
	Для Каждого ВидДокумента Из ВидыДокументов Цикл
		
		НовыйЭлементТЗ = Результат.Добавить();
		НовыйЭлементТЗ.ВидДокументаID 		= ВидДокумента;
		НовыйЭлементТЗ.СвойствоТипОснования = Свойства_ТипОснованияПоВидуДокумента(ВидДокумента);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ТаблицаСвойстваТипОснованияПоВидуДокумента()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ВидДокументаID"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат.Колонки.Добавить("СвойствоТипОснования", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
	Иначе
		ИмяТипаСвойств = "ПланВидовХарактеристикСсылка." + Свойства_ИмяПланаВидовХарактеристик();
		Результат.Колонки.Добавить("СвойствоТипОснования", Новый ОписаниеТипов(ИмяТипаСвойств));
