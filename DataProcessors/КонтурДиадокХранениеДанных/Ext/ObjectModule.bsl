	ВыборкаЗначений = Ссылка.ДополнительныеРеквизиты.Найти(ИмяРеквизита);
	
	Если ВыборкаЗначений <> Неопределено Тогда
		Результат = Справочники_ЗначениеДопРеквизита_Диадок(ВыборкаЗначений);
	КонецЕсли;
	
	Возврат Результат;
	
