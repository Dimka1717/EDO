Функция Организации_ДанныеОрганизации_1С(Идентификаторы)
	
	Результат = Контракт_ОрганизацияЭДО();
	
	BoxID = Идентификаторы.ID;
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxID);
	
	Результат.ID						= BoxID;
	Результат.OrgId						= СтрокаКонтекста.OrgId;
	Результат.ИНН						= СтрокаКонтекста.ИНН;
	Результат.КПП						= СтрокаКонтекста.КПП;
	Результат.Наименование				= СтрокаКонтекста.ОрганизацияНаименование;
	Результат.ИдентификаторУчастникаЭДО	= СтрокаКонтекста.Box.Organization.FnsParticipantId;
	
	СвязанныйСправочник1 = Организации_СопоставленнаяВ1С_1С(Идентификаторы);
	
	Если СвязанныйСправочник1 <> Неопределено Тогда
		
		Результат.СвязанныйСправочник1 = СвязанныйСправочник1;
		
		ОсновнойПакет = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().ОсновнойПакет);
		Результат.ОсновнойПакет	= ?(ОсновнойПакет = Неопределено, "", ОсновнойПакет);
		
		ОтпечатокСертификатаНаСервере = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().ОтпечатокСертификатаНаСервере);
		Результат.ОтпечатокСертификатаНаСервере	= ?(ОтпечатокСертификатаНаСервере = Неопределено, "", ОтпечатокСертификатаНаСервере);
		
		ШифроватьДокументы = ДопРеквизиты_ЗначениеШифрованияДокумента_1С(Идентификаторы);
		Результат.ШифроватьДокументы = ?(ШифроватьДокументы = Неопределено, Ложь, ШифроватьДокументы);
		
		УказыватьОтсутствиеОснованияУПД = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().УказыватьОтсутствиеОснованияУПД, Ложь);
		Результат.УказыватьОтсутствиеОснованияУПД = ?(УказыватьОтсутствиеОснованияУПД = Неопределено, Ложь, УказыватьОтсутствиеОснованияУПД);
		
		ОтправлятьНепроведенныеДокументы = Организации_НастройкаОтправлятьНепроведенныеДокументы_1С(СвязанныйСправочник1);
		Результат.ОтправлятьНепроведенныеДокументы = ?(ОтправлятьНепроведенныеДокументы = Неопределено, Ложь, ОтправлятьНепроведенныеДокументы);

		ЗаписыватьКомментарииВДокументы1С = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().ЗаписыватьКомментарииВДокументы1С);
		Результат.ЗаписыватьКомментарииВДокументы1С = ?(ЗаписыватьКомментарииВДокументы1С = Неопределено, Ложь, ЗаписыватьКомментарииВДокументы1С);
		
		ТекстКомментарияОтправка = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().ТекстКомментарияОтправка, Ложь);
		Результат.ТекстКомментарияОтправка = ?(ТекстКомментарияОтправка = Неопределено, "", ТекстКомментарияОтправка);
		
		ТекстКомментарияПолучение = ДопРеквизиты_Значение_1С(СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().ТекстКомментарияПолучение);
		Результат.ТекстКомментарияПолучение = ?(ТекстКомментарияПолучение = Неопределено, "", ТекстКомментарияПолучение);
		
		ID_ОсновноеПодразделение = Организации_ОсновноеПодразделениеОрганизации_1С(СвязанныйСправочник1);
		Результат.ID_ОсновноеПодразделение = ?(ID_ОсновноеПодразделение = Неопределено, "", ID_ОсновноеПодразделение);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
            
Функция Организации_НастройкаОтправлятьНепроведенныеДокументы_1С(Организация)
	
	Результат = Ложь;
	
	ОтправлятьНепроведенныеДокументы = ДопРеквизиты_Значение_1С(Организация, Перечисление_ИменаСвойствНастроек_1С().ОтправлятьНепроведенныеДокументы, Ложь);
	
	Если ОтправлятьНепроведенныеДокументы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	// для совместимости с настрокой модулей Стандарт
	Если ТипЗнч(ОтправлятьНепроведенныеДокументы) = Тип("Строка") Тогда
		Результат = ОтправлятьНепроведенныеДокументы = "Да";
	Иначе
		Результат = ОтправлятьНепроведенныеДокументы;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

