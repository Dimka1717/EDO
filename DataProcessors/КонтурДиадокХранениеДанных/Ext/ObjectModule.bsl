КонецФункции

// Возвращает признак использования в модуле функциональности добавляения счетов в пакет
// 
// Возвращаемое значение:
//  Булево - Истина, если хотя бы для одной организации или контрагента значение настройки Истина
//
Функция Настройки_ЕстьНастройкаДобавлятьСчетВПакет() Экспорт

	Если ИспользоватьПодсистемуДиадока() Тогда
		Результат = Настройки_ЕстьНастройкаДобавлятьСчетВПакет_Диадок();	
	Иначе
		Результат = Настройки_ЕстьНастройкаДобавлятьСчетВПакет_1С();
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

// см. Настройки_ЕстьНастройкаДобавлятьСчетВПакет
//
Функция Настройки_ЕстьНастройкаДобавлятьСчетВПакет_Диадок() Экспорт
	
	ИмяСвойства = Перечисление_ИмяСвойствНастройки_ДобавлятьСчетВПакет();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Значение
	|ИЗ
	|	РегистрСведений.Диадок_НастройкиКонтрагентов
	|ГДЕ
	|	ИмяСвойства = &ИмяСвойства
	|	И Значение = ИСТИНА"
	);                            
	Запрос.УстановитьПараметр("ИмяСвойства", ИмяСвойства);
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = Не РезультатЗапроса.Пустой();
	
	Возврат Результат;
	
КонецФункции

// см. Настройки_ЕстьНастройкаДобавлятьСчетВПакет
//
Функция Настройки_ЕстьНастройкаДобавлятьСчетВПакет_1С() Экспорт

	ИмяСвойства = Перечисление_ИмяСвойствНастройки_ДобавлятьСчетВПакет();
	
	СсылкаНаСвойство = Свойства_СсылкаНаСвойство(ИмяСвойства, Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Значение
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов
	|ГДЕ
	|	Свойство = &СсылкаНаСвойство
	|	И Значение = ИСТИНА"
	);                            
	Запрос.УстановитьПараметр("СсылкаНаСвойство", СсылкаНаСвойство);
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Запрос.Текст);
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = Не РезультатЗапроса.Пустой();
	
	Возврат Результат;
	
КонецФункции

// Сохраняет значение настройки Добавлять счет в пакет для организации или контрагента
//
// Параметры:
//  ЗначениеНастройки	 - Булево - сохранаяемое значение настройки
//  ДанныеОрганизации	 - Структура - заполненный данные организации (см. Организации_ЗаполненныеРеквизиты)
//  ДанныеКонтрагента	 - Структура, Неопределено - заполненный данные контрагента (см. Контрагенты_ЗаполненныеРеквизиты).
//													Неопределено, если сохраняем настройки для организации
//
Процедура НастройкиДокументов_СохранитьЗначениеДобавлятьСчетВПакет(ЗначениеНастройки, ДанныеОрганизации, ДанныеКонтрагента = Неопределено) Экспорт
	
	ИмяСвойства = Перечисление_ИмяСвойствНастройки_ДобавлятьСчетВПакет();
	
	ЗначенияСвойств = Новый Соответствие;
	ЗначенияСвойств.Вставить(ИмяСвойства, ЗначениеНастройки);
	
	Настройки_ЗаписатьЗначенияСвойств(ЗначенияСвойств, ДанныеОрганизации, ДанныеКонтрагента);
	
КонецПроцедуры

// Возвращает значение настройки "Добавлять счет в пакет" для контрагента или организации
// Если ДанныеКонтрагента <> Неопределено, тогда проверяем настройку 2 раза.
// Первый раз индивидуальную настройку контрагента. Если значение ее Ложь, то смотрим уже
// настройку для организации.
//
// Параметры:
//  ДанныеОрганизации	 - Структура 				- см. Организация_ЗаполненныеРеквизиты
//  ДанныеКонтрагента	 - Структура, Неопределено	- см. Контрагенты_ЗаполненныеРеквизиты
// 
// Возвращаемое значение:
//  Булево - Истина - настройка включена, Ложь - нет
//
Функция НастройкиДокументов_ЗначениеНастройкиДобавлятьСчетВПакет(ДанныеОрганизации,	ДанныеКонтрагента = Неопределено) Экспорт
	
	ИмяСвойства =  Перечисление_ИмяСвойствНастройки_ДобавлятьСчетВПакет();
		
	Результат = Настройки_ЗначениеСвойства(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента);

	Возврат Результат;
	
КонецФункции

