// НАСТРОЙКИ: ПОДСИСТЕМА ДИАДОКА

// Структура значений строк элемента "ОбщиеНастройки" в справочнике "Диадок_ДополнительныеСправочники"
Функция Настройки_ОбщиеНастройки_Диадок()
	
	Результат = Контракт_ОбщиеНастройки();
	
	ОбщиеНастройкиСсылка = ДопСправочники_НайтиПоНаименованию_Диадок("ОбщиеНастройки", "ОбщиеНастройки");
	
	Если ОбщиеНастройкиСсылка <> Неопределено Тогда
		
		Для Каждого ТекНастройка Из Результат Цикл
			
			ЗначениеНастройки = ДопРеквизиты_Значение(ОбщиеНастройкиСсылка, ТекНастройка.Ключ);
			
			Если ЗначениеНастройки <> Неопределено Тогда
				Результат[ТекНастройка.Ключ] = ЗначениеНастройки;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗаписатьОбщиеНастройки_Диадок(СтруктураНастроек)
	
	Результат = Новый Массив;
	
	ОбщиеНастройкиСсылка = ДопСправочники_НайтиПоНаименованию_Диадок("ОбщиеНастройки", "ОбщиеНастройки");
	
	Если ОбщиеНастройкиСсылка = Неопределено Тогда
		
		ОбщиеНастройкиОбъект = Справочники.Диадок_ДополнительныеСправочники.СоздатьЭлемент();
		ОбщиеНастройкиОбъект.Наименование	= "ОбщиеНастройки";
		ОбщиеНастройкиОбъект.ИмяСправочника	= "ОбщиеНастройки";
		ОбщиеНастройкиОбъект.УстановитьНовыйКод();
		
	Иначе
		ОбщиеНастройкиОбъект = ОбщиеНастройкиСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	Для Каждого ТекНастройка Из СтруктураНастроек Цикл
		
		Если ТекНастройка.Ключ = "СлужебнаяУчетнаяЗаписьПароль" Тогда
			СохраняемоеЗначение = Новый ХранилищеЗначения(ТекНастройка.Значение);
		Иначе
			СохраняемоеЗначение = ТекНастройка.Значение;
		КонецЕсли;
		
		ДопРеквизиты_УстановитьЗначение(ОбщиеНастройкиОбъект, ТекНастройка.Ключ, СохраняемоеЗначение);
		
	КонецЦикла;
	
	ОбщиеНастройкиОбъект.Записать();
	
	Возврат Результат;
	
КонецФункции

Функция Настройки_ЗначениеСвойства_Диадок(ИмяСвойства, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ОрганизацияЭДО",	ДанныеОрганизации.Ссылка);
	СтруктураДанных.Вставить("ИмяСвойства",		ИмяСвойства);
	
	Если ДанныеКонтрагента = Неопределено Тогда
		СтруктураДанных.Вставить("КонтрагентЭДО", Контрагенты_ПустаяСсылка_Диадок());
	Иначе
		СтруктураДанных.Вставить("КонтрагентЭДО", ДанныеКонтрагента.Ссылка);
	КонецЕсли;
	
	Результат = Справочники_ЗначениеЗаписиНастроекКонтрагентов_Диадок(СтруктураДанных);
	
	Возврат Результат;
	
КонецФункции

Процедура Настройки_ЗаписатьЗначенияСвойств_Диадок(КоллекцияСвойств, ДанныеОрганизации, ДанныеКонтрагента = Неопределено)
	
	Для Каждого Элемент Из КоллекцияСвойств Цикл
		
		СтруктураДанных = Новый Структура;
		
		СтруктураДанных.Вставить("ОрганизацияЭДО",	ДанныеОрганизации.Ссылка);
		СтруктураДанных.Вставить("ИмяСвойства",		Элемент.Ключ);
		СтруктураДанных.Вставить("Значение",		Элемент.Значение);
		
		Если ДанныеКонтрагента = Неопределено Тогда
			СтруктураДанных.Вставить("КонтрагентЭДО", Контрагенты_ПустаяСсылка_Диадок());
		Иначе
			СтруктураДанных.Вставить("КонтрагентЭДО", ДанныеКонтрагента.Ссылка);
		КонецЕсли;
		
		Справочники_ЗаписатьЗначениеНастроекКонтрагентов_Диадок(СтруктураДанных);
	
	КонецЦикла;
	
КонецПроцедуры


