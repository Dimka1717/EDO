// Возвращает сведений об установленных в модуле плагинах
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Сведения об установленных в модуле плагинах
//   * ID - Строка - Идентификатор плагина
//   * Версия - Строка - Версия плагина
//   * Включен - Булево - Истина, если плагин активен
//   * Представление - Строка - Название плагина
//
Функция КонтурПлагины_ПолучитьСписокУстановленныхПлагинов() Экспорт
	
	ИмяСправочникаПлагинов = КонтурПлагины_ИмяСправочникаПлагинов();
	
	СвойстваПлагина = "ID, Версия, Включен, Представление";
	
	Результат = ДопСправочники_СписокЭлементов(
		ИмяСправочникаПлагинов,
		СвойстваПлагина
	);
	
	Возврат Результат;
	
КонецФункции

// Добавляет или обновляет плагин в справочник КонтурПлагины.
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные - файл плагина;
//  ИдентификаторПлагина - Строка - идентификатор загружаемого плагина;
//  Версия - Строка - версия плагина;
//  Включен - Булево - Истина, если плагин включен
//  Представление - Строка - (Необязательный) название плагина;
//
Процедура КонтурПлагины_ЗаписатьПлагин(ДвоичныеДанные, Знач Идентификатор, Знач Версия, Знач Включен, Знач Представление = "") Экспорт
	
	ИмяСправочникаПлагинов = КонтурПлагины_ИмяСправочникаПлагинов();
	
	ПлагинСсылка = ДопСправочники_СсылкаПоИдентификатору(
		ИмяСправочникаПлагинов,
		Идентификатор
	);
	
	Если ЗначениеЗаполнено(ПлагинСсылка) Тогда
		
		ТекОбъект = ПлагинСсылка.ПолучитьОбъект();
		ТекОбъект.ДополнительныеРеквизиты.Очистить();
		
	Иначе
		
		ТекОбъект = ДопСправочники_СоздатьЭлемент_Диадок(
			ИмяСправочникаПлагинов,
			Представление
		);
		
	КонецЕсли;
	
	ДопРеквизиты_УстановитьЗначение(
		ТекОбъект,
		"ID",
		Идентификатор,
		Представление
	);
	
	ДопРеквизиты_УстановитьЗначение(
		ТекОбъект,
		"Версия",
		Версия,
		""
	);
	
	ДопРеквизиты_УстановитьЗначение(
		ТекОбъект,
		"Включен",
		Включен,
		""
	);
	
	ДопРеквизиты_УстановитьЗначение(
		ТекОбъект,
		"Представление",
		Представление,
		""
	);
	
	ДопРеквизиты_УстановитьЗначение(
		ТекОбъект,
		"ДвоичныеДанные",
		Новый ХранилищеЗначения(ДвоичныеДанные),
		""
	);
	
	ТекОбъект.Записать();
	
КонецПроцедуры

// Удаляет плагин из справочника КонтурПлагины
//
// Параметры:
//  ИдентификаторПлагина - Строка - Идентификатор плагина, который будет удален
//
Процедура КонтурПлагины_УдалитьПлагин(ИдентификаторПлагина) Экспорт
	
	ИмяСправочникаПлагинов = КонтурПлагины_ИмяСправочникаПлагинов();
	
	ПлагинСсылка = ДопСправочники_СсылкаПоИдентификатору(
		ИмяСправочникаПлагинов,
		ИдентификаторПлагина
	);
	
	ОбъектПлагина = ПлагинСсылка.ПолучитьОбъект();
	ОбъектПлагина.ОбменДанными.Загрузка = Истина;
	ОбъектПлагина.Удалить();
	
КонецПроцедуры

// Возвращает двоичные данные файла плагина
//
// Параметры:
//  ИдентификаторПлагина - Строка - Идентификатор плагина
