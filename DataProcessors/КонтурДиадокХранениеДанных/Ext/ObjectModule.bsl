Функция Документы_ДанныеДокумента_Диадок(Идентификаторы)
	
	Результат = Контракт_Документ();
	
	Выборка	= Документы_ВыборкаДанныхДокументаИзБазы_Диадок(Идентификаторы);
		
	Если Выборка.Следующий() Тогда
		
		Результат = Документы_КонтрактДокументаПоВыборке_Диадок(Выборка);
		
		ПакетОтправлен = ЗначениеЗаполнено(Результат.Идентификаторы.LetterId);
		Если Не ПакетОтправлен Тогда
			ПараметрыОтправки = Контракт_ПараметрыОтправкиДокумента();
			Результат.СлужебнаяИнформация.Вставить("ПараметрыОтправки", ПараметрыОтправки);
		КонецЕсли;
		
		СтруктураДопРеквизитов = ДопРеквизиты_СписокРеквизитов(Выборка.ДокументЭДО);
		
		Для Каждого ДопРеквизит Из СтруктураДопРеквизитов Цикл
			
			Если ДопРеквизит.Ключ = "InitialDocumentIds" Тогда
				Результат.Связи.InitialDocumentIDs = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "SubordinateDocumentIds" Тогда
				Результат.Связи.SubordinateDocumentIds = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "TransformedToLetterIds" Тогда
				Результат.Связи.TransformedToLetterIds = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "OriginMessageId" Тогда
				Результат.Связи.OriginMessageId = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "CustomDocumentId" Тогда
				Результат.Связи.CustomDocumentId = ДопРеквизит.Значение;	
			ИначеЕсли ДопРеквизит.Ключ = "Шаблон" Тогда
				Результат.Шаблон = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "MessageFromBoxId" Тогда
				Результат.ПараметрыШаблона.MessageFromBoxId = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "MessageToBoxId" Тогда
				Результат.ПараметрыШаблона.MessageToBoxId = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "MessageToDepartmentId" Тогда
				Результат.ПараметрыШаблона.MessageToDepartmentId = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "EditingSettingId" Тогда
				Результат.ПараметрыШаблона.EditingSettingId = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "LockMode" Тогда
				Результат.ПараметрыШаблона.LockMode = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "ЗапрашиватьИзвещение" И Не ПакетОтправлен Тогда
				Результат.СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьИзвещение = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "ЗапрашиватьОтветнуюПодпись" И Не ПакетОтправлен Тогда
				Результат.СлужебнаяИнформация.ПараметрыОтправки.ЗапрашиватьОтветнуюПодпись = ДопРеквизит.Значение;
			ИначеЕсли ДопРеквизит.Ключ = "Комментарий" Тогда
				Результат.Комментарий = ДопРеквизит.Значение;
			ИначеЕсли Найти(ДопРеквизит.Ключ, "ВнешнийСтатус_") > 0 Тогда
				Результат.Статусы.ВнешниеСтатусы.Вставить(ДопРеквизит.Ключ, ДопРеквизит.Значение);
			Иначе
				Результат.ДопРеквизиты.Вставить(ДопРеквизит.Ключ, ДопРеквизит.Значение);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

Функция Документы_ВыборкаДанныхДокументаИзБазы_Диадок(Идентификаторы)
	
	ДокументЭДО	= СвойствоСтруктуры(Идентификаторы, "ДокументЭДО",	Неопределено);
	BoxID		= СвойствоСтруктуры(Идентификаторы, "BoxID",		"");
	LetterID	= СвойствоСтруктуры(Идентификаторы, "LetterID",		"");
	DocumentID	= СвойствоСтруктуры(Идентификаторы, "DocumentID",	"");
	
	Если ЗначениеЗаполнено(ДокументЭДО) Тогда
		Отбор = "Документы.Ссылка = &Документ";
	Иначе
		Отбор = "Документы.BoxId = &BoxId И Документы.LetterId = &LetterId И Документы.DocumentID = &DocumentID";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = Документы_ТекстЗапросаЗаполненияКонтракта(Отбор);
	
	Запрос.УстановитьПараметр("Документ",	ДокументЭДО);
	Запрос.УстановитьПараметр("BoxID",		BoxID);
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	Запрос.УстановитьПараметр("DocumentID",	DocumentID);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаменитьСвязиДляСправочникаДиадокЮрФизЛица_ДиадокСХ1(ТекстЗапроса)
	
	ПодставляемоеЗначение = "
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Организация
	|		ПО Документы.ОрганизацияДиадок = Диадок_ЮрФизЛица_Организация.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Контрагент
	|		ПО Документы.КонтрагентДиадок = Диадок_ЮрФизЛица_Контрагент.Ссылка";

	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&СвязиТаблицСопоставленныхСправочников", ПодставляемоеЗначение);
	
КонецПроцедуры

Процедура ЗаменитьСвязиДляСправочникаДиадокЮрФизЛица_ДиадокРасширение(ТекстЗапроса)
	
	ПодставляемоеЗначение = "
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты_Организация
	|			ПО Документы.ОрганизацияДиадок = Диадок_ЮрФизЛицаДополнительныеРеквизиты_Организация.Ссылка 
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты_Организация.ИмяРеквизита = ""СвязанныйСправочник1"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК Диадок_ЮрФизЛицаДополнительныеРеквизиты_Контрагент
	|			ПО Документы.КонтрагентДиадок = Диадок_ЮрФизЛицаДополнительныеРеквизиты_Контрагент.Ссылка
	|			И (Диадок_ЮрФизЛицаДополнительныеРеквизиты_Контрагент.ИмяРеквизита = ""СвязанныйСправочник1"")";

	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&СвязиТаблицСопоставленныхСправочников", ПодставляемоеЗначение);
	
КонецПроцедуры

// BSLLS:MethodSize-off
//
// Параметры:
//  ОтборНаДокументы - Строка - параметр запроса "Отбор"
//  ОтборНаРезультат - Строка - параметр запроса "ОтборНаРезультат"
// 
// Возвращаемое значение:
// Строка - текст запроса заполнения контракта
//
Функция Документы_ТекстЗапросаЗаполненияКонтракта(
		ОтборНаДокументы = "Истина",
		ОтборНаРезультат = "Истина")
	
	Результат =
		
		"ВЫБРАТЬ
		|	Документы.Ссылка КАК Ссылка,
		|	Документы.DepartmentId КАК DepartmentId,
		|	Документы.ВидДокумента КАК ВидДокумента,
		|	Документы.Пакет КАК Пакет,
		|	Диадок_ПакетыДокументов.ВидПакета КАК ПакетВидПакета
		|ПОМЕСТИТЬ ВТ_Документы
		|ИЗ
		|	Справочник.Диадок_Документы КАК Документы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
		|		ПО Документы.Пакет = Диадок_ПакетыДокументов.Ссылка
		|ГДЕ
		|	&Отбор
		|	И НЕ Документы.ПометкаУдаления
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка,
		|	DepartmentId,
		|	ВидДокумента,
		|	ПакетВидПакета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Диадок_ЮрФизЛица_Подразделения.Ссылка КАК Ссылка,
		|	Диадок_ЮрФизЛица_Подразделения.Наименование КАК Наименование,
		|	Диадок_ЮрФизЛица_Подразделения.ID КАК ID,
		|	Диадок_ЮрФизЛица_Подразделения.ID_ВладелецПодразделения КАК ID_ВладелецПодразделения
		|ПОМЕСТИТЬ ВТ_ВсеПодразделения
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица_Подразделения
		|ГДЕ
		|	Диадок_ЮрФизЛица_Подразделения.ИмяСправочника = ""ПодразделенияОрганизаций""
		|	И Диадок_ЮрФизЛица_Подразделения.ID В
		|			(ВЫБРАТЬ
		|				ВТ_Документы.DepartmentId КАК DepartmentId
		|			ИЗ
		|				ВТ_Документы КАК ВТ_Документы)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ID
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка КАК ВидДокумента,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение КАК ИдентификаторВида,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка.Наименование КАК НаименованиеВида
		|ПОМЕСТИТЬ ВТ_ВидыДокументов
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Диадок_ДополнительныеСправочникиДополнительныеРеквизиты
		|ГДЕ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка.ИмяСправочника = ""ВидыДокументов""
