Функция Контрагенты_СписокСоСтатусами_Диадок(ПараметрыСписка)
	
	ТекстЗапроса = Контрагенты_ТекстЗапросаВременнаяТаблицаКонтрагентовОрганизацииСоСтатусами_Диадок();
	
	Если ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_РазделительЗапросов()
			+ Справочники_ТекстЗапросаВременнойТаблицыСвязиОбъектов_Диадок("Контрагенты");	
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_РазделительЗапросов()
		+ Контрагенты_ТекстЗапросаРеквизитыКонтрагентовОрганизации_Диадок();
		
	Если ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ Тогда
		
		ТекстЗапросаРеквизитыКонтрагентовИБ = ",
		|	СвязиКонтрагентов.ОбъектИБ КАК КонтрагентИБ,
		|	СвязиКонтрагентов.НаименованиеОбъектаИБ КАК НаименованиеКонтрагентаИБ,
		|	СвязиКонтрагентов.ИННОбъектаИБ КАК ИННКонтрагентаИБ,
		|	СвязиКонтрагентов.КППОбъектаИБ КАК КППКонтрагентаИБ,
		|	СвязиКонтрагентов.ИмяРеквизита КАК ИмяРеквизита";
		
		ТекстЗапросаСоединениеСКонтрагентамиИБ = "
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВремСвязиОбъектов КАК СвязиКонтрагентов
		|	ПО Диадок_ЮрФизЛица.Ссылка = СвязиКонтрагентов.ОбъектДиадок";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//ПОЛЯ"		, ТекстЗапросаРеквизитыКонтрагентовИБ);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//СОЕДИНЕНИЯ"	, ТекстЗапросаСоединениеСКонтрагентамиИБ);
		
	КонецЕсли;
		
	Если ПараметрыСписка.Упорядочить Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_ПоляУпорядочивания("Наименование");
	КонецЕсли;
		
	Если ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_ПоляИтогов("Ссылка");
	КонецЕсли;
		
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Отбор = ПараметрыСписка.Отбор;
	
	Запрос.УстановитьПараметр("Организация",Отбор.ОрганизацияЭДО.Ссылка);
	Запрос.УстановитьПараметр("ИНН",		Отбор.ОрганизацияЭДО.ИНН);
	Запрос.УстановитьПараметр("КПП",		Отбор.ОрганизацияЭДО.КПП);
		
	Запрос.УстановитьПараметр("Статусы",	Отбор.Статусы);
	
	Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТаблицаКонтрактов = Ядро.Контрагенты_НоваяТаблицаКонтрактов();
	
	Если ПараметрыСписка.ДобавитьРеквизитыКонтрагентовИБ Тогда
		
		ТаблицаКонтрактов.Колонки.Добавить("РеквизитыСвязанныхСправочников", Новый ОписаниеТипов("Массив"));
		
		ВыборкаКонтрагентовЭДО = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаКонтрагентовЭДО.Следующий() Цикл
			
			СтрокаКонтракта = ТаблицаКонтрактов.Добавить();
			
			СвязанныеКонтрагентыИБ = Новый Массив;
			
			ВыборкаДетальныхДанных = ВыборкаКонтрагентовЭДО.Выбрать();
			Пока ВыборкаДетальныхДанных.Следующий() Цикл
				
				Если Не ЗначениеЗаполнено(СтрокаКонтракта.ID) Тогда
					ЗаполнитьЗначенияСвойств(СтрокаКонтракта, ВыборкаДетальныхДанных);	
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ВыборкаДетальныхДанных.КонтрагентИБ) Тогда
					Продолжить;
				КонецЕсли;
				
				ЗначенияРеквизитовКонтрагентаИБ = Контракт_РеквизитыКонтрагентов1С();
				ЗначенияРеквизитовКонтрагентаИБ.Ссылка 			= ВыборкаДетальныхДанных.КонтрагентИБ;
				ЗначенияРеквизитовКонтрагентаИБ.Наименование 	= ВыборкаДетальныхДанных.НаименованиеКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.ИНН 			= ВыборкаДетальныхДанных.ИННКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.КПП 			= ВыборкаДетальныхДанных.КППКонтрагентаИБ;
				
				СтрокаКонтракта.РеквизитыСвязанныхСправочников.Добавить(ЗначенияРеквизитовКонтрагентаИБ);
				
			КонецЦикла;
			
		КонецЦикла;	
		
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаКонтракта = ТаблицаКонтрактов.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаКонтракта, Выборка);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТаблицаКонтрактов;	
	
КонецФункции

Процедура Контрагенты_ДополнитьТаблицуКонтрактовДаннымиИБ_Диадок(ТаблицаКонтрактов, ОрганизацияЭДО, ДобавитьРеквизитыКонтрагентовИБ)
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТаблицаКонтрактов.Колонки.Добавить("РеквизитыСвязанныхСправочников", Новый ОписаниеТипов("Массив"));
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	Диадок_НастройкиКонтрагентов.Контрагент КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ЮрФизЛицаДиадок
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|ГДЕ
		|	Диадок_НастройкиКонтрагентов.Организация = &Организация
		|	И Диадок_НастройкиКонтрагентов.Контрагент.ID В(&МассивBoxId)
		|	И Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус""";
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_РазделительЗапросов()
			+ Справочники_ТекстЗапросаВременнойТаблицыСвязиОбъектов_Диадок("Контрагенты");
	КонецЕсли;
	
	ТекстЗапросаРеквизитыКонтрагентовОрганизации = 
		"ВЫБРАТЬ
		|	Диадок_ЮрФизЛица.ID КАК ID,
		|	Диадок_ЮрФизЛица.Ссылка КАК Ссылка,
		|	Диадок_ЮрФизЛица.ID_ОсновноеПодразделение КАК ID_ОсновноеПодразделение
		|	//ПОЛЯ
		|ИЗ
		|	Справочник.Диадок_ЮрФизЛица КАК Диадок_ЮрФизЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЮрФизЛицаДиадок КАК КонтрагентыЭДО
		|		ПО Диадок_ЮрФизЛица.Ссылка = КонтрагентыЭДО.Ссылка
		|		//СОЕДИНЕНИЯ
		|ГДЕ
		|	Диадок_ЮрФизЛица.ID В(&МассивBoxId)
		|	И НЕ Диадок_ЮрФизЛица.ПометкаУдаления";
	
	ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_РазделительЗапросов() + ТекстЗапросаРеквизитыКонтрагентовОрганизации;
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		
		ТекстЗапросаРеквизитыКонтрагентовИБ = ",
		|	СвязиКонтрагентов.ОбъектИБ КАК КонтрагентИБ,
		|	СвязиКонтрагентов.НаименованиеОбъектаИБ КАК НаименованиеКонтрагентаИБ,
		|	СвязиКонтрагентов.ИННОбъектаИБ КАК ИННКонтрагентаИБ,
		|	СвязиКонтрагентов.КППОбъектаИБ КАК КППКонтрагентаИБ,
		|	СвязиКонтрагентов.ИмяРеквизита КАК ИмяРеквизита";
		
		ТекстЗапросаСоединениеСКонтрагентамиИБ = "
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВремСвязиОбъектов КАК СвязиКонтрагентов
		|	ПО Диадок_ЮрФизЛица.Ссылка = СвязиКонтрагентов.ОбъектДиадок";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//ПОЛЯ"		, ТекстЗапросаРеквизитыКонтрагентовИБ);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//СОЕДИНЕНИЯ"	, ТекстЗапросаСоединениеСКонтрагентамиИБ);
		
	КонецЕсли;
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапроса_ПоляИтогов("Ссылка");
	КонецЕсли;
	
	ИдентификаторыКонтрагентовЭДО = ТаблицаКонтрактов.ВыгрузитьКолонку("ID");
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Организация", ОрганизацияЭДО.Ссылка);
	Запрос.УстановитьПараметр("МассивBoxId", ИдентификаторыКонтрагентовЭДО);
	Запрос.УстановитьПараметр("ШаблонИмениРеквизита_СвязанныйСправочник", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если ДобавитьРеквизитыКонтрагентовИБ Тогда
		
		ВыборкаКонтрагентовЭДО = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаКонтрагентовЭДО.Следующий() Цикл
			
			СтрокаКонтракта = ТаблицаКонтрактов.Найти(ВыборкаКонтрагентовЭДО.ID, "ID");
			Если СтрокаКонтракта = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			СвязанныеКонтрагентыИБ = Новый Массив;
			
			ВыборкаДетальныхДанных = ВыборкаКонтрагентовЭДО.Выбрать();
			Пока ВыборкаДетальныхДанных.Следующий() Цикл
				
				Если Не ЗначениеЗаполнено(СтрокаКонтракта.Ссылка) Тогда
					ЗаполнитьЗначенияСвойств(СтрокаКонтракта, ВыборкаДетальныхДанных);
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ВыборкаДетальныхДанных.КонтрагентИБ) Тогда
					Продолжить;
				КонецЕсли;
				
				ЗначенияРеквизитовКонтрагентаИБ = Контракт_РеквизитыКонтрагентов1С();
				ЗначенияРеквизитовКонтрагентаИБ.Ссылка 			= ВыборкаДетальныхДанных.КонтрагентИБ;
				ЗначенияРеквизитовКонтрагентаИБ.Наименование 	= ВыборкаДетальныхДанных.НаименованиеКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.ИНН 			= ВыборкаДетальныхДанных.ИННКонтрагентаИБ;
				ЗначенияРеквизитовКонтрагентаИБ.КПП 			= ВыборкаДетальныхДанных.КППКонтрагентаИБ;
				
				СтрокаКонтракта.РеквизитыСвязанныхСправочников.Добавить(ЗначенияРеквизитовКонтрагентаИБ);
				
			КонецЦикла;
			
		КонецЦикла;
		
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаКонтракта = ТаблицаКонтрактов.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаКонтракта, Выборка);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Контрагенты_РезультатГрупповогоСопоставления_Диадок(Организация, СтатусКонтрагентаЭДО)
	
	Результат = Новый Структура;
	Результат.Вставить("КоличествоСопоставленных",	0);
	Результат.Вставить("МассивОшибокДублей",		Новый Массив);
	Результат.Вставить("МассивОшибокСопоставления",	Новый Массив);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= Новый МенеджерВременныхТаблиц;
	
	Если Организация = Неопределено Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		Запрос.УстановитьПараметр("Организация", Организация.Ссылка);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтатусКонтрагентаЭДО", СтатусКонтрагентаЭДО);
	Запрос.УстановитьПараметр("ИмяСправочника", "Контрагенты");
	Запрос.УстановитьПараметр("ИмяРеквизита", ШаблонПараметраЗапросаИмяРеквизитаСвязанныйСправочник());
	
	ТекстЗапроса_РазделительЗапросов = ТекстЗапроса_РазделительЗапросов();
	ТекстЗапросаВТ_КонтрагентыСервиса = Контрагенты_ТекстЗапросаВТ_КонтрагентыСервиса_Диадок(СтатусКонтрагентаЭДО);
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		ТекстЗапросаВТ_ТаблицаСоСвязями = Контрагенты_ТекстЗапроса_ТаблицаСоСвязями_ДиадокРасширение();
	Иначе
		ТекстЗапросаВТ_ТаблицаСоСвязями = Контрагенты_ТекстЗапроса_ТаблицаСоСвязями_ДиадокСХ1();
	КонецЕсли;
	
	ТексЗапросаСвязанныеСправочники = Контрагенты_ТекстСвязанныхСправочников();
		
	ЧастиТекстаЗапроса = Новый Массив;
	
	ЧастиТекстаЗапроса.Добавить(ТекстЗапросаВТ_КонтрагентыСервиса);
	ЧастиТекстаЗапроса.Добавить(ТекстЗапросаВТ_ТаблицаСоСвязями);
	ЧастиТекстаЗапроса.Добавить(ТексЗапросаСвязанныеСправочники);
	
	Запрос.Текст = СоединитьСтроку(ЧастиТекстаЗапроса, ТекстЗапроса_РазделительЗапросов);
	
	РезультатЗапросаСвязанныхКонтрагентов = Запрос.Выполнить();
	
	Запрос.Текст = Контрагенты_ТекстДублейЯщиков();
	ВыборкаДублейКонтрагентов = Запрос.Выполнить().Выбрать();
	
	РезультатСопоставления = Контрагенты_УстановленныеСвязи(РезультатЗапросаСвязанныхКонтрагентов);
	
	ЗаполнитьЗначенияСвойств(Результат, РезультатСопоставления);
	
	Результат.МассивОшибокДублей = Контрагенты_ДополнитьОшибкиСопоставления(ВыборкаДублейКонтрагентов);
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
	Возврат Результат;
	
КонецФункции	

Функция Контрагенты_ТекстЗапросаВТ_КонтрагентыСервиса_Диадок(СтатусКонтрагентаЭДО)

	Результат = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЮрФизЛица.Ссылка КАК Ссылка,
	|	ЮрФизЛица.ID КАК ID,
	|	ЮрФизЛица.ИНН КАК ИНН,
	|	ЮрФизЛица.КПП КАК КПП,
	|	ЮрФизЛица.ИдентификаторУчастникаЭДО КАК ИдентификаторУчастникаЭДО,
	|	ПОДСТРОКА(ЮрФизЛица.ИдентификаторУчастникаЭДО, 1, 3) КАК КодОператораЭДО,
	|	ВЫБОР
	|		КОГДА ПОДСТРОКА(ЮрФизЛица.ИдентификаторУчастникаЭДО, 1, 3) = ""2BM""
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоЯщиковДД,
	|	ВЫБОР
	|		КОГДА ПОДСТРОКА(ЮрФизЛица.ИдентификаторУчастникаЭДО, 1, 3) <> ""2BM""
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоЯщиковРоуминг
	|ПОМЕСТИТЬ ВТ_КонтрагентыСервиса
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
	|		ПО ЮрФизЛица.Ссылка = Диадок_НастройкиКонтрагентов.Контрагент
	|			И (Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус"")
	|			И (&ОтборПоСтатусу)
	|ГДЕ
	|	ЮрФизЛица.ИмяСправочника = &ИмяСправочника
	|	И НЕ ЮрФизЛица.ПометкаУдаления
	|	И (&Организация = НЕОПРЕДЕЛЕНО
	|			ИЛИ Диадок_НастройкиКонтрагентов.Организация = &Организация)";
	
	Если СтатусКонтрагентаЭДО = Неопределено Тогда
		ОтборПоСтатусу = "ИСТИНА";
	Иначе
		ОтборПоСтатусу = "Диадок_НастройкиКонтрагентов.Значение = &СтатусКонтрагентаЭДО";
	КонецЕсли;
	
	Результат = СтрЗаменить(Результат, "&ОтборПоСтатусу", ОтборПоСтатусу);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ТекстЗапроса_ТаблицаСоСвязями_ДиадокРасширение()

	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЮрФизЛицаДопРеквизиты.Значение КАК Контрагент1С,
	|	ЮрФизЛица.Ссылка КАК КонтрагентЭДО,
	|	ЮрФизЛица.ID КАК ID,
	|	ЮрФизЛица.ИдентификаторУчастникаЭДО КАК ИдентификаторУчастникаЭДО
	|ПОМЕСТИТЬ ВТ_ТаблицаСоСвязями
	|ИЗ
	|	Справочник.Диадок_ЮрФизЛица КАК ЮрФизЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диадок_ЮрФизЛица.ДополнительныеРеквизиты КАК ЮрФизЛицаДопРеквизиты
	|		ПО ЮрФизЛица.Ссылка = ЮрФизЛицаДопРеквизиты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыСервиса КАК КонтрагентыСервиса
	|		ПО ЮрФизЛица.Ссылка = КонтрагентыСервиса.Ссылка
	|ГДЕ
	|	НЕ КонтрагентыСервиса.Ссылка ЕСТЬ NULL
	|	И ЮрФизЛицаДопРеквизиты.ИмяРеквизита ПОДОБНО &ИмяРеквизита
	|	И НЕ ЮрФизЛицаДопРеквизиты.Значение = НЕОПРЕДЕЛЕНО
	|	И НЕ ЮрФизЛицаДопРеквизиты.Значение = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)";
	
	ИмяТаблицыКонтрагенты = Справочники_УстановитьИмяТаблицыКонтрагентовВТекстеЗапроса(Результат);
	
	Возврат Результат;
	
КонецФункции

