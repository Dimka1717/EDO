Функция Пакеты_КонтрактПоВыборкеДанных_Диадок(Выборка)
	
	Результат = Контракт_Пакет();
	
	ЗаполнитьЗначенияСвойств(Результат, 				Выборка, "Направление, ДокументУчета, ДатаЭДО, Состояние, Заблокирован, ИдентификаторВида");
	ЗаполнитьЗначенияСвойств(Результат.Реквизиты, 		Выборка, "Дата, Номер, Сумма");
	ЗаполнитьЗначенияСвойств(Результат.Идентификаторы, 	Выборка, "BoxId, LetterId, ПакетЭДО");
	
	ЗаполнитьУчастниковДокументооборота(Результат.Отправитель, Результат.Получатель, Выборка);
	
	Если ЗначениеЗаполнено(Выборка.ТекстОшибки)
		И Результат.Направление = Перечисление_Направления().Исходящее Тогда
		Результат.СлужебнаяИнформация.Вставить("ОшибкиОтправки", Выборка.ТекстОшибки);
	КонецЕсли;
	
	ПакетОтправлен = ЗначениеЗаполнено(Результат.Идентификаторы.LetterId);
	Если Не ПакетОтправлен Тогда
		ПараметрыОтправки = Контракт_ПараметрыОтправкиПакета();
		Результат.СлужебнаяИнформация.Вставить("ПараметрыОтправки", ПараметрыОтправки);
	КонецЕсли;
	
	СтруктураДопРеквизитов = ДопРеквизиты_СписокРеквизитов(Выборка.ПакетЭДО);
	
	Для Каждого ДопРеквизит Из СтруктураДопРеквизитов Цикл
		
		Если ДопРеквизит.Ключ = "FromDepartmentId" Тогда
			Результат.Отправитель.DepartmentId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "ToDepartmentId" Тогда
			Результат.Получатель.DepartmentId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "ЗашифрованныйПакет" Тогда
			Результат.СлужебнаяИнформация.Вставить(ДопРеквизит.Ключ, ДопРеквизит.Значение);
		ИначеЕсли ДопРеквизит.Ключ = "ProxyBoxId" Тогда
			ПромежуточныйПолучатель = Результат.СлужебнаяИнформация.ПараметрыОтправки.ПромежуточныйПолучатель;
			ПромежуточныйПолучатель.BoxId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "ProxyDepartmentId" Тогда
			ПромежуточныйПолучатель = Результат.СлужебнаяИнформация.ПараметрыОтправки.ПромежуточныйПолучатель;
			ПромежуточныйПолучатель.DepartmentId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "ПараметрыПереотправки" Тогда
			Результат.СлужебнаяИнформация.Вставить(ДопРеквизит.Ключ, ДопРеквизит.Значение);
		ИначеЕсли ДопРеквизит.Ключ = "Шаблон" Тогда
			Результат.Шаблон = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "MessageFromBoxId" Тогда
			Результат.ПараметрыШаблона.MessageFromBoxId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "MessageToBoxId" Тогда
			Результат.ПараметрыШаблона.MessageToBoxId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "MessageToDepartmentId" Тогда
			Результат.ПараметрыШаблона.MessageToDepartmentId = ДопРеквизит.Значение;
		ИначеЕсли ДопРеквизит.Ключ = "LockMode" Тогда
			Результат.ПараметрыШаблона.LockMode = ДопРеквизит.Значение;
		Иначе
			Результат.ДопРеквизиты.Вставить(ДопРеквизит.Ключ, ДопРеквизит.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_МассивКонтрактовДокументовПакета_Диадок(Идентификаторы)

	Результат = Новый Массив;
	
	МассивДокументовПакета = Пакеты_ДокументыПакета_Диадок(Идентификаторы);
	
	Для Каждого ИдентификаторыДокумента Из МассивДокументовПакета Цикл
		
		Документ = Документы_ДанныеДокумента_Диадок(ИдентификаторыДокумента);
		Результат.Добавить(Документ);
		
	КонецЦикла;	
	
	Возврат Результат;

КонецФункции

Функция Пакеты_СсылкаПоИдентификаторам_Диадок(Идентификаторы)
	
	Результат = Неопределено;
	
	BoxId	 = СвойствоСтруктуры(Идентификаторы, "BoxId",		"");
	LetterId = СвойствоСтруктуры(Идентификаторы, "LetterId",	"");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Диадок_ПакетыДокументов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
	|ГДЕ
	|	Диадок_ПакетыДокументов.BoxId = &BoxId
	|	И Диадок_ПакетыДокументов.LetterId = &LetterId");
	
	Запрос.УстановитьПараметр("BoxId",		АдресЯщикаВИдентификатор(BoxId));
	Запрос.УстановитьПараметр("LetterId",	LetterId);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаЗапроса.Следующий() Тогда
		Результат = ВыборкаЗапроса.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Пакеты_ДокументУчета_Диадок(Идентификаторы)
	
	Результат = Неопределено;
	
	ПакетЭДО = СвойствоСтруктуры(Идентификаторы, "ПакетЭДО");

	Если ПакетЭДО = Неопределено Тогда
		ПакетЭДО = Пакеты_СсылкаПоИдентификаторам_Диадок(Идентификаторы);
	КонецЕсли;
	
	Если ПакетЭДО <> Неопределено Тогда
		Результат = ПакетЭДО.Документ;
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Процедура Пакеты_ВыполнитьОчисткуУстаревшихПодготовленных_Диадок()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Диадок_ПакетыДокументов.Ссылка КАК Пакет,
	|	Диадок_ПакетыДокументов.Документ КАК Документ1С
	|ПОМЕСТИТЬ ВТ_ПодготовленныеПакеты
	|ИЗ
	|	Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
	|ГДЕ
	|	Диадок_ПакетыДокументов.Метка = &МеткаПодготовлен
	|	И Диадок_ПакетыДокументов.LetterId = &ПустойLetterId
	|	И НЕ Диадок_ПакетыДокументов.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Документ1С
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПодготовленныеПакеты.Документ1С КАК Документ1С
	|ПОМЕСТИТЬ ВТ_ДокументыСДублямиПакетов
	|ИЗ
	|	Справочник.Диадок_ПакетыДокументов КАК Диадок_ПакетыДокументов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПодготовленныеПакеты КАК ВТ_ПодготовленныеПакеты
	|		ПО Диадок_ПакетыДокументов.Документ = ВТ_ПодготовленныеПакеты.Документ1С
	|			И Диадок_ПакетыДокументов.Ссылка <> ВТ_ПодготовленныеПакеты.Пакет
	|ГДЕ
	|	Диадок_ПакетыДокументов.Метка <> &МеткаПодготовлен
	|	И Диадок_ПакетыДокументов.Метка <> """"
	|	И НЕ Диадок_ПакетыДокументов.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ПодготовленныеПакеты.Документ1С
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Диадок_ПакетыДокументов.Ссылка) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ПодготовленныеПакеты.Пакет КАК Пакет
	|ИЗ
	|	ВТ_ПодготовленныеПакеты КАК ВТ_ПодготовленныеПакеты
	|ГДЕ
	|	ВТ_ПодготовленныеПакеты.Документ1С В
	|			(ВЫБРАТЬ
	|				ВТ_ДокументыСДублямиПакетов.Документ1С КАК Документ1С
	|			ИЗ
	|				ВТ_ДокументыСДублямиПакетов КАК ВТ_ДокументыСДублямиПакетов)";
	
	Запрос.УстановитьПараметр("ПустойLetterId", "                                    ");
	Запрос.УстановитьПараметр("МеткаПодготовлен", Метка_Подготовлен());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПакетОбъект = ВыборкаДетальныеЗаписи.Пакет.ПолучитьОбъект();
		ПакетОбъект.УстановитьПометкуУдаления(Истина);
		
	КонецЦикла;
	
	КоличествоУдаленных = ВыборкаДетальныеЗаписи.Количество();
	Если КоличествоУдаленных > 0 Тогда
	
		ЗаписьЖурналаРегистрации("Диадок.Автоматическая очистка подготовленных пакетов"
			, УровеньЖурналаРегистрации.Информация
			,
			,
			, "Удалено пакетов: " + КоличествоУдаленных
		);
		
	КонецЕсли;
	
КонецПроцедуры

