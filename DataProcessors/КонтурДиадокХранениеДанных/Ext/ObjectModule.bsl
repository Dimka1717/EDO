КонецФункции	

// Исправляет некорректо указанные свойства в связях подразделений Диадок и подразделений 1С
// Данный метод заменяет некорректное свойство "DDPro_DDPro_IDПодразделенияКонтрагент"
// в записях регистра на "DDPro_IDПодразделенияКонтрагент".
// Исправление внесено в бэтмене 4.20.4. В дальнейшем данный функционал будет удален
//
Процедура Подразделения_ЗаменитьСвойстваПодразделенийКонтрагентовПриОбновлении_1С() Экспорт
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	IDПодразделенияКонтрагента 	= Перечисление_ИменаСвойствНастроек_1С().IDПодразделенияКонтрагента;
	КорректноеИмяСвойства 		= ПрефиксНастройки_1С(Истина) + IDПодразделенияКонтрагента;
		
	СПрефиксом = Истина;
	НекорректноеСвойство = Свойства_НайтиСвойство(КорректноеИмяСвойства, СПрефиксом);
	Если Не ЗначениеЗаполнено(НекорректноеСвойство) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	*
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов
	|ГДЕ
	|	Свойство = &Свойство";
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Свойство", НекорректноеСвойство);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ДляОрганизации = Ложь;
		КорректноеСвойство = ИмяСвойстваПодразделения(ДляОрганизации);
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ЗаписьРегистра = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(ЗаписьРегистра, Выборка);
			
			ЗаписьРегистра.Прочитать();
			ЗаписьРегистра.Свойство = КорректноеСвойство;
			ЗаписьРегистра.Записать(Истина);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

//}		СПРАВОЧНИКИ: ОРГАНИЗАЦИИ, КОНТРАГЕНТЫ, ПОДРАЗДЕЛЕНИЯ


