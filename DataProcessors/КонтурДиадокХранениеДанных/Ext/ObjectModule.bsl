Функция Организации_УчастникДО_1С(Идентификаторы)
	
	Результат = Контракт_УчастникДокументооборота();

	BoxID = ИдентификаторВАдресЯщика(Идентификаторы.ID);
	
	Если BoxID = "" Тогда
		BoxID = Организации_ИдентификаторПоСсылке_1С(Идентификаторы);
		Идентификаторы.ID = BoxID;
	КонецЕсли;	
	
	СтрокаКонтекста = КонтекстСеанса_СтрокаКонтекста(BoxID);
	
	ЗаполнитьЗначенияСвойств(Результат, СтрокаКонтекста);
	
	Результат.BoxId				= BoxID;
	Результат.Наименование		= СтрокаКонтекста.ОрганизацияНаименование;
	Результат.FNSParticipantId	= СтрокаКонтекста.Box.Organization.FnsParticipantId;
	
	ОрганизацииВ1С = Организации_СопоставленныеВ1С(Идентификаторы);
	
	Если ЗначениеЗаполнено(ОрганизацииВ1С) Тогда
		
		ОрганизацияВ1С = ОрганизацииВ1С[0].Ссылка;
		
		// для совместимости заполним реквизит "Организация"
		Результат.Организация = ОрганизацияВ1С;
					
		// при множественном сопоставлении не важно по какой из сопоставленных организаций 1С искать подразделение по умолчанию,
		// т.к. для всех сопоставленных настройка будет одинакова
		Результат.DepartmentId	= Организации_ОсновноеПодразделениеОрганизации_1С(ОрганизацияВ1С);
		
	КонецЕсли;	
	
	Возврат Результат;
	
КонецФункции

Функция Организации_ОсновноеПодразделениеОрганизации_1С(ОрганизацияВ1С)
		
	ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
		
	Результат = ДопРеквизиты_Значение_1С(ОрганизацияВ1С, ИменаСвойствНастроек.IDОсновноеПодразделениеОрганизации, Ложь);
	
	ДлинаID = 36;
		
	Если СтрДлина(Результат) <> ДлинаID Тогда
		Результат = "";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Организации_НастройкиСертификатовНаСервере1С_1С()
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Объект КАК Справочник.Организации) КАК Организация,
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(1000)) КАК ОтпечатокСертификата
	|ПОМЕСТИТЬ ВТ_Отпечатки
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство = &Свойство_Отпечаток
	|	И (ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(1000))) <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Объект КАК Справочник.Организации) КАК Организация,
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(1000)) КАК BoxID
	|ПОМЕСТИТЬ ВТ_Организации
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство = &Свойство_ID
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Организации.BoxID,
	|	ВТ_Организации.Организация.ИНН КАК ИНН,
	|	ВТ_Организации.Организация.КПП КАК КПП,
	|	ВТ_Отпечатки.ОтпечатокСертификата
	|ИЗ
	|	ВТ_Отпечатки КАК ВТ_Отпечатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Организации КАК ВТ_Организации
	|		ПО ВТ_Отпечатки.Организация = ВТ_Организации.Организация";
	
	ИмяТаблицыОрганизации	= ТипЗначенияОбъекта("Организации", "ДляЗапроса");
	ТекстЗапроса			= СтрЗаменить(ТекстЗапроса, "Справочник.Организации", ИмяТаблицыОрганизации);
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Свойство_Отпечаток",	Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().ОтпечатокСертификатаНаСервере));
	Запрос.УстановитьПараметр("Свойство_ID",		Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().IDОрганизации, Ложь));
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		СтруктураНастройки = Новый Структура;
		СтруктураНастройки.Вставить("BoxId",					"");
		СтруктураНастройки.Вставить("Наименование",				"");
		СтруктураНастройки.Вставить("ИНН",						"");
		СтруктураНастройки.Вставить("КПП",						"");
		СтруктураНастройки.Вставить("ОрганизацияДиадокСсылка",	Неопределено);
		СтруктураНастройки.Вставить("ОтпечатокСертификата",		"");
		СтруктураНастройки.Вставить("Облачный",					Ложь);
		
		ЗаполнитьЗначенияСвойств(СтруктураНастройки, ВыборкаЗапроса);
		СтруктураНастройки.ОтпечатокСертификата = ВРег(СтруктураНастройки.ОтпечатокСертификата);
		
		Результат.Добавить(СтруктураНастройки);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Перезаписывает дополнительные реквизиты для Организации ЭДО
//
// Параметры:
//	Организация 		- Структура - данные организации ЭДО
//	СтруктураРеквизитов - Структура - реквизиты требующие обновления
Процедура Организации_ОбновлениеРеквизитов_1С(Организация, СтруктураРеквизитов)
	
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		ID = СвойствоСтруктуры(Организация, "ID", "");
		
		Организации_ОчиститьНастройки_1С(ID);
		
		ИменаСвойствНастроек = Перечисление_ИменаСвойствНастроек_1С();
		
		Для Каждого ЭлементКоллекции Из СтруктураРеквизитов.СвязанныеСправочники Цикл
			
			СвязанныйСправочник = ЭлементКоллекции.Ссылка;
			
			ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.IDОрганизации, ID, Ложь);
			
			Если СтруктураРеквизитов.Свойство("ОсновнойПакет") Тогда
				ОсновнойПакет = ?(СтруктураРеквизитов.ОсновнойПакет = Неопределено, "", СтруктураРеквизитов.ОсновнойПакет);
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ОсновнойПакет, ОсновнойПакет);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ШифроватьДокументы") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ШифроватьДокументы, СтруктураРеквизитов.ШифроватьДокументы);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("УказыватьОтсутствиеОснованияУПД") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.УказыватьОтсутствиеОснованияУПД, СтруктураРеквизитов.УказыватьОтсутствиеОснованияУПД, Ложь);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ОтправлятьНепроведенныеДокументы") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ОтправлятьНепроведенныеДокументы, СтруктураРеквизитов.ОтправлятьНепроведенныеДокументы, Ложь);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ЗаписыватьКомментарииВДокументы1С") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ЗаписыватьКомментарииВДокументы1С, СтруктураРеквизитов.ЗаписыватьКомментарииВДокументы1С);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ТекстКомментарияОтправка") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ТекстКомментарияОтправка, СтруктураРеквизитов.ТекстКомментарияОтправка, Ложь);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ТекстКомментарияПолучение") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ТекстКомментарияПолучение, СтруктураРеквизитов.ТекстКомментарияПолучение);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ОтпечатокСертификатаНаСервере") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.ОтпечатокСертификатаНаСервере, СтруктураРеквизитов.ОтпечатокСертификатаНаСервере);
			КонецЕсли;
			
			Если СтруктураРеквизитов.Свойство("ID_ОсновноеПодразделение") Тогда
				ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, ИменаСвойствНастроек.IDОсновноеПодразделениеОрганизации, СтруктураРеквизитов.ID_ОсновноеПодразделение, Ложь);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция Организации_ТаблицаСопоставленныхОрганизаций_1С()
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(ЗначенияСвойствОбъектов.Значение КАК СТРОКА(1000)) КАК BoxID,
	|	"""" КАК Наименование,
	|	ЗначенияСвойствОбъектов.Объект КАК Ссылка
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство = &Свойство_ID";
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	ТекстЗапроса	= СтрЗаменить(ТекстЗапроса, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Свойство_ID", Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().IDОрганизации, Ложь));
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Очищает доп реквизиты организации ЭДО в подсистеме 1С
//
// Параметры:
//	ID - Строка - идентификатор организации ЭДО
Процедура Организации_ОчиститьНастройки_1С(ID)
	
	МассивСопоставленных = Организации_МассивСопоставленныхВ1С_1С(Новый Структура("ID", ID));
	
	Для Каждого СопоставленнаяОрганизация Из МассивСопоставленных Цикл
		
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_IDОрганизации());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_IDОсновноеПодразделениеОрганизации());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ОсновнойПакет());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ШифроватьДокументы());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_УказыватьОтсутствиеОснованияУПД());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ОтправлятьНепроведенныеДокументы());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ЗаписыватьКомментарииВДокументы1С());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ТекстКомментарияОтправка());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ТекстКомментарияПолучение());
		ДопРеквизиты_УдалитьЗначение_1С(СопоставленнаяОрганизация, Свойства_ОтпечатокСертификатаНаСервере());
		
	КонецЦикла;	
	
КонецПроцедуры

Функция Организации_ИдентификаторПоСсылке_1С(Идентификаторы)
	
	Ссылка = Идентификаторы.Ссылка;
	
	Результат = ДопРеквизиты_Значение_1С(Ссылка, Перечисление_ИменаСвойствНастроек_1С().IDОрганизации, Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_ДанныеКонтрагента_1С(Идентификаторы)
	
	Результат = Контракт_КонтрагентЭДО();
	
	СтруктураКонтрагента = Контрагенты_РеквизитыКонтрагента_АПИ(Идентификаторы.ID);
	
	ЗаполнитьЗначенияСвойств(Результат, СтруктураКонтрагента);
	
	МассивСопоставленных = Контрагенты_МассивСопоставленныхВ1С_1С(Идентификаторы);
	
	Сч = 1;
	
	Для Каждого СвязанныйСправочник Из МассивСопоставленных Цикл
		
		Если Сч > 3 Тогда
			Продолжить;
		КонецЕсли;
		
		Результат["СвязанныйСправочник" + Сч] = СвязанныйСправочник;
		
		Сч = Сч + 1;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Результат.СвязанныйСправочник1) Тогда
		ID_ОсновноеПодразделение = ДопРеквизиты_Значение_1С(Результат.СвязанныйСправочник1, Перечисление_ИменаСвойствНастроек_1С().IDОсновноеПодразделениеКонтрагента, Ложь);
		Результат.ID_ОсновноеПодразделение = ?(ID_ОсновноеПодразделение = Неопределено, "", ID_ОсновноеПодразделение);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_СопоставленныйВ1С_1С(Идентификаторы)

	Результат = Неопределено;
	
	МассивСопоставленных = Контрагенты_МассивСопоставленныхВ1С_1С(Идентификаторы);
	
	Если МассивСопоставленных.Количество() > 0 Тогда
		Результат = МассивСопоставленных[0];
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция Контрагенты_СопоставленныеВ1С_1С(Идентификаторы)
	
	Результат = Контрагенты_МассивСопоставленныхВ1С_1С(Идентификаторы);
		
	Возврат Результат;
	
КонецФункции

Функция Контрагенты_МассивСопоставленныхВ1С_1С(Идентификаторы)

	Результат = Новый Массив;
	
	BoxID					= ИдентификаторВАдресЯщика(Идентификаторы.ID);
	Свойство_IDКонтрагента	= Свойства_СсылкаНаСвойство(Перечисление_ИменаСвойствНастроек_1С().IDКонтрагента, Ложь);
	
	Запрос = Новый Запрос;
			
	Запрос.Текст = Свойства_ТекстЗапроса_ЗначениеОбъекта();
	
	Запрос.УстановитьПараметр("Значение",	BoxID);
	Запрос.УстановитьПараметр("Свойство",	Свойство_IDКонтрагента);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		Результат.Добавить(ВыборкаЗапроса.Ссылка);
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Функция Контрагенты_УчастникДО_1С(Идентификаторы, ОрганизацияЭДО)
	
	Результат = Контракт_УчастникДокументооборота();

	BoxID = ИдентификаторВАдресЯщика(Идентификаторы.ID);
	
	Если BoxID = "" Тогда
		BoxID = Контрагенты_ИдентификаторПоСсылке_1С(Идентификаторы);
		Идентификаторы.ID = BoxID;
	КонецЕсли;
	
	СтруктураКонтрагента = Контрагенты_РеквизитыКонтрагента_АПИ(BoxId);
	
	Результат.BoxId				= BoxID;
	Результат.Наименование		= СтруктураКонтрагента.Наименование;
	Результат.FNSParticipantId	= СтруктураКонтрагента.ИдентификаторУчастникаЭДО;
	
	КонтрагентыВ1С = Контрагенты_СопоставленныеВ1С(Идентификаторы);
	
	Если ЗначениеЗаполнено(КонтрагентыВ1С) Тогда
		
		КонтрагентВ1С = КонтрагентыВ1С[0].Ссылка;
		
		// для совместимости заполним реквизит "Организация"
		Результат.Организация	= КонтрагентВ1С;
				
		// при множественном сопоставлении не важно по какому из сопоставленных контрагентов 1С искать подразделение по умолчанию,
		// т.к. для всех сопоставленных настройка будет одинакова
		Результат.DepartmentId	= ДопРеквизиты_Значение_1С(КонтрагентВ1С, Перечисление_ИменаСвойствНастроек_1С().IDОсновноеПодразделениеКонтрагента, Ложь);
		
	КонецЕсли;	
	
	Возврат Результат;
		
КонецФункции

Процедура Контрагенты_ОбновлениеРеквизитов_1С(Идентификаторы, СтруктураРеквизитов)
			
	Если СтруктураРеквизитов.Свойство("СвязанныеСправочники") Тогда
		
		ID = СвойствоСтруктуры(Идентификаторы, "ID", "");
		ID_ОсновноеПодразделение = СвойствоСтруктуры(СтруктураРеквизитов, "ID_ОсновноеПодразделение");
		
		Контрагенты_ОчиститьНастройки_1С(ID);
							
		Для каждого ЭлементКоллекции Из СтруктураРеквизитов.СвязанныеСправочники Цикл
			Если ЗначениеЗаполнено(ЭлементКоллекции.Ссылка) Тогда
				Контрагенты_УстановитьНастройки_1С(ЭлементКоллекции.Ссылка, ID, ID_ОсновноеПодразделение);
			КонецЕсли;	
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Контрагенты_ОчиститьНастройки_1С(ID)
	
	МассивСопоставленных = Контрагенты_МассивСопоставленныхВ1С_1С(Новый Структура("ID", ID));
	
	Для Каждого СвязанныйСправочник Из МассивСопоставленных Цикл
		
		ДопРеквизиты_УдалитьЗначение_1С(СвязанныйСправочник, Свойства_IDКонтрагента());
		ДопРеквизиты_УдалитьЗначение_1С(СвязанныйСправочник, Свойства_IDОсновноеПодразделениеКонтрагента());
		
	КонецЦикла;	
	
КонецПроцедуры

Процедура Контрагенты_УстановитьНастройки_1С(СвязанныйСправочник, ID, ID_ОсновноеПодразделение)
	
	Если ЗначениеЗаполнено(СвязанныйСправочник) Тогда
		
		ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, Перечисление_ИменаСвойствНастроек_1С().IDКонтрагента, ID, Ложь);
		
		Если ЗначениеЗаполнено(ID_ОсновноеПодразделение) Тогда
			ДопРеквизиты_УстановитьЗначение_1С(СвязанныйСправочник, Перечисление_ИменаСвойствНастроек_1С().IDОсновноеПодразделениеКонтрагента, ID_ОсновноеПодразделение, Ложь);
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

Функция Контрагенты_ИдентификаторПоСсылке_1С(Идентификаторы)
	
	Ссылка = Идентификаторы.Ссылка;
	
	Результат = ДопРеквизиты_Значение_1С(Ссылка, Перечисление_ИменаСвойствНастроек_1С().IDКонтрагента, Ложь);
	
	Возврат Результат;
	
КонецФункции


Функция Подразделения_ДанныеПодразделения_1С(Идентификаторы, ДанныеВладельца, ДляОрганизации)

	Результат = Подразделения_РеквизитыПодразделения_АПИ(Идентификаторы, ДанныеВладельца, ДляОрганизации);
			
	Возврат Результат;

КонецФункции

Функция Подразделения_МассивСопоставленныхВ1С_1С(Идентификаторы, ДляОрганизации)

	Результат = Новый Массив;
	
	BoxID = Идентификаторы.ID;
	
	Свойство_IDПодразделения = ИмяСвойстваПодразделения(ДляОрганизации);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = Свойства_ТекстЗапроса_ЗначениеОбъекта();
			
	Запрос.УстановитьПараметр("Значение",	BoxID);
	Запрос.УстановитьПараметр("Свойство",	Свойство_IDПодразделения);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		Результат.Добавить(ВыборкаЗапроса.Ссылка);
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Функция Подразделения_СопоставленныйВ1С_1С(Идентификаторы, ДляОрганизации)

	Результат = Неопределено;
	
	МассивСопоставленных = Подразделения_МассивСопоставленныхВ1С_1С(Идентификаторы, ДляОрганизации);
	
	Если МассивСопоставленных.Количество() > 0 Тогда
		Результат = МассивСопоставленных[0];
	КонецЕсли;
	
	Возврат Результат;
	
