Функция ДопРеквизиты_СписокРеквизитов_1С(Ссылка, СписокДопРеквизитов)
	
	Результат = Новый Структура(СписокДопРеквизитов);
	
	Запрос = Новый Запрос(                                            

	"ВЫБРАТЬ РАЗРЕШЕННЫЕ                                             
	|	ЗначенияСвойствОбъектов.Объект,
	|	ЗначенияСвойствОбъектов.Свойство.Наименование КАК ИмяРеквизита,
	|	ЗначенияСвойствОбъектов.Значение КАК ЗначениеРеквизита
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Объект = &Ссылка");
	
	ИмяРегистра		= Свойства_ИмяРегистраСведений();
	Запрос.Текст	= СтрЗаменить(Запрос.Текст, "РегистрСведений.ЗначенияСвойствОбъектов", "РегистрСведений." + ИмяРегистра);
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ИмяРеквизита = Выборка.ИмяРеквизита;
		
		Если СписокДопРеквизитов = ""
			ИЛИ Результат.Свойство(ИмяРеквизита) Тогда
			
			Результат.Вставить(ИмяРеквизита, Выборка.ЗначениеРеквизита);
			
		КонецЕсли;	
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции

Функция ДопРеквизиты_Значение_1С(ОбъектСсылка, НаименованиеСвойства, СПрефиксом = Истина) Экспорт
	
	Если ЗначениеЗаполнено(ОбъектСсылка) Тогда
		Объект = ОбъектСсылка;
	Иначе
		Объект = ОбъектОбщихНастроек_1С();
	КонецЕсли;	
	
	Результат = Свойства_ЗначениеСвойства(НаименованиеСвойства, Объект, СПрефиксом);
	
	Возврат Результат;	
	
КонецФункции

Функция ДопРеквизиты_ЗначениеШифрованияДокумента_1С(ИдентификаторыОрганизации, ДляОрганизации = Истина)
	
	Если ДляОрганизации Тогда
		Элемент = Организации_СопоставленнаяВ1С_1С(ИдентификаторыОрганизации);
	Иначе
		Элемент = Контрагенты_СопоставленныйВ1С_1С(ИдентификаторыОрганизации);
	КонецЕсли;
	
	Результат	= ДопРеквизиты_Значение_1С(Элемент, Перечисление_ИменаСвойствНастроек_1С().ШифроватьДокументы);
	
	Возврат Результат;
	
КонецФункции

Процедура ДопРеквизиты_УстановитьЗначение_1С(Элемент, ИмяСвойства, Значение, СПрефиксом = Истина) Экспорт
	
	Если Не ЗначениеЗаполнено(ИмяСвойства) Тогда
		Возврат;
	КонецЕсли;
	
	// BSLLS:SetPrivilegedMode-off
	УстановитьПривилегированныйРежим(Истина);
	// BSLLS:SetPrivilegedMode-on
	
	Свойство = ИмяСвойства;
	
	Если ТипЗнч(ИмяСвойства) = Тип("Строка") Тогда
		Свойство = Свойства_СсылкаНаСвойство(ИмяСвойства, СПрефиксом);
	КонецЕсли;
				
	Если ЗначениеЗаполнено(Элемент) Тогда
		Объект = Элемент.Ссылка;
	Иначе
		Объект = ОбъектОбщихНастроек_1С();
	КонецЕсли;
	
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	Запись		= РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
	
	Запись.Объект	= Объект;
	Запись.Свойство = Свойство;
	Запись.Значение = Значение;
	
	Запись.Записать();
	
КонецПроцедуры

Процедура ДопРеквизиты_УдалитьЗначение_1С(Элемент, СсылкаНаСвойство)
	
	Если НЕ ЗначениеЗаполнено(СсылкаНаСвойство) Тогда
		Возврат;
	КонецЕсли;
	
	Свойство = СсылкаНаСвойство;
	
	Если ТипЗнч(СсылкаНаСвойство) = Тип("Строка") Тогда
		Свойство = Свойства_СсылкаНаСвойство(СсылкаНаСвойство);
	КонецЕсли;
		
	ИмяРегистра = Свойства_ИмяРегистраСведений();
	
	Запись = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
	
	Запись.Объект	= Элемент;
	Запись.Свойство = Свойство;
	
	Запись.Удалить();
	
КонецПроцедуры

Функция ДопСправочники_СписокЭлементов_1С(ИмяСправочника, ПереченьРеквизитов)
	
	Результат = ДопСправочники_НоваяТаблица_1С(ПереченьРеквизитов);
	
	Если ИмяСправочника = "ТипыДокументовAPI" Тогда
		
		Таблица = Кэш_Прочитать("ТаблицаТиповДокументовAPI");
		
	ИначеЕсли ИмяСправочника = "ВидыПакетов"
		  ИЛИ ИмяСправочника = "ВидыДокументов" Тогда
		  
		Таблица = СопоставлениеДанныхПМ_ТаблицаВидовСправочника(ИмяСправочника);
		
	ИначеЕсли ИмяСправочника = "ВидыГруппировкиПолученных" Тогда
		
		Таблица = Кэш_Прочитать("ТаблицаВидовГруппировкиПолученных");
		
		Если Таблица = Неопределено Тогда
			
			Таблица = ДопСправочники_ВидыГруппировкиПолученных_1С();
			Кэш_Поместить("ТаблицаВидовГруппировкиПолученных", Таблица);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Таблица <> Неопределено Тогда
		Для Каждого ТекСтрока Из Таблица Цикл
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;               
	
КонецФункции

Функция ДопСправочники_НоваяТаблица_1С(ПереченьРеквизитов)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Ссылка",		Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(50)));
	Результат.Колонки.Добавить("Наименование",	Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(150)));
	
	СписокДопРеквизитов = РазделитьСтрокуЛок(ПереченьРеквизитов);
	
	Для Каждого ДопРеквизит Из СписокДопРеквизитов Цикл
		
		Если ДопРеквизит = "УПД" Тогда
			Результат.Колонки.Добавить(ДопРеквизит, Новый ОписаниеТипов("Булево"));
		ИначеЕсли ДопРеквизит = "ID" Тогда
			Результат.Колонки.Добавить(ДопРеквизит, Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(50)));	
		Иначе	
			Результат.Колонки.Добавить(ДопРеквизит);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции	

Функция ДопСправочники_СсылкаПоИдентификатору_1С(ИмяСправочника, Идентификатор)
	
	Результат = Идентификатор;
	
	Возврат Результат;
	
КонецФункции

