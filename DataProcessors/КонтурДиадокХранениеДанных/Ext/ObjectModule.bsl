		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТипОснования_Приоритет1 КАК ВТ_ТипОснования_Приоритет1
		|		ПО ВТ_КэшКонтрагентовПоТипуОснования.Контрагент1С = ВТ_ТипОснования_Приоритет1.Контрагент1С
		|			И ВТ_КэшКонтрагентовПоТипуОснования.ВидДокументаID = ВТ_ТипОснования_Приоритет1.ВидДокументаID
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТипОснования_Приоритет2 КАК ВТ_ТипОснования_Приоритет2
		|		ПО ВТ_КэшКонтрагентовПоТипуОснования.Организация1С = ВТ_ТипОснования_Приоритет2.Организация1С
		|			И ВТ_КэшКонтрагентовПоТипуОснования.ВидДокументаID = ВТ_ТипОснования_Приоритет2.ВидДокументаID
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация1С,
		|	Контрагент1С
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшКонтрагентовПоКатегориям.Организация1С КАК Организация1С,
		|	ВТ_КэшКонтрагентовПоКатегориям.Контрагент1С КАК Контрагент1С,
		|	ЕСТЬNULL(ЕСТЬNULL(ВТ_КэшНастроекВидовПакетов_Приоритет1.ВидПакетаID, ВТ_КэшНастроекВидовПакетов_Приоритет2.ВидПакетаID), ВТ_КэшКонтрагентовПоКатегориям.ПоУмолчаниюВидПакетаID) КАК ВидПакетаID,
		|	ВТ_КэшКонтрагентовПоКатегориям.КатегорияПакета КАК КатегорияПакета,
		|	ВТ_КэшКонтрагентовПоКатегориям.ПоУмолчаниюВидПакетаID КАК ПоУмолчаниюВидПакетаID,
		|	ЕСТЬNULL(ВТ_КэшНастроекОтправкиНепроведенных.ОтправлятьНепроведенные, ЛОЖЬ) КАК ОтправлятьНепроведенные
		|ПОМЕСТИТЬ ВТ_КэшКонтрагентовПоВидамПакетов
		|ИЗ
		|	ВТ_КэшКонтрагентовПоКатегориям КАК ВТ_КэшКонтрагентовПоКатегориям
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекВидовПакетов_Приоритет1 КАК ВТ_КэшНастроекВидовПакетов_Приоритет1
		|		ПО ВТ_КэшКонтрагентовПоКатегориям.Контрагент1С = ВТ_КэшНастроекВидовПакетов_Приоритет1.Контрагент1С
		|			И ВТ_КэшКонтрагентовПоКатегориям.КатегорияПакета = ВТ_КэшНастроекВидовПакетов_Приоритет1.КатегорияПакета
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекВидовПакетов_Приоритет2 КАК ВТ_КэшНастроекВидовПакетов_Приоритет2
		|		ПО ВТ_КэшКонтрагентовПоКатегориям.Организация1С = ВТ_КэшНастроекВидовПакетов_Приоритет2.Организация1С
		|			И ВТ_КэшКонтрагентовПоКатегориям.КатегорияПакета = ВТ_КэшНастроекВидовПакетов_Приоритет2.КатегорияПакета
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекОтправкиНепроведенных КАК ВТ_КэшНастроекОтправкиНепроведенных
		|		ПО ВТ_КэшКонтрагентовПоКатегориям.Организация1С = ВТ_КэшНастроекОтправкиНепроведенных.Организация1С
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация1С,
		|	Контрагент1С
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияСвойствОбъектов.Объект КАК Документ,
		|	ВТ_КэшВидовПакетов.ВидПакетаID КАК ВидПакета,
		|	ВТ_КэшВидовПакетов.КатегорияПакета КАК КатегорияПакета
		|ПОМЕСТИТЬ ВТ_КэшДокументовПоВидамПакета
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ЗначенияСвойствОбъектов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшВидовПакетов КАК ВТ_КэшВидовПакетов
		|	ПО ВТ_КэшВидовПакетов.ВидПакетаID = ЗначенияСвойствОбъектов.Значение
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство.Наименование = ""DDPro_ВидПакета""
		|	ИЛИ ЗначенияСвойствОбъектов.Свойство.Наименование = ""DDPro_ВидПакетаСчет""
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Документ
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияСвойствОбъектов.Объект КАК Документ,
		|	ВТ_КэшДокументовПоВидамПакета.ВидПакета КАК ВидПакета,
		|	ВТ_КэшДокументовПоВидамПакета.КатегорияПакета КАК КатегорияПакета
		|ПОМЕСТИТЬ ВТ_ОтправленныеДокументы
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ЗначенияСвойствОбъектов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшДокументовПоВидамПакета КАК ВТ_КэшДокументовПоВидамПакета
		|	ПО ЗначенияСвойствОбъектов.Объект = ВТ_КэшДокументовПоВидамПакета.Документ
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство В(&СвойстваИдентификаторовДокументов)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшВидовПакетов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшВидовПакетовПоУмолчанию
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшКонтрагентов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшКонтрагентовПоКатегориям
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшНастроекОтправкиНепроведенных
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшНастроекВидовПакетов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшНастроекВидовПакетов_Приоритет1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшНастроекВидовПакетов_Приоритет2
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшВидовДокументов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшКонтрагентовПоТипуОснования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_КэшДокументовПоВидамПакета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_ТипОснования_Приоритет1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТ_ТипОснования_Приоритет2";
	
	ТекстЗапроса_УстановитьИмяРегистраСведений(Результат);
	ТекстЗапроса_УстановитьИмяТаблицыОрганизаций(Результат);
	ТекстЗапроса_УстановитьИмяТаблицыКонтрагентов(Результат);
	
	Возврат Результат;
	
КонецФункции


// Формирует временную таблицу ВТ_ОтправленныеДокументы с колонками
//  * Документ - ЛюбаяСсылка - учетный документ
//  * ВидПакета - СправочникСсылка.Диадок_ДополнительныеСправочники, Неопределено - ссылка на описание вида пакета (заполняется только для СХ-1)
//  * ВидПакетаID - Строка - идентификатор вида пакета
//  * КатегорияПакета - Строка - идентификатор категории пакета
//
// Параметры:
//  МенеджерВТ - МенеджерВременныхТаблиц - хранилище временных таблиц
//  ВидыПакетов - ТаблицаЗначений - используемые виды пакетов (см. Ядро.Списки_ТаблицаИспользуемыхВидовПакетов)
//
Процедура СписокНаОтправку_ПодготовитьОтправленныеДокументы(МенеджерВТ, ВидыПакетов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.УстановитьПараметр("ВидыПакетов", ВидыПакетов);
	
	ВТ_КэшВидовПакетов =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.ID КАК ВидПакетаID,
	|	Т.КатегорияПакета КАК КатегорияПакета
	|ПОМЕСТИТЬ ВТ_КэшВидовПакетов
	|ИЗ
	|	&ВидыПакетов КАК Т";
	
	ЧастиЗапроса = Новый Массив;
	ЧастиЗапроса.Добавить(ВТ_КэшВидовПакетов);
	
	Если ИспользоватьПодсистемуДиадока() Тогда
		
		ВТ_КэшВидовПакетовИзСправочника =
		"ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка КАК ВидПакета,
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение КАК ВидПакетаID,
		|	ВТ_КэшВидовПакетов.КатегорияПакета КАК КатегорияПакета
		|ПОМЕСТИТЬ ВТ_КэшВидовПакетовИзСправочника
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Диадок_ДополнительныеСправочникиДополнительныеРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КэшВидовПакетов КАК ВТ_КэшВидовПакетов
		|		ПО Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение = ВТ_КэшВидовПакетов.ВидПакетаID
		|ГДЕ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка.ИмяСправочника = ""ВидыПакетов""
		|	И Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ИмяРеквизита = ""ID""";
		
		ЧастиЗапроса.Добавить(ВТ_КэшВидовПакетовИзСправочника);
		ЧастиЗапроса.Добавить(СписокНаОтправку_ТекстЗапроса_ОтправленныеДокументы_Диадок());
		ЧастиЗапроса.Добавить("УНИЧТОЖИТЬ ВТ_КэшВидовПакетовИзСправочника");
		
	Иначе
		
		ВТ_ОтправленныеДокументы =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияСвойствОбъектов.Объект КАК Документ,
		|	ВТ_КэшВидовПакетов.ВидПакетаID КАК ВидПакета,
		|	ВТ_КэшВидовПакетов.КатегорияПакета КАК КатегорияПакета
		|ПОМЕСТИТЬ ВТ_КэшДокументовПоВидамПакета
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ЗначенияСвойствОбъектов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшВидовПакетов КАК ВТ_КэшВидовПакетов
		|	ПО ВТ_КэшВидовПакетов.ВидПакетаID = ЗначенияСвойствОбъектов.Значение
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство.Наименование = ""DDPro_ВидПакета""
		|	ИЛИ ЗначенияСвойствОбъектов.Свойство.Наименование = ""DDPro_ВидПакетаСчет""
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Документ
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияСвойствОбъектов.Объект КАК Документ,
		|	НЕОПРЕДЕЛЕНО КАК ВидПакета,
		|	ВТ_КэшДокументовПоВидамПакета.ВидПакета КАК ВидПакетаID,
		|	ВТ_КэшДокументовПоВидамПакета.КатегорияПакета КАК КатегорияПакета
		|ПОМЕСТИТЬ ВТ_ОтправленныеДокументы
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ЗначенияСвойствОбъектов
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшДокументовПоВидамПакета КАК ВТ_КэшДокументовПоВидамПакета
		|	ПО ЗначенияСвойствОбъектов.Объект = ВТ_КэшДокументовПоВидамПакета.Документ
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство В(&СвойстваИдентификаторовДокументов)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Документ";
		
		ТекстЗапроса_УстановитьИмяРегистраСведений(ВТ_ОтправленныеДокументы);
		
		ЧастиЗапроса.Добавить(ВТ_ОтправленныеДокументы);
		ЧастиЗапроса.Добавить("УНИЧТОЖИТЬ ВТ_КэшДокументовПоВидамПакета");
		
		Запросы_ЗаполнитьПараметрыСвойствИдентификаторовДокумента(Запрос);
		
	КонецЕсли;
	
	ЧастиЗапроса.Добавить("УНИЧТОЖИТЬ ВТ_КэшВидовПакетов");
	
	Запрос.Текст = СоединитьСтроку(ЧастиЗапроса, ТекстЗапроса_РазделительЗапросов());
	Запрос.ВыполнитьПакет();
	
КонецПроцедуры

// Формирует пустую временную таблицу ВТ_ОтправленныеДокументы с колонками
//  * Документ - ЛюбаяСсылка - учетный документ
//  * ВидПакета - СправочникСсылка.Диадок_ДополнительныеСправочники, Неопределено - ссылка на описание вида пакета (заполняется только для СХ-1)
//  * ВидПакетаID - Строка - идентификатор вида пакета
//  * КатегорияПакета - Строка - идентификатор категории пакета
//
// Параметры:
//  МенеджерВТ - МенеджерВременныхТаблиц - хранилище временных таблиц
//
Процедура СписокНаОтправку_ПодготовитьПустуюТаблицуОтправленныеДокументы(МенеджерВТ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 0
	|	НЕОПРЕДЕЛЕНО КАК Документ,
	|	НЕОПРЕДЕЛЕНО КАК ВидПакета,
	|	"""" КАК ВидПакетаID,
	|	"""" КАК КатегорияПакета
	|ПОМЕСТИТЬ ВТ_ОтправленныеДокументы";
	
	Запрос.ВыполнитьПакет();
	
КонецПроцедуры

//**********************************************
// СПИСКИ ДОКУМЕНТОВ: ПОДСИСТЕМА ДИАДОКА

Функция СписокДокументов_Подготовленные_Диадок(Параметры)
	
	Результат = Новый_СписокДокументов();
	
	ОрганизацииИзКонтекста = Организации_ОрганизацииЭДОИзКонтекста();
	
	Отбор = "
	|	(ПакетыДокументов.Метка = ""Подготовлен""
	|			ИЛИ ПакетыДокументов.Метка = ""Не отправлен"")
	|	И ПакетыДокументов.ДатаДокумента МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ПакетыДокументов.ВидПакета В(&ВидыПакетов)
	|	И ПакетыДокументов.ОрганизацияДиадок В (&ОрганизацииИзКонтекста)
	|	И &ОтборПоИдентификаторуПакета
	|	И ВЫБОР
	|			КОГДА &ВключитьОтборПоОрганизации
	|				ТОГДА &ПолеОтборПоОрганизации = &ОтборПоОрганизации
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ВключитьОтборПоКонтрагенту
	|				ТОГДА &ПолеОтборПоКонтрагенту = &ОтборПоКонтрагенту
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Если ИспользуютсяСвязиТолькоИзТабличнойЧастиСправочникаЮрФизЛиц() Тогда
		
		Отбор = СтрЗаменить(Отбор, "&ПолеОтборПоОрганизации", "Диадок_ЮрФизЛица_Организация.Значение");
		Отбор = СтрЗаменить(Отбор, "&ПолеОтборПоКонтрагенту", "Диадок_ЮрФизЛица_Контрагент.Значение");
		
	Иначе
		
		Отбор = СтрЗаменить(Отбор, "&ПолеОтборПоОрганизации", "Диадок_ЮрФизЛица_Организация.СвязанныйСправочник1");
		Отбор = СтрЗаменить(Отбор, "&ПолеОтборПоКонтрагенту", "Диадок_ЮрФизЛица_Контрагент.СвязанныйСправочник1");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ОтборПоПакету) Тогда
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "ПакетыДокументов.LetterId = &ИдентификаторПакета");		
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "Истина");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Пакеты_ТекстЗапросаДляЗаполненияКонтракта_Диадок(Отбор);
	
	ВидыПакетов			= ДопСправочники_СсылкиПоИдентификаторам_Диадок("ВидыПакетов", Параметры.МассивВыбранныхВидов);
	ИдентификаторПакета	= СокрЛП(СвойствоСтруктуры(Параметры.ОтборПоПакету, "ИдентификаторПакета"));
	
	Запрос.УстановитьПараметр("ВидыПакетов",				ВидыПакетов);
	Запрос.УстановитьПараметр("НачалоПериода",				Параметры.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",				Параметры.КонецПериода);
	Запрос.УстановитьПараметр("ОтборПоОрганизации",			Параметры.ОтборПоОрганизации);
	Запрос.УстановитьПараметр("ОтборПоКонтрагенту",			Параметры.ОтборПоКонтрагенту);
	Запрос.УстановитьПараметр("ВключитьОтборПоКонтрагенту",	Параметры.ВключитьОтборПоКонтрагенту);
	Запрос.УстановитьПараметр("ВключитьОтборПоОрганизации",	Параметры.ВключитьОтборПоОрганизации);
	Запрос.УстановитьПараметр("ОрганизацииИзКонтекста",		ОрганизацииИзКонтекста);
	Запрос.УстановитьПараметр("ИдентификаторПакета",		ИдентификаторПакета);
	
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		
		СтрокаСписка = Результат.Добавить();
		СписокДокументов_ЗаполнитьСтрокуСпискаПоВыборке_Диадок(СтрокаСписка, Выборка, Ложь);
		
		СтруктураДопРеквизитов = ДопРеквизиты_СписокРеквизитов(Выборка.ПакетЭДО);
		
		Для Счетчик = 1 По 5 Цикл
			
			ИмяДопРеквизита = "ДопРеквизит" + Строка(Счетчик);
			СтрокаСписка[ИмяДопРеквизита] = СвойствоСтруктуры(СтруктураДопРеквизитов, ИмяДопРеквизита);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДопСправочники_СсылкиПоИдентификаторам_Диадок(ИмяСправочника, Идентификаторы)
	
	Результат = Новый Массив;
	
	Для Каждого Идентификатор Из Идентификаторы Цикл
		
		Если ТипЗнч(Идентификатор) = Тип("Строка") Тогда
			ВидПакета = ДопСправочники_СсылкаПоИдентификатору_Диадок(ИмяСправочника, Идентификатор);
		Иначе
			ВидПакета = Идентификатор;
		КонецЕсли;
		
		Результат.Добавить(ВидПакета);
		
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_Отправленные_Диадок(Параметры)
	
	Результат = Новый_СписокДокументов();
	
	КонтрагентДляОтбора = Параметры.ОтборПоКонтрагенту;
	КонтрагентыСервиса = Справочники_СвязанныеКонтрагентыСервиса_Диадок(КонтрагентДляОтбора);
	
	ОрганизацияДляОтбора = Параметры.ОтборПоОрганизации;
	ОрганизацииСервиса = Справочники_СвязанныеОрганизацииСервиса_Диадок(ОрганизацияДляОтбора);
	
	ОрганизацииИзКонтекста = Организации_ОрганизацииЭДОИзКонтекста();
	
	Отбор = "
	|	ВЫБОР
	|			КОГДА &РежимОтбораПоПериоду = ""ПоДатеДокумента""
	|				ТОГДА Документы.ДатаДокумента МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИНАЧЕ Документы.ДатаЗагрузки МЕЖДУ &НачалоПериода И &КонецПериода
	|		КОНЕЦ
	|	И Документы.Направление В (&СписокНаправлений)
	|	И Документы.Статус <> ""Не отправлен""
	|	И НЕ Документы.Метка В (&ИсключаемыеМетки)
	|	И &ДополнительныйОтбор
	|	И &ОтборПоИдентификаторуПакета
	|	И Документы.ОрганизацияДиадок В (&ОрганизацииИзКонтекста)
	|	И ВЫБОР
	|			КОГДА &ЕстьОтборПоОрганизации
	|				ТОГДА Документы.ОрганизацияДиадок В(&ОрганизацииСервиса)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ЕстьОтборПоКонтрагенту
	|				ТОГДА Документы.КонтрагентДиадок В(&КонтрагентыСервиса)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоСтатусу <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Документы.Статус ПОДОБНО &ОтборПоСтатусу
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Если ЗначениеЗаполнено(Параметры.МассивВыбранныхВидов) Тогда
		Отбор = СтрЗаменить(Отбор, "&ДополнительныйОтбор", "Документы.ВидДокумента В(&МассивВыбранныхВидов)");
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ДополнительныйОтбор", "Истина");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ОтборПоПакету) Тогда
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "Документы.LetterId = &ИдентификаторПакета");		
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "Истина");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = Документы_ТекстЗапросаЗаполненияКонтракта(Отбор);
	
	ИсключаемыеМетки	= ИсключаемыеМетки_ОтправленныеДокументы(); 
	ИдентификаторПакета	= СокрЛП(СвойствоСтруктуры(Параметры.ОтборПоПакету, "ИдентификаторПакета"));
	
	Запрос.УстановитьПараметр("НачалоПериода",			Параметры.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",			Параметры.КонецПериода);
	Запрос.УстановитьПараметр("МассивВыбранныхВидов",	Параметры.МассивВыбранныхВидов);
	Запрос.УстановитьПараметр("ОтборПоСтатусу",			"%" + Параметры.ОтборПоСтатусу + "%");
	Запрос.УстановитьПараметр("РежимОтбораПоПериоду",	Параметры.РежимОтбораПоПериоду);
	Запрос.УстановитьПараметр("ОрганизацииИзКонтекста",	ОрганизацииИзКонтекста); 
	Запрос.УстановитьПараметр("ИсключаемыеМетки",		ИсключаемыеМетки);
	Запрос.УстановитьПараметр("ИдентификаторПакета",	ИдентификаторПакета);
	Запрос.УстановитьПараметр("ЕстьОтборПоКонтрагенту", ЗначениеЗаполнено(КонтрагентДляОтбора));
	Запрос.УстановитьПараметр("КонтрагентыСервиса", КонтрагентыСервиса);
	Запрос.УстановитьПараметр("ЕстьОтборПоОрганизации", ЗначениеЗаполнено(ОрганизацияДляОтбора));
	Запрос.УстановитьПараметр("ОрганизацииСервиса", ОрганизацииСервиса);
	
	СписокНаправлений = Новый Массив;
	СписокНаправлений.Добавить("Исходящее");

	Запрос.УстановитьПараметр("СписокНаправлений", СписокНаправлений);
	
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
				
		СтрокаСписка = Результат.Добавить();
		СписокДокументов_ЗаполнитьСтрокуСпискаПоВыборке_Диадок(СтрокаСписка, Выборка);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СписокДокументов_Полученные_Диадок(Параметры)
	
	Результат = Новый_СписокДокументов();
	
	КонтрагентДляОтбора = Параметры.ОтборПоКонтрагенту;
	КонтрагентыСервиса = Справочники_СвязанныеКонтрагентыСервиса_Диадок(КонтрагентДляОтбора);
	
	ОрганизацияДляОтбора = Параметры.ОтборПоОрганизации;
	ОрганизацииСервиса = Справочники_СвязанныеОрганизацииСервиса_Диадок(ОрганизацияДляОтбора);
	
	ОрганизацииИзКонтекста = Организации_ОрганизацииЭДОИзКонтекста();
	
	Отбор = "
	|	ВЫБОР
	|			КОГДА &РежимОтбораПоПериоду = ""ПоДатеДокумента""
	|				ТОГДА Документы.ДатаДокумента МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИНАЧЕ Документы.ДатаЗагрузки МЕЖДУ &НачалоПериода И &КонецПериода
	|		КОНЕЦ
	|	И &ДополнительныйОтбор
	|	И &ОтборПоИдентификаторуПакета
	|	И &ПоказыватьЗавершенные
	|	И Документы.Направление = ""Входящее""
	|	И Документы.ОрганизацияДиадок В (&ОрганизацииИзКонтекста)
	|	И ВЫБОР
	|			КОГДА &ЕстьОтборПоОрганизации
	|				ТОГДА Документы.ОрганизацияДиадок В(&ОрганизацииСервиса)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ЕстьОтборПоКонтрагенту
	|				ТОГДА Документы.КонтрагентДиадок В(&КонтрагентыСервиса)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоСтатусу <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Документы.Статус = &ОтборПоСтатусу
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	ОтборНаРезультат = "Истина";
	
	Если Параметры.ПоказыватьЗавершенные Тогда
		Отбор = СтрЗаменить(Отбор, "&ПоказыватьЗавершенные", "Истина");
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ПоказыватьЗавершенные",
		"	НЕ (Документы.АнализПроведен
		|		И Документы.ТребуемоеДействиеВ1С = """"
		|		И Документы.ТребуемоеДействиеВДД = """")");
		
		ОтборНаРезультат = "ЕСТЬNULL(РеквизитШаблон.Значение, Ложь) = Ложь";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.МассивВыбранныхВидов) Тогда
		Отбор = СтрЗаменить(Отбор, "&ДополнительныйОтбор", "Документы.ТипДокумента В (&МассивТиповДокументов)");		
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ДополнительныйОтбор", "Истина");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ОтборПоПакету) Тогда
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "Документы.LetterId = &ИдентификаторПакета");		
	Иначе
		Отбор = СтрЗаменить(Отбор, "&ОтборПоИдентификаторуПакета", "Истина");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = Документы_ТекстЗапросаЗаполненияКонтракта(Отбор);
		
	ИдентификаторПакета = СокрЛП(СвойствоСтруктуры(Параметры.ОтборПоПакету, "ИдентификаторПакета"));
	
	Запрос.УстановитьПараметр("НачалоПериода",			Параметры.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",			Параметры.КонецПериода);
	Запрос.УстановитьПараметр("ОтборПоСтатусу",			Параметры.ОтборПоСтатусу);
	Запрос.УстановитьПараметр("РежимОтбораПоПериоду",	Параметры.РежимОтбораПоПериоду);
	Запрос.УстановитьПараметр("ОрганизацииИзКонтекста",	ОрганизацииИзКонтекста);
	Запрос.УстановитьПараметр("МассивТиповДокументов",	МассивВидовГруппировок_В_МассивВидовДокументов(Параметры.МассивВыбранныхВидов));
	Запрос.УстановитьПараметр("ИдентификаторПакета",	ИдентификаторПакета);
	Запрос.УстановитьПараметр("ЕстьОтборПоКонтрагенту", ЗначениеЗаполнено(КонтрагентДляОтбора));
	Запрос.УстановитьПараметр("КонтрагентыСервиса", КонтрагентыСервиса);
	Запрос.УстановитьПараметр("ЕстьОтборПоОрганизации", ЗначениеЗаполнено(ОрганизацияДляОтбора));
	Запрос.УстановитьПараметр("ОрганизацииСервиса", ОрганизацииСервиса);
	
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		
		СтрокаСписка = Результат.Добавить();
		СписокДокументов_ЗаполнитьСтрокуСпискаПоВыборке_Диадок(СтрокаСписка, Выборка);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

