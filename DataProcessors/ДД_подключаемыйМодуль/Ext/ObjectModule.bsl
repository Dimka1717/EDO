Процедура Заполнить_InvoiceCorrectionTable(Контент, Документ1С)

	// Документация: http://1c-docs.diadoc.ru/ru/latest/InvoiceCorrectionTable.html
	
	ТипСтроки = Контент.Свойства().Получить("Items").Тип.Имя;
	
	Для Каждого СтрокаТовары Из Документ1С.Товары Цикл
		
		СтрокаДо = 	Документ1С.Товары.Найти(СтрокаТовары.Номенклатура, "Номенклатура");

		НовЭлемент = Контент.Items.Добавить(НовыйКонтент(ТипСтроки));
		Заполнить_ExtendedInvoiceCorrectionItem(НовЭлемент, СтрокаТовары, СтрокаДо);
	
	КонецЦикла;
	
	//Для Каждого СтрокаТовары Из Документ1С.Услуги Цикл
	//	
	//	СтрокаДо = 	Документ1С.Услуги.Найти(СтрокаТовары.Номенклатура,"Номенклатура");

	//	НовЭлемент = Контент.Items.Добавить(НовыйКонтент(ТипСтроки));
	//	Заполнить_ExtendedInvoiceCorrectionItem(НовЭлемент, СтрокаТовары, СтрокаДо);
	//
	//КонецЦикла;

	//Если Расхождения.Итог("СуммаСНДС") > 0 Тогда
	//	Заполнить_InvoiceTotalsDiff				(Контент.TotalsInc, Расхождения);
	//Иначе	
	//	Заполнить_InvoiceTotalsDiff				(Контент.TotalsDec, Расхождения);
	//КонецЕсли;
	
	ИтогПлюс = 0;
	ИтогСНДСПлюс = 0;
	ИтогНДСПлюс = 0;
	ИтогМинус = 0;
	ИтогСНДСМинус = 0;
	ИтогНДСМинус = 0;	
	
	Счетчик = Контент.Items.Количество() - 1;
	
	Пока Счетчик >= 0 Цикл
		
		Если ЗначениеЗаполнено(Контент.Items[Счетчик].AmountsInc.Total) Тогда
			ИтогСНДСПлюс 	= ИтогСНДСПлюс + Контент.Items[Счетчик].AmountsInc.Total;
			ИтогПлюс 		= ИтогПлюс + Контент.Items[Счетчик].AmountsInc.TotalWithVatExcluded;
			ИтогНДСПлюс 	= ИтогНДСПлюс + Контент.Items[Счетчик].AmountsInc.Vat;			
		ИначеЕсли ЗначениеЗаполнено(Контент.Items[Счетчик].AmountsDec.Total) Тогда
			ИтогСНДСМинус 	= ИтогСНДСМинус + Контент.Items[Счетчик].AmountsDec.Total;
			ИтогМинус 		= ИтогМинус + Контент.Items[Счетчик].AmountsDec.TotalWithVatExcluded;
			ИтогНДСМинус 	= ИтогНДСМинус + Контент.Items[Счетчик].AmountsDec.Vat;
		Иначе
			Контент.Items.Удалить(Счетчик);
		КонецЕсли;	
		
		Счетчик = Счетчик - 1;
		
	КонецЦикла;

	Заполнить_InvoiceTotalsDiff				(Контент.TotalsInc, ИтогПлюс, ИтогСНДСПлюс, ИтогНДСПлюс);	
	Заполнить_InvoiceTotalsDiff				(Контент.TotalsDec, ИтогМинус, ИтогСНДСМинус, ИтогНДСМинус);

КонецПроцедуры

Процедура Заполнить_ExtendedInvoiceCorrectionItem(Контент, СтрокаТовары, СтрокаДо)

	// Документация: http://1c-docs.diadoc.ru/ru/latest/ExtendedInvoiceCorrectionItem.html
	
	Если ЗначениеЗаполнено(СтрокаТовары.Номенклатура.НаименованиеПолное) Тогда
		УстановитьЗначениеXDTO(Контент, "Product",					СтрокаТовары.Номенклатура.НаименованиеПолное);		
	Иначе
		УстановитьЗначениеXDTO(Контент, "Product",					СтрокаТовары.Номенклатура.Наименование);
	КонецЕсли;
	
	УстановитьЗначениеXDTO(Контент, "ItemAccountDebit",			Неопределено);
	УстановитьЗначениеXDTO(Контент, "ItemAccountCredit",		Неопределено);

	Заполнить_InvoiceItemFields				(Контент.OriginalValues, СтрокаТовары,СтрокаДо,"оригинальные");
	Заполнить_InvoiceItemFields				(Контент.CorrectedValues, СтрокаТовары,СтрокаДо,"скорректированные");
	
	Если СтрокаТовары.СуммаДоИзменения > СтрокаТовары.Сумма Тогда
		Заполнить_AmountsDiff					(Контент.AmountsDec, СтрокаТовары);	
	Иначе
		Заполнить_AmountsDiff					(Контент.AmountsInc, СтрокаТовары);	
	КонецЕсли;


КонецПроцедуры

Процедура Заполнить_InvoiceItemFields(Контент,СтрокаТовары,СтрокаДо,ТипКонтента)
	// Документация: http://1c-docs.diadoc.ru/ru/latest/InvoiceItemFields.html
	
	Попытка 
		Попытка
			ЕдиницаИзмерения = СтрокаДо.Номенклатура.БазоваяЕдиницаИзмерения;
		Исключение
			ЕдиницаИзмерения = СтрокаДо.Номенклатура.Номенклатура.БазоваяЕдиницаИзмерения;
		КонецПопытки;
	Исключение	
		ЕдиницаИзмерения = СтрокаДо.ЕдиницаИзмерения;
	КонецПопытки;
	
	Если ТипКонтента = "оригинальные" Тогда
				
		УстановитьЗначениеXDTO(Контент, "UnitCode",					ЕдиницаИзмерения.Код);
		
		УстановитьЗначениеXDTO(Контент, "UnitName",					ЕдиницаИзмерения.Наименование);
		
		УстановитьЗначениеXDTO(Контент, "Quantity",					СтрокаДо.КоличествоДоИзменения);
		УстановитьЗначениеXDTO(Контент, "TaxRate",					привестиСтавкуНДС(СтрокаДо.СтавкаНДС));
		УстановитьЗначениеXDTO(Контент, "Excise",					Неопределено);
		УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		СтрокаДо.СуммаДоИзменения - СтрокаДо.СуммаНДСДоИзменения);
		УстановитьЗначениеXDTO(Контент, "Vat",						СтрокаДо.СуммаНДСДоИзменения);
		УстановитьЗначениеXDTO(Контент, "Total",					СтрокаДо.СуммаДоИзменения);   
		//УстановитьЗначениеXDTO(Контент, "Price",					СтрокаДо.Цена);		
		УстановитьЗначениеXDTO(Контент, "Price",					Окр(Контент.TotalWithVatExcluded / Контент.Quantity, 2));
	
	Иначе
	
		УстановитьЗначениеXDTO(Контент, "UnitCode",					ЕдиницаИзмерения.Код);
		
		УстановитьЗначениеXDTO(Контент, "UnitName",					ЕдиницаИзмерения.Наименование);
		
		УстановитьЗначениеXDTO(Контент, "Quantity",					СтрокаТовары.Количество);
		УстановитьЗначениеXDTO(Контент, "TaxRate",					привестиСтавкуНДС(СтрокаДо.СтавкаНДС));
		УстановитьЗначениеXDTO(Контент, "Excise",					Неопределено);
		УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		СтрокаДо.Сумма - СтрокаДо.СуммаНДС);
		УстановитьЗначениеXDTO(Контент, "Vat",						СтрокаДо.СуммаНДС);
		УстановитьЗначениеXDTO(Контент, "Total",					СтрокаДо.Сумма);	
		Если   Контент.Quantity = 0 Тогда
		УстановитьЗначениеXDTO(Контент, "Price",					0);
		Иначе
		//УстановитьЗначениеXDTO(Контент, "Price",					СтрокаДо.Цена);		
		УстановитьЗначениеXDTO(Контент, "Price",					Окр(Контент.TotalWithVatExcluded / Контент.Quantity, 2));
		КонецЕсли;		
		
	КонецЕсли;

КонецПроцедуры

Процедура Заполнить_InvoiceTotalsDiff(Контент, ИтогБезНДС, ИтогСНДС, ИтогНДС)

	// Документация: http://1c-docs.diadoc.ru/ru/latest/InvoiceTotalsDiff.html
	Если ИтогБезНДС <> 0 Тогда 
		УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		ИтогБезНДС);
	Иначе
		УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		НЕОПРЕДЕЛЕНО);
	КонецЕсли;
	
	Если ИтогБезНДС <> 0 Тогда 
		УстановитьЗначениеXDTO(Контент, "Total",		ИтогСНДС);
	Иначе
		УстановитьЗначениеXDTO(Контент, "Total",		НЕОПРЕДЕЛЕНО);
	КонецЕсли;
	
	Если ИтогНДС <> 0 Тогда 
		УстановитьЗначениеXDTO(Контент, "Vat",		ИтогНДС);
	Иначе
		УстановитьЗначениеXDTO(Контент, "Vat",		НЕОПРЕДЕЛЕНО);
	КонецЕсли;

КонецПроцедуры

Процедура Заполнить_AmountsDiff(Контент,СтрокаТовары)

	// Документация: http://1c-docs.diadoc.ru/ru/latest/AmountsDiff.html
	
	Если СтрокаТовары.СуммаДоИзменения > СтрокаТовары.Сумма Тогда
		СуммаБезНДС = (СтрокаТовары.СуммаДоИзменения - СтрокаТовары.СуммаНДСДоИзменения) - (СтрокаТовары.Сумма - СтрокаТовары.СуммаНДС) ;
		СуммаНДС = СтрокаТовары.СуммаНДСДоИзменения - СтрокаТовары.СуммаНДС;
		СуммаСНДС = СтрокаТовары.СуммаДоИзменения - СтрокаТовары.Сумма;
	Иначе
		СуммаБезНДС =  (СтрокаТовары.Сумма - СтрокаТовары.СуммаНДС) - (СтрокаТовары.СуммаДоИзменения - СтрокаТовары.СуммаНДСДоИзменения) ;
		СуммаНДС =  СтрокаТовары.СуммаНДС - СтрокаТовары.СуммаНДСДоИзменения;
		СуммаСНДС =  СтрокаТовары.Сумма - СтрокаТовары.СуммаДоИзменения;
	КонецЕсли;
		
		
	УстановитьЗначениеXDTO(Контент, "Excise",					Неопределено);
	УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		СуммаБезНДС);
	УстановитьЗначениеXDTO(Контент, "Vat",						СуммаНДС);
	УстановитьЗначениеXDTO(Контент, "Total",					СуммаСНДС);
	
КонецПроцедуры

//Конец Сбора документа


