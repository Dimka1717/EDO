Функция ЭДО_ВерсияAPIПодключаемогоМодуля() Экспорт
	
	Возврат 3; // Основной модуль проверяет указанную тут версию, в целях контроля совместимости с ПМ.
	
КонецФункции

Процедура ПриглашениеОтладки()
	
	// Может пригодиться при отладке в режиме управляемых форм, когда точки остановки в открытом модуле не срабатывают.
	// Достаточно вставить вызов данной процедуры в нужном месте и включить остановку по ошибке.
	
	Попытка
		ВызватьИсключение "catch me if you can";
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция ТиповойМодульДиадока()
		
	РежимОтладки = Ложь;
	//РежимОтладки = Истина; // Для отладки стандартного модуля интеграции УФ, необходимо выгрузить его в КаталогМодуля
	
	Если ТиповойМодульДиадока = Неопределено Тогда
		
		ДвоичныеДанные = ОсновнойМодуль.ЭДО_Служебные_ПолучитьМакет("ТиповойМодульДиадок" + ?(РежимУправляемыхФорм, "УФ", "") + "_epf");
		
		Если РежимОтладки Тогда
			
			КаталогМодуля  = "C:\WORK\Розетка\ПМ\temp\";
			
			ИмяФайла = КаталогМодуля + "ТиповойМодульДиадок" + ?(РежимУправляемыхФорм, "УФ", "") + ".epf";
			
			ДвоичныеДанные.Записать(ИмяФайла);
			
			ТиповойМодульДиадока = ОсновнойМодуль.ИнициализацияТиповогоМодуля(ИмяФайла, РежимУправляемыхФорм, РежимОтладки, КаталогМодуля);
			
		Иначе
			
			ТиповойМодульДиадока = ОсновнойМодуль.ИнициализацияТиповогоМодуля(ДвоичныеДанные, РежимУправляемыхФорм);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТиповойМодульДиадока;
	
КонецФункции

Процедура ЗаполнитьПодпись(КонтентПодписи, ФИО, Должность="")
	
	Если ТипЗнч(ФИО) = Тип("Структура") Тогда
		
		КонтентПодписи.FirstName	= ФИО.Имя;
		КонтентПодписи.Surname		= ФИО.Фамилия;
		КонтентПодписи.Patronymic	= ФИО.Отчество;
		
	ИначеЕсли ТипЗнч(ФИО) = Тип("Массив") Тогда
		
		КонтентПодписи.FirstName	= ФИО[0];
		КонтентПодписи.Surname		= ФИО[1];
		КонтентПодписи.Patronymic	= ФИО[2];
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Должность) Тогда
		КонтентПодписи.JobTitle	= Должность;
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьДляНакладнойНаличиеДублей(ДокументДД, Документ1С, Результат)
		
	// Ищем ТОРГ-12 или УПД, относящийся к другому (не к текущему) пакету, и находящийся в статусе "Требуется подпись" или "Подписан".
	// Еще искомый документ должен быть уже проверен и признан "хорошим" (возможно, его еще не подписали, но уже проверили)
	// Если такой есть, то по текущему документу будем отказывать в подписи, т.к. это дубль
	
	ТипыДокументов = Новый Массив;
	
	ТипыДокументов.Добавить("XmlTorg12");
	ТипыДокументов.Добавить("UniversalTransferDocument");
	
	Статусы  = Новый Массив;
	Статусы.Добавить("Подписан");
	Статусы.Добавить("Требуется подпись");
	
	Если ОсновнойМодуль.ЭДО_Использовать1СЭДО() Тогда 
		//TODO добавить проверку дублей для 1С-ЭДО
	Иначе		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Диадок_Документы.Ссылка,
		|	Диадок_Документы.АнализПроведен КАК АнализПроведен,
		|	Диадок_Документы.ТекстОшибки КАК ОшибкиПроверкиТекст
		|ИЗ
		|	Справочник.Диадок_Документы КАК Диадок_Документы
		|ГДЕ
		|	Диадок_Документы.Ссылка <> &ТекущийДокументДД
		|	И Диадок_Документы.LetterId <> &LetterId
		|	И Диадок_Документы.Документ = &Документ1С
		|	И (Диадок_Документы.Направление = ""Inbound"" или Диадок_Документы.Направление = ""Входящее"" )  //переходный период перед релизом 1.0.0
		|	И Диадок_Документы.ТипДокумента В(&ТипДокумента)
		|	И Диадок_Документы.АнализПроведен
		|	И Диадок_Документы.Статус В(&Статусы)
		|	И Выразить(Диадок_Документы.ТекстОшибки как строка(1)) = """"     //  ТекстОшибки сейчас неограниченная строка. Выразить работает в сторону уменьшения длины, но не увеличения
		//|	И Диадок_Документы.ДатаЗагрузки <= &ДатаЗагрузки
		|
		|УПОРЯДОЧИТЬ ПО
		|	Диадок_Документы.ДатаЗагрузки";
		
		Запрос.УстановитьПараметр("ТекущийДокументДД",	ДокументДД);
		Запрос.УстановитьПараметр("Документ1С",			Документ1С);
		Запрос.УстановитьПараметр("ТипДокумента",		ТипыДокументов);
		Запрос.УстановитьПараметр("Статусы",			Статусы);		
		Запрос.УстановитьПараметр("LetterId",			ДокументДД.LetterId);
		Запрос.УстановитьПараметр("ДатаЗагрузки",		ДокументДД.ДатаЗагрузки);
		
		Выборка = Запрос.Выполнить().Выгрузить();
		
		Если Выборка.Количество()>0 И ЗначениеЗаполнено(Выборка[0].Ссылка) Тогда
			Док = Выборка[0].Ссылка;
			Результат.Добавить("ДУБЛИКАТ: накладная уже была учтена в электронном виде (дата " +формат(Док.ДатаДокумента, "ДФ=dd.MM.yyyy")
			+", номер "+Док.НомерДокумента+", загружен из Диадок "+Док.ДатаЗагрузки +")");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьКонтентОтвета(ДокументДД, Документ1С, ДействиеВДД, ТекстВсехОшибок)
	
	Content = ОсновнойМодуль.ЭДО_ПолучитьПустойКонтентОтветаДляДокумента(ДокументДД, ДействиеВДД);
	
	Если нрег(Content.Тип().Имя) = "torg12buyercontent" Тогда
		
		Content.ShipmentReceiptDate = Документ1С.Дата;
		
		ДанныеПодписанта = ПолучитьРеквизитыПодписантаПоОрганизации1С(Документ1С.Организация, Документ1С.Дата);
		
		ЗаполнитьПодпись(Content.Receiver, ДанныеПодписанта, ДанныеПодписанта.Должность); // лицо, получившее груз
		ЗаполнитьПодпись(Content.Accepter, ДанныеПодписанта, ДанныеПодписанта.Должность); // лицо, принявшее груз

	ИначеЕсли нрег(Content.Тип().Имя) = "utdbuyercontent" Тогда
		
		Content.AcceptanceDate		= Документ1С.Дата;
		Content.Creator				= "" + Документ1С.Организация.НаименованиеПолное + ", ИНН " + Документ1С.Организация.ИНН + ", КПП "+Документ1С.Организация.КПП;
		Content.CreatorBase			= "";
		Content.OperationCode		= "";
		Content.OperationContent	= "Товары и услуги получены, претензий нет";
		
		ДанныеПодписанта = ПолучитьРеквизитыПодписантаПоОрганизации1С(Документ1С.Организация, Документ1С.Дата);
		
		ЗаполнитьПодпись(Content.Employee, ДанныеПодписанта); // работник организации покупателя
				
		Content.Employee.EmployeePosition	= ДанныеПодписанта.Должность;
		Content.Employee.EmployeeBase		= "Должностные обязанности";
		
	ИначеЕсли нрег(Content.Тип().Имя) = "utd820buyercontent" Тогда
		
		Content.AcceptanceDate		= Документ1С.Дата;
		Content.DocumentCreator		= "" + Документ1С.Организация.НаименованиеПолное + ", ИНН " + Документ1С.Организация.ИНН + ", КПП "+Документ1С.Организация.КПП;
		Content.DocumentCreatorBase	= "";
		Content.OperationCode		= "";
		Content.OperationContent	= "Товары и услуги получены, претензий нет";
		
		ДанныеПодписанта = ПолучитьРеквизитыПодписантаПоОрганизации1С(Документ1С.Организация, Документ1С.Дата);
		
		ЗаполнитьПодпись(Content.Employee, ДанныеПодписанта); // работник организации покупателя
				
		Content.Employee.EmployeePosition	= ДанныеПодписанта.Должность;
		Content.Employee.EmployeeBase		= "Должностные обязанности";	
		
	ИначеЕсли нрег(Content.Тип().Имя) = "acceptancecertificatebuyercontent" Тогда
		
		ДанныеПодписанта = ПолучитьРеквизитыПодписантаПоОрганизации1С(Документ1С.Организация, Документ1С.Дата);
		
		ЗаполнитьПодпись(Content.Official, ДанныеПодписанта, ДанныеПодписанта.Должность); // лицо, подписывающее со стороны заказчика
		
	ИначеЕсли нрег(Content.Тип().Имя) = "correctionrequestcontent"	// запрос на уточнение по СФ
		Или нрег(Content.Тип().Имя) = "formalizedrejectioncontent"  // отказ по формализованному
		Или нрег(Content.Тип().Имя) = "rejectioncontent" Тогда		// отказ по неформализованному
				
		Content.Comment = ТекстВсехОшибок;
		
	КонецЕсли;	
	
	Возврат Content;
	
КонецФункции

Функция ДобавитьОбъединениеВТекстЗапроса(ТекстЗапроса)
	
	Возврат ?(ТекстЗапроса = "",
					"",
					ТекстЗапроса + "
					|
					|ОБЪЕДИНИТЬ ВСЕ 
					|
					|");

КонецФункции

Функция ПолучитьТекстЗапросаВременныхТаблицДляСпискаПакетовНаОтправку()
	
	Если ОсновнойМодуль.ИспользоватьПодсистемуДиадока() Тогда
		
		Результат = 
		"ВЫБРАТЬ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка КАК ВидПакета,
		|	ВЫРАЗИТЬ(Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Значение КАК БУЛЕВО) КАК УПД
		|ПОМЕСТИТЬ ВТ_КэшВидовПакетов
		|ИЗ
		|	Справочник.Диадок_ДополнительныеСправочники.ДополнительныеРеквизиты КАК Диадок_ДополнительныеСправочникиДополнительныеРеквизиты
		|ГДЕ
		|	Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.Ссылка.ИмяСправочника = ""ВидыПакетов""
		|	И Диадок_ДополнительныеСправочникиДополнительныеРеквизиты.ИмяРеквизита = ""УПД""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Диадок_НастройкиКонтрагентов.Организация.СвязанныйСправочник1 КАК Организация1С,
		|	Диадок_НастройкиКонтрагентов.Контрагент.СвязанныйСправочник1 КАК Контрагент1С,
		|	Диадок_НастройкиКонтрагентов.Организация КАК Организация,
		|	Диадок_НастройкиКонтрагентов.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ВТ_КэшКонтрагентов
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|ГДЕ
		|	Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Статус""
		|	И Диадок_НастройкиКонтрагентов.Значение = ""IsMyCounteragent""
		|	И Диадок_НастройкиКонтрагентов.Организация.СвязанныйСправочник1 <> НЕОПРЕДЕЛЕНО
		|	И Диадок_НастройкиКонтрагентов.Контрагент.СвязанныйСправочник1 <> НЕОПРЕДЕЛЕНО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Диадок_НастройкиКонтрагентов.Организация.СвязанныйСправочник1 КАК Организация1С,
		|	Диадок_НастройкиКонтрагентов.Контрагент.СвязанныйСправочник1 КАК Контрагент1С,
		|	Диадок_НастройкиКонтрагентов.Организация КАК Организация,
		|	Диадок_НастройкиКонтрагентов.Контрагент КАК Контрагент,
		|	Диадок_НастройкиКонтрагентов.Значение КАК ОсновнойПакет
		|ПОМЕСТИТЬ ВТ_КэшНастроекВидовУПД
		|ИЗ
		|	РегистрСведений.Диадок_НастройкиКонтрагентов КАК Диадок_НастройкиКонтрагентов
		|ГДЕ
		|	Диадок_НастройкиКонтрагентов.ИмяСвойства = ""Основной пакет""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшНастроекВидовУПД.Организация1С КАК Организация1С,
		|	ВТ_КэшНастроекВидовУПД.Контрагент1С КАК Контрагент1С,
		|	ВТ_КэшНастроекВидовУПД.ОсновнойПакет КАК ОсновнойПакет
		|ПОМЕСТИТЬ ВТ_КэшНастроекВидовУПД_Приоритет1
		|ИЗ
		|	ВТ_КэшНастроекВидовУПД КАК ВТ_КэшНастроекВидовУПД
		|ГДЕ
		|	ВТ_КэшНастроекВидовУПД.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|	И ВТ_КэшНастроекВидовУПД.Контрагент <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшНастроекВидовУПД.Контрагент1С КАК Контрагент1С,
		|	ВТ_КэшНастроекВидовУПД.ОсновнойПакет КАК ОсновнойПакет
		|ПОМЕСТИТЬ ВТ_КэшНастроекВидовУПД_Приоритет2
		|ИЗ
		|	ВТ_КэшНастроекВидовУПД КАК ВТ_КэшНастроекВидовУПД
		|ГДЕ
		|	ВТ_КэшНастроекВидовУПД.Организация = ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|	И ВТ_КэшНастроекВидовУПД.Контрагент <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшНастроекВидовУПД.Организация1С КАК Организация1С,
		|	ВТ_КэшНастроекВидовУПД.ОсновнойПакет КАК ОсновнойПакет
		|ПОМЕСТИТЬ ВТ_КэшНастроекВидовУПД_Приоритет3
		|ИЗ
		|	ВТ_КэшНастроекВидовУПД КАК ВТ_КэшНастроекВидовУПД
		|ГДЕ
		|	ВТ_КэшНастроекВидовУПД.Организация <> ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|	И ВТ_КэшНастроекВидовУПД.Контрагент = ЗНАЧЕНИЕ(Справочник.Диадок_ЮрФизЛица.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшКонтрагентов.Организация1С КАК Организация1С,
		|	ВТ_КэшКонтрагентов.Контрагент1С КАК Контрагент1С,
		|	ВТ_КэшКонтрагентов.Организация КАК Организация,
		|	ВТ_КэшКонтрагентов.Контрагент КАК Контрагент,
		|	ЕСТЬNULL(ЕСТЬNULL(ВТ_КэшНастроекВидовУПД_Приоритет1.ОсновнойПакет, ВТ_КэшНастроекВидовУПД_Приоритет2.ОсновнойПакет), ВТ_КэшНастроекВидовУПД_Приоритет3.ОсновнойПакет) КАК ОсновнойПакет
		|ПОМЕСТИТЬ ВТ_КэшКонтрагентовПоВидамУПД_Предварительно
		|ИЗ
		|	ВТ_КэшКонтрагентов КАК ВТ_КэшКонтрагентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекВидовУПД_Приоритет1 КАК ВТ_КэшНастроекВидовУПД_Приоритет1
		|		ПО ВТ_КэшКонтрагентов.Организация1С = ВТ_КэшНастроекВидовУПД_Приоритет1.Организация1С
		|			И ВТ_КэшКонтрагентов.Контрагент1С = ВТ_КэшНастроекВидовУПД_Приоритет1.Контрагент1С
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекВидовУПД_Приоритет2 КАК ВТ_КэшНастроекВидовУПД_Приоритет2
		|		ПО ВТ_КэшКонтрагентов.Контрагент1С = ВТ_КэшНастроекВидовУПД_Приоритет2.Контрагент1С
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшНастроекВидовУПД_Приоритет3 КАК ВТ_КэшНастроекВидовУПД_Приоритет3
		|		ПО ВТ_КэшКонтрагентов.Организация1С = ВТ_КэшНастроекВидовУПД_Приоритет3.Организация1С
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КэшКонтрагентов.Организация1С КАК Организация1С,
		|	ВТ_КэшКонтрагентов.Контрагент1С КАК Контрагент1С,
		|	ВТ_КэшКонтрагентов.Организация КАК Организация,
		|	ВТ_КэшКонтрагентов.Контрагент КАК Контрагент,
		|	ВТ_КэшКонтрагентов.ОсновнойПакет КАК ОсновнойПакет,
		|	ЕСТЬNULL(ВТ_КэшВидовПакетаУПД.УПД, ЛОЖЬ) КАК ИспользоватьУПД
		|ПОМЕСТИТЬ ВТ_КэшКонтрагентовПоВидамУПД
		|ИЗ
		|	ВТ_КэшКонтрагентовПоВидамУПД_Предварительно КАК ВТ_КэшКонтрагентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КэшВидовПакетов КАК ВТ_КэшВидовПакетаУПД
		|		ПО ВТ_КэшКонтрагентов.ОсновнойПакет = ВТ_КэшВидовПакетаУПД.ВидПакета
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Организация1С,
		|	Контрагент1С";
		
	Иначе
		
		Результат = 
		"ВЫБРАТЬ
		|	ЗначенияСвойствОбъектов.Объект КАК Документ,
		|	ЗначенияСвойствОбъектов.Объект КАК Ссылка,
		|	ЗначенияСвойствОбъектов.Значение КАК ВидПакета
		|ПОМЕСТИТЬ ВТ_ОтправленныеДокументы
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство = &Свойство_ВидПакета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаВидовПакетов.ID,
		|	ТаблицаВидовПакетов.УПД
		|ПОМЕСТИТЬ ВТ_ВидыПакетов
		|ИЗ
		|	&ТаблицаВидовПакетов КАК ТаблицаВидовПакетов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияСвойствОбъектов.Объект КАК Организация1С,
		|	ЗначенияСвойствОбъектов.Значение КАК ОсновнойПакет,
		|	ВТ_ВидыПакетов.УПД
		|ПОМЕСТИТЬ ВТ_ОсновнойПакет
		|ИЗ
		|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВидыПакетов КАК ВТ_ВидыПакетов
		|		ПО ЗначенияСвойствОбъектов.Значение = ВТ_ВидыПакетов.ID
		|			И (ЗначенияСвойствОбъектов.Свойство = &Свойство_ОсновнойПакет)
		|ГДЕ
		|	ЗначенияСвойствОбъектов.Свойство = &Свойство_ОсновнойПакет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаКонтрагентов.Организация1С,
		|	ТаблицаКонтрагентов.Контрагент1С
		|ПОМЕСТИТЬ ВТ_Контрагенты
		|ИЗ
		|	&ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Контрагенты.Организация1С,
		|	ВТ_Контрагенты.Контрагент1С,
		|	ВТ_ОсновнойПакет.ОсновнойПакет,
		|	ЕСТЬNULL(ВТ_ОсновнойПакет.УПД, ЛОЖЬ) КАК ИспользоватьУПД
		|ПОМЕСТИТЬ ВТ_КэшКонтрагентовПоВидамУПД
		|ИЗ
		|	ВТ_Контрагенты КАК ВТ_Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОсновнойПакет КАК ВТ_ОсновнойПакет
		|		ПО ВТ_Контрагенты.Организация1С = ВТ_ОсновнойПакет.Организация1С";
		
	КонецЕсли;
	
	Возврат Результат;
			
КонецФункции

Функция СформироватьВнешнююПечатнуюФорму(Документ,	ВнешняяПечатнаяФорма, ИдентификаторКомандыПечатнойФормы=Неопределено, ДопПараметры=Неопределено)
	
	ИсточникМакета = Новый Структура("СсылкаНаВнешнююОбработку, НомерСтроки", ВнешняяПечатнаяФорма, 1);	
	ТабличныйДокумент = УниверсальныеМеханизмы.НапечататьВнешнююФорму(Документ, ИсточникМакета);
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла();	
	ИмяФайла = ВнешняяПечатнаяФорма.Наименование + " № " + Документ.Номер + " от " + Формат(Документ.Дата,"ДФ=dd.MM.yyyy") + ".pdf";
	
	ТабличныйДокумент.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.PDF);
			
	Возврат Новый Структура("ИмяВременногоФайла, ИмяФайла", ИмяВременногоФайла, ИмяФайла);
	
КонецФункции

Функция УчетнаяЗапись()
	
	// Логин и пароль служебной учетки для выполнения регламентных действий
	Результат = Новый Структура;
	Результат.Вставить("Логин",		ОсновнойМодуль.ЭДО_Модуль_ОбщиеНастройки().СлужебнаяУчетнаяЗаписьЛогин);
	Результат.Вставить("Пароль",	ОсновнойМодуль.ЭДО_Модуль_ОбщиеНастройки().СлужебнаяУчетнаяЗаписьПароль);
	
	Возврат Результат;
	
КонецФункции

