//{ ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ РАБОТЫ С ТЕКУЩЕЙ КОНФИГУРАЦИЕЙ БАЗЫ

Процедура ДобавитьНоменклатуруДляСопоставления(Результат, Контрагент, Наименование, Код = "", Артикул = "")
	
	Если НЕ Результат.Свойство("ТаблицаНоменклатурыДляСопоставления") Тогда
		
		Результат.Вставить("ТаблицаНоменклатурыДляСопоставления", Новый ТаблицаЗначений);
		
		МетаданныеРегистра = Метаданные.РегистрыСведений.НоменклатураКонтрагентов;		
		
		// Ограничения типам реквизитов для текущей конфигурации
		Результат.ТаблицаНоменклатурыДляСопоставления.Колонки.Добавить("Контрагент"  , МетаданныеРегистра.Измерения.Контрагент.Тип);
		Результат.ТаблицаНоменклатурыДляСопоставления.Колонки.Добавить("Наименование", МетаданныеРегистра.Ресурсы.НаименованиеНоменклатурыКонтрагента.Тип);
		Результат.ТаблицаНоменклатурыДляСопоставления.Колонки.Добавить("Код"		 , МетаданныеРегистра.Ресурсы.Идентификатор.Тип,, 10);
		Результат.ТаблицаНоменклатурыДляСопоставления.Колонки.Добавить("Артикул"	 , МетаданныеРегистра.Ресурсы.АртикулНоменклатурыКонтрагента.Тип,, 10);
		Результат.ТаблицаНоменклатурыДляСопоставления.Колонки.Добавить("Номенклатура", МетаданныеРегистра.Измерения.Номенклатура.Тип);
		
	КонецЕсли;
	
	НоваяСтрока = Результат.ТаблицаНоменклатурыДляСопоставления.Добавить();
	НоваяСтрока.Контрагент	 = Контрагент;
	НоваяСтрока.Наименование = Наименование;
	НоваяСтрока.Код			 = Код;
	НоваяСтрока.Артикул		 = Артикул;
	
КонецПроцедуры

Функция НайтиНоменклатуруПоставщикаПоРегистру(Контрагент, Наименование, Код)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НоменклатураПоставщиков.Номенклатура КАК Номенклатура,
	|	1 КАК Приоритет
	|ИЗ
	|	РегистрСведений.НоменклатураКонтрагентов КАК НоменклатураПоставщиков
	|ГДЕ
	|	&Код <> """"
	|	И НоменклатураПоставщиков.Идентификатор = &Код
	|	И НоменклатураПоставщиков.Контрагент = &Владелец
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	НоменклатураПоставщиков.Номенклатура,
	|	2
	|ИЗ
	|	РегистрСведений.НоменклатураКонтрагентов КАК НоменклатураПоставщиков
	|ГДЕ
	|	&Код <> """"
	|	И НоменклатураПоставщиков.АртикулНоменклатурыКонтрагента = &Код
	|	И НоменклатураПоставщиков.Контрагент = &Владелец
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	НоменклатураПоставщиков.Номенклатура,
	|	3
	|ИЗ
	|	РегистрСведений.НоменклатураКонтрагентов КАК НоменклатураПоставщиков
	|ГДЕ
	|	&Код <> """"
	|	И НоменклатураПоставщиков.КодНоменклатурыКонтрагента = &Код
	|	И НоменклатураПоставщиков.Контрагент = &Владелец
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	НоменклатураПоставщиков.Номенклатура,
	|	4
	|ИЗ
	|	РегистрСведений.НоменклатураКонтрагентов КАК НоменклатураПоставщиков
	|ГДЕ
	|	&Наименование <> """"
	|	И ПОДСТРОКА(НоменклатураПоставщиков.НаименованиеНоменклатурыКонтрагента, 1, &ДлинаНаименования) = &Наименование
	|	И НоменклатураПоставщиков.Контрагент = &Владелец
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет");
	
	Запрос.УстановитьПараметр("Владелец", Контрагент);
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("Код", ?(ЗначениеЗаполнено(Код), Код, ""));
	Запрос.УстановитьПараметр("ДлинаНаименования", Макс(СтрДлина(Наименование), 1));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Номенклатура;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция НайтиНоменклатуруПоРеквизиту(ИмяРеквизита, ЗначениеРеквизита)
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(ЗначениеРеквизита) Тогда
		
		Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 2 Ссылка ИЗ Справочник.Номенклатура ГДЕ "+ИмяРеквизита+" = &ЗначениеРеквизита");
		
		Запрос.УстановитьПараметр("ЗначениеРеквизита", ЗначениеРеквизита);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если НЕ РезультатЗапроса.Пустой() Тогда
			
			Выборка = РезультатЗапроса.Выбрать();
			
			Если Выборка.Количество() = 1 Тогда
				Выборка.Следующий();
				Результат = Выборка.Ссылка;
			КонецЕсли;			

		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСсылкуНаСтавкуНДС(ПредставлениеСтавкиНДС)
		
	ПредставлениеСтавкиНДС = СокрЛП(СтрЗаменить(ПредставлениеСтавкиНДС, "%", ""));
	
	Если ПредставлениеСтавкиНДС = "10" Тогда
		Возврат Перечисления.СтавкиНДС.НДС10;
		
	ИначеЕсли ПредставлениеСтавкиНДС = "18" Тогда
		Возврат Перечисления.СтавкиНДС.НДС18;
		
	ИначеЕсли ПредставлениеСтавкиНДС = "20" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20");	
		
	ИначеЕсли ПредставлениеСтавкиНДС = "0" Тогда
		Возврат Перечисления.СтавкиНДС.НДС0;
		
	Иначе
		Возврат Перечисления.СтавкиНДС.БезНДС;
	КонецЕсли;

КонецФункции

Функция ПолучитьСсылкуНаГТД(НомерГТД)
	
	СсылкаНомераГТД = Справочники.НомераГТД.НайтиПоКоду(НомерГТД);
	
	Если НЕ ЗначениеЗаполнено(СсылкаНомераГТД) Тогда
		
		НовыйЭлемент = Справочники.НомераГТД.СоздатьЭлемент();		
		НовыйЭлемент.Код = НомерГТД;		
		НовыйЭлемент.Записать();
		
		СсылкаНомераГТД = НовыйЭлемент.Ссылка;
		
	КонецЕсли;
	
	Возврат СсылкаНомераГТД;
	
КонецФункции

Функция ПолучитьСсылкуНаСтрану(КодСтраны)
	
	СтранаСсылка = Справочники.КлассификаторСтранМира.НайтиПоКоду(КодСтраны);
		
	Если НЕ ЗначениеЗаполнено(СтранаСсылка) Тогда
		
		Если ОКСМ = Неопределено Тогда
			ОКСМ = ОсновнойМодуль.ЭДО_Модуль_РаботаСКонтентом().ПолучитьОКСМ();
		КонецЕсли;
		
		ДанныеСтраны = ОКСМ.Найти(КодСтраны);
		
		Если ДанныеСтраны <> Неопределено Тогда
			НовыйЭлемент = Справочники.КлассификаторСтранМира.СоздатьЭлемент();
			НовыйЭлемент.Код = КодСтраны;
			НовыйЭлемент.Наименование 		= ДанныеСтраны.НаименованиеКраткое;
			НовыйЭлемент.НаименованиеПолное = ДанныеСтраны.НаименованиеПолное;
			НовыйЭлемент.Записать();
			СтранаСсылка = НовыйЭлемент.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтранаСсылка;
	
КонецФункции

Функция ПолучитьСсылкуНаСериюНоменклатуры(Номенклатура, НомерГТД, КодСтраны)
		
	СерияНоменклатуры = Справочники.СерииНоменклатуры.НайтиПоРеквизиту("НомерГТД", НомерГТД, , Номенклатура);
	
	Если НЕ ЗначениеЗаполнено(СерияНоменклатуры) Тогда
		
		НомерГТДСсылка	= ПолучитьСсылкуНаГТД(НомерГТД);
		СтранаСсылка	= ПолучитьСсылкуНаСтрану(КодСтраны);
		
		Если ЗначениеЗаполнено(НомерГТДСсылка) И ЗначениеЗаполнено(СтранаСсылка) ТОгда
			
			НовыйЭлемент = Справочники.СерииНоменклатуры.СоздатьЭлемент();
			НовыйЭлемент.Владелец = Номенклатура;
			НовыйЭлемент.НомерГТД = НомерГТДСсылка;
			НовыйЭлемент.СтранаПроисхождения = СтранаСсылка;
			НовыйЭлемент.Наименование = "" + НомерГТД + ", " + СтранаСсылка;
			
			НовыйЭлемент.Записать();
			
			СерияНоменклатуры = НовыйЭлемент.Ссылка;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СерияНоменклатуры;
	
КонецФункции

Функция ПолучитьРеквизитыПодписантаПоОрганизации1С(Организация, Дата)
	
	Результат = Новый Структура("Фамилия, Имя, Отчество, Должность", "", "", "", "");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОтветственныеЛицаОрганизацииСрезПоследних.ФизическоеЛицо КАК ФизЛицо,
	|	ОтветственныеЛицаОрганизацииСрезПоследних.Должность.Наименование КАК Должность,
	|	ФИОФизЛицСрезПоследних.Фамилия КАК Фамилия,
	|	ФИОФизЛицСрезПоследних.Имя КАК Имя,
	|	ФИОФизЛицСрезПоследних.Отчество КАК Отчество,
	|	ВЫБОР
	|		КОГДА ФИОФизЛицСрезПоследних.ФизЛицо ЕСТЬ NULL 
	|			ТОГДА ОтветственныеЛицаОрганизацииСрезПоследних.ФизическоеЛицо.Наименование
	|		ИНАЧЕ ФИОФизЛицСрезПоследних.Фамилия + ВЫБОР
	|				КОГДА ПОДСТРОКА(ФИОФизЛицСрезПоследних.Имя, 1, 1) <> """"
	|					ТОГДА "" "" + ПОДСТРОКА(ФИОФизЛицСрезПоследних.Имя, 1, 1) + "".""
	|				ИНАЧЕ """"
	|			КОНЕЦ + ВЫБОР
	|				КОГДА ПОДСТРОКА(ФИОФизЛицСрезПоследних.Отчество, 1, 1) <> """"
	|					ТОГДА "" "" + ПОДСТРОКА(ФИОФизЛицСрезПоследних.Отчество, 1, 1) + "".""
	|				ИНАЧЕ """"
	|			КОНЕЦ
	|	КОНЕЦ КАК СокрФИО
	|ИЗ
	|	РегистрСведений.ОтветственныеЛицаОрганизации.СрезПоследних(
	|			&Дата,
	|			СтруктурнаяЕдиница = &Организация
	|				И ОтветственноеЛицо = ЗНАЧЕНИЕ(Перечисление.ОтветственныеЛицаОрганизации.Руководитель)) КАК ОтветственныеЛицаОрганизацииСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизЛиц.СрезПоследних(&Дата, ФизЛицо ССЫЛКА Справочник.ФизическиеЛица) КАК ФИОФизЛицСрезПоследних
	|		ПО ОтветственныеЛицаОрганизацииСрезПоследних.ФизическоеЛицо = ФИОФизЛицСрезПоследних.ФизЛицо");
	
	// немного универсальности
	Если Метаданные.Перечисления.Найти("ОтветственныеЛицаОрганизаций") <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ОтветственныеЛицаОрганизации", "ОтветственныеЛицаОрганизаций");
	КонецЕсли;
	
	Если Метаданные.РегистрыСведений.Найти("ФИОФизическихЛиц") <> Неопределено Тогда
		// для БП 3.0
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ФИОФизЛиц",	"ФИОФизическихЛиц");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ФизЛицо",		"ФизическоеЛицо");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Организация", Организация);

	Запрос.УстановитьПараметр("Дата", Дата);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		Результат.Фамилия 	= Выборка.Фамилия;
		Результат.Имя 		= Выборка.Имя;
		Результат.Отчество 	= Выборка.Отчество;
		Результат.Должность = Выборка.Должность;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура СоздатьДокументПоступления(Документ, ТабличнаяЧасть, ДеревоКонтента, Результат)
	
	Отказ			= Ложь;
	МассивОшибок	= Новый Массив;
	
	ДокументОбъект = Документы.ПоступлениеТоваровУслуг.СоздатьДокумент();
	
	ДокументОбъект.Контрагент				= Документ.Отправитель.Организация;
	ДокументОбъект.Организация				= Документ.Получатель.Организация;			
	ДокументОбъект.ДатаВходящегоДокумента	= Документ.Реквизиты.Дата;
	ДокументОбъект.НомерВходящегоДокумента	= Документ.Реквизиты.Номер;			
	
	ДокументОбъект.Дата 					= ТекущаяДата();	
	ДокументОбъект.Ответственный			= ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.УчитыватьНДС				= Истина;
	ДокументОбъект.СуммаВключаетНДС			= Ложь;
	ДокументОбъект.КратностьВзаиморасчетов	= 1;
	ДокументОбъект.КурсВзаиморасчетов		= 1;
	ДокументОбъект.ВалютаДокумента			= Константы.ВалютаРегламентированногоУчета.Получить();
	ДокументОбъект.Подразделение			= УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь, "ОсновноеПодразделение");
	ДокументОбъект.СкладОрдер				= УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь, "ОсновнойСклад");
	ДокументОбъект.ВидПоступления 			= Перечисления.ВидыПоступленияТоваров.НаСклад;
	
	ДокументОбъект.ОтражатьВУправленческомУчете	= УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь, "ОтражатьДокументыВУправленческомУчете");
	ДокументОбъект.ОтражатьВБухгалтерскомУчете	= УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь, "ОтражатьДокументыВБухгалтерскомУчете");
	ДокументОбъект.ОтражатьВНалоговомУчете		= УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь, "ОтражатьДокументыВНалоговомУчете");
	
	СписокВидовДоговоров = Новый Массив;
	СписокВидовДоговоров.Добавить(Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком);
	УправлениеВзаиморасчетами.УстановитьДоговорКонтрагента(ДокументОбъект.ДоговорКонтрагента, ДокументОбъект.Контрагент, ДокументОбъект.Организация, СписокВидовДоговоров);
	
	Для Каждого СтрокаДанных Из ТабличнаяЧасть Цикл
		
		Номенклатура = НайтиНоменклатуруПоставщикаПоРегистру(ДокументОбъект.Контрагент, СтрокаДанных.Наименование, СтрокаДанных.Код);
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Если ЗначениеЗаполнено(СтрокаДанных.Код) Тогда				
				Номенклатура = НайтиНоменклатуруПоРеквизиту("Артикул", СтрокаДанных.Код);
			Иначе
				Номенклатура = НайтиНоменклатуруПоРеквизиту("Наименование", СтрокаДанных.Наименование);
			КонецЕсли;				
		КонецЕсли;				
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			
			ДобавитьНоменклатуруДляСопоставления(Результат, ДокументОбъект.Контрагент, СтрокаДанных.Наименование, СтрокаДанных.Код);
			МассивОшибок.Добавить("Для контрагента """+ДокументОбъект.Контрагент+""" не найдена номенклатура: "+СтрокаДанных.Код+" "+СтрокаДанных.Наименование);
			
			Отказ = Истина;
			Продолжить;
			
		ИначеЕсли Номенклатура.Услуга Тогда
			СтрокаТЧ = ДокументОбъект.Услуги.Добавить();
			СтрокаТЧ.Содержание = СтрокаДанных.Наименование;
			СтрокаТЧ.СтатьяЗатрат = Номенклатура.СтатьяЗатрат;
			СтрокаТЧ.НоменклатурнаяГруппа = Номенклатура.НоменклатурнаяГруппа;
		Иначе				
			СтрокаТЧ = ДокументОбъект.Товары.Добавить();
			СтрокаТЧ.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.НайтиПоРеквизиту("ЕдиницаПоКлассификатору", Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(СтрокаДанных.КодЕдИзм), , Номенклатура);
			СтрокаТЧ.Коэффициент = 1;
			
			Если ЗначениеЗаполнено(СтрокаДанных.НомерГТД) Тогда					
				СтрокаТЧ.СерияНоменклатуры = ПолучитьСсылкуНаСериюНоменклатуры(Номенклатура, СтрокаДанных.НомерГТД, СтрокаДанных.КодСтраны);
			КонецЕсли;
			
		КонецЕсли;			
		
		СтрокаТЧ.Номенклатура	= Номенклатура;
		СтрокаТЧ.Количество		= СтрокаДанных.Количество;
		СтрокаТЧ.Цена			= СтрокаДанных.Цена;			
		СтрокаТЧ.Сумма			= СтрокаДанных.СуммаБезНДС;
		СтрокаТЧ.СуммаНДС		= СтрокаДанных.СуммаНДС;
		СтрокаТЧ.СтавкаНДС		= ПолучитьСсылкуНаСтавкуНДС(СтрокаДанных.СтавкаНДС);
		
	КонецЦикла;
	
	
	Если НЕ Отказ Тогда
		
		Если ПустаяСтрока(ДокументОбъект.Номер) Тогда
			ДокументОбъект.УстановитьНовыйНомер();
		КонецЕсли;
		
		// Ищем в пакете документ счета-фактуры: если есть, то сразу создаем его в 1С
		
		СтруктураДанныхСФ = Неопределено;
		
		Если Документ.Тип.ТипДокумента = "UniversalTransferDocument" И Документ.Тип.ФункцияДокумента = "InvoiceAndBasic" Тогда				
			СтруктураДанныхСФ = Документ;
		Иначе
			
			ТаблицаДокументовПакета = ОсновнойМодуль.Пакеты_ДокументыПакетов(Документ.Идентификаторы);
			
			Для Каждого ДокументПакета Из ТаблицаДокументовПакета Цикл					
				
				Если Документ.Идентификаторы.DocumentId <> ДокументПакета.Идентификаторы.DocumentId Тогда						
					
					Если ДокументПакета.Тип.ТипДокумента = "Invoice" ИЛИ ДокументПакета.Тип.ФункцияДокумента = "Invoice" Тогда
						СтруктураДанныхСФ = ДокументПакета;
						Прервать;
					КонецЕсли;						
					
				КонецЕсли;					
				
			КонецЦикла;				
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтруктураДанныхСФ) Тогда
			
			ДокументОбъект.Записать();			
			
			ДокументСФ = Документы.СчетФактураПолученный.СоздатьДокумент();
			ДокументСФ.Заполнить(ДокументОбъект.Ссылка);
			ДокументСФ.ДатаВходящегоДокумента	= СтруктураДанныхСФ.Реквизиты.Дата;
			ДокументСФ.НомерВходящегоДокумента	= СтруктураДанныхСФ.Реквизиты.Номер;
			ДокументСФ.Дата						= ТекущаяДата();
			ДокументСФ.Записать();
			
			Если Документ.Идентификаторы.DocumentId <> СтруктураДанныхСФ.Идентификаторы.DocumentId Тогда
				ОсновнойМодуль.ОбновлениеРеквизитовДокумента(СтруктураДанныхСФ.Идентификаторы, ДокументСФ.Ссылка);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		Результат.ОсновнойОбъект = ДокументОбъект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивОшибок) Тогда
		Результат.ОписаниеОшибки = ОсновнойМодуль.ЭДО_Служебные_МассивВСтроку(МассивОшибок);		
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьДокументКорректировки(Документ, ТабличнаяЧасть, ДеревоКонтента, Результат)
	
	НомерДатаСФ = ДеревоКонтента.Документ.СвКСчФ.СчФ;
	
	Если ТипЗнч(НомерДатаСФ) = Тип("СписокXDTO") Тогда
		Возврат; // УКД по нескольким СФ пропускаем (нужна подробная аналитика такого сценария)
	КонецЕсли;
	
	НомерОснования = НомерДатаСФ.НомерСчФ;
	ДатаОснования  = ОсновнойМодуль.ДатаXML_в_Дата1С(НомерДатаСФ.ДатаСчФ);
	
	ДокументОснование = Неопределено;
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Организация",		Документ.Получатель.Организация);
	ПараметрыОтбора.Вставить("Контрагент",		Документ.Отправитель.Организация);
	ПараметрыОтбора.Вставить("ДатаДокумента",	ДатаОснования);
	ПараметрыОтбора.Вставить("НомерДокумента",	НомерОснования);
	
	Если Документ.Тип.ФункцияДокумента = "InvoiceAndBasic" Тогда
		
		ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "СчетФактураПолученный");
		
		Если ДокументыОснования1С <> Неопределено И ДокументыОснования1С.Количество() = 1 
			И ДокументыОснования1С[0].ДокументыОснования.Количество() = 1 Тогда
			ДокументОснование = ДокументыОснования1С[0].ДокументыОснования[0].ДокументОснование;
		КонецЕсли;
		
	ИначеЕсли Документ.Тип.ФункцияДокумента = "Basic" Тогда

		ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "ПоступлениеТоваровУслуг");
		
		Если ДокументыОснования1С = Неопределено Тогда
			ДокументыОснования1С = ПолучитьДокументы1С(ПараметрыОтбора, "ПоступлениеДопРасходов");
		КонецЕсли;
		
		Если ДокументыОснования1С <> Неопределено И ДокументыОснования1С.Количество() = 1 Тогда
			ДокументОснование = ДокументыОснования1С[0];
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДокументОснование = Неопределено Тогда
		Возврат; // Не нашли документ-основание для УКД
	КонецЕсли;
	
	Отказ = Ложь;
	МассивОшибок = Новый Массив;
	
	ДокументОбъект = Документы.КорректировкаПоступления.СоздатьДокумент();
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение;
	ДокументОбъект.Заполнить(ДокументОснование);
	ДокументОбъект.Товары.Очистить();
	ДокументОбъект.Услуги.Очистить();
		
	ДокументОбъект.Дата 					= ТекущаяДата();
	ДокументОбъект.ДатаВходящегоДокумента	= Документ.Реквизиты.Дата;
	ДокументОбъект.НомерВходящегоДокумента	= Документ.Реквизиты.Номер;
		
	Для Каждого СтрокаДанных Из ТабличнаяЧасть Цикл
		
		Номенклатура = НайтиНоменклатуруПоставщикаПоРегистру(ДокументОбъект.Контрагент, СтрокаДанных.Наименование, "");
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Номенклатура = НайтиНоменклатуруПоРеквизиту("Наименование", СтрокаДанных.Наименование);
		КонецЕсли;				
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			
			ДобавитьНоменклатуруДляСопоставления(Результат, ДокументОбъект.Контрагент, СтрокаДанных.Наименование);
			МассивОшибок.Добавить("Для контрагента """+ДокументОбъект.Контрагент+""" не найдена номенклатура: "+СтрокаДанных.Наименование);
			
			Отказ = Истина;
			Продолжить;
			
		ИначеЕсли Номенклатура.Услуга Тогда
			СтрокаТЧ = ДокументОбъект.Услуги.Добавить();			
			СтрокаТЧ.Содержание = СтрокаДанных.Наименование;
			СтрокаТЧ.СодержаниеДоИзменения = СтрокаДанных.Наименование;
		Иначе
			СтрокаТЧ = ДокументОбъект.Товары.Добавить();
			СтрокаТЧ.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.НайтиПоРеквизиту("ЕдиницаПоКлассификатору", Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(СтрокаДанных.КодЕдИзм), , Номенклатура);
			СтрокаТЧ.Коэффициент = 1;
		КонецЕсли;			
		
		СтрокаТЧ.Номенклатура			= Номенклатура;
		СтрокаТЧ.Количество				= СтрокаДанных.Количество;
		СтрокаТЧ.КоличествоДоИзменения	= СтрокаДанных.Количество_До;
		СтрокаТЧ.Цена					= СтрокаДанных.Цена;
		СтрокаТЧ.ЦенаДоИзменения		= СтрокаДанных.Цена_До;
		СтрокаТЧ.Сумма					= СтрокаДанных.СуммаБезНДС;
		СтрокаТЧ.СуммаДоИзменения		= СтрокаДанных.СуммаБезНДС_До;
		СтрокаТЧ.СуммаНДС				= СтрокаДанных.СуммаНДС;
		СтрокаТЧ.СуммаНДСДоИзменения	= СтрокаДанных.СуммаНДС_До;
		СтрокаТЧ.СтавкаНДС				= ПолучитьСсылкуНаСтавкуНДС(СтрокаДанных.СтавкаНДС);
		СтрокаТЧ.СтавкаНДСДоИзменения	= ПолучитьСсылкуНаСтавкуНДС(СтрокаДанных.СтавкаНДС_До);
						
	КонецЦикла;
	
	
	Если НЕ Отказ Тогда
			
		Если ПустаяСтрока(ДокументОбъект.Номер) Тогда
			ДокументОбъект.УстановитьНовыйНомер();
		КонецЕсли;
		
		// Ищем в пакете документ УКД-КСЧФ: если есть, то сразу создаем его в 1С
		
		СтруктураДанныхСФ = Неопределено;
		
		Если Документ.Тип.ТипДокумента = "UniversalCorrectionDocument" И Документ.Тип.ФункцияДокумента = "InvoiceAndBasic" Тогда				
			СтруктураДанныхСФ = Документ;
		Иначе
			
			ТаблицаДокументовПакета = ОсновнойМодуль.Пакеты_ДокументыПакетов(Документ.Идентификаторы);
			
			Для Каждого ДокументПакета Из ТаблицаДокументовПакета Цикл					
				
				Если Документ.Идентификаторы.DocumentId <> ДокументПакета.Идентификаторы.DocumentId Тогда						
					
					Если ДокументПакета.Тип.ТипДокумента = "UniversalCorrectionDocument" И ДокументПакета.Тип.ФункцияДокумента = "Invoice" Тогда
						СтруктураДанныхСФ = ДокументПакета;
						Прервать;
					КонецЕсли;						
					
				КонецЕсли;	
				
			КонецЦикла;				
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтруктураДанныхСФ) Тогда
			
			ДокументОбъект.Записать();			
			
			ДокументСФ = Документы.СчетФактураПолученный.СоздатьДокумент();
			ДокументСФ.Заполнить(ДокументОбъект.Ссылка);
			ДокументСФ.ДатаВходящегоДокумента = СтруктураДанныхСФ.Реквизиты.Дата;
			ДокументСФ.НомерВходящегоДокумента = СтруктураДанныхСФ.Реквизиты.Номер;
			ДокументСФ.Дата = ТекущаяДата();
			ДокументСФ.Записать();
			
			Если Документ.Идентификаторы.DocumentId <> СтруктураДанныхСФ.Идентификаторы.DocumentId Тогда
				ОсновнойМодуль.ОбновлениеРеквизитовДокумента(СтруктураДанныхСФ.Идентификаторы, ДокументСФ.Ссылка);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		Результат.ОсновнойОбъект = ДокументОбъект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивОшибок) Тогда
		Результат.ОписаниеОшибки = ОсновнойМодуль.ЭДО_Служебные_МассивВСтроку(МассивОшибок);		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьДокументы1С(ПараметрыОтбора, ВидДокумента1С)

	Результат = Неопределено;
	
	Запрос = Новый Запрос;
	
	Для Каждого Элемент Из ПараметрыОтбора Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Если ВидДокумента1С = "ПоступлениеТоваровУслуг" Тогда				
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПоступлениеТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.ПоступлениеТоваровУслуг КАК ПоступлениеТоваровУслуг
		|ГДЕ
		|	НЕ ПоступлениеТоваровУслуг.ПометкаУдаления
		|	И ПоступлениеТоваровУслуг.Организация = &Организация
		|	И ПоступлениеТоваровУслуг.Контрагент = &Контрагент
		|	И ПоступлениеТоваровУслуг.ДатаВходящегоДокумента = &ДатаДокумента
		|	И ПоступлениеТоваровУслуг.НомерВходящегоДокумента = &НомерДокумента";
	
	ИначеЕсли ВидДокумента1С = "ПоступлениеДопРасходов" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПоступлениеДопРасходов.Ссылка
		|ИЗ
		|	Документ.ПоступлениеДопРасходов КАК ПоступлениеДопРасходов
		|ГДЕ
		|	НЕ ПоступлениеДопРасходов.ПометкаУдаления
		|	И ПоступлениеДопРасходов.Организация = &Организация
		|	И ПоступлениеДопРасходов.Контрагент = &Контрагент
		|	И ПоступлениеДопРасходов.ДатаВходящегоДокумента = &ДатаДокумента
		|	И ПоступлениеДопРасходов.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "КорректировкаПоступления" Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КорректировкаПоступления.Ссылка
		|ИЗ
		|	Документ.КорректировкаПоступления КАК КорректировкаПоступления
		|ГДЕ
		|	НЕ КорректировкаПоступления.ПометкаУдаления
		|	И КорректировкаПоступления.Организация = &Организация
		|	И КорректировкаПоступления.Контрагент = &Контрагент
		|	И КорректировкаПоступления.ДатаВходящегоДокумента = &ДатаДокумента
		|	И КорректировкаПоступления.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "СчетФактураПолученный" Тогда
	
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетФактураПолученный.Ссылка
		|ИЗ
		|	Документ.СчетФактураПолученный КАК СчетФактураПолученный
		|ГДЕ
		|	НЕ СчетФактураПолученный.ПометкаУдаления
		|	И СчетФактураПолученный.Организация = &Организация
		|	И СчетФактураПолученный.Контрагент = &Контрагент
		|	И СчетФактураПолученный.ДатаВходящегоДокумента = &ДатаДокумента
		|	И СчетФактураПолученный.НомерВходящегоДокумента = &НомерДокумента";
		
	ИначеЕсли ВидДокумента1С = "СчетНаОплатуПоставщика" Тогда
	
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетНаОплатуПоставщика.Ссылка
		|ИЗ
		|	Документ.СчетНаОплатуПоставщика КАК СчетНаОплатуПоставщика
		|ГДЕ
		|	НЕ СчетНаОплатуПоставщика.ПометкаУдаления
		|	И СчетНаОплатуПоставщика.Организация = &Организация
		|	И СчетНаОплатуПоставщика.Контрагент = &Контрагент
		|	И СчетНаОплатуПоставщика.ДатаВходящегоДокумента = &ДатаДокумента
		|	И СчетНаОплатуПоставщика.НомерВходящегоДокумента = &НомерДокумента";		
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Запрос.Текст) Тогда
		
		РезультатЗапроса = Запрос.Выполнить();

		Если НЕ РезультатЗапроса.Пустой() Тогда
			Результат = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//} ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ РАБОТЫ С ТЕКУЩЕЙ КОНФИГУРАЦИЕЙ БАЗЫ



