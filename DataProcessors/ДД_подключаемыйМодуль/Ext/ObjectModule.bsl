//utd820

Процедура Заполнить_UtdSellerContent(Контент, Документ1С, ФункцияУПД) 
	
	Если ФункцияУПД = "СЧФДОП" Тогда
		УстановитьЗначениеXDTO(Контент, "Function",	"InvoiceAndBasic");
	    ДокОсн = Документ1С.ДокументОснование;
	ИначеЕсли ФункцияУПД = "СЧФ" Тогда
		УстановитьЗначениеXDTO(Контент, "Function",	"Invoice");
		ДокОсн = Документ1С.ДокументОснование;
	Иначе
		УстановитьЗначениеXDTO(Контент, "Function",	"Basic");
		ДокОсн = Документ1С;
	КонецЕсли;

	УстановитьЗначениеXDTO(Контент, "DocumentDate",      		Документ1С.Дата); 
	УстановитьЗначениеXDTO(Контент, "DocumentNumber",     		СокрЛП(Документ1С.Номер));
	УстановитьЗначениеXDTO(Контент, "Currency",     			ДокОсн.ВалютаДокумента.Код);
//	УстановитьЗначениеXDTO(Контент, "CurrencyRate",				Документ1С.КурсВалюты);
	УстановитьЗначениеXDTO(Контент, "DocumentCreator",			ДокОсн.Организация.НаименованиеПолное);
	УстановитьЗначениеXDTO(Контент, "GovermentContractInfo",	Неопределено);

	
	НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Sellers);
	Заполнить_ExtendedOrganizationInfo	(НовЭлемент, 	ДокОсн.Организация, 	Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Продавец");
	
	НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Buyers);
	Заполнить_ExtendedOrganizationInfo	(НовЭлемент, 	ДокОсн.Контрагент, 		Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента, "Покупатель");
	
	НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Shippers);
	Заполнить_Shipper(НовЭлемент, 	ДокОсн.Организация, ДокОсн.Грузоотправитель, "Грузоотправитель");
	
	Если ЗначениеЗаполнено(ДокОсн.Грузополучатель) Тогда
		НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Consignees);
		Заполнить_ExtendedOrganizationInfo	(НовЭлемент, ДокОсн.Грузополучатель, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента, "Грузополучатель");
	КонецЕсли;	
		
	Заполнить_InvoiceTable			(Контент.Table,				ДокОсн, ФункцияУПД);
	Заполнить_TransferInfo			(Контент.TransferInfo,  	ДокОсн);
	//Заполнить_AdditionalInfoId  	(Контент.AdditionalInfoId, 	ДокОсн);
	
	Для Сч = 1 По 0 Цикл
		НовЭлемент = НовыйЭлементСпискаXDTO(Контент.PaymentDocuments);
		Заполнить_PaymentDocumentInfo(НовЭлемент, Неопределено);
	КонецЦикла;
 
КонецПроцедуры

Процедура Заполнить_ExtendedOrganizationInfo(Контент, Организация, ВидАдреса, Признак) 
	// Документация: http://1c-docs.diadoc.ru/ru/latest/ExtendedOrganizationInfo.html
	
	УстановитьЗначениеXDTO(Контент, "BoxId",    			Неопределено);
	УстановитьЗначениеXDTO(Контент, "Name",					СокрЛП(Организация.НаименованиеПолное));
	УстановитьЗначениеXDTO(Контент, "Inn",      			Сокрлп(Организация.ИНН));
	УстановитьЗначениеXDTO(Контент, "FnsParticipantId",  	Неопределено);
	Если СтрДлина(Контент.Inn) = 10 Тогда
		УстановитьЗначениеXDTO(Контент, "Type",      "LegalEntity");
		УстановитьЗначениеXDTO(Контент, "Kpp",       Организация.КПП);
	Иначе  
		УстановитьЗначениеXDTO(Контент, "Type",      "IndividualEntity");
		УстановитьЗначениеXDTO(Контент, "Kpp",       Неопределено);
	КонецЕсли;
	УстановитьЗначениеXDTO(Контент, "Okopf",     Неопределено);
	УстановитьЗначениеXDTO(Контент, "Okpo",      Неопределено);
	УстановитьЗначениеXDTO(Контент, "Okpd",      Неопределено);
	УстановитьЗначениеXDTO(Контент, "Phone",     Неопределено);
	УстановитьЗначениеXDTO(Контент, "Email",     Неопределено);
		
	Попытка		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаКонтрагентов.Банк.КоррСчет <> """"
		|			ТОГДА БанковскиеСчетаКонтрагентов.Банк.КоррСчет
		|		ИНАЧЕ БанковскиеСчетаКонтрагентов.КоррСчетБанка
		|	КОНЕЦ КАК БанкКоррСчет,
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаКонтрагентов.Банк.Наименование <> """"
		|			ТОГДА БанковскиеСчетаКонтрагентов.Банк.Наименование
		|		ИНАЧЕ БанковскиеСчетаКонтрагентов.НаименованиеБанка
		|	КОНЕЦ КАК БанкНаименование,
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаКонтрагентов.Банк.Код <> """"
		|			ТОГДА БанковскиеСчетаКонтрагентов.Банк.Код
		|		ИНАЧЕ БанковскиеСчетаКонтрагентов.БИКБанка
		|	КОНЕЦ КАК БанкКод,
		|	БанковскиеСчетаКонтрагентов.НомерСчета КАК НомерСчета
		|ИЗ
		|	Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов
		|ГДЕ
		|	БанковскиеСчетаКонтрагентов.Владелец = &Владелец
		|	И БанковскиеСчетаКонтрагентов.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаОрганизаций.Банк.КоррСчет <> """"
		|			ТОГДА БанковскиеСчетаОрганизаций.Банк.КоррСчет
		|		ИНАЧЕ БанковскиеСчетаОрганизаций.КоррСчетБанка
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаОрганизаций.Банк.Наименование <> """"
		|			ТОГДА БанковскиеСчетаОрганизаций.Банк.Наименование
		|		ИНАЧЕ БанковскиеСчетаОрганизаций.НаименованиеБанка
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА БанковскиеСчетаОрганизаций.Банк.Код <> """"
		|			ТОГДА БанковскиеСчетаОрганизаций.Банк.Код
		|		ИНАЧЕ БанковскиеСчетаОрганизаций.БИКБанка
		|	КОНЕЦ,
		|	БанковскиеСчетаОрганизаций.НомерСчета
		|ИЗ
		|	Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчетаОрганизаций
		|ГДЕ
		|	БанковскиеСчетаОрганизаций.Владелец = &Владелец
		|	И БанковскиеСчетаОрганизаций.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("Владелец", Организация);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			УстановитьЗначениеXDTO(Контент, "CorrespondentAccount",		СокрЛП(ВыборкаДетальныеЗаписи.БанкКоррСчет));
			УстановитьЗначениеXDTO(Контент, "BankAccountNumber",		СокрЛП(ВыборкаДетальныеЗаписи.НомерСчета));
			УстановитьЗначениеXDTO(Контент, "BankName",					СокрЛП(ВыборкаДетальныеЗаписи.БанкНаименование));
			УстановитьЗначениеXDTO(Контент, "BankId",					СокрЛП(ВыборкаДетальныеЗаписи.БанкКод));
		КонецЕсли;		
	Исключение		
		УстановитьЗначениеXDTO(Контент, "CorrespondentAccount",		СокрЛП(Организация.ОсновнойБанковскийСчет.Банк.КоррСчет));
		УстановитьЗначениеXDTO(Контент, "BankAccountNumber",		СокрЛП(Организация.ОсновнойБанковскийСчет.НомерСчета));
		УстановитьЗначениеXDTO(Контент, "BankName",					СокрЛП(Организация.ОсновнойБанковскийСчет.Банк.Наименование));
		УстановитьЗначениеXDTO(Контент, "BankId",					СокрЛП(Организация.ОсновнойБанковскийСчет.Банк.Код));		
	КонецПопытки;
		
	УстановитьЗначениеXDTO(Контент, "Department",    							Неопределено);
	УстановитьЗначениеXDTO(Контент, "AdditionalInfo",   						Неопределено);
	УстановитьЗначениеXDTO(Контент, "OrganizationOrPersonInfo", 				Неопределено);
	УстановитьЗначениеXDTO(Контент, "IndividualEntityRegistrationCertificate",	Неопределено);
	УстановитьЗначениеXDTO(Контент, "Ссылка",     								Организация, Истина);
	
	Заполнить_AddressInfo(Контент.Address, Организация,	ВидАдреса);
	
КонецПроцедуры  

Процедура Заполнить_Shipper(Контент, Продавец, Грузоотправитель, Признак) 
	// Документация: http://1c-docs.diadoc.ru/ru/latest/Shipper.html
	
	Если Грузоотправитель = Продавец ИЛИ НЕ ЗначениеЗаполнено(Грузоотправитель)  Тогда		
		УстановитьЗначениеXDTO(Контент, "SameAsSeller",    Истина);		
	Иначе		
		УстановитьЗначениеXDTO(Контент, "SameAsSeller",    Ложь);
		Заполнить_ExtendedOrganizationInfo(Контент.OrganizationInfo, Грузоотправитель, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, Признак);		
	КонецЕсли;
	
КонецПроцедуры

Процедура Заполнить_AddressInfo(Контент, Организация, ВидАдреса)  
		
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Представление КАК СТРОКА(1000)) КАК Представление
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка = &Организация
		|	И КонтрагентыКонтактнаяИнформация.Вид = &ВидАдреса
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ОрганизацииКонтактнаяИнформация.Представление КАК СТРОКА(1000)) КАК Представление
		|ИЗ
		|	Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|ГДЕ
		|	ОрганизацииКонтактнаяИнформация.Ссылка = &Организация
		|	И ОрганизацииКонтактнаяИнформация.Вид = &ВидАдреса";			
		
		Запрос.УстановитьПараметр("ВидАдреса",		ВидАдреса);
		Запрос.УстановитьПараметр("Организация",	Организация);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда		
			УстановитьЗначениеXDTO(Контент, "AddressText",				ВыборкаДетальныеЗаписи.Представление);
			УстановитьЗначениеXDTO(Контент, "IsForeign",			   	Истина);
			УстановитьЗначениеXDTO(Контент, "CountryCode",			   	643);
		КонецЕсли;
		
	Исключение
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(КонтактнаяИнформация.Представление КАК СТРОКА(1000)) КАК Представление
		|ИЗ
		|	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
		|ГДЕ
		|	КонтактнаяИнформация.Объект = &Организация
		|	И КонтактнаяИнформация.Вид = &ВидАдреса";			
		
		Запрос.УстановитьПараметр("ВидАдреса",		ВидАдреса);
		Запрос.УстановитьПараметр("Организация",	Организация);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда		
			УстановитьЗначениеXDTO(Контент, "AddressText",				ВыборкаДетальныеЗаписи.Представление);
			УстановитьЗначениеXDTO(Контент, "IsForeign",			   	Истина);
			УстановитьЗначениеXDTO(Контент, "CountryCode",			   	643);
		КонецЕсли;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура Заполнить_InvoiceTable(Контент, ДокОсн, ФункцияДокумента)
	
	Для каждого Услуга из ДокОсн.Услуги Цикл 
		
		СтрокаТЧ = Новый Структура;
		
		СтрокаТЧ.Вставить("Артикул", 			СокрЛП(Услуга.Номенклатура.Артикул));
		СтрокаТЧ.Вставить("Наименование", 		СокрЛП(Услуга.Номенклатура.НаименованиеПолное));
		Попытка
			СтрокаТЧ.Вставить("ЕдиницаИзмерения", 	Услуга.Номенклатура.ЕдиницаИзмерения);
		Исключение
			СтрокаТЧ.Вставить("ЕдиницаИзмерения", 	Услуга.Номенклатура.БазоваяЕдиницаИзмерения);
		КонецПопытки;
		СтрокаТЧ.Вставить("Количество", 		Услуга.Количество); //Если ФункцияДокумента = "СЧФДОП" ИЛИ  
		СтрокаТЧ.Вставить("Цена", 				Услуга.Цена);
		СтрокаТЧ.Вставить("НалоговаяСтавка", 	ПривестиСтавкуНДС(Услуга.СтавкаНДС));
		СтрокаТЧ.Вставить("СуммаНалога", 		Услуга.СуммаНДС);
		Если ДокОсн.СуммаВключаетНДС Тогда
			СтрокаТЧ.Вставить("СуммаБезНалога", 	Услуга.Сумма - Услуга.СуммаНДС);
			СтрокаТЧ.Вставить("СуммаСНалогом", 		Услуга.Сумма);
		Иначе
			СтрокаТЧ.Вставить("СуммаБезНалога", 	Услуга.Сумма);
			СтрокаТЧ.Вставить("СуммаСНалогом", 		Услуга.Сумма + Услуга.СуммаНДС);
		КонецЕсли;
		Если Услуга.Номенклатура.Услуга Тогда
			СтрокаТЧ.Вставить("ТоварУслуга", 		"Service");
		Иначе
			СтрокаТЧ.Вставить("ТоварУслуга", 		"Property");
		КонецЕсли;
		
		НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Items);
		Заполнить_Item(НовЭлемент, СтрокаТЧ, ФункцияДокумента);
	
	КонецЦикла;
	
	Для каждого Товар из ДокОсн.Товары Цикл 
		
		СтрокаТЧ = Новый Структура;
		
		СтрокаТЧ.Вставить("Артикул", 			СокрЛП(Товар.Номенклатура.Артикул));
		СтрокаТЧ.Вставить("Наименование", 		СокрЛП(Товар.Номенклатура.НаименованиеПолное));
		Попытка
			СтрокаТЧ.Вставить("ЕдиницаИзмерения", 	Товар.Номенклатура.ЕдиницаИзмерения);
		Исключение
			СтрокаТЧ.Вставить("ЕдиницаИзмерения", 	Товар.Номенклатура.БазоваяЕдиницаИзмерения);
		КонецПопытки;
		СтрокаТЧ.Вставить("Количество", 		Товар.Количество);
		СтрокаТЧ.Вставить("Цена", 				Товар.Цена);
		СтрокаТЧ.Вставить("НалоговаяСтавка", 	ПривестиСтавкуНДС(Товар.СтавкаНДС));
		СтрокаТЧ.Вставить("СуммаНалога", 		Товар.СуммаНДС);
		Если ДокОсн.СуммаВключаетНДС Тогда
			СтрокаТЧ.Вставить("СуммаБезНалога", 	Товар.Сумма - Товар.СуммаНДС);
			СтрокаТЧ.Вставить("СуммаСНалогом", 		Товар.Сумма);
		Иначе
			СтрокаТЧ.Вставить("СуммаБезНалога", 	Товар.Сумма);
			СтрокаТЧ.Вставить("СуммаСНалогом", 		Товар.Сумма + Товар.СуммаНДС);
		КонецЕсли;
		Если Товар.Номенклатура.Товар Тогда
			СтрокаТЧ.Вставить("Товар/Услуга", 		"Service");
		Иначе
			СтрокаТЧ.Вставить("Товар/Услуга", 		"Property");
		КонецЕсли;
		
		НовЭлемент = НовыйЭлементСпискаXDTO(Контент.Items);
		Заполнить_Item(НовЭлемент, СтрокаТЧ, ФункцияДокумента);
	
	КонецЦикла;
	
	TotalWithVatExcluded = 0;
	Vat = 0;
	Total = 0;
		
	Для каждого Стр из Контент.Items Цикл
		
		TotalWithVatExcluded = TotalWithVatExcluded + Стр.SubtotalWithVatExcluded;
		Vat = Vat + Стр.Vat;
		Total = Total + Стр.Subtotal;
		
	КонецЦикла;	
	
	УстановитьЗначениеXDTO(Контент, "TotalWithVatExcluded",		TotalWithVatExcluded);
	Если Vat = 0 И Контент.Items[0].TaxRate = "без НДС" Тогда
		УстановитьЗначениеXDTO(Контент, "Vat",						Неопределено);
	Иначе	
		УстановитьЗначениеXDTO(Контент, "Vat",						Vat);
	КонецЕсли;
	УстановитьЗначениеXDTO(Контент, "Total",					Total);
	УстановитьЗначениеXDTO(Контент, "TotalNet",					Неопределено);
	
КонецПроцедуры

Процедура Заполнить_Item(Контент, СтрокаТЧ, ФункцияДокумента)
			
	УстановитьЗначениеXDTO(Контент, "Product",					СтрокаТЧ.Наименование);
	УстановитьЗначениеXDTO(Контент, "Unit",						СокрЛП(СтрокаТЧ.ЕдиницаИзмерения.Код));
	УстановитьЗначениеXDTO(Контент, "UnitName",					СокрЛП(СтрокаТЧ.ЕдиницаИзмерения.Наименование));
	УстановитьЗначениеXDTO(Контент, "Quantity",					СтрокаТЧ.Количество);
