	Заполнить_ExtendedOrganizationInfo		(Контент.Seller, ДокОсн.Организация, Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Продавец");
	Заполнить_ExtendedOrganizationInfo		(Контент.Buyer,  ДокОсн.Контрагент, Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента, 	"Покупатель");
	Заполнить_EventContent					(Контент.EventContent, Документ1С, Документ1С.ИсправляемыйСчетФактура.Номер, Документ1С.ИсправляемыйСчетФактура.Дата);
	Заполнить_InvoiceCorrectionTable		(Контент.InvoiceCorrectionTable, ДокОсн);
	//Заполнить_AdditionalInfoId				(Контент.AdditionalInfoId, Неопределено);
	Контент.Seller.Name = ДокОсн.Организация.Наименование;
	
