	УстановитьЗначениеXDTO(Контент, "Subtotal",					СтрокаТЧ.СуммаСНалогом);
	УстановитьЗначениеXDTO(Контент, "Vat",						СтрокаТЧ.СуммаНалога);
	УстановитьЗначениеXDTO(Контент, "ItemMark",					СтрокаТЧ.ТоварУслуга);
	УстановитьЗначениеXDTO(Контент, "WithoutVat",				Неопределено);
	
	//Для Сч = 1 По 0 Цикл	
