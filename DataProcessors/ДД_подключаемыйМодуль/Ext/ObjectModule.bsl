Процедура Заполнить_UcdSellerContent(Контент, Документ1С, ФункцияУПД)
	
	// Документация: http://1c-docs.diadoc.ru/ru/latest/UcdSellerContent.html

	Если ФункцияУПД = "СЧФ" Тогда
		УстановитьЗначениеXDTO(Контент, "Function",					"Invoice");
		ДокОсн = Документ1С.ДокументОснование; 
	ИначеЕсли ФункцияУПД = "ДОП" Тогда	
		УстановитьЗначениеXDTO(Контент, "Function",					"Basic");
		ДокОсн = Документ1С; 
	Иначе
		УстановитьЗначениеXDTO(Контент, "Function",					"InvoiceAndBasic");
		ДокОсн = Документ1С.ДокументОснование;
	КонецЕсли;	
	
	УстановитьЗначениеXDTO(Контент, "Name",						Неопределено);
