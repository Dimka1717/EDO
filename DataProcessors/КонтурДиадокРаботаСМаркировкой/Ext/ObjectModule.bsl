// Формирует правила преобразования видов упаковок подсистемы ИСМП во внутреннее представление,
// которое используется для заполнения развернутой таблицы упаковок.
// 
// Возвращаемое значение:
//  Соответствие:
//   * Ключ - ПеречислениеСсылка.ВидыУпаковокИС - вид упаковки в формате ИСМП.
//   * Значение - Строка - Внутреннее представление вида упаковки.
//
Функция ПравилаКонвертацииУпаковокИСМП()
	
	Если _ПравилаКонвертацииУпаковокИСМП <> Неопределено Тогда
		Возврат _ПравилаКонвертацииУпаковокИСМП;
	КонецЕсли;
	
	_ПравилаКонвертацииУпаковокИСМП = Новый Соответствие;
	
	МетаданныеВидыУпаковокИС = Метаданные.Перечисления.Найти("ВидыУпаковокИС");
	Если МетаданныеВидыУпаковокИС <> Неопределено Тогда
		
		ВидыУпаковокИСМП = Перечисления.ВидыУпаковокИС;
		
		_ПравилаКонвертацииУпаковокИСМП.Вставить(ВидыУпаковокИСМП.Групповая, УпаковкаГрупповая());
		_ПравилаКонвертацииУпаковокИСМП.Вставить(ВидыУпаковокИСМП.Логистическая, УпаковкаЛогистическая());
		_ПравилаКонвертацииУпаковокИСМП.Вставить(ВидыУпаковокИСМП.Потребительская, УпаковкаПотребительская()); 
		
		ЕстьОбъемноСортовойУчет = МетаданныеВидыУпаковокИС.ЗначенияПеречисления.Найти("ОбъемноСортовойУчет") <> Неопределено;
		Если ЕстьОбъемноСортовойУчет Тогда
			_ПравилаКонвертацииУпаковокИСМП.Вставить(ВидыУпаковокИСМП.ОбъемноСортовойУчет, УпаковкаОбъемноСортовойУчет());
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат _ПравилаКонвертацииУпаковокИСМП;
	
КонецФункции

