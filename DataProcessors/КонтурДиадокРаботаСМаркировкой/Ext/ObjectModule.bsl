Функция СоставКодаОСУ(КодОСУ)
	
	Результат = Новый Структура("GTIN, КоличествоТовара");
	
	ДлинаGTIN = 14;
	ДлинаКодаОСУ = СтрДлина(КодОСУ);
	ДлинаРазделителей = 4; // 02 и 37
	
	Результат.GTIN = Сред(КодОСУ, 3, ДлинаGTIN);
	Результат.КоличествоТовара = Число(Прав(КодОСУ, ДлинаКодаОСУ - ДлинаGTIN - ДлинаРазделителей));
	
	Возврат Результат;
	
КонецФункции

Функция СформироватьКодОСУИзGTIN(КоличествоТовара, СтрокаУпаковки)
	
	Если СтрокаУпаковки.КоличествоВПотребительскойУпаковке = 0 Тогда
		КоличествоПоТегу37 = 0;
	Иначе
		КоличествоПоТегу37 = Окр(КоличествоТовара / СтрокаУпаковки.КоличествоВПотребительскойУпаковке);
	КонецЕсли;
	
	Результат = НовыйКодОСУ(СтрокаУпаковки.ЗначениеШтрихкода, КоличествоПоТегу37);
	
	Возврат Результат;
	
КонецФункции

Функция НовыйКодОСУ(GTIN, Количество)
	
	КоличествоСтрокой = Формат(Количество, "ЧДЦ=0; ЧН=0; ЧГ=;");
	
	ЧастиКодаОСУ = Новый Массив;
	ЧастиКодаОСУ.Добавить("02");
	ЧастиКодаОСУ.Добавить(GTIN);
	ЧастиКодаОСУ.Добавить("37");
	ЧастиКодаОСУ.Добавить(КоличествоСтрокой);
	
	Результат = СтрСоединитьЛок(ЧастиКодаОСУ);
	
	Возврат Результат;
		
КонецФункции

