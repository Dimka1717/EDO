Функция ОписаниеТиповЗначения(Значение)
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(ТипЗнч(Значение));
	
	Результат = Новый ОписаниеТипов(МассивТипов);
	
	Возврат Результат;
	
КонецФункции

Функция ПлатформаПоддерживаетОпределяемыеТипы()
	
	Результат = Истина;
	
	СисИнфо = Новый СистемнаяИнформация;
	ТекущаяВерсияПлатформы = СисИнфо.ВерсияПриложения;
	НеобходимаяВерсияПлатформы = "8.3.3";
	
	Результат = СравнитьВерсии(ТекущаяВерсияПлатформы, НеобходимаяВерсияПлатформы) >= 0;
	
	Возврат Результат;
	
КонецФункции

