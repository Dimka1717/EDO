//{		СВЕДЕНИЯ О МАРКИРОВКЕ ОБЩЕЕ

Процедура ЗаполнитьСведенияОМаркировкеВКонтенте970(Контент, РазвернутаяТаблицаУпаковок)
	
	Для Каждого СтрокаКонтента Из Контент.Table.Items Цикл
		
		ТребуемоеКоличество = СтрокаКонтента.Quantity;
		
		Если Не ЗначениеЗаполнено(ТребуемоеКоличество) Тогда
			Продолжить;
		КонецЕсли;
		
		КодыМаркировки = Новый_СведенияОМаркировке();
		
		ПодобратьКодыМаркировки(КодыМаркировки, РазвернутаяТаблицаУпаковок, СтрокаКонтента.СлужебнаяИнформация, ТребуемоеКоличество);
		ЗаполнитьКодыМаркировкиВСтрокеКонтента970(СтрокаКонтента, КодыМаркировки);
		
	КонецЦикла;
	
КонецПроцедуры

// Переносит коды маркировки в строку контента.
//
// Параметры:
//  СтрокаКонтента - Структура - содержит объект Item970 (см. МодульИнтеграции.Контракт_Item970())
//  КодыМаркировки - Структура - содержит коллекции кодов маркировки (см. Новый_СведенияОМаркировке)
//
Процедура ЗаполнитьКодыМаркировкиВСтрокеКонтента970(СтрокаКонтента, КодыМаркировки)
	
	ИдентификационныйНомер = Неопределено;
	
	Для Каждого Элемент Из КодыМаркировки.ТранспортныеУпаковки Цикл
		
		ИдентификационныйНомер = Новый_ItemIdentificationNumber();
		ИдентификационныйНомер.TransPackageId = Элемент;
		СтрокаКонтента.ItemIdentificationNumbers.Добавить(ИдентификационныйНомер);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(КодыМаркировки.ИндивидуальныеУпаковки) Тогда
		
		ИдентификационныйНомер = Новый_ItemIdentificationNumber();
		
		Для Каждого Элемент Из КодыМаркировки.ИндивидуальныеУпаковки Цикл
			ИдентификационныйНомер.PackageIds.Добавить(Элемент);
		КонецЦикла;
		
		СтрокаКонтента.ItemIdentificationNumbers.Добавить(ИдентификационныйНомер);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КодыМаркировки.КонтрольныеИдентификационныеЗнаки) Тогда
		
		ИдентификационныйНомер = Новый_ItemIdentificationNumber();
		
		Для Каждого Элемент Из КодыМаркировки.КонтрольныеИдентификационныеЗнаки Цикл
			ИдентификационныйНомер.Units.Добавить(Элемент);
		КонецЦикла;
		
		СтрокаКонтента.ItemIdentificationNumbers.Добавить(ИдентификационныйНомер);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КодыМаркировки.ГТИН) И КодыМаркировки.КоличествоТовараВУпаковке > 0 Тогда
		
		ИдентификационныйНомер = Новый_ItemIdentificationNumber();
		ИдентификационныйНомер.MarkedItemsQuantity = КодыМаркировки.КоличествоТовараВУпаковке;
		
		СтрокаКонтента.ItemIdentificationNumbers.Добавить(ИдентификационныйНомер);
		СтрокаКонтента.GTIN = КодыМаркировки.ГТИН;
		
	КонецЕсли;
	
	Если ИдентификационныйНомер <> Неопределено
		И ЗначениеЗаполнено(КодыМаркировки.НомерПартии) Тогда
		ИдентификационныйНомер.BatchCode = КодыМаркировки.НомерПартии;
	КонецЕсли;
	
КонецПроцедуры

// Переносит коды маркировки в строку контента.
//
// Параметры:
//  СтрокаКонтента - Структура - содержит объект Item970 (см. МодульИнтеграции.Контракт_Item970())
//  СведенияОМаркировке - Массив - содержит коллекции кодов маркировки (см. Новый_СведенияОМаркировке)
//
Процедура ЗаполнитьКодыМаркировкиНесколькихПартийВСтрокеКонтента970(СтрокаКонтента, СведенияОМаркировке)
	
	Для Каждого СведенияОПартииМаркировки Из СведенияОМаркировке Цикл
		
		ЗаполнитьКодыМаркировкиВСтрокеКонтента970(СтрокаКонтента, СведенияОПартииМаркировки);
		
	КонецЦикла;
	
КонецПроцедуры


// Подбирает требуемое количество кодов маркировки, удовлетворяющих параметрам номенклатуры.
// В исходной таблице кодов строки с подобранными кодами отмечаются как обработанные.
//
// Параметры:
//  КодыМаркировки		 - Структура - результат подбора (см. Новый_СведенияОМаркировке)
//  ТаблицаКодов		 - ТаблицаЗначений - таблица штрихкодов упаковок (см. РазвернутаяТаблицаУпаковок)
//  СлужебнаяИнформация	 - Структура - содержит параметры номенклатуры (см. НоваяСлужебнаяИнформацияСтроки)
//  ТребуемоеКоличество	 - Число - Количество кодов, которые нужно подобрать
//
Процедура ПодобратьКодыМаркировки(КодыМаркировки
	, РазвернутаяТаблицаУпаковок
	, СлужебнаяИнформация
	, Знач ТребуемоеКоличество
	, ПодобратьКодДляПолногоВозрата = Ложь)
	
	Для Каждого СтрокаУпаковки Из РазвернутаяТаблицаУпаковок Цикл
		
		МожноПодобратьКодПоУпаковке = МожноПодобратьКодМаркировкиПоУпаковке(СтрокаУпаковки, ТребуемоеКоличество, ПодобратьКодДляПолногоВозрата);
		
		Если НЕ МожноПодобратьКодПоУпаковке Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаУпаковки.Номенклатура <> СлужебнаяИнформация.Номенклатура Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаУпаковки.ИспользоватьХарактеристики
			И СтрокаУпаковки.Характеристика <> СлужебнаяИнформация.Характеристика Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаУпаковки.ИспользоватьСерии
			И ЗначениеЗаполнено(СлужебнаяИнформация.Серия)
			И СтрокаУпаковки.Серия <> СлужебнаяИнформация.Серия Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеШК = СтрокаУпаковки.ЗначениеШтрихкода; 
		
		Если ЗначениеЗаполнено(ЗначениеШК) Тогда
			
			ВидУпаковки = СтрокаУпаковки.ВидУпаковки;
			
			Если ВидУпаковки = УпаковкаЛогистическая() Тогда
				КодыМаркировки.ТранспортныеУпаковки.Добавить(ЗначениеШК);
			ИначеЕсли ВидУпаковки = УпаковкаГрупповая() Тогда
				КодыМаркировки.ИндивидуальныеУпаковки.Добавить(ЗначениеШК);
			ИначеЕсли ВидУпаковки = УпаковкаОбъемноСортовойУчет() Тогда
				
				СоставКодаОСУ = СоставКодаОСУ(ЗначениеШК);
				
				КодыМаркировки.КоличествоТовараВУпаковке = СоставКодаОСУ.КоличествоТовара;
				КодыМаркировки.ГТИН = СоставКодаОСУ.GTIN;
				
			Иначе
				КодыМаркировки.КонтрольныеИдентификационныеЗнаки.Добавить(ЗначениеШК);
			КонецЕсли;
			
			ТребуемоеКоличество = ТребуемоеКоличество - 1;
			
		КонецЕсли;
		
		СтрокаУпаковки.Обработан = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

Функция МожноПодобратьКодМаркировкиПоУпаковке(СтрокаУпаковки, ТребуемоеКоличество, ПодобратьКодДляПолногоВозрата)
	
	Результат = Истина;
	
	Если СтрокаУпаковки.Обработан Тогда
		
		Результат = Ложь;
		
	ИначеЕсли ПодобратьКодДляПолногоВозрата 
		И ТребуемоеКоличество = 0 Тогда
		
		ЭтоОСУ = СтрокаУпаковки.ВидУпаковки = УпаковкаОбъемноСортовойУчет();
		
		Если НЕ ЭтоОСУ Тогда
			Результат = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТребуемоеКоличество <= 0 Тогда
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


// Конструктор таблицы кодов маркировки, развернутой по номенклатуре.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - таблица упаковок с товарными данными:
//   * Ссылка             - Произвольный - объект-владелец штрихкода - исходная колонка
//   * Номенклатура       - ОпределяемыйТип.Номенклатура - содержимое
//   * Характеристика     - ОпределяемыйТип.ХарактеристикаНоменклатуры - содержимое
//   * Серия              - ОпределяемыйТип.СерияНоменклатуры - содержимое
//   * ЗначениеШтрихкода  - Строка - текстовое представление исходного штрихкода для передачи в ЭДО
//   * ВидУпаковки        - Строка - вид упаковки номенклатуры для кодировки значения штрихкода. Допустимые значения:
//                                   УпаковкаПотребительская(), УпаковкаЛогистическая(), УпаковкаГрупповая(), Неопределено.
//   * Обработан          - Булево - признак сопоставления строки товарной части документа
//
//
