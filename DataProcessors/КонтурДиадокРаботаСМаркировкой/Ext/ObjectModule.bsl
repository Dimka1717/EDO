	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьХарактеристики", Ложь);
	Результат.Вставить("ИспользоватьСерии", Ложь);
	
	Если Метаданные.Справочники.Найти("ХарактеристикиНоменклатуры") <> Неопределено Тогда
		Результат.ИспользоватьХарактеристики = Истина;
	КонецЕсли;
	
	Если Метаданные.Справочники.Найти("СерииНоменклатуры") <> Неопределено Тогда
		Результат.ИспользоватьСерии = Истина;
	КонецЕсли;
	
	Возврат Новый ФиксированнаяСтруктура(Результат);
	
