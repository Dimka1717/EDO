//{		СВЕДЕНИЯ О МАРКИРОВКЕ КОНТУР МАРКИРОВКА

Процедура ЗаполнитьСведенияОМаркировке970_КонтурМаркировка(Контент)
	
	ПроверитьПодсистемуКонтурМаркировка();
	
	Если ИспользуетсяКонтурМаркировка33() Тогда
		
		РазвернутаяТаблицаУпаковок = Новый_РазвернутаяТаблицаУпаковок_КонтурМаркировка33();
		ОшибкиЗаполнения = Новый Массив;
		
		ЗаполнитьРазвернутуюТаблицуУпаковокИзКонтента(РазвернутаяТаблицаУпаковок, Контент);
		КонтурМаркировка_ЗаполнитьСведенияОМаркировке(РазвернутаяТаблицаУпаковок, ОшибкиЗаполнения);
		ОбработатьОшибкиПолученияКодовКонтурМаркировка970(Контент, ОшибкиЗаполнения);
		
		ЗаполнитьСведенияОМаркировкеВКонтенте970_КонтурМаркировка33(Контент, РазвернутаяТаблицаУпаковок);
		ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_КонтурМаркировка33(Контент, РазвернутаяТаблицаУпаковок);
		
	Иначе
		
		РазвернутаяТаблицаУпаковок = Новый_РазвернутаяТаблицаУпаковок();
		ДокументыПередачи = ВладельцыКодовМаркировки(Контент);
		ОшибкиЗаполнения = Новый Массив;
		
		ЗаполнитьРазвернутуюТаблицуКодов_КонтурМаркировка(РазвернутаяТаблицаУпаковок, ДокументыПередачи, ОшибкиЗаполнения);
		ОбработатьОшибкиПолученияКодовКонтурМаркировка970(Контент, ОшибкиЗаполнения);
		
		ЗаполнитьСведенияОМаркировкеВКонтенте970(Контент, РазвернутаяТаблицаУпаковок);
		ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_КонтурМаркировка(Контент, РазвернутаяТаблицаУпаковок)
		
	КонецЕсли;
	
КонецПроцедуры


Процедура ЗаполнитьРазвернутуюТаблицуУпаковокИзКонтента(РазвернутаяТаблицаУпаковок, Контент)
	
	НомерСтроки = 1;
	
	Для Каждого СтрокаТЧ Из Контент.Table.Items Цикл
		
		СлужебнаяИнформацияСтрокиТЧ = СтрокаТЧ.СлужебнаяИнформация;
		
		СтрокаТаблицыУпаковок = РазвернутаяТаблицаУпаковок.Добавить();
		
		ЗаполнитьЗначенияСвойств(СтрокаТаблицыУпаковок, СлужебнаяИнформацияСтрокиТЧ);
		
		СтрокаТаблицыУпаковок.ИндексСтроки = НомерСтроки;
		СтрокаТаблицыУпаковок.Количество = СтрокаТЧ.Quantity;
		СтрокаТаблицыУпаковок.ПервичныйДокумент = СлужебнаяИнформацияСтрокиТЧ.ДокументОтгрузки;
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет таблицу кодов по данным подсистемы Контур.Маркировка
//
// Параметры:
//  Результат - ТаблицаЗначений - Заполняемая таблица (см. Новый_РазвернутаяТаблицаУпаковок)
//  СсылкаНаОбъект - ЛюбаяСсылка - объект-владелец штрихкода
//  ОшибкиЗаполнения - Массив - (Необязательный) Коллекция ошибок получения кодов (возвращаемый параметр).
//
Процедура ЗаполнитьРазвернутуюТаблицуКодов_КонтурМаркировка(Результат, ДокументыПередачи, ОшибкиЗаполнения)
	
	ДанныеШтрихкодовУпаковок = КонтурМаркировка_РазвернутаяТаблицаУпаковок(ДокументыПередачи, ОшибкиЗаполнения);
	
	Если Не ЗначениеЗаполнено(ДанныеШтрихкодовУпаковок) Тогда
		Возврат;
	КонецЕсли;
	
	КолонкиШтрихкодов = ДанныеШтрихкодовУпаковок.Колонки;
	ЕстьПараметрыНоменклатуры = (КолонкиШтрихкодов.Найти("ИспользоватьХарактеристики") <> Неопределено);
	ПараметрыНоменклатурыПоУмолчанию = ПараметрыУчетаНоменклатуры();
	ПравилаКонвертацииУпаковок = ПравилаКонвертацииУпаковокКонтурМаркировка();
	ПравилаКонвертацииТоварныхГрупп = ПравилаКонвертацииТоварныхГруппКонтурМаркировка();
	
	Для Каждого УпаковкаКМ Из ДанныеШтрихкодовУпаковок Цикл
		
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, УпаковкаКМ);
		
		НоваяСтрока.ВидУпаковки = ВидУпаковкиПоДаннымКонтурМаркировка(УпаковкаКМ.ВидУпаковки, ПравилаКонвертацииУпаковок);
		НоваяСтрока.КодТоварнойГруппы = КодТоварнойГруппыПоДаннымКонтурМаркировка(УпаковкаКМ.ВидПродукции, ПравилаКонвертацииТоварныхГрупп);
		
		Если Не ЕстьПараметрыНоменклатуры Тогда
			НоваяСтрока.ИспользоватьХарактеристики = ПараметрыНоменклатурыПоУмолчанию.ИспользоватьХарактеристики;
			НоваяСтрока.ИспользоватьСерии = ПараметрыНоменклатурыПоУмолчанию.ИспользоватьСерии;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОМаркировкеВКонтенте970_КонтурМаркировка33(Контент, РазвернутаяТаблицаУпаковок)
	
	ВКонтурМаркировкеЕстьИнформацияПоПартиям = ВКонтурМаркировкеЕстьИнформацияПоПартиям();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДляОбработкиСведенийОМаркировке();
	
	НомерСтроки = 1;
	
	Для Каждого СтрокаКонтента Из Контент.Table.Items Цикл
		
		СтрокаТаблицы = РазвернутаяТаблицаУпаковок.Найти(НомерСтроки, "ИндексСтроки");
		СведенияОМаркировке = СтрокаТаблицы.СведенияОМаркировке;
		
		НомерСтроки = НомерСтроки + 1;
		
		Если СведенияОМаркировке.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ВКонтурМаркировкеЕстьИнформацияПоПартиям Тогда
			ДобавитьКолонкуПартииВСведенияОМаркировке(СведенияОМаркировке);
		КонецЕсли;
		
		СведенияОМаркировкеДляСтрокиКонтента = Новый Массив;
		
		Запрос.УстановитьПараметр("СведенияОМаркировке", СведенияОМаркировке);
		
		ПакетРезультатовЗапроса = Запрос.ВыполнитьПакет();
		РезультатПоПартиям = ПакетРезультатовЗапроса[1];
		РезультатПоGTIN = ПакетРезультатовЗапроса[2];
		
		ВыборкаПоGTIN = РезультатПоGTIN.Выбрать();
		НесколькоGTINДляСтрокиДокумента = ВыборкаПоGTIN.Количество() > 1;
		
		ИтогиПоПартиям = РезультатПоПартиям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ИтогиПоПартиям.Следующий() Цикл
			
			СведенияОПартииМаркировки = Новый_СведенияОМаркировке();
			СведенияОПартииМаркировки.НомерПартии = ИтогиПоПартиям.НомерПартии;
			
			ЗаполнитьСведенияОПартииКодамиМаркировки(
				СведенияОПартииМаркировки,
				ИтогиПоПартиям,
				НесколькоGTINДляСтрокиДокумента
			);
			
			СведенияОМаркировкеДляСтрокиКонтента.Добавить(СведенияОПартииМаркировки);
			
		КонецЦикла;
		
		ЗаполнитьКодыМаркировкиНесколькихПартийВСтрокеКонтента970(СтрокаКонтента, СведенияОМаркировкеДляСтрокиКонтента);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОПартииКодамиМаркировки(
	СведенияОПартииМаркировки,
	ИтогиПоПартиям,
	НесколькоGTINДляСтрокиДокумента)
	
	ВидыУпаковокКМ = Перечисления.КонтурМаркировка_ВидыУпаковок;
	УпаковкаГрупповая = ВидыУпаковокКМ.Групповая;
	УпаковкаЛогистическая = ВидыУпаковокКМ.Логистическая;
	УпаковкаОбъемноСортовойУчет = ВидыУпаковокКМ.ОбъемноСортовойУчет;
	
	СведенияОМаркировке = ИтогиПоПартиям.Выбрать();
	
	Пока СведенияОМаркировке.Следующий() Цикл
		
		ВидУпаковки = СведенияОМаркировке.ВидУпаковки;
		ЗначениеШК = СведенияОМаркировке.ЗначениеШтрихкода;
		
		Если ВидУпаковки = УпаковкаЛогистическая Тогда
			
			СведенияОПартииМаркировки.ТранспортныеУпаковки.Добавить(ЗначениеШК);
			
		ИначеЕсли ВидУпаковки = УпаковкаГрупповая Тогда
			
			СведенияОПартииМаркировки.ИндивидуальныеУпаковки.Добавить(ЗначениеШК);
			
		ИначеЕсли ВидУпаковки = УпаковкаОбъемноСортовойУчет Тогда
			
			Если НесколькоGTINДляСтрокиДокумента Тогда
				
				СведенияОПартииМаркировки.ИндивидуальныеУпаковки.Добавить(ЗначениеШК);
				
			Иначе
				
				СведенияОПартииМаркировки.ГТИН = СведенияОМаркировке.GTIN;
				СведенияОПартииМаркировки.КоличествоТовараВУпаковке = СведенияОМаркировке.Количество;
				
			КонецЕсли;
			
		Иначе
			СведенияОПартииМаркировки.КонтрольныеИдентификационныеЗнаки.Добавить(ЗначениеШК);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_КонтурМаркировка33(Контент, РазвернутаяТаблицаУпаковок)
	
	ЕстьМаркировка = Ложь;
	ЕстьАлкогольнаяПродукция = Ложь;
	ЕстьТабачнаяПродукция = Ложь;
	
	ТипТаблицаЗначений = Тип("ТаблицаЗначений");
	
	Для Каждого СтрокаТаблицыУпаковок Из РазвернутаяТаблицаУпаковок Цикл
		
		СведенияОМаркировке = СтрокаТаблицыУпаковок.СведенияОМаркировке;
		
		Если НЕ ЕстьМаркировка
			И ТипЗнч(СведенияОМаркировке) = ТипТаблицаЗначений
			И СведенияОМаркировке.Количество() > 0 Тогда
			
			ЕстьМаркировка = Истина;
			
		КонецЕсли;
		
		Если ЕстьМаркировка
			И НЕ ЕстьАлкогольнаяПродукция Тогда
			
			ЕстьАлкогольнаяПродукция = ЭтоАлкогольнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			
		КонецЕсли;
		
		Если ЕстьМаркировка
			И НЕ ЕстьТабачнаяПродукция Тогда
			
			ЕстьТабачнаяПродукция = ЭтоТабачнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ВидыТоваровДокумента = Контент.СлужебнаяИнформация.ContentsDocumentProductsType;
	ВидыТоваровДокумента.ContainsMarkedProducts = ЕстьМаркировка;
	ВидыТоваровДокумента.ContainsAlcoholeProducts = ЕстьАлкогольнаяПродукция;
	ВидыТоваровДокумента.ContainsTobaccoProducts = ЕстьТабачнаяПродукция;
	
КонецПроцедуры

Процедура ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_КонтурМаркировка(Контент, РазвернутаяТаблицаУпаковок)
	
	ЕстьМаркировка = Ложь;
	ЕстьАлкогольнаяПродукция = Ложь;
	ЕстьТабачнаяПродукция = Ложь;
	
	Для Каждого СтрокаТаблицыУпаковок Из РазвернутаяТаблицаУпаковок Цикл
		
		Если НЕ ЕстьМаркировка
			И ЗначениеЗаполнено(СтрокаТаблицыУпаковок.ЗначениеШтрихкода) Тогда
			
			ЕстьМаркировка = Истина;
			
		КонецЕсли;
		
		Если ЕстьМаркировка
			И НЕ ЕстьАлкогольнаяПродукция Тогда
			
			ЕстьАлкогольнаяПродукция = ЭтоАлкогольнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			
		КонецЕсли;
		
		Если ЕстьМаркировка
			И НЕ ЕстьТабачнаяПродукция Тогда
			
			ЕстьТабачнаяПродукция = ЭтоТабачнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ВидыТоваровДокумента = Контент.СлужебнаяИнформация.ContentsDocumentProductsType;
	ВидыТоваровДокумента.ContainsMarkedProducts = ЕстьМаркировка;
	ВидыТоваровДокумента.ContainsAlcoholeProducts = ЕстьАлкогольнаяПродукция;
