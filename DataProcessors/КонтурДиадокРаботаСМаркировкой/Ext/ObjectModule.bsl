Функция ВерсияУстановленнойПодсистемыКонтурМаркировка()
	
	ИмяМодуля = "ОбновлениеИнформационнойБазыКонтурМаркировка";
	
	МетаданныеМодуля = Метаданные.ОбщиеМодули.Найти(ИмяМодуля);
	
	Если МетаданныеМодуля <> Неопределено Тогда
		
		Попытка
			
			МодульОбновлениеИнформационнойБазыКонтурМаркировка = Вычислить(ИмяМодуля);
			
			Результат = МодульОбновлениеИнформационнойБазыКонтурМаркировка.ВерсияБиблиотеки();
			
		Исключение
			Возврат НеизвестнаяВерсияПродукта();
		КонецПопытки;
		
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВерсияУстановленногоМодуляКонтурМаркировка()
	
	ИмяМодуля = ИмяМодуляВзаимодействиеКонтурМаркировка();
	
	МетаданныеМодуля = Метаданные.ОбщиеМодули.Найти(ИмяМодуля);
	
	Если МетаданныеМодуля <> Неопределено Тогда
		
		УстановленнаяВерсияПодсистемыКМ = ВерсияУстановленнойПодсистемыКонтурМаркировка();
		НеобходимаяВерсияПодсистемыКМ = "3.0.0";
		
		Если СравнитьВерсии(УстановленнаяВерсияПодсистемыКМ, НеобходимаяВерсияПодсистемыКМ) >= 0 Тогда
			
			// На всякий случай, чтобы мы не падали,
			// если подсистему обновили криво,
			// либо если подсистему обновили нормально, а модуль обновили криво
			Попытка
				
				МодульВзаимодействиеКонтурМаркировка = Вычислить(ИмяМодуля);
				
				Результат = МодульВзаимодействиеКонтурМаркировка.ВерсияМодуля();
				
			Исключение
				Результат = НеизвестнаяВерсияПродукта();
			КонецПопытки;
			
		Иначе
			Результат = НеизвестнаяВерсияПродукта();
		КонецЕсли;
		
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяМодуляВзаимодействиеКонтурМаркировка()
	Возврат "ВзаимодействиеКонтурМаркировка";
