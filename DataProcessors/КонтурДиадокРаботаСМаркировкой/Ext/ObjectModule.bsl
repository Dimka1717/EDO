		КонецЕсли;
		
		Если Результат.Найти(ДокументОтгрузки) = Неопределено Тогда
			Результат.Добавить(ДокументОтгрузки);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

