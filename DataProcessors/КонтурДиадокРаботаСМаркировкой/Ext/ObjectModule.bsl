// Формирует правила преобразования видов упаковок подсистемы КонтурМаркировка во внутреннее представление,
// которое используется для заполнения развернутой таблицы упаковок.
// 
// Возвращаемое значение:
//  Соответствие:
//   * Ключ - ПеречислениеСсылка.КонтурМаркировка_ВидыУпаковок - вид упаковки в формате КонтурМаркировка.
//   * Значение - Строка - Внутреннее представление вида упаковки.
//
Функция ПравилаКонвертацииУпаковокКонтурМаркировка()
	
	Если _ПравилаКонвертацииУпаковокКМ <> Неопределено Тогда
		Возврат _ПравилаКонвертацииУпаковокКМ;
	КонецЕсли;
	
	_ПравилаКонвертацииУпаковокКМ = Новый Соответствие;
	
	МетаданныеВидыУпаковокКонтурМаркировка = Метаданные.Перечисления.Найти("КонтурМаркировка_ВидыУпаковок");
	Если МетаданныеВидыУпаковокКонтурМаркировка <> Неопределено Тогда
		
		ВидыУпаковокКМ = Перечисления.КонтурМаркировка_ВидыУпаковок;
		
		_ПравилаКонвертацииУпаковокКМ.Вставить(ВидыУпаковокКМ.Групповая, УпаковкаГрупповая());
		_ПравилаКонвертацииУпаковокКМ.Вставить(ВидыУпаковокКМ.Логистическая, УпаковкаЛогистическая());
		_ПравилаКонвертацииУпаковокКМ.Вставить(ВидыУпаковокКМ.Потребительская, УпаковкаПотребительская()); 
		
		ЕстьОбъемноСортовойУчет = МетаданныеВидыУпаковокКонтурМаркировка.ЗначенияПеречисления.Найти("ОбъемноСортовойУчет") <> Неопределено;
		Если ЕстьОбъемноСортовойУчет Тогда
			_ПравилаКонвертацииУпаковокКМ.Вставить(ВидыУпаковокКМ.ОбъемноСортовойУчет, УпаковкаОбъемноСортовойУчет());
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат _ПравилаКонвертацииУпаковокКМ;
	
КонецФункции

