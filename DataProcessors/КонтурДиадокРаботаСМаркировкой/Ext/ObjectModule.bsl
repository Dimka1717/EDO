//{		СВЕДЕНИЯ О МАРКИРОВКЕ ИСМП

Процедура ЗаполнитьСведенияОМаркировке970_ИСМП(Контент)
	
	Если НЕ ЕстьИнтеграцияИСМП() Тогда
		Возврат;
	КонецЕсли;
	
	ДокументыПередачи = ВладельцыКодовМаркировки(Контент);
	ТаблицаУпаковок = ТаблицаУпаковокИСМП(ДокументыПередачи);
	
	Если Не ЗначениеЗаполнено(ТаблицаУпаковок) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользуетсяИнтеграцияИСМП10127() Тогда
		
		РазвернутаяТаблицаУпаковок = Новый_РазвернутаяТаблицаУпаковок_ИСМП10127();
		ТаблицаТоваров = ТаблицаТоваровИСМП(Контент.Table.Items);
		ДанныеШтрихкодовУпаковок = ИСМП_ЧастичноеСодержимоеИКодыОСУ(ТаблицаУпаковок, ТаблицаТоваров, ДокументыПередачи);
		
		ЗаполнитьРазвернутуюТаблицуКодов_ИСМП(РазвернутаяТаблицаУпаковок, ДанныеШтрихкодовУпаковок);
		ЗаполнитьСведенияОМаркировкеВКонтенте970_ИСМП10127(Контент, РазвернутаяТаблицаУпаковок);
		ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_ИСМП(Контент, РазвернутаяТаблицаУпаковок);
		
	Иначе
		
		РазвернутаяТаблицаУпаковок = Новый_РазвернутаяТаблицаУпаковок();
		ДанныеШтрихкодовУпаковок = ИСМП_ЧастичноеСодержимое(ТаблицаУпаковок);
		
		ЗаполнитьРазвернутуюТаблицуКодов_ИСМП(РазвернутаяТаблицаУпаковок, ДанныеШтрихкодовУпаковок);
		ЗаполнитьСведенияОМаркировкеВКонтенте970(Контент, РазвернутаяТаблицаУпаковок);
		ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_ИСМП(Контент, РазвернутаяТаблицаУпаковок);
		
	КонецЕсли;
	
КонецПроцедуры

// Заполняет таблицу кодов средствами типовой библиотеки интеграции с ИС МП.
//
// Параметры:
//  Результат - ТаблицаЗначений - Заполняемая таблица (см. НоваяРазвернутаяТаблицаУпаковок)
//  СсылкаНаДокумент - ЛюбаяСсылка - объект-владелец штрихкода
//
Процедура ЗаполнитьРазвернутуюТаблицуКодов_ИСМП(Результат, ДанныеШтрихкодовУпаковок)
	
	ЕстьВидУпаковки = (ДанныеШтрихкодовУпаковок.Колонки.Найти("ВидУпаковки") <> Неопределено);
	ИсключаемыеСвойства = "";
	
	Если ЕстьВидУпаковки Тогда 
		ИсключаемыеСвойства = "ВидУпаковки";
	КонецЕсли;
	
	ПараметрыНоменклатуры = ПараметрыУчетаНоменклатуры();
	ПравилаКонвертацииУпаковок = ПравилаКонвертацииУпаковокИСМП();
	ПравилаКонвертацииВидаПродукции = ПравилаКонвертацииВидаПродукцииИСМП();
	
	Для Каждого УпаковкаИСМП Из ДанныеШтрихкодовУпаковок Цикл
		
		ВидУпаковкиИСМП = Неопределено;
		Если ЕстьВидУпаковки Тогда
			ВидУпаковкиИСМП = УпаковкаИСМП.ВидУпаковки;
		КонецЕсли;
		
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, УпаковкаИСМП, , ИсключаемыеСвойства);
		НоваяСтрока.ВидУпаковки = ВидУпаковкиПоДаннымИСМП(ВидУпаковкиИСМП, ПравилаКонвертацииУпаковок);
		НоваяСтрока.ИспользоватьХарактеристики = ПараметрыНоменклатуры.ИспользоватьХарактеристики;
		НоваяСтрока.ИспользоватьСерии = ПараметрыНоменклатуры.ИспользоватьСерии;
		НоваяСтрока.КодТоварнойГруппы = КодТоварнойГруппыПоДаннымИСМП(УпаковкаИСМП.ВидПродукции, ПравилаКонвертацииВидаПродукции);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОМаркировкеВКонтенте970_ИСМП10127(Контент, РазвернутаяТаблицаУпаковок)
	
	Для Каждого СтрокаКонтента Из Контент.Table.Items Цикл
		
		ТребуемоеКоличество = СтрокаКонтента.Quantity;
		
		Если Не ЗначениеЗаполнено(ТребуемоеКоличество) Тогда
			Продолжить;
		КонецЕсли;
		
		КодыМаркировки = Новый_СведенияОМаркировке();
		
		ПодобратьКодыМаркировки970_ИСМП10127(КодыМаркировки, РазвернутаяТаблицаУпаковок, СтрокаКонтента.СлужебнаяИнформация, ТребуемоеКоличество);
		ЗаполнитьКодыМаркировкиВСтрокеКонтента970(СтрокаКонтента, КодыМаркировки);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПризнакиМаркируемыхТоваровВКонтенте970_ИСМП(Контент, РазвернутаяТаблицаУпаковок)
	
	ЕстьМаркировка = Ложь;
	
	Для Каждого СтрокаКонтента Из Контент.Table.Items Цикл
		
		Если СтрокаКонтента.ItemIdentificationNumbers.Количество() > 0 Тогда
			ЕстьМаркировка = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	ЕстьАлкогольнаяПродукция = Ложь;
	ЕстьТабачнаяПродукция = Ложь;
	
	Если ЕстьМаркировка Тогда
		
		Для Каждого СтрокаТаблицыУпаковок Из РазвернутаяТаблицаУпаковок Цикл
			
			Если НЕ ЕстьАлкогольнаяПродукция Тогда
				ЕстьАлкогольнаяПродукция = ЭтоАлкогольнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			КонецЕсли;
			
			Если НЕ ЕстьТабачнаяПродукция Тогда
				ЕстьТабачнаяПродукция = ЭтоТабачнаяПродукция(СтрокаТаблицыУпаковок.КодТоварнойГруппы);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ВидыТоваровДокумента = Контент.СлужебнаяИнформация.ContentsDocumentProductsType;
	ВидыТоваровДокумента.ContainsMarkedProducts = ЕстьМаркировка;
	ВидыТоваровДокумента.ContainsAlcoholeProducts = ЕстьАлкогольнаяПродукция;
	ВидыТоваровДокумента.ContainsTobaccoProducts = ЕстьТабачнаяПродукция;
	
КонецПроцедуры

Процедура ПодобратьКодыМаркировки970_ИСМП10127(КодыМаркировки, РазвернутаяТаблицаУпаковок, СлужебнаяИнформация, ТребуемоеКоличество)
	
	Для Каждого СтрокаУпаковки Из РазвернутаяТаблицаУпаковок Цикл
		
		Если СтрокаУпаковки.Обработан Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаУпаковки.Номенклатура <> СлужебнаяИнформация.Номенклатура Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаУпаковки.ИспользоватьХарактеристики
			И СтрокаУпаковки.Характеристика <> СлужебнаяИнформация.Характеристика Тогда
			Продолжить;
		КонецЕсли;
		
		ВидУпаковки = СтрокаУпаковки.ВидУпаковки;
		
		Если (ВидУпаковки <> УпаковкаОбъемноСортовойУчет() ИЛИ ЗначениеЗаполнено(СтрокаУпаковки.Штрихкод))
			И СтрокаУпаковки.ИспользоватьСерии
			И ЗначениеЗаполнено(СлужебнаяИнформация.Серия)
			И СтрокаУпаковки.Серия <> СлужебнаяИнформация.Серия Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеШК = СтрокаУпаковки.ЗначениеШтрихкода;
		
		Если ЗначениеЗаполнено(ЗначениеШК) Тогда
			
			Если ВидУпаковки = УпаковкаЛогистическая() Тогда
				КодыМаркировки.ТранспортныеУпаковки.Добавить(ЗначениеШК);
			ИначеЕсли ВидУпаковки = УпаковкаГрупповая() Тогда
				КодыМаркировки.ИндивидуальныеУпаковки.Добавить(ЗначениеШК);
			ИначеЕсли ВидУпаковки = УпаковкаОбъемноСортовойУчет() Тогда
				
				Если ЗначениеЗаполнено(СтрокаУпаковки.Штрихкод) Тогда
					КодыМаркировки.ИндивидуальныеУпаковки.Добавить(ЗначениеШК);
				Иначе
					
					Если СтрокаУпаковки.КоличествоВПотребительскойУпаковке = 0 Тогда
						КодыМаркировки.КоличествоТовараВУпаковке = 0;
					Иначе
						КодыМаркировки.КоличествоТовараВУпаковке = Окр(ТребуемоеКоличество / СтрокаУпаковки.КоличествоВПотребительскойУпаковке);
					КонецЕсли;
					
					КодыМаркировки.ГТИН = СтрокаУпаковки.ЗначениеШтрихкода;
					
					Прервать;
					
				КонецЕсли;
				
			Иначе
				КодыМаркировки.КонтрольныеИдентификационныеЗнаки.Добавить(ЗначениеШК);
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаУпаковки.Обработан = Истина;
		
	КонецЦикла;
	
КонецПроцедуры


// Разворачивает таблицу транспортных и индивидуальных штрихкодов до номенклатуры, характеристики, серии
//   для дальнейшего сопоставления информации об упаковках с товарной частью.
//   Для транспортных упаковок номенклатура (характеристика, серия)- это номенклатура (характеристика, серия)
//   первого вложенного (на любом уровне) индивидуального штрихкода.
// 
// Параметры:
// 	ТаблицаУпаковок - ТаблицаЗначений - исходная таблица упаковок:
// 	 * Ссылка   - Произвольный - объект-владелец штрихкода
// 	 * Штрихкод - СправочникСсылка.ШтрихкодыУпаковокТоваров
// Возвращаемое значение - ТаблицаЗначений - таблица упаковок с товарными данными:
// 	 * Ссылка             - Произвольный - объект-владелец штрихкода - исходная колонка
// 	 * Штрихкод           - СправочникСсылка.ШтрихкодыУпаковокТоваров - ссылка на индивидуальный штрихкод содержимого
// 	 * Номенклатура       - ОпределяемыйТип.Номенклатура - содержимое
// 	 * Характеристика     - ОпределяемыйТип.ХарактеристикаНоменклатуры - содержимое
// 	 * Серия              - ОпределяемыйТип.СерияНоменклатуры - содержимое
// 	 * ЗначениеШтрихкода  - Строка - текстовое представление исходного штрихкода для передачи в ЭДО
// 	 * Обработан          - Булево - признак сопоставления строки товарной части документа
//
Функция ИСМП_ЧастичноеСодержимое(ТаблицаУпаковок)
	
	МодульЭлектронноеВзаимодействиеИСМП = Вычислить("ЭлектронноеВзаимодействиеИСМП");
	Результат = МодульЭлектронноеВзаимодействиеИСМП.ЧастичноеСодержимое(ТаблицаУпаковок);
	
	Возврат Результат;
	
КонецФункции

// Разворачивает таблицу транспортных и индивидуальных штрихкодов до номенклатуры, характеристики, серии
//   для дальнейшего сопоставления информации об упаковках с товарной частью.
// Добавляет в таблицу коды ОСУ для строк, по которым коды маркировки не указывались. Считаем что таблица товаров
//   уже соответствует таблице штрихкодов упаковок (с учетом невнесенных ОСУ).
//
// Параметры:
// 	ТаблицаУпаковок - ТаблицаЗначений - исходная таблица упаковок:
// 	 * Ссылка   - Произвольный - объект-владелец штрихкода
// 	 * Штрихкод - СправочникСсылка.ШтрихкодыУпаковокТоваров - Штрихкод
//  ТаблицаТоваров	 - ТаблицаЗначений - исходная таблица товаров: 
// 	 * Ссылка         - Произвольный - объект-владелец штрихкода
// 	 * Номенклатура   - ОпределяемыйТип.Номенклатура - номенклатура
// 	 * Характеристика - ОпределяемыйТип.ХарактеристикаНоменклатуры - характеристика
// 	 * Количество     - Число - количество
//  ПараметрыСканирования - См. ШтрихкодированиеИС.ПараметрыСканирования
// Возвращаемое значение:
//  ТаблицаЗначений - См. ЧастичноеСодержимое
//
Функция ИСМП_ЧастичноеСодержимоеИКодыОСУ(ТаблицаУпаковок, ТаблицаТоваров, ДокументыОснования)
	
	Если ДокументыОснования.Количество() Тогда
		ДокументОснование = ДокументыОснования[0];
	ИначеЕсли ТаблицаТоваров.Количество() Тогда
		ДокументОснование = ТаблицаТоваров[0].Ссылка;
	КонецЕсли;
	
	Если ИспользуетсяРасширеннаяВерсияГосИС() Тогда
		МодульШтрихкодированиеИС = Вычислить("ШтрихкодированиеОбщегоНазначенияИС");
	Иначе
		МодульШтрихкодированиеИС = Вычислить("ШтрихкодированиеИС");
	КонецЕсли;
	
	ПараметрыСканирования = МодульШтрихкодированиеИС.ПараметрыСканирования(ДокументОснование);
	МодульЭлектронноеВзаимодействиеИСМП = Вычислить("ЭлектронноеВзаимодействиеИСМП");
	
	Результат = МодульЭлектронноеВзаимодействиеИСМП.ЧастичноеСодержимоеИКодыОСУ(
		ТаблицаУпаковок,
		ТаблицаТоваров,
		ПараметрыСканирования);
	
	Возврат Результат;
	
КонецФункции


// Возвращает таблицу упаковок, сформированную по данным библиотеки интеграции с ИС МП.
//
// Параметры:
//  ДокументыПередачи - Массив - ссылки на документы, по которым необходимо получить таблицу упаковок
// 
// Возвращаемое значение:
//  ТаблицаЗначений - таблица упаковок:
//   * Ссылка   - Произвольный - объект-владелец штрихкода
//   * Штрихкод - СправочникСсылка.ШтрихкодыУпаковокТоваров
//
Функция ТаблицаУпаковокИСМП(ДокументыПередачи)
	
	ВладельцыШтрихкодов = Новый Массив;
	ТипыСсылок = Новый Соответствие;
	ТекстыЗапросов = Новый Массив;
	
	Для Каждого СсылкаНаДокумент Из ДокументыПередачи Цикл
		
		Тип = ТипЗнч(СсылкаНаДокумент);
		
		Если ТипыСсылок[Тип] = Неопределено Тогда
			
			МетаданныеОбъекта = СсылкаНаДокумент.Метаданные();
			ЕстьШК = ЕстьШтрихкодыУпаковокИСМП(МетаданныеОбъекта);
			
			ТипыСсылок.Вставить(Тип, ЕстьШК);
			
			Если ЕстьШК Тогда
				ТекстЗапросаШК = ТекстЗапросаТаблицыУпаковокИСМП(МетаданныеОбъекта.ПолноеИмя());
				ТекстыЗапросов.Добавить(ТекстЗапросаШК);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипыСсылок[Тип] Тогда
			ВладельцыШтрихкодов.Добавить(СсылкаНаДокумент);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Неопределено;
	
	Если ЗначениеЗаполнено(ТекстыЗапросов) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = СтрСоединитьЛок(ТекстыЗапросов, РазделительОбъединенияЗапросов());
		Запрос.УстановитьПараметр("ВладельцыШтрихкодов", ВладельцыШтрихкодов);
		
		Результат = Запрос.Выполнить().Выгрузить();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТаблицаТоваровИСМП(СтрокиКонтента)
	
	Результат = Новый_ТаблицаТоваровИСМП(СтрокиКонтента);
	
	Для Каждого СтрокаКонтента Из СтрокиКонтента Цикл
		
		СлужебнаяИнформацияСтрокиКонтента = СтрокаКонтента.СлужебнаяИнформация;
		
		СтрокаТаблицыТоваров = Результат.Добавить();
		СтрокаТаблицыТоваров.Номенклатура = СлужебнаяИнформацияСтрокиКонтента.Номенклатура;
		СтрокаТаблицыТоваров.Характеристика = СлужебнаяИнформацияСтрокиКонтента.Характеристика;
		СтрокаТаблицыТоваров.Ссылка = СлужебнаяИнформацияСтрокиКонтента.ДокументОтгрузки;
		СтрокаТаблицыТоваров.Количество = СтрокаКонтента.Quantity;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция Новый_ТаблицаТоваровИСМП(СтрокиКонтента)
	
	ОписаниеТипаНоменклатура = Новый ОписаниеТипов(Справочники.ТипВсеСсылки());
	ОписаниеТипаСсылка = Новый ОписаниеТипов(Документы.ТипВсеСсылки());
	ОписаниеТипаХарактеристика = Неопределено;
	
	Если ПлатформаПоддерживаетОпределяемыеТипы() Тогда
		
		ОпределяемыеТипы = Метаданные["ОпределяемыеТипы"];
		ОпределяемыйТипХарактеристики = ОпределяемыеТипы.Найти("ХарактеристикаНоменклатуры");
		
		Если НЕ ОпределяемыйТипХарактеристики = Неопределено Тогда
			ОписаниеТипаХарактеристика = ОпределяемыйТипХарактеристики.Тип;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОписаниеТипаХарактеристика) Тогда
		ОписаниеТипаХарактеристика = Новый ОписаниеТипов(Справочники.ТипВсеСсылки());
	КонецЕсли;
	
	Если СтрокиКонтента.Количество() Тогда
		
		СлужебнаяИнформацияСтрокиКонтента = СтрокиКонтента[0].СлужебнаяИнформация;
		
		Если ЗначениеЗаполнено(СлужебнаяИнформацияСтрокиКонтента.Номенклатура) Тогда
			ОписаниеТипаНоменклатура = ОписаниеТиповЗначения(СлужебнаяИнформацияСтрокиКонтента.Номенклатура);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СлужебнаяИнформацияСтрокиКонтента.Характеристика) Тогда
			ОписаниеТипаХарактеристика = ОписаниеТиповЗначения(СлужебнаяИнформацияСтрокиКонтента.Характеристика);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СлужебнаяИнформацияСтрокиКонтента.ДокументОтгрузки) Тогда
			ОписаниеТипаСсылка = ОписаниеТиповЗначения(СлужебнаяИнформацияСтрокиКонтента.ДокументОтгрузки);
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Номенклатура", ОписаниеТипаНоменклатура);
	Результат.Колонки.Добавить("Характеристика", ОписаниеТипаХарактеристика);
	Результат.Колонки.Добавить("Ссылка", ОписаниеТипаСсылка);
	Результат.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	
	Возврат Результат;
	
КонецФункции

// Проверяет, встроена ли в конфигурацию библиотека интеграции с ИС МП.
// 
// Возвращаемое значение:
//  Булево - Истина, если подсистема есть.
//
Функция ЕстьИнтеграцияИСМП()
	
	Результат = Ложь;
	
	Если Метаданные.ОбщиеМодули.Найти("СтандартныеПодсистемыПовтИсп") <> Неопределено Тогда
		
		МодульСтандартныеПодсистемыПовтИсп = Вычислить("СтандартныеПодсистемыПовтИсп");
		
		ОписанияПодсистем = МодульСтандартныеПодсистемыПовтИсп.ОписанияПодсистем().ПоИменам;
		
		Если ОписанияПодсистем.Получить("БиблиотекаИнтеграцииИСМП") <> Неопределено Тогда
			Результат = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат = Ложь И Метаданные.ОбщиеМодули.Найти("ОбновлениеИнформационнойБазыИСМП") <> Неопределено Тогда
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, поддерживает-ли встроенная версия библиотеки интеграции с ИС МП распределение одного кода ОСУ по нескольким строкам
// 
// Возвращаемое значение:
//  Булево - Истина, если библиотека поддерживает функционал.
//
Функция ИспользуетсяИнтеграцияИСМП10127()
	
	Результат = Ложь;
	
	ВерсияПодсистемыИСМП = "";
	
	Если Метаданные.ОбщиеМодули.Найти("СтандартныеПодсистемыПовтИсп") <> Неопределено Тогда
		
		МодульСтандартныеПодсистемыПовтИсп = Вычислить("СтандартныеПодсистемыПовтИсп");
		
		ОписанияПодсистем = МодульСтандартныеПодсистемыПовтИсп.ОписанияПодсистем().ПоИменам;
		ОписаниеПодсистемыБиблиотекиИнтеграцииИСМП = ОписанияПодсистем.Получить("БиблиотекаИнтеграцииИСМП");
		
		Если НЕ ОписаниеПодсистемыБиблиотекиИнтеграцииИСМП = Неопределено Тогда
			ВерсияПодсистемыИСМП = ОписаниеПодсистемыБиблиотекиИнтеграцииИСМП.Версия;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВерсияПодсистемыИСМП) Тогда
		
		ОписаниеПодсистемы = Новый Структура;
		ОписаниеПодсистемы.Вставить("Имя", "");
		ОписаниеПодсистемы.Вставить("Версия", "");
		ОписаниеПодсистемы.Вставить("ТребуемыеПодсистемы", Новый Массив);
		
		МодульОбновлениеИнформационнойБазыИСМП = Вычислить("ОбновлениеИнформационнойБазыИСМП");
		МодульОбновлениеИнформационнойБазыИСМП.ПриДобавленииПодсистемы(ОписаниеПодсистемы);
		
		ВерсияПодсистемыИСМП = ОписаниеПодсистемы.Версия;
		
	КонецЕсли;
	
	Если СравнитьВерсии(ВерсияПодсистемыИСМП, "10.1.27") >= 0 Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, есть ли у объекта метаданных табличная часть с штрихкодами упаковок товаров.
//
// Параметры:
//  ОбъектМетаданных - ОбъектМетаданных - проверяемый объект метаданных.
// 
// Возвращаемое значение:
//  Булево - Истина, если у объекта есть табличная часть "ШтрихкодыУпаковок".
